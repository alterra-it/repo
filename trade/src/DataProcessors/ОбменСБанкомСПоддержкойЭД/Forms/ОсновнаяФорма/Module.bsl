	|	Организация,
	|	БИКБанка,
	|	НаименованиеБанка,
	|	Банк,
	|	Программа,
	|	ФайлЗагрузки,
	|	ФайлВыгрузки,
	|	Кодировка
	|
	|ИТОГИ ПО
	|	Организация,
	|	БИКБанка,
	|	Программа
	|");
	
	ВыборкаПоОрганизациям = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаПоОрганизациям.Следующий() Цикл
		
		ВыборкаПоБанкам = ВыборкаПоОрганизациям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаПоБанкам.Следующий() Цикл
			
			ВыборкаПоПрограммам = ВыборкаПоБанкам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Если ВыборкаПоПрограммам.Количество() = 1 Тогда
				
				ВыборкаПоПрограммам.Следующий();
				Выборка = ВыборкаПоПрограммам.Выбрать(ОбходРезультатаЗапроса.Прямой);
				Выборка.Следующий();
				
				НоваяСтрока = ТаблицаПрограммЗагрузки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				НоваяСтрока.Представление = Строка(Выборка.Организация)
					+ "; " + Строка(Выборка.НаименованиеБанка);
				НоваяСтрока.ПутьКФайлу = Выборка.ФайлЗагрузки;
				
				НоваяСтрока = ТаблицаПрограммВыгрузки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				НоваяСтрока.Представление = Строка(Выборка.Организация)
					+ "; " + Строка(Выборка.НаименованиеБанка);
				НоваяСтрока.ПутьКФайлу = Выборка.ФайлВыгрузки;
				
			Иначе
			
				Пока ВыборкаПоПрограммам.Следующий() Цикл
					
					Выборка = ВыборкаПоПрограммам.Выбрать(ОбходРезультатаЗапроса.Прямой);
					
					ЕстьЗаписьПрямогоОбмена = Ложь;
					Пока Выборка.Следующий() Цикл
						
						Если ЕстьЗаписьПрямогоОбмена И Выборка.ПрямойОбмен Тогда
							Продолжить;
						КонецЕсли;
						
						НоваяСтрока = ТаблицаПрограммЗагрузки.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
						НоваяСтрока.Представление = Строка(Выборка.Организация)
							+ "; " + Строка(Выборка.НаименованиеБанка)
							+ "; " + Строка(Выборка.Программа);
						НоваяСтрока.ПутьКФайлу = Выборка.ФайлЗагрузки;
						
						НоваяСтрока = ТаблицаПрограммВыгрузки.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
						НоваяСтрока.Представление = Строка(Выборка.Организация)
							+ "; " + Строка(Выборка.НаименованиеБанка)
							+ "; " + Строка(Выборка.Программа);
						НоваяСтрока.ПутьКФайлу = Выборка.ФайлВыгрузки;
						
						Если Выборка.ПрямойОбмен Тогда
							ЕстьЗаписьПрямогоОбмена = Истина;
						КонецЕсли;
						
					КонецЦикла;
					
				КонецЦикла;
			
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	МассивПрограммЗагрузки = ТаблицаПрограммЗагрузки.Выгрузить(, "Представление").ВыгрузитьКолонку("Представление");
	Элементы.ПрограммаФайлЗагрузкиПрямойОбмен.СписокВыбора.ЗагрузитьЗначения(МассивПрограммЗагрузки);
	Элементы.ПрограммаФайлЗагрузкиКлиентБанк.СписокВыбора.ЗагрузитьЗначения(МассивПрограммЗагрузки);
	
	МассивПрограммВыгрузки = ТаблицаПрограммВыгрузки.Выгрузить(, "Представление").ВыгрузитьКолонку("Представление");
	Элементы.ПрограммаФайлВыгрузкиПрямойОбмен.СписокВыбора.ЗагрузитьЗначения(МассивПрограммВыгрузки);
	Элементы.ПрограммаФайлВыгрузкиКлиентБанк.СписокВыбора.ЗагрузитьЗначения(МассивПрограммВыгрузки);
	
КонецПроцедуры

&НаСервере
Процедура УправлениеЭлементамиФормыВыгрузка()
	
	СоглашениеЗаполнено = ЗначениеЗаполнено(СоглашениеЭДВыгрузка);
	ЭтоПрямойОбмен = ПараметрыВыгрузки.ПрямойОбмен;
	
	Элементы.ДокументыНаЭкспорт.Доступность = СоглашениеЗаполнено Или Не ЭтоПрямойОбмен;
	Элементы.ПериодВыгрузкиПрямойОбмен.Доступность = СоглашениеЗаполнено Или Не ЭтоПрямойОбмен;
	Элементы.ДокументыНаЭкспортСформироватьПодписатьОтправитьЭД.Видимость = ЭтоПрямойОбмен;
	Элементы.ДокументыНаЭкспортСостояниеЭД.Видимость = ЭтоПрямойОбмен;
	Элементы.ДокументыНаЭкспортВыгрузить.Видимость = Не ЭтоПрямойОбмен;
	Элементы.ДокументыНаЭкспортОтчетОВыгрузке.Видимость = Не ЭтоПрямойОбмен;
	Элементы.ВыгружатьКПП.Видимость = Не ЭтоПрямойОбмен;
КонецПроцедуры

&НаСервере
Процедура УправлениеЭлементамиФормыЗагрузка()
	
	СоглашениеЗаполнено = ЗначениеЗаполнено(СоглашениеЭДЗагрузка);
	ЭтоНеПрямойОбмен = НЕ ПараметрыЗагрузки.ПрямойОбмен;
	ДоступностьДокументов = СоглашениеЗаполнено Или ЭтоНеПрямойОбмен;
	Элементы.ДокументыКИмпорту.Доступность = ДоступностьДокументов;
	Элементы.ПериодЗагрузкиПрямойОбмен.Доступность = СоглашениеЗаполнено;
	Элементы.ЗапроситьВыписку.Доступность = СоглашениеЗаполнено;
	Элементы.ДокументыКИмпортуПрочитатьДанныеИзФайла.Видимость = ЭтоНеПрямойОбмен;
	Элементы.ДокументыКИмпортуСформироватьОтчетОЗагрузке.Видимость = ЭтоНеПрямойОбмен;
	Элементы.СтраницыСоглашенияЭДЗагрузка.Видимость = НЕ ЭтоНеПрямойОбмен;
КонецПроцедуры

&НаКлиенте
Процедура СообщитьОбОтсутствииСоглашенияЭД()
	
	ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru='Отсутствует действующее соглашение об обмене электронными документами между банком %1 и организацией %2.
			|Настройка соглашений осуществляется в разделе ""Нормативно-справочная информация"", ""Настройки и справочники"", ""Соглашения об использовании электронных документов"".'"),
		ПараметрыВыгрузки.Банк,
		ПараметрыВыгрузки.Организация);
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		ТекстСообщения);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтруктураПараметровВыгрузкиЗагрузки()
	
	СтруктураПараметровВыгрузкиЗагрузки = Новый Структура;
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("Представление", "");
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("Организация", Неопределено);
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("Банк", Неопределено);
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("БИКБанка", "");
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("ПрямойОбмен", Ложь);
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("Программа", "");
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("ПутьКФайлу", "");
	СтруктураПараметровВыгрузкиЗагрузки.Вставить("Кодировка", "");
	Возврат СтруктураПараметровВыгрузкиЗагрузки;
КонецФункции

&НаКлиенте
Процедура ОткрытьФайлДляПросмотра(ПараметрыОбмена, Заголовок)
	
	Текст = Новый ТекстовыйДокумент;
	Если ПараметрыОбмена.Кодировка = "DOS" Тогда
		Кодир = КодировкаТекста.OEM;
	Иначе
		Кодир = КодировкаТекста.ANSI;
	КонецЕсли;
	
	Попытка
		Текст.Прочитать(ПараметрыОбмена.ПутьКФайлу, Кодир);
		Текст.Показать(Заголовок, ПараметрыОбмена.ПутьКФайлу);
	Исключение
		ПоказатьПредупреждение(Неопределено, НСтр("ru='Не найден файл!'"));
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьЭД(ЭД)
	
	Перем ДеревоРазбора;
	
	ОбменСБанками.ПолучитьДанныеВыпискиБанкаДеревоЗначений(ЭД, ДеревоРазбора);
	ХранилищеДереваРазбора = Новый ХранилищеЗначения(ДеревоРазбора);
	ЗаполнитьДокументыНаИмпорт(ДеревоРазбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСоглашениеЭД(Организация, Банк)
	
	ПараметрыОснования = Новый Структура("Организация, Контрагент, СпособОбменаЭД",
		Организация,
		Банк,
		ПредопределенноеЗначение("Перечисление.СпособыОбменаЭД.УдалитьЧерезВебРесурсБанка"));
	
	ОткрытьФорму("Справочник.НастройкиОбменСБанками.Форма.ФормаЭлемента",
		Новый Структура("Основание", ПараметрыОснования),
		ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСостояниеЭД()
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	СостоянияЭД.СсылкаНаОбъект КАК Ссылка,
	|	СостоянияЭД.СостояниеВерсииЭД КАК СостояниеЭД
	|ИЗ
	|	РегистрСведений.СостоянияЭД КАК СостоянияЭД
	|ГДЕ
	|	СостоянияЭД.СсылкаНаОбъект В(&МассивОбъектов)");
	Запрос.УстановитьПараметр("МассивОбъектов",
		Объект.ПлатежныеДокументы.Выгрузить(,"Документ").ВыгрузитьКолонку("Документ"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Строки = Объект.ПлатежныеДокументы.НайтиСтроки(Новый Структура("Документ", Выборка.Ссылка));
		Для Каждого СтрокаТЧ Из Строки Цикл
			СтрокаТЧ.СостояниеЭД = Выборка.СостояниеЭД;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСоглашениеЭД(СоглашениеЭД, СтатусСоглашенияЭД, Знач ПараметрыОбмена)
	
	СоглашениеЭД = Неопределено;
	СтатусСоглашенияЭД = Неопределено;
	
	Если ЗначениеЗаполнено(ПараметрыОбмена.Организация) И ЗначениеЗаполнено(ПараметрыОбмена.Банк)
		И ПравоДоступа("Чтение", Метаданные.Справочники.СоглашенияОбИспользованииЭД) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Соглашения.Ссылка КАК СоглашениеЭД,
		|	Соглашения.СтатусСоглашения
		|ИЗ
		|	Справочник.СоглашенияОбИспользованииЭД КАК Соглашения
		|ГДЕ
		|	Соглашения.Организация = &Организация
		|	И Соглашения.Контрагент = &Банк
		|	И Соглашения.СпособОбменаЭД = ЗНАЧЕНИЕ(Перечисление.СпособыОбменаЭД.УдалитьЧерезВебРесурсБанка)";
		
		Запрос.УстановитьПараметр("Организация", ПараметрыОбмена.Организация);
		Запрос.УстановитьПараметр("Банк", ПараметрыОбмена.Банк);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			СоглашениеЭД = Выборка.СоглашениеЭД;
			СтатусСоглашенияЭД = Выборка.СтатусСоглашения;
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьСтраницуСоглашенийЭД()
	
	Если Элементы.Страницы.ТекущаяСтраница = Элементы.ВыгрузкаДокументов Тогда
		Если ПараметрыВыгрузки.ПрямойОбмен Тогда
			Элементы.ГруппаПараметрыВыгрузки.ТекущаяСтраница = Элементы.СтраницаПараметрыВыгрузкиПрямойОбмен;
			
			Если ЗначениеЗаполнено(СоглашениеЭДВыгрузка) Тогда
				Элементы.ГруппаДействияССоглашениемЭДВыгрузка.ТекущаяСтраница = Элементы.СтраницаЕстьСоглашениеЭДВыгрузка;
				Элементы.ДекорацияСоглашениеЭДВыгрузка.Заголовок = 
					СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru='%1, (%2)'"), СоглашениеЭДВыгрузка, СтатусСоглашенияЭДВыгрузка);
			ИначеЕсли ЕстьПравоДобавленияСоглашенийЭД Тогда
				Элементы.ГруппаДействияССоглашениемЭДВыгрузка.ТекущаяСтраница = Элементы.СтраницаНетСоглашенияЭДДобавлениеВыгрузка;
			Иначе
				Элементы.ГруппаДействияССоглашениемЭДВыгрузка.ТекущаяСтраница = Элементы.СтраницаНетСоглашенияЭДНетПравВыгрузка;
			КонецЕсли;
		Иначе
			Элементы.ГруппаПараметрыВыгрузки.ТекущаяСтраница = Элементы.СтраницаПараметрыВыгрузкиКлиентБанк;
		КонецЕсли;
	Иначе
		Если ПараметрыЗагрузки.ПрямойОбмен Тогда
			Элементы.ГруппаПараметрыЗагрузки.ТекущаяСтраница = Элементы.СтраницаПараметрыЗагрузкиПрямойОбмен;
			Если ЗначениеЗаполнено(СоглашениеЭДЗагрузка) Тогда
				Элементы.СтраницыСоглашенияЭДЗагрузка.ТекущаяСтраница = Элементы.ЕстьОдноСоглашениеЭДЗагрузка;
				Элементы.ДекорацияСоглашениеЭДЗагрузка.Заголовок = 
					СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru='%1, (%2)'"), СоглашениеЭДЗагрузка, СтатусСоглашенияЭДЗагрузка);
			ИначеЕсли ЕстьПравоДобавленияСоглашенийЭД Тогда
				Элементы.СтраницыСоглашенияЭДЗагрузка.ТекущаяСтраница = Элементы.НетСоглашенийЭДДобавлениеЗагрузка;
			Иначе
				Элементы.СтраницыСоглашенияЭДЗагрузка.ТекущаяСтраница = Элементы.НетСоглашенияЭДНетПравЗагрузка;
			КонецЕсли;
		Иначе
			Элементы.ГруппаПараметрыЗагрузки.ТекущаяСтраница = Элементы.СтраницаПараметрыЗагрузкиКлиентБанк;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбработкаОповещенияСервер()
	
	ПриИзмененииПараметровВыгрузкиЗагрузкиСервер(ПараметрыВыгрузки, СоглашениеЭДВыгрузка, СтатусСоглашенияЭДВыгрузка);
	ПриИзмененииПараметровВыгрузкиЗагрузкиСервер(ПараметрыЗагрузки, СоглашениеЭДЗагрузка, СтатусСоглашенияЭДЗагрузка);
	
КонецПроцедуры
	
&НаСервере
Процедура ОбновитьИнформациюПоСоглашениямЭД(Результат, ДополнительныеПараметры)
	
	ОбработкаОповещенияСервер();
КонецПроцедуры

&НаКлиенте
Процедура СформироватьПодписатьОтправитьЭДПродолжение(Результат, МассивДокументов) Экспорт
	
	Если ЗначениеЗаполнено(МассивДокументов) Тогда
		ОбменСБанкамиКлиент.СформироватьПодписатьОтправитьЭД(МассивДокументов);
	КонецЕсли;
	
	ОбновитьСостояниеЭД();

КонецПроцедуры

#КонецОбласти

#КонецОбласти
