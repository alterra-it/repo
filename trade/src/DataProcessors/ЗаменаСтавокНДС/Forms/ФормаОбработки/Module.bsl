	ПараметрыФормы.Вставить("СтавкаНДС", СтавкаНДС);
	ПараметрыФормы.Вставить("Период",    Период);
	
	ОткрытьФорму("РегистрСведений.СтавкиНДСНоменклатуры.Форма.РабочееМесто", ПараметрыФормы);
	
