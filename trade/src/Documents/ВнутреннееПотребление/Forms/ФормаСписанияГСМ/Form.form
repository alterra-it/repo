    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДвижениеТопливаОстатки.Топливо,
	ДвижениеТопливаОстатки.Склад,
	ДокументПутевойЛист.РасходФактический КАК Количество,
	ДокументПутевойЛист.Ссылка КАК Ссылка
ИЗ
	РегистрНакопления.ДвижениеТоплива.Остатки(
			,
			Склад = &amp;Склад
				ИЛИ &amp;Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)) КАК ДвижениеТопливаОстатки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПутевойЛист КАК ДокументПутевойЛист
		ПО ДвижениеТопливаОстатки.ПутевойЛист = ДокументПутевойЛист.Ссылка</queryText>
      <mainTable>Document.ПутевойЛист</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
