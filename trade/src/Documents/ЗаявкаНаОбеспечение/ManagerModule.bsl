Функция ТаблицаТоваровДляЗаказа(Заявка)экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаОбеспечениеТовары.Номенклатура КАК Номенклатура,
		|	ЗаявкаНаОбеспечениеТовары.КЗаказу КАК Количество,
		|	ЗаявкаНаОбеспечениеТовары.Упаковка КАК Упаковка,
		|	ЗаявкаНаОбеспечениеТовары.КЗаказу КАК КоличествоУпаковок,
		|	ЗаявкаНаОбеспечениеТовары.Ссылка.Склад КАК Склад
		|ИЗ
		|	Документ.ЗаявкаНаОбеспечение.Товары КАК ЗаявкаНаОбеспечениеТовары
		|ГДЕ
		|	ЗаявкаНаОбеспечениеТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Заявка);
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции // ТаблицаТоваровДляЗаказа()
	
Функция РеквизитыДокументаЗаказа(Заявка) экспорт

	      	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаОбеспечение.Партнер КАК Партнер,
		|	ЗаявкаНаОбеспечение.Контрагент КАК Контрагент,
		|	ЗаявкаНаОбеспечение.Соглашение КАК Соглашение,
		|	ЗаявкаНаОбеспечение.Договор КАК Договор,
		|	&Ссылка КАК ДокументОснование
		|ИЗ
		|	Документ.ЗаявкаНаОбеспечение КАК ЗаявкаНаОбеспечение
		|ГДЕ
		|	ЗаявкаНаОбеспечение.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Заявка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если  ВыборкаДетальныеЗаписи.Следующий() тогда
		
		   возврат ВыборкаДетальныеЗаписи;
	Конецесли;
	
    Возврат Новый Структура();

КонецФункции // РеквизитыДокументаЗаказа()
	
	
#КонецЕсли
