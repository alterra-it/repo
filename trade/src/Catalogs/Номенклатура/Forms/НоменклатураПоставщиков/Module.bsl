
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Номенклатура") Тогда 
		Номенклатура = Параметры.Номенклатура; 
	КонецЕсли;      
	
	ПерезаполнитьСписки();
КонецПроцедуры

&НаКлиенте
Процедура ПоставщикиПарсингПриИзменении(Элемент)
	Элементы.Источник.Видимость = ПоставщикиПарсинг = 1; 
	Источник = ПредопределенноеЗначение("Перечисление.РегистрацияЦенНоменклатурыПоставщикаИсточник.ПустаяСсылка");
	ПерезаполнитьСписки();
КонецПроцедуры      

&НаКлиенте
Процедура ИсточникПриИзменении(Элемент)
	ПерезаполнитьСписок();
КонецПроцедуры 

&НаСервере
Процедура ПерезаполнитьСписки()
	ПерезаполнитьСписок();
	ПерезаполнитьСписок2();
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьСписок()  
	
		Список.ТекстЗапроса =
			"ВЫБРАТЬ
			|	ЦеныНоменклатурыПоставщиковСрезПоследних.Партнер КАК Партнер,
			|	ЦеныНоменклатурыПоставщиковСрезПоследних.Номенклатура КАК Номенклатура,
			|	ЦеныНоменклатурыПоставщиковСрезПоследних.Цена КАК Цена,
			|	ЦеныНоменклатурыПоставщиковСрезПоследних.Регистратор КАК Регистратор,
			|	ВЫБОР
			|		КОГДА ЦеныНоменклатурыПоставщиковСрезПоследних.Регистратор ССЫЛКА Документ.РегистрацияЦенНоменклатурыПоставщика
			|			ТОГДА ЦеныНоменклатурыПоставщиковСрезПоследних.Регистратор.Источник
			|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.РегистрацияЦенНоменклатурыПоставщикаИсточник.ПустаяСсылка)
			|	КОНЕЦ КАК Источник
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатурыПоставщиков.СрезПоследних КАК ЦеныНоменклатурыПоставщиковСрезПоследних
			|ГДЕ
			|	ЦеныНоменклатурыПоставщиковСрезПоследних.Номенклатура = &Номенклатура
			|	И ЦеныНоменклатурыПоставщиковСрезПоследних.Партнер.Парсинг = &ПоставщикиПарсинг";
	
	Если ЗначениеЗаполнено(Источник) Тогда
		Список.ТекстЗапроса = Список.ТекстЗапроса +
			"	И ВЫБОР
			|			КОГДА ЦеныНоменклатурыПоставщиковСрезПоследних.Регистратор ССЫЛКА Документ.РегистрацияЦенНоменклатурыПоставщика
			|				ТОГДА ЦеныНоменклатурыПоставщиковСрезПоследних.Регистратор.Источник
			|			ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.РегистрацияЦенНоменклатурыПоставщикаИсточник.ПустаяСсылка)
			|		КОНЕЦ = &Источник";
		
		Список.Параметры.УстановитьЗначениеПараметра("Источник", Источник);

	КонецЕсли;
	
	Список.Параметры.УстановитьЗначениеПараметра("Номенклатура", Номенклатура);
	Список.Параметры.УстановитьЗначениеПараметра("ПоставщикиПарсинг", ?(ПоставщикиПарсинг = 1, Истина, Ложь));

КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьСписок2()           
	
	Список2.ТекстЗапроса =
		"ВЫБРАТЬ
		|	НоменклатураПоставщиков.Ссылка КАК НоменклатураПоставщика,
		|	НоменклатураПоставщиков.Владелец КАК Поставщик,
		|	НоменклатураПоставщиков.Владелец.Парсинг КАК Парсинг,
		|	НоменклатураПоставщиков.Номенклатура КАК Номенклатура
		|ИЗ
		|	Справочник.НоменклатураКонтрагентов КАК НоменклатураПоставщиков
		|ГДЕ
		|	НоменклатураПоставщиков.Номенклатура = &Номенклатура
		|	И НоменклатураПоставщиков.Владелец.Парсинг = &ПоставщикиПарсинг";
	
	Список2.Параметры.УстановитьЗначениеПараметра("Номенклатура", Номенклатура);
	Список2.Параметры.УстановитьЗначениеПараметра("ПоставщикиПарсинг", ?(ПоставщикиПарсинг = 1, Истина, Ложь));

КонецПроцедуры           













