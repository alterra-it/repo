
//выглядит странно, но зато тут нет ни попытки-исключения (=безопасно для транзакций), 
//	ни регулярных выражений (не тратим ресурсы на COMобъект). И работает более-менее быстро
Функция ВернутьНормированныйНомер(знач номерСтрокой, разделитель = ".")
	//маленькая оптимизация. сразу вернем известные значения
	Если  номерСтрокой = "8.2.14.0" тогда
		возврат 8000200140000
	ИначеЕсли  номерСтрокой = "8.3.7.0" тогда
		возврат 8000300070000
	КонецЕсли;
	
	номерСтрокой = сокрЛП(номерСтрокой);
	Если СтрДлина(номерСтрокой) > 12 тогда
		возврат 0; //слишком много, скорее всего это не то, что нам нужно
	КонецЕсли;
	
	рез = 0; секция = 0;
	для сч = 1 по СтрДлина(номерстрокой) цикл
		смв = сред(номерстрокой,сч,1);
		Если смв = разделитель тогда
			рез = рез*10000 + секция; 
			секция = 0;
		ИначеЕсли (смв >="0" и смв <= "9") тогда
			секция = секция*10+число(смв)
			
		Иначе //это не цифра и не разделитель -- значит, это не номер,который нам нужен
			возврат 0;
		КонецЕсли;
	КонецЦикла;	
	
	рез = рез*10000 + секция;
	
	возврат рез;
КонецФункции	
 
Функция ПолучитьФайлКомпоненты(знач ПутьККомпонентеМаркера)
	
	Если ПараметрыСеанса.сфп_ПутьККомпонентеМаркеров <> "" тогда
		возврат ПараметрыСеанса.сфп_ПутьККомпонентеМаркеров;
	КонецЕсли;
	
	
	префикс = нрег( "SPMRKAddInNative_");
	//длинаПрефикса = СтрДлина(префикс);
	
	//определимся, какую архитектуру ищем и вообще, где находимся
	инфо = новый СистемнаяИнформация;
	
	Если инфо.ТипПлатформы = ТипПлатформы.Windows_x86_64 тогда
		Это64x = истина;
		этоWindows = истина;
		
	ИначеЕсли инфо.ТипПлатформы = ТипПлатформы.Windows_x86 тогда
		Это64x = ложь;
		этоWindows = истина;
		
	ИначеЕсли найти(строка(инфо.ТипПлатформы), "_x86_64") тогда
		//Архитектуры добавлялись постепенно, старые платформы могут не знать про х64 линукс и макос.
		//попытку-иключение для такой проверки использовать нельзя, можем потенциальную транзакцию порушить
		//Поэтому проверяем строковое представление
		
		Это64x = истина;
		этоWindows = ложь;
		
	Иначе
		Это64x = ложь;
		этоWindows = ложь;
	КонецЕсли;	
		
	//проверим, указали ли конечный (бэк)слеш
	разделитель = ?(этоWindows, "\","/");
	ПутьККомпонентеМаркера = сокрлп(ПутьККомпонентеМаркера);
	Если прав(ПутьККомпонентеМаркера,1) <> разделитель тогда
		ПутьККомпонентеМаркера=  ПутьККомпонентеМаркера + разделитель;
	КонецЕсли;	
	
	                                                                
	//пробежимся по подпапкам.
	//выберем папку с наибольшим номеров в названии
	//но только такую, в которой есть нужная нам компонента
	ПоследняяВерсия = 0;
	ПутьКВерсии = "";
	
	папки = НайтиФайлы(ПутьККомпонентеМаркера,"*.*",ложь);
	для каждого папка из папки цикл
		Если папка.ЭтоФайл() тогда
			продолжить;
		КонецЕсли;
		
		текущаяВерсия = ВернутьНормированныйНомер(папка.имя);
		Если текущаяВерсия > ПоследняяВерсия тогда
			//нашли более позднюю версию. проверим, есть ли там нужная компонента
			
			файлы = НайтиФайлы(папка.ПолноеИмя, префикс+"*.dll", ложь);
			
			полныйПутьККомпоненте = "";
			
			для каждого ф из файлы цикл
				имяФайла =  нрег( ф.ИмяБезРасширения);
				//Если лев(имяФайла, длинаПрефикса) = префикс тогда
				Если (Это64x и прав(имяФайла, 4) = "_x64")
					или (Это64x = ложь и прав(имяФайла, 4) <> "_x64") тогда
					
					полныйПутьККомпоненте = ф.ПолноеИмя;
					прервать;
				КонецЕсли;
				//КонецЕсли;	
			КонецЦикла;	
			//нашли компоненту в папке. Обновим значения-"лидеры"
			Если не ПустаяСтрока(полныйПутьККомпоненте) тогда
				ПоследняяВерсия = текущаяВерсия;
				ПутьКВерсии = полныйПутьККомпоненте;
			КонецЕсли;	
			
		КонецЕсли;	
	КонецЦикла;
	
	
	//запомним найденное значение чтобы позже в течение сеанса не искать файл заново.
	ПараметрыСеанса.сфп_ПутьККомпонентеМаркеров = ПутьКВерсии;
	
	возврат ПутьКВерсии;
КонецФункции

Функция ЗагрузитьКомпонентуМаркера(рез) Экспорт
	ВКМаркеров = неопределено;
	
	результатПрошлойЗагрузки = ПараметрыСеанса.сфп_МаркерЗагруженУспешно;
	Если результатПрошлойЗагрузки = -1 тогда //то есть раньше в этом сеансе уже не удалось загрузить маркеры
		
		рез = ""; //флаг кэшированной проверки взвели до нас, значит и поругаться на ошибку уже успели. 
			      //не будем спамить пользователя лишний раз, вернем пустую ошибку
		
		возврат ВКМаркеров;
	КонецЕсли;	
	
	инфо = новый СистемнаяИнформация;
	Версия1С =  инфо.ВерсияПриложения;
	нормированнаяВерсия = ВернутьНормированныйНомер(версия1с);
	
	совместимость = метаданные.РежимСовместимости; 		
	
	запрос = новый запрос;
	
	Если совместимость=Метаданные.СвойстваОбъектов.РежимСовместимости.Версия8_2_13 
		или совместимость=Метаданные.СвойстваОбъектов.РежимСовместимости.Версия8_1 
		или нормированнаяВерсия <  ВернутьНормированныйНомер ("8.2.14.0") тогда
		
		//запрос для старой модели констант
		запрос.Текст = "ВЫБРАТЬ
		               |	Константа.СФП_ПутьККомпонентеМаркера,
		               |	Константа.СФП_ИмяSQLСервера,
		               |	Константа.СФП_ИмяБД,
		               |	Константа.СФП_СерверССервисомИнтеграции
		               |ИЗ
		               |	Константы КАК Константа";
		
	Иначе
		запрос.Текст = "ВЫБРАТЬ
		               |	СФП_ПутьККомпонентеМаркера_.Значение КАК СФП_ПутьККомпонентеМаркера,
		               |	СФП_ИмяSQLСервера_.Значение КАК СФП_ИмяSQLСервера,
		               |	СФП_ИмяБД_.Значение КАК СФП_ИмяБД,
		               |	СФП_СерверССервисомИнтеграции_.Значение КАК СФП_СерверССервисомИнтеграции
		               |ИЗ
		               |	Константа.СФП_ПутьККомпонентеМаркера КАК СФП_ПутьККомпонентеМаркера_,
		               |	Константа.СФП_ИмяSQLСервера КАК СФП_ИмяSQLСервера_,
		               |	Константа.СФП_ИмяБД КАК СФП_ИмяБД_,
		               |	Константа.СФП_СерверССервисомИнтеграции КАК СФП_СерверССервисомИнтеграции_ ";
	КонецЕсли;
		
	
	данныеМаркеров = запрос.Выполнить().Выбрать();
	данныеМаркеров.Следующий();
	
	ПутьККомпонентеМаркера    = данныеМаркеров.СФП_ПутьККомпонентеМаркера;
	ИмяSQLСервера 		      = данныеМаркеров.СФП_ИмяSQLСервера;
	ИмяБД					  = данныеМаркеров.СФП_ИмяБД;
	СерверССервисомИнтеграции = данныеМаркеров.СФП_СерверССервисомИнтеграции;
	
	Если нормированнаяВерсия > ВернутьНормированныйНомер ("8.3.7.0")	тогда
		ИмяТекущегоКомпьютера = вычислить("ПолучитьТекущийСеансИнформационнойБазы().ИмяКомпьютера"); //"вычислить" чтобы не поломались старые платформы
	Иначе 
		//в более старых версиях платформы нет способа определить имя компьютера без риска подвиснуть на несколько секунд
		ИмяТекущегоКомпьютера = "";
	КонецЕсли;	
	
	Если Не(ЗначениеЗаполнено(ПутьККомпонентеМаркера) 
			И ЗначениеЗаполнено(ИмяSQLСервера) 
			И ЗначениеЗаполнено(ИмяБД) 
			И ЗначениеЗаполнено(СерверССервисомИнтеграции)) тогда
		
		рез = "Ошибка подключения внешней компоненты: не заполнены параметры сервиса интеграции СофтПоинт.";
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;
		Возврат ВКМаркеров;
	КонецЕсли;
	
	//ПолныйПутьККомпоненте = ПутьККомпонентеМаркера + "SPMRKAddInNative_4_x64.dll"; ;// 
	ПолныйПутьККомпоненте = ПолучитьФайлКомпоненты(ПутьККомпонентеМаркера);
	
	Если ПустаяСтрока(ПолныйПутьККомпоненте) тогда
		рез = "Не удалось найти файл компоненты маркеров. Возможно, недостаточно прав";
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;
		возврат ВКМаркеров;
	КонецЕсли;	
	
	//файл найден, можно инициализировать
	Попытка
		//а тут уже никуда от попытки не денешься. Без нее можно и сеанс оборвать
		Если ПодключитьВнешнююКомпоненту(ПолныйПутьККомпоненте, "КомпонентаМаркеров", ТипВнешнейКомпоненты.Native) Тогда
			ВКМаркеров = Новый("AddIn.КомпонентаМаркеров.SpMrkExt_4");
			
			портСервисаИнтеграции = 12900;
			Если НЕ ВКМаркеров.Initialize(ИмяSQLСервера, ИмяБД, ИмяПользователя(), СерверССервисомИнтеграции, портСервисаИнтеграции, ИмяТекущегоКомпьютера) Тогда
				рез = "Ошибка инициализации компоненты мониторинга: " + ВКМаркеров.GetLastError();
				
				ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;	
				возврат ВКМаркеров;
			КонецЕсли;
		Иначе
			рез = "Ошибка подключения внешней компоненты";
			ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;
			возврат ВКМаркеров;
  		КонецЕсли;
    Исключение
    	рез = "Ошибка 1С при загрузке компоненты маркеров: " + ОписаниеОшибки();
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;
		возврат ВКМаркеров;
	КонецПопытки;
	
	Если результатПрошлойЗагрузки <> 1 тогда
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = 1;
	КонецЕсли;	
	
	Возврат ВКМаркеров;
КонецФункции


Функция ЭтоТестовыйСервер() экспорт
	имяТестовойБазы = "<имя тестовой базы>";
	
 	возврат найти(СтрокаСоединенияИнформационнойБазы(), имяТестовойБазы) >0;
	
КонецФункции




