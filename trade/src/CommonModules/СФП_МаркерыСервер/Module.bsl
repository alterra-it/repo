
Процедура СообщитьОбОшибке(сообщение)
	Сообщить(сообщение, СтатусСообщения.Информация);
	
	ЗаписьЖурналаРегистрации("Сфп_Маркеры", УровеньЖурналаРегистрации.Информация, ,, сообщение, РежимТранзакцииЗаписиЖурналаРегистрации.Независимая);
	
	
КонецПроцедуры	

Процедура МаркерИнициализация() Экспорт
	рез = "";
	ВкМаркеров = СФП_МаркерыСерверПовторно.ЗагрузитьКомпонентуМаркера(рез);
	
	Если ВкМаркеров = неопределено Тогда
		Если не ПустаяСтрока(рез) тогда
			СообщитьОбОшибке("МаркерИнициализация: ошибка загрузки компоненты маркеров. " + рез);
		КонецЕсли;	
		возврат;
	КонецЕсли;
	
КонецПроцедуры

Процедура МаркерНачало(ИмяМаркера, ДопИнфо = "", этоМаркерСАвтозавершением = ложь) Экспорт
	Если ПараметрыСеанса.сфп_ИспользоватьМаркеры <> истина тогда
		возврат;
	КонецЕсли;	
	
	рез = "";
	_ДопИнфо = "" + ДопИнфо; //приведем к строке
	_ДопИнфо = лев(сокрЛП(_ДопИнфо), 255); //удостоверимся, что ДопИнфо поместится в базу
	
	ВкМаркеров = СФП_МаркерыСерверПовторно.ЗагрузитьКомпонентуМаркера(рез);
	
	Если ВкМаркеров = неопределено Тогда
		Если не ПустаяСтрока(рез) тогда
			СообщитьОбОшибке("МаркерИнициализация: ошибка загрузки компоненты маркеров. " + рез);
			
			ОбновитьПовторноИспользуемыеЗначения(); //чтобы неудачный вызов маркеров  и неудачное сообщение об ошибке не закэшировалось. 
													//следующим вызовом вернется пустой ответ, пустое сообщение об ошибке и его уже можно кэшировать
			
		КонецЕсли;
		возврат;
	КонецЕсли;
	
	префикс = "";
	//Если СФП_МаркерыСерверПовторно.ЭтоТестовыйСервер() тогда
	//	префикс = "Тест_" ;
	//КонецЕсли;
	
	ключиВызоваМаркеров = ПолучитьСписокАктивныхМаркеров();
	
	_ключ = новый УникальныйИдентификатор;
	ключ = строка(_ключ);
	Если этоМаркерСАвтозавершением тогда
		ключиВызоваМаркеров .Вставить("МаркерСАвтозавершением", ключ);
	Иначе
		ключиВызоваМаркеров .Вставить(ИмяМаркера, ключ);
	КонецЕсли;
	
	ОбновитьСписокАктивныхМаркеров(ключиВызоваМаркеров);
	
	попытка
		Если ВкМаркеров.BeginMark(префикс + ИмяМаркера, _ДопИнфо, НомерСеансаИнформационнойБазы(), ключ)  <> true Тогда
			СообщитьОбОшибке("Ошибка в BeginMark: " + ВкМаркеров.GetLastError());
		КонецЕсли;
	исключение
		СообщитьОбОшибке("Ошибка в BeginMark: " +ОписаниеОшибки());
		
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;
		ОбновитьПовторноИспользуемыеЗначения();
	КонецПопытки;
	
КонецПроцедуры

Процедура МаркерКонец(ИмяМаркера="", этоМаркерСАвтозавершением = ложь) Экспорт
	рез = "";
	
	Если ПараметрыСеанса.сфп_ИспользоватьМаркеры <> истина тогда
		возврат;
	КонецЕсли;	
	
	ВкМаркеров = СФП_МаркерыСерверПовторно.ЗагрузитьКомпонентуМаркера(рез);
	
	Если ВкМаркеров = неопределено Тогда
		Если не ПустаяСтрока(рез) тогда
			СообщитьОбОшибке("МаркерИнициализация: ошибка загрузки компоненты маркеров. " + рез);
		КонецЕсли;
		возврат;
	КонецЕсли;

	
	списокМаркеров = ПолучитьСписокАктивныхМаркеров();
	имяМаркераДляПоиска = ?(этоМаркерСАвтозавершением, "МаркерСАвтозавершением", ИмяМаркера);
	ключМаркера = списокМаркеров .получить(имяМаркераДляПоиска );
	
	
	Если ключМаркера <> Неопределено тогда
		списокМаркеров.удалить(имяМаркераДляПоиска );
		ОбновитьСписокАктивныхМаркеров(списокМаркеров);
	Иначе
		ключМаркера= "";
	КонецЕсли;
	
	попытка
		ответ  =  ВкМаркеров.EndMark(ИмяМаркера, 0, ключМаркера) ;
		Если ответ   <> true Тогда
			СообщитьОбОшибке( "Ошибка в EndMark: " + ВкМаркеров.GetLastError() );
		КонецЕсли;
	исключение
		Сообщить("Ошибка в EndMark: " +ОписаниеОшибки());
		
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = -1;
		ОбновитьПовторноИспользуемыеЗначения();
	КонецПопытки;
	
КонецПроцедуры


Процедура УстановитьЗначенияПараметровСеанса(параметры) экспорт
	если параметры = Неопределено тогда возврат; КонецЕсли;
				 
					  
	
	Если параметры.найти("сфп_МаркерЗагруженУспешно") <> Неопределено тогда
		ПараметрыСеанса.сфп_МаркерЗагруженУспешно = 0;
	КонецЕсли;
	Если параметры.найти("сфп_ИспользоватьМаркеры") <> Неопределено тогда
		ПараметрыСеанса.сфп_ИспользоватьМаркеры = Константы.сфп_использоватьМаркеры.Получить();
	КонецЕсли;
	Если параметры.найти("сфп_ПутьККомпонентеМаркеров") <> Неопределено тогда
		ПараметрыСеанса.сфп_ПутьККомпонентеМаркеров = "";
	КонецЕсли;

	Если параметры.найти("сфп_АктивныеМаркеры") <> Неопределено тогда
		с = новый Соответствие;
		ПараметрыСеанса.сфп_АктивныеМаркеры = новый ХранилищеЗначения(с );
	КонецЕсли;

	
КонецПроцедуры	

Функция ПолучитьСписокАктивныхМаркеров() 
	
	с = ПараметрыСеанса.сфп_АктивныеМаркеры.Получить();
	Если с = неопределено тогда
		с = новый Соответствие;
		ПараметрыСеанса.сфп_АктивныеМаркеры = новый ХранилищеЗначения(с);
	КонецЕсли;
	
	возврат с;
КонецФункции

Функция ОбновитьСписокАктивныхМаркеров(новыйСписок) 
		
	
	ПараметрыСеанса.сфп_АктивныеМаркеры = новый ХранилищеЗначения(новыйСписок);
	
КонецФункции