Процедура ДополнитьЗаписиРегистраПоВидуНоменклатуры(ВидНоменклатуры) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СопутствующиеВидыНоменклатуры.Ссылка КАК Ссылка,
	|	СопутствующиеВидыНоменклатуры.Владелец КАК Владелец
	|ПОМЕСТИТЬ ВТ_ВидыНоменклатуры
	|ИЗ
	|	Справочник.СопутствующиеВидыНоменклатуры КАК СопутствующиеВидыНоменклатуры
	|ГДЕ
	|	НЕ СопутствующиеВидыНоменклатуры.ПометкаУдаления
	|	И СопутствующиеВидыНоменклатуры.Владелец = &ВидНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СортировкаСопутствующихВидовНоменклатуры.СопутствующийВидНоменклатуры КАК СопутствующийВидНоменклатуры,
	|	СортировкаСопутствующихВидовНоменклатуры.ВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ ВТ_СортировкаСопутствующихВидов
	|ИЗ
	|	РегистрСведений.СортировкаСопутствующихВидовНоменклатуры КАК СортировкаСопутствующихВидовНоменклатуры
	|ГДЕ
	|	СортировкаСопутствующихВидовНоменклатуры.ВидНоменклатуры = &ВидНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ВидыНоменклатуры.Ссылка КАК СопутствующийВидНоменклатуры,
	|	ВТ_ВидыНоменклатуры.Владелец КАК ВидНоменклатуры
	|ИЗ
	|	ВТ_ВидыНоменклатуры КАК ВТ_ВидыНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СортировкаСопутствующихВидов КАК ВТ_СортировкаСопутствующихВидов
	|		ПО ВТ_ВидыНоменклатуры.Ссылка = ВТ_СортировкаСопутствующихВидов.СопутствующийВидНоменклатуры
	|ГДЕ
	|	ВТ_СортировкаСопутствующихВидов.СопутствующийВидНоменклатуры ЕСТЬ NULL";

	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры); 

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Набор = РегистрыСведений.СортировкаСопутствующихВидовНоменклатуры.СоздатьНаборЗаписей(); 
	
	Пока Выборка.Следующий() Цикл
		НоваяЗапись = Набор.Добавить();
		НоваяЗапись.ВидНоменклатуры = Выборка.ВидНоменклатуры;
		НоваяЗапись.СопутствующийВидНоменклатуры = Выборка.СопутствующийВидНоменклатуры;
		НоваяЗапись.Сортировка = 0;
	КонецЦикла;
	
	Набор.Записать(Ложь);
	
КонецПроцедуры
