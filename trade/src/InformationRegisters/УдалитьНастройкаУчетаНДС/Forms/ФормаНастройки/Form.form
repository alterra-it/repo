  <attributes>
    <name>СписокНастроекОрганизаций</name>
    <title>
      <key>ru</key>
      <value>Список настроек организаций</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	Организации.Ссылка КАК Организация,
	НастройкаУчетаНДССрезПервых.Период КАК ДатаНачалаВеденияУчетаНДС,
	НастройкаУчетаНДССрезПоследних.Период КАК ДатаПоследнегоИзмененияНастроекУчетаНДС,
	СпрУчетнаяПолитика.СистемаНалогообложения,
	РегистрУчетнаяПолитика.Период КАК ДатаПоследнегоИзмененияСистемыНалогооблажения,
	НастройкаУчетаНДССрезПоследних.УстановленыОтборы,
	НастройкаУчетаНДССрезПоследних.ФормироватьДвиженияАвтоматически,
	ВложенныйЗапрос.ПерваяЗапись,
	ВложенныйЗапрос.ПоследняяЗапись
ИЗ
	Справочник.Организации КАК Организации
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УчетнаяПолитикаОрганизаций.СрезПоследних КАК РегистрУчетнаяПолитика
		ПО Организации.Ссылка = РегистрУчетнаяПолитика.Организация
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УчетныеПолитикиОрганизаций КАК СпрУчетнаяПолитика
		ПО РегистрУчетнаяПолитика.УчетнаяПолитика = СпрУчетнаяПолитика.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УдалитьНастройкаУчетаНДС.СрезПоследних КАК НастройкаУчетаНДССрезПоследних
		ПО Организации.Ссылка = НастройкаУчетаНДССрезПоследних.Организация
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УдалитьНастройкаУчетаНДС.СрезПервых КАК НастройкаУчетаНДССрезПервых
		ПО Организации.Ссылка = НастройкаУчетаНДССрезПервых.Организация
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ДанныеПоОрганизациям.Ссылка КАК Ссылка,
			МАКСИМУМ(ДанныеПоОрганизациям.ПоследняяЗапись) КАК ПоследняяЗапись,
			МИНИМУМ(ДанныеПоОрганизациям.ПерваяЗапись) КАК ПерваяЗапись
		ИЗ
			(ВЫБРАТЬ
				Организации.Ссылка КАК Ссылка,
				МАКСИМУМ(НДСЗаписиКнигиПокупок.Период) КАК ПоследняяЗапись,
				МИНИМУМ(НДСЗаписиКнигиПокупок.Период) КАК ПерваяЗапись
			ИЗ
				Справочник.Организации КАК Организации
					ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.НДСЗаписиКнигиПокупок КАК НДСЗаписиКнигиПокупок
					ПО Организации.Ссылка = НДСЗаписиКнигиПокупок.Организация
			
			СГРУППИРОВАТЬ ПО
				Организации.Ссылка
			
			ОБЪЕДИНИТЬ ВСЕ
			
			ВЫБРАТЬ
				Организации.Ссылка,
				МАКСИМУМ(НДСЗаписиКнигиПродаж.Период),
				МИНИМУМ(НДСЗаписиКнигиПродаж.Период)
			ИЗ
				Справочник.Организации КАК Организации
					ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.НДСЗаписиКнигиПродаж КАК НДСЗаписиКнигиПродаж
					ПО Организации.Ссылка = НДСЗаписиКнигиПродаж.Организация
			
			СГРУППИРОВАТЬ ПО
				Организации.Ссылка) КАК ДанныеПоОрганизациям
		
		СГРУППИРОВАТЬ ПО
			ДанныеПоОрганизациям.Ссылка) КАК ВложенныйЗапрос
		ПО Организации.Ссылка = ВложенныйЗапрос.Ссылка
ГДЕ
	Организации.Ссылка &lt;> ЗНАЧЕНИЕ(Справочник.Организации.УправленческаяОрганизация)		
	И НЕ Организации.ПометкаУдаления</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <formCommands>
    <name>ОткрытьИсториюИзмененияНастройки</name>
    <title>
      <key>ru</key>
      <value>История изменения </value>
    </title>
    <id>1</id>
    <toolTip>
      <key>ru</key>
      <value>Открыть историю изменения настройки учета НДС организации</value>
    </toolTip>
    <use>
      <common>true</common>
    </use>
    <currentRowUse>DontUse</currentRowUse>
  </formCommands>
