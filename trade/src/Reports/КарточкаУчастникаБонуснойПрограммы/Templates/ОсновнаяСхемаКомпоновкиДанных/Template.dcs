		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ПроцентЗаКрупнуюПокупку</dataPath>
			<field>ПроцентЗаКрупнуюПокупку</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Процент за крупную покупку</v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	БонусныеБаллыОстаткиИОбороты.Регистратор КАК Регистратор,
	БонусныеБаллыОстаткиИОбороты.ПериодСекунда КАК ПериодСекунда,
	БонусныеБаллыОстаткиИОбороты.ПериодМинута КАК ПериодМинута,
	БонусныеБаллыОстаткиИОбороты.ПериодЧас КАК ПериодЧас,
	БонусныеБаллыОстаткиИОбороты.ПериодДень КАК ПериодДень,
	БонусныеБаллыОстаткиИОбороты.ПериодНеделя КАК ПериодНеделя,
	БонусныеБаллыОстаткиИОбороты.ПериодДекада КАК ПериодДекада,
	БонусныеБаллыОстаткиИОбороты.ПериодМесяц КАК ПериодМесяц,
	БонусныеБаллыОстаткиИОбороты.ПериодКвартал КАК ПериодКвартал,
	БонусныеБаллыОстаткиИОбороты.ПериодПолугодие КАК ПериодПолугодие,
	БонусныеБаллыОстаткиИОбороты.ПериодГод КАК ПериодГод,
	БонусныеБаллыОстаткиИОбороты.БонуснаяПрограммаЛояльности КАК БонуснаяПрограммаЛояльности,
	БонусныеБаллыОстаткиИОбороты.Партнер КАК Партнер,
	БонусныеБаллыОстаткиИОбороты.НачисленоНачальныйОстаток КАК НачальныйОстаток,
	БонусныеБаллыОстаткиИОбороты.НачисленоКонечныйОстаток - БонусныеБаллыОстаткиИОбороты.ВРезервеКонечныйОстаток КАК КонечныйОстаток,
	БонусныеБаллыОстаткиИОбороты.НачисленоПриход КАК Приход,
	БонусныеБаллыОстаткиИОбороты.НачисленоРасход КАК Расход,
	СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Статус КАК Статус,
	БонусныеБаллыОстаткиИОбороты.ВРезервеПриход КАК ВРезервеПриход,
	БонусныеБаллыОстаткиИОбороты.ВРезервеРасход КАК ВРезервеРасход,
	БонусныеБаллыОстаткиИОбороты.ВРезервеНачальныйОстаток КАК ВРезервеНачальныйОстаток,
	БонусныеБаллыОстаткиИОбороты.ВРезервеКонечныйОстаток КАК Резерв,
	ВЫБОР
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЗаказКлиента
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.ЗаказКлиента).СуммаДокумента
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.РеализацияТоваровУслуг).СуммаДокумента
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЧекККМ
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.ЧекККМ).СуммаДокумента
		ИНАЧЕ 0
	КОНЕЦ КАК СуммаДокумента,
	ВЫБОР
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЗаказКлиента
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.ЗаказКлиента).СтатусПартнераВПрограммеЛояльности.Коэффициент * 100
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.РеализацияТоваровУслуг).СтатусПартнераВПрограммеЛояльности.Коэффициент * 100
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЧекККМ
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.ЧекККМ).СтатусПартнераВПрограммеЛояльности.Коэффициент * 100
		ИНАЧЕ 0
	КОНЕЦ КАК ПроцентЗаСтатус,
	ВЫБОР
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЗаказКлиента
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.ЗаказКлиента).ПроцентЗаКрупнуюПокупку
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.РеализацияТоваровУслуг).ПроцентЗаКрупнуюПокупку
		КОГДА БонусныеБаллыОстаткиИОбороты.Регистратор ССЫЛКА Документ.ЧекККМ
			ТОГДА ВЫРАЗИТЬ(БонусныеБаллыОстаткиИОбороты.Регистратор КАК Документ.ЧекККМ).ПроцентЗаКрупнуюПокупку
		ИНАЧЕ 0
	КОНЕЦ КАК ПроцентЗаКрупнуюПокупку
ИЗ
	РегистрНакопления.БонусныеБаллы.ОстаткиИОбороты(, , Авто, , ) КАК БонусныеБаллыОстаткиИОбороты
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СрезПоследних КАК СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних
		ПО БонусныеБаллыОстаткиИОбороты.Партнер = СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Партнер
			И БонусныеБаллыОстаткиИОбороты.БонуснаяПрограммаЛояльности = СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.БонуснаяПрограммаЛояльности
</query>
	</dataSet>
	<totalField>
		<dataPath>НачальныйОстаток</dataPath>
		<expression>НачальныйОстаток</expression>
		<group>ПериодСекунда</group>
	</totalField>
	<totalField>
		<dataPath>Приход</dataPath>
		<expression>Сумма(Приход)</expression>
	</totalField>
	<totalField>
		<dataPath>Расход</dataPath>
		<expression>Сумма(Расход)</expression>
	</totalField>
	<totalField>
		<dataPath>КонечныйОстаток</dataPath>
		<expression>КонечныйОстаток</expression>
		<group>Регистратор</group>
	</totalField>
	<totalField>
		<dataPath>ВРезервеПриход</dataPath>
		<expression>Сумма(ВРезервеПриход)</expression>
	</totalField>
	<totalField>
		<dataPath>ВРезервеРасход</dataPath>
		<expression>Сумма(ВРезервеРасход)</expression>
	</totalField>
	<totalField>
		<dataPath>Резерв</dataPath>
		<expression>Резерв</expression>
		<group>Регистратор</group>
	</totalField>
	<totalField>
		<dataPath>ДоступноЧерез1День</dataPath>
		<expression>Сумма(КонечныйОстаток1)</expression>
	</totalField>
	<totalField>
		<dataPath>ДоступноЧерез2Дня</dataPath>
		<expression>Сумма(КонечныйОстаток2) </expression>
	</totalField>
	<totalField>
		<dataPath>ДоступноЧерез3Дня</dataPath>
		<expression>Сумма(КонечныйОстаток3) </expression>
	</totalField>
	<totalField>
		<dataPath>КонечныйОстаток1</dataPath>
		<expression>Сумма(КонечныйОстаток1)</expression>
	</totalField>
	<totalField>
		<dataPath>КонечныйОстаток2</dataPath>
		<expression>Сумма(КонечныйОстаток2)</expression>
	</totalField>
	<totalField>
		<dataPath>КонечныйОстаток3</dataPath>
		<expression>Сумма(КонечныйОстаток3)</expression>
	</totalField>
	<totalField>
		<dataPath>Сумма1</dataPath>
		<expression>Сумма(Сумма1)</expression>
	</totalField>
	<totalField>
		<dataPath>Сумма2</dataPath>
		<expression>Сумма(Сумма2)</expression>
