			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ТекущийОборот</dataPath>
			<field>ТекущийОборот</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Текущий оборот</v8:content>
				</v8:item>
			</title>
			<appearance>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>Формат</dcscor:parameter>
					<dcscor:value xsi:type="v8:LocalStringType">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>ЧДЦ=2</v8:content>
						</v8:item>
					</dcscor:value>
				</dcscor:item>
				<dcscor:item xsi:type="dcsset:SettingsParameterValue">
					<dcscor:parameter>МинимальнаяШирина</dcscor:parameter>
					<dcscor:value xsi:type="xs:decimal">25</dcscor:value>
				</dcscor:item>
			</appearance>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	Партнер,
	Статус
ПОМЕСТИТЬ втПартнеры
ИЗ
	РегистрСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СрезПоследних
;

//////////////////////////////////////////////////////////////////////////////////////        
ВЫБРАТЬ  
	АналитикаУчетаПоПартнерам.КлючАналитики,
	втПартнеры.Партнер,
	втПартнеры.Статус
ПОМЕСТИТЬ втКлючиАналитики
ИЗ
	втПартнеры 
    СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаУчетаПоПартнерам          
    ПО втПартнеры.Партнер = АналитикаУчетаПоПартнерам.Партнер
;	 

//////////////////////////////////////////////////////////////////////////////////////     
ВЫБРАТЬ                   
	втКлючиАналитики.КлючАналитики,  
	Регистратор,     
	СУММА(ВыручкаИСебестоимостьПродаж.СуммаВыручки) КАК ТекущийОборот
ПОМЕСТИТЬ втОборот
ИЗ
	втКлючиАналитики
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВыручкаИСебестоимостьПродаж КАК ВыручкаИСебестоимостьПродаж
	ПО ВыручкаИСебестоимостьПродаж.Активность = ИСТИНА
		И ВыручкаИСебестоимостьПродаж.АналитикаУчетаПоПартнерам = втКлючиАналитики.КлючАналитики
СГРУППИРОВАТЬ ПО
	втКлючиАналитики.КлючАналитики,   
	Регистратор             
;
        
//////////////////////////////////////////////////////////////////////////////////////     
ВЫБРАТЬ           
	втКлючиАналитики.Партнер,
	втКлючиАналитики.Статус КАК ТекущийСтатус,
	Сумма(втОборот.ТекущийОборот) КАК ТекущийОборот   
ИЗ 
	втОборот
	ЛЕВОЕ СОЕДИНЕНИЕ втКлючиАналитики ПО
		втОборот.КлючАналитики = втКлючиАналитики.КлючАналитики 	
ГДЕ      
	ВЫБОР
		КОГДА втОборот.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг
		ТОГДА ВЫРАЗИТЬ(втОборот.Регистратор КАК Документ.РеализацияТоваровУслуг).Кассир &lt;&gt; ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		КОГДА втОборот.Регистратор ССЫЛКА Документ.КорректировкаРеализации
		ТОГДА ВЫРАЗИТЬ(втОборот.Регистратор КАК Документ.КорректировкаРеализации).Кассир &lt;&gt; ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		КОГДА втОборот.Регистратор ССЫЛКА Документ.ВозвратТоваровОтКлиента
		ТОГДА ВЫРАЗИТЬ(втОборот.Регистратор КАК Документ.ВозвратТоваровОтКлиента).Кассир &lt;&gt; ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		ИНАЧЕ ИСТИНА
	КОНЕЦ 
СГРУППИРОВАТЬ ПО
	втКлючиАналитики.Партнер,
	втКлючиАналитики.Статус
</query>
	</dataSet>
