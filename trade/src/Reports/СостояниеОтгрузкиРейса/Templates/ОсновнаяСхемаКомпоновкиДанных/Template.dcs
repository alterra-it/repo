				<dataPath>Партнер</dataPath>
				<field>Партнер</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Характеристика</dataPath>
				<field>Характеристика</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Склад</dataPath>
				<field>Склад</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Номенклатура</dataPath>
				<field>Номенклатура</field>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Реализовано</dataPath>
				<field>Реализовано</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Реализовано</v8:content>
					</v8:item>
				</title>
			</field>
			<field xsi:type="DataSetFieldField">
				<dataPath>Основание</dataPath>
				<field>Основание</field>
				<title xsi:type="v8:LocalStringType">
					<v8:item>
						<v8:lang>ru</v8:lang>
						<v8:content>Основание</v8:content>
					</v8:item>
				</title>
			</field>
			<dataSource>ИсточникДанных1</dataSource>
			<query>ВЫБРАТЬ
	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК ДокументПродажи
ПОМЕСТИТЬ РасчетДоставки
ИЗ
	Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
ГДЕ
	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка = &amp;Рейс1
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЕСТЬNULL(РеализацияТоваровУслуг.Ссылка, 0) КАК Реализация,
	Заказ.Ссылка КАК Заказ,
	ВЫБОР
		КОГДА ЕСТЬNULL(РеализацияТоваровУслуг.Ссылка, 0) = 0
			ТОГДА Заказ.Ссылка
		ИНАЧЕ РеализацияТоваровУслуг.Ссылка
	КОНЕЦ КАК ОснованиеДляЗаказа
ПОМЕСТИТЬ ВТ_ОснованиеДляЗаказа
ИЗ
	Документ.ЗаказКлиента КАК Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		ПО (РеализацияТоваровУслуг.ЗаказКлиента = Заказ.Ссылка)
ГДЕ
	Заказ.Ссылка В
			(ВЫБРАТЬ
				РасчетДоставки.ДокументПродажи КАК ДокументПродажи
			ИЗ
				РасчетДоставки КАК РасчетДоставки)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	ЗаказКлиентаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	ВЫБОР
		КОГДА ЗаказКлиентаТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ЗаказКлиентаТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ КАК Упаковка,
	ЗаказКлиентаТовары.Ссылка.Партнер КАК Партнер,
	ВЫБОР
		КОГДА ЗаказКлиентаТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА ЗаказКлиентаТовары.Номенклатура.ВесЗнаменатель &lt;&gt; 0
						ТОГДА ЗаказКлиентаТовары.КоличествоУпаковок * ЗаказКлиентаТовары.Номенклатура.ВесЧислитель / ЗаказКлиентаТовары.Номенклатура.ВесЗнаменатель
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ ЗаказКлиентаТовары.КоличествоУпаковок * ЗаказКлиентаТовары.Упаковка.Вес
	КОНЕЦ КАК Вес,
	ВЫБОР
		КОГДА ЗаказКлиентаТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА ЗаказКлиентаТовары.Номенклатура.ОбъемЗнаменатель &lt;&gt; 0
						ТОГДА ЗаказКлиентаТовары.КоличествоУпаковок * ЗаказКлиентаТовары.Номенклатура.ОбъемЧислитель / ЗаказКлиентаТовары.Номенклатура.ОбъемЗнаменатель
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ ЗаказКлиентаТовары.КоличествоУпаковок * ЗаказКлиентаТовары.Упаковка.Объем
	КОНЕЦ КАК Объем,
	ЗаказКлиентаТовары.Характеристика КАК Характеристика,
	ЗаказКлиентаТовары.Склад КАК Склад,
	ЗаказКлиентаТовары.Ссылка КАК Ссылка
ПОМЕСТИТЬ ВТ_ТоварыЗаказов
ИЗ
	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
ГДЕ
	ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	И ЗаказКлиентаТовары.Отменено = ЛОЖЬ
	И ЗаказКлиентаТовары.ВариантОбеспечения = &amp;ВариантОбеспечения
	И ЗаказКлиентаТовары.Ссылка В
			(ВЫБРАТЬ РАЗЛИЧНЫЕ
				ВТ_ОснованиеДляЗаказа.ОснованиеДляЗаказа КАК ОснованиеДляЗаказа
			ИЗ
				ВТ_ОснованиеДляЗаказа КАК ВТ_ОснованиеДляЗаказа)

ОБЪЕДИНИТЬ

ВЫБРАТЬ
	РеализацияТоваровУслугТовары.Номенклатура,
	РеализацияТоваровУслугТовары.КоличествоУпаковок,
	ВЫБОР
		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА РеализацияТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ РеализацияТоваровУслугТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	РеализацияТоваровУслугТовары.Ссылка.Партнер,
	ВЫБОР
		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА РеализацияТоваровУслугТовары.Номенклатура.ВесЗнаменатель &lt;&gt; 0
						ТОГДА РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Номенклатура.ВесЧислитель / РеализацияТоваровУслугТовары.Номенклатура.ВесЗнаменатель
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Упаковка.Вес
	КОНЕЦ,
	ВЫБОР
		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА РеализацияТоваровУслугТовары.Номенклатура.ОбъемЗнаменатель &lt;&gt; 0
						ТОГДА РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Номенклатура.ОбъемЧислитель / РеализацияТоваровУслугТовары.Номенклатура.ОбъемЗнаменатель
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Упаковка.Объем
	КОНЕЦ,
	РеализацияТоваровУслугТовары.Характеристика,
	РеализацияТоваровУслугТовары.Склад,
	РеализацияТоваровУслугТовары.Ссылка
ИЗ
	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
ГДЕ
	РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	И РеализацияТоваровУслугТовары.Ссылка В
			(ВЫБРАТЬ РАЗЛИЧНЫЕ
				ВТ_ОснованиеДляЗаказа.ОснованиеДляЗаказа КАК ОснованиеДляЗаказа
			ИЗ
				ВТ_ОснованиеДляЗаказа КАК ВТ_ОснованиеДляЗаказа)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	РеализацияТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	ВЫБОР
		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА РеализацияТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ РеализацияТоваровУслугТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ КАК Упаковка,
	РеализацияТоваровУслугТовары.Ссылка.Партнер КАК Партнер,
	ВЫБОР
		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА РеализацияТоваровУслугТовары.Номенклатура.ВесЗнаменатель &lt;&gt; 0
						ТОГДА РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Номенклатура.ВесЧислитель / РеализацияТоваровУслугТовары.Номенклатура.ВесЗнаменатель
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Упаковка.Вес
	КОНЕЦ КАК Вес,
	ВЫБОР
		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ВЫБОР
					КОГДА РеализацияТоваровУслугТовары.Номенклатура.ОбъемЗнаменатель &lt;&gt; 0
						ТОГДА РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Номенклатура.ОбъемЧислитель / РеализацияТоваровУслугТовары.Номенклатура.ОбъемЗнаменатель
					ИНАЧЕ 0
				КОНЕЦ
		ИНАЧЕ РеализацияТоваровУслугТовары.КоличествоУпаковок * РеализацияТоваровУслугТовары.Упаковка.Объем
	КОНЕЦ КАК Объем,
	РеализацияТоваровУслугТовары.Характеристика КАК Характеристика,
	РеализацияТоваровУслугТовары.Ссылка.Склад КАК Склад,
	РеализацияТоваровУслугТовары.Ссылка КАК Основание
ПОМЕСТИТЬ ВТ_Товары
ИЗ
	РасчетДоставки КАК РасчетДоставки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		ПО РасчетДоставки.ДокументПродажи = РеализацияТоваровУслугТовары.Ссылка
ГДЕ
	РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЧекККМТовары.Номенклатура,
	ЧекККМТовары.КоличествоУпаковок,
	ВЫБОР
		КОГДА ЧекККМТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЧекККМТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ЧекККМТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	ЧекККМТовары.Ссылка.Партнер,
	ВЫБОР
		КОГДА ЧекККМТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЧекККМТовары.Номенклатура.ВесЧислитель * ЧекККМТовары.КоличествоУпаковок
		ИНАЧЕ ЧекККМТовары.КоличествоУпаковок * ЧекККМТовары.Упаковка.Вес
	КОНЕЦ,
	ВЫБОР
		КОГДА ЧекККМТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЧекККМТовары.Номенклатура.ОбъемЧислитель * ЧекККМТовары.КоличествоУпаковок
		ИНАЧЕ ЧекККМТовары.КоличествоУпаковок * ЧекККМТовары.Упаковка.Объем
	КОНЕЦ,
	ЧекККМТовары.Характеристика,
	ЧекККМТовары.Ссылка.Склад,
	ЧекККМТовары.Ссылка
ИЗ
	РасчетДоставки КАК РасчетДоставки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ЧекККМТовары
		ПО РасчетДоставки.ДокументПродажи = ЧекККМТовары.Ссылка
ГДЕ
	ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ВТ_ТоварыЗаказов.Номенклатура,
	ВТ_ТоварыЗаказов.КоличествоУпаковок,
	ВТ_ТоварыЗаказов.Упаковка,
	ВТ_ТоварыЗаказов.Партнер,
	ВТ_ТоварыЗаказов.Вес,
	ВТ_ТоварыЗаказов.Объем,
	ВТ_ТоварыЗаказов.Характеристика,
	ВТ_ТоварыЗаказов.Склад,
	ВТ_ТоварыЗаказов.Ссылка
ИЗ
	ВТ_ТоварыЗаказов КАК ВТ_ТоварыЗаказов
ГДЕ
	ВТ_ТоварыЗаказов.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Товары.Номенклатура КАК Номенклатура,
	СУММА(ВТ_Товары.КоличествоУпаковок) КАК Количество,
	ВТ_Товары.Упаковка КАК Упаковка,
	ВТ_Товары.Партнер КАК Партнер,
	СУММА(ВТ_Товары.Вес) КАК Вес,
	СУММА(ВТ_Товары.Объем) КАК Объем,
	ВТ_Товары.Характеристика КАК Характеристика,
	ВТ_Товары.Склад КАК Склад,
	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	ВТ_Товары.Основание КАК Основание
ПОМЕСТИТЬ ВТ
ИЗ
	ВТ_Товары КАК ВТ_Товары
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
			И (ИСТИНА = РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)

СГРУППИРОВАТЬ ПО
	ВТ_Товары.Номенклатура,
	ВТ_Товары.Характеристика,
	ВТ_Товары.Партнер,
	ВТ_Товары.Упаковка,
	ВТ_Товары.Склад,
	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток,
	ВТ_Товары.Основание
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ.Партнер КАК Партнер,
	ВТ.Склад КАК Склад,
	ВТ.Секция КАК Секция,
	ВТ.Номенклатура КАК Номенклатура,
	ВТ.Количество КАК Реализовано,
	ВТ.Упаковка КАК Упаковка,
	ВТ.Вес КАК Вес,
	ВТ.Объем КАК Объем,
	ВТ.Характеристика КАК Характеристика,
	ВТ.Основание КАК Основание
ИЗ
	ВТ КАК ВТ</query>
		</item>
		<item xsi:type="DataSetQuery">
