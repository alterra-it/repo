
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)  
	
	ДокОснованиеСсылка = ПараметрКоманды; 	
	
	Если ДокОснованиеСсылка.Пустая() Тогда  
		
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Данные еще не записаны.
		|Выполнение действия ""%1"" возможно только после записи данных.'"),
		"Начисление И Списание Бонусных Баллов");
		
		Если СтрНайти(ПараметрыВыполненияКоманды.Источник.ИмяФормы, "Список")> 0 
			Или СтрНайти(ПараметрыВыполненияКоманды.Источник.ИмяФормы, "Списка")> 0 Тогда  
			
			ТекстВопроса  = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'На основании данного типа документа
			|не предусмотрено Начисление бонусов.'"),
			"Начисление И Списание Бонусных Баллов");
			
		КонецЕсли;
		
		ПоказатьПредупреждение(,ТекстВопроса);
		Возврат;	
	КонецЕсли;
	
	ИмяДокумента= "НачислениеИСписаниеБонусныхБаллов";
	СтруктураПараметров= Новый структура("Основание",ДокОснованиеСсылка);	
	ОткрытьФорму("Документ."+ИмяДокумента+".ФормаОбъекта",структураПараметров);
	
КонецПроцедуры
