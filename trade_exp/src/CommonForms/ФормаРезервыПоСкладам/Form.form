  <attributes>
    <name>ПоступлениеИОтгрузка</name>
    <title>
      <key>ru</key>
      <value>Поступление и отгрузка</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	1 КАК Действие,
	Таблица.Номенклатура КАК Номенклатура,
	Таблица.Склад КАК Склад,
	ДАТАВРЕМЯ(1, 1, 1) КАК ПериодРасшифровка,
	Таблица.ДокументОтгрузки КАК ДокументОснование,
	0 КАК НачальныйОстаток,
	0 КАК Приход,
	Таблица.КОтгрузкеОстаток КАК Расход,
	3 КАК Запрос
ПОМЕСТИТЬ ВТ
ИЗ
	РегистрНакопления.ТоварыКОтгрузке.Остатки(, Номенклатура = &amp;Номенклатура) КАК Таблица
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеквизитыРаспоряжения
		ПО Таблица.ДокументОтгрузки = РеквизитыРаспоряжения.Ссылка
			И (НЕ РеквизитыРаспоряжения.ДополнительнаяЗапись)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	2,
	Таблица.Номенклатура,
	Таблица.Склад,
	ДАТАВРЕМЯ(1, 1, 1),
	ВЫБОР
		КОГДА Таблица.Назначение.Заказ = НЕОПРЕДЕЛЕНО
			ТОГДА Таблица.Назначение
		ИНАЧЕ Таблица.Назначение.Заказ
	КОНЕЦ,
	0,
	0,
	СУММА(Таблица.Зарезервировано),
	4
ИЗ
	РегистрСведений.РаспределениеЗапасов КАК Таблица
ГДЕ 
	Таблица.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе)
	И Номенклатура = &amp;Номенклатура 
	И НЕ Таблица.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
СГРУППИРОВАТЬ ПО
	Таблица.Номенклатура,
	Таблица.Склад,
	Таблица.Назначение                
ИМЕЮЩИЕ
	СУММА(Таблица.Зарезервировано) > 0

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	3,
	Таблица.Номенклатура,
	Таблица.Склад,
	ДАТАВРЕМЯ(1, 1, 1),
	Таблица.ДокументОтгрузки,
	0,
	0,
	Таблица.ВРезервеОстаток,
	5
ИЗ
	РегистрНакопления.ТоварыКОтгрузке.Остатки(, Номенклатура = &amp;Номенклатура) КАК Таблица
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеквизитыРаспоряжения
		ПО Таблица.ДокументОтгрузки = РеквизитыРаспоряжения.Ссылка
			И (НЕ РеквизитыРаспоряжения.ДополнительнаяЗапись)      
ГДЕ (Таблица.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)) 
			
ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	4,
	Таблица.Номенклатура,
	Таблица.Склад,
	ДАТАВРЕМЯ(1, 1, 1),
	Таблица.ЗаказНаОтгрузку,
	0,
	0,
	СУММА(Таблица.РезервироватьПоМереПоступления),
	6
ИЗ
	РегистрСведений.РаспределениеЗапасов КАК Таблица
ГДЕ 
	Таблица.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаемаяОтгрузка)
	И Номенклатура = &amp;Номенклатура 
СГРУППИРОВАТЬ ПО
	Таблица.Номенклатура,
	Таблица.Склад,
	Таблица.ЗаказНаОтгрузку
ИМЕЮЩИЕ
	СУММА(Таблица.РезервироватьПоМереПоступления) > 0  

ОБЪЕДИНИТЬ ВСЕ
	
ВЫБРАТЬ
	6,
	Таблица.Номенклатура,
	Таблица.Склад,
	ДАТАВРЕМЯ(1, 1, 1),
	ВЫБОР
		КОГДА Таблица.Назначение.Заказ = НЕОПРЕДЕЛЕНО
			ТОГДА Таблица.Назначение
		ИНАЧЕ Таблица.Назначение.Заказ
	КОНЕЦ,
	0,
	0,
	СУММА(Таблица.Обеспечено),
	4
ИЗ
	РегистрСведений.РаспределениеЗапасов КАК Таблица
ГДЕ 
	Номенклатура = &amp;Номенклатура 
	И НЕ Таблица.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
СГРУППИРОВАТЬ ПО
	Таблица.Номенклатура,
	Таблица.Склад,
	Таблица.Назначение                
ИМЕЮЩИЕ
	СУММА(Таблица.Обеспечено) > 0
	
			
 ;  

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВЫБОР
		КОГДА ВТ.Действие = 1
			ТОГДА &quot;Отгружается&quot;
		КОГДА ВТ.Действие = 2
			ТОГДА &quot;Резерв (обособленный)&quot;
		КОГДА ВТ.Действие = 3
			ТОГДА &quot;Резерв&quot;
		КОГДА ВТ.Действие = 4
			ТОГДА &quot;Ожидается поступление&quot;
		КОГДА ВТ.Действие = 5
			ТОГДА &quot;Резерв к дате отгрузки&quot;
		КОГДА ВТ.Действие = 6
			ТОГДА &quot;Обеспечено обособленно&quot;	
		ИНАЧЕ &quot;&quot;
	КОНЕЦ КАК Действие,
	ВТ.ПериодРасшифровка КАК ПериодРасшифровка,
	ВТ.ДокументОснование КАК ДокументОснование,
	ВТ.НачальныйОстаток КАК НачальныйОстаток,
	ВТ.Приход КАК Приход,
	ВТ.Расход КАК Расход,
	ВТ.Запрос КАК Запрос,
	ВТ.Склад КАК Склад
ИЗ
	ВТ КАК ВТ

УПОРЯДОЧИТЬ ПО
	Запрос</queryText>
