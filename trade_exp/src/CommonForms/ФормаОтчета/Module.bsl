
&НаСервере
Процедура Док_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка) 
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДатаНачала = Константы.ДатаНачалаОграниченияДоступаКОстаткам.Получить();
	ТекДата = ТекущаяДата();
	
	ОграничениеДоступаКДанным = ?(ДатаНачала <> Дата(1,1,1) И ТекДата > ДатаНачала, Истина, Ложь);
	
	Если ОграничениеДоступаКДанным И Не АльтерраОбщегоНазначения.ЕстьПравоПросмотраОстатков(Пользователи.ТекущийПользователь()) Тогда
		ПолучитьСтандартнуюСхемуКД();
	КонецЕсли;
	
	Элементы.ПерейтиКНастройкамДляТехническогоСпециалиста.Видимость = АльтерраОбщегоНазначения._ЕстьРоль("ДоступКНастройкамДляТехническогоСпециалистаВОтчетах");
КонецПроцедуры

&НаСервере
Процедура Док_ОбработкаПроверкиЗаполненияНаСервереПосле(Отказ, ПроверяемыеРеквизиты)
	
	МассивСтрок = СтрРазделить(ИмяФормы, ".");
	Если МассивСтрок[0] <> "ВнешнийОтчет" Тогда
		Возврат;
	КонецЕсли;	
	
	ВнешнийОтчет = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяОбъекта", МассивСтрок[1]);
	Если ВнешнийОтчет.Пустая() Тогда
		Возврат;
	КонецЕсли;	
	
	Если НЕ ВнешнийОтчет.ВключитьОграниченияФормирования Тогда
		Возврат;
	КонецЕсли;
	
	Если ВнешнийОтчет.ТолькоНаБазеTrade и НСтр(СтрокаСоединенияИнформационнойБазы(), "Ref") <> "trade" Тогда
		Возврат;
	КонецЕсли;	
	
	ТЧПараметрыИОтборы = ВнешнийОтчет.ПараметрыИОтборы;
	ПараметрыИОтборы = АльтерраОбщегоНазначения.ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроек(Отчет.КомпоновщикНастроек);
	ЭлементыПользовательскихНастроек = Отчет.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы;
	МассивПараметров = Новый Массив;
	МассивОтборов = Новый Массив;
	
	Для Каждого СтрокаТЧ из ТЧПараметрыИОтборы Цикл
		Если СтрокаТЧ.Обязательный Тогда
			
			НайденныйЭлемент = ПараметрыИОтборы.Найти(СтрокаТЧ.Наименование, "Заголовок");
			
			Если НайденныйЭлемент = Неопределено Тогда
				Если СтрокаТЧ.ЭтоПараметр Тогда
					МассивПараметров.Добавить(СтрокаТЧ.Наименование);
				Иначе
					МассивОтборов.Добавить(СтрокаТЧ.Наименование);
				КонецЕсли;	
				Отказ = Истина;
				Продолжить;
			КонецЕсли;
			
			Для Каждого ЭлементПользовательскойНастройки Из ЭлементыПользовательскихНастроек Цикл
			
				Если ТипЗнч(ЭлементПользовательскойНастройки) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") и СтрокаТЧ.ЭтоПараметр Тогда
					
					Если НЕ (ЭлементПользовательскойНастройки.Использование и ЗначениеЗаполнено(ЭлементПользовательскойНастройки.Значение))
					 и ЭлементПользовательскойНастройки.ИдентификаторПользовательскойНастройки = НайденныйЭлемент.ИдентификаторПользовательскойНастройки Тогда
						МассивПараметров.Добавить(НайденныйЭлемент.Заголовок);
						Отказ = Истина;
					КонецЕсли;
					
					Если ЭлементПользовательскойНастройки.Использование и ЗначениеЗаполнено(ЭлементПользовательскойНастройки.Значение)
					 и ТипЗнч(ЭлементПользовательскойНастройки.Значение) = Тип("СтандартныйПериод")
					 и ЭлементПользовательскойНастройки.ИдентификаторПользовательскойНастройки = НайденныйЭлемент.ИдентификаторПользовательскойНастройки Тогда	
					 
					 	ПараметрСтандартныйПериод = ЭлементПользовательскойНастройки.Значение;
						ДатаНачала = ПараметрСтандартныйПериод.ДатаНачала;
						ДатаОкончания = ПараметрСтандартныйПериод.ДатаОкончания;
						Если (ДатаОкончания - ДатаНачала)/(31*24*3600) > СтрокаТЧ.ПериодПараметра и СтрокаТЧ.ПериодПараметра > 0 Тогда  
							МассивПараметров.Добавить("параметр периода " + НайденныйЭлемент.Заголовок + " не более " + СтрокаТЧ.ПериодПараметра + " месяцев");
							Отказ = Истина;
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
		
				Если ТипЗнч(ЭлементПользовательскойНастройки) = Тип("ЭлементОтбораКомпоновкиДанных") и НЕ СтрокаТЧ.ЭтоПараметр Тогда
					
					Если НЕ (ЭлементПользовательскойНастройки.Использование и ЗначениеЗаполнено(ЭлементПользовательскойНастройки.ПравоеЗначение))
					 и ЭлементПользовательскойНастройки.ИдентификаторПользовательскойНастройки = НайденныйЭлемент.ИдентификаторПользовательскойНастройки Тогда
					 	МассивОтборов.Добавить(НайденныйЭлемент.ЛевоеЗначениеСтрока);
						Отказ = Истина;
					КонецЕсли;
					
				КонецЕсли;
			
			КонецЦикла;	
		КонецЕсли;
	КонецЦикла;	
	
	Если Отказ Тогда
		Сообщение = "Чтобы сформировать отчет заполните:";
		Если МассивПараметров.Количество() > 0 Тогда
			Сообщение = Сообщение + Символы.ПС + "- параметры: " + СтрСоединить(МассивПараметров, ", ");
		КонецЕсли;
		Если МассивОтборов.Количество() > 0 Тогда
			Сообщение = Сообщение + Символы.ПС + "- отборы: " + СтрСоединить(МассивОтборов, ", ");
		КонецЕсли;	
		АльтерраОбщегоНазначения.СообщитьПользователю(, Сообщение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
&Перед("Сформировать")
Процедура Док_Сформировать()
	ЗаписатьОтборыВЛог();//Если надо

	НазваниеОтчета= Строка(НастройкиОтчета.ОтчетСсылка);
	НазваниеВарианта= Строка(НастройкиОтчета.ВариантСсылка);
	СтрокаОтборов= ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроекСерверСкращенные();
	
	ДопДанные = НазваниеВарианта + "; " + Символы.ПС + "Отборы: " + СтрокаОтборов;
	
	Префикс= "";
	Если НСтр(СтрокаСоединенияИнформационнойБазы(), "Ref") <> "trade" Тогда
		Префикс= "test ";
	КонецЕсли;
	
	СФП_МаркерыКлиент.МаркерНачало(Префикс+"Отчет: "+НазваниеОтчета, "Вариант: "+ДопДанные);
КонецПроцедуры

&НаСервере
Функция ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроекСерверСкращенные()
	
	МассивПравыхЗначений = Новый Массив;
	ПараметрыИОтборы = АльтерраОбщегоНазначения.ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроек(Отчет.КомпоновщикНастроек);
	СтрокаПараметров = "";
	СтрокаОтборов = "";
	Для Каждого СтрокаТЗ Из ПараметрыИОтборы Цикл
		
		Если СтрокаТЗ.Использование Тогда
			
			ПравоеЗначение = СтрокаТЗ.ПравоеЗначение;
			Если ТипЗнч(СтрокаТЗ.ПравоеЗначение) = Тип("СписокЗначений") Тогда
				МассивПравыхЗначений = ПравоеЗначение.ВыгрузитьЗначения();
				СтрокаПравоеЗначение = СтрСоединить(МассивПравыхЗначений, ",");
			Иначе
				СтрокаПравоеЗначение = Строка(ПравоеЗначение);
			КонецЕсли;	
			
			Если СтрокаТЗ.ЭтоПараметр Тогда
				Если ТипЗнч(СтрокаТЗ.ПравоеЗначение) = Тип("СтандартныйПериод") ИЛИ
					ТипЗнч(СтрокаТЗ.ПравоеЗначение) = Тип("Дата") Тогда
					СтрокаПараметров = СтрокаПараметров + СтрокаТЗ.Заголовок + "=" + СтрокаПравоеЗначение + ";" + Символы.ПС;
				Иначе
					СтрокаПараметров = СтрокаПараметров + СтрокаТЗ.Заголовок + ";" + Символы.ПС;
				КонецЕсли;
			Иначе
				//Сокращяем данные
				СтрокаОтборов = СтрокаОтборов + СтрокаТЗ.Заголовок + ";" + Символы.ПС;
				
			КонецЕсли;
		КонецЕсли;	
		
	КонецЦикла;	
	СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(СтрокаПараметров, 2);
	СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(СтрокаОтборов, 2);
	СтрокаОбщая = СтрокаПараметров + ";" + Символы.ПС + СтрокаОтборов + ";";
		
	Возврат СтрокаОбщая;
	
КонецФункции

&НаСервере
Функция ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроекСерверПолные()
	
	МассивПравыхЗначений = Новый Массив;
	ПараметрыИОтборы = АльтерраОбщегоНазначения.ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроек(Отчет.КомпоновщикНастроек);
	СтрокаПараметров = "";
	СтрокаОтборов = "";
	Для Каждого СтрокаТЗ Из ПараметрыИОтборы Цикл
		
		Если СтрокаТЗ.Использование Тогда
			
			ПравоеЗначение = СтрокаТЗ.ПравоеЗначение;
			Если ТипЗнч(СтрокаТЗ.ПравоеЗначение) = Тип("СписокЗначений") Тогда
				МассивПравыхЗначений = ПравоеЗначение.ВыгрузитьЗначения();
				СтрокаПравоеЗначение = СтрСоединить(МассивПравыхЗначений, ",");
			Иначе
				СтрокаПравоеЗначение = Строка(ПравоеЗначение);
			КонецЕсли;	
			
			Если СтрокаТЗ.ЭтоПараметр Тогда
				СтрокаПараметров = СтрокаПараметров + СтрокаТЗ.Заголовок + " = """ + СтрокаПравоеЗначение + """;" + Символы.ПС;
			Иначе
				СтрокаОтборов = СтрокаОтборов + СтрокаТЗ.Заголовок + " " + Строка(СтрокаТЗ.ВидСравнения) 
				+ " """ + СтрокаПравоеЗначение + """;" + Символы.ПС;
			КонецЕсли;
		КонецЕсли;	
		
	КонецЦикла;	
	СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(СтрокаПараметров, 2);
	СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(СтрокаОтборов, 2);
	СтрокаОбщая = СтрокаПараметров + ";" + Символы.ПС + СтрокаОтборов + ";";
		
	Возврат СтрокаОбщая;
	
КонецФункции


// приостановлена
&НаСервере
Процедура ЗаписатьОтборыВЛог()  
	возврат;
	МассивСтрок = СтрРазделить(ИмяФормы, ".");
	Если МассивСтрок[0] <> "ВнешнийОтчет" Тогда
		Возврат;
	КонецЕсли;	
	
	ВнешнийОтчет = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяОбъекта", МассивСтрок[1]);
	Если Не ВнешнийОтчет.Пустая() И ВнешнийОтчет.ВестиЛогирование Тогда
		
		НазваниеОтчета= Строка(НастройкиОтчета.ОтчетСсылка);
		НазваниеВарианта= Строка(НастройкиОтчета.ВариантСсылка);
		
		СтрокаОтборовДляЛога= ПолучитьПараметрыИОтборыОтчетаПоКомпоновщикуНастроекСерверПолные();
		
		ДатаВФайл= Формат(НачалоНедели(ТекущаяДата()), "ДФ=dd-MM-yyyy");
		ФайлЛогов= "C:\Bitrix\Log\"+ДатаВФайл+"_Параметры_отчетов.txt";
		ТекДата= Строка(ТекущаяДата());
		ТекПользователь= Пользователи.ТекущийПользователь();
		
		Попытка
			ЗаписьТекста= Новый ЗаписьТекста(ФайлЛогов, КодировкаТекста.UTF8,, Истина);
			ЗаписьТекста.ЗаписатьСтроку(НазваниеОтчета+": ("+НазваниеВарианта+")");
			ЗаписьТекста.ЗаписатьСтроку(ТекДата + " ; "+ТекПользователь);
			ЗаписьТекста.ЗаписатьСтроку(СтрокаОтборовДляЛога);
			ЗаписьТекста.ЗаписатьСтроку("");
		Исключение
			ЗаписьЖурналаРегистрации("Запись лога отчетов", УровеньЖурналаРегистрации.Ошибка,, "Ошибка записи лога отчетов");
		КонецПопытки;
	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте 
&После("ПослеФормирования")
Процедура Док_ПослеФормирования(Результат, ПараметрыФормирования) Экспорт
	
	СФП_МаркерыКлиент.ЗавершитьМаркерАвтоНеГлобальный();
	
КонецПроцедуры	

&НаКлиенте
&ИзменениеИКонтроль("ПоказатьСписокВыбора")
Процедура Док_ПоказатьСписокВыбора(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;

	Сведения = ОтчетыКлиент.СведенияОЭлементеНастройки(Отчет.КомпоновщикНастроек, Элемент.Имя);
	ОписаниеНастроек = Сведения.Описание;

	ПользовательскиеНастройки = Отчет.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы;

	ПараметрыВыбора = ОтчетыКлиентСервер.ПараметрыВыбора(
		Сведения.Настройки, ПользовательскиеНастройки, Сведения.Элемент);

	РасширенноеОписаниеТипов = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		Отчет.КомпоновщикНастроек.Настройки.ДополнительныеСвойства, "РасширенноеОписаниеТипов");

	ТипЗначения = Неопределено;
	Если РасширенноеОписаниеТипов <> Неопределено Тогда
		РасширенноеОписаниеТипа = РасширенноеОписаниеТипов[Сведения.Индекс];
		Если РасширенноеОписаниеТипа <> Неопределено Тогда
			ТипЗначения = РасширенноеОписаниеТипа.ОписаниеТиповДляФормы;
		КонецЕсли;
	КонецЕсли;

	Элемент.ДоступныеТипы = ОтчетыКлиент.ТипЗначенияОграниченныйСвязьюПоТипу(
		Сведения.Настройки, ПользовательскиеНастройки, Сведения.Элемент, ОписаниеНастроек, ТипЗначения);

	Если ТипЗнч(Сведения.ЭлементПользовательскойНастройки) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") Тогда
		ТекущееЗначение = Сведения.ЭлементПользовательскойНастройки.Значение;
	Иначе
		ТекущееЗначение = Сведения.ЭлементПользовательскойНастройки.ПравоеЗначение;
	КонецЕсли;

	ОтмеченныеЗначения = ОтчетыКлиентСервер.ЗначенияСписком(ТекущееЗначение);
	ДоступныеЗначения = ?(ОписаниеНастроек = Неопределено, Неопределено, ОписаниеНастроек.ДоступныеЗначения);

	Условие = ОтчетыКлиентСервер.УсловиеЭлементаНастройки(Сведения.ЭлементПользовательскойНастройки, ОписаниеНастроек);
	ВыборГруппИЭлементов = ОтчетыКлиент.ЗначениеТипаИспользованиеГруппИЭлементов(
		?(ОписаниеНастроек = Неопределено, Неопределено, ОписаниеНастроек.ВыборГруппИЭлементов), Условие);

	ЗначенияДляВыбора = ЗначенияДляВыбора(Элемент.СписокВыбора, Сведения.ЭлементПользовательскойНастройки, 
		Элемент.ДоступныеТипы, ДоступныеЗначения);

	ОграничиватьВыборУказаннымиЗначениями = ДоступныеЗначения <> Неопределено;

	ПараметрыОбработчика = Новый Структура;
	ПараметрыОбработчика.Вставить("ЭлементПользовательскойНастройки", Сведения.ЭлементПользовательскойНастройки);
	ПараметрыОбработчика.Вставить("ОграничиватьВыборУказаннымиЗначениями", ОграничиватьВыборУказаннымиЗначениями);
	ПараметрыОбработчика.Вставить("ИмяЭлемента", Элемент.Имя);

	Обработчик = Новый ОписаниеОповещения("ЗавершитьВыборИзСписка", ЭтотОбъект, ПараметрыОбработчика);

	Если ОтчетыКлиент.ВыборПереопределен(ЭтотОбъект, Обработчик, Сведения.Описание, Элемент.ДоступныеТипы,
		ОтмеченныеЗначения, ПараметрыВыбора) Тогда
		Возврат;
	КонецЕсли;

	Если ОтчетыКлиент.ЭтоВыборОбъектовМетаданных(Элемент.ДоступныеТипы, ОтмеченныеЗначения, Обработчик) Тогда
		Возврат;
	КонецЕсли;
	#Вставка
		Если Элемент.Заголовок = "Номенклатура" Тогда
		
		ЗначениеОтбораТочки = ПроверитьОтборПоТочкеПересчета();
		
		Если ЗначениеЗаполнено(ЗначениеОтбораТочки) Тогда
			
			ЗначениеОтбораПоВидам = ПолучитьЗначениеОтбораПоТочке(ЗначениеОтбораТочки);
			
			Отбор = Новый Массив;
			Отбор.Добавить(Новый ПараметрВыбора("Отбор.Ссылка", ЗначениеОтбораПоВидам));
			ПараметрыВыбора = Новый ФиксированныйМассив(Отбор);
		КонецЕсли; 
		
	КонецЕсли; 
	#КонецВставки

	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Отмеченные", ОтмеченныеЗначения);
	ПараметрыОткрытия.Вставить("ОписаниеТипов", Элемент.ДоступныеТипы);
	ПараметрыОткрытия.Вставить("ЗначенияДляВыбора", ЗначенияДляВыбора);
	ПараметрыОткрытия.Вставить("ЗначенияДляВыбораЗаполнены", Элемент.СписокВыбора.Количество() > 0);
	ПараметрыОткрытия.Вставить("ОграничиватьВыборУказаннымиЗначениями", ОграничиватьВыборУказаннымиЗначениями);
	ПараметрыОткрытия.Вставить("Представление", Элемент.Заголовок);
	ПараметрыОткрытия.Вставить("ПараметрыВыбора", Новый Массив(ПараметрыВыбора));
	ПараметрыОткрытия.Вставить("ВыборГруппИЭлементов", ВыборГруппИЭлементов);
	ПараметрыОткрытия.Вставить("БыстрыйВыбор", ?(ОписаниеНастроек = Неопределено, Ложь, ОписаниеНастроек.БыстрыйВыбор));
	
	Контекст = Новый Структура;
	Контекст.Вставить("ПараметрыОткрытия", ПараметрыОткрытия);
	Контекст.Вставить("Обработчик", Обработчик);
	
	Если ОграничиватьВыборУказаннымиЗначениями Тогда
		ПоказатьСписокВыбораПродолжение(Неопределено, Контекст);
	Иначе
		ОтчетыКлиент.НачатьВыборПользователей(ЭтотОбъект,
			Элемент, Элемент.ДоступныеТипы, ОтмеченныеЗначения, ПараметрыВыбора, Обработчик,
			Новый ОписаниеОповещения("ПоказатьСписокВыбораПродолжение", ЭтотОбъект, Контекст));
	КонецЕсли;
	

КонецПроцедуры

#Область ЧтениеРегистровБезПрав
&НаСервере
Процедура ПолучитьСтандартнуюСхемуКД()
	
	Если СтрНайти(ЭтотОбъект.ИмяФормы, "БезОстатков") > 0 Тогда
	
		ОтчетОбъект = РеквизитФормыВЗначение("Отчет");
		Если СтрНайти(ЭтотОбъект.ИмяФормы, "БезОстатков") > 0 Тогда
			Схема = ОтчетОбъект.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
		КонецЕсли;
		
		ОтчетОбъект.СхемаКомпоновкиДанных = Схема;
		АдресСхемы = ПоместитьВоВременноеХранилище(Схема, УникальныйИдентификатор);
		ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемы);
		Отчет.КомпоновщикНастроек.Инициализировать(ИсточникНастроек);
		Отчет.КомпоновщикНастроек.ЗагрузитьНастройки(Схема.НастройкиПоУмолчанию);
		
		Элементы.ВсеНастройкиЕще.Видимость = Ложь;
		Элементы.СброситьНастройки.Видимость = Ложь;
		Элементы.ГруппаНастройкиОтчета.Видимость = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
&Вместо("ВсеНастройки")
Процедура Док_ВсеНастройки(Команда)
	ПолныеПрава = ПроверитьПрава();
	Если Не ПолныеПрава И СтрНайти(ЭтотОбъект.ИмяФормы, "БезОстатков") > 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПродолжитьВызов(Команда);
КонецПроцедуры

&НаСервере
Функция ПроверитьПрава()
	Возврат РольДоступна("ПолныеПрава");
КонецФункции

#КонецОбласти 
	
#Область ТочкиПересчетаОбучение
&НаКлиенте
Функция ПроверитьОтборПоТочкеПересчета()
	
	Для каждого Элемент Из Отчет.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы Цикл
		Если ТипЗнч(Элемент) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
			Если ТипЗнч(Элемент.ПравоеЗначение) = Тип("СправочникСсылка.ТочкиПересчетаОбучение") Тогда
				Если Элемент.Использование Тогда
					Возврат Элемент.ПравоеЗначение;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 

КонецФункции 

&НаСервере
Функция ПолучитьЗначениеОтбораПоТочке(Точки)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Номенклатура
		|ИЗ
		|	Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
		|		ПО ВидыНоменклатуры.Ссылка = Номенклатура.ВидНоменклатуры
		|ГДЕ
		|	ВидыНоменклатуры.ТочкаПересчетаОбучение В(&Точки)";
	
	Запрос.УстановитьПараметр("Точки", Точки);
	Список = Новый СписокЗначений;
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Список.Добавить(Выборка.Номенклатура)
	КонецЦикла;
	
	Возврат Список;
	
КонецФункции

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	ОтобразитьЗаголовкиПериодов();	
