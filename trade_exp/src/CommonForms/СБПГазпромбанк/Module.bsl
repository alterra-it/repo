#Область СобытияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Документ = Параметры.Документ;
	КОплате = Параметры.КОплате;
	
	//ИЛИ ТипЗнч(Документ) = Тип("ДокументСсылка.ВозвратПодарочныхСертификатов")
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.ЧекККМВозврат") или 
		(ТипЗнч(Документ) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") 
			и Документ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту)  Тогда
		ИДТранзакцииОплаты = Параметры.Идентификатор;
		ЭтоВозврат = Истина;
	Иначе
		ИдентификаторКассовойСсылки = Параметры.Идентификатор;
	КонецЕсли;	
		
	ВремяЖизниКС = 5;
	
	Если НЕ РольДоступна("ПолныеПрава") Тогда
		Элементы.РучныеКоманды.Доступность = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
 
	Если ЭтоВозврат Тогда
		Элементы.Оплата.Видимость = Ложь;
		ПолучитьСписокБанков(); 
	Иначе
		Элементы.Возврат.Видимость = Ложь;		
	КонецЕсли;	
КонецПроцедуры 

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка) 
	
	
	Если ЭтоВозврат Тогда
	
	ИначеЕсли ЗначениеЗаполнено(ИДТранзакцииОплаты) Тогда
		
			Кнопки = Новый СписокЗначений;
			Кнопки.Добавить("ОтменитьОплату", НСтр("ru = 'Отменить оплату'"));
			Кнопки.Добавить("Отмена", НСтр("ru = 'Отмена'"));
		   	Отказ = Истина;
		   
			Оповещение = Новый ОписаниеОповещения("ПередЗакрытиемВопросЗавершение", ЭтаФорма);
			ТекстВопроса = "Оплата уже проведена. Необходимо отменить оплату, если Вы хотите закрыть форму";
			ПоказатьВопрос(Оповещение, ТекстВопроса, Кнопки);
			
	КонецЕсли;
		
	
	Если НЕ Отказ и КСАктивирована Тогда
		РезультатДеактивации = ДеактивироватьКСНаСервере();
		Если ТипЗнч(РезультатДеактивации) = Тип("Строка") Тогда
			Оповестить("ПроблемыДеактивацииКСФормаСБП", РезультатДеактивации, ЭтотОбъект);	
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры 

&НаКлиенте
Процедура ПередЗакрытиемВопросЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = "ОтменитьОплату" тогда
		АварийныйВозврат(Неопределено);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти


#Область Оплата

&НаКлиенте
Процедура АктивироватьКС(Команда)
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("qrcId", ИдентификаторКассовойСсылки);  
	ДанныеЗаполнения.Вставить("amount", Формат(КОплате*100, "ЧГ=")); //сумма в копейках
	//ДанныеЗаполнения.Вставить("qrTtl", ВремяЖизниКС);  //нужно предварительно заполнить времяжизни, по умолчанию 5 мин
	Если ЗначениеЗаполнено(Документ) Тогда
		ДанныеЗаполнения.Вставить("paymentPurpose", Строка(Документ.УникальныйИдентификатор()));
	КонецЕсли;
	Ответ = ИнтеграцияСБПГазпромбанк.АктивацияКассовойСсылки(ДанныеЗаполнения);
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда 
		Если Ответ.code = "000" Тогда
			Элементы.ДекорацияРезультатАктивацииКС.Заголовок = "КС активирована. Клиент может сканировать qr-код и оплачивать";
			ИДПараметров = Ответ.data.paramsId;
			ДатаНачалаПолученияСтатуса = ТекущаяДата();
			ПодключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной", 3);
			КСАктивирована = Истина;
			Элементы.АктивироватьКС.Доступность = Ложь;
		Иначе
			ТекстСообщения = СтрШаблон("Не удалось активировать КС %1. Код ошибки: %2, описание: %3", ИдентификаторКассовойСсылки, Ответ.code, Ответ.message); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;		 
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отправить запрос на активацию КС. "+Ответ);
	КонецЕсли;
	
	//ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной");
КонецПроцедуры 

&НаКлиенте
Процедура ПолучитьСтатусОплатыОсновной() 
	
    Ответ = ИнтеграцияСБПГазпромбанк.ЗапросСтатусаКассовойСсылкиОсн(ИдентификаторКассовойСсылки);
	
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда
		transactionId = Неопределено;
		Ответ.Свойство("transactionId", transactionId);
		Если Ответ.Свойство("data") тогда 
			СтруктураДанных = Ответ.data[0];
			status = Неопределено; 
			trxId = Неопределено;
			СтруктураДанных.Свойство("trxId", trxId);
			СтруктураДанных.Свойство("status", status);
			Если СтруктураДанных.code = "RQ00000" Тогда
				Если status = "ACCEPTED" Тогда
					ИДТранзакцииОплаты = trxId;
					Элементы.ДекорацияРезультатОплаты.Заголовок = "Оплата прошла успешно";
					ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной");
					//ДеактивироватьКСНаСервере(); 
					
					ОбработатьОплатуВозврат(status, trxId);
				ИначеЕсли status = "RECEIVED" или status = "IN_PROGRESS" Тогда
					Элементы.ДекорацияРезультатОплаты.Заголовок = "Операция оплаты обрабатывается. Будет произведен повторный запрос";
				ИначеЕсли status = "NOT_STARTED" Тогда
					Элементы.ДекорацияРезультатОплаты.Заголовок = "Ожидается оплата от клиента. Операция оплаты не начата";
				ИначеЕсли status = "REJECTED" Тогда
					Элементы.ДекорацияРезультатОплаты.Заголовок = "Оплата отклонена"; 
					ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной");
					//ДеактивироватьКСНаСервере();
                    ЗадатьВопросАварийныйВозврат();
					
				КонецЕсли;
	
			Иначе
				ТекстСообщения = СтрШаблон("При получении статуса оплаты по КС получен код: %1, описание: %2", СтруктураДанных.code, СтруктураДанных.message); 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения); 
				ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной");
			КонецЕсли;
		
		Иначе
			ТекстСообщения = СтрШаблон("Не удалось получить статус оплаты по КС %1. Код ошибки: %2, описание: %3", ИдентификаторКассовойСсылки, Ответ.code, Ответ.message); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения); 
			ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной");
		КонецЕсли;
		//sign = Ответ.sign;
		//request_sign = Ответ.request_sign;
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось получить статус оплаты. "+Ответ);
	КонецЕсли;   
	
	Если ДатаНачалаПолученияСтатуса + ВремяЖизниКС*60 < ТекущаяДата() Тогда
		ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыОсновной");
		//ДеактивироватьКС(Неопределено);
		Элементы.ДекорацияРезультатОплаты.Заголовок = "Время жизни КС истекло, но оплата не была совершена. Нужна повторная активация КС";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗадатьВопросАварийныйВозврат()
	Оповещение = Новый ОписаниеОповещения("ВыполнитьАварийныйВозврат", ЭтаФорма);
   	ТекстВопроса = "Оплата была отклонена, рекомендован аварийный возврат. Выполнить?";
   	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);	
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьАварийныйВозврат(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да тогда
		АварийныйВозврат(Неопределено); 
	Иначе
		Закрыть(КодВозвратаДиалога.Отмена);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеактивироватьКС(Команда)
	Результат = ДеактивироватьКСНаСервере();
	Если ТипЗнч(Результат) = Тип("Строка") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат);	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ДеактивироватьКСНаСервере()
	Ответ = ИнтеграцияСБПГазпромбанк.ДеактивацияКассовойСсылки(ИдентификаторКассовойСсылки);
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда 
		Если Ответ.code = "000" Тогда
			Элементы.ДекорацияРезультатОплаты.Заголовок = Элементы.ДекорацияРезультатОплаты.Заголовок + "КС деактивирована";
			КСАктивирована = Ложь;
			Возврат Истина;
		Иначе
			ТекстСообщения = СтрШаблон("Необходимо ручное вмешательство!!! Не удалось деактивировать КС %1. Код ошибки: %2, описание: %3", ИдентификаторКассовойСсылки, Ответ.code, Ответ.message); 
			Возврат ТекстСообщения;
		КонецЕсли;	 
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
		ТекстСообщения = "Необходимо ручное вмешательство!!! Не удалось отправить запрос на деактивацию КС. "+Ответ;
		Возврат ТекстСообщения;
	КонецЕсли;
КонецФункции

