&НаСервере
Процедура ПолучитьСписокБанков()
	Данные = "{""code"": ""000"", ""message"": ""Запрос обработан успешно"", ""transactionId"": ""003665567575"", ""members"": [{""memberId"": ""100000000202"", ""memberName"": ""Norvik Bank"", ""memberNameRus"": ""Норвик Банк""}, {""memberId"": ""100000000201"", ""memberName"": ""BANK KREMLYOVSKIY"", ""memberNameRus"": ""Банк Кремлевский""}, {""memberId"": ""100000000200"", ""memberName"": ""JSCB SLAVIA"", ""memberNameRus"": ""АКБ СЛАВИЯ""}]}";
	Ответ = ИнтеграцияСБПГазпромбанк.ПолучитьУчастниковСБП();
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда
		Если Ответ.Свойство("members") Тогда
			Участники = Ответ.members;
			Для каждого Участник из Участники Цикл
				Элементы.БанкПолучатель.СписокВыбора.Добавить(Участник.memberId, Участник.memberNameRus);
					
			КонецЦикла;
		Иначе	
			 ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Список банков участников СБП пустой. Выполнить возврат можно будет только в банк, который участвовал в оплате ");
		КонецЕсли;
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось получить банки участники СБП. Выполнить возврат можно будет только в банк, который участвовал в оплате "+Ответ);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьСтатусОплатыРасш()

	Ответ = ИнтеграцияСБПГазпромбанк.ЗапросСтатусаКассовойСсылкиРасш(ИдентификаторКассовойСсылки, ИДПараметров);
	
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда
		Если Ответ.Свойство("data") тогда
			cashRegisterQrcStatus = "";
			trxStatus = "";  
			amount = 0;
			Ответ.data.Свойство("cashRegisterQrcStatus", cashRegisterQrcStatus); 
			Ответ.data.Свойство("trxStatus", trxStatus);
			Ответ.data.Свойство("amount", amount); 
			//timestamp = Неопределено; 
			//trxId = Неопределено;
			//payerId = Неопределено;
			//kzo = Неопределено; 
			transactionId = Неопределено;
			Ответ.data.Свойство("transactionId", transactionId);
			//Ответ.data.Свойство("timestamp", timestamp); 
			//Ответ.data.Свойство("trxId", trxId);
			//Ответ.data.Свойство("payerId", payerId);
			//Ответ.data.Свойство("kzo", kzo);
			
			Если trxStatus = "ACWP" Тогда
				Если  cashRegisterQrcStatus = "DEACTIVATED" Тогда
				    Элементы.ДекорацияРезультатОплаты.Заголовок = "Оплата прошла успешно. КС деактивирована";
				Иначе
				    Элементы.ДекорацияРезультатОплаты.Заголовок = "Оплата прошла успешно. ";
					//ДеактивироватьКСНаСервере();
				КонецЕсли;
				ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыРасш");
				//ОбработатьОплатуВозврат(trxStatus, transactionId, amount);
			ИначеЕсли trxStatus = "NTST" Тогда
				Если  cashRegisterQrcStatus = "DEACTIVATED" Тогда
				    Элементы.ДекорацияРезультатОплаты.Заголовок = "Время жизни КС истекло, но оплата не была совершена. Нужна повторная активация КС";
					ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыРасш");
				ИначеЕсли cashRegisterQrcStatus = "WAITING_PAYMENT" тогда
				    Элементы.ДекорацияРезультатОплаты.Заголовок = "Ожидается оплата от клиента. Операция оплаты не начата";  
				Иначе
					Элементы.ДекорацияРезультатОплаты.Заголовок = cashRegisterQrcStatus + " " + trxStatus;
				КонецЕсли;
			ИначеЕсли trxStatus = "RJCT" Тогда
				Если  cashRegisterQrcStatus = "DEACTIVATED" Тогда
				    Элементы.ДекорацияРезультатОплаты.Заголовок = "Оплата отклонена. КС деактивирована"; 
				Иначе
					Элементы.ДекорацияРезультатОплаты.Заголовок = cashRegisterQrcStatus + " " + trxStatus+ " Оплата отклонена. ";
				КонецЕсли;
				ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыРасш");
			ИначеЕсли trxStatus = "RCVD" Тогда
				Если  cashRegisterQrcStatus = "IN_PROGRESS" Тогда
				    Элементы.ДекорацияРезультатОплаты.Заголовок = "Операция оплаты обрабатывается. Будет произведен повторный запрос";
				Иначе
					Элементы.ДекорацияРезультатОплаты.Заголовок = cashRegisterQrcStatus + " " + trxStatus;
				КонецЕсли;
			Иначе
				ТекстСообщения = СтрШаблон("Не получен статус транзакции по КС %1. Необходимо ручное разбирательство", ИдентификаторКассовойСсылки); 
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			
			КонецЕсли;
						

		Иначе
			ТекстСообщения = СтрШаблон("Не удалось получить статус оплаты по КС %1. Код ошибки: %2, описание: %3", ИдентификаторКассовойСсылки, Ответ.code, Ответ.message); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения); 
			ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыРасш");
		КонецЕсли;
		 
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отправить запрос на получение статуса оплаты. "+Ответ);
		ОтключитьОбработчикОжидания("ПолучитьСтатусОплатыРасш");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьДоговорПодключения() 
	СтруктураНастроек = ИнтеграцияСБПГазпромбанк.ПолучитьСтруктуруХранилищаНастроек();
	Если СтруктураНастроек.Свойство("ДоговорПодключения") Тогда
		ДоговорСБП = СтруктураНастроек.ДоговорПодключения;
	Иначе
		ДоговорСБП = Справочники.ДоговорыЭквайринга.НайтиПоНаименованию("тест сбп");
	КонецЕсли;
	ТерминалСБП = ИнтеграцияСБПГазпромбанк.ПолучитьТерминалСБППоУмолчанию();
	ДоговорСБП = ТерминалСБП.Владелец;
	
	Возврат ДоговорСБП;
КонецФункции

