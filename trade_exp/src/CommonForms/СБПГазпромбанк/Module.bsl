#Область Возвраты                                                                                                                    

&НаКлиенте
Процедура АварийныйВозврат(Команда)
	АварийныйВозвратНаСервере();
	Если УспешныйВозврат Тогда
		Закрыть();
	КонецЕсли;	
КонецПроцедуры 

&НаСервере
Процедура АварийныйВозвратНаСервере() 

	Ответ = ИнтеграцияСБПГазпромбанк.Rollback(ИдентификаторКассовойСсылки);
	
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда
		//transactionId = "";
		//Ответ.Свойство("transactionId",transactionId);
		Если Ответ.Свойство("transactionId") Тогда  
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Аварийный возврат в процессе. Получаем статус операции");
			ПолучитьСтатусОперацииНаСервере(Ответ.transactionId);
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Не получен transactionId. Необходимо повторить Аварийный возврат. Код ответа: %1, описание: %2", Ответ.code, Ответ.message));
		КонецЕсли;	
		
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Возврат не прошел. "+Ответ);
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
Процедура ПолучитьСтатусОперацииНаСервере(transactionId)
	Ответ = ИнтеграцияСБПГазпромбанк.ПолучениеИнформацииОВозврате(transactionId);
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда
		Если Ответ.Свойство("transactionId") тогда
			ИДТранзакцииВозврата = Ответ.transactionId; //транзакция итога возврата 
			type = Ответ.type;
			status = Ответ.status;
			Если status = "DRAFT" Тогда
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция инициирована"; 	
			ИначеЕсли status = "IN_PROGRESS" Тогда 
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция выполняется";
			ИначеЕсли status = "PERFORMED" Тогда 
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция выполнена успешно";
				ИДТранзакцииОплаты = ""; 
				//ИДТранзакцииВозврата = "";
				УспешныйВозврат = Истина;
				//пробивать чек 
			ИначеЕсли status = "CANCELLED" Тогда 
	            Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция отменена";
			ИначеЕсли status = "ERROR" Тогда 	
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Не найден QRC, по которому поступил запрос на оплату";
			ИначеЕсли status = "ERROR_CHECK" Тогда 	
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция не выполнена, не пройден /confirm";
			ИначеЕсли status = "INCOMPLETE" Тогда 	
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Пришел запрос на подтверждение операции, которая не найдена в БД";
			ИначеЕсли status = "ERROR_EXECUTE" Тогда 
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция не выполнена, не пройден /execute";
			ИначеЕсли status = "ERROR_MANUAL_HANDLING" Тогда 
				Элементы.ДекорацияРезультатВозврата.Заголовок = "Операция требует ручного разбора";
			КонецЕсли;
		Иначе
			ТекстСообщения = СтрШаблон("Не удалось получить статус возврата. Код ошибки: %1, описание: %2", Ответ.code, Ответ.message); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		//sign = Ответ.sign;
		//request_sign = Ответ.request_sign;
	ИначеЕсли ТипЗнч(Ответ) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Возврат не прошел. "+Ответ);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ИнициироватьВозвратОплаты(Команда)
	Элементы.ИнициироватьВозврат.Доступность = Ложь;
	ИнициироватьВозвратОплатыНаСервере();	
	Если УспешныйВозврат Тогда
		ОбработатьОплатуВозврат("ACCEPTED", ИДТранзакцииВозврата);
	КонецЕсли;
КонецПроцедуры 

&НаСервере
Процедура ИнициироватьВозвратОплатыНаСервере()
	
	ДанныеЗаполнения = Новый Структура;
	ДанныеЗаполнения.Вставить("transactionId", ИДТранзакцииОплаты); 
	ДанныеЗаполнения.Вставить("amount", Формат(КОплате*100, "ЧГ="));
	Если ЗначениеЗаполнено(БанкПолучатель) Тогда
		ДанныеЗаполнения.Вставить("recipientBankId", БанкПолучатель);
	КонецЕсли;
	Если ЗначениеЗаполнено(КомментарийВозврата) Тогда
		ДанныеЗаполнения.Вставить("comment", КомментарийВозврата);     //комментарий возврата
	КонецЕсли;

	ОтветЧерновик = ИнтеграцияСБПГазпромбанк.ПодготовкаВозврата(ДанныеЗаполнения);  
	
	Если ТипЗнч(ОтветЧерновик) = Тип("Структура") Тогда
		Если ОтветЧерновик.Свойство("transactionId") тогда
			Элементы.ДекорацияРезультатВозврата.Заголовок = "Возврат инициирован. Ожидаем подтвержение возврата";
			ИДТранзакцииПодготовкиВозврата = ОтветЧерновик.transactionId; //транзакция подготовки возврата 
			ПодтвердитьВозвратОплатыНаСервере();
		Иначе
			ТекстСообщения = СтрШаблон("Не удалось инициировать возврат. Код ошибки: %1, описание: %2", ОтветЧерновик.code, ОтветЧерновик.message); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);

		КонецЕсли;
		//sign = Ответ.sign;
		//request_sign = Ответ.request_sign;
	ИначеЕсли ТипЗнч(ОтветЧерновик) = Тип("Строка") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Возврат не инициирован. "+ОтветЧерновик);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьВозвратОплаты(Команда)
	ПодтвердитьВозвратОплатыНаСервере();
	//
КонецПроцедуры 

&НаСервере
Процедура ПодтвердитьВозвратОплатыНаСервере()
	
	ОтветПодтверждение = ИнтеграцияСБПГазпромбанк.ПодтверждениеВозврата(ИДТранзакцииПодготовкиВозврата);
			
	Если ТипЗнч(ОтветПодтверждение) = Тип("Структура") Тогда
		Если ОтветПодтверждение.code = "000" тогда 
			Элементы.ДекорацияРезультатВозврата.Заголовок = "Возврат подтвержден. Ожидаем итоговый статус возврата";
			ИДТранзакцииВозврата = ОтветПодтверждение.transactionId;
			ПолучитьСтатусОперацииНаСервере(ИДТранзакцииВозврата);		
		Иначе
			ТекстСообщения = СтрШаблон("Не удалось подтвердить возврат. Код ошибки: %1, описание: %2", ОтветПодтверждение.code, ОтветПодтверждение.message); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		//sign = Ответ.sign;
		//request_sign = Ответ.request_sign;
	ИначеЕсли ТипЗнч(ОтветПодтверждение) = Тип("Строка") Тогда
	    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Возврат не подтвержден. "+ОтветПодтверждение);
	КонецЕсли;	
КонецПроцедуры	

