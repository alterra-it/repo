&НаКлиенте
Процедура АвтоматическиОбработать(Команда)
	
	ЗаполнитьПоступлениеНаСервере(Ложь);
	ЗаполнитьНедостачиНаСервере();
    ЗаполнитьБракНаСервере();
		
	Если ТоварыКПоступлению.Количество() > 0 Тогда
		ссылкаНаДок = ПолучитьСозданныйДокумент("Поступление");
		ОткрытьЗначение(ссылкаНаДок);
	Иначе
		Сообщить("Пустая табличная часть!");
	КонецЕсли;

	Если ТоварыКПеремещениюНедостачи.Количество() > 0 Тогда
		ссылкаНаДок = ПолучитьСозданныйДокумент("ПеремещениеНедостачи");
		ОткрытьЗначение(ссылкаНаДок);
	Иначе
		Сообщить("Пустая табличная часть!");
	КонецЕсли;

	Если ТоварыКПеремещениюБрак.Количество() > 0 Тогда
		ссылкаНаДок = ПолучитьСозданныйДокумент("ПеремещениеБрак");
		ОткрытьЗначение(ссылкаНаДок);
	Иначе
		Сообщить("Пустая табличная часть!");
	КонецЕсли;

	Закрыть(Ложь);
КонецПроцедуры


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Элементы.СозданиеПриобретениеТоваровИУслуг.Видимость=Истина;
		Элементы.ТоварыИзменитьПеремещение.Видимость=Ложь;
	ИначеЕсли ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Элементы.СозданиеПриобретениеТоваровИУслуг.Видимость=Ложь;
		Элементы.ТоварыИзменитьПеремещение.Видимость=Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПеремещение(Команда)
	ЗаполнитьТаблицу();
	Закрыть(ТоварыИзменитьВПеремещении);
КонецПроцедуры

Функция ПолучитьСозданныйДокумент(ТипДокумента)
Если ТипДокумента = "Поступление" Тогда
ТЗ = ТоварыКПоступлению.Выгрузить();
ссылкаНаДок = Альтерра_СкладСервер.СоздатьПриобретениеТоваровУслуг(ДокументОснование, ТЗ);
