&НаКлиенте
Процедура ЗаполнитьКоличествоФактПоПлану(Команда)
	 ВывестиВопросОбработкаВыбранныхИлиВсех("ЗаполнениеКоличестваФактическогоПоПлановому");
	 ЗаполнитьРасхождения();
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВопросОбработкаВыбранныхИлиВсех(ВыбранныйВариантДействий)
	
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбранныхИлиВсех", ЭтотОбъект,ВыбранныйВариантДействий);
	
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить(КодВозвратаДиалога.Нет,"Выбранные");
	СписокЗначений.Добавить(КодВозвратаДиалога.Да,"Все");
	СписокЗначений.Добавить(КодВозвратаДиалога.Отмена,"Отменить");
	
    ПоказатьВопрос(Оповещение,"Обработать выбранные строки или все?",СписокЗначений, 0,КодВозвратаДиалога.Да); 
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбранныхИлиВсех(Результат, Параметры) Экспорт
	
	ОбработкаТолькоВыбранных = Ложь;
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработатьВыбранныйВариантОформления(ОбработкаТолькоВыбранных,Параметры);
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		ОбработкаТолькоВыбранных = Истина;
		ОбработатьВыбранныйВариантОформления(ОбработкаТолькоВыбранных,Параметры);		
	КонецЕсли;	
 
КонецПроцедуры

Процедура ОбработатьВыбранныйВариантОформления(ОбработкаТолькоВыбранных,ВыбранныйВариантДействий)
	
	Если ВыбранныйВариантДействий = "ЗаполнениеКоличестваФактическогоПоПлановому" Тогда  
		Для каждого Строка из Товары Цикл
			Если ОбработкаТолькоВыбранных Тогда
				Если Строка.Выбрать Тогда
					Строка.КоличествоФакт = Строка.Количество;
				КонецЕсли;
			Иначе
				Строка.КоличествоФакт = Строка.Количество;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если ВыбранныйВариантДействий = "ОчищениеКоличестваФакт" Тогда  
		Для каждого Строка из Товары Цикл
			Если ОбработкаТолькоВыбранных Тогда
				Если Строка.Выбрать Тогда
					Строка.КоличествоФакт = 0;
				КонецЕсли;
			Иначе
				Строка.КоличествоФакт = 0;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ВыбранныйВариантДействий = "ОчищениеКоличестваБрак" Тогда  
		Для каждого Строка из Товары Цикл
			Если ОбработкаТолькоВыбранных Тогда
				Если Строка.Выбрать Тогда
					Строка.КоличествоБрак = 0;
				КонецЕсли;
			Иначе
				Строка.КоличествоБрак = 0;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;


КонецПроцедуры

&НаКлиенте
Процедура ОчиститьКоличествоФакт(Команда)
	ВывестиВопросОбработкаВыбранныхИлиВсех("ОчищениеКоличестваФакт");
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьРасхожденияПланаИФакта()
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	Если ТекущаяСтрока.Количество > ТекущаяСтрока.КоличествоФакт Тогда
			ТекущаяСтрока.Расхождение = ТекущаяСтрока.Количество - ТекущаяСтрока.КоличествоФакт;
			ТекущаяСтрока.Описание = "Недостачи";
		ИначеЕсли ТекущаяСтрока.Количество < ТекущаяСтрока.КоличествоФакт Тогда
			ТекущаяСтрока.Расхождение = ТекущаяСтрока.КоличествоФакт - ТекущаяСтрока.Количество;
			ТекущаяСтрока.Описание = "Излишки";
		Иначе
			ТекущаяСтрока.Расхождение = 0;
			ТекущаяСтрока.Описание = "";
	КонецЕсли;

	Если ТекущаяСтрока.КоличествоБрак > 0 Тогда
			ТекущаяСтрока.Описание = ТекущаяСтрока.Описание + ?(ПустаяСтрока(ТекущаяСтрока.Описание) = Истина, "Брак", ", Брак");
	КонецЕсли;
	
КонецПроцедуры


