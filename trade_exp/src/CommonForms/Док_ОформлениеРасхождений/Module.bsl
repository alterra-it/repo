Процедура ЗаполнитьТаблицу()
	
	Если ДокументОснование.ПеремещениеПоЗаказам Тогда
		Для каждого Строка из Товары Цикл
			ПараметрыОтбора = Новый Структура("КодСтроки",Строка.КодСтроки);
			НайденныеСтроки = ДокументОснование.Товары.НайтиСтроки(ПараметрыОтбора);
			Если НайденныеСтроки.Количество()<>0 Тогда
				Для каждого НайденнаяСтрока из НайденныеСтроки Цикл
					Если Строка.КоличествоФакт > 0 Тогда
						Если НайденнаяСтрока.Количество <= Строка.КоличествоФакт Тогда
                            НоваяСтрока1 = ТоварыИзменитьВПеремещении.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока1,НайденнаяСтрока);
