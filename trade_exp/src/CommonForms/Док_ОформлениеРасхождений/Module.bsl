Процедура ЗаполнитьБракНаСервере()
	ТоварыКПеремещениюБрак.Очистить();
	
	Для каждого Строка из Товары Цикл
		
		Если Строка.КоличествоБрак > 0 Тогда
			
			НоваяСтрока = ТоварыКПеремещениюБрак.Добавить();
            ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
			НоваяСтрока.Количество = Строка.КоличествоБрак;
		
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

