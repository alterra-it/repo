
&НаКлиенте
Процедура ТоварыКоличествоФактПриИзменении(Элемент)
ПересчитатьРасхожденияПланаИФакта();	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Документ") Тогда 
		ДокументОснование = Параметры.Документ;
	КонецЕсли;

	Товары.Загрузить(ЗаполнитьТабличнуюЧасть(ДокументОснование));
	
	ЗаполнитьРасхождения();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаполнитьТабличнуюЧасть(ДокументСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПоставщикуТовары.КодСтроки КАК КодСтроки,
		|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
		|	ЗаказПоставщикуТовары.Характеристика КАК Характеристика,
		|	ЗаказПоставщикуТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	0 КАК КоличествоФакт,
		|	0 КАК КоличествоБрак
		|ПОМЕСТИТЬ ВТ_ТоварыПоОснованию
		|ИЗ
		|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
		|ГДЕ
		|	ЗаказПоставщикуТовары.Ссылка = &Ссылка
		|	И ЗаказПоставщикуТовары.Отменено = ЛОЖЬ
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.КодСтроки,
		|	ПеремещениеТоваровТовары.Номенклатура,
		|	ПеремещениеТоваровТовары.Характеристика,
		|	ПеремещениеТоваровТовары.КоличествоУпаковок,
		|	0,
		|	0
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка = &Ссылка
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТоварыПоОснованию.КодСтроки КАК КодСтроки,
		|	ВТ_ТоварыПоОснованию.Номенклатура КАК Номенклатура,
		|	ВТ_ТоварыПоОснованию.Характеристика КАК Характеристика,
		|	СУММА(ВТ_ТоварыПоОснованию.КоличествоУпаковок) КАК Количество,
		|	СУММА(ВТ_ТоварыПоОснованию.КоличествоФакт) КАК КоличествоФакт,
		|	СУММА(ВТ_ТоварыПоОснованию.КоличествоБрак) КАК КоличествоБрак
		|ИЗ
		|	ВТ_ТоварыПоОснованию КАК ВТ_ТоварыПоОснованию
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ТоварыПоОснованию.КодСтроки,
		|	ВТ_ТоварыПоОснованию.Номенклатура,
		|	ВТ_ТоварыПоОснованию.Характеристика";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	
	
	Возврат РезультатЗапроса;	
	
КонецФункции

