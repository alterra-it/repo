&НаКлиенте
Процедура СоздатьПриобретениеТоваровИУслуг(Команда)
	
	Если ТоварыКПоступлению.Количество() > 0 Тогда
		ссылкаНаДок = ПолучитьСозданныйДокумент("Поступление");
		ОткрытьЗначение(ссылкаНаДок);
	Иначе
		Сообщить("Пустая табличная часть!");
	КонецЕсли;
		
КонецПроцедуры

Процедура ПолучитьТЗТовары(ИмяТабличнаяЧасть)
ТоварыИзменитьВПеремещении.Очистить();	
	
Если ИмяТабличнаяЧасть = "ТоварыКПоступлению" Тогда	
ТоварыИзменитьВПеремещении.Загрузить(ТоварыКПоступлению.Выгрузить());
КонецЕсли;

Если ИмяТабличнаяЧасть = "ТоварыКПеремещениюНедостачи" Тогда
ТоварыИзменитьВПеремещении.Загрузить(ТоварыКПеремещениюНедостачи.Выгрузить());
КонецЕсли;

Если ИмяТабличнаяЧасть = "Товары" Тогда
ТоварыИзменитьВПеремещении.Загрузить(Товары.Выгрузить());
КонецЕсли;

Если ИмяТабличнаяЧасть = "ТоварыКПеремещениюБрак" Тогда
ТоварыИзменитьВПеремещении.Загрузить(ТоварыКПеремещениюБрак.Выгрузить());
КонецЕсли;

КонецПроцедуры
