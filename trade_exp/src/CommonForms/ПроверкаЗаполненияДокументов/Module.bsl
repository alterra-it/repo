&НаКлиенте
Процедура Док_СохранитьТЧПосле(Команда)
	СохранитьТЧВХранилищеНастроекКлиент();
КонецПроцедуры

&НаКлиенте
Процедура СохранитьТЧВХранилищеНастроекКлиент()
	
	Если Элементы.Страницы.ТекущаяСтраница.Имя = "СтраницаПроверка" Тогда
		СохранитьТЧВХранилищеНастроек();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьТЧВХранилищеНастроек()
	
	КлючОбъекта = ТипЗнч(Ссылка);
	КлючНастроек = Ссылка.УникальныйИдентификатор();
	ДанныеТовары = Товары.Выгрузить();
	ИмяПользователя = ИмяПользователя();
	ХранилищеОбщихНастроек.Сохранить(КлючОбъекта, КлючНастроек, ДанныеТовары, , ИмяПользователя);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьТЧИзХранилищаНастроек()
	
	Попытка
		КлючОбъекта  = ТипЗнч(Ссылка);
		КлючНастроек = Ссылка.УникальныйИдентификатор();
		ИмяПользователя = ИмяПользователя();
		СтруктураНастроек = ХранилищеОбщихНастроек.Загрузить(КлючОбъекта,КлючНастроек, ,ИмяПользователя);
		ЭтотОбъект.Товары.Загрузить(СтруктураНастроек);
	Исключение
		Сообщение = Новый СообщениеПользователю();
		Сообщение.Текст = ("Для " + ИмяПользователя + ",нет сохраненных файлов в документе " + Ссылка);
		Сообщение.Сообщить();
		
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура Док_ЗагрузитьТЧПосле(Команда)
	ЗагрузитьТЧИзХранилищаНастроек();
КонецПроцедуры

