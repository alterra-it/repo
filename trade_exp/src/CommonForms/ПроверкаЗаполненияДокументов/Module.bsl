	Если ВремяНачалаПриемки = '00010101' Тогда
		ВремяНачалаПриемки = ТекущаяДата();
	КонецЕсли;
	//Альтерра +
КонецПроцедуры

&НаСервере
&Вместо("ПоискПоШтрихкодуЗавершениеНаСервере")
Процедура Док_ПоискПоШтрихкодуЗавершениеНаСервере(ДополнительныеПараметры)
	
	СобытияФорм.ПриИзмененииЭлемента(ЭтотОбъект, "ОбработатьДанныеШтрихкода", ДополнительныеПараметры);
	ПослеОбработкиШтрихкодов(ДополнительныеПараметры);
