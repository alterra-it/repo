	ДополнительныеПараметры.РезультатОбработкиШтрихкода.ИзмененныеСтроки  = Новый Массив;
	//Альтерра +
	Если ВремяНачалаПриемки = '00010101' Тогда
		ВремяНачалаПриемки = ТекущаяДата();
	КонецЕсли;
	//Альтерра +
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыКоличествоУпаковокФактПриИзмененииПосле(Элемент)

	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;	
	ТекущиеДанные.СпособВводаКоличества = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Клавиатура");	
	
	Если ВремяНачалаПриемки = '00010101' Тогда
		ВремяНачалаПриемки = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыПриИзмененииПосле(Элемент)
	
	Если ВремяНачалаПриемки = '00010101' Тогда
		ВремяНачалаПриемки = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры
