
&НаКлиенте
Процедура Сегодня(Команда)
	ДатаОтгрузки = ТекущаяДата();
	Закрыть(ДатаОтгрузки);
КонецПроцедуры

&НаКлиенте
Процедура Завтра(Команда)
	ДатаОтгрузки = НачалоДня(ТекущаяДата()-43200);
	Закрыть(ДатаОтгрузки);
КонецПроцедуры

&НаКлиенте
Процедура КДате(Команда)
	Закрыть(ДатаОтгрузки);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если ДатаОтгрузки = Дата(1, 1, 1) Тогда
		Сообщить("Дата отгрузки не заполнена!");
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("ДатаОтгрузкиСамовывоз") Тогда
		ДатаОтгрузки = Параметры.ДатаОтгрузкиСамовывоз
	КонецЕсли;
КонецПроцедуры


