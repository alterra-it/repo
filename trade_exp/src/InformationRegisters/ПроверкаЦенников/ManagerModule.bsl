&НаСервере
Процедура ЗаписьВРегистре(Документ) Экспорт
	УстановитьПривилегированныйРежим(Истина); 
	Запрос = Новый Запрос;
	ЗапросТекст = ПолучитьЗапрос(Документ);   
	
	Если не ЗапросТекст = Неопределено Тогда 
	 	
		Запрос.Текст = ЗапросТекст;  
		Запрос.УстановитьПараметр("Документ", Документ);
		
		Результат = Запрос.Выполнить(); 
		
		Выборка = Результат.Выбрать(); 
		
		ПроверкаЦенников = РегистрыСведений.ПроверкаЦенников;
		НаборЗапись = ПроверкаЦенников.СоздатьНаборЗаписей();
			 
		НаборЗапись.Отбор.Документ.Установить(Документ);
		НаборЗапись.Прочитать();
	    НаборЗапись.Очистить();
		
		Пока Выборка.Следующий() Цикл
			Запись = НаборЗапись.Добавить();
			Запись.Период = Документ.Дата;
			Запись.Документ = Документ;
			Запись.Номенклатура = Выборка.Номенклатура; 
			Запись.Характеристика = Выборка.Характеристика;
			Запись.Склад = Выборка.Склад;  
			Запись.Сотрудник = Выборка.Сотрудник; 
			Запись.Проверено = Выборка.Проверено;
			Запись.Просчитано = Выборка.Просчитано; 
			Запись.ЦенникиПроверены = Выборка.ЦенникиПроверены;  
		КонецЦикла;
		НаборЗапись.Записать(); 
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь); 


КонецПроцедуры

&НаСервере
Функция ПолучитьЗапрос(документ) 
	
	Если ТипЗнч(документ) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
		ТекстЗапроса = "ВЫБРАТЬ Различные
						|	ПересчетТоваровТовары.Номенклатура КАК Номенклатура,
						|	ПересчетТоваровТовары.Характеристика КАК Характеристика,
						|	ПересчетТоваров.Склад КАК Склад,
						|	ПересчетТоваров.Ответственный КАК Сотрудник,
						|	1 КАК Просчитано,
						|	0 КАК Проверено,
						|	0 КАК ЦенникиПроверены
						|ИЗ
						|	Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары
						|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПересчетТоваров КАК ПересчетТоваров
						|		ПО (ПересчетТоваровТовары.Ссылка = ПересчетТоваров.Ссылка)
						|ГДЕ
						|	ПересчетТоваров.Ссылка = &Документ";
	ИначеЕсли ТипЗнч(документ) = Тип("ДокументСсылка.ПроверкаЦенников")
			  И Документ.ВидПроверки = Перечисления.ВидПроверкиЦенников.ПоПлану Тогда 
		ТекстЗапроса = "ВЫБРАТЬ Различные
		               |	ПроверкаЦенниковТовары.Номенклатура КАК Номенклатура,
		               |	NULL КАК Характеристика,
		               |	ПроверкаЦенников.Склад КАК Склад,
		               |	ПроверкаЦенников.Ответственный КАК Сотрудник,
		               |	1 КАК Проверено,
		               |	0 КАК Просчитано,
					   |	0 КАК ЦенникиПроверены
		               |ИЗ
		               |	Документ.ПроверкаЦенников.Товары КАК ПроверкаЦенниковТовары
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПроверкаЦенников КАК ПроверкаЦенников
		               |		ПО ПроверкаЦенниковТовары.Ссылка = ПроверкаЦенников.Ссылка
		               |ГДЕ
		               |	ПроверкаЦенников.Ссылка = &Документ
		               |	И (ПроверкаЦенниковТовары.Проверено = ИСТИНА)";
	ИначеЕсли ТипЗнч(документ) = Тип("ДокументСсылка.ПроверкаЦенников")
			  И Документ.ВидПроверки = Перечисления.ВидПроверкиЦенников.ПоПереоценке Тогда 
		ТекстЗапроса = "ВЫБРАТЬ Различные
		               |	ПроверкаЦенниковТовары.Номенклатура КАК Номенклатура,
		               |	NULL КАК Характеристика,
		               |	ПроверкаЦенников.Склад КАК Склад,
		               |	ПроверкаЦенников.Ответственный КАК Сотрудник,
		               |	0 КАК Проверено,
		               |	0 КАК Просчитано,
					   |	1 КАК ЦенникиПроверены
		               |ИЗ
		               |	Документ.ПроверкаЦенников.Товары КАК ПроверкаЦенниковТовары
		               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПроверкаЦенников КАК ПроверкаЦенников
		               |		ПО ПроверкаЦенниковТовары.Ссылка = ПроверкаЦенников.Ссылка
		               |ГДЕ
		               |	ПроверкаЦенников.Ссылка = &Документ
		               |	И (ПроверкаЦенниковТовары.Проверено = ИСТИНА)";
	Иначе 
		ТекстЗапроса = Неопределено; 
	КонецЕсли; 
	Возврат ТекстЗапроса; 

	
КонецФункции