
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТемыАкадемии.Ссылка КАК ТипТемы
		|ПОМЕСТИТЬ ВТ_ТипыТем
		|ИЗ
		|	Справочник.ТемыАкадемии КАК ТемыАкадемии
		|ГДЕ
		|	(ТемыАкадемии.Наименование = ""Инструкции и стандарты""
		|			ИЛИ ТемыАкадемии.Наименование = ""Изучение ассортимента"")
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	АкадемияДолжностьЗакрепленныйМатериал.Отдел КАК Отдел,
		|	АкадемияДолжностьЗакрепленныйМатериал.Должность КАК Должность,
		|	АкадемияДолжностьЗакрепленныйМатериал.Тема.ТипТемы КАК ТипТемы,
		|	ВЫБОР
		|		КОГДА АкадемияДолжностьЗакрепленныйМатериал.Тема.Родитель В
		|				(ВЫБРАТЬ
		|					ВТ_ТипыТем.ТипТемы
		|				ИЗ
		|					ВТ_ТипыТем)
		|			ТОГДА АкадемияДолжностьЗакрепленныйМатериал.Тема
		|	КОНЕЦ КАК ГруппаТемы
		|ПОМЕСТИТЬ ВТ_ГруппыТем
		|ИЗ
		|	РегистрСведений.АкадемияДолжностьЗакрепленныйМатериал КАК АкадемияДолжностьЗакрепленныйМатериал
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_ГруппыТем.Отдел КАК Отдел,
		|	ВТ_ГруппыТем.Должность КАК Должность,
		|	ВТ_ГруппыТем.ТипТемы КАК ТипТемы,
		|	ВТ_ГруппыТем.ГруппаТемы КАК ГруппаТемы,
		|	АкадемияДолжностьЗакрепленныйМатериал.Тема КАК Тема
		|ПОМЕСТИТЬ ВТ_Темы
		|ИЗ
		|	ВТ_ГруппыТем КАК ВТ_ГруппыТем
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АкадемияДолжностьЗакрепленныйМатериал КАК АкадемияДолжностьЗакрепленныйМатериал
		|		ПО ВТ_ГруппыТем.ГруппаТемы = АкадемияДолжностьЗакрепленныйМатериал.Тема.Родитель
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_Темы.Отдел КАК Отдел,
		|	ВТ_Темы.Должность КАК Должность,
		|	ВТ_Темы.ТипТемы КАК ТипТемы,
		|	ВТ_Темы.ГруппаТемы КАК ГруппаТемы,
		|	ВТ_Темы.Тема КАК Тема,
		|	АкадемияДолжностьЗакрепленныйМатериал.Тема КАК Подтема
		|ИЗ
		|	ВТ_Темы КАК ВТ_Темы
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АкадемияДолжностьЗакрепленныйМатериал КАК АкадемияДолжностьЗакрепленныйМатериал
		|		ПО ВТ_Темы.Тема = АкадемияДолжностьЗакрепленныйМатериал.Тема.Родитель
		|
		|УПОРЯДОЧИТЬ ПО
		|	Отдел,
		|	Должность,
		|	ТипТемы,
		|	ГруппаТемы,
		|	Тема,
		|	Подтема
		|ИТОГИ ПО
		|	Отдел,
		|	Должность";
	
    ЗначениеВРеквизитФормы(Запрос.Выполнить().Выгрузить(), "ТЗ");
	
КонецПроцедуры
