#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда


&НаСервере
Процедура ОбновитьЗаписьВРегистре(Ордер) Экспорт 
	УстановитьПривилегированныйРежим(Истина); 
	
	//Сначала удаляем принудительно запись, чтобы не было дублей или лишних записей
	УдалитьЗаписьВРегистре(Ордер); 
	
	Запрос = Новый Запрос;
 	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура КАК Номенклатура,
	|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика КАК Характеристика,
	|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Назначение КАК Назначение,
	|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Количество КАК Количество,
	|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка,
	|	РасходныйОрдерНаТовары.Склад КАК Склад,
	|	РасходныйОрдерНаТовары.ЯчейкаПромежуточногоХранения КАК ЯчейкаПромежуточногоХранения,
	|	РасходныйОрдерНаТовары.Статус КАК Статус
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ОтгружаемыеТовары КАК РасходныйОрдерНаТоварыОтгружаемыеТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	|		ПО (РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка = РасходныйОрдерНаТовары.Ссылка)
	|ГДЕ
	|	РасходныйОрдерНаТовары.Ссылка = &Ордер
	|	И не РасходныйОрдерНаТовары.ЯчейкаПромежуточногоХранения = Значение(Справочник.СкладскиеЯчейки.ПустаяСсылка)
	|	 И РасходныйОрдерНаТовары.Статус = Значение(Перечисление.СтатусыРасходныхОрдеров.КОтгрузке)
	|	И РасходныйОрдерНаТовары.Проведен = Истина"; 
	Запрос.УстановитьПараметр("Ордер", Ордер);
	
	Результат = Запрос.Выполнить(); 
	
	Выборка = Результат.Выбрать(); 
	
	Пока Выборка.Следующий() Цикл  //Ордер в япх
		
		НоваяЗапись = РегистрыСведений.ТоварыВЯчейкеПромежуточногоХранения.СоздатьМенеджерЗаписи();
    	НоваяЗапись.Ордер = Ордер;
    	НоваяЗапись.Номенклатура = Выборка.Номенклатура;
		НоваяЗапись.Характеристика = Выборка.Характеристика;
		НоваяЗапись.Назначение = Выборка.Назначение;
		НоваяЗапись.Склад = Выборка.Склад;
		НоваяЗапись.ЯПХ = Выборка.ЯчейкаПромежуточногоХранения; 
		НоваяЗапись.Количество = Выборка.Количество;
    	НоваяЗапись.Записать(Истина);
		
	КонецЦикла; 
	
	УстановитьПривилегированныйРежим(Ложь); 


КонецПроцедуры



&НаСервере
Процедура УдалитьЗаписьВРегистре(Ордер) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ТоварыВЯчейкеПромежуточногоХранения = РегистрыСведений.ТоварыВЯчейкеПромежуточногоХранения;
	НаборЗапись = ТоварыВЯчейкеПромежуточногоХранения.СоздатьНаборЗаписей();
			 
	НаборЗапись.Отбор.Ордер.Установить(Ордер);
	НаборЗапись.Записать();
   
	УстановитьПривилегированныйРежим(Ложь);  
КонецПроцедуры

