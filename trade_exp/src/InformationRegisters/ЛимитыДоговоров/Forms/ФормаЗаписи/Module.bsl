&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	если Параметры.Свойство("ЗаполнениеПоДоговору") тогда	
		Элементы.Договор.Видимость=ложь;
		ЗаполнитьЗначенияСвойств(Запись,Параметры);
		если не значениезаполнено(Запись.Ответственный) тогда
			Запись.Ответственный=Пользователи.ТекущийПользователь();
		конецесли;	
	конецесли;
	если значениезаполнено(Запись.Договор) тогда
		Контрагент=Запись.Договор.Контрагент;
		Организация=Запись.Договор.Организация;
	конецесли;
	если не значениезаполнено(Запись.Ответственный) тогда
		 Запись.Ответственный=Пользователи.ТекущийПользователь();
	конецесли;
	ОтобразитьОформлениеПериод();
КонецПроцедуры

&НаСервере
Процедура ОтобразитьОформлениеПериод()
	Элементы.ДатаОкончания.Доступность=истина;
	если запись.ВариантВыбора=0 тогда
		Элементы.Периодично.Доступность=истина;
	иначеесли запись.ВариантВыбора=1 тогда
		Элементы.ДатаОкончания.Доступность=Ложь;
		Элементы.Периодично.Доступность=ложь;
	конецесли;
КонецПроцедуры
&НаСервере
Процедура ЗаписатьПредставление()
	если запись.ВариантВыбора=0 тогда
		СТР_ПредставлениеПериода="С "+Формат(запись.ДатаНачала, "ДФ=dd.MM.гггг")+" по "+Формат(запись.ДатаОкончания, "ДФ=dd.MM.гггг");
		если Запись.Периодично тогда
			СТР_ПредставлениеПериода=СТР_ПредставлениеПериода+" с пролонгацией";
		конецесли;	
	иначеесли запись.ВариантВыбора=1 тогда
		СТР_ПредставлениеПериода="С "+Формат(запись.ДатаНачала, "ДФ=dd.MM.гггг")+" бессрочно";
	конецесли;	
	Запись.ПредставлениеПериода=СТР_ПредставлениеПериода; 

КонецПроцедуры


&НаКлиенте
Процедура БессрочноПриИзменении(Элемент)
	ОтобразитьОформлениеПериод();
	если Запись.Периодично тогда
		 Запись.Периодично=ложь;
	 Конецесли;	 
	 Запись.ДатаОкончания="";
	 ЗаписатьПредставление();
	 
КонецПроцедуры

&НаКлиенте
Процедура ДействуетДоДатыПриИзменении(Элемент)
	ОтобразитьОформлениеПериод();
	ЗаписатьПредставление();
КонецПроцедуры

&НаКлиенте
Процедура ПериодичноПриИзменении(Элемент)
	ЗаписатьПредставление();
КонецПроцедуры

&НаКлиенте
Процедура ДатаНачалаПриИзменении(Элемент)
		ЗаписатьПредставление();
КонецПроцедуры

&НаКлиенте
Процедура ДатаОкончанияПриИзменении(Элемент)
		ЗаписатьПредставление();
КонецПроцедуры
