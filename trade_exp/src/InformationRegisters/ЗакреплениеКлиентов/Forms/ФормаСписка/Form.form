    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	НачальныйРегистр.Клиент, 
	НачальныйРегистр.ВидМенеджераКлиента, 
	НачальныйРегистр.ЗакрепленныйПользователь,
	НачальныйРегистр.ПодразделениеПользователя,
	НачальныйРегистр.ОтделПользователя,
	НачальныйРегистр.НаправлениеПользователя,
	НачальныйРегистр.Период КАК НачалоЗакрепления,	                                                                      
	НачальныйРегистр.АвторИзменения,
	НачальныйРегистр.ДатаИВремяЗаписи,
	ЕСТЬNULL(МИНИМУМ(ДОБАВИТЬКДАТЕ(КонечныйРегистр.Период, СЕКУНДА, -1)), ДАТАВРЕМЯ(1, 1, 1))  КАК ОкончаниеЗакрепления,
	ЕСТЬNULL(МИНИМУМ(ДОБАВИТЬКДАТЕ(КонечныйРегистр.Период, СЕКУНДА, -1)), ДАТАВРЕМЯ(3000, 1, 1))  КАК ОкончаниеЗакрепленияПериод
ПОМЕСТИТЬ
	втИсходноеЗакреплениеКлиентов	
ИЗ
	РегистрСведений.ЗакреплениеКлиентов НачальныйРегистр
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗакреплениеКлиентов КонечныйРегистр
    	ПО НачальныйРегистр.Клиент = КонечныйРегистр.Клиент
		И НачальныйРегистр.ВидМенеджераКлиента = КонечныйРегистр.ВидМенеджераКлиента   
		И НачальныйРегистр.Период &lt; КонечныйРегистр.Период
СГРУППИРОВАТЬ ПО	
	НачальныйРегистр.Период,	
	НачальныйРегистр.Клиент, 
	НачальныйРегистр.ВидМенеджераКлиента, 
	НачальныйРегистр.ЗакрепленныйПользователь,
	НачальныйРегистр.ПодразделениеПользователя,
	НачальныйРегистр.ОтделПользователя,
	НачальныйРегистр.НаправлениеПользователя,
	НачальныйРегистр.АвторИзменения,
	НачальныйРегистр.ДатаИВремяЗаписи
;                  

//////////////////////////////////////////////////////////////////////////////// 
ВЫБРАТЬ	
	Закрепление.Клиент,	
	Партнеры.Код КАК КодКлиента,
	Закрепление.ВидМенеджераКлиента, 
	Закрепление.ЗакрепленныйПользователь,	
	Закрепление.ПодразделениеПользователя,
	Закрепление.ОтделПользователя, 
	Закрепление.НаправлениеПользователя,	
	Закрепление.АвторИзменения,	
	Закрепление.ДатаИВремяЗаписи,	
	Закрепление.НачалоЗакрепления, 
	Закрепление.ОкончаниеЗакрепления
ИЗ	
	втИсходноеЗакреплениеКлиентов КАК Закрепление   
	СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		ПО Закрепление.Клиент = Партнеры.Ссылка
ГДЕ 
	Закрепление.НачалоЗакрепления МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
	ИЛИ Закрепление.ОкончаниеЗакрепленияПериод МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
