#Область СлужебныеПроцедурыиФункции
&НаКлиенте
Функция СтруктураТаблицы_ЦеноваяГруппа()

	СтруктураТаблицы=Новый Структура;
	СтруктураТаблицы.Вставить("ГруппаВидовЦен", "СправочникСсылка.ГруппировкиВидовЦен#Группа видов цен#20#1#Справочники.ГруппировкиВидовЦен.НайтиПоНаименованию(""&Ячейка&"")#ГруппаВидовЦен");
	СтруктураТаблицы.Вставить("Регион", "СправочникСсылка.РегионыПрисутствия#Регион#20#1#Справочники.РегионыПрисутствия.НайтиПоНаименованию(""&Ячейка&"")#Регион");
	СтруктураТаблицы.Вставить("ЦеноваяГруппа_Номенклатура",
		"СправочникСсылка.ЦеновыеГруппы#Ценовая группа#30#1#Справочники.ЦеновыеГруппы.НайтиПоНаименованию(""&Ячейка&"")#ЦеноваяГруппа_Номенклатура");
	СтруктураТаблицы.Вставить("ПроцентНаценки", "число#% наценки#10");
	
	Возврат СтруктураТаблицы;
КонецФункции

&НаКлиенте
Функция СтруктураТаблицы_Номенклатура()

	СтруктураТаблицы=Новый Структура;
	СтруктураТаблицы.Вставить("ГруппаВидовЦен", "СправочникСсылка.ГруппировкиВидовЦен#Группа видов цен#20#1#Справочники.ГруппировкиВидовЦен.НайтиПоНаименованию(""&Ячейка&"")#ГруппаВидовЦен");
	СтруктураТаблицы.Вставить("Регион", "СправочникСсылка.РегионыПрисутствия#Регион#20#1#Справочники.РегионыПрисутствия.НайтиПоНаименованию(""&Ячейка&"")#Регион");
	СтруктураТаблицы.Вставить("Код", "строка#Код номенклатуры#15#1#Справочники.Номенклатура.НайтиПоКоду(""&Ячейка&"")#ЦеноваяГруппа_Номенклатура");
	СтруктураТаблицы.Вставить("ЦеноваяГруппа_Номенклатура",
		"СправочникСсылка.Номенклатура#Номенклатура#30#1#Справочники.Номенклатура.НайтиПоНаименованию(""&Ячейка&"")#ЦеноваяГруппа_Номенклатура");
	СтруктураТаблицы.Вставить("Начало", "Дата#Начало#10");
	СтруктураТаблицы.Вставить("Окончание", "Дата#Окончание#10");
	СтруктураТаблицы.Вставить("ПроцентНаценки", "число#% наценки#10");
	
	Возврат СтруктураТаблицы;
КонецФункции

