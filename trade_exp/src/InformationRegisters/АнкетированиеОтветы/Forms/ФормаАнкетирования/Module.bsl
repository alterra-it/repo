
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Элементы.ФормаНазад.Видимость = Ложь;
	Элементы.ФормаГотово.Видимость = Ложь;
	Элементы.ФормаДалее.Доступность = Ложь;
	ДатаЗаполнения = ТекущаяДата();
	НомерВопроса = 0;
	Ответственный = ПараметрыСеанса.ТекущийПользователь;
	Если Не Параметры.Респондент.Пустая() Тогда
		Респондент = Параметры.Респондент;
	КонецЕсли;
	если Параметры.Свойство("ВзаимодействиеОснование") тогда
		ВзаимодействиеОснование=Параметры.ВзаимодействиеОснование;
	конецесли;	
КонецПроцедуры

&НаКлиенте
Процедура Далее(Команда)
	Если Элементы.ПервыйЭтап.Видимость Тогда
		Элементы.ПервыйЭтап.Видимость = Ложь;
		Элементы.ВторойЭтап.Видимость = Истина;
		Элементы.ФормаНазад.Видимость = Истина;
		ВывестиВопрос(СписокВопросов[НомерВопроса].Значение);
	Иначе
		ДобавитьОтвет(СписокВопросов[НомерВопроса].Значение);
		НомерВопроса = НомерВопроса + 1;
		ВывестиВопрос(СписокВопросов[НомерВопроса].Значение);
	КонецЕсли;
	Если НомерВопроса = СписокВопросов.Количество() - 1 Тогда
		Элементы.ФормаДалее.Видимость = Ложь;
		Элементы.ФормаГотово.Видимость = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	Если НомерВопроса = 0 Тогда
		Ответы.Очистить();
		Элементы.ФормаНазад.Видимость = Ложь;
		Элементы.ВторойЭтап.Видимость = Ложь;
		Элементы.ПервыйЭтап.Видимость = Истина;
	Иначе
		ДобавитьОтвет(СписокВопросов[НомерВопроса].Значение);
		НомерВопроса = НомерВопроса - 1;
		ВывестиВопрос(СписокВопросов[НомерВопроса].Значение);
		Если НомерВопроса = СписокВопросов.Количество() - 2 Тогда
			Элементы.ФормаГотово.Видимость = Ложь;
			Элементы.ФормаДалее.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДоступностьКнопок()
	Если Не Анкета.Пустая() И Не Респондент.Пустая() Тогда
		СписокСформирован = СформироватьСписокВопросов();
		Если СписокСформирован Тогда
			Элементы.ФормаДалее.Доступность = Истина;
		КонецЕсли;
	Иначе
		Элементы.ФормаДалее.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры

