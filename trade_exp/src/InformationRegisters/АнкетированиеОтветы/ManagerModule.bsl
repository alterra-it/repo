#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Процедура СформироватьТабличныйДокументОпроса(Респондент, Шаблон,ДатаЗаполнения, ТабДок) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	АнкетированиеОтветы.Респондент,
	               |	АнкетированиеОтветы.ШаблонАнкеты,
	               |	АнкетированиеОтветы.Вопрос КАК Вопрос,
	               |	АнкетированиеОтветы.НомерВарианта КАК НомерВарианта,
	               |	АнкетированиеОтветы.Ответ,
	               |	АнкетированиеОтветы.ДатаЗаполнения как дата
	               |ИЗ
	               |	РегистрСведений.АнкетированиеОтветы КАК АнкетированиеОтветы
	               |ГДЕ
	               |	АнкетированиеОтветы.Респондент = &Респондент
	               |	И АнкетированиеОтветы.ШаблонАнкеты = &ШаблонАнкеты
	               |	И АнкетированиеОтветы.ДатаЗаполнения = &ДатаЗаполнения
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Вопрос,
	               |	НомерВарианта";
	Запрос.УстановитьПараметр("Респондент", Респондент);
	Запрос.УстановитьПараметр("ШаблонАнкеты", Шаблон);
	Запрос.УстановитьПараметр("ДатаЗаполнения", ДатаЗаполнения);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Макет = РегистрыСведений.АнкетированиеОтветы.ПолучитьМакет("Макет");
	Шапка = Макет.ПолучитьОбласть("Шапка");
	Ответ = Макет.ПолучитьОбласть("Ответ");
	ДругойОтвет = Макет.ПолучитьОбласть("ДругойОтвет");
	ШапкаВыведена = Ложь;
	Вопрос = Справочники.ВопросыАнкетАльтерра.ПустаяСсылка();
	Пока Выборка.Следующий() Цикл
		Если Не ШапкаВыведена Тогда
			Шапка.Параметры.Заполнить(Выборка);
			ТабДок.Вывести(Шапка);
			ШапкаВыведена = Истина;
		КонецЕсли;
		Если Вопрос <> Выборка.Вопрос Тогда
			Ответ.Параметры.Заполнить(Выборка);
			ТабДок.Вывести(Ответ);
			Вопрос = Выборка.Вопрос;
		Иначе
			ДругойОтвет.Параметры.Заполнить(Выборка);
			ТабДок.Вывести(ДругойОтвет);
		КонецЕсли;
	КонецЦикла;
	ТабДок.Вывести(Макет.ПолучитьОбласть("Подвал"));
КонецПроцедуры
#КонецЕсли