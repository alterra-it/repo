#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
Процедура УстановитьГраницуПоследовательности(НаборРегистра,режим) экспорт
		
		ДокументСсылка=НаборРегистра.Отбор.Регистратор.Значение;
		если типзнч(ДокументСсылка)=тип("ДокументСсылка.РасчетСебестоимостиТоваров") тогда
			возврат;
		конецесли;	
		МенеджерЗаписи=РегистрыСведений.ГраницаПоследовательностиСебестоимости.СоздатьМенеджерЗаписи();
		если режим=3 тогда
			МенеджерЗаписи.Документ = ДокументСсылка.ссылка; 
			МенеджерЗаписи.Записать();    
			возврат;
		конецесли;	
		если режим=1 тогда	
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ первые 1
			|	истина
			|ИЗ
			|	РегистрСведений.ГраницаПоследовательностиСебестоимости КАК Граница
			|ГДЕ  
			|	Граница.Документ.МоментВремени >= &МоментВремени";
			
			Запрос.УстановитьПараметр("МоментВремени", ДокументСсылка.МоментВремени());
			РезультатЗапроса = Запрос.Выполнить();    
			если не РезультатЗапроса.Пустой() тогда
				если ИзмененияЗафиксированы(НаборРегистра) тогда
					МенеджерЗаписи.Документ = ДокументСсылка.ссылка; 
					МенеджерЗаписи.Записать();    
				конецесли;
			конецесли;	
		конецесли;
		если режим = 2 тогда  
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	СебестоимостьТоваров.Регистратор КАК Регистратор,
			|	СебестоимостьТоваров.МоментВремени КАК МоментВремени
			|ПОМЕСТИТЬ ВР_Документ
			|ИЗ
			|	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
			|ГДЕ
			|	СебестоимостьТоваров.МоментВремени > &МоментВремени
			|
			|УПОРЯДОЧИТЬ ПО
			|	СебестоимостьТоваров.Период возр
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	ВР_Документ.Регистратор КАК Регистратор
			|ИЗ
			|	РегистрСведений.ГраницаПоследовательностиСебестоимости КАК ГраницаПоследовательностиСебестоимости
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВР_Документ КАК ВР_Документ
			|		ПО (ГраницаПоследовательностиСебестоимости.Документ.МоментВремени > ВР_Документ.МоментВремени)";
			
			Запрос.УстановитьПараметр("МоментВремени", ДокументСсылка.МоментВремени());
			РезультатЗапроса = Запрос.Выполнить();    
			Выборка= РезультатЗапроса.Выбрать();
			если Выборка.Следующий() тогда
				МенеджерЗаписи.Документ = Выборка.Регистратор; 
				МенеджерЗаписи.Записать();    
			конецесли;	
			
		конецесли;	
		
	КонецПроцедуры
	
Функция ИзмененияЗафиксированы(НаборНовый)
		НаборСтарый = РегистрыНакопления.СебестоимостьТоваров.СоздатьНаборЗаписей();
		Для Каждого ЗначениеОтбора Из НаборНовый.Отбор Цикл
			
			Если ЗначениеОтбора.Использование = Ложь Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаОтбора = НаборСтарый.Отбор.Найти(ЗначениеОтбора.Имя);
			СтрокаОтбора.Значение = ЗначениеОтбора.Значение;
			СтрокаОтбора.Использование = Истина;
			
		КонецЦикла;
		
		НаборСтарый.Прочитать();
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтарыйРегистр.НомерСтроки КАК НомерСтроки,
		|	СтарыйРегистр.Стоимость + СтарыйРегистр.ДопРасходы + СтарыйРегистр.СтоимостьБезНДС + СтарыйРегистр.ДопРасходыБезНДС + СтарыйРегистр.СтоимостьРегл + СтарыйРегистр.СтоимостьЗабалансовая + СтарыйРегистр.ДопРасходыРегл + СтарыйРегистр.СтоимостьУпр + СтарыйРегистр.ДопРасходыУпр + СтарыйРегистр.СтоимостьЗабалансоваяРегл КАК КонтрСумма,
		|	СтарыйРегистр.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры
		|ПОМЕСТИТЬ ВР_СтарыйРегистр
		|ИЗ
		|	&СтарыйРегистр КАК СтарыйРегистр
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НовыйРегистр.НомерСтроки КАК НомерСтроки,
		|	НовыйРегистр.Стоимость + НовыйРегистр.ДопРасходы + НовыйРегистр.СтоимостьБезНДС + НовыйРегистр.ДопРасходыБезНДС + НовыйРегистр.СтоимостьРегл + НовыйРегистр.ДопРасходыРегл + НовыйРегистр.СтоимостьЗабалансовая + НовыйРегистр.СтоимостьУпр + НовыйРегистр.ДопрасходыУпр + НовыйРегистр.СтоимостьЗабалансоваяРегл КАК КонтрСумма,
		|	НовыйРегистр.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры
		|ПОМЕСТИТЬ ВР_НовыйРегистр
		|ИЗ
		|	&НовыйРегистр КАК НовыйРегистр
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЕСТЬNULL(ВР_НовыйРегистр.АналитикаУчетаНоменклатуры, ВР_СтарыйРегистр.АналитикаУчетаНоменклатуры) КАК Аналитика,
		|	ВР_НовыйРегистр.КонтрСумма КАК КонтрСуммаНовая,
		|	ВР_СтарыйРегистр.КонтрСумма КАК КонтрСуммаСтарая
		|ИЗ
		|	ВР_СтарыйРегистр КАК ВР_СтарыйРегистр
		|		ПОЛНОЕ СОЕДИНЕНИЕ ВР_НовыйРегистр КАК ВР_НовыйРегистр
		|		ПО ВР_СтарыйРегистр.НомерСтроки = ВР_НовыйРегистр.НомерСтроки
		|			И ВР_СтарыйРегистр.АналитикаУчетаНоменклатуры = ВР_НовыйРегистр.АналитикаУчетаНоменклатуры
		|ГДЕ
		|	ЕСТЬNULL(ВР_НовыйРегистр.КонтрСумма, 0) <> ЕСТЬNULL(ВР_СтарыйРегистр.КонтрСумма, 0)";
		
		Запрос.УстановитьПараметр("СтарыйРегистр",НаборСтарый.Выгрузить());
		Запрос.УстановитьПараметр("НовыйРегистр",НаборНовый.Выгрузить());
		РезультатЗапроса = Запрос.Выполнить();
		возврат не РезультатЗапроса.Пустой();
		
	КонецФункции // ИзмененияЗафиксированы()
	
#КонецЕсли 
