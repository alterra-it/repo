  <attributes>
    <name>Дашборд</name>
    <title>
      <key>ru</key>
      <value>Дашборд</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Дашборд.ЗаказНаДоставку</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>Дашборд.Рейс</segments>
    </notDefaultUseAlwaysAttributes>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ 
	ДоставкаЯндекс.ЗаказНаДоставку  КАК ЗаказНаДоставку
ПОМЕСТИТЬ 
	втЗаказы	
ИЗ
	РегистрСведений.ДоставкаЯндекс КАК ДоставкаЯндекс 
ГДЕ	
	ДоставкаЯндекс.СтатусДоставки &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)	
    И ДоставкаЯндекс.ВремяСобытия МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
;
//////////////////////////////////////////////////////////
ВЫБРАТЬ
	втЗаказы.ЗаказНаДоставку КАК ЗаказНаДоставку,
	МАКСИМУМ(СтатусДоставки.Порядок) КАК ПорядокСтатусДоставки
ПОМЕСТИТЬ
	втПоследнийСтатус
ИЗ
	втЗаказы КАК втЗаказы   
	СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ДоставкаЯндекс
		ПО втЗаказы.ЗаказНаДоставку = ДоставкаЯндекс.ЗаказНаДоставку
		И ДоставкаЯндекс.СтатусДоставки &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)	
СГРУППИРОВАТЬ ПО
	втЗаказы.ЗаказНаДоставку  
;           
//////////////////////////////////////////////////////////
ВЫБРАТЬ   
	ДоставкаЯндекс.ЗаказНаДоставку,  
	Заказы.Номер,
	Заказы.Дата,
	Заказы.Партнер КАК Клиент,
	Заказы.АдресДоставки,
	Заказы.ПрибытиеНаОтгрузку,
	Заказы.ВремяДоставкиС, 
	Заказы.ВремяДоставкиПо,   
	ПОДСТРОКА(&quot;0&quot; + СТРОКА(ДЕНЬ(Заказы.ПрибытиеНаОтгрузку)), 
		ДЛИНАСТРОКИ(&quot;0&quot; + СТРОКА(ДЕНЬ(Заказы.ПрибытиеНаОтгрузку))) - 1, 2) + &quot;.&quot; + 
	ПОДСТРОКА(&quot;0&quot; + СТРОКА(МЕСЯЦ(Заказы.ПрибытиеНаОтгрузку)), 
		ДЛИНАСТРОКИ(&quot;0&quot; + СТРОКА(МЕСЯЦ(Заказы.ПрибытиеНаОтгрузку))) - 1, 2) + &quot;.&quot; + 
	ПОДСТРОКА(СТРОКА(ГОД(Заказы.ПрибытиеНаОтгрузку)), 1, 1) +  
	ПОДСТРОКА(СТРОКА(ГОД(Заказы.ПрибытиеНаОтгрузку)), 3, 3) + &quot;   &quot; + 
	ПОДСТРОКА(&quot;0&quot; + СТРОКА(ЧАС(Заказы.ВремяДоставкиС)), 
		ДЛИНАСТРОКИ(&quot;0&quot; + СТРОКА(ЧАС(Заказы.ВремяДоставкиС))) - 1, 2) + &quot;:&quot; + 
	ПОДСТРОКА(&quot;0&quot; + СТРОКА(МИНУТА(Заказы.ВремяДоставкиС)), 
		ДЛИНАСТРОКИ(&quot;0&quot; + СТРОКА(МИНУТА(Заказы.ВремяДоставкиС))) - 1, 2) + &quot; - &quot; +
	ПОДСТРОКА(&quot;0&quot; + СТРОКА(ЧАС(Заказы.ВремяДоставкиПо)), 
		ДЛИНАСТРОКИ(&quot;0&quot; + СТРОКА(ЧАС(Заказы.ВремяДоставкиПо))) - 1, 2) + &quot;:&quot; + 
	ПОДСТРОКА(&quot;0&quot; + СТРОКА(МИНУТА(Заказы.ВремяДоставкиПо)), 
		ДЛИНАСТРОКИ(&quot;0&quot; + СТРОКА(МИНУТА(Заказы.ВремяДоставкиПо))) - 1, 2) КАК ИнтервалДоставки,
	ДоставкаЯндекс.СтатусДоставки,
	ДоставкаЯндекс.ВремяСобытия
ПОМЕСТИТЬ
	втПоследниеСобытия 
ИЗ             
	втПоследнийСтатус КАК втПоследнийСтатус 
 	СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ДоставкаЯндекс
    	ПО втПоследнийСтатус.ЗаказНаДоставку = ДоставкаЯндекс.ЗаказНаДоставку
    	И втПоследнийСтатус.ПорядокСтатусДоставки = ДоставкаЯндекс.СтатусДоставки.Порядок
    	И ДоставкаЯндекс.СтатусДоставки &lt;> ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)
    ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК Заказы
    	ПО ДоставкаЯндекс.ЗаказНаДоставку = Заказы.Ссылка	
СГРУППИРОВАТЬ ПО
	ДоставкаЯндекс.ЗаказНаДоставку,
	Заказы.Номер,
	Заказы.Дата,
	Заказы.Партнер,
	Заказы.АдресДоставки,
	Заказы.ПрибытиеНаОтгрузку,
	Заказы.ВремяДоставкиС,
	Заказы.ВремяДоставкиПО,
	ДоставкаЯндекс.ВремяСобытия,
	ДоставкаЯндекс.ПлановоеВремяДоставки,
	ДоставкаЯндекс.СтатусДоставки
;   
//////////////////////////////////////////////////////////
ВЫБРАТЬ   
	втПоследниеСобытия.ЗаказНаДоставку, 
	втПоследниеСобытия.Номер,
	втПоследниеСобытия.Дата,
	втПоследниеСобытия.Клиент,
	втПоследниеСобытия.АдресДоставки, 
	втПоследниеСобытия.ПрибытиеНаОтгрузку,
	втПоследниеСобытия.ВремяДоставкиС, 
	втПоследниеСобытия.ВремяДоставкиПо,   
	втПоследниеСобытия.ИнтервалДоставки,
	втПоследниеСобытия.СтатусДоставки,
	втПоследниеСобытия.ВремяСобытия,  
	ЗаданиеРейс.Ссылка КАК Рейс,
	ЗаданиеРейс.Номер КАК НомерРейса,
	ЗаданиеРейс.Дата КАК ДатаРейса,
	СобытияТрекингов.ПлановоеВремяДоставки,
	СобытияТрекингов.Трекинг,
	ВЫБОР 
		КОГДА втПоследниеСобытия.СтатусДоставки = 
			ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПереданоВДоставку)
		ТОГДА 0
		КОГДА втПоследниеСобытия.СтатусДоставки В (
			 ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказОтправленСоСклада),
			 ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПредыдущийЗаказДоставлен),
			 ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказПодъезжает),
			 ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказПриехал))
		ТОГДА 1   
		КОГДА втПоследниеСобытия.СтатусДоставки = 
			ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказДоставлен)
		ТОГДА 2
		ИНАЧЕ 3
	КОНЕЦ КАК ИндексКартинкиДоставки		
ИЗ
	втПоследниеСобытия КАК втПоследниеСобытия 
	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ОснованияРейса
		ПО втПоследниеСобытия.ЗаказНаДоставку = ОснованияРейса.Документ 
	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеРейс 
		ПО ОснованияРейса.Ссылка = ЗаданиеРейс.Ссылка
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК СобытияТрекингов
    	ПО втПоследниеСобытия.ЗаказНаДоставку = СобытияТрекингов.ЗаказНаДоставку
    	И СобытияТрекингов.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)
</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
