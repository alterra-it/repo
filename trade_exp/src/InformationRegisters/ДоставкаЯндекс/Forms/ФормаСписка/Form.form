  <attributes>
    <name>СписокСобытий</name>
    <title>
      <key>ru</key>
      <value>Список событий</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДоставкаЯндекс.ЗаказНаДоставку,
	ДоставкаЯндекс.СтатусДоставки,
	ДоставкаЯндекс.ВремяСобытия,
	ДоставкаЯндекс.ПлановоеВремяДоставки,
	ДоставкаЯндекс.Трекинг
ИЗ
	РегистрСведений.ДоставкаЯндекс КАК ДоставкаЯндекс
ГДЕ
	ДоставкаЯндекс.ВремяСобытия МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания</queryText>
      <mainTable>InformationRegister.ДоставкаЯндекс</mainTable>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ЗаказНаДоставку</dataPath>
        <field>ЗаказНаДоставку</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>СтатусДоставки</dataPath>
        <field>СтатусДоставки</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ВремяСобытия</dataPath>
        <field>ВремяСобытия</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Трекинг</dataPath>
        <field>Трекинг</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>ПлановоеВремяДоставки</dataPath>
        <field>ПлановоеВремяДоставки</field>
      </fields>
      <parameters>
        <name>ДатаНачала</name>
