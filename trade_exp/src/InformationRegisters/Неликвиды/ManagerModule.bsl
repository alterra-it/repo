#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
Функция ВернутьЛиквидностьТовара(Номенклатура,Подразделение) экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НеликвидыСрезПоследних.Ликвидность КАК Ликвидность
	|ИЗ
	|	РегистрСведений.Неликвиды.СрезПоследних(, ) КАК НеликвидыСрезПоследних
	|ГДЕ
	|	НеликвидыСрезПоследних.Номенклатура = &Номенклатура
	|	И НеликвидыСрезПоследних.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		возврат ВыборкаДетальныеЗаписи.Ликвидность; 
	иначе
		возврат Перечисления.Ликвидность.ПустаяСсылка()
	Конецесли;
	
КонецФункции // ВернутьКлассТовара()
#КонецЕсли
