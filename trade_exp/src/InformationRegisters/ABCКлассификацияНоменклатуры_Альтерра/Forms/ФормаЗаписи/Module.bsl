
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(Параметры.Номенклатура) Тогда
		Запись.Номенклатура = Параметры.Номенклатура;
	Иначе
		Если Параметры.Свойство("ЗначениеЗаполнения") Тогда	
			ЗаполнитьЗначенияСвойств(Запись, Параметры.ЗначениеЗаполнения);    
		КонецЕсли;
	КонецЕсли;
	Запись.Менеджер = ПараметрыСеанса.ТекущийПользователь;
КонецПроцедуры
