#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область СоздатьЯчейки

Процедура СоздатьЯчейки(Отказ, Товары, Склад, РабочийУчасток) Экспорт
	Если Не Отказ И ЗначениеЗаполнено(Товары) И ЗначениеЗаполнено(Склад) И ЗначениеЗаполнено(РабочийУчасток) Тогда 
		Если Склад.Наименование = "Центральный склад" Тогда
			Если СравнитьСтроки(РабочийУчасток.Наименование, "Секция А") Тогда
				СоздатьЗаписи(Товары, "Центральный склад", "Секция А", "Секция А (Общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция С") Тогда
				СоздатьЗаписи(Товары, "Центральный склад", "Секция С", "Секция С (Общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция Д") Тогда
				СоздатьЗаписи(Товары, "Центральный склад", "Секция Д", "Секция Д (Общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция М") Тогда
				СоздатьЗаписи(Товары, "Центральный склад", "Секция М", "Секция М (Общая)");
			КонецЕсли;
		ИначеЕсли Склад.Наименование = "Склад (Выбор)" Тогда
			Если СравнитьСтроки(РабочийУчасток.Наименование, "Секция А") Тогда
				СоздатьЗаписи(Товары, "Склад (Выбор)", "Секция А", "Секция А (общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция В.С") Тогда
				СоздатьЗаписи(Товары, "Склад (Выбор)", "Секция В.С", "Секция В.С (общая)");
			КонецЕсли;
		ИначеЕсли Склад.Наименование = "Склад (Барнаул)" Тогда
			Если СравнитьСтроки(РабочийУчасток.Наименование, "Секция В") Тогда  
				СоздатьЗаписи(Товары, "Склад (Барнаул)", "Секция В", "СекцияВ+Метал(общая");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция Металл") Тогда
				СоздатьЗаписи(Товары, "Склад (Барнаул)", "Секция В", "СекцияВ+Метал(общая");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция С") Тогда     
				СоздатьЗаписи(Товары, "Склад (Барнаул)", "Секция С", "Секция С(Общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция А") Тогда 
				СоздатьЗаписи(Товары, "Склад (Барнаул)", "Секция А", "Секция А (общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция Д") Тогда          
				СоздатьЗаписи(Товары, "Склад (Барнаул)", "Секция Д (Барнаул)", "Секция Д (общая)");
			КонецЕсли;
		ИначеЕсли Склад.Наименование = "Склад (Бийск)" Тогда
			Если СравнитьСтроки(РабочийУчасток.Наименование, "Секция А") Тогда  
				СоздатьЗаписи(Товары, "Склад (Бийск)", "Секция A", "Секция А (общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция В") Тогда   
				СоздатьЗаписи(Товары, "Склад (Бийск)", "Секция B", "Секция В (общая)");
			ИначеЕсли СравнитьСтроки(РабочийУчасток.Наименование, "Секция С") Тогда  
				СоздатьЗаписи(Товары, "Склад (Бийск)", "Секция С", "Секция С (общая)");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьЗаписи(Товары, Склад, РабочийУчасток, Ячейка)  
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкладскиеЯчейки.Ссылка КАК Ячейка,
		|	СкладскиеЯчейки.Владелец КАК Склад
		|ИЗ
		|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
		|ГДЕ
		|	НЕ СкладскиеЯчейки.ПометкаУдаления
		|	И СкладскиеЯчейки.Код = &Ячейка
		|	И СкладскиеЯчейки.РабочийУчасток.Наименование = &РабочийУчасток
		|	И СкладскиеЯчейки.Владелец.Наименование = &Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СпрНоменклатура.Ссылка КАК Номенклатура,
		|	ВЫБОР
		|		КОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЕстьЯчейка
		|ИЗ
		|	Справочник.Номенклатура КАК СпрНоменклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО СпрНоменклатура.Ссылка = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад.Наименование = &Склад)
		|ГДЕ
		|	СпрНоменклатура.Ссылка В(&Товары)
		|	И НЕ СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)";
		
	Запрос.УстановитьПараметр("Ячейка", Ячейка);
	Запрос.УстановитьПараметр("РабочийУчасток", РабочийУчасток);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Товары", Товары);     
	
	Результат = Запрос.ВыполнитьПакет();     
	Выборка = Результат[0].Выбрать();
	Если Выборка.Следующий() Тогда  
		Склад = Выборка.Склад;
		Ячейка = Выборка.Ячейка; 
		Если ЗначениеЗаполнено(Склад) И ЗначениеЗаполнено(Ячейка) Тогда				
			Выборка = Результат[1].Выбрать();
			Пока Выборка.Следующий() Цикл 
				Если Не Выборка.ЕстьЯчейка Тогда          
					МенеджерЗаписи = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьМенеджерЗаписи();
					МенеджерЗаписи.Склад = Склад;
					МенеджерЗаписи.Ячейка = Ячейка;
					МенеджерЗаписи.Номенклатура = Выборка.Номенклатура;
					МенеджерЗаписи.ОсновнаяЯчейка = Истина;
		
					Попытка
						МенеджерЗаписи.Записать();
					Исключение 
						ОбщегоНазначения.СообщитьПользователю("Не удалось создать ячейку для '" + Выборка.Номенклатура + "'");
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли
	КонецЕсли;
КонецПроцедуры

Функция СравнитьСтроки(Знач Строка1, Знач Строка2)
	Строка1 = ИнтеграцияИСКлиентСервер.ЗаменитьНечитаемыеСимволы(ВРег(Строка1));
	Строка2 = ИнтеграцияИСКлиентСервер.ЗаменитьНечитаемыеСимволы(ВРег(Строка2));

	Строка1 = СтроковыеФункцииКлиентСервер.ЗаменитьОдниСимволыДругими("АВЕКМНОРСТУХ", Строка1, "ABEKMHOPCTYX");
	Строка2 = СтроковыеФункцииКлиентСервер.ЗаменитьОдниСимволыДругими("АВЕКМНОРСТУХ", Строка2, "ABEKMHOPCTYX");

	Возврат Строка1 = Строка2;
КонецФункции 

#КонецОбласти   

#КонецЕсли
