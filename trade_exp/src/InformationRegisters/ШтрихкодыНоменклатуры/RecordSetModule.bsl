&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, Замещение)
        
    УстановитьПривилегированныйРежим(Истина);
    
    ТекДата = ТекущаяДата();
        
    Если ЭтотОбъект.Количество() = 0 Тогда
        Набор = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
        Набор.Отбор.Штрихкод.Установить(ЭтотОбъект.Отбор.Штрихкод.Значение);
        Набор.Прочитать();
        Для Каждого Запись Из Набор Цикл
            ЗафиксироватьИзменение(Запись, ТекДата, "Удалено");
        КонецЦикла;    
    КонецЕсли;
    
    УстановитьПривилегированныйРежим(Ложь);
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	Для Каждого Запись Из ЭтотОбъект Цикл
		Запись.Ответственный=Пользователи.ТекущийПользователь();
	КонецЦикла;
	
КонецПроцедуры

&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ, Замещение)
    
    УстановитьПривилегированныйРежим(Истина);
    
    ТекДата = ТекущаяДата();
    
    Для Каждого Запись Из ЭтотОбъект Цикл
        Набор = РегистрыСведений.ИзмененияШтрихкодов.СоздатьНаборЗаписей();
        Набор.Отбор.Номенклатура.Установить(Запись.Номенклатура);
        Набор.Отбор.Характеристика.Установить(Запись.Характеристика);
        Набор.Отбор.Упаковка.Установить(Запись.Упаковка);
        Набор.Прочитать();
        Для Каждого Эл Из Набор Цикл
            Если Эл.Пользователь = Пользователи.ТекущийПользователь() И Эл.Операция = "Удалено" И Эл.Период >= ТекДата - 15 Тогда
                 Эл.Штрихкод2 = Запись.Штрихкод;
                 Эл.Операция = "Изменено";
                 Набор.Записать();
             Иначе
                
                ЗафиксироватьИзменение(Запись, ТекДата, "Добавлено");
            КонецЕсли;
        КонецЦикла;
    МаркировкаАльтерра.ЗаписатьGTINИС(Запись);
    КонецЦикла;
    
    УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры


Процедура ЗафиксироватьИзменение(Запись, ТекДата, Операция)
    МенеджерЗаписи = РегистрыСведений.ИзмененияШтрихкодов.СоздатьМенеджерЗаписи();
    ЗаполнитьЗначенияСвойств(МенеджерЗаписи, Запись);
    МенеджерЗаписи.Период = ТекДата;
    МенеджерЗаписи.Пользователь = Пользователи.ТекущийПользователь();
    МенеджерЗаписи.Операция = Операция;
    Если Операция = "Добавлено" Тогда
        МенеджерЗаписи.Штрихкод = Null;
        МенеджерЗаписи.Штрихкод2 = Запись.Штрихкод;
    Иначе
        Штрихкод2 = Null;
    КонецЕсли;
    МенеджерЗаписи.Изменение = Истина;
    МенеджерЗаписи.Записать();    
КонецПроцедуры


