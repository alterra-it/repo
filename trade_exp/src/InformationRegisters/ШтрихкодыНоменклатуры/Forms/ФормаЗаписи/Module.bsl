&НаКлиенте
&После("ОбработатьШтрихкоды")
Процедура Спр_ОбработатьШтрихкоды(ДанныеШтрихкодов)
	Если ДанныеШтрихкодов.Количество() > 0 Тогда
		Штрихкод = ДанныеШтрихкодов[ДанныеШтрихкодов.Количество() - 1].Штрихкод;
		Префикс= Лев(Штрихкод, 1);
		
		Если Префикс = "2" Тогда
			Запись.Наш= Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ОбработкаОповещенияПосле(ИмяСобытия, Параметр, Источник)
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда

	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "Barcode" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			Штрихкод = Новый Массив;
			Штрихкод.Добавить(Параметр);
			Штрихкод.Добавить(Неопределено);
			ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Штрихкод));
		КонецЕсли;
	КонецЕсли;
	
	#КонецЕсли
КонецПроцедуры
