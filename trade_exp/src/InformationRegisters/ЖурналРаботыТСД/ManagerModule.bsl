#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
Процедура ЗаписатьСобытие(Событие,Комментарий="",Документ=Неопределено,Сотрудник=Неопределено,ИдентификаторКлиента=Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Сотрудник = ?(Сотрудник = Неопределено,Альтерра_СкладСервер.ТекущийСотрудник(),Сотрудник);
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		
		НаборЗаписей= РегистрыСведений.ЖурналРаботыТСД.СоздатьНаборЗаписей();
		Запись= НаборЗаписей.Добавить();
		Запись.Период= ТекущаяДата();
		Запись.Сотрудник = Сотрудник;
		Запись.Подразделение = Сотрудник.Подразделение;
		Запись.Склад = Сотрудник.Склад;
		Запись.ИдентификаторКлиента = ?(ИдентификаторКлиента=Неопределено,Альтерра_СкладСервер.ПолучитьИдентификаторКлиента(),ИдентификаторКлиента);
		Запись.Событие = Событие;
		Запись.Комментарий = Комментарий; 
		Запись.Документ = Документ; 
        Запись.НомерСеанса = НомерСеансаИнформационнойБазы();    
		Попытка
			НаборЗаписей.Записать(Ложь);
		Исключение
			АльтерраОбщегоНазначения.СообщитьПользователю(,ОписаниеОшибки());
		КонецПопытки
	
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры
#КонецЕсли
