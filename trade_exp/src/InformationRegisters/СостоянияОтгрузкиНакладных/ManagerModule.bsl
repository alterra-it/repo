#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&НаСервере
Процедура ОбновитьСостояниеОтгрузкиНакладной(Накладная,Склад,РабочийУчасток=Неопределено) Экспорт  
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Накладная = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если РабочийУчасток = Неопределено Тогда
		УдалениеЗаписейВРегистре(Накладная);
	КонецЕсли;
	
	ИспользуетсяОтгрузкаПоНакладным = АльтерраОбщегоНазначения.ОтгрузкаПоНакладным(Накладная.Дата,Склад);
	
	Если Не ИспользуетсяОтгрузкаПоНакладным Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоПеремещение = ТипЗнч(Накладная.Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = ТекстЗапросаТаблицаСтатусовПоНакладным();   
	
	Запрос.УстановитьПараметр("РабочийУчасток", РабочийУчасток);
	Запрос.УстановитьПараметр("УсловиеПоСекции",Не РабочийУчасток=Неопределено);	
	Запрос.УстановитьПараметр("Накладная", Накладная.Ссылка);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.Отгружен);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ЭтоПеремещение Тогда
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл	
			ЗаписатьДанныеВРегистрПоЗаказам(ВыборкаДетальныеЗаписи);
		КонецЦикла;  
		
	Иначе
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ЗаписатьДанныеВРегистр(ВыборкаДетальныеЗаписи);
		КонецЦикла;  
		
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры  

&НаСервере
Функция ТекстЗапросаТаблицаСтатусовПоНакладным()
	
	ТекстЗапроса =
	
	"ВЫБРАТЬ
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Склад КАК Склад,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.РабочийУчасток КАК РабочийУчасток,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Накладная КАК Накладная,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Заказ КАК Заказ,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Получатель КАК Получатель,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Характеристика КАК Характеристика,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Назначение КАК Назначение,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.Серия КАК Серия,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.КОтгрузкеПриход КАК КОтгрузкеПриход,
	|	ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.КОтгрузкеРасход КАК КОтгрузкеРасход,
	|	ВЫБОР
	|		КОГДА ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.КОтгрузкеКонечныйОстаток - ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.СобираетсяКонечныйОстаток - ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.СобраноКонечныйОстаток > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ОжидаетсяОтбор,
	|	ВЫБОР
	|		КОГДА ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.СобираетсяКонечныйОстаток > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Набирается,
	|	ВЫБОР
	|		КОГДА ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.СобраноКонечныйОстаток > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Набран,
	|	ВЫБОР
	|		КОГДА ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.КОтгрузкеКонечныйОстаток < 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Ошибка
	|ПОМЕСТИТЬ ПромежуточнаяТаблица
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузкеПоНакладным.ОстаткиИОбороты(, , , , Накладная = &Накладная) КАК ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &УсловиеПоСекции
	|				ТОГДА ТоварыКОтгрузкеПоНакладнымОстаткиИОбороты.РабочийУчасток = &РабочийУчасток
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИСТИНА КАК ЕстьОрдер,
	|	РасходныйОрдерНаТовары.Накладная КАК Накладная,
	|	РасходныйОрдерНаТовары.РабочийУчасток КАК РабочийУчасток
	|ПОМЕСТИТЬ ОрдераВСтатусеОтгружен
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	|ГДЕ
	|	РасходныйОрдерНаТовары.Проведен
	|	И РасходныйОрдерНаТовары.Накладная = &Накладная
	|	И РасходныйОрдерНаТовары.Статус = &Статус
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ЧекККМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ОтметкаКассы,
	|	ЧекККМНарезка.Ссылка КАК ЕстьНарезка,
	|	ЧекККМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ОтметкаКассыНарезка
	|ИЗ
	|	Документ.ЧекККМ.Нарезка КАК ЧекККМНарезка
	|		ПРАВОЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
	|		ПО ЧекККМНарезка.Ссылка = ЧекККМ.Ссылка
	|ГДЕ
	|	ЧекККМ.Ссылка = &Накладная
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ,
	|	РеализацияТоваровУслугНарезка.Ссылка,
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Нарезка КАК РеализацияТоваровУслугНарезка
	|		ПРАВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО РеализацияТоваровУслугНарезка.Ссылка = РеализацияТоваровУслуг.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &Накладная
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПромежуточнаяТаблица.Склад КАК Склад,
	|	ПромежуточнаяТаблица.РабочийУчасток КАК РабочийУчасток,
	|	ПромежуточнаяТаблица.Накладная КАК Документ,
	|	ПромежуточнаяТаблица.Заказ КАК Заказ,
	|	ПромежуточнаяТаблица.Получатель КАК Получатель,
	|	МАКСИМУМ(ПромежуточнаяТаблица.ОжидаетсяОтбор) КАК ОжидаетсяОтбор,
	|	МАКСИМУМ(ПромежуточнаяТаблица.Набирается) КАК Набирается,
	|	МАКСИМУМ(ПромежуточнаяТаблица.Набран) КАК Набран,
	|	МАКСИМУМ(ПромежуточнаяТаблица.Ошибка) КАК Ошибка,
	|	МАКСИМУМ(ЕСТЬNULL(ОрдераВСтатусеОтгружен.ЕстьОрдер, ЛОЖЬ)) КАК ЕстьОрдер,
	|	МАКСИМУМ(ЕСТЬNULL(ОтметкаКассыНарезка.ОтметкаКассы, ИСТИНА)) КАК ОтметкаКассы,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА ОтметкаКассыНарезка.ЕстьНарезка ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) КАК ЕстьНарезка
	|ИЗ
	|	ПромежуточнаяТаблица КАК ПромежуточнаяТаблица
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОрдераВСтатусеОтгружен КАК ОрдераВСтатусеОтгружен
	|		ПО ПромежуточнаяТаблица.Накладная = ОрдераВСтатусеОтгружен.Накладная
	|			И ПромежуточнаяТаблица.РабочийУчасток = ОрдераВСтатусеОтгружен.РабочийУчасток
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОтметкаКассыНарезка КАК ОтметкаКассыНарезка
	|		ПО (ОтметкаКассыНарезка.Ссылка = ПромежуточнаяТаблица.Накладная)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПромежуточнаяТаблица.Склад,
	|	ПромежуточнаяТаблица.РабочийУчасток,
	|	ПромежуточнаяТаблица.Накладная,
	|	ПромежуточнаяТаблица.Заказ,
	|	ПромежуточнаяТаблица.Получатель";
	
	Возврат ТекстЗапроса;
	
КонецФункции

&НаСервере
Процедура ЗаписатьДанныеВРегистр(ДанныеЗаписи)
	
	Набор = РегистрыСведений.СостоянияОтгрузкиНакладных.СоздатьНаборЗаписей();
	Набор.Отбор.Документ.Установить(ДанныеЗаписи.Документ);  
	Набор.Отбор.Склад.Установить(ДанныеЗаписи.Склад);  
	Набор.Отбор.РабочийУчасток.Установить(ДанныеЗаписи.РабочийУчасток);
	
	НоваяЗапись = Набор.Добавить(); 
	
	ЗаполнитьЗначенияСвойств(НоваяЗапись,ДанныеЗаписи);
	
	Если НЕ (НоваяЗапись.ОжидаетсяОтбор ИЛИ НоваяЗапись.Набирается ИЛИ  НоваяЗапись.Набран) Тогда
		НоваяЗапись.Отгружен = Истина;
		НоваяЗапись.ЧастичноОтгружен = Ложь;
	ИначеЕсли ДанныеЗаписи.ЕстьОрдер Тогда
		НоваяЗапись.ЧастичноОтгружен = Истина;
		НоваяЗапись.Отгружен = Ложь;
	Иначе 
		НоваяЗапись.Отгружен = Ложь;
		НоваяЗапись.ЧастичноОтгружен = Ложь;
	КонецЕсли;
	
	Набор.Записать(Истина);
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьДанныеВРегистрПоЗаказам(ДанныеЗаписи)
	
	Набор = РегистрыСведений.СостоянияОтгрузкиНакладных.СоздатьНаборЗаписей();
	Набор.Отбор.Документ.Установить(ДанныеЗаписи.Документ);  
	Набор.Отбор.Склад.Установить(ДанныеЗаписи.Склад);  
	Набор.Отбор.РабочийУчасток.Установить(ДанныеЗаписи.РабочийУчасток);
	Набор.Отбор.Заказ.Установить(ДанныеЗаписи.Заказ); 
	
	НоваяЗапись = Набор.Добавить(); 
	
	ЗаполнитьЗначенияСвойств(НоваяЗапись,ДанныеЗаписи);
	
	Если НЕ (НоваяЗапись.ОжидаетсяОтбор ИЛИ НоваяЗапись.Набирается ИЛИ  НоваяЗапись.Набран) Тогда
		НоваяЗапись.Отгружен = Истина;
		НоваяЗапись.ЧастичноОтгружен = Ложь;
	ИначеЕсли ДанныеЗаписи.ЕстьОрдер Тогда
		НоваяЗапись.ЧастичноОтгружен = Истина;
		НоваяЗапись.Отгружен = Ложь;
	Иначе 
		НоваяЗапись.Отгружен = Ложь;
		НоваяЗапись.ЧастичноОтгружен = Ложь;
	КонецЕсли;
	
	Набор.Записать(Истина);
	
КонецПроцедуры
&НаСервере
Процедура ПриИзмененииСкладаИлиНесколькоЗаказов(Накладная,Склад,НесколькоЗаказов=Ложь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Истина КАК Проверка
	|ИЗ
	|	РегистрСведений.СостоянияОтгрузкиНакладных КАК СостоянияОтгрузкиНакладных
	|ГДЕ
	|	СостоянияОтгрузкиНакладных.Документ = &Накладная 
	|   И Не СостоянияОтгрузкиНакладных.Склад = &Склад";

	Запрос.УстановитьПараметр("Накладная", Накладная);
	Запрос.УстановитьПараметр("Склад", Склад);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если Не РезультатЗапроса.Пустой() ИЛИ НесколькоЗаказов Тогда 
		УдалениеЗаписейВРегистре(Накладная);
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура УдалениеЗаписейВРегистре(Документ) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Если Документ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Набор = РегистрыСведений.СостоянияОтгрузкиНакладных.СоздатьНаборЗаписей();
	Набор.Отбор.Документ.Установить(Документ.Ссылка);
	Набор.Прочитать();
	Если Набор.Количество() Тогда
		Набор.Очистить();
		Набор.Записать(Истина);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);   
	
КонецПроцедуры


#КонецЕсли
