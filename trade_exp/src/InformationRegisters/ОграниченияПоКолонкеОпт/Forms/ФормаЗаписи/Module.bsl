
#Область ОбработчикиСобытийЭлементовШапкиФормы
&НаКлиенте
Процедура ТСКПриИзменении(Элемент)
	ОграничитьЗначения("ТСК");
КонецПроцедуры


&НаКлиенте
Процедура МДПриИзменении(Элемент)
	ОграничитьЗначения("МД");
КонецПроцедуры

&НаКлиенте
Процедура МДРПриИзменении(Элемент)
	ОграничитьЗначения("МДР");
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаКлиенте
Процедура ОграничитьЗначения(ИмяРеквизита)
	если имяРеквизита="ТСК" тогда
		если Запись.ТСК=4 тогда
			Запись.МД=4; 
			Запись.МДР=4; 
		иначе
			Запись.МД=5;
			Запись.МДР=5; 
		конецесли;	
	 конецесли;
КонецПроцедуры


&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
	
	если Запись.ИсходныйКлючЗаписи.Пустой() тогда  
		Запись.ТСК=4;
		Запись.МД=4;
		Запись.МДР=4;
	конецесли;	
	
КонецПроцедуры
#КонецОбласти