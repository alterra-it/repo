#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
Функция ПолучитьАналогиНоменклатуры(Номенклатура,ВидЦены,Склад) Экспорт
		УстановитьПривилегированныйРежим(Истина);
		Запрос = Новый Запрос; 
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	АналогиНоменклатуры.АналогНоменклатуры КАК АналогНоменклатуры,
			|	МАКСИМУМ(АналогиНоменклатуры.Приоритет) КАК Приоритет
			|ПОМЕСТИТЬ ВТ_Аналоги
			|ИЗ
			|	РегистрСведений.АналогиНоменклатуры КАК АналогиНоменклатуры
			|ГДЕ
			|	АналогиНоменклатуры.Номенклатура = &Номенклатура
			|
			|СГРУППИРОВАТЬ ПО
			|	АналогиНоменклатуры.АналогНоменклатуры
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	АналогНоменклатуры
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_Аналоги.АналогНоменклатуры КАК АналогНоменклатуры,
			|	ВТ_Аналоги.Приоритет КАК Приоритет,
			|	ЕСТЬNULL(ХарактеристикиНоменклатуры.Ссылка, ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК Ссылка
			|ПОМЕСТИТЬ ВТ_АналогиХарактеристики
			|ИЗ
			|	ВТ_Аналоги КАК ВТ_Аналоги
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
			|		ПО ВТ_Аналоги.АналогНоменклатуры = ХарактеристикиНоменклатуры.Владелец
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СУММА(ЕСТЬNULL(СвободныеОстаткиОстатки.ВНаличииОстаток, 0) + ЕСТЬNULL(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток, 0)) КАК Остаток,
			|	СУММА(ЕСТЬNULL(СвободныеОстаткиОстатки.ВНаличииОстаток, 0) - ЕСТЬNULL(ТоварыКОтгрузкеОстатки.ВРезервеОстаток, 0)) КАК Доступно,
			|	МАКСИМУМ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0)) КАК Цена,
			|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс КАК Класс,
			|	ВТ_АналогиХарактеристики.АналогНоменклатуры КАК АналогНоменклатуры,
			|	ВТ_АналогиХарактеристики.Приоритет КАК Приоритет
			|ПОМЕСТИТЬ ВТ_ДанныеАналогов
			|ИЗ
			|	ВТ_АналогиХарактеристики КАК ВТ_АналогиХарактеристики
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
			|		ПО ВТ_АналогиХарактеристики.АналогНоменклатуры = ЦеныНоменклатурыСрезПоследних.Номенклатура
			|			И ВТ_АналогиХарактеристики.Ссылка = ЦеныНоменклатурыСрезПоследних.Характеристика
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних(, Подразделение = &Подразделение) КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
			|		ПО ВТ_АналогиХарактеристики.АналогНоменклатуры = ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура
			|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
			|			ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
			|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК ВНаличииОстаток,
			|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Свободно,
			|			СУММА(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Резерв
			|		ИЗ
			|			РегистрНакопления.ЗапасыИПотребности.Остатки(
			|					,
			|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
			|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки
			|		
			|		СГРУППИРОВАТЬ ПО
			|			ЗапасыИПотребностиОстатки.Номенклатура,
			|			ЗапасыИПотребностиОстатки.Характеристика) КАК СвободныеОстаткиОстатки
			|		ПО ВТ_АналогиХарактеристики.АналогНоменклатуры = СвободныеОстаткиОстатки.Номенклатура
			|			И ВТ_АналогиХарактеристики.Ссылка = СвободныеОстаткиОстатки.Характеристика
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &Склад) КАК ТоварыКОтгрузкеОстатки
			|		ПО ВТ_АналогиХарактеристики.АналогНоменклатуры = ТоварыКОтгрузкеОстатки.Номенклатура
			|			И ВТ_АналогиХарактеристики.Ссылка = ТоварыКОтгрузкеОстатки.Характеристика
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_АналогиХарактеристики.АналогНоменклатуры,
			|	ВТ_АналогиХарактеристики.Приоритет,
			|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_ДанныеАналогов.АналогНоменклатуры КАК Номенклатура,
			|	ВТ_ДанныеАналогов.Остаток КАК Остаток,
			|	ВТ_ДанныеАналогов.Доступно КАК Доступно,
			|	ВТ_ДанныеАналогов.Цена КАК Цена,
			|	ВТ_ДанныеАналогов.Класс КАК Класс,
			|	ВТ_ДанныеАналогов.Приоритет КАК Приоритет,
			|	ВТ_ДанныеАналогов.АналогНоменклатуры.ПометкаУдаления КАК ПометкаУдаления,
			|	ВТ_ДанныеАналогов.АналогНоменклатуры.Код КАК Код,
			|	&Склад КАК Склад,
			|	&ВидЦены КАК ВидЦены,
			|	ВТ_ДанныеАналогов.АналогНоменклатуры.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			|	ИСТИНА КАК ЭтоТовар,
			|	ЛОЖЬ КАК ЭтоУслуга,
			|	ЛОЖЬ КАК ЭтоГруппа,
			|	ВТ_ДанныеАналогов.АналогНоменклатуры.ИспользованиеХарактеристик <> ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать) КАК ХарактеристикиИспользуются
			|ИЗ
			|	ВТ_ДанныеАналогов КАК ВТ_ДанныеАналогов
			|
			|УПОРЯДОЧИТЬ ПО
			|	Приоритет";
			
		Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
		Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
		Запрос.УстановитьПараметр("Подразделение", Склад.Подразделение);
		Запрос.УстановитьПараметр("Склад", Склад);
		
		РезультатЗапроса = Новый ТаблицаЗначений;
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		УстановитьПривилегированныйРежим(Ложь);
		
		Возврат РезультатЗапроса;
		
КонецФункции	
	
Функция ЕстьАналогСТемжеПриоритетом(ТекЗапись) Экспорт 
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	АналогиНоменклатуры.Номенклатура КАК Номенклатура,
		|	АналогиНоменклатуры.Характеристика КАК Характеристика,
		|	АналогиНоменклатуры.АналогНоменклатуры КАК АналогНоменклатуры,
		|	АналогиНоменклатуры.АналогХарактеристики КАК АналогХарактеристики,
		|	АналогиНоменклатуры.Кратность КАК Кратность,
		|	АналогиНоменклатуры.Приоритет КАК Приоритет,
		|	АналогиНоменклатуры.ОбратнаяАналогия КАК ОбратнаяАналогия
		|ИЗ
		|	РегистрСведений.АналогиНоменклатуры КАК АналогиНоменклатуры
		|ГДЕ
		|	АналогиНоменклатуры.Номенклатура = &Номенклатура
		|	И АналогиНоменклатуры.Характеристика = &Характеристика
		|	И АналогиНоменклатуры.Приоритет = &Приоритет";
		
		Запрос.УстановитьПараметр("Номенклатура", ТекЗапись.Номенклатура);
		Запрос.УстановитьПараметр("Характеристика", ТекЗапись.Характеристика);
		Запрос.УстановитьПараметр("Приоритет", ТекЗапись.Приоритет);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Возврат ?(ВыборкаДетальныеЗаписи.Количество() = 0, Ложь, Истина);
КонецФункции
	
#КонецЕсли