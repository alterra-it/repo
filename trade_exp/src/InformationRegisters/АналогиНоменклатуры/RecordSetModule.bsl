#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ЭтотОбъект.Количество()=0 Тогда
		Если  Модифицированность() Тогда
			Попытка
				
				АналогНоменклатуры = ЭтотОбъект.Отбор.АналогНоменклатуры.Значение;
				Номенклатуры = ЭтотОбъект.Отбор.Номенклатура.Значение;       
				ХарактеристикаАналогНоменклатуры = ЭтотОбъект.Отбор.АналогХарактеристики.Значение;
				ХарактеристикаНоменклатуры = ЭтотОбъект.Отбор.Характеристика.Значение;
				
				НаборЗаписей = РегистрыСведений.АналогиНоменклатуры.СоздатьНаборЗаписей(); 
				НаборЗаписей.Отбор.Номенклатура.Установить(АналогНоменклатуры);
				НаборЗаписей.Отбор.Характеристика.Установить(ХарактеристикаАналогНоменклатуры);
				НаборЗаписей.Отбор.АналогНоменклатуры.Установить(Номенклатуры);
				НаборЗаписей.Отбор.АналогХарактеристики.Установить(ХарактеристикаНоменклатуры);
				НаборЗаписей.Прочитать();
				
				Для каждого ЗаписьНабора из НаборЗаписей Цикл
					Если ЗаписьНабора.ОбратнаяАналогия Тогда
						ЗаписьНабора.ОбратнаяАналогия = Ложь;
					КонецЕсли;
				КонецЦикла;
				
				НаборЗаписей.Записать(); 
				
			Исключение
				Сообщить("Ошибка:" + ОписаниеОшибки());
			КонецПопытки
			
		КонецЕсли;
	Иначе
		Для Каждого ТекЗапись Из ЭтотОбъект Цикл
			Если Не (ЗначениеЗаполнено(ТекЗапись.Номенклатура) И ЗначениеЗаполнено(ТекЗапись.АналогНоменклатуры)) Тогда
				Отказ = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&Вместо("ПриЗаписи")
Процедура ПриЗаписи(Отказ, Замещение)
	Для Каждого ТекЗапись Из ЭтотОбъект Цикл
		Попытка
			Если ТекЗапись.ОбратнаяАналогия Тогда
				Если Не ЕстьАналогичнаяЗапись(ТекЗапись.АналогНоменклатуры,ТекЗапись.АналогХарактеристики,ТекЗапись.Номенклатура,ТекЗапись.Характеристика) Тогда
					ОбратнаяЗапись = РегистрыСведений.АналогиНоменклатуры.СоздатьМенеджерЗаписи();
					ОбратнаяЗапись.Номенклатура = ТекЗапись.АналогНоменклатуры;
					ОбратнаяЗапись.АналогНоменклатуры = ТекЗапись.Номенклатура;
					ОбратнаяЗапись.Характеристика = ТекЗапись.АналогХарактеристики;
					ОбратнаяЗапись.АналогХарактеристики = ТекЗапись.Характеристика;
					ОбратнаяЗапись.Кратность = ?(ТекЗапись.Кратность <> 0,Окр(1/ТекЗапись.Кратность,1,РежимОкругления.Окр15как20),0);
					ОбратнаяЗапись.ОбратнаяАналогия = Истина;
					ОбратнаяЗапись.Записать();
				КонецЕсли;
			Иначе
				Если ЕстьАналогичнаяЗапись(ТекЗапись.АналогНоменклатуры,ТекЗапись.АналогХарактеристики,ТекЗапись.Номенклатура,ТекЗапись.Характеристика) Тогда
					НаборЗаписей = РегистрыСведений.АналогиНоменклатуры.СоздатьНаборЗаписей(); 
					НаборЗаписей.Отбор.Номенклатура.Установить(ТекЗапись.АналогНоменклатуры);
					НаборЗаписей.Отбор.Характеристика.Установить(ТекЗапись.АналогХарактеристики);
					НаборЗаписей.Отбор.АналогНоменклатуры.Установить(ТекЗапись.Номенклатура);
					НаборЗаписей.Отбор.АналогХарактеристики.Установить(ТекЗапись.Характеристика);
					НаборЗаписей.Записать();
				КонецЕсли;
			КонецЕсли;
		Исключение
			Сообщить("Ошибка:" + ОписаниеОшибки());
		КонецПопытки
	КонецЦикла;
КонецПроцедуры

Функция ЕстьАналогичнаяЗапись(АналогНоменклатуры,АналогХарактеристики,Номенклатура,Характеристика)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АналогиНоменклатуры.Номенклатура КАК Номенклатура,
		|	АналогиНоменклатуры.Характеристика КАК Характеристика,
		|	АналогиНоменклатуры.АналогНоменклатуры КАК АналогНоменклатуры,
		|	АналогиНоменклатуры.АналогХарактеристики КАК АналогХарактеристики,
		|	АналогиНоменклатуры.Кратность КАК Кратность,
		|	АналогиНоменклатуры.Приоритет КАК Приоритет,
		|	АналогиНоменклатуры.ОбратнаяАналогия КАК ОбратнаяАналогия
		|ИЗ
		|	РегистрСведений.АналогиНоменклатуры КАК АналогиНоменклатуры
		|ГДЕ
		|	АналогиНоменклатуры.Номенклатура = &АналогНоменклатуры
		|	И АналогиНоменклатуры.Характеристика = &АналогХарактеристики
		|	И АналогиНоменклатуры.АналогНоменклатуры = &Номенклатура
		|	И АналогиНоменклатуры.АналогХарактеристики = &Характеристика";
	
	Запрос.УстановитьПараметр("АналогНоменклатуры", АналогНоменклатуры);
	Запрос.УстановитьПараметр("АналогХарактеристики", АналогХарактеристики);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

    Возврат ?(ВыборкаДетальныеЗаписи.Количество() = 0, Ложь, Истина);
КонецФункции

#КонецЕсли

