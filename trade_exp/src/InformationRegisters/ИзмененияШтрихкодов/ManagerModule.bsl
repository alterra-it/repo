
&НаСервере
Процедура НачальноеЗаполнениеРегистраИзмененийШтрихкодов() Экспорт
    
    Если НЕ РольДоступна("ПолныеПрава") Тогда
		Возврат;
	КонецЕсли;
    
    НаборШтрихкодовНоменклатуры = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьНаборЗаписей();
    НаборШтрихкодовНоменклатуры.Прочитать();
    
    ТекДата = ТекущаяДата();
    ТЗ = НаборШтрихкодовНоменклатуры.Выгрузить();
    
    ТЗ.Колонки.Добавить("Период");
    ТЗ.Колонки.Добавить("Пользователь");
    
    ТЗ.ЗаполнитьЗначения(ТекДата, "Период");
    ТЗ.ЗаполнитьЗначения(Пользователи.ТекущийПользователь(), "Пользователь");

    НаборИзменений = РегистрыСведений.ИзмененияШтрихкодов.СоздатьНаборЗаписей();
    НаборИзменений.Загрузить(ТЗ);
    НаборИзменений.Записать();
    
КонецПроцедуры