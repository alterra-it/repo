
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Ключ") Тогда
		Если ТипЗнч(Параметры.Ключ) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Водитель", Параметры.Ключ, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Свойство("Ключ") Тогда
		Если ТипЗнч(Параметры.Ключ) = Тип("СправочникСсылка.ТранспортныеСредства") Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Автомобиль", Параметры.Ключ, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Свойство("Ключ") Тогда
		Если ТипЗнч(Параметры.Ключ) = Тип("СправочникСсылка.Партнеры") Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "ПеревозчикПартнер", Параметры.Ключ, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.Свойство("Ключ") Тогда
		Если ТипЗнч(Параметры.Ключ) = Тип("СправочникСсылка.Контрагенты") Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "ПеревозчикКонтрагент", Параметры.Ключ, ВидСравненияКомпоновкиДанных.Равно,, Истина);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
