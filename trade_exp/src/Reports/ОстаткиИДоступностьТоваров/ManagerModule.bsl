 #Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

// Текст запроса должен быть добавлен к запросу, в котором существует ОтборПоСегментуНоменклатуры с полями Номенклатура, Характеристика, ИспользуетсяОтборПоСегментуНоменклатуры
// Если не передан чек УстановитьВручнуюТаблицуНоменклатуры, она будет создана типовым способом
//
// В этой функции ИспользуетсяОтборПоСегментуНоменклатуры = ИСТИНА и ПоказатьОбособленныеТовары = ЛОЖЬ, но это можно изменить, передав соответствующие флаги функции
// Параметр запроса ИспользуетсяОтборПоСегментуНоменклатуры устанавливается вызовом функции СегментыСервер.ВключитьОтборПоСегментуНоменклатурыВСКД,
// 		Она принимает Параметры:
//  		ОбъектНастройки 			- КомпоновщикНастроекКомпоновкиДанных, НастройкиВложенногоОбъектаКомпоновкиДанных - откуда брать настройки.
//  		ИспользоватьТолькоНастройки - Булево - признак того, что будут использованы настройки по умолчанию.
// Параметр запроса ПоказатьОбособленныеТовары устанавливается пользовательскими настройками
//
// Параметры:
//		НазваниеТаблицыОтстатков 					- Строка - название временной таблицы, в которую будут помещены остатки
//		УстановитьВручнуюТаблицуНоменклатуры		- Булево - признак того, что таблица Номенклатуры "ОтборПоСегментуНоменклатуры" уже задана в запросе, к которому добавляется текст
//		УстановитьВручнуюОтборПоСегменту 			- Булево - признак того, что ИспользуетсяОтборПоСегментуНоменклатуры будет установлен позже вручную
//		УстановитьВручнуюПоказОбособленныхТоваров 	- Булево - признак того, что ПоказатьОбособленныеТовары будет установлен позже вручную
//
// Возвращаемое значение:
//		Строка   - Текст запроса фактических остатков, выбранных во временную таблицу остатков с названием по умолчанию ЗапасыИПотребности с полями:
// 			- Номенклатура,
//			- Характеристика,
// 			- Склад,
// 			- Назначение,
//			- Заказ,
//			- ДатаСобытия,
//			- ВНаличииОстаток,
//			- ПоступитОстаток
//
Функция ПолучитьТекстЗапросаОстатков(НазваниеТаблицыОтстатков = "ЗапасыИПотребности", УстановитьВручнуюТаблицуНоменклатуры = Ложь, УстановитьВручнуюОтборПоСегменту = Ложь, УстановитьВручнуюПоказОбособленныхТоваров = Ложь) Экспорт
	
	ТекстТаблицаСегмент = "// Временная таблица отбора: ОтборПоСегментуНоменклатуры.
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	Сегменты.Номенклатура КАК Номенклатура,
	|	Сегменты.Характеристика КАК Характеристика,
	|	ИСТИНА КАК ИспользуетсяОтборПоСегментуНоменклатуры
	|ПОМЕСТИТЬ ОтборПоСегментуНоменклатуры
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК Сегменты
	|{ГДЕ
	|	Сегменты.Сегмент.* КАК СегментНоменклатуры,
	|	Сегменты.Номенклатура.* КАК Номенклатура,
	|	Сегменты.Характеристика.* КАК Характеристика}
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура,
	|	Характеристика,
	|	ИспользуетсяОтборПоСегментуНоменклатуры
	|" + ОбщегоНазначенияУТ.РазделительЗапросовВПакете()
	+ "// Временная таблица отбора остатков: " + НазваниеТаблицыОтстатков + ".
	|";
	
	НачалоЗапроса = ?(Не УстановитьВручнуюТаблицуНоменклатуры, ТекстТаблицаСегмент, "// Временная таблица отбора остатков: " + НазваниеТаблицыОтстатков + ".
	|");
	
	Если ОбеспечениеВДокументахСервер.ЭтоПроизводительныйРежим() Тогда
		
		Текст =
			"ВЫБРАТЬ
			|	ИнформацияОДоступности.Номенклатура КАК Номенклатура,
			|	ИнформацияОДоступности.Характеристика КАК Характеристика,
			|	ИнформацияОДоступности.Склад КАК Склад,
			|	ИнформацияОДоступности.Назначение КАК Назначение,
			|	ИнформацияОДоступности.Заказ КАК Заказ,
			|	ИнформацияОДоступности.ДатаСобытия КАК ДатаСобытия,
			|	ИнформацияОДоступности.ВНаличииОстаток КАК ВНаличииОстаток,
			|	ИнформацияОДоступности.ПоступитОстаток КАК ПоступитОстаток
			|ПОМЕСТИТЬ " + НазваниеТаблицыОтстатков + "
			|ИЗ
			|	РегистрНакопления.ЗапасыИПотребности.Остатки(,
			|		Склад ССЫЛКА Справочник.Склады
			|			И ВЫБОР
			|				КОГДА &ПоказатьОбособленныеТовары
			|					ТОГДА
			|						ИСТИНА
			|				ИНАЧЕ Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
			|			КОНЕЦ
			|			{(Номенклатура, Характеристика) В(
			|				ВЫБРАТЬ
			|					ТаблицаОтбора.Номенклатура КАК Номенклатура,
			|					ТаблицаОтбора.Характеристика КАК Характеристика
			|				ИЗ
			|					ОтборПоСегментуНоменклатуры КАК ТаблицаОтбора
			|				ГДЕ
			|					ТаблицаОтбора.ИспользуетсяОтборПоСегментуНоменклатуры = &ИспользуетсяОтборПоСегментуНоменклатуры)}
			|			{Номенклатура.* КАК Номенклатура,
			|			Характеристика.* КАК Характеристика,
			|			Склад.* КАК Склад}) КАК ИнформацияОДоступности
			|";
		
	Иначе
		
		Текст =
			"ВЫБРАТЬ
			|	ИнформацияОДоступности.Номенклатура КАК Номенклатура,
			|	ИнформацияОДоступности.Характеристика КАК Характеристика,
			|	ИнформацияОДоступности.Склад КАК Склад,
			|	ИнформацияОДоступности.Назначение КАК Назначение,
			|	ИнформацияОДоступности.ЗаказНаПоступление КАК Заказ,
			|	ИнформацияОДоступности.ДатаПоступления КАК ДатаСобытия,
			|	ВЫБОР
			|		КОГДА ИнформацияОДоступности.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе)
			|			ТОГДА ИнформацияОДоступности.Запас
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК ВНаличииОстаток,
			|	ВЫБОР
			|		КОГДА ИнформацияОДоступности.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаемоеПоступление)
			|			ТОГДА ИнформацияОДоступности.Запас
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК ПоступитОстаток
			|ПОМЕСТИТЬ " + НазваниеТаблицыОтстатков + "
			|ИЗ
			|	РегистрСведений.РаспределениеЗапасов КАК ИнформацияОДоступности
			|		{ВНУТРЕННЕЕ СОЕДИНЕНИЕ ОтборПоСегментуНоменклатуры КАК ТаблицаОтбора
			|		ПО ТаблицаОтбора.Номенклатура = ИнформацияОДоступности.Номенклатура
			|			И ТаблицаОтбора.Характеристика = ИнформацияОДоступности.Характеристика}
			|ГДЕ
			|	ИнформацияОДоступности.Состояние В (
			|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе),
			|		ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОжидаемоеПоступление))
			|	И ИнформацияОДоступности.Запас <> 0
			|	И ИнформацияОДоступности.Склад ССЫЛКА Справочник.Склады
			|	И ВЫБОР
			|			КОГДА &ПоказатьОбособленныеТовары ТОГДА
			|				ИСТИНА
			|			ИНАЧЕ
			|				ИнформацияОДоступности.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
			|		КОНЕЦ
			|{ГДЕ
			|	ТаблицаОтбора.ИспользуетсяОтборПоСегментуНоменклатуры = &ИспользуетсяОтборПоСегментуНоменклатуры
			|}
			|{ГДЕ
			|	ИнформацияОДоступности.Склад.* КАК Склад,
			|	ИнформацияОДоступности.Номенклатура.* КАК Номенклатура,
			|	ИнформацияОДоступности.Характеристика.* КАК Характеристика}
			|";
		
	КонецЕсли;
	
	ОкончаниеЗапроса = "ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение";
	
	Текст = НачалоЗапроса + Текст + ОкончаниеЗапроса + ОбщегоНазначенияУТ.РазделительЗапросовВПакете();
	
	Если Не УстановитьВручнуюОтборПоСегменту Тогда
		Текст = СтрЗаменить(Текст, "&ИспользуетсяОтборПоСегментуНоменклатуры", "ИСТИНА");
	КонецЕсли;
	
	Если Не УстановитьВручнуюПоказОбособленныхТоваров Тогда
		Текст = СтрЗаменить(Текст, "&ПоказатьОбособленныеТовары", "ЛОЖЬ");
	КонецЕсли;
	
	Возврат Текст;

КонецФункции // ПолучитьТекстЗапросаОстатков()

// Текст запроса должен быть добавлен к запросу, в котором существует ТаблицаНоменклатуры с полями Номенклатура, Характеристика, Склад
// Если не передан чек УстановитьВручнуюТаблицуНоменклатуры, она будет создана согласно классификации и размещения по ячейкам
//
// Параметры:
//		НазваниеТаблицыОтстатков 					- Строка - название временной таблицы, в которую будут помещены остатки
//		УстановитьВручнуюТаблицуНоменклатуры		- Булево - признак того, что таблица Номенклатуры "ТаблицаНоменклатуры" уже задана в запросе, к которому добавляется текст
//		КонецПериода								- Строка в виде "yyyy,MM,dd,HH,mm,ss". Если не заполнено, будет взята Текущая дата
//
// Возвращаемое значение:
//		Строка   - Текст запроса фактических остатков, выбранных во временную таблицу остатков с названием по умолчанию ЗапасыИПотребности с полями:
// 			- Номенклатура,
//			- Характеристика,
// 			- Склад,
// 			- Ячейка, (опционально)
// 			- Класс, (опционально)
// 			- Назначение,
// 			- ВНаличии,
// 			- ВРезерве,
// 			- Доступно,
//			- РезервироватьПоМереПоступления,
//			- КОбеспечению,
//			- НеОбеспечивать
//
Функция ПолучитьТекстЗапросаОстатковНаДату(
	НазваниеТаблицыОтстатков = "ЗапасыИПотребности",
	УстановитьВручнуюТаблицуНоменклатуры = Ложь,
	КонецПериода = Неопределено,
	СКлассамиИЯчейками = Истина) Экспорт
	
	КонецПериода = ?(ЗначениеЗаполнено(КонецПериода), КонецПериода, Формат(ТекущаяДата(), "ДФ=yyyy,MM,dd,HH,mm,ss"));
	//КонецПериода = ?(ЗначениеЗаполнено(КонецПериода), КонецПериода, "3999, 01, 01, 00, 00, 00");
	
	Если СКлассамиИЯчейками Тогда
		ТекстТаблицаНоменклатуры = "ВЫБРАТЬ
           |	тНоменклатура.Ссылка КАК Номенклатура,
           |	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
           |	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Подразделение КАК Подразделение,
           |	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс КАК Класс
           |ПОМЕСТИТЬ ВТ_Класс
           |ИЗ
           |	Справочник.Номенклатура КАК тНоменклатура
           |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних({&КонецПериода_},) КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
           |		ПО тНоменклатура.Ссылка = ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура
           |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
           |		ПО (тНоменклатура.Ссылка = ХарактеристикиНоменклатуры.Владелец)
           |;
           |
           |////////////////////////////////////////////////////////////////////////////////
           |ВЫБРАТЬ
           |	ВТ_Класс.Номенклатура КАК Номенклатура,
           |	ВТ_Класс.Характеристика КАК Характеристика,
           |	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад КАК Склад,
           |	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
           |	ВТ_Класс.Класс КАК Класс
		   |ПОМЕСТИТЬ ТаблицаНоменклатуры
           |ИЗ
           |	ВТ_Класс КАК ВТ_Класс
           |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
           |		ПО ВТ_Класс.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
           |			И ВТ_Класс.Подразделение = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад.Подразделение
		   |" + ОбщегоНазначенияУТ.РазделительЗапросовВПакете()
			+ "// Временная таблица отбора остатков: &НазваниеТаблицыОтстатков.
			|";
	Иначе
		ТекстТаблицаНоменклатуры = "ВЫБРАТЬ
           |	тНоменклатура.Ссылка КАК Номенклатура,
           |	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
           |	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад КАК Склад
		   |ПОМЕСТИТЬ ТаблицаНоменклатуры
           |ИЗ
           |	Справочник.Номенклатура КАК тНоменклатура
           |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
           |		ПО (тНоменклатура.Ссылка = ХарактеристикиНоменклатуры.Владелец)
           |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
           |		ПО тНоменклатура.Ссылка = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		   |" + ОбщегоНазначенияУТ.РазделительЗапросовВПакете()
			+ "// Временная таблица отбора остатков: &НазваниеТаблицыОтстатков.
			|";
	КонецЕсли;
									
	
	НачалоЗапроса = ?(Не УстановитьВручнуюТаблицуНоменклатуры, ТекстТаблицаНоменклатуры, "// Временная таблица отбора остатков: " + НазваниеТаблицыОтстатков + ".
	|");
	
		
		Текст =		
			"ВЫБРАТЬ
			|	ЗапасыИПотребности.Номенклатура КАК Номенклатура,
			|	ЗапасыИПотребности.Характеристика КАК Характеристика,
			|	ЗапасыИПотребности.Склад КАК Склад,
			|	ЗапасыИПотребности.Назначение КАК Назначение,
			|	-ЗапасыИПотребности.ВНаличии КАК ВНаличии,
			|	-ЗапасыИПотребности.РезервироватьНаСкладе КАК ВРезерве,
			|	-ЗапасыИПотребности.РезервироватьПоМереПоступления КАК РезервироватьПоМереПоступления,
			|	-ЗапасыИПотребности.КОбеспечению КАК КОбеспечению,
			|	-ЗапасыИПотребности.НеОбеспечивать КАК НеОбеспечивать
			|ПОМЕСТИТЬ ВТ_Набор
			|ИЗ
			|	РегистрНакопления.ЗапасыИПотребности КАК ЗапасыИПотребности
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
			|		ПО ЗапасыИПотребности.Номенклатура = ТаблицаНоменклатуры.Номенклатура
			|ГДЕ
			|	ЗапасыИПотребности.Период <= &КонецПериода_
			|	И ЗапасыИПотребности.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ЗапасыИПотребности.Номенклатура,
			|	ЗапасыИПотребности.Характеристика,
			|	ЗапасыИПотребности.Склад,
			|	ЗапасыИПотребности.Назначение,
			|	ЗапасыИПотребности.ВНаличии,
			|	ЗапасыИПотребности.РезервироватьНаСкладе,
			|	ЗапасыИПотребности.РезервироватьПоМереПоступления,
			|	ЗапасыИПотребности.КОбеспечению,
			|	ЗапасыИПотребности.НеОбеспечивать
			|ИЗ
			|	РегистрНакопления.ЗапасыИПотребности КАК ЗапасыИПотребности
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
			|		ПО ЗапасыИПотребности.Номенклатура = ТаблицаНоменклатуры.Номенклатура
			|ГДЕ
			|	ЗапасыИПотребности.Период <= &КонецПериода_
			|	И ЗапасыИПотребности.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТ_Набор.Номенклатура КАК Номенклатура,
			|	ВТ_Набор.Характеристика КАК Характеристика,
			|	ВТ_Набор.Склад КАК Склад,
			|	ВТ_Набор.Назначение КАК Назначение,
			|	СУММА(ВТ_Набор.ВНаличии) КАК ВНаличии,
			|	СУММА(ВТ_Набор.ВРезерве) КАК ВРезерве,
			|	СУММА(ВТ_Набор.ВНаличии - ВТ_Набор.ВРезерве) КАК Доступно,
			|	СУММА(ВТ_Набор.РезервироватьПоМереПоступления) КАК РезервироватьПоМереПоступления,
			|	СУММА(ВТ_Набор.КОбеспечению) КАК КОбеспечению,
			|	СУММА(ВТ_Набор.НеОбеспечивать) КАК НеОбеспечивать
			|ПОМЕСТИТЬ ВТ_ТаблицаОтстатков
			|ИЗ
			|	ВТ_Набор КАК ВТ_Набор
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_Набор.Номенклатура,
			|	ВТ_Набор.Характеристика,
			|	ВТ_Набор.Склад,
			|	ВТ_Набор.Назначение";
		
	
	Если СКлассамиИЯчейками Тогда
		Текст = Текст + ОбщегоНазначенияУТ.РазделительЗапросовВПакете() + "ВЫБРАТЬ
			|	ВТ_ТаблицаОтстатков.Номенклатура КАК Номенклатура,
			|	ВТ_ТаблицаОтстатков.Характеристика КАК Характеристика,
			|	ВТ_ТаблицаОтстатков.Склад КАК Склад,
			|	ТаблицаНоменклатуры.Ячейка КАК Ячейка,
			|	ТаблицаНоменклатуры.Класс КАК Класс,
			|	ВТ_ТаблицаОтстатков.Назначение КАК Назначение,
			|	ВТ_ТаблицаОтстатков.ВНаличии КАК ВНаличии,
			|	ВТ_ТаблицаОтстатков.ВРезерве КАК ВРезерве,
			|	ВТ_ТаблицаОтстатков.Доступно КАК Доступно,
			|	ВТ_ТаблицаОтстатков.Доступно КАК РезервироватьПоМереПоступления,
			|	ВТ_ТаблицаОтстатков.Доступно КАК КОбеспечению,
			|	ВТ_ТаблицаОтстатков.Доступно КАК НеОбеспечивать
			|ПОМЕСТИТЬ &НазваниеТаблицыОтстатков
			|ИЗ
			|	ВТ_ТаблицаОтстатков КАК ВТ_ТаблицаОтстатков
			|		ЛЕВОЕ СОЕДИНЕНИЕ ТаблицаНоменклатуры КАК ТаблицаНоменклатуры
			|		ПО ВТ_ТаблицаОтстатков.Номенклатура = ТаблицаНоменклатуры.Номенклатура
			|			И ВТ_ТаблицаОтстатков.Характеристика = ТаблицаНоменклатуры.Характеристика
			|			И ВТ_ТаблицаОтстатков.Склад = ТаблицаНоменклатуры.Склад
			|";
	Иначе
		Текст = Текст + ОбщегоНазначенияУТ.РазделительЗапросовВПакете() + "ВЫБРАТЬ *
			|ПОМЕСТИТЬ &НазваниеТаблицыОтстатков
			|ИЗ
			|	ВТ_ТаблицаОтстатков КАК ВТ_ТаблицаОтстатков
			|";
	КонецЕсли;
		
	ОкончаниеЗапроса = "ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура, Характеристика, Склад, Назначение";
	
	Текст = НачалоЗапроса + Текст + ОкончаниеЗапроса + ОбщегоНазначенияУТ.РазделительЗапросовВПакете();
	                                                                                
	Текст = СтрЗаменить(Текст, "&КонецПериода_", "ДАТАВРЕМЯ(" + КонецПериода + ")");

	Текст = СтрЗаменить(Текст, "&НазваниеТаблицыОтстатков", НазваниеТаблицыОтстатков);
	
	Возврат Текст;

КонецФункции // ПолучитьТекстЗапросаОстатковНаДату()

 #КонецЕсли
