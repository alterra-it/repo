					<v8:content>Цена набора</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СчетчикКомплектующих</dataPath>
			<field>СчетчикКомплектующих</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Счетчик комплектующих</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВидЦеныНаименование</dataPath>
			<field>ВидЦеныНаименование</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Вид цены </v8:content>
				</v8:item>
			</title>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЗНАЧЕНИЕ(Справочник.номенклатура.ПустаяСсылка) КАК НаборНоменклатуры,
	0 КАК КоличествоВНаборе,
	0 КАК ЦенаНабора,
	0 КАК СчетчикКомплектующих,
	ЗНАЧЕНИЕ(Справочник.номенклатура.ПустаяСсылка) КАК Номенклатура,
	ЗНАЧЕНИЕ(Справочник.Характеристикиноменклатуры.ПустаяСсылка) КАК Характеристика,
	ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка) КАК ВидЦены,
	"" КАК Цена,
	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
	ЗНАЧЕНИЕ(Справочник.Валюты.ПустаяСсылка) КАК Валюта,
	ЗНАЧЕНИЕ(Справочник.ЦеновыеГруппы.ПустаяСсылка) КАК ЦеноваяГруппа,
	ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка) КАК Склад,
	0 КАК Остаток,
	"" КАК ОстатокТекстом,
	"" КАК ВидЦеныНаименование
{ВЫБРАТЬ
	Номенклатура.*,
	Характеристика.*,
	ВидЦены.*,
	Цена,
	Упаковка,
	Валюта.*,
	ЦеноваяГруппа.*,
	Склад.*}
ГДЕ
	&amp;ДатаОтчета = ДАТАВРЕМЯ(1, 1, 1)
	И &amp;Период = ДАТАВРЕМЯ(1, 1, 1)
	И &amp;ИспользуетсяОтборПоСегментуНоменклатуры
	И &amp;ИспользуетсяОтборПоАссортименту
	И &amp;ВидыЦен
	И &amp;ТекстЗапросаКоэффициентУпаковки
	И &amp;ПодстановкаТоварногоОграничения
	И &amp;РазмерИзображений
	И &amp;ТекстЗапросаВторойКоэффициентУпаковки
{ГДЕ
	(ЗНАЧЕНИЕ(Справочник.номенклатура.ПустаяСсылка)).* КАК Номенклатура}</query>
	</dataSet>
	<totalField>
		<dataPath>Валюта</dataPath>
		<expression>Максимум(Валюта)</expression>
	</totalField>
	<totalField>
		<dataPath>Цена</dataPath>
		<expression>Выбор Когда Количество(Различные Цена) = 1 Тогда Максимум(Цена) Иначе Неопределено Конец</expression>
		<group>Номенклатура</group>
	</totalField>
	<totalField>
		<dataPath>Остаток</dataPath>
		<expression>Выбор Когда Количество(Различные Остаток) = 1 Тогда Максимум(Остаток) Иначе Неопределено Конец</expression>
		<group>Номенклатура</group>
		<group>НаборНоменклатуры</group>
	</totalField>
	<totalField>
		<dataPath>ОстатокТекстом</dataPath>
		<expression>Выбор Когда Количество(Различные ОстатокТекстом) = 1 Тогда Максимум(ОстатокТекстом) Иначе Неопределено Конец</expression>
		<group>Номенклатура</group>
		<group>НаборНоменклатуры</group>
	</totalField>
	<totalField>
		<dataPath>Цена</dataPath>
		<expression>Выбор Когда Сумма(СчетчикКомплектующих)&gt;0 И Количество(Различные Валюта)&gt;1 Тогда "-" 
Иначе Выбор Когда Количество(Различные Склад)&gt;0 и Сумма(СчетчикКомплектующих)/Количество(Различные Склад)&gt;1 Тогда Сумма(ЦенаНабора)/Количество(Различные Склад) 
Иначе Выбор Когда Количество(Различные Склад)=0 И Сумма(СчетчикКомплектующих)&gt;1 Тогда Сумма(ЦенаНабора) 
Иначе Выбор Когда Количество(Различные Цена) = 1 Тогда Максимум(Цена) Иначе Неопределено Конец Конец Конец Конец</expression>
		<group>НаборНоменклатуры</group>
	</totalField>
	<totalField>
		<dataPath>Цена</dataPath>
		<expression>0</expression>
		<group>Номенклатура Иерархия</group>
		<group>НаборНоменклатуры Иерархия</group>
	</totalField>
	<totalField>
		<dataPath>Остаток</dataPath>
		<expression>0</expression>
		<group>Номенклатура Иерархия</group>
		<group>НаборНоменклатуры Иерархия</group>
	</totalField>
	<totalField>
		<dataPath>ОстатокТекстом</dataPath>
		<expression>0</expression>
		<group>Номенклатура Иерархия</group>
		<group>НаборНоменклатуры Иерархия</group>
	</totalField>
	<parameter>
		<name>ДатаОтчета</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Дата отчета</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>false</useRestriction>
		<denyIncompleteValues>true</denyIncompleteValues>
		<use>Always</use>
	</parameter>
	<parameter>
		<name>ВидыЦен</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Виды цен</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type xmlns:d4p1="http://v8.1c.ru/8.1/data/enterprise/current-config">d4p1:CatalogRef.ВидыЦен</v8:Type>
		</valueType>
		<useRestriction>false</useRestriction>
		<valueListAllowed>true</valueListAllowed>
	</parameter>
	<parameter>
		<name>ИспользуетсяОтборПоСегментуНоменклатуры</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Используется отбор по сегменту номенклатуры</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:boolean</v8:Type>
		</valueType>
		<value xsi:type="xs:boolean">false</value>
		<useRestriction>true</useRestriction>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>ИспользуетсяОтборПоАссортименту</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Используется отбор по ассортименту</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:boolean</v8:Type>
		</valueType>
		<value xsi:type="xs:boolean">false</value>
		<useRestriction>true</useRestriction>
		<availableAsField>false</availableAsField>
	</parameter>
	<parameter>
		<name>ТекстЗапросаКоэффициентУпаковки</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Текст запроса коэффициент упаковки</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:decimal</v8:Type>
			<v8:NumberQualifiers>
				<v8:Digits>0</v8:Digits>
				<v8:FractionDigits>0</v8:FractionDigits>
				<v8:AllowedSign>Any</v8:AllowedSign>
			</v8:NumberQualifiers>
		</valueType>
		<value xsi:type="xs:decimal">0</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>ПодстановкаТоварногоОграничения</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Подстановка товарного ограничения</v8:content>
			</v8:item>
		</title>
		<value xsi:nil="true"/>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>РазмерИзображений</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Размер изображений</v8:content>
			</v8:item>
		</title>
		<value xsi:nil="true"/>
		<useRestriction>false</useRestriction>
		<availableValue>
			<value xsi:type="dcscor:DesignTimeValue">Перечисление.РазмерКартинок.Маленькие</value>
		</availableValue>
		<availableValue>
			<value xsi:type="dcscor:DesignTimeValue">Перечисление.РазмерКартинок.Средние</value>
		</availableValue>
		<availableValue>
			<value xsi:type="dcscor:DesignTimeValue">Перечисление.РазмерКартинок.Большие</value>
		</availableValue>
	</parameter>
	<parameter>
		<name>ТекстЗапросаВторойКоэффициентУпаковки</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Текст запроса второй коэффициент упаковки</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:decimal</v8:Type>
			<v8:NumberQualifiers>
				<v8:Digits>0</v8:Digits>
				<v8:FractionDigits>0</v8:FractionDigits>
				<v8:AllowedSign>Any</v8:AllowedSign>
			</v8:NumberQualifiers>
		</valueType>
		<value xsi:type="xs:decimal">0</value>
		<useRestriction>true</useRestriction>
	</parameter>
	<parameter>
		<name>Период</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>На дату</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>DateTime</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:type="xs:dateTime">0001-01-01T00:00:00</value>
		<useRestriction>true</useRestriction>
		<expression>ВЫБОР КОГДА &amp;ДатаОтчета= ДатаВремя(1,1,1) Тогда КонецПериода(ТекущаяДата(),"День") Иначе КонецПериода(&amp;ДатаОтчета,"День") КОНЕЦ</expression>
	</parameter>
	<template>
		<name>Макет1</name>
		<template xmlns:dcsat="http://v8.1c.ru/8.1/data-composition-system/area-template" xsi:type="dcsat:AreaTemplate">
			<dcsat:item xsi:type="dcsat:TableRow">
				<dcsat:tableCell>
					<dcsat:item xsi:type="dcsat:Field">
						<dcsat:value xsi:type="v8:LocalStringType">
							<v8:item>
								<v8:lang>ru</v8:lang>
								<v8:content>Прайс-лист на </v8:content>
							</v8:item>
						</dcsat:value>
						<dcsat:appearance>
							<dcscor:item>
								<dcscor:parameter>Формат</dcscor:parameter>
								<dcscor:value xsi:type="xs:string">ДЛФ=ДД</dcscor:value>
							</dcscor:item>
						</dcsat:appearance>
					</dcsat:item>
					<dcsat:item xsi:type="dcsat:Field">
						<dcsat:value xsi:type="dcscor:Parameter">Период</dcsat:value>
						<dcsat:appearance>
							<dcscor:item>
								<dcscor:parameter>Формат</dcscor:parameter>
								<dcscor:value xsi:type="xs:string">ДЛФ=ДД</dcscor:value>
							</dcscor:item>
						</dcsat:appearance>
					</dcsat:item>
					<dcsat:appearance>
						<dcscor:item>
							<dcscor:parameter>Шрифт</dcscor:parameter>
							<dcscor:value xsi:type="v8ui:Font" faceName="Arial" height="12" bold="true" italic="false" underline="false" strikeout="false" kind="Absolute" scale="100"/>
