					<dcscor:parameter>ДатаОкончания</dcscor:parameter>
					<dcscor:value xsi:type="xs:dateTime">0001-01-01T00:00:00</dcscor:value>
					<dcsset:userSettingID>334c6bb7-d0b5-48ee-90f5-62fa9f7dd517</dcsset:userSettingID>
				</dcscor:item>
