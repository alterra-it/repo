		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;	
	
КонецФункции

Функция verifyPhone(Запрос)   
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка                               
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		Если Не ПараметрыВходногоЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПараметрыВходногоЗапроса.Сообщение);			
		КонецЕсли;	
		
		ДанныеЗапроса = Новый Структура("ТипВерификации, НомерТелефона, Действие, Результат, Сообщение", 
											Запрос.ПараметрыЗапроса.Получить("verify_type"),
											Запрос.ПараметрыЗапроса.Получить("phone"),
											Запрос.ПараметрыЗапроса.Получить("from"),  
											Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.ТипВерификации, 	"Не указан тип верификации verify_type (call, sms)");	
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.НомерТелефона,	"Не указан номер телефона phone");									
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Действие,			"Не указан источник верификации from (auth_card, auth_balance, auth_payment, register)");									
		Если Не ДанныеЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;											
	
        Верификация = Новый Структура("Код, Результат, Сообщение", "", Истина, "");

		Если ДанныеЗапроса.ТипВерификации = "call" Тогда   
			Верификация.Код = ИнтеграцияЗвонки.FlashCall(ДанныеЗапроса.НомерТелефона, ДанныеЗапроса.Действие);  
			Если Не ЗначениеЗаполнено(Верификация.Код) Тогда
				Верификация.Код = "0000";
			КонецЕсли;
				
		ИначеЕсли ДанныеЗапроса.ТипВерификации = "sms" Тогда    
			
			ТекстСмс = ИнтеграцияЗвонки.ПолучитьТекстСмс(ДанныеЗапроса.Действие);
			Если ТекстСмс = "" Тогда                                                      
				ТекстОшибки = СтрШаблон("Для типа verify_type = %1 не определен текст смс", ДанныеЗапроса.Действие);
				Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ТекстОшибки);			
			КонецЕсли;
			
			Генератор = Новый ГенераторСлучайныхЧисел;
			Верификация.Код = Формат(Генератор.СлучайноеЧисло(1000, 9999), "ЧГ=");
			
			Верификация.Сообщение = СтрШаблон(ТекстСмс, Верификация.Код);
			ОтправитьSMS(ДанныеЗапроса.НомерТелефона, Верификация.Сообщение);	
			
		КонецЕсли;
			
		Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, Верификация);    
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки; 
	
КонецФункции

Функция Login(Запрос) 
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка                               
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		Если Не ПараметрыВходногоЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПараметрыВходногоЗапроса.Сообщение);			
		КонецЕсли;	
		
		ДанныеЗапроса = Новый Структура("Документ, НомерТелефона, УИДКлиента, Результат, Сообщение", 
											Запрос.ПараметрыЗапроса.Получить("document_id"),
											Запрос.ПараметрыЗапроса.Получить("phone"),
											Запрос.ПараметрыЗапроса.Получить("user_id"),  
											Истина, ""); 

		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.УИДклиента, "");											
		Если Не ДанныеЗапроса.Результат  Тогда									
			ДанныеЗапроса.Результат = Истина;
			ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.НомерТелефона, "");
			Если Не ДанныеЗапроса.Результат Тогда									
				ДанныеЗапроса.Результат = Истина;
				ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.НомерТелефона, "Не введен номер телефона");
			КонецЕсли;
		КонецЕсли;  
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;				
	
		Авторизация = Авторизовать(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		Корзина = ?(Авторизация.Свойство("Корзина"), Авторизация.Корзина, Неопределено);
		
		Если Авторизация.Результат Тогда      
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, Авторизация);    

		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, Авторизация.Сообщение, , Корзина);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), , Корзина);			
	КонецПопытки;	
	
КонецФункции 

Функция Register(Запрос)  
	
	УстановитьПривилегированныйРежим(Истина);   
	
	Попытка                               
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		Если Не ПараметрыВходногоЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПараметрыВходногоЗапроса.Сообщение);			
		КонецЕсли;	
		
		ДанныеЗапроса = Новый Структура("Документ, НомерТелефона, Имя, Отчество, Фамилия, Результат, Сообщение", 
											Запрос.ПараметрыЗапроса.Получить("document_id"),
											Запрос.ПараметрыЗапроса.Получить("phone"),        
											Запрос.ПараметрыЗапроса.Получить("first_name"),     
											Запрос.ПараметрыЗапроса.Получить("second_name"),    
											Запрос.ПараметрыЗапроса.Получить("last_name"),  
											Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.НомерТелефона, 	"Не заполнен номер телефона");
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Имя, 				"Не заполнено имя");
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Фамилия, 			"Не заполнена фамилия"); 
		
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;
	
		Регистрация = Зарегистрировать(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		Корзина = ?(Регистрация.Свойство("Корзина"), Регистрация.Корзина, Неопределено);
		
