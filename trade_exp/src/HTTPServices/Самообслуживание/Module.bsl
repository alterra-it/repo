			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;
	
		ПолучениеПокупателей = ПолучитьПокупателей(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		
		Если ПолучениеПокупателей.Результат Тогда      
			
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ПолучениеПокупателей);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПолучениеПокупателей.Сообщение);			
