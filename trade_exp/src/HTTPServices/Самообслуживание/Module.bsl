Функция getMarkingImage(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);  
	
	Попытка                               
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		Если Не ПараметрыВходногоЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПараметрыВходногоЗапроса.Сообщение);			
		КонецЕсли;
		
		ДанныеЗапроса = Новый Структура("УИДВидМаркировки, Результат, Сообщение", 
											Запрос.ПараметрыЗапроса.Получить("product_type"),
											Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.УИДВидМаркировки, "Необходимо указать вид продукции (product_type)");
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;   
		
		ПередачаКартинкиМаркировки = ПередатьКартинкуМаркировки(ДанныеЗапроса);	   

		Если ПередачаКартинкиМаркировки.Результат Тогда                                                   
			
			КартинкаДД = ПередачаКартинкиМаркировки.Картинка.ПолучитьДвоичныеДанные();
			
			Ответ = Новый HTTPСервисОтвет(200);
			
			Заголовки = Новый Соответствие;
			ФорматКартинкиМаркировки = ?(ПередачаКартинкиМаркировки.Картинка.Формат() = ФорматКартинки.PNG, "image/png", "image/jpeg"); 
			Заголовки.Вставить("Content-Type", ФорматКартинкиМаркировки);
			Ответ.Заголовки = Заголовки;
			Ответ.УстановитьТелоИзДвоичныхДанных(КартинкаДД);
			
			ЗаписатьЛог(ПараметрыВходногоЗапроса, 
				ПараметрыВходногоЗапроса.ДатаЗапроса + Символы.ПС + ПараметрыВходногоЗапроса.Запрос + Символы.ПС + Формат(ТекущаяДата(), 
				"ДФ=дд.ММ.гггг ЧЧ:мм:сс") + Символы.ПС);
		
			Возврат Ответ;
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПередачаКартинкиМаркировки.Сообщение);			
		КонецЕсли;  
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;	
	
