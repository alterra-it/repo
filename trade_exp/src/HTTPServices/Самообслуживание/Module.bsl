#Область ВходящиеHTTPЗапросы

Функция onScan(Запрос)  
	
	УстановитьПривилегированныйРежим(Истина);  
	
	Попытка                               
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		Если Не ПараметрыВходногоЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПараметрыВходногоЗапроса.Сообщение);			
		КонецЕсли;
		
		ДанныеЗапроса = Новый Структура("Документ, Штрихкод, Результат, Сообщение", 
											Запрос.ПараметрыЗапроса.Получить("document_id"),
											Запрос.ПараметрыЗапроса.Получить("barcode"),  
											Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Штрихкод, "Просканировался пустой штрихкод");
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;
	
		СканированиеШтрихкода = СканироватьШтрихкод(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		Корзина = ?(СканированиеШтрихкода.Свойство("Корзина"), СканированиеШтрихкода.Корзина, Неопределено);
		
		Если СканированиеШтрихкода.Результат Тогда                                         
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, СканированиеШтрихкода);    
		Иначе     
			ОшибкаМаркировки = СканированиеШтрихкода.Свойство("ОшибкаМаркировки") И СканированиеШтрихкода.ОшибкаМаркировки;
			ИнформацияИСМП = СканированиеШтрихкода.Свойство("ИнформацияИСМП") И ТипЗнч(СканированиеШтрихкода.ИнформацияИСМП) = Тип("Структура");
			ПроверкаИСМП = СканированиеШтрихкода.Свойство("ПроверкаИСМП") И ТипЗнч(СканированиеШтрихкода.ПроверкаИСМП) = Тип("Структура");
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, 
				?(ОшибкаМаркировки, "Отсканируйте код маркировки", СканированиеШтрихкода.Сообщение), 
				?(ОшибкаМаркировки, 418, 400), Корзина, ,
				?(ОшибкаМаркировки Или ПроверкаИСМП Или ИнформацияИСМП, СканированиеШтрихкода, Неопределено));			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), , Корзина);			
	КонецПопытки;	 
	
КонецФункции    

Функция changeQuantity(Запрос)      
	
	УстановитьПривилегированныйРежим(Истина);  
	
	Попытка        
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		Если Не ПараметрыВходногоЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПараметрыВходногоЗапроса.Сообщение);			
		КонецЕсли;	
		
		ДанныеЗапроса = Новый Структура("Документ, Товар, Количество, Результат, Сообщение", 
											Запрос.ПараметрыЗапроса.Получить("document_id"),
											Запрос.ПараметрыЗапроса.Получить("product_id"),
											Запрос.ПараметрыЗапроса.Получить("quantity"),
											Истина, ""); 
											
		ДанныеЗапроса.Количество = ?(ДанныеЗапроса.Количество <> Неопределено И Число(ДанныеЗапроса.Количество) <= 0, Неопределено, ДанныеЗапроса.Количество);
		
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Документ,		"Не определена корзина текущей покупки");
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Товар,		"Не указан товар для изменения");										
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Количество,	"Укажите количество изменяемого товара больше нуля");
		Если Не ДанныеЗапроса.Результат Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;	
	
		ИзменениеКоличества = ИзменитьКоличество(ПараметрыВходногоЗапроса, ДанныеЗапроса);	   
		Корзина = ?(ИзменениеКоличества.Свойство("Корзина"), ИзменениеКоличества.Корзина, Неопределено);

		Если ИзменениеКоличества.Результат Тогда      

			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ИзменениеКоличества);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ИзменениеКоличества.Сообщение, , Корзина);			
		КонецЕсли;  
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), , Корзина);			
	КонецПопытки;	
	
КонецФункции

Функция deleteProducts(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);  
	
	Попытка                
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);      
		
		ВходныеДанныеJSON = Запрос.ПолучитьТелоКакСтроку("UTF-8");
		
		Если ПустаяСтрока(ВходныеДанныеJSON) Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не переданы данные");			
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ВходныеДанныеJSON);
		ВходныеДанные = ПрочитатьJSON(ЧтениеJSON, Истина);
		
		Если ВходныеДанные.Количество() = 0 Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не удалось получить данные");
		КонецЕсли;  
		
		ДанныеЗапроса = Новый Структура("Документ, Товары, Результат, Сообщение", 
											ВходныеДанные.Получить("document_id"),
											ВходныеДанные.Получить("products"),
											Истина, ""); 
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Документ,	"Не определена корзина текущей покупки");	
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Товары,	"Не указаны товары для удаления");									
		Если Не ДанныеЗапроса.Результат Или ТипЗнч(ДанныеЗапроса.Товары) <> Тип("Массив") Или ДанныеЗапроса.Товары.Количество() = 0 Тогда   
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;	
	                    
		УдалениеТоваров = УдалитьТовар(ПараметрыВходногоЗапроса, ДанныеЗапроса);	   
		Корзина = ?(УдалениеТоваров.Свойство("Корзина"), УдалениеТоваров.Корзина, Неопределено);

		Если УдалениеТоваров.Результат Тогда      

			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, УдалениеТоваров);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, УдалениеТоваров.Сообщение, , Корзина);			
		КонецЕсли;  
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()), , Корзина);			
	КонецПопытки; 
	
КонецФункции

