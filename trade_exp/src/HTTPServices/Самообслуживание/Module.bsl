											Неопределено, 
											Запрос.ПараметрыЗапроса.Получить("product_id"),
											Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Товар, "Не задан УИД товара (product_id)");
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;   
		
		Попытка
			ДанныеЗапроса.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.Товар));
