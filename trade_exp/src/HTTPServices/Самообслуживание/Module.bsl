Функция ПолучитьВидПродукцииИС(ИсходноеЗначение) 
	
	РезультатВыполнения = Новый Структура("ВидМаркировки, УИДВидМаркировки");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ 
		|	Ссылка КАК ВидМаркировки,
		|	УникальныйИдентификатор(Ссылка) КАК УИДВидМаркировки
		|ИЗ 
		|	Перечисление.ВидыПродукцииИС
		|ГДЕ     
		|	%Условие = &ИсходноеЗначение";
	
	Если ТипЗнч(ИсходноеЗначение) = Тип("ПеречислениеСсылка.ВидыПродукцииИС") Тогда
        Условие = "Ссылка";
		Запрос.УстановитьПараметр("ИсходноеЗначение", ИсходноеЗначение);
		
	ИначеЕсли ТипЗнч(ИсходноеЗначение) = Тип("Строка") Тогда
		Условие = "УникальныйИдентификатор(Ссылка)";       
		Запрос.УстановитьПараметр("ИсходноеЗначение", Новый УникальныйИдентификатор(ИсходноеЗначение));
	КонецЕсли;
		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие", Условие); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда         
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, Выборка);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
