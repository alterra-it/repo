Функция ЕстьТакаяМаркировкаВКорзинах(Корзина, ПолныйКодМаркировки)
	
	РезультатВыполнения = Новый Структура("Результат, ЭтаКорзина, Номенклатура", Ложь);
	
	// Проверка других корзин
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Ложь КАК ЭтаКорзина,
		|	Номенклатура
		|ИЗ
		|	Документ.КорзинаСамообслуживания.Товары
		|ГДЕ               
		|	ПолныйКодМаркировки = &ПолныйКодМаркировки
		|	И Ссылка <> &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Корзина.Ссылка);
	Запрос.УстановитьПараметр("ПолныйКодМаркировки", ПолныйКодМаркировки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		РезультатВыполнения.Результат = Истина;
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, Выборка);		
		Возврат РезультатВыполнения;
	КонецЕсли;   
	
	// Проверка этой корзины пока не записанной  
	НайденныеСтрокиТовара = Корзина.Товары.НайтиСтроки(Новый Структура ("ПолныйКодМаркировки", ПолныйКодМаркировки));
	Если НайденныеСтрокиТовара.Количество() > 0 Тогда
		РезультатВыполнения.Результат = Истина;
		РезультатВыполнения.ЭтаКорзина = Истина;  
		РезультатВыполнения.Номенклатура = НайденныеСтрокиТовара[0].Номенклатура;
		Возврат РезультатВыполнения;
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
