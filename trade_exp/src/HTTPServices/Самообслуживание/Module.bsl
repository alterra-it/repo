#Область Маркировка

Функция ПроверитьМаркировку(QRКодМаркировки, ПроверкаВладельца = Истина, РежимПроверки = -1)	
	
	РезультатВыполнения = Новый Структура("Результат, Сообщение, РазрешительныйРежим, Штрихкод, 
		|ИнформацияИСМП, ПроверкаИСМП, ПроверкаМаркировки, НоменклатураХарактеристика, КодМаркировки, ПолныйКодМаркировки", Ложь, "", Ложь, "");

	// Разобрать код маркировки 
	СтруктураКодаМаркировки = РазборКодаМаркировкиИССлужебный.РазобратьКодМаркировки(QRКодМаркировки); 

	Если ТипЗнч(СтруктураКодаМаркировки) = Тип("Структура") И СтруктураКодаМаркировки.Свойство("СоставКодаМаркировки") 
		И СтруктураКодаМаркировки.СоставКодаМаркировки.Свойство("EAN") И ЗначениеЗаполнено(СтруктураКодаМаркировки.СоставКодаМаркировки.EAN) Тогда
			
		РезультатВыполнения.Штрихкод = СтруктураКодаМаркировки.СоставКодаМаркировки.EAN;
		РезультатВыполнения.НоменклатураХарактеристика = ПолучитьНоменклатуруХарктеристику(РезультатВыполнения.Штрихкод);
		
		Если ЗначениеЗаполнено(РезультатВыполнения.НоменклатураХарактеристика.Номенклатура) Тогда 
			
			// Получить/создать элемент ШтрихкодыУпаковокТоваров
			РезультатВыполнения.НоменклатураХарактеристика.Вставить("Серия", ПредопределенноеЗначение("Справочник.СерииНоменклатуры.ПустаяСсылка"));
			
			Попытка
				РезультатВыполнения.КодМаркировки = МаркировкаАльтерра.ПолучитьСсылкуНаШтрихкодМаркируемогоТовара(СтруктураКодаМаркировки, РезультатВыполнения.НоменклатураХарактеристика);
				РезультатВыполнения.ПолныйКодМаркировки = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(QRКодМаркировки));
				РезультатВыполнения.Результат = ЗначениеЗаполнено(РезультатВыполнения.КодМаркировки);
			Исключение
				РезультатВыполнения.Сообщение = СтрШаблон("Не создан/получен штрихкод упаковки: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;
			
		Иначе
			РезультатВыполнения.Сообщение = "Не найден штрихкод из состава кода маркировки";	
		КонецЕсли;

	Иначе
		РезультатВыполнения.Сообщение = "Не выделен штрихкод из состава кода маркировки";
	КонецЕсли;
	
	// Проверить код маркировки в ЧЗ
	Если РезультатВыполнения.Результат Тогда 
	
		ВидПродукции = МаркировкаАльтерра.ОпределитьВидПродукции(РезультатВыполнения.НоменклатураХарактеристика.Номенклатура, СтруктураКодаМаркировки.ВидыПродукции);
		НастройкиПроверкиКМ = МаркировкаАльтерра.НастройкиПроверкиКМПоВидуПродукции(ВидПродукции, ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ВыводИзОборотаРозничнаяПродажа"));
	
		QRКодыМаркировки = Новый Массив;
		QRКодыМаркировки.Добавить(QRКодМаркировки);
		
		// Проверка на владельца
		Если ПроверкаВладельца И НастройкиПроверкиКМ.КонтрольВладельца И МаркировкаДатаОптКонтроль(ВидПродукции) Тогда
			РезультатВыполнения.ИнформацияИСМП = МаркировкаАльтерра.ПолучениеИнформацииМаркировки(QRКодыМаркировки, РежимПроверки, , Истина);
			РезультатВыполнения.Сообщение = 
				МаркировкаАльтерра.ПолучитьОписаниеОшибкиПолученияИнформации(РезультатВыполнения.ИнформацияИСМП, 
				НастройкиПроверкиКМ.КонтрольВладельца, РезультатВыполнения.Номенклатурахарактеристика.Номенклатура); 
		 КонецЕсли;
		
		// Проверка на оборот, срок годности, блокировку ОГВ и получение данных для Такскома
		РезультатВыполнения.ПроверкаИСМП = МаркировкаАльтерра.ПроверитьМаркировку(QRКодыМаркировки, РежимПроверки, , , Истина);
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ?(ЗначениеЗаполнено(РезультатВыполнения.Сообщение), Символы.ПС, "") + 
			МаркировкаАльтерра.ПолучитьОписаниеОшибкиПроверки(РезультатВыполнения.ПроверкаИСМП, 
			НастройкиПроверкиКМ.КонтрольСтатуса, РезультатВыполнения.Номенклатурахарактеристика.Номенклатура); 
		
		РезультатВыполнения.Результат = Не ЗначениеЗаполнено(РезультатВыполнения.Сообщение);
		
		// Параметры разрешительного режима
		РезультатВыполнения.РазрешительныйРежим = РезультатВыполнения.Результат;
		РезультатВыполнения.ПроверкаМаркировки = ДопМодульСервер.СформироватьРазрешительныйРежимОФД(РезультатВыполнения.ПроверкаИСМП.УИДЗапроса, РезультатВыполнения.ПроверкаИСМП.ДатаРегистрацииЗапроса);

	КонецЕсли;
	
	// На все разннобразные ошибки маркировки - для покупателя выводить одно и то же
	Если РезультатВыполнения.Сообщение <> "" Тогда
		РезультатВыполнения.Сообщение = "QR код поврежден, пожалуйста, возьмите другой экземпляр с полки.";
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция МаркировкаДатаОптКонтроль(ВидПродукции)
	
	Запрос = Новый Запрос;

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДатаОптКонтрольПоштучно
		|ИЗ
		|	РегистрСведений.НастройкиУчетаМаркируемойПродукцииИСМП 
		|ГДЕ
		|	ВидПродукции = &ВидПродукции
		|	И ДатаОптКонтрольПоштучно <> ДАТАВРЕМЯ(1, 1, 1)    
		|	И ДатаОптКонтрольПоштучно < &ТекДата";
		
	Запрос.УстановитьПараметр("ВидПродукции", ВидПродукции);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
