Функция CreateKlient(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	
	Ответ = Новый HTTPСервисОтвет(200);
	
	ДанныеКлиентаJSON= Запрос.ПолучитьТелоКакСтроку("UTF-8");
	
	Если ПустаяСтрока(ДанныеКлиентаJSON) Тогда
		Ответ= ПодготовитьHTTPОтвет("Переданы пустые данные");
		Возврат Ответ;
	КонецЕсли;
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ДанныеКлиентаJSON);
	СоответствиеКлиента    =  ПрочитатьJSON(ЧтениеJSON, Истина);
	
	//СоответствиеКлиента= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеКлиентаJSON);
	
	Если СоответствиеКлиента.Количество() = 0 Тогда
		Ответ= ПодготовитьHTTPОтвет("Не удалось радобрать JSON");
		Возврат Ответ;
	КонецЕсли;
	
	ДанныеПартнера= Новый Структура;
	
	Фамилия= СоответствиеКлиента["Фамилия"];
	Имя= СоответствиеКлиента["Имя"];
	Отчество= СоответствиеКлиента["Отчество"];
	
	ДанныеПартнера.Вставить("Наименование", СокрЛП(Фамилия+" "+Имя+" "+Отчество));
	ДанныеПартнера.Вставить("Телефон", СоответствиеКлиента["Телефон"]);
	ДанныеПартнера.Вставить("Почта", СоответствиеКлиента["E-mail"]);
	ДанныеПартнера.Вставить("СогласенПолучатьПочту",  Булево(Число(СоответствиеКлиента["soglasen"])));
	ДанныеПартнера.Вставить("ДатаРождения", Дата(СоответствиеКлиента["ДатаРождения"]));
	//ДанныеПартнера.Вставить("БизнесРегион= СоответствиеКлиента["Регион"];
	ДанныеПартнера.Вставить("БизнесРегион", "Сайт");
	ДанныеПартнера.Вставить("БонуснаяПрограммаАктивна", Ложь);
	ДанныеПартнера.Вставить("Комментарий", "Создан автоматически с сайта");
	ДанныеПартнера.Вставить("Б_Идентификатор", СоответствиеКлиента["Б_Идентификатор"]);
	
	Если Не ЗначениеЗаполнено(ДанныеПартнера.Телефон) Тогда
		Ответ= ПодготовитьHTTPОтвет("Не задан телефон");
		Возврат Ответ;
	КонецЕсли;
	
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(ДанныеПартнера.Телефон);
	
	//ПОИСК ПАРТНЕРА
	Если Не ПустаяСтрока(ДанныеПартнера.Телефон) Тогда
		Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоТелефону(ДанныеПартнера.Телефон);
		
		Если ЗначениеЗаполнено(Партнер) Тогда
			//Проверим и присвоем ИД с сайта
			Если Не ПустаяСтрока(ДанныеПартнера.Б_Идентификатор) И ДанныеПартнера.Б_Идентификатор <> Партнер.Б_Идентификатор Тогда
				//ПрисвоитьБ_Идентификатор(Партнер, ДанныеПартнера.Б_Идентификатор, Ответ);
			Иначе
				Ответ= ПодготовитьHTTPОтвет("", XMLСтрока(Партнер));
				Возврат Ответ;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Партнер) И Не ПустаяСтрока(ДанныеПартнера.Почта) Тогда
		Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоПочте(ДанныеПартнера.Почта);
		
		Если ЗначениеЗаполнено(Партнер) Тогда
			Ответ= ПодготовитьHTTPОтвет("Найден партнер по e-mail ("+Партнер.Код+") "+Партнер, XMLСтрока(Партнер));
			Возврат Ответ;
		КонецЕсли;
	КонецЕсли;
	
	//СОЗДАЕМ
	Если Не ЗначениеЗаполнено(Партнер) Тогда 
