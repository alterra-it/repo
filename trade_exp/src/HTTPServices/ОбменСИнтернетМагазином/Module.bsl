		|	втОсновноеСоглашение.Склад = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка) 
		|УПОРЯДОЧИТЬ ПО
		|	СоглашениеЦеновыеГруппы.НомерСтроки,
		|	СтруктураПредприятия.РегионПрисутствия		
		|;                  
		|//////////////////////////////////////////////////////////////////////////////// 
		|// Уточнения по номенклатуре
		|ВЫБРАТЬ 
		|	СпрНоменклатура.Ссылка КАК Номенклатура,
		|	СпрНоменклатура.Наименование КАК НоменклатураНаименование,
		|	ВидыЦен.Ссылка КАК ВидЦены,     
		|	ВидыЦен.Наименование КАК ВидЦеныНаименование,
		|	СтруктураПредприятия.ИдентификаторСайта КАК ИдентификаторСайта
		|ИЗ          
		|	втОсновноеСоглашение
		|	СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашениеТовары
		|		ПО втОсновноеСоглашение.Соглашение = СоглашениеТовары.Ссылка    
		|	СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО СоглашениеТовары.Номенклатура = СпрНоменклатура.Ссылка
		|	СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|		ПО СоглашениеТовары.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
		|		И ВидыЦен.ФорматПодразделения = &ФорматПодразделения    
		|	СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ПО ВидыЦен.ФорматПодразделения = СтруктураПредприятия.ФорматПодразделения
		|		И ВидыЦен.РегионПрисутствия = СтруктураПредприятия.РегионПрисутствия
		|		И СтруктураПредприятия.ИдентификаторСайта <> &ПустаяСтрока
		|;                                                                       
		|////////////////////////////////////////////////////////////////////////////////
		|// Контактные лица
		|ВЫБРАТЬ                                               
		|	КонтактныеЛица.Ссылка КАК КонтактноеЛицо,
		|	КонтактныеЛица.Наименование КАК КонтактноеЛицоНаименование,
		|	ЕСТЬNULL(ТелефонКонтактногоЛица.НомерТелефона, &ПустаяСтрока) КАК НомерТелефона
		|ИЗ                        
		|	втПартнер                                         
		|	СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛица
		|		ПО втПартнер.Партнер = КонтактныеЛица.Владелец   
		|		И НЕ КонтактныеЛица.ПометкаУдаления     
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.КонтактнаяИнформация КАК ТелефонКонтактногоЛица
		|		ПО ТелефонКонтактногоЛица.Ссылка = КонтактныеЛица.Ссылка
		|		И ТелефонКонтактногоЛица.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.МобильныйТелефонКонтактногоЛица)";
		
		Запрос.УстановитьПараметр("АдресЭП", АдресЭП);                  
		Запрос.УстановитьПараметр("ИмяГруппыПартнеров", "ГруппыПартнеров");
		Запрос.УстановитьПараметр("ГруппаБригадиры", "Бригадиры");
		Запрос.УстановитьПараметр("ФорматПодразделения",Справочники.ФорматыПодразделений.НайтиПоНаименованию("ТСК"));           
		Запрос.УстановитьПараметр("ВыгружатьНаСайт", "ВыгружатьНаСайт");                  
		Запрос.УстановитьПараметр("ПустаяСтрока", "");                  
		
		ПакетЗапросов = Запрос.ВыполнитьПакет();
		
		ВыборкаПартнер = ПакетЗапросов[8].Выбрать();
		Если ВыборкаПартнер.Количество() = 0 Тогда
			Возврат ОшибкаОбменаСИнтернетМагазином(Новый Структура("description","Клиент не найден"));	
		КонецЕсли;
		
		ВыборкаПартнер.Следующий();

		СтруктураОтвета = Новый Структура("email, partner, name, phone, business_region, business_region_name, legal_entity, agreement, agreement_name, price_type, price_type_name", 
			ВыборкаПартнер.АдресЭП, XMLСтрока(ВыборкаПартнер.Партнер), ВыборкаПартнер.ПартнерНаименование, ВыборкаПартнер.НомерТелефона, 
			XMLСтрока(ВыборкаПартнер.БизнесРегион), ВыборкаПартнер.БизнесРегионНаименование, Не ВыборкаПартнер.ЭтоБригадир, 
			XMLСтрока(ВыборкаПартнер.Соглашение), ВыборкаПартнер.СоглашениеНаименование, XMLСтрока(ВыборкаПартнер.ВидЦены), ВыборкаПартнер.ВидЦеныНаименование);  
			
		СтруктураОтвета.Вставить("extra", Новый Структура("card, delay, delivery", ВыборкаПартнер.ОплатаКартой, ВыборкаПартнер.Отсрочка, ВыборкаПартнер.Доставка));	        
		
		ВыборкаДубли = ПакетЗапросов[2].Выбрать(); 
		МассивДубли = Новый Массив();
		Пока ВыборкаДубли.Следующий() Цикл 
			МассивДубли.Добавить(Новый Структура("email, partner, name, phone, business_region, business_region_name, legal_entity", 
				ВыборкаДубли.АдресЭП, XMLСтрока(ВыборкаДубли.Партнер), ВыборкаДубли.ПартнерНаименование, ВыборкаДубли.НомерТелефона, 
				XMLСтрока(ВыборкаДубли.БизнесРегион), ВыборкаДубли.БизнесРегионНаименование, ВыборкаДубли.ЭтоБригадир)); 
		КонецЦикла;
		СтруктураОтвета.Вставить("doubles", МассивДубли); 
		
		ВыборкаДубли = ПакетЗапросов[5].Выбрать(); 
		МассивДубли = Новый Массив();
		Пока ВыборкаДубли.Следующий() Цикл 
			МассивДубли.Добавить(Новый Структура("id, name, priority", 
				XMLСтрока(ВыборкаДубли.Соглашение), ВыборкаДубли.СоглашениеНаименование, ВыборкаДубли.Приоритет));
		КонецЦикла;
		СтруктураОтвета.Вставить("agreements", МассивДубли);
		
		ВыборкаВидЦены = ПакетЗапросов[9].Выбрать();
		МассивВидовЦен = Новый Массив;
		Пока ВыборкаВидЦены.Следующий() Цикл
			МассивВидовЦен.Добавить(Новый Структура("shop, price_type, price_type_name", ВыборкаВидЦены.ИдентификаторСайта, XMLСтрока(ВыборкаВидЦены.ВидЦены), ВыборкаВидЦены.ВидЦеныНаименование));	
		КонецЦикла;    
		СтруктураОтвета.Вставить("default_prices", МассивВидовЦен); 
		
		ВыборкаКонтактныеЛица = ПакетЗапросов[12].Выбрать();
		МассивКонтактныхЛиц = Новый Массив();
		Пока ВыборкаКонтактныеЛица.Следующий() Цикл 
			МассивКонтактныхЛиц.Добавить(Новый Структура("id, name, phone", XMLСтрока(ВыборкаКонтактныеЛица.КонтактноеЛицо), ВыборкаКонтактныеЛица.КонтактноеЛицоНаименование, ВыборкаКонтактныеЛица.НомерТелефона));
		КонецЦикла;
		СтруктураОтвета.Вставить("contacts", МассивКонтактныхЛиц); 
		
		ВыборкаОтклонениеГруппы = ПакетЗапросов[10].Выбрать();
		МассивОтклоненияГруппы = Новый Массив;
		Пока ВыборкаОтклонениеГруппы.Следующий() Цикл
			МассивОтклоненияГруппы.Добавить(Новый Структура("id, name, price_type, price_type_name, shop",
				XMLСтрока(ВыборкаОтклонениеГруппы.ЦеноваяГруппа), ВыборкаОтклонениеГруппы.ЦеноваяГруппаНаименование, 
				XMLСтрока(ВыборкаОтклонениеГруппы.ВидЦены), ВыборкаОтклонениеГруппы.ВидЦеныНаименование, ВыборкаОтклонениеГруппы.ИдентификаторСайта));
		КонецЦикла;
		
		ВыборкаОтклонениеТовары = ПакетЗапросов[11].Выбрать();  
		МассивОтклоненияТовары = Новый Массив;
		Пока ВыборкаОтклонениеТовары.Следующий() Цикл
			МассивОтклоненияТовары.Добавить(Новый Структура("id, name, price_type, price_type_name, shop",
			XMLСтрока(ВыборкаОтклонениеТовары.Номенклатура), ВыборкаОтклонениеТовары.НоменклатураНаименование, 
			XMLСтрока(ВыборкаОтклонениеТовары.ВидЦены), ВыборкаОтклонениеТовары.ВидЦеныНаименование, ВыборкаОтклонениеТовары.ИдентификаторСайта));
		КонецЦикла;		
		
		СтруктураОтвета.Вставить("deviations", Новый Структура("groups, products", МассивОтклоненияГруппы, МассивОтклоненияТовары));
		
		Возврат ПодготовитьHTTPОтвет(Ложь, СтруктураОтвета, Ложь);	
		
	Исключение
		Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка выполнения запроса!");			
	КонецПопытки;
	
КонецФункции

функция AddClientToAuthLog(ВходящиеДанные)
	
	УстановитьПривилегированныйРежим(Истина);  
	HTTPОтвет = Новый HTTPСервисОтвет(200);   
		
	Попытка 
		УИД = ВходящиеДанные.XML_ID;
		ПартнерСсылка = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(УИД)); 
	Исключение 
		ПартнерСсылка = Справочники.Партнеры.ПустаяСсылка();
	КонецПопытки;

	Попытка
    ПочтаПартнера = ВходящиеДанные.Email;	
	ТелефонКонтактногоЛица = ВходящиеДанные.Tel;
	
	Запрос = Новый Запрос;
	Запрос.Текст =                   
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Партнеры.Ссылка КАК Клиент,
	|	МАКСИМУМ(Почта.Представление) КАК Почта
	|ПОМЕСТИТЬ ПартнерыИПочта
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК Почта
	|		ПО (Партнеры.Ссылка = Почта.Ссылка)
	|ГДЕ
	|	НЕ Партнеры.ПометкаУдаления
	|	И Почта.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера)
	|	И (Партнеры.Ссылка = &Ссылка
	|			ИЛИ Почта.Представление = &Почта
	|				И &Почта <> """")
	|
	|СГРУППИРОВАТЬ ПО
	|	Партнеры.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПартнерыИПочта.Клиент КАК Клиент,
	|	ПартнерыИПочта.Почта КАК Почта,
	|	Телефон.Представление КАК Телефон,
	|	NULL КАК НомерКарты,
	|	NULL КАК КонтактноеЛицо,
	|	NULL КАК ТелефонКонтактногоЛица
	|ПОМЕСТИТЬ Вт_Объединение
	|ИЗ
	|	ПартнерыИПочта КАК ПартнерыИПочта
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК Телефон
	|		ПО (ПартнерыИПочта.Клиент = Телефон.Ссылка)
	|ГДЕ
	|	Телефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ 
	|   ПартнерыИПочта.Клиент,
	|	ПартнерыИПочта.Почта, 
	|	NULL,
	|	Карта.Штрихкод,
	|	NULL,
	|	NULL
	|	
	|ИЗ
	|	ПартнерыИПочта КАК ПартнерыИПочта
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КартыЛояльности КАК Карта
	|		ПО ПартнерыИПочта.Клиент = Карта.Партнер
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|   ПартнерыИПочта.Клиент,
	|	ПартнерыИПочта.Почта,
	|	NULL,
	|	NULL,
	|	КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка,
	|	КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона
	|ИЗ
	|	ПартнерыИПочта КАК ПартнерыИПочта
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.КонтактнаяИнформация КАК КонтактныеЛицаПартнеровКонтактнаяИнформация
	|		ПО (КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка.Владелец = ПартнерыИПочта.Клиент)
	|ГДЕ
	|	КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона = &Тел
	|	И КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона <> """"
	|	И КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Вт_Объединение.Клиент КАК Клиент,
	|	МАКСИМУМ(Вт_Объединение.Почта) КАК Почта,
	|	МАКСИМУМ(Вт_Объединение.Телефон) КАК Телефон,
	|	МАКСИМУМ(Вт_Объединение.НомерКарты) КАК НомерКарты,
	|	МАКСИМУМ(Вт_Объединение.КонтактноеЛицо) КАК КонтактноеЛицо,
	|	МАКСИМУМ(Вт_Объединение.ТелефонКонтактногоЛица) КАК ТелефонКонтактногоЛица
	|ИЗ
	|	Вт_Объединение КАК Вт_Объединение
	|
	|СГРУППИРОВАТЬ ПО
	|	Вт_Объединение.Клиент";
		
	Запрос.УстановитьПараметр("Ссылка",ПартнерСсылка);
    Запрос.УстановитьПараметр("Почта",ПочтаПартнера);
	Запрос.УстановитьПараметр("Тел",ТелефонКонтактногоЛица);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ТекДата = ТекущаяДата();
		РегистрВходКлиент = РегистрыСведений.ИсторияИдентификацииКлиентовСайт;
		Отбор = Новый Структура("Клиент", Выборка.Клиент);
		ПоследняяЗапись = РегистрВходКлиент.СрезПоследних(ТекДата,Отбор);
		ПослДатаВхода = ?(ПоследняяЗапись.Количество() = 0,'00010101',ПоследняяЗапись[0].Период);
		Если ПослДатаВхода < ТекДата-20 Тогда
			Запись = РегистрВходКлиент.СоздатьМенеджерЗаписи();
			Запись.Период = ТекДата;
			ЗаполнитьЗначенияСвойств(Запись,Выборка);
			Запись.Записать(); 
		КонецЕсли;
	КонецЕсли;	
	
        HTTPОтвет.УстановитьТелоИзСтроки("error: false", КодировкаТекста.UTF8);
    	Возврат HTTPОтвет;
		
   Исключение 
		HTTPОтвет.УстановитьТелоИзСтроки("error: true", КодировкаТекста.UTF8);
		Возврат HTTPОтвет;
   КонецПопытки;
                                                       
КонецФункции		

Функция getDeliveryPrice(ВходящиеДанные)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
	
	МаксимальнаяДлина =(ВходящиеДанные["max_length"]);
	Интервал = Справочники.ИнтервалыДоставки.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные["interval_id"]));
	ЗонаДоставкиДляВодителя = Справочники.ЗоныДоставкиДоКлиента.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные["zone_id"]));
	ПрибытиеНаОтгрузку = Дата((ВходящиеДанные["Date"]));
	Вес = (ВходящиеДанные["weight"]); 
	
	Товары = Новый ТаблицаЗначений(); 
	Товары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Товары.Колонки.Добавить("КоличествоУпаковок", Новый ОписаниеТипов("Число"));
	
	Для Каждого Строка Из ВходящиеДанные["products"] Цикл   
		НС = Товары.Добавить();
		НС.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор (Строка.xml_id));
		НС.КоличествоУпаковок = Строка.count;
	КонецЦикла;
		
	СтруктураОбъекта = Новый Структура("Интервал, Товары, МаксимальнаяДлина,ЗонаДоставкиДляВодителя,ПрибытиеНаОтгрузку,Вес",
	Интервал,Товары, МаксимальнаяДлина,ЗонаДоставкиДляВодителя,ПрибытиеНаОтгрузку,Вес);
	
	СтруктураТарифыТипы = УправлениеЛогистикойСервер.ОпределениеТарифаСайт(СтруктураОбъекта);
	
	Если СтруктураТарифыТипы.СообщениеОбОшибке <> "" Тогда
		Возврат ОшибкаОбменаСИнтернетМагазином(СтруктураТарифыТипы.СообщениеОбОшибке);
	КонецЕсли;
	
	МассивТарифов = Новый Массив;	
	Для Каждого Строка Из  СтруктураТарифыТипы.ТарифыТипы Цикл
		МассивТарифов.Добавить(Новый Структура("price,tariff,car_id", Строка.СтоимостьДляКлиента,Строка(Строка.УИД_Тарифа),Строка(Строка.УИД_ТипаТС)));
	КонецЦикла;
	
	Возврат ПодготовитьHTTPОтвет(Ложь, МассивТарифов);		
	Исключение
		Возврат ОшибкаОбменаСИнтернетМагазином("Не удалось получить цены доставки");			
	КонецПопытки; 
	УстановитьПривилегированныйРежим(Ложь);

КонецФункции


Функция ОшибкаОбменаСИнтернетМагазином(ТекстОшибки)
	Ответ = ПодготовитьHTTPОтвет(Истина, ТекстОшибки);
	ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазином", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
	Возврат Ответ;
КонецФункции
#КонецОбласти

#Область ВспомогательныеОплата 

Функция Ошибка(Сообщение, ВернутьСтруктуру = Ложь, СтатусОшибки = Истина, ЗаписьВЖурналРегистрации = Истина) 
	Если ЗаписьВЖурналРегистрации Тогда
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , Сообщение);
	КонецЕсли;
	
	Если ВернутьСтруктуру Тогда
		Возврат Новый Структура("СтатусОшибки, Сообщение", СтатусОшибки, Сообщение);
	Иначе
		Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(СтатусОшибки, Сообщение); 
	КонецЕсли;
КонецФункции

Функция ПроверкаНаНаличиеЗаписейВРегистре(ЗаказКлиента, ЭквайринговаяОперация, СуммаОплаты, АдресУведомленияКлиента, НомерКарты, ЭквайринговыйТерминал, ИдентификаторОплаты) Экспорт
	МаксимальноеКоличествоПопытокПробития = 5;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОчередьЧековКПробитию.КоличествоПопытокПробития КАК КоличествоПопытокПробития,
		|	ОчередьЧековКПробитию.СтатусОшибки КАК СтатусОшибки,
		|	ОчередьЧековКПробитию.Информация КАК Информация
		|ИЗ
		|	РегистрСведений.ОчередьЧековКПробитию КАК ОчередьЧековКПробитию
		|ГДЕ
		|	ОчередьЧековКПробитию.ЗаказКлиента = &ЗаказКлиента";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();	
	Если РезультатЗапроса.Следующий() Тогда
		Если РезультатЗапроса.СтатусОшибки Тогда
			СтатусОшибки = МаксимальноеКоличествоПопытокПробития <= РезультатЗапроса.КоличествоПопытокПробития;  
			Возврат Ошибка( 
				"Чек находится в очереди к пробитию!" + Символы.ПС +
				"Количество попыток пробития - " + РезультатЗапроса.КоличествоПопытокПробития + Символы.ПС + 
				"Информация по текущему статусу: " + Символы.ПС + РезультатЗапроса.Информация, Истина, СтатусОшибки, СтатусОшибки);
		Иначе 
			Возврат Ошибка("Чек пробит!", Истина, Ложь, Ложь);
		КонецЕсли;
	КонецЕсли;
	
	ДатаПостановки = ТекущаяДатаСеанса();     
	
	ТипСсылки = ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт");
	НастройкиДинамическиеСсылки = ИнтеграцияБанки.ПолучитьНастройкиДинамическиеСсылки(ТипСсылки);
	Если НастройкиДинамическиеСсылки.Результат Тогда
		Касса = НастройкиДинамическиеСсылки.Ответ.ККТ;    
	Иначе
		Касса = Константы.КассаИнтернетМагазина.Получить();
	КонецЕсли;
	
	ТекстСообщения = "Чек помещен в очередь!";
	НоваяЗапись = РегистрыСведений.ОчередьЧековКПробитию.СоздатьМенеджерЗаписи();
	НоваяЗапись.ТипСсылки            		= ТипСсылки;
	НоваяЗапись.Касса	            		= Касса;
	НоваяЗапись.ДатаПостановки            	= ДатаПостановки;
	НоваяЗапись.ЗаказКлиента              	= ЗаказКлиента;
	НоваяЗапись.ЭквайринговаяОперация     	= ЭквайринговаяОперация;
	НоваяЗапись.СуммаОплаты               	= СуммаОплаты;
	НоваяЗапись.АдресУведомленияКлиента   	= АдресУведомленияКлиента;
	НоваяЗапись.НомерКарты                	= НомерКарты;
	НоваяЗапись.ЭквайринговыйТерминал     	= ЭквайринговыйТерминал;	
	НоваяЗапись.ДинамическаяСсылка			= ИдентификаторОплаты;
	НоваяЗапись.КоличествоПопытокПробития 	= 0;
	НоваяЗапись.СтатусОшибки              	= Истина;
	НоваяЗапись.Информация                	= ТекстСообщения;
    НоваяЗапись.Записать(Истина);
    
    // Сразу пробить чек
	ДопМодульСервер.ВыполнитьПробитиеЧека(ДатаПостановки, ЗаказКлиента);
	
	Возврат Ошибка(ТекстСообщения, Истина, Ложь, Ложь);
	
КонецФункции

Функция НайтиЗаказКлиента(Ид, ВернутьСтруктуру = Ложь)
	Ответ = Новый HTTPСервисОтвет(200);
	Если СтрДлина(ИД) > 7 Тогда
		Попытка
			УИД = Новый УникальныйИдентификатор(ИД);
		Исключение                  
			Возврат Ошибка("Не верный УИД", ВернутьСтруктуру);
		КонецПопытки;
		
		Заказ = Документы.ЗаказКлиента.ПолучитьСсылку(УИД);
	Иначе
		Заказ = НайтиЗаказПоНомеруССайта(ИД);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Заказ) Тогда     
		Возврат Ошибка("Заказ не найден", ВернутьСтруктуру);
	КонецЕсли;
	
	Если Не Заказ.Проведен Тогда             
		Возврат Ошибка("Заказ не проведен", ВернутьСтруктуру);
	КонецЕсли;
	
	Возврат Заказ;
КонецФункции

Функция НайтиДокументОплаты(Заказ, СуммаОплаты, ЭквайринговыйТерминал, ВернутьСтруктуру = Ложь)
	ЭквайринговаяОперация = Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(Заказ, ЭквайринговыйТерминал);	
	Если ЗначениеЗаполнено(ЭквайринговаяОперация) Тогда
		//проверка на пробитие чека и оплату
		ФискальнаяОперацияДанныеЖурнала = ОборудованиеЧекопечатающиеУстройстваВызовСервера.ДанныеФискальнойОперации(ЭквайринговаяОперация);
		Если ЗначениеЗаполнено(ФискальнаяОперацияДанныеЖурнала) Тогда
			//чек уже пробит, вернуть ошибку 
			Возврат Ошибка("По заказу " + Строка(Заказ) + " уже есть пробитая оплата!" + Строка(ЭквайринговаяОперация), ВернутьСтруктуру, Ложь);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЭквайринговаяОперация;
КонецФункции

#Область Временно_убрать_после_внедрения_автоопределняи_тарифа

Функция ПолучитьТариф(ТЗ_Товары, ВидДоставки, ЭкспрессДоставка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ * ПОМЕСТИТЬ Товар ИЗ &ТЗ_Товары КАК ТЗ_Товары";
	Запрос.УстановитьПараметр("ТЗ_Товары", ТЗ_Товары);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товар.Номенклатура КАК Номенклатура,
	|	Товар.Количество КАК Количество
	|ИЗ
	|	Товар КАК Товар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Товар.Количество * &ТекстЗапросаВесНоменклатуры), 0) КАК ВесГруза,
	|	ЕСТЬNULL(СУММА(Товар.Количество * &ТекстЗапросаОбъемНоменклатуры), 0) КАК ОбъемГруза
	|ИЗ
	|	Товар КАК Товар";
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
		
	ВесГруза = Запрос.Выполнить().Выбрать();
	Если ВесГруза.Следующий() Тогда 
		Возврат ЗапросДляВыбораТарифа(ВидДоставки, ЭкспрессДоставка, ВесГруза.ВесГруза/1000, ВесГруза.ОбъемГруза);
	Иначе
		Возврат ЗапросДляВыбораТарифа(ВидДоставки, ЭкспрессДоставка, 0, 0);
	КонецЕсли;
	
КонецФункции

Функция ЗапросДляВыбораТарифа(ВидДоставки, Экспресс, ВесГруза, ОбъемГруза)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТарифыПеревозчиков.Наименование КАК name,
	               |	ТарифыПеревозчиков.ТипДоставки.Код КАК ТипДоставки,
	               |	ТарифыПеревозчиков.МаксимальнаяДлинаГруза КАК MaxLength,
	               |	ТарифыПеревозчиков.ГрузоподъемностьВТоннах КАК ГрузоподъемностьВТоннах,
	               |	ТарифыПеревозчиков.Приоритет КАК Приоритет,
	               |	ТарифыПеревозчиков.Подразделение.Код КАК Подразделение,
	               |	ТарифыПеревозчиков.ВидАвтомобиля КАК ВидАвтомобиля
	               |ИЗ
	               |	Справочник.ТарифыПеревозчиков КАК ТарифыПеревозчиков
	               |ГДЕ
	               |	ТарифыПеревозчиков.Экспресс = &Экспресс
	               |	И ТарифыПеревозчиков.ГрузоподъемностьВТоннах >= &ВесГруза
	               |	И ТарифыПеревозчиков.ВидДоставки = &ВидДоставки
	               |	И ТарифыПеревозчиков.ПометкаУдаления = ЛОЖЬ
	               |	И ТарифыПеревозчиков.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТарифыПеревозчиков.Наименование,
	               |	ТарифыПеревозчиков.ТипДоставки.Код,
	               |	ТарифыПеревозчиков.МаксимальнаяДлинаГруза,
	               |	ТарифыПеревозчиков.ГрузоподъемностьВТоннах,
	               |	NULL,
	               |	ТарифыПеревозчиков.Подразделение.Код,
	               |	ТарифыПеревозчиков.ВидАвтомобиля
	               |ИЗ
	               |	Справочник.ТарифыПеревозчиков КАК ТарифыПеревозчиков
	               |ГДЕ
	               |	ТарифыПеревозчиков.ВидДоставки = &ВидДоставки
	               |	И ТарифыПеревозчиков.ПометкаУдаления = ЛОЖЬ
	               |	И ТарифыПеревозчиков.ВидДоставки <> ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	MaxLength,
	               |	ГрузоподъемностьВТоннах,
	               |	Приоритет УБЫВ";
	
	Запрос.УстановитьПараметр("ВидДоставки", ВидДоставки);
	Запрос.УстановитьПараметр("Экспресс", Экспресс);
	Запрос.УстановитьПараметр("ВесГруза", ВесГруза);
	//Запрос.УстановитьПараметр("ОбъемГруза", ОбъемГруза);
	
	ВыборкаТарифов = Запрос.Выполнить().Выгрузить();
	
	Возврат ВыборкаТарифов;
	
КонецФункции

Функция ПолучитьФилиалДляСайта(Код)

	Если Код = Null Тогда
		Возврат Ложь;
	Иначе
		Если Код = "0А-000001" Тогда
			Возврат "center";
		ИначеЕсли Код = "0А-000003" Тогда
			Возврат "novoalt";
		ИначеЕсли Код = "0А-000002" Тогда
			Возврат "barnaul";
		ИначеЕсли Код = "0А-000004" Тогда
			Возврат "biysk";
		КонецЕсли;
	КонецЕсли;
			
КонецФункции

#КонецОбласти
#Область РасчетБонусов

Функция ПолучитьТоварыКРасчетуБаллов(Товары, ЭтоЗаказ = Ложь, Дата = Неопределено, ОставитьТоварБезБонусов = Ложь)
	
	ТаблицаТоваров = ?(ТипЗнч(Товары) = Тип("ТаблицаЗначений"), Товары, Товары.Выгрузить());
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура,
		|	Сумма
		|ПОМЕСТИТЬ Товар
		|ИЗ
		|	&Товар КАК Товар
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Номенклатура,
		|	Сумма
		|ПОМЕСТИТЬ ТоварБезТары	
		|ИЗ
		|	Товар 
		|ГДЕ
		|	Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ Номенклатура В ИЕРАРХИИ (&ГрТара)
		|;
		|////////////////////////////////////////////////////////////////////////////////     
		|ВЫБРАТЬ 
		|	ЦеноваяГруппа,
		|	ДатаОкончанияДействия
		|ПОМЕСТИТЬ втЦеновыеГруппыБезБонусовПоследние
		|ИЗ
		|	РегистрСведений.ЦеновыеГруппыБезБонусов.СрезПоследних(&Дата)
		|;
		|////////////////////////////////////////////////////////////////////////////////     
		|ВЫБРАТЬ 
		|	ЦеноваяГруппа    
		|ПОМЕСТИТЬ втЦеновыеГруппыБезБонусов
		|ИЗ
		|	втЦеновыеГруппыБезБонусовПоследние
		|ГДЕ 
		|	ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)  
		|ОБЪЕДИНИТЬ
		|ВЫБРАТЬ 
		|	ЦеноваяГруппа    
		|ИЗ
		|	втЦеновыеГруппыБезБонусовПоследние
		|ГДЕ 
		|	ДатаОкончанияДействия >= &Дата
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварБезТары.Номенклатура,
		|	ТоварБезТары.Сумма
		|   ГДЕ 
		|   ТоварБезТары.Номенклатура.ЦеноваяГруппа НЕ В 
		|  (ВЫБРАТЬ * ИЗ втЦеновыеГруппыБезБонусов)
		|  ";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%УсловиеБезБонусов", ?(ОставитьТоварБезБонусов, "", "ГДЕ втЦеновыеГруппыБезБонусов.ЦеноваяГруппа ЕСТЬ NULL"));
	
    Запрос.УстановитьПараметр("Товар", ТаблицаТоваров);
	Запрос.УстановитьПараметр("ГрТара", Справочники.Номенклатура.НайтиПоКоду("00448      "));
	Запрос.УстановитьПараметр("Дата", ?(Дата = Неопределено, НачалоДня(ТекущаяДата()), НачалоДня(Дата)));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
КонецФункции



Функция РасчетБонусов(Партнер, ТаблицаДляРасчета, Подразделение, ОпределяемВсеВозможные=Истина)

	ТЗТовары = ПолучитьТоварыКрасчетуБаллов(ТаблицаДляРасчета, Ложь , ТекущаяДатаСеанса());

	//Дополнительный расчет бонусов за крупную покупку
	СуммаКРасчету = ТЗТовары.Итог("Сумма");
	
	КоэффициентЗаКрупнуюПокупку = 0;
	Если СуммаКРасчету >= 90000 Тогда
		КоэффициентЗаКрупнуюПокупку = 0.03;
	ИначеЕсли СуммаКРасчету >= 50000 Тогда
		КоэффициентЗаКрупнуюПокупку =  0.02;
	ИначеЕсли СуммаКРасчету >= 30000 Тогда
		КоэффициентЗаКрупнуюПокупку =  0.01;
	КонецЕсли;  
	
	Если Не ОпределяемВсеВозможные тогда
	ПартнерВПрограмме=Истина; 
	 
	ЭтоБригадир = АльтерраОбщегоНазначения.ЭтоБригадир(Партнер);
	
	РезервБаллов			 = БонусыАльтерраРезерв.ПолучитьОбщийРезервБонусныхБаллов(Партнер, Неопределено);
	
	Текст = 
		"ВЫБРАТЬ
		|	СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.БонуснаяПрограммаЛояльности КАК БонуснаяПрограммаЛояльности,
		|   СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Статус КАК Статус
		|ИЗ
		|	РегистрСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СрезПоследних(
		|			&Период,
