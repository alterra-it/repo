Функция НайтиЗаказПоНомеруССайта(НомерНаСайте)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка КАК Ссылка,
	|	ЗаказКлиента.Проведен КАК Проведен,
	|	ЗаказКлиента.ПометкаУдаления КАК ПометкаУдаления,
	|	ЗаказКлиента.Номер КАК Номер,
	|	ЗаказКлиента.Дата КАК Дата,
	|	ЗаказКлиента.ССайта КАК ССайта,
	|	ЗаказКлиента.НомерНаСайте КАК НомерНаСайте,
	|	ЗаказКлиента.ПередатьНаСайт КАК ПередатьНаСайт
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|ГДЕ
	|	ЗаказКлиента.НомерНаСайте = &НомерНаСайте
	|	И ЗаказКлиента.ССайта
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка,
	|	ЗаказКлиента.Проведен,
	|	ЗаказКлиента.ПометкаУдаления,
	|	ЗаказКлиента.Номер,
	|	ЗаказКлиента.Дата,
	|	ЗаказКлиента.ССайта,
	|	ЗаказКлиента.НомерНаСайте,
	|	ЗаказКлиента.ПередатьНаСайт
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|ГДЕ
	|	ЗаказКлиента.НомерНаСайте = &НомерНаСайте
	|	И ЗаказКлиента.ПередатьНаСайт";
	
	Запрос.УстановитьПараметр("НомерНаСайте", НомерНаСайте);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции
#КонецОбласти 

#Область Вспомогательные
Функция ПодготовитьHTTPОтвет(Ошибка, Данные=Неопределено, БезОтступов = Истина)  Экспорт
	Ответ= ПодготовитьОтвет(Ошибка, Данные);
	
	ДанныеОтправки= ОбщийHTTPСервер.СериализоватьВJSON(Ответ, БезОтступов);
	
	HTTPОтвет = Новый HTTPСервисОтвет(200);      
	
	HTTPОтвет.УстановитьТелоИзСтроки(ДанныеОтправки, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Возврат HTTPОтвет;   
	
КонецФункции
Функция ПодготовитьОтвет(Ошибка, Данные=Неопределено)  Экспорт
	Если Данные = Неопределено Тогда
		Данные= Новый Структура();
	КонецЕсли;
	
	Ответ= Новый Структура("Ошибка, Данные", Ошибка, Данные);
	
	Возврат Ответ;
КонецФункции

Функция ПрисвоитьБ_Идентификатор(Партнер, Б_Идентификатор, Ответ)
	ПартнерОбъект= Партнер.ПолучитьОбъект();
	ПартнерОбъект.Б_Идентификатор= Б_Идентификатор;
	ПартнерОбъект.Записать();
	
	Ответ.УстановитьТелоИзСтроки("Найден партнер по телефону ("+Партнер.Код+"). Установлен Б_Идентификатор "+Партнер, КодировкаТекста.UTF8);	
	Возврат Ответ;
КонецФункции

