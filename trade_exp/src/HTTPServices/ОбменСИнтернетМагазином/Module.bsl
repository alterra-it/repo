	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеJSON= Запрос.ПолучитьТелоКакСтроку("UTF-8");
	Попытка   
		ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);   
		
	//	Если ВходящиеДанные=НЕОПРЕДЕЛЕНО и Запрос.ПараметрыЗапроса.Количество() > 0 Тогда  
      //      ВходящиеДанные=Запрос.ПараметрыЗапроса;
	//	конецесли;	
			
	Исключение   
	КонецПопытки;  

		
	Метод= Запрос.ОтносительныйURL;
		
	//Маршрутизация
	Если Метод = "/GetIntervals" Тогда
		ОтветHTTP= GetIntervals(ВходящиеДанные);	
