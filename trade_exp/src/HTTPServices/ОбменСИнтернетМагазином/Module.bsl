#Область ОбработкаМаршрутов
Функция GetIntervals(ВходящиеДанные)
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		//ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		
		Подразделение       = ПолучитьФилиал(ВходящиеДанные["Branch"]);
		ДатаОтгрузки        = Дата(ВходящиеДанные["Date"]);
		Если ВходящиеДанные.Свойство("UnLoading") Тогда
			ДоставкаСРазгрузкой = Булево(ВходящиеДанные["UnLoading"]);
		Иначе
			ДоставкаСРазгрузкой = Ложь;
		КонецЕсли;
		DeliveryType        = ВходящиеДанные["DeliveryType"];
		КорИнтервала        = Число(ВходящиеДанные["delay"]);
		
		Если DeliveryType = "retail" Тогда
			ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
		ИначеЕсли DeliveryType = "ork" Тогда
			ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК;
		Иначе
			ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
		КонецЕсли;	
		
		ТекстЗапросаДляВыбораИнтервала = Справочники.ИнтервалыДоставки.ПолучитьТекстЗапросаДляВыбораИнтервала();
		Если ДоставкаСРазгрузкой Тогда
			ТекстЗапросаДляВыбораИнтервала = ТекстЗапросаДляВыбораИнтервала + " ГДЕ Результат1.КоличествоСРазгрузкойПоУмолчанию > 0 ";	
		КонецЕсли;
		
		ЗапросДляВыбораИнтервала = Новый Запрос(ТекстЗапросаДляВыбораИнтервала + " ИТОГИ ПО КодТипаДоставки");
		
		ЗапросДляВыбораИнтервала.УстановитьПараметр("ДатаОтгрузки",        ДатаОтгрузки);
		ЗапросДляВыбораИнтервала.УстановитьПараметр("Подразделение",       Подразделение);
		ЗапросДляВыбораИнтервала.УстановитьПараметр("ВидДоставки",         ВидДоставки);
		ЗапросДляВыбораИнтервала.УстановитьПараметр("ДоставкаСРазгрузкой", ДоставкаСРазгрузкой);
		ЗапросДляВыбораИнтервала.УстановитьПараметр("КорИнтервала",        КорИнтервала);
		ЗапросДляВыбораИнтервала.УстановитьПараметр("ТекДата",             ТекущаяДата());
		
		Если ДеньНедели(ДатаОтгрузки) < 6  И ВидДоставки <> Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
			ЗапросДляВыбораИнтервала.УстановитьПараметр("ДеньНедели", 0);
		Иначе
			ЗапросДляВыбораИнтервала.УстановитьПараметр("ДеньНедели", ДеньНедели(ДатаОтгрузки));
		КонецЕсли;		
		
		МассивТиповДоставки = Новый Массив;	
		ИтоговыеЗаписи = ЗапросДляВыбораИнтервала.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ИтоговыеЗаписи.Следующий() Цикл
			
			КодТипаДоставки = ИтоговыеЗаписи.КодТипаДоставки;
			Если ЗначениеЗаполнено(КодТипаДоставки) Тогда
				
				МассивЭлементовОдногоТипа = Новый Массив;
				ДетальныеЗаписи = ИтоговыеЗаписи.Выбрать();	
				Пока ДетальныеЗаписи.Следующий() Цикл		
					
					ДлительностьИнтервала = ДетальныеЗаписи.ВремяПо - ДетальныеЗаписи.ВремяС;               
					ДлительностьИнтервала = ДлительностьИнтервала - (ДлительностьИнтервала % 60); // отбрасываем секунды
					Минуты = ДлительностьИнтервала % 3600;
					
					МассивЭлементовОдногоТипа.Добавить(Новый Структура("interval_id, name, label, interval, is_active, range, unloading",
					Строка(ДетальныеЗаписи.УИД),
					ДетальныеЗаписи.Наименование,
					ДетальныеЗаписи.НаименованиеНаСайте,
					Новый Структура("from, to",
					// Формат(ДетальныеЗаписи.ВремяС, "ДФ=Ч:мм"), 
					// Формат(ДетальныеЗаписи.ВремяПо, "ДФ=Ч:мм")),
					Час(ДетальныеЗаписи.ВремяС) + (Минута(ДетальныеЗаписи.ВремяС) / 100), 
					Час(ДетальныеЗаписи.ВремяПо) + (Минута(ДетальныеЗаписи.ВремяПо) / 100)
					),
					(ДетальныеЗаписи.ДоступноНаСегодня > 0 И ДетальныеЗаписи.МожноВыбрать),
					(ДлительностьИнтервала - Минуты) / 3600 + (Минуты / 6000),
					(ДетальныеЗаписи.ДоступноНаСегодняСРазгрузкой > 0 И ДетальныеЗаписи.МожноВыбрать И ДетальныеЗаписи.МожноВыбратьРазгрузка)
					)
					);
				КонецЦикла;
				
				МассивТиповДоставки.Добавить(Новый Структура(КодТипаДоставки, МассивЭлементовОдногоТипа));
			КонецЕсли;
		КонецЦикла;
		
		Возврат ПодготовитьHTTPОтвет(Ложь, МассивТиповДоставки);		
	Исключение
		Возврат ОшибкаОбменаСИнтернетМагазином("Не удалось получить интервалы доставки!");			
	КонецПопытки;
КонецФункции

Функция UpdatePartner(ВходящиеДанные)
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		ИД = ВходящиеДанные["ref"];
		Если Не ЗначениеЗаполнено(ИД) Тогда
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка обновления данных партнера: Передан пустой ИД");
		КонецЕсли;
		
		Партнер = АльтерраОбщегоНазначения.ПолучитьпартнераПоСсылке(ИД);
		Если Не ЗначениеЗаполнено(Партнер) Тогда                                              
			Возврат ОшибкаОбменаСИнтернетМагазином(СтрШаблон("Ошибка обновления данных партнера: Клиент по УИД %1 не найден; данные обновления: " + 
				"e-mail: %2, тел.: %3, дата рождения: %4",
				ВходящиеДанные["ref"], ВходящиеДанные["emale"], ВходящиеДанные["tel"], ВходящиеДанные["birthday"]));
		КонецЕсли;
		ТелефонПартнера =ВходящиеДанные["tel"]; 
		Если ДопМодульКлиентСервер.НомерСуществуетВБазе(Партнер, ТелефонПартнера) Тогда  
			 Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка обновления данных партнера: Такой номер уже существует в базе у другого партнера");
		КонецЕсли;
		Партнер = Партнер.ПолучитьОбъект();
		ДопМодульКлиентСервер.ОбновитьДП(
			Партнер, 
			"",  
			ВходящиеДанные["birthday"], 
			ВходящиеДанные["tel"], 
			ВходящиеДанные["emale"]);

			Возврат ПодготовитьHTTPОтвет(Ложь, XMLСтрока(Партнер.Ссылка));
		Исключение 
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка обновления данных партнера!");			
	КонецПопытки; 
КонецФункции

Функция GetTarif(ВходящиеДанные)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		МассивНоменклатур = ВходящиеДанные["goods"];
		DeliveryType      = ВходящиеДанные["DeliveryType"];
		ЭкспрессДоставка  = Булево(ВходящиеДанные["express"]);
		
		Если ЗначениеЗаполнено(МассивНоменклатур) И ТипЗнч(МассивНоменклатур) = Тип("Массив") Тогда
			ТЗ_Товары = Новый ТаблицаЗначений();
			ТЗ_Товары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			ТЗ_Товары.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
			Попытка
				Для Инд = 0 По МассивНоменклатур.Количество() - 1 Цикл
					Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(МассивНоменклатур[Инд].ref));
					Если ПустаяСтрока(Номенклатура.Код) Тогда
						Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Передан неверный массив, пустой код номенклатуры в массиве");
					КонецЕсли;    
					СтрокаТЗ = ТЗ_Товары.Добавить();
					СтрокаТЗ.Номенклатура = Номенклатура;
					СтрокаТЗ.Количество = МассивНоменклатур[Инд].count;
				КонецЦикла;
			Исключение
				Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Передан неверный массив, ошибка в попытке добавить строку");
			КонецПопытки;
		Иначе
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Передан неверный массив, массив пустой или передан не массив");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(DeliveryType) Тогда
			Если DeliveryType = "retail" Тогда
				ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
			ИначеЕсли DeliveryType = "ork" Тогда
				ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК;
			Иначе
				ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
			КонецЕсли;
		КонецЕсли;
		
		//Восстановить после внедрения автоопределения тарифа
		//ПодходящийТариф = Документы.ЗаказНаДоставкуКлиенту.ПолучитьТариф(ТЗ_Товары, ВидДоставки, ЭкспрессДоставка);
		//Если ЗначениеЗаполнено(ПодходящийТариф) Тогда
		//	СтруктураОтвета = Новый Структура;
		//	СтруктураОтвета.Вставить("name", ПодходящийТариф.Наименование);
		//	СтруктураОтвета.Вставить("DeliveryType", ПодходящийТариф.ТипДоставки.Код);
		//	СтруктураОтвета.Вставить("CarTypeID", XMLСтрока(ПодходящийТариф.ВидАвтомобиля));
		//	Возврат ПодготовитьHTTPОтвет(Ложь, СтруктураОтвета);
		//Иначе
		//	Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Ошибка в методе 'ПолучитьТариф()'");
		//КонецЕсли;
		
		//Убрать после внедрения автоопределения тарифа +
		
		ТЗТарифов = ПолучитьТариф(ТЗ_Товары, ВидДоставки, ЭкспрессДоставка);
		
		МассивТарифов = Новый Массив;
						
		Для каждого СтрокаТаблицы из ТЗТарифов Цикл
			
			СтруктураОтвета = Новый Структура("name,DeliveryType,CarTypeID,MaxLength,Branch",);

			ЗаполнитьЗначенияСвойств(СтруктураОтвета,СтрокаТаблицы);
			СтруктураОтвета.DeliveryType = ?(ЗначениеЗаполнено(СтрокаТаблицы.ТипДоставки),СтрокаТаблицы.ТипДоставки,Ложь);
			СтруктураОтвета.CarTypeID = ?(ЗначениеЗаполнено(СтрокаТаблицы.ВидАвтомобиля),XMLСтрока(СтрокаТаблицы.ВидАвтомобиля),Ложь);
			СтруктураОтвета.Branch = ПолучитьФилиалДляСайта(СтрокаТаблицы.Подразделение);
			
			МассивТарифов.Добавить(СтруктураОтвета);
			
		КонецЦикла;
		
		//Убрать после внедрения автоопределения тарифа -

		Если МассивТарифов.Количество()>0 Тогда
			Возврат ПодготовитьHTTPОтвет(Ложь, МассивТарифов);
		Иначе
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Ошибка в методе 'ПолучитьТариф()'");
		КонецЕсли;

	Исключение
		Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки!");			
	КонецПопытки;
	
КонецФункции

Функция CalculateBonuses(ВходящиеДанные)
	
	УстановитьПривилегированныйРежим(Истина);
	    
	Попытка
		МассивНоменклатур = ВходящиеДанные["products"];
		IDПартнера = ВходящиеДанные["client_xml_id"];
		ИмяПодразделения = ВходящиеДанные["branch"];
		ПочтовыйАдресПартнера = ВходящиеДанные["client_email"];
		
		ОпределяемВсеВозможные = Ложь;
		
		Если ПустаяСтрока(IDПартнера) И ПустаяСтрока(ПочтовыйАдресПартнера) тогда
			ОпределяемВсеВозможные = Истина;
		  иначе
			  Партнер= АльтерраОбщегоНазначения.ПолучитьпартнераПоСсылке(IDПартнера);
			Если НЕ ЗначениеЗаполнено(Партнер) тогда
				Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоПочте(ПочтовыйАдресПартнера);
			КонецЕсли;	
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(Партнер) тогда
		   ОпределяемВсеВозможные = Истина;
		КонецЕсли;
		
		Если ПустаяСтрока(ИмяПодразделения) тогда
					Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Не указано подразделение");
		иначе	
			        Подразделение = ПолучитьФилиал(ИмяПодразделения);
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(МассивНоменклатур) И ТипЗнч(МассивНоменклатур) = Тип("Массив") Тогда
			ТЗ_Товары = Новый ТаблицаЗначений();
			ТЗ_Товары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
			ТЗ_Товары.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
			ТЗ_Товары.Колонки.Добавить("Цена", Новый ОписаниеТипов("Число"));
			ТЗ_Товары.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
			Попытка
				Для Инд = 0 По МассивНоменклатур.Количество() - 1 Цикл
					Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(МассивНоменклатур[Инд].ref));
					Если ПустаяСтрока(Номенклатура.Код) Тогда
						Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Передан неверный массив, пустой код номенклатуры в массиве");
					КонецЕсли;    
					СтрокаТЗ = ТЗ_Товары.Добавить();
					СтрокаТЗ.Номенклатура = Номенклатура;
					СтрокаТЗ.Количество = МассивНоменклатур[Инд].count;
					СтрокаТЗ.Цена = МассивНоменклатур[Инд].price;
					СтрокаТЗ.Сумма = СтрокаТЗ.Количество*СтрокаТЗ.Цена;
				КонецЦикла;
			Исключение
				Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка расчета бонусов: Передан неверный массив, ошибка в попытке добавить строку");
			КонецПопытки;
		Иначе
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка расчета бонусов: Передан неверный массив, массив пустой или передан не массив");
		КонецЕсли;
		
		ТЗБонусов = РасчетБонусов(Партнер, ТЗ_Товары, Подразделение, ОпределяемВсеВозможные);

		            МассивБонусов = Новый Массив;
					СтруктураОтвета = Новый Структура;
					
                Для каждого СтрокаТаблицы из ТЗБонусов Цикл
                     СтруктураОтвета.Вставить(СтрокаТаблицы.Статус,СтрокаТаблицы.СуммаБаллов);
		       КонецЦикла;
			     МассивБонусов.Добавить(СтруктураОтвета);
		
		Если МассивБонусов.Количество()>0 Тогда
			Возврат ПодготовитьHTTPОтвет(Ложь, МассивБонусов);
		Иначе
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки: Ошибка в методе 'CalculateBonuses'");
		КонецЕсли;

	Исключение
		Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения тарифа доставки!");			
	КонецПопытки;
	
	
КонецФункции	

