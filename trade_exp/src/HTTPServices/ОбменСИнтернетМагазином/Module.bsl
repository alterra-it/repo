Функция PayOrder(Запрос)
	Ответ = Новый HTTPСервисОтвет(200);
	УстановитьПривилегированныйРежим(Истина);
	
	Если Запрос.ПараметрыЗапроса.Количество() = 0 Тогда
		Ответ.УстановитьТелоИзСтроки("Переданы пустые параметры", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Переданы пустые параметры");
		Возврат Ответ;
	КонецЕсли;
	
	ИД = Запрос.ПараметрыЗапроса.Получить("XML_ID");
	СуммаОплаты = Число(Запрос.ПараметрыЗапроса.Получить("SUMMA"));
	
	Если ПустаяСтрока(ИД) Тогда
		Ответ.УстановитьТелоИзСтроки("Передан пустой XML_ID", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Передан пустой XML_ID");
		Возврат Ответ;
	КонецЕсли;
	
	Если СтрДлина(ИД) > 7 Тогда
		Попытка
			УИД = Новый УникальныйИдентификатор(ИД);
		Исключение
			Ответ.УстановитьТелоИзСтроки("Не верный УИД", КодировкаТекста.UTF8);
			ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Не верный УИД");
			Возврат Ответ;
		КонецПопытки;
		
		Заказ = Документы.ЗаказКлиента.ПолучитьСсылку(УИД);
	Иначе
		Заказ = НайтиЗаказПоНомеруССайта(ИД);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Заказ) Тогда
		Ответ.УстановитьТелоИзСтроки("Заказ не найден", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Заказ не найден");
		Возврат Ответ;
	КонецЕсли;
	
	Если Не Заказ.Проведен Тогда
		Ответ.УстановитьТелоИзСтроки("Заказ не проведен", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Заказ не проведен");
		Возврат Ответ;
	КонецЕсли;
	
	ЭквайринговыйТерминал = Документы.ОперацияПоПлатежнойКарте.ПолучитьТерминалССайтаПоУмолчанию();
	Эквайринг = Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(Заказ, ЭквайринговыйТерминал);
	Если Не ЗначениеЗаполнено(Эквайринг) Тогда
		Ответ.УстановитьТелоИзСтроки("Нет эквайринговой операции к оплате", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Нет эквайринговой операции к оплате");
		Возврат Ответ;
	КонецЕсли;
	
	Если Эквайринг.Проведен Тогда
		Ответ.УстановитьТелоИзСтроки("Эквайринг уже проведен", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Эквайринг уже проведен");
		Возврат Ответ;
	КонецЕсли;
	
	Если СуммаОплаты <= 0 Тогда
		Ответ.УстановитьТелоИзСтроки("Сумма равна нулю", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Сумма равна нулю");
		Возврат Ответ;
	КонецЕсли;
	
	//Если Эквайринг.СуммаДокумента <> СуммаОплаты Тогда
	//	Ответ.УстановитьТелоИзСтроки("Не совпадает сумма оплаты", КодировкаТекста.UTF8);
	//	Возврат Ответ;
	//КонецЕсли;
	
	Док = Эквайринг.ПолучитьОбъект();
	Док.Комментарий = Док.Комментарий + " Оплачена на сайте.";
	Док.Дата = ТекущаяДата();
	
	ФинансыКлиентСервер.ПересчитатьСуммыВСтрокеРасшифровкиПлатежа(Док, СуммаОплаты, Ложь);
	Док.СуммаДокумента = Док.РасшифровкаПлатежа.Итог("Сумма");
	
	Попытка
		//Док.Записать(РежимЗаписиДокумента.Запись);
		Док.НомерПлатежнойКарты = "0202";
		Док.Записать(РежимЗаписиДокумента.Проведение);
		
		Ответ.УстановитьТелоИзСтроки("Эквайринг проведен!", КодировкаТекста.UTF8);
		
		Попытка
			АльтерраОбщегоНазначения.ОтправитьСМСПоИнтернетЗаказу(Заказ);
			АльтерраОбщегоНазначения.ОтправитьОповещениеБ24ПоИнтернетЗаказу(Заказ);
		Исключение
			ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось отправить сообщение в Битрикс24");
		КонецПопытки;
		
		Возврат Ответ;
	Исключение
		Ответ.УстановитьТелоИзСтроки("Ошибка записи Эквайринга", КодировкаТекста.UTF8);
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, ,	ИнформацияОбОшибке().Описание, "Ошибка записи Эквайринга");
		Возврат Ответ;
	КонецПопытки;		
	
	Ответ.УстановитьТелоИзСтроки("Неизвестная ситуация", КодировкаТекста.UTF8);
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Ответ;
КонецФункции

Функция GetBarcode(Запрос)
	Ответ = Новый HTTPСервисОтвет(200);
	УстановитьПривилегированныйРежим(Истина);
	
	Если Запрос.ПараметрыЗапроса.Количество() = 0 Тогда
		Ответ.УстановитьТелоИзСтроки("0", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	
	ИД= Запрос.ПараметрыЗапроса.Получить("XML_ID");
	
	Если ПустаяСтрока(ИД) Тогда
		Ответ.УстановитьТелоИзСтроки("0", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	
	Если СтрДлина(ИД) > 7 Тогда
		Попытка
			УИД= Новый УникальныйИдентификатор(ИД);
		Исключение
			Ответ.УстановитьТелоИзСтроки("0", КодировкаТекста.UTF8);
			Возврат Ответ;
		КонецПопытки;
		
		Заказ= Документы.ЗаказКлиента.ПолучитьСсылку(УИД);
	Иначе
		Заказ= НайтиЗаказПоНомеруССайта(ИД);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Заказ) Тогда
		Ответ.УстановитьТелоИзСтроки("0", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	
	Штрихкод= ШтрихкодированиеПечатныхФорм.ЧисловойКодПоСсылке(Заказ);
	
	Ответ.УстановитьТелоИзСтроки(Штрихкод, КодировкаТекста.UTF8);
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Ответ;
	
КонецФункции

