Функция PrintСheck(ПараметрыЗапроса) 
	Ответ = Новый HTTPСервисОтвет(200);
	
	УстановитьПривилегированныйРежим(Истина);
	Если ПараметрыЗапроса.Количество() = 0 Тогда
		Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Отсутствуют параметры"); 
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Переданы пустые параметры");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПараметрыЗапроса.Свойство("XML_ID") И ПараметрыЗапроса.XML_ID<>"" Тогда
		ИДЗаказа = ПараметрыЗапроса.XML_ID;
	Иначе
		Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Передан пустой XML_ID");
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Передан пустой XML_ID");
		Возврат Ответ;
	КонецЕсли;
	
	СуммаОплаты = 0;
	Если ПараметрыЗапроса.Свойство("SUMMA") Тогда 
		СуммаОплаты = Число(ПараметрыЗапроса.SUMMA);
	КонецЕсли;
	
	Если СуммаОплаты <= 0 Тогда
		Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Переданная сумма оплаты равна 0");
		ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "Передана сумма оплаты 0");
		Возврат Ответ;
	КонецЕсли;

	ИДПлатежнойСистемы = "21"; // Эквайринговый Терминал по умолчанию ("Сайт, СБП Альфа (Альтерра)") 
	Если ПараметрыЗапроса.Свойство("PS_ID") Тогда 
		ИДПлатежнойСистемы = Строка(ПараметрыЗапроса.PS_ID);
	КонецЕсли;
	
	//Временный костыль для СБП Альфа
	Если ИДПлатежнойСистемы = "19" Тогда
		ИДПлатежнойСистемы = "21";
	КонецЕсли;
	
	ЭквайринговыйТерминал = Справочники.ЭквайринговыеТерминалы.НайтиПоКоду(ИДПлатежнойСистемы);
	
	//получить заказ клиента
	Ответ = НайтиЗаказКлиента(ИДЗаказа);
	//log
	ПараметрыЛоговДляКассы = Новый Структура("АдресХраненияЛогов,ВремяХраненияВДнях");
	УстановитьПривилегированныйРежим(Истина);
	КассаОплат = Константы.КассаИнтернетМагазина.Получить();
	УстановитьПривилегированныйРежим(Ложь);
	ПараметрыЛоговДляКассы.АдресХраненияЛогов = КассаОплат.АдресХраненияЛогов;
	ПараметрыЛоговДляКассы.ВремяХраненияВДнях = КассаОплат.ВремяХраненияВДнях;
	
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, "ИДЗаказа="+ИДЗаказа+";СуммаОплаты="+СуммаОплаты, "", "Параметры запроса");
	
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, Ответ, Ответ, "Поиск заказа");
	Если ТипЗнч(Ответ) <> Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Возврат Ответ;
	КонецЕсли;
	
	ЗаказКлиента = Ответ;
	
	Ответ = НайтиДокументОплаты(ЗаказКлиента, СуммаОплаты, ЭквайринговыйТерминал);
	//log
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, ЗаказКлиента, Ответ, "Поиск оплаты");
	
	Если ТипЗнч(Ответ)=Тип("HTTPСервисОтвет") Тогда
		Возврат Ответ;
	КонецЕсли;
	
	ЭквайринговаяОперация = Ответ;

//получить данные партнера для отправки уведомления
	АдресУведомленияКлиента = ""; //email или телефон
	ОтправитьНаEmail = Ложь;
	Если ПараметрыЗапроса.Свойство("EMAIL") И СтрЗаменить(ПараметрыЗапроса.EMAIL, " ", "") <> "" Тогда
		АдресУведомленияКлиента = ПараметрыЗапроса.EMAIL;
		ОтправитьНаEmail = Истина;
	Иначе
		//получить данные партнёра
		КонтактныеДанныеПартнера = АльтерраОбщегоНазначения.ПолучитьТелефонПочтуПартнера(ЗаказКлиента.Партнер); 
		ЭПКлиента = "";
		НомерКлиента = "";
		Для каждого СтрДанных из КонтактныеДанныеПартнера Цикл
			Если СтрДанных.АдресЭП <> "" Тогда
				ЭПКлиента = СтрДанных.АдресЭП;
				Прервать;
			КонецЕсли;
			Если СтрДанных.НомерТелефона <> "" И НомерКлиента="" Тогда
				НомерКлиента = СтрДанных.НомерТелефона;
			КонецЕсли;
		КонецЦикла;
		
		Если ЭПКлиента<>"" Тогда
			//если есть email,
			АдресУведомленияКлиента = ЭПКлиента;
			ОтправитьНаEmail = Истина;
		ИначеЕсли НомерКлиента <> "" Тогда
			//если нет - номер телефона в формате +{Ц}
			Если Лев(НомерКлиента,1) = "9" Тогда
				АдресУведомленияКлиента = "+7"+НомерКлиента;
			Иначе
				АдресУведомленияКлиента = НомерКлиента;
			КонецЕсли;
		Иначе
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "У клиента не найден email и номер телефона. Нужно либо отправить с сайта, либо указать в клиенте в 1С", "");
			ЗаписьЖурналаРегистрации("ОбменСИнтернетМагазиномОплата", УровеньЖурналаРегистрации.Ошибка, , , "У клиента не найден email и номер телефона");
			Возврат Ответ;
		КонецЕсли;
	КонецЕсли;
	
	//
	НомерКарты = "";
	Если ПараметрыЗапроса.Свойство("CARD_NUM") Тогда
		   НомерКарты = СтрЗаменить(ПараметрыЗапроса.CARD_NUM, " ", "");
	КонецЕсли;
	
	ИдентификаторОплаты = ?(ПараметрыЗапроса.Свойство("PS_INVOICE_ID"), ПараметрыЗапроса.PS_INVOICE_ID, "");	
	
	Ответ = АльтерраОбщегоНазначения.ПроверкаНаНаличиеЗаписейВРегистре(ЗаказКлиента, ЭквайринговаяОперация, СуммаОплаты, АдресУведомленияКлиента, НомерКарты, ЭквайринговыйТерминал, ИдентификаторОплаты);
	
	//log
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, ЗаказКлиента, Ответ, "Ответ 1С сайту");
	
	Возврат Ответ;
КонецФункции // PrintСheck()    

Функция PrintСheckArray(Запрос, ПараметрыЗапроса)  
	УстановитьПривилегированныйРежим(Истина); 
	
	СтатусОшибки = Ложь;
	ТекстОтвета = "";
	
	Если ЗначениеЗаполнено(ПараметрыЗапроса) Тогда
		Если ПараметрыЗапроса.Свойство("array") И ЗначениеЗаполнено(ПараметрыЗапроса.array) Тогда
			Массив = ПараметрыЗапроса.array;  
		КонецЕсли;
		
		Если ПараметрыЗапроса.Свойство("XML_ID") Тогда
			Массив = Новый Массив;
			Массив.Добавить(ПараметрыЗапроса);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Массив) Тогда
			НомерЭлемента = 1;
			Для Каждого ЭлементМассива Из Массив Цикл             
				Ответ = PrintСheck_ОбработатьЭлементМассива(ЭлементМассива);
				Если ТипЗнч(Ответ) = Тип("Структура") Тогда
					Если Ответ.СтатусОшибки Тогда
						СтатусОшибки = Истина;
					КонецЕсли;    
					
					ТекстОтвета = ТекстОтвета + " Элемент " + НомерЭлемента + ": " + Ответ.Сообщение;
				Иначе                  
					СтатусОшибки = Истина;      
					ТекстОтвета = ТекстОтвета + " Элемент " + НомерЭлемента + ": " + "Неверный формат данных";	
				КонецЕсли;
				
				НомерЭлемента = НомерЭлемента + 1;
			КонецЦикла;
		Иначе            
			СтатусОшибки = Истина;      
			ТекстОтвета = "Ошибка в данных";
		КонецЕсли;  
	Иначе                    
		СтатусОшибки = Истина;      
		ТекстОтвета = "Переданы пустые параметры";
	КонецЕсли;
	
	// Записать лог
	ПараметрыЗапроса = ДопМодульСервер.ПолучитьПараметрыHTTPЗапроса(Запрос);
	Тело = ДопМодульСервер.ФорматироватьJsonТекст(ОбщийHTTPСервер.ПодготовитьОтвет(СтатусОшибки, ТекстОтвета));  
	ДопМодульСервер.ЗаписатьЛогЛК(ПараметрыЗапроса, Тело, СтатусОшибки);
	
	Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(СтатусОшибки, ТекстОтвета);
	
КонецФункции    

Функция PrintСheck_ОбработатьЭлементМассива(ПараметрыЗапроса)
	Если ПараметрыЗапроса.Свойство("XML_ID") И ЗначениеЗаполнено(ПараметрыЗапроса.XML_ID) Тогда 
		ИДЗаказа = ПараметрыЗапроса.XML_ID;
	Иначе               
		Возврат Ошибка("Передан пустой XML_ID", Истина);
	КонецЕсли;
	
	Попытка
		Если ПараметрыЗапроса.Свойство("SUMMA") И ЗначениеЗаполнено(ПараметрыЗапроса.SUMMA) И Число(ПараметрыЗапроса.SUMMA) > 0 Тогда 
			СуммаОплаты = Число(ПараметрыЗапроса.SUMMA);    
		Иначе
			Возврат Ошибка("Переданная сумма оплаты равна 0", Истина);
		КонецЕсли; 
	Исключение
		Возврат Ошибка("Переданная сумма оплаты равна 0", Истина);
	КонецПопытки;
	
	Если ПараметрыЗапроса.Свойство("CARD_NUM") Тогда
		НомерКарты = СтрЗаменить(ПараметрыЗапроса.CARD_NUM, " ", "");
	Иначе
		НомерКарты = "";
	КонецЕсли;
	
	ИдентификаторОплаты = ПолучитьИдентификаторОплаты(ПараметрыЗапроса);
	
	Если ПараметрыЗапроса.Свойство("PS_ID") Тогда
		ИДПлатежнойСистемы = Строка(ПараметрыЗапроса.PS_ID);
		//Временный костыль для СБП Альфа
		Если ИДПлатежнойСистемы = "19" Тогда
			ИДПлатежнойСистемы = "21";
		КонецЕсли; 
		//-
		ЭквайринговыйТерминал = Справочники.ЭквайринговыеТерминалы.НайтиПоКоду(ИДПлатежнойСистемы);
	КонецЕсли;	
	Если Не ЗначениеЗаполнено(ЭквайринговыйТерминал) Тогда // Эквайринговый Терминал по умолчанию ("Сайт, СБП Открытие (Альтерра)" 
		ЭквайринговыйТерминал = Справочники.ЭквайринговыеТерминалы.НайтиПоКоду("21");
	КонецЕсли;                
	
	ЗаказКлиента = НайтиЗаказКлиента(ИДЗаказа, Истина);
	КассаОплат = Константы.КассаИнтернетМагазина.Получить();        
	ПараметрыЛоговДляКассы = Новый Структура("АдресХраненияЛогов, ВремяХраненияВДнях", КассаОплат.АдресХраненияЛогов, КассаОплат.ВремяХраненияВДнях);	
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, "ИДЗаказа="+ИДЗаказа+";СуммаОплаты="+СуммаОплаты, "", "Параметры запроса");	
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, ЗаказКлиента, ЗаказКлиента, "Поиск заказа");	
	Если ТипЗнч(ЗаказКлиента) = Тип("Структура") Тогда
		Возврат ЗаказКлиента; 
	ИначеЕсли Не ЗначениеЗаполнено(ЗаказКлиента) Тогда
		Возврат Ошибка("Не найден Заказ Клиента", Истина);
	КонецЕсли;             
	
	ЭквайринговаяОперация = НайтиДокументОплаты(ЗаказКлиента, СуммаОплаты, ЭквайринговыйТерминал, Истина);
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, ЗаказКлиента, ЭквайринговаяОперация, "Поиск оплаты");	
	Если ТипЗнч(ЭквайринговаяОперация) = Тип("Структура") Тогда
		Возврат ЭквайринговаяОперация;
	ИначеЕсли Не ЗначениеЗаполнено(ЭквайринговаяОперация) Тогда
		Возврат Ошибка("Не найдена Эквайринговая Операция", Истина);
	КонецЕсли;
	
	Если ПараметрыЗапроса.Свойство("EMAIL") И СтрЗаменить(ПараметрыЗапроса.EMAIL, " ", "") <> "" Тогда
		ОтправитьНаEmail = Истина;
		АдресУведомленияКлиента = ПараметрыЗапроса.EMAIL;
	Иначе                     
		//получить данные партнёра
		КонтактныеДанныеПартнера = АльтерраОбщегоНазначения.ПолучитьТелефонПочтуПартнера(ЗаказКлиента.Партнер); 
		ЭПКлиента = "";
		НомерКлиента = "";
		Для каждого СтрДанных из КонтактныеДанныеПартнера Цикл
			Если ЗначениеЗаполнено(СтрДанных.АдресЭП) Тогда
				ЭПКлиента = СтрДанных.АдресЭП;
				Прервать;
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрДанных.НомерТелефона) И Не ЗначениеЗаполнено(НомерКлиента) Тогда
				НомерКлиента = СтрДанных.НомерТелефона;
			КонецЕсли;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ЭПКлиента) Тогда // если есть email
			ОтправитьНаEmail = Истина;
			АдресУведомленияКлиента = ЭПКлиента;
		ИначеЕсли ЗначениеЗаполнено(НомерКлиента) Тогда // если нет - номер телефона в формате +{Ц}
			ОтправитьНаEmail = Ложь;
			Если Лев(НомерКлиента,1) = "9" Тогда
				АдресУведомленияКлиента = "+7" + НомерКлиента;
			Иначе
				АдресУведомленияКлиента = НомерКлиента;
			КонецЕсли;
		Иначе             
			Возврат Ошибка("У клиента не найден email и номер телефона. Нужно либо отправить с сайта, либо указать в клиенте в 1С", Истина);
		КонецЕсли;
	КонецЕсли;
	                      
	Ответ = ПроверкаНаНаличиеЗаписейВРегистре(ЗаказКлиента, ЭквайринговаяОперация, СуммаОплаты, АдресУведомленияКлиента, НомерКарты, ЭквайринговыйТерминал, ИдентификаторОплаты);
	АТОЛСревер.ЗаписатьЛогВФайл(ПараметрыЛоговДляКассы, ЗаказКлиента, Ответ, "Ответ 1С сайту");	
	Возврат Ответ;
КонецФункции

Функция ПолучитьИдентификаторОплаты(ПараметрыЗапроса)
	
	ИдентификаторОплаты = "";
	НомерЗаказа = "";
	
	Если ПараметрыЗапроса.Свойство("PS_INVOICE_ID") Тогда
		ИдентификаторОплаты = ПараметрыЗапроса.PS_INVOICE_ID;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИдентификаторОплаты) И ПараметрыЗапроса.Свойство("PS_STATUS_MESSAGE") И ЗначениеЗаполнено(ПараметрыЗапроса.PS_STATUS_MESSAGE) Тогда
		МассивСообщения = СтрРазделить(ПараметрыЗапроса.PS_STATUS_MESSAGE, " ");
		Если МассивСообщения.Количество() > 0 Тогда
			Попытка
				НомерЗаказаСтрока = МассивСообщения[МассивСообщения.Количество() - 1];
				НомерЗаказаЧисло = Число(НомерЗаказаСтрока);
				НомерЗаказа = НомерЗаказаСтрока;
			Исключение
				НомерЗаказа = "";
			КонецПопытки;
		КонецЕсли;
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(ИдентификаторОплаты) И ЗначениеЗаполнено(НомерЗаказа) Тогда
		
		ТекДата = ТекущаяДатаСеанса();
		Сутки = 24 * 60 * 60;
		
		НастройкиДС = ИнтеграцияБанки.ПолучитьНастройкиДинамическиеСсылки(ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт")).Ответ;
		ПараметрыСтатистикиДС = ИнтеграцияБанки.ПараметрыСтатистикаДинамическихСсылок(НастройкиДС, 
			НачалоДня(ТекДата - Сутки), НачалоДня(ТекДата + Сутки));
		ОплатаЗаказа = ИнтеграцияБанки.ПолучитьСтатистикуДинамическихСсылок(НастройкиДС, ПараметрыСтатистикиДС, НомерЗаказа).Ответ;
		
		Если ТипЗнч(ОплатаЗаказа) = Тип("Структура") И ОплатаЗаказа.Свойство("УИД") Тогда
			ИдентификаторОплаты = ОплатаЗаказа.УИД; 
		КонецЕсли;
			
	КонецЕсли;
	
	Возврат ИдентификаторОплаты;
	
КонецФункции

Функция GetUnloadingCost(ВходящиеДанные)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		//Входящие данные
		Этаж = Число(ВходящиеДанные["level"]);
		Разгрузка = Булево(ВходящиеДанные["unloading"]);
		ПодъемНаЭтаж = Булево(ВходящиеДанные["risetothefloor"]);
		Лифт = Булево(ВходящиеДанные["lift"]);
		ЛифтГрузовой = Булево(ВходящиеДанные["servicelift"]);
		Зона = Число(ВходящиеДанные["zone"]);
		
		МассивНоменклатур = ВходящиеДанные["goods"];
		
		Если ВходящиеДанные.Свойство("slicing") Тогда
			МассивНарезки = ВходящиеДанные["slicing"];
		Иначе
			МассивНарезки = Новый Массив();
		КонецЕсли;
		
		ТЗ_Товары = Новый ТаблицаЗначений();
		ТЗ_Товары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		ТЗ_Товары.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
		
		//Товары
		Если ЗначениеЗаполнено(МассивНоменклатур) И ТипЗнч(МассивНоменклатур) = Тип("Массив") Тогда
			Попытка
				Для Инд = 0 По МассивНоменклатур.Количество() - 1 Цикл
					Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(МассивНоменклатур[Инд].ref));
					Если ПустаяСтрока(Номенклатура.Код) Тогда
						Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: Передан неверный массив");
					КонецЕсли;    
					СтрокаТЗ = ТЗ_Товары.Добавить();
					СтрокаТЗ.Номенклатура = Номенклатура;
					СтрокаТЗ.Количество = МассивНоменклатур[Инд].count;
				КонецЦикла;
			Исключение
				Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: Передан неверный массив");
			КонецПопытки;
		Иначе
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: Передан неверный массив");
		КонецЕсли;
		
		ТЗ_ТоварыНарезки = Новый ТаблицаЗначений();
		ТЗ_ТоварыНарезки.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		ТЗ_ТоварыНарезки.Колонки.Добавить("КоличествоРезов", Новый ОписаниеТипов("Число"));
		
		//Нарезка
		Если ЗначениеЗаполнено(МассивНарезки) И ТипЗнч(МассивНарезки) = Тип("Массив") Тогда				
			Попытка
				Для Инд = 0 По МассивНарезки.Количество() - 1 Цикл
					Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(МассивНоменклатур[Инд].ref));
					Если ПустаяСтрока(Номенклатура.Код) Тогда
						Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: Передан неверный массив нарезки");
					КонецЕсли;    
					СтрокаТЗ = ТЗ_ТоварыНарезки.Добавить();
					СтрокаТЗ.Номенклатура = Номенклатура;
					СтрокаТЗ.КоличествоРезов = МассивНарезки[Инд].numberofcuts;
				КонецЦикла;
			Исключение
				Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: Передан неверный массив нарезки");
			КонецПопытки;
		КонецЕсли;
		
		СтруктураНоменклатуры = Новый Структура();
		СтруктураНоменклатуры.Вставить("Товары",ТЗ_Товары);
		СтруктураНоменклатуры.Вставить("Нарезка",ТЗ_ТоварыНарезки);
		
		//Вариант разгрузки
		СпособРазгрузки = Перечисления.СпособыРазгрузки.ПустаяСсылка(); 
		
		Если ПодъемНаЭтаж Тогда
			Если ЛифтГрузовой ИЛИ Лифт Тогда
				СпособРазгрузки = Перечисления.СпособыРазгрузки.Лифт;
			Иначе
				СпособРазгрузки = Перечисления.СпособыРазгрузки.Лестница;
			КонецЕсли;
		ИначеЕсли Разгрузка Тогда
			СпособРазгрузки = Перечисления.СпособыРазгрузки.Разгрузка;
		КонецЕсли;	
		
		ВариантРазгрузки = УправлениеЛогистикойСервер.ПолучитьВариантРазгрузкиПоСпособу(СпособРазгрузки,ЛифтГрузовой);
		
		Если ВариантРазгрузки.Пустая() Тогда
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: вариант разгрузки не определен");
		КонецЕсли;
		
		//Зона
		ГлобальнаяЗона = Перечисления.ЗоныДоставкиКлиента.ПустаяСсылка();
		
		Если Зона = 1 Тогда
			ГлобальнаяЗона = Перечисления.ЗоныДоставкиКлиента.Зона1; 
		ИначеЕсли Зона = 2 Тогда
			ГлобальнаяЗона = Перечисления.ЗоныДоставкиКлиента.Зона2; 
		Конецесли;
		
		Если ГлобальнаяЗона.Пустая() Тогда
			Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки: зона не определена");
		КонецЕсли;
		
		//Расчет
		ТоварыКРазгрузке = УправлениеЛогистикойСервер.ПолучитьТаблицуРазгрузкиТовара(СтруктураНоменклатуры);
		
		Если ЛифтГрузовой Тогда
			ПараметрыОтбора = Новый Структура("Разгрузка,Лестница,Лифт,ЛифтГрузовой",Истина,Ложь,Ложь,Ложь);
		ИначеЕсли Лифт Тогда
			ПараметрыОтбора = Новый Структура("Разгрузка,Лестница,Лифт",Истина,Ложь,Ложь);
		Иначе	
			ПараметрыОтбора = Новый Структура("Разгрузка,Лестница",Истина,Ложь);
		КонецЕсли;
		
		НеГабаритМассивСтрок = ТоварыКРазгрузке.НайтиСтроки(ПараметрыОтбора);
		
		МассивНеГабарит = Новый Массив();
		
		Для каждого СтрокаНеГабарита из НеГабаритМассивСтрок Цикл
			МассивНеГабарит.Добавить(XMLСтрока(СтрокаНеГабарита.Номенклатура.УникальныйИдентификатор()));
		КонецЦикла;
		
		ЕстьНеГабарит = МассивНеГабарит.Количество()>0;
		
		МассивСпособов = Новый Массив;
		МассивСпособов.Добавить(СпособРазгрузки);
		
		Если СпособРазгрузки = Перечисления.СпособыРазгрузки.Лифт Тогда
			МассивСпособов.Добавить(Перечисления.СпособыРазгрузки.Лестница);
			МассивСпособов.Добавить(Перечисления.СпособыРазгрузки.Разгрузка);
		ИначеЕсли СпособРазгрузки = Перечисления.СпособыРазгрузки.Лестница Тогда
			МассивСпособов.Добавить(Перечисления.СпособыРазгрузки.Разгрузка);
		КонецЕсли;
		
		ИтоговыйВес = 0;
		ИтоговыйОбъем = 0;
		СтоимостьРазгрузки = 0;
		СтоимостьПодъемаНаЭтаж = 0;
		КоличествоСпособовРазгрузки = 0;
		ВремяРазгрузки = 0;
		
		Для каждого ЗначениеМассива из МассивСпособов Цикл
			
			СтоимостьУслуги = 0;
			СтоимостьУслугиНегабарит = 0;
			Вес = 0;
			ВесНегабарит = 0;
			Объем = 0;
			
			Если ЗначениеМассива = Перечисления.СпособыРазгрузки.Лифт Тогда
				ИмяКолонки = Строка(ЗначениеМассива) + ?(ЛифтГрузовой,"Грузовой","");
			Иначе
				ИмяКолонки = Строка(ЗначениеМассива);
			КонецЕсли;
			
			МассивСтрок = ТоварыКРазгрузке.НайтиСтроки(Новый Структура(ИмяКолонки,Истина));
			
			Если МассивСтрок.Количество()> 0 Тогда 								
				
				Для каждого СтрокаТовара из МассивСтрок Цикл
					Если СтрокаТовара.Негабарит Тогда
						ВесНегабарит = ВесНегабарит + СтрокаТовара.Вес;
					Иначе
						Вес = Вес+СтрокаТовара.Вес;
					КонецЕсли;
					ТоварыКРазгрузке.Удалить(СтрокаТовара);
				КонецЦикла;
				
				//Если ВесНегабарит>0 Тогда
				//	СтруктураСтоимостиНегабарит = УправлениеЛогистикойСервер.ПолучитьСтоимостиРазгрузки(ВесНегабарит,Этаж,ТекущаяДата(),ГлобальнаяЗона,Истина,ЗначениеМассива); 
				//	СтоимостьУслугиНегабарит = СтруктураСтоимостиНегабарит.ЦенаДляКлиента;
				//	ВремяРазгрузки = ВремяРазгрузки + СтруктураСтоимостиНегабарит.ВремяРазгрузки
				//КонецЕсли;
				//
				//Если Вес>0 Тогда
				//	СтруктураСтоимости = УправлениеЛогистикойСервер.ПолучитьСтоимостиРазгрузки(Вес,Этаж,ТекущаяДата(),ГлобальнаяЗона,Ложь,ЗначениеМассива);
				//	СтоимостьУслуги = СтруктураСтоимости.ЦенаДляКлиента;
				//	ВремяРазгрузки = ВремяРазгрузки + СтруктураСтоимости.ВремяРазгрузки
				//КонецЕсли;
				
				Если Вес + ВесНегабарит > 0 Тогда
					СтруктураСтоимостиНегабарит = УправлениеЛогистикойСервер.ПолучитьСтоимостиРазгрузки(Вес + ВесНегабарит,Этаж,ТекущаяДата(),ГлобальнаяЗона,ВесНегабарит > 0, ЗначениеМассива); 
					СтоимостьУслуги = СтруктураСтоимостиНегабарит.ЦенаДляКлиента;
					ВремяРазгрузки = ВремяРазгрузки + СтруктураСтоимостиНегабарит.ВремяРазгрузки
				КонецЕсли;
				
				//Если ЗначениеМассива=Перечисления.СпособыРазгрузки.Разгрузка Тогда
				//	СтоимостьРазгрузки = СтоимостьРазгрузки + СтоимостьУслугиНегабарит + СтоимостьУслуги;
				//Иначе
				//	СтоимостьПодъемаНаЭтаж = СтоимостьПодъемаНаЭтаж + СтоимостьУслугиНегабарит + СтоимостьУслуги;
				//КонецЕсли;
				
				Если ЗначениеМассива=Перечисления.СпособыРазгрузки.Разгрузка Тогда
					СтоимостьРазгрузки = СтоимостьРазгрузки + СтоимостьУслуги;
				Иначе
					СтоимостьПодъемаНаЭтаж = СтоимостьПодъемаНаЭтаж + СтоимостьУслуги;
				КонецЕсли;
				
				КоличествоСпособовРазгрузки = КоличествоСпособовРазгрузки + 1;
			КонецЕсли;
			
		КонецЦикла;
		
		МинимальнаяСтоимостьДляКлиента = УправлениеЛогистикойСервер.МинимальнаяСтоимостьРазгрузкиДляКлиента();
		
		Если КоличествоСпособовРазгрузки>1 Тогда
			
			Если ВремяРазгрузки< 1 Тогда 
				СтоимостьПодъемаНаЭтаж = СтоимостьПодъемаНаЭтаж - МинимальнаяСтоимостьДляКлиента;
			КонецЕсли;
			
		КонецЕсли;
		
		//Исходящие данные
		
		СтруктураОтвета = Новый Структура;
		СтруктураОтвета.Вставить("unloadingcost",СтоимостьРазгрузки);
		СтруктураОтвета.Вставить("liftingcost",СтоимостьПодъемаНаЭтаж);
		СтруктураОтвета.Вставить("oversized",МассивНеГабарит);
		
		Возврат ПодготовитьHTTPОтвет(Ложь, СтруктураОтвета);
		
	Исключение
		Возврат ОшибкаОбменаСИнтернетМагазином("Ошибка получения стоимости разгрузки!");			
	КонецПопытки;
	
КонецФункции

