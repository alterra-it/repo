#Область HTTPСервисы

Функция ДанныеПоНомеруТелефонаGetInfoByTel(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.Заголовки.Вставить("Content-Type", "text/html");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Methods", "OPTIONS, GET"); 
	
	Партнер= Неопределено;
	
	Если Запрос.ПараметрыЗапроса.Количество() > 0 Тогда
		НомерТелефона= Запрос.ПараметрыЗапроса.Получить("tel");
		REF= Запрос.ПараметрыЗапроса.Получить("ref");
		
		Если Не ПустаяСтрока(REF) Тогда
			Партнер= АльтерраОбщегоНазначения.ПолучитьпартнераПоСсылке(REF);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Партнер) И ПустаяСтрока(НомерТелефона) Тогда
			Возврат ПодготовитьHTTPОтвет("Передан пустой номер телефона");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Партнер) Тогда
			ТЗ= АльтерраОбщегоНазначения.ПолучитьДанныеКлиентаПоТелефону(НомерТелефона);
		Иначе
			ТЗ= АльтерраОбщегоНазначения.ПолучитьДанныеПартнера(Партнер);
		КонецЕсли;
		
		Если ТЗ.Количество() > 0 Тогда
			//стрJSON= АльтерраОбщегоНазначения.СформироватьСтрокуJSON(ТЗ);
			мДанные= ОбщегоНазначения.ТаблицаЗначенийВМассив(ТЗ);
			
			Ответ= ПодготовитьHTTPОтвет("", мДанные);
		Иначе
			Ответ= ПодготовитьHTTPОтвет("Клиент не найден")
		КонецЕсли;
		
	Иначе
		Ответ= ПодготовитьHTTPОтвет("Переданы пустые параметры");
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Ответ;
КонецФункции

Функция ПолучитьТелефонПоПочтеGetTelByEmale(Запрос)
	Ответ = Новый HTTPСервисОтвет(200);
	УстановитьПривилегированныйРежим(Истина);
	
	Если Запрос.ПараметрыЗапроса.Количество() = 0 Тогда
		Ответ.УстановитьТеломСтроки("Переданы пустые параметры", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	
	Почта= Запрос.ПараметрыЗапроса.Получить("emale");
	Если ПустаяСтрока(Почта) Тогда
		Ответ.УстановитьТелоИзСтроки("Передан пустой адрес электронной почты", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	
	Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоПочте(Почта);
	Если Не ЗначениеЗаполнено(Партнер) Тогда
		Ответ.УстановитьТелоИзСтроки("Клиент не найден", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	
	ТЗ= АльтерраОбщегоНазначения.ПолучитьДанныеПартнера(Партнер);
	Если ТЗ.Количество() > 0 Тогда
		стрJSON= АльтерраОбщегоНазначения.СформироватьСтрокуJSON(ТЗ);
		
		Ответ.УстановитьТелоИзСтроки(стрJSON, КодировкаТекста.UTF8);
		Возврат Ответ;
	Иначе
		Ответ.УстановитьТелоИзСтроки("Не удалось получить информацию о клиенте", КодировкаТекста.UTF8);
		Возврат Ответ;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Ответ;
КонецФункции

