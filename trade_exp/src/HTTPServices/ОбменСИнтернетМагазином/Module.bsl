	ИначеЕсли Метод = "/PrintСheckArray" Тогда
		ОтветHTTP= PrintСheckArray(Запрос, ВходящиеДанные);
	ИначеЕсли Метод = "/GetUnloadingCost" Тогда
		ОтветHTTP= GetUnloadingCost(ВходящиеДанные);
	ИначеЕсли Метод = "/GetInfoLegalEntity" Тогда
		ОтветHTTP= GetInfoLegalEntity(ВходящиеДанные); 
	ИначеЕсли Метод = "/AddClientToAuthLog" Тогда 
		ОтветHTTP= AddClientToAuthLog(ВходящиеДанные); 
	ИначеЕсли Метод = "/getDeliveryPrice" Тогда
		ОтветHTTP= getDeliveryPrice(ВходящиеДанные); 
