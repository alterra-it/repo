	 |		ПО ВТ_ПартнерыСегментов.Партнер = ПартнерыКонтактнаяИнформация.Ссылка
	 |			И (ПартнерыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера))
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
