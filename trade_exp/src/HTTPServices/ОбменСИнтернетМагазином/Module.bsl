	КонецЕсли;
КонецФункции

Функция ОтдатьИнформациюПоСопутствующимТоварамgetSoputka(Запрос)
	
	Ответ = Новый HTTPСервисОтвет(200);
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СопутствующиеВидыНоменклатуры.Владелец КАК ВладелецСсылка,
	|	СопутствующиеВидыНоменклатуры.СопутствующийВидНоменклатуры КАК СопутствующийВидНоменклатуры,
	|	СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Номенклатура КАК Номенклатура,
	|	СортировкаСопутствующихВидовНоменклатуры.Сортировка КАК Сортировка
	|ИЗ
	|	Справочник.СопутствующиеВидыНоменклатуры.СопутствующаяНоменклатура КАК СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СопутствующиеВидыНоменклатуры КАК СопутствующиеВидыНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СортировкаСопутствующихВидовНоменклатуры КАК СортировкаСопутствующихВидовНоменклатуры
	|			ПО (СопутствующиеВидыНоменклатуры.Ссылка = СортировкаСопутствующихВидовНоменклатуры.СопутствующийВидНоменклатуры)
	|		ПО (СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Ссылка = СопутствующиеВидыНоменклатуры.Ссылка)
	|ГДЕ
	|	СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Ссылка.ПометкаУдаления = ЛОЖЬ
	|	И СопутствующиеВидыНоменклатуры.Владелец.ПометкаУдаления = ЛОЖЬ
	|	И СопутствующиеВидыНоменклатуры.СопутствующийВидНоменклатуры.ПометкаУдаления = ЛОЖЬ
	|	И СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Номенклатура.ПометкаУдаления = ЛОЖЬ";

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивRelated = Новый Массив();	
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		СтруктураRelated  = Новый Структура("UF_VLADELETS,UF_SOPUTSTVUYSHCHIY,UF_KODTOVARA,UF_SORT",); 
		СтруктураRelated.UF_VLADELETS = ВыборкаДетальныеЗаписи.ВладелецСсылка.УникальныйИдентификатор(); 
		СтруктураRelated.UF_SOPUTSTVUYSHCHIY = ВыборкаДетальныеЗаписи.СопутствующийВидНоменклатуры.УникальныйИдентификатор(); 
		СтруктураRelated.UF_KODTOVARA = ВыборкаДетальныеЗаписи.Номенклатура.УникальныйИдентификатор(); 
		СтруктураRelated.UF_SORT = ВыборкаДетальныеЗаписи.Сортировка;
		МассивRelated.Добавить(СтруктураRelated);
	КонецЦикла;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Комплектующие.Номенклатура КАК Номенклатура,
		|	Комплектующие.Комплектующее КАК Комплектующее
		|ИЗ
		|	РегистрСведений.Комплектующие КАК Комплектующие
		|ГДЕ
		|	НЕ Комплектующие.Номенклатура.ПометкаУдаления
		|	И НЕ Комплектующие.Комплектующее.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивAccessories = Новый Массив();	

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	    СтруктураAccessories  = Новый Структура("UF_KODTOVARA,UF_KODACCESSORIES",); 
		СтруктураAccessories.UF_KODTOVARA = ВыборкаДетальныеЗаписи.Номенклатура.УникальныйИдентификатор(); 
		СтруктураAccessories.UF_KODACCESSORIES = ВыборкаДетальныеЗаписи.Комплектующее.УникальныйИдентификатор(); 
		МассивAccessories.Добавить(СтруктураAccessories);
	КонецЦикла;
	
    СтруктураОтвета = Новый Структура("related,accessories",МассивRelated,МассивAccessories); 
	
	стрJSON = АльтерраОбщегоНазначения.СформироватьСтрокуJSON(СтруктураОтвета);
	
	Ответ.УстановитьТелоИзСтроки(стрJSON, КодировкаТекста.UTF8);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Ответ;
КонецФункции

Функция ПолучитьREFПартнераПоТелефону(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	
	Ответ = Новый HTTPСервисОтвет(200);
	Если Запрос.ПараметрыЗапроса.Количество() = 0 Тогда
		Ответ= ПодготовитьHTTPОтвет("Переданы пустые параметры в запросе");
		Возврат Ответ;
	КонецЕсли;
	
	НомерТелефона= Запрос.ПараметрыЗапроса.Получить("tel");
	Почта= Запрос.ПараметрыЗапроса.Получить("email");
	
	Партнер= Неопределено;
	
	//Ищем по телефону
	Если Не ПустаяСтрока(НомерТелефона) Тогда
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);
		
		Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоТелефону(НомерТелефона);
	КонецЕсли;
	
	
	Если Не ЗначениеЗаполнено(Партнер) Тогда
		//Ищем по почте
		Если Не ПустаяСтрока(Почта) Тогда
			Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоПочте(Почта);
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Партнер) Тогда
		Ответ= ПодготовитьHTTPОтвет("Не удалось найти партнера");
		Возврат Ответ;
	КонецЕсли;
	
	REF= XMLСтрока(Партнер);
	Ответ= ПодготовитьHTTPОтвет("", REF);
	
	Возврат Ответ;
КонецФункции

