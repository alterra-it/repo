
Функция MobileEventPOST(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеJSON= Запрос.ПолучитьТелоКакСтроку("UTF-8");
	
	Метод= ПолучитьМетод(Запрос);
	
	//Маршрутизация
	Если Метод = "/Authentication" Тогда
		ОтветHTTP= Authentication(ДанныеJSON);
	ИначеЕсли Метод = "/ExchangeListRKO" Тогда
		ОтветHTTP= ExchangeСписокОтгрузка(ДанныеJSON); 
	ИначеЕсли Метод = "/ExchangeListPKO" Тогда
		ОтветHTTP= ExchangeСписокПриемка(ДанныеJSON);
	ИначеЕсли Метод = "/ExchangeListPR" Тогда
		ОтветHTTP= ExchangeСписокПересчет(ДанныеJSON);
	ИначеЕсли Метод = "/ExchangeRKO" Тогда
		ОтветHTTP= ExchangeОтгрузка(ДанныеJSON); 
    ИначеЕсли Метод = "/ExchangeStatus" Тогда
		ОтветHTTP= ExchangeStatus(ДанныеJSON)
	ИначеЕсли Метод = "/ExchangePKO" Тогда
		ОтветHTTP= ExchangeПриемка(ДанныеJSON);
	ИначеЕсли Метод = "/ExchangePR" Тогда
		ОтветHTTP= ExchangeПересчет(ДанныеJSON);
	ИначеЕсли Метод = "/ChangeStatus" Тогда
		ОтветHTTP= СозданиеИзменениеОрдера(ДанныеJSON);  
	ИначеЕсли Метод = "/DeleteDocument" Тогда
		ОтветHTTP= УдалениеОрдера(ДанныеJSON); 
    ИначеЕсли Метод = "/ChangeString" Тогда
		ОтветHTTP= СозданиеИзменениеСтроки(ДанныеJSON);
	ИначеЕсли Метод = "/Exchange2" Тогда
		ОтветHTTP= СозданиеИзменениеПКО(ДанныеJSON);
	ИначеЕсли Метод = "/Exchange3" Тогда
		ОтветHTTP= СозданиеИзменениеПересчета(ДанныеJSON);
	ИначеЕсли Метод = "/GetPicture" Тогда
		ОтветHTTP= ПолучитьКартинку(ДанныеJSON);
	ИначеЕсли Метод = "/GetCell" Тогда
		ОтветHTTP= ПолучитьЯчейки(ДанныеJSON);
	ИначеЕсли Метод = "/EditCell" Тогда
		ОтветHTTP= ИзменитьЯчейку(ДанныеJSON);
	ИначеЕсли Метод = "/AddBarcode" Тогда
		ОтветHTTP= ДобавитьШтрихкод(ДанныеJSON); 
	ИначеЕсли Метод = "/AddBlocking" Тогда
		ОтветHTTP= СозданиеБлокировки(ДанныеJSON); 
    ИначеЕсли Метод = "/GetBarcodeGoods" Тогда
		ОтветHTTP= ПолучитьШтрихкодыНоменклатуры(ДанныеJSON);
	ИначеЕсли Метод = "/GetBalance" Тогда
		ОтветHTTP= ПолучитьОстатокПоТовару(ДанныеJSON);
	ИначеЕсли Метод = "/GetProductList" Тогда
		ОтветHTTP= ПолучитьСписокТоваров(ДанныеJSON); 
	ИначеЕсли Метод = "/GetCharacteristicsList" Тогда
		ОтветHTTP= ПолучитьСписокХарактеристик(ДанныеJSON);
	ИначеЕсли Метод = "/GetNKList" Тогда
		ОтветHTTP= ПолучитьСписокНекондиции(ДанныеJSON); 
	ИначеЕсли Метод = "/AddNK" Тогда
		ОтветHTTP= СоздатьОграниченноГодный(ДанныеJSON);
	ИначеЕсли Метод = "/GetUnidentifiedGoods" Тогда
		ОтветHTTP= ПолучитьНеопознанныйТовар(ДанныеJSON);
	ИначеЕсли Метод = "/AddAttachedFile" Тогда
		ОтветHTTP= ДобавитьПрисоединенныйФайл(ДанныеJSON);	
	ИначеЕсли Метод = "/GetProduct" Тогда
		ОтветHTTP= ПолучитьТоварПоШтрихкоду(ДанныеJSON); 
	ИначеЕсли Метод = "/GetProductMark" Тогда
		ОтветHTTP= ПолучитьТоварПоШтрихкодуМаркировки(ДанныеJSON); 
	ИначеЕсли Метод = "/UploadFile" Тогда
		ОтветHTTP= ЗагрузитьФайлВПапку(ДанныеJSON);
	ИначеЕсли Метод = "/ExchangeCheck" Тогда
		ОтветHTTP= ПроверкаОбмена(ДанныеJSON);
	ИначеЕсли Метод = "/UpdateApplication" Тогда
		ОтветHTTP= ПолучитьАктуальнуюВерсиюПриложения(ДанныеJSON);
	ИначеЕсли Метод = "/GetAdditionalCell" Тогда
		ОтветHTTP= ПолучитьДополнительнуюЯчейкуНоменклатуры(ДанныеJSON);
	ИначеЕсли Метод = "/GetMainCell" Тогда
		ОтветHTTP= ЕстьОсновнаяЯчейка(ДанныеJSON);
	ИначеЕсли Метод = "/GetProductFromCell" Тогда
		ОтветHTTP= ПолучитьНоменклатуруИзЯчейки(ДанныеJSON);
	ИначеЕсли Метод = "/CheckInTestResult" Тогда
		ОтветHTTP= ЗаписатьРезультатПроверкиАХ(ДанныеJSON);
    ИначеЕсли Метод = "/CheckMarking" Тогда
		ОтветHTTP= ПроверитьМаркировку(ДанныеJSON);	
	ИначеЕсли Метод = "/EndOfSession" Тогда
		ОтветHTTP= ЗавершениеСессии(ДанныеJSON);
	Иначе
		ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Передан неверный метод");
	КонецЕсли;
	
	Возврат ОтветHTTP; 
	
КонецФункции

Функция ПолучитьМетод(Запрос)
	
	ОтносительныйURL= Запрос.ОтносительныйURL;
	Возврат ОтносительныйURL; 
	
КонецФункции

#Область ОбработкаМаршрутов

Функция Authentication(ДанныеJSON)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		
		Если ТипЗнч(ВходящиеДанные) = Тип("Структура") Тогда
			
			Штрихкод = ВходящиеДанные.ШтрихкодСотрудника;
			ИдентификаторКлиента = Новый УникальныйИдентификатор(ВходящиеДанные.ИдентификаторКлиента);
			
			Если Лев(Штрихкод, 4) = "8888" Тогда
				
				Сотрудник = Справочники.Сотрудники.НайтиПоКоду(Штрихкод);
								
				Если Сотрудник.Пустая() Тогда
					
					Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "По данному штрихкоду не удалось найти сотрудника!"); 
					
					Возврат Ответ;   
					
				Иначе     
					Если Сотрудник.РабочиеУчастки.Количество()>0 Тогда  
						
						СтруктураОтвета = Новый Структура;
						
						МассивСекций = Сотрудник.РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток");
						ОграничениеОстатков = Ложь;
						Если АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков() Тогда
							Для каждого Секция Из МассивСекций Цикл
								Если Секция.СкрытьКоличествоПоУчету Тогда
									ОграничениеОстатков = Истина;
									Прервать;
								КонецЕсли;
							КонецЦикла;
						КонецЕсли;
						СтруктураОтвета.Вставить("ФИОСотрудника", СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(Сотрудник.Наименование," ")[1]);
						СтруктураОтвета.Вставить("Местоположение",СтрСоединить(МассивСекций, ","));
						СтруктураОтвета.Вставить("ОграничениеОстатков", ОграничениеОстатков);
						СтруктураОтвета.Вставить("Склад",XMLСтрока(Сотрудник.Склад));
												
						Запрос = Новый Запрос;
						Запрос.Текст = 
						"ВЫБРАТЬ
						|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СкладскиеЯчейки.Ссылка) КАК Ссылка,
						|	СкладскиеЯчейки.Наименование КАК Наименование,
						|	СкладскиеЯчейки.Штрихкод КАК Штрихкод
						|ИЗ
						|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
						|ГДЕ
						|	НЕ СкладскиеЯчейки.ПометкаУдаления
						|	И НЕ СкладскиеЯчейки.ЭтоГруппа
						|	И СкладскиеЯчейки.Родитель В ИЕРАРХИИ (&Родитель)";
						
						Запрос.УстановитьПараметр("Родитель", ПолучитьМассивГруппЯПХ(МассивСекций));
						
						РезультатЗапроса = Запрос.Выполнить();
						
						ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
						
						ЯПХ = Новый Массив();
	
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
							СтруктураСтрока = Новый Структура();
							СтруктураСтрока.Вставить("Ячейка",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Наименование)));
							СтруктураСтрока.Вставить("ЯчейкаУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Ссылка));
							СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Штрихкод))); 
						 													
							ЯПХ.Добавить(СтруктураСтрока);
						КонецЦикла;
						
						Альтерра_СкладСервер.ЗаписьВРегистрЖурналРаботыТСД(Перечисления.СобытияРаботыТСД.Вход,"Мобильное приложение",,Сотрудник,ИдентификаторКлиента);
						
						СтруктураОтвета.Вставить("ЯПХ", ЯПХ);
						
						Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
												
						Возврат Ответ;          
						
					Иначе
						
						Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "У сотрудника не настроены секции в карточке сотрудника!");
						
						Возврат Ответ;   
						
					КонецЕсли; 
					
				КонецЕсли;	
				
			Иначе
				
				Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Штрихкод сотрудника начинается на 8888!");    
				
				Возврат Ответ; 
				
			КонецЕсли;  
			
		Иначе
			
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получена пустая структура");   
			
			Возврат Ответ; 
			
		КонецЕсли;	
		
	Исключение
		
		Ошибка = ИнформацияОбОшибке();
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось аутентифицировать сотрудника!");
		ЗаписьЖурналаРегистрации("МобильноеПриложениеСклада", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось аутентифицировать сотрудника.  " + Ошибка.Описание); 
		
		Возврат Ответ;	
		
	КонецПопытки; 
			
КонецФункции

Функция ExchangeСписокОтгрузка(ДанныеJSON)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		
		Если ТипЗнч(ВходящиеДанные) = Тип("Структура") Тогда
			
			Штрихкод = ВходящиеДанные.ШтрихкодСотрудника;
			ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;
			ДатаНачала = Дата(СтрЗаменить(Лев(ВходящиеДанные.ДатаНачала,10),"-",""));
			ДатаОкончания = Дата(СтрЗаменить(Лев(ВходящиеДанные.ДатаОкончания,10),"-",""));
			ТипСписка = ВходящиеДанные.ТипСписка;
			
			Если Лев(Штрихкод, 4) = "8888" Тогда
				
				Сотрудник = Справочники.Сотрудники.НайтиПоКоду(Штрихкод);
								
				Если Сотрудник.Пустая() Тогда
					
					Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "По данному штрихкоду не удалось найти сотрудника!"); 
					
					Возврат Ответ;   
					
				Иначе     
					Если Сотрудник.РабочиеУчастки.Количество()>0 Тогда  
						
						//отгрузка
						СтруктураОтвета = Новый Структура;
						
						МассивСекций = Сотрудник.РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток");
						
						Если ТипСписка = "Отгрузка" Тогда 						
						Запрос = Новый Запрос;
						Запрос.Текст = 
						"ВЫБРАТЬ
						|	СостоянияОтгрузкиНакладных.РабочийУчасток КАК РабочийУчастокУИД,
						|	СостоянияОтгрузкиНакладных.Документ КАК Документ,
						|	СостоянияОтгрузкиНакладных.Заказ КАК Заказ,
						|	СостоянияОтгрузкиНакладных.РабочийУчасток КАК РабочийУчасток,
						|	ТИПЗНАЧЕНИЯ(СостоянияОтгрузкиНакладных.Документ) КАК ТипДокумента,
						|	СостоянияОтгрузкиНакладных.Документ.Дата КАК Дата,
						|	СостоянияОтгрузкиНакладных.Документ.Номер КАК Номер,
						|	СостоянияОтгрузкиНакладных.Получатель КАК Получатель,
						|	СостоянияОтгрузкиНакладных.ОжидаетсяОтбор КАК ОжидаетсяОтбор,
						|	СостоянияОтгрузкиНакладных.Набирается КАК Набирается,
						|	СостоянияОтгрузкиНакладных.Набран КАК Набран,
						|	СостоянияОтгрузкиНакладных.ЧастичноОтгружен КАК ЧастичноОтгружен,
						|	СостоянияОтгрузкиНакладных.Отгружен КАК Отгружен,
						|	СостоянияОтгрузкиНакладных.Ошибка КАК Ошибка,
						|	СостоянияОтгрузкиНакладных.ОтметкаКассы КАК ОтметкаКассы,
						|	ШтрихкодыПоСекциямДокумента.Штрихкод КАК Штрихкод
						|ПОМЕСТИТЬ Промежуточный
						|ИЗ
						|	РегистрСведений.СостоянияОтгрузкиНакладных КАК СостоянияОтгрузкиНакладных
						|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыПоСекциямДокумента КАК ШтрихкодыПоСекциямДокумента
						|		ПО (ШтрихкодыПоСекциямДокумента.Документ = СостоянияОтгрузкиНакладных.Документ)
						|		И (ШтрихкодыПоСекциямДокумента.Секция = СостоянияОтгрузкиНакладных.РабочийУчасток)
						|ГДЕ
						|	СостоянияОтгрузкиНакладных.РабочийУчасток В (&РабочийУчасток)
						|	И НЕ СостоянияОтгрузкиНакладных.Отгружен
						|	И СостоянияОтгрузкиНакладных.Документ.Дата МЕЖДУ &ДатаНачала и &ДатаОкончания
						|	И НЕ СостоянияОтгрузкиНакладных.Документ.Ссылка есть NULL
						|	И НЕ СостоянияОтгрузкиНакладных.Документ ССЫЛКА Документ.СборкаТоваров
						|;
						|
						|////////////////////////////////////////////////////////////////////////////////
						|ВЫБРАТЬ
						|	РаспоряженияИСостояния.Документ КАК Документ,
						|	ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку,
						|	МАКСИМУМ(ЗаказыКДоставке.Рейс) КАК Рейс
						|ПОМЕСТИТЬ ЗаказыНаДоставку
						|ИЗ
						|	Промежуточный КАК РаспоряженияИСостояния
						|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
						|		ПО РаспоряженияИСостояния.Заказ = ЗаказыКДоставке.ДокументПродажи
						|ГДЕ
						|   НЕ РаспоряженияИСостояния.Заказ = Неопределено
						|
						|СГРУППИРОВАТЬ ПО
						|	РаспоряженияИСостояния.Документ,
						|	ЗаказыКДоставке.ЗаказНаДоставку
						|
						|ОБЪЕДИНИТЬ
						|
						|ВЫБРАТЬ
						|	РаспоряженияИСостояния.Документ,
						|	ЗаказыКДоставке.ЗаказНаДоставку,
						|	МАКСИМУМ(ЗаказыКДоставке.Рейс)
						|ИЗ
						|	Промежуточный КАК РаспоряженияИСостояния
						|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
						|		ПО РаспоряженияИСостояния.Документ = ЗаказыКДоставке.ДокументПродажи
						|СГРУППИРОВАТЬ ПО
						|	РаспоряженияИСостояния.Документ,
						|	ЗаказыКДоставке.ЗаказНаДоставку
						|;
						|
						|////////////////////////////////////////////////////////////////////////////////
						|ВЫБРАТЬ
						|	РаспоряженияИСостояния.Документ КАК Документ,
						|	ДОБАВИТЬКДАТЕ(ЗаказыКДоставке.ЗаказНаДоставку.ПрибытиеНаОтгрузку, ЧАС,
						|		ЧАС(ЗаказыКДоставке.ЗаказНаДоставку.ВремяДоставкиС) - 2) КАК ДатаОтгрузки
						|ПОМЕСТИТЬ ДатаОтгрузки
						|ИЗ
						|	Промежуточный КАК РаспоряженияИСостояния
						|		ЛЕВОЕ СОЕДИНЕНИЕ ЗаказыНаДоставку КАК ЗаказыКДоставке
						|		ПО РаспоряженияИСостояния.Документ = ЗаказыКДоставке.Документ
						|;
						|
						|////////////////////////////////////////////////////////////////////////////////
						|ВЫБРАТЬ различные
						|	Промежуточный.РабочийУчастокУИД,
						|	Промежуточный.Документ,
						|	Промежуточный.Заказ,
						|	Промежуточный.РабочийУчасток,
						|	Промежуточный.ТипДокумента,
						|	ВЫБОР
						|		КОГДА Итоговый.ДатаОтгрузки ЕСТЬ NULL
						|			ТОГДА Итоговый.Документ.Дата
						|		ИНАЧЕ Итоговый.ДатаОтгрузки
						|	КОНЕЦ КАК Дата,
						|	Промежуточный.Номер,
						|	Промежуточный.Получатель,
						|	Промежуточный.ОжидаетсяОтбор,
						|	Промежуточный.Набирается,
						|	Промежуточный.Набран,
						|	Промежуточный.ЧастичноОтгружен,
						|	Промежуточный.Отгружен,
						|	Промежуточный.Ошибка,
						|	Промежуточный.ОтметкаКассы,
						|	Промежуточный.Штрихкод
						|ИЗ
						|	ДатаОтгрузки КАК Итоговый
						|		ПРАВОЕ СОЕДИНЕНИЕ Промежуточный КАК Промежуточный
						|		ПО Итоговый.Документ = Промежуточный.Документ";
						Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаНачала));
						Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));
						Запрос.УстановитьПараметр("РабочийУчасток", МассивСекций); 
						РезультатЗапроса = Запрос.Выполнить();
						
						ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
						
