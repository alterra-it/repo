		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкладскиеЯчейки.Ссылка КАК Ссылка,
		|	СкладскиеЯчейки.Наименование КАК Наименование,
		|	СкладскиеЯчейки.Штрихкод КАК Штрихкод
		|ИЗ
		|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
		|ГДЕ
		|	СкладскиеЯчейки.РабочийУчасток В (&Владелец)
		|	И НЕ СкладскиеЯчейки.ПометкаУдаления
		|	И СкладскиеЯчейки.Наименование <> """"
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование УБЫВ";
		
		Запрос.УстановитьПараметр("Владелец", МассивРабочихУчастков);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
			
			СтруктураСтрока = Новый Структура();
			СтруктураСтрока.Вставить("ЯчейкаУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Ссылка)); 
			СтруктураСтрока.Вставить("Ячейка",XMLСтрока(ВыборкаДетальныеЗаписи.Наименование));
			СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(ВыборкаДетальныеЗаписи.Штрихкод)); 
			
			Ячейки.Добавить(СтруктураСтрока);
		КонецЦикла;
	КонецЕсли;
	
	СтруктураОтвета.Вставить("Ячейки", Ячейки);

	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;  
КонецФункции

