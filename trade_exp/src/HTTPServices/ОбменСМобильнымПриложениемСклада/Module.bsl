Функция ПолучитьОстатокПоТовару(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;   
	ШтрихкодНоменклатуры = ВходящиеДанные.Штрихкод;
	Склад = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника).Склад;
	
	СтруктураОтвета = Новый Структура;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Номенклатура.ЕдиницаИзмерения КАК Упаковка,
	|	ТочкиПересчетаОбучение.Наименование КАК ТочкаПересчета
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТочкиПересчетаОбучение КАК ТочкиПересчетаОбучение
	|			ПО ВидыНоменклатуры.ТочкаПересчетаОбучение = ТочкиПересчетаОбучение.Ссылка
	|		ПО ШтрихкодыНоменклатуры.Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 
	|ВЫБРАТЬ
	|	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
	|	ВТ_Номенклатура.Характеристика КАК Характеристика,
	|	ВТ_Номенклатура.ТочкаПересчета КАК ТочкаПересчета,
	|	ВТ_Номенклатура.Упаковка КАК Упаковка,
	|	ЕстьNull(ТоварыНаСкладахОстатки.ВНаличииОстаток,0) КАК ОстатокНаСкладе,
	|	&Склад КАК Склад
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	ВТ_Номенклатура КАК ВТ_Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(, Склад = &Склад) КАК ТоварыНаСкладахОстатки
	|		ПО ВТ_Номенклатура.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|		И ВТ_Номенклатура.Характеристика = ТоварыНаСкладахОстатки.Характеристика
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Номенклатура КАК Номенклатура,
	|	ВТ.Характеристика КАК Характеристика,
	|	ВТ.ТочкаПересчета КАК ТочкаПересчета,
	|	ВТ.Упаковка КАК Упаковка,
	|	ВТ.ОстатокНаСкладе КАК ОстатокНаСкладе,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
	|ИЗ
	|	ВТ КАК ВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК
	|			РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВТ.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|		И ВТ.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад";
	
	Запрос.УстановитьПараметр("Штрихкод", ШтрихкодНоменклатуры);
	Запрос.УстановитьПараметр("Склад", Склад);

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		СтруктураОтвета.Вставить("НоменклатураГУИД", XMLСтрока(Выборка.Номенклатура));
		СтруктураОтвета.Вставить("Номенклатура", XMLСтрока(Строка(Выборка.Номенклатура)));
		СтруктураОтвета.Вставить("Характеристика", XMLСтрока(Строка(Выборка.Характеристика)));
		СтруктураОтвета.Вставить("ТочкаПересчета", XMLСтрока(Строка(Выборка.ТочкаПересчета)));
		СтруктураОтвета.Вставить("ЕдиницаИзмерения", XMLСтрока(Строка(Выборка.Упаковка)));
		СтруктураОтвета.Вставить("ОстатокНаСкладе", XMLСтрока(Выборка.ОстатокНаСкладе));
		СтруктураОтвета.Вставить("Ячейка", XMLСтрока(Строка(Выборка.Ячейка)));
		СтруктураОтвета.Вставить("ЯчейкаГУИД", XMLСтрока(Выборка.Ячейка));
		СтруктураОтвета.Вставить("СкладГУИД", XMLСтрока(Склад));
		СтруктураОтвета.Вставить("РабочийУчастокГУИД", XMLСтрока(Выборка.Ячейка.РабочийУчасток));		
	КонецЕсли;	
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
КонецФункции

