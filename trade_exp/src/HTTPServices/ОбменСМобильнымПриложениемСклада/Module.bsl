		СтруктураТовара.Вставить("СкладУИД", XMLСтрока(Склад));
		СтруктураТовара.Вставить("Ячейка", XMLСтрока(Строка(Выборка.Ячейка)));
		СтруктураТовара.Вставить("ЯчейкаУИД", XMLСтрока(Выборка.Ячейка));
		МассивТоваров.Добавить(СтруктураТовара);
	КонецЦикла;	
	
	СтруктураОтвета.Вставить("МассивТоваров",МассивТоваров);
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
