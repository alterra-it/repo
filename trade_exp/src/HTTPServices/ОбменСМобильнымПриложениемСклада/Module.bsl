Функция СозданиеБлокировки(ДанныеJSON)
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;   
	СтруктураОтвета = Новый Структура;
	
	ПричинаБлокировки = Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию(ВходящиеДанные.ПричинаБлокировки);
	Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Склад));
	Комментарий = ?(ВходящиеДанные.Свойство("Комментарий"),"Создан на ТСД: " + Строка(ВходящиеДанные.Комментарий),"Создан на ТСД");
	МассивТоваров = ВходящиеДанные.МассивТоваров;
	
	ДокументБлокировки = ?(ВходящиеДанные.Свойство("ИдентификаторДокумента"),
	Документы.БлокировкаДвиженияТоваров.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.ИдентификаторДокумента)).ПолучитьОбъект(),
	Документы.БлокировкаДвиженияТоваров.СоздатьДокумент());

	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("Дата", ТекущаяДата());
	ПараметрыЗаполнения.Вставить("Склад",Склад);
	ПараметрыЗаполнения.Вставить("Статус",Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано);
	ПараметрыЗаполнения.Вставить("ПричинаБлокировки",ПричинаБлокировки);
	ПараметрыЗаполнения.Вставить("Комментарий",Комментарий); 
	ПараметрыЗаполнения.Вставить("ДокументОснование",Неопределено);
	
	Товары = Новый ТаблицаЗначений;
	Товары.Колонки.Добавить("Номенклатура");
	Товары.Колонки.Добавить("Характеристика");
	Товары.Колонки.Добавить("Количество");
	Товары.Колонки.Добавить("КоличествоУпаковок");

	Для Каждого СтрокаЗначения Из МассивТоваров Цикл
		НоваяСтрока = Товары.Добавить();
		НоваяСтрока.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(
			Новый УникальныйИдентификатор(СтрокаЗначения.Номенклатура));
	    НоваяСтрока.Характеристика = Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию(
			СтрокаЗначения.Характеристика, Истина, , НоваяСтрока.Номенклатура);
		НоваяСтрока.Количество = Число(СтрокаЗначения.Количество);
		НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
	КонецЦикла;

	ПараметрыЗаполнения.Вставить("Товары",Товары);
	
	Альтерра_СкладСервер.СоздатьИзменитьБлокировкуДвиженияТоваров(ДокументБлокировки,ПараметрыЗаполнения,Истина);	
	
	СтруктураОтвета.Вставить("ИдентификаторДокумента",XMLСтрока(ДокументБлокировки.Ссылка));	
	СтруктураОтвета.Вставить("НомерДокумента",XMLСтрока(ДокументБлокировки.Номер));
	СтруктураОтвета.Вставить("НаименованиеСклада",XMLСтрока(Строка(ДокументБлокировки.Склад)));
	
	Ошибка = Ложь;	

	Если ДокументБлокировки.Ссылка.Пустая() Тогда
		Ошибка = Истина;	
	КонецЕсли;
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ошибка,,СтруктураОтвета);   
	
	Возврат Ответ;    
	
КонецФункции

Функция ПолучитьШтрихкодыНоменклатуры(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;   
	СтруктураОтвета = Новый Структура;
	
	МассивНоменклатуры = Новый Массив();
	
	Для каждого Строка из ВходящиеДанные.МассивТоваров Цикл
		Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.НоменклатураУИД)); 
		МассивНоменклатуры.Добавить(Номенклатура);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ШтрихкодыНоменклатуры.Номенклатура) КАК Номенклатура
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура В (&Номенклатура)";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ШтрихкодыНоменклатуры = Новый Массив();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СтруктураСтрока = Новый Структура();
		СтруктураСтрока.Вставить("НоменклатураУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Номенклатура));
		СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Штрихкод))); 
		
		ШтрихкодыНоменклатуры.Добавить(СтруктураСтрока);
	КонецЦикла;
	
	СтруктураОтвета.Вставить("ШтрихкодыНоменклатуры", ШтрихкодыНоменклатуры);
	
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
КонецФункции

