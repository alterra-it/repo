Функция ПроверитьМаркировку(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;   
	    
    Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Номенклатура));
    Штрихкод = ВходящиеДанные.Штрихкод;
	Если ВходящиеДанные.Свойство("ТипОперации") и ВходящиеДанные.ТипОперации = "Приемка" Тогда
		Операция = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.Приемка");
		ТекстДополнения = "
			|Товар будет добавлен без КМ!";

	Иначе
		Операция = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ОтгрузкаПродажа");
		ТекстДополнения = "
			|Отложите товар!";
	КонецЕсли;	
    
    МассивКодовМаркировкиЧЗ = Новый Массив;
	МассивКодовМаркировкиЧЗ.Добавить(Штрихкод);
    МассивКодовМаркировкиЧЗ = МаркировкаАльтерра.ПодготовитьКодыМаркировкиДляПроверки(МассивКодовМаркировкиЧЗ);  	
     
    СтруктураКодаМаркировки = МаркировкаАльтерра.ПолучитьСтруктуруКодаМаркировки(Штрихкод);
    ВидПродукции = МаркировкаАльтерра.ОпределитьВидПродукции(Номенклатура,СтруктураКодаМаркировки.ВидыПродукции);
    
        РезультатПроверки = МаркировкаАльтерра.ПроверкаЧЗ(СтруктураКодаМаркировки.МассивКодовМаркировкиЧЗ,ВидПродукции,Операция);
    СообщениеОбОшибках = ?(ЗначениеЗаполнено(РезультатПроверки.СообщениеОбОшибках),РезультатПроверки.СообщениеОбОшибках + ТекстДополнения,""); 
						
	СтруктураОтвета = Новый Структура;

	СтруктураОтвета.Вставить("Результат", XMLСтрока(РезультатПроверки.КодВалидный));		
    СтруктураОтвета.Вставить("ТекстСообщения", XMLСтрока(СообщениеОбОшибках));
    
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
КонецФункции

