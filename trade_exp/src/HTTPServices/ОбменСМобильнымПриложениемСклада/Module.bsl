		СтруктураОтвета.Вставить("ЕдиницаИзмерения", XMLСтрока(Строка(Выборка.ЕдиницаИзмерения)));
		СтруктураОтвета.Вставить("ЯчейкаУИД", XMLСтрока(Выборка.Ячейка));
		СтруктураОтвета.Вставить("Ячейка", XMLСтрока(Строка(Выборка.Ячейка)));
		СтруктураОтвета.Вставить("СкладУИД", XMLСтрока(Склад));
