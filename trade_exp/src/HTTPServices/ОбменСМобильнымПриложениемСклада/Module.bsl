	КонецЕсли;
	
	СтруктураОтвета = Новый Структура;
	
	ТекстОшибки="";
	
	Попытка
	    Справочники.Номенклатура.СоздатьОграниченноГодныйТовар(Номенклатура, Склад);
	Исключение
		ТекстОшибки = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("МобильноеПриложениеСклада", УровеньЖурналаРегистрации.Ошибка, , ,ТекстОшибки);
	КонецПопытки; 
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(?(ПустаяСтрока(ТекстОшибки),Ложь,Истина),ТекстОшибки,СтруктураОтвета);   
	
	Возврат Ответ;     
	
