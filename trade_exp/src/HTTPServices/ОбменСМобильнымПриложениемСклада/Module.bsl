Процедура СоздатьШК(Штрихкод,Номенклатура,Характеристика=Неопределено, СтруктураОтвета)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика,
	|	ШтрихкодыНоменклатуры.Упаковка,
	|	ШтрихкодыНоменклатуры.Номенклатура.Наименование КАК НоменклатураПредставление,
	|	ШтрихкодыНоменклатуры.Характеристика.Наименование КАК ХарактеристикаПредставление,
	|	ШтрихкодыНоменклатуры.Упаковка.Наименование КАК УпаковкаПредставление
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ОписаниеОшибки = НСтр("ru='Такой штрихкод уже назначен для номенклатуры %Номенклатура%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%Номенклатура%", """" + Выборка.НоменклатураПредставление + """"
		+ ?(ЗначениеЗаполнено(Выборка.Характеристика), " " + НСтр("ru='с характеристикой'") + " """ + Выборка.ХарактеристикаПредставление + """", "")
		+ ?(ЗначениеЗаполнено(Выборка.Упаковка), " " + НСтр("ru='в упаковке'") + " """ + Выборка.УпаковкаПредставление + """", ""));
		
		//Сообщение = Новый СообщениеПользователю;
		//Сообщение.Текст = ОписаниеОшибки;
		//Сообщение.Сообщить();     
		СтруктураОтвета.Ошибка = Истина;
		СтруктураОтвета.ТекстОшибки = ОписаниеОшибки;
		
	Иначе
		МенеджерЗаписи = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Штрихкод = Штрихкод;
		МенеджерЗаписи.Номенклатура = Номенклатура;
		МенеджерЗаписи.Характеристика = Характеристика;
		
		МенеджерЗаписи.Записать();
		
		//Сообщение = Новый СообщениеПользователю;
		//Сообщение.Текст = "Штрихкод записан!";
		//Сообщение.Сообщить();         
		СтруктураОтвета.Ошибка = Ложь;
		СтруктураОтвета.ТекстОшибки = "";
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПреобразоватьИзШестнадцатеричнойСистемыСчисленияВДесятичноеЧисло(Знач Значение)
	
	Значение = НРег(Значение);
	ДлинаСтроки = СтрДлина(Значение);
	
	Результат = 0;
	Для НомерСимвола = 1 По ДлинаСтроки Цикл
		Результат = Результат * 16 + СтрНайти("0123456789abcdef", Сред(Значение, НомерСимвола, 1)) - 1;
	КонецЦикла;
	
	Возврат Формат(Результат, "ЧГ=0");
	
КонецФункции

Функция СоздатьОрдерПоНакладной(СтруктураДокумента) Экспорт
	
	РасходныйОрдер = Документы.РасходныйОрдерНаТовары.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(РасходныйОрдер,СтруктураДокумента,"Накладная,Склад,РабочийУчасток,Статус");
	ТекущийПользователь = Пользователи.ТекущийПользователь();
		
	РасходныйОрдер.Дата = ТекущаяДата(); 
	РасходныйОрдер.ДатаОтгрузки = ТекущаяДата();
	
	Если Не ЗначениеЗаполнено(РасходныйОрдер.Статус) Тогда
		РасходныйОрдер.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен;
	КонецЕсли; 
	
	РасходныйОрдер.Ответственный = ТекущийПользователь;
	РасходныйОрдер.Приоритет = Справочники.Приоритеты.ПолучитьПриоритетПоУмолчанию(РасходныйОрдер.Приоритет);
	РасходныйОрдер.Получатель = Документы.РасходныйОрдерНаТовары.ПолучательДляЗаполнения(РасходныйОрдер.Накладная); 
	РасходныйОрдер.Контролер = ТекущийПользователь;
	РасходныйОрдер.Сотрудник = АльтерраОбщегоНазначения.ПолучитьСотрудника(ТекущийПользователь);
	РасходныйОрдер.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;
	РасходныйОрдер.СкладскаяОперация = ПолучитьСкладскуюОперацию(РасходныйОрдер.Накладная);
	
	ТЧТовары = Документы.РасходныйОрдерНаТовары.ПолучитьТоварыДляЗаполнения(РасходныйОрдер.Накладная,РасходныйОрдер.РабочийУчасток,РасходныйОрдер.Склад);
	РасходныйОрдер.ТоварыПоРаспоряжениям.Загрузить(ТЧТовары);				
	
	РасходныйОрдер.ОтгружаемыеТовары.Загрузить(ТЧТовары); 
	РасходныйОрдер.ОтгружаемыеТовары.Свернуть("Действие,Номенклатура,Характеристика,Назначение,Серия,Упаковка","Количество,КоличествоУпаковок");
		
	Попытка
		РасходныйОрдер.Записать();    
	Исключение 
		ЗаписьЖурналаРегистрации("МобильноеПриложениеСклада", УровеньЖурналаРегистрации.Ошибка, , ,ОписаниеОшибки());
	КонецПопытки;   
	
	Возврат РасходныйОрдер.Ссылка;	
	
КонецФункции

Функция ПолучитьСкладскуюОперацию(Накладная) Экспорт 
	
	СкладскаяОперация = Перечисления.СкладскиеОперации.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = СкладыСервер.ТекстЗапросаСкладскаяОперацияТипДокумента()+ " 
	|ВЫБРАТЬ
	|	СкладскаяОперацияТипДокумента.СкладскаяОперация КАК СкладскаяОперация
	|ИЗ
	|	СкладскаяОперацияТипДокумента КАК СкладскаяОперацияТипДокумента
	|ГДЕ
	|	СкладскаяОперацияТипДокумента.Тип = &Тип";
	
	Запрос.УстановитьПараметр("Тип",ТипЗнч(Накладная));
	
	Результат = Запрос.Выполнить().Выбрать();  
	Результат.Следующий();
	
	СкладскаяОперация = Результат.СкладскаяОперация;
	
	Возврат  СкладскаяОперация;
	
КонецФункции 

Функция ПолучитьХозяйственнуюОперацию(ХозяйственнаяОперацияИмя) Экспорт 
	
	ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПустаяСсылка();
	
	ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации[ХозяйственнаяОперацияИмя]; 
	
	Возврат  ХозяйственнаяОперация;
	
КонецФункции 

Функция ПолучитьИмяДокумента(ТипДокумента) 

	Если ТипДокумента = "Перемещение товаров" Тогда
		Возврат "ПеремещениеТоваров";
	ИначеЕсли ТипДокумента = "Реализация товаров и услуг" Тогда
		Возврат "РеализацияТоваровУслуг";
	ИначеЕсли ТипДокумента = "Чек ККМ" Тогда
		Возврат "ЧекККМ";
	ИначеЕсли ТипДокумента = "Сборка товаров" Тогда
		Возврат "СборкаТоваров";
	ИначеЕсли ТипДокумента = "Корректировка реализации" Тогда
		Возврат "КорректировкаРеализации";
	ИначеЕсли ТипДокумента = "Заказ поставщику" Тогда
		Возврат "ЗаказПоставщику";
	ИначеЕсли ТипДокумента = "Возврат товаров от клиента" Тогда
		Возврат "ВозвратТоваровОтКлиента";   
	ИначеЕсли ТипДокумента = "Чек ККМ на возврат" Тогда
		Возврат "ЧекККМВозврат";
	ИначеЕсли ТипДокумента = "Приобретение товаров и услуг" Тогда
		Возврат "ПриобретениеТоваровУслуг";
	ИначеЕсли ТипДокумента = "Акт о расхождениях после приемки" Тогда
		Возврат "АктОРасхожденияхПослеПриемки";
	Иначе
		Возврат "";
	КонецЕсли;
		
КонецФункции

Функция ПолучитьРасходныеОрдераПоНакладной(Документ,Секция)
	
	СтруктураВозврата = Новый Структура;

	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостоянияОтгрузкиНакладных.ОжидаетсяОтбор КАК ОжидаетсяОтбор,
	|	СостоянияОтгрузкиНакладных.Набирается КАК Набирается,
	|	СостоянияОтгрузкиНакладных.Набран КАК Набран,
	|	СостоянияОтгрузкиНакладных.Отгружен ИЛИ СостоянияОтгрузкиНакладных.ЧастичноОтгружен КАК Отгружен
	|ИЗ
	|	РегистрСведений.СостоянияОтгрузкиНакладных КАК СостоянияОтгрузкиНакладных
	|ГДЕ
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СостоянияОтгрузкиНакладных.РабочийУчасток) = &РабочийУчасток
	|   И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СостоянияОтгрузкиНакладных.Документ) = &Накладная";
	
	Запрос.УстановитьПараметр("Накладная", Документ);
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ОжидаетсяОтбор = Ложь;
	Набирается = Ложь; 
	Набран = Ложь; 
	Отгружен = Ложь;
		
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		ОжидаетсяОтбор = ВыборкаДетальныеЗаписи.ОжидаетсяОтбор;
		Набирается = ВыборкаДетальныеЗаписи.Набирается; 
		Набран = ВыборкаДетальныеЗаписи.Набран; 
		Отгружен = ВыборкаДетальныеЗаписи.Отгружен; 
	КонецЦикла;
	
	МассивОрдеров = Новый Массив();
	ПодготовленныеОрдера = Новый Массив();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
		|ГДЕ
		|	РасходныйОрдерНаТовары.Проведен = ИСТИНА
		|	И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходныйОрдерНаТовары.Накладная) = &Накладная
		|	И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходныйОрдерНаТовары.РабочийУчасток) = &РабочийУчасток";
	
	Запрос.УстановитьПараметр("Накладная", Документ);
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		 МассивОрдеров.Добавить(ВыборкаДетальныеЗаписи.Ссылка); 
		 Если ВыборкаДетальныеЗаписи.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен Тогда  
		 ПодготовленныеОрдера.Добавить(ВыборкаДетальныеЗаписи.Ссылка); 
		 КонецЕсли;
	КонецЦикла;
	
	СтруктураВозврата.Вставить("МассивОрдеров",МассивОрдеров); 
	СтруктураВозврата.Вставить("ПодготовленныеОрдера",ПодготовленныеОрдера);
	СтруктураВозврата.Вставить("ОжидаетсяОтбор",ОжидаетсяОтбор);
    СтруктураВозврата.Вставить("Набирается",Набирается);
    СтруктураВозврата.Вставить("Набран",Набран);
    СтруктураВозврата.Вставить("Отгружен",Отгружен);
 	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ПолучитьСтатусДокументаПоРегистру(Документ,Секция) 
	
	СтруктураОтвета = Новый Структура("Статус,Сотрудник,Ордер",);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ  
		|   СтатусыДокументовОбменТСД.ДокументОрдер КАК Ордер,
		|	СтатусыДокументовОбменТСД.Состояние КАК Статус,
		|	СтатусыДокументовОбменТСД.Сотрудник КАК Сотрудник
		|ИЗ
		|	РегистрСведений.СостоянияДокументовОбменМП КАК СтатусыДокументовОбменТСД
		|ГДЕ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СтатусыДокументовОбменТСД.ДокументНакладная) = &Документ
		|	И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СтатусыДокументовОбменТСД.РабочийУчасток) = &РабочийУчасток";
	
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	     ЗаполнитьЗначенияСвойств(СтруктураОтвета,ВыборкаДетальныеЗаписи);	
	КонецЦикла;

	Возврат СтруктураОтвета;
	
КонецФункции

Функция СоздатьРасходныйОрдерНаТовары(Документ,Секция,Сотрудник)   
	
	ОбъектДок = Документы.РасходныйОрдерНаТовары.СоздатьДокумент();      
	ОбъектДок.ОбменДанными.Загрузка = Истина;   
	ОбъектДок.Дата = ТекущаяДата();
	ОбъектДок.УстановитьНовыйНомер();  
	ОбъектДок.Проведен = Ложь;
	
	ОбъектДок.ДатаОтгрузки = ТекущаяДата(); 
	ОбъектДок.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен;		
	ОбъектДок.Ответственный = Пользователи.ТекущийПользователь(); 
	ОбъектДок.Сотрудник = Сотрудник; 
	ОбъектДок.Приоритет = Справочники.Приоритеты.ПолучитьПриоритетПоУмолчанию();
	ОбъектДок.Склад = Секция.Владелец;
	ОбъектДок.Получатель = Документы.РасходныйОрдерНаТовары.ПолучательДляЗаполнения(Документ); 
	ОбъектДок.РабочийУчасток = Секция;
	ОбъектДок.Накладная = Документ;
	ОбъектДок.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;
	ОбъектДок.СкладскаяОперация = ПолучитьСкладскуюОперацию(Документ);
	
	ТЧТовары = Документы.РасходныйОрдерНаТовары.ПолучитьТоварыДляЗаполнения(Документ,Секция,Секция.Владелец);
	ОбъектДок.ТоварыПоРаспоряжениям.Загрузить(ТЧТовары);				
	
	ОбъектДок.ОтгружаемыеТовары.Загрузить(ТЧТовары); 
	ОбъектДок.ОтгружаемыеТовары.Свернуть("Действие,Номенклатура,Характеристика,Назначение,Серия,Упаковка","Количество,КоличествоУпаковок");
	
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(ОбъектДок,Истина);
	
	Возврат ОбъектДок.Ссылка;
	
КонецФункции

Функция ПолучитьМассивГруппЯПХ(МассивСекций)
	
	МассивГрупп = Новый Массив();
		
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РабочиеУчастки.ГруппаСкладскихЯчеекХраненияПриОтгрузке КАК Группа
		|ИЗ
		|	Справочник.РабочиеУчастки КАК РабочиеУчастки
		|ГДЕ
		|	РабочиеУчастки.Ссылка В (&Ссылка)";
	
	Запрос.УстановитьПараметр("Ссылка", МассивСекций);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивГрупп.Добавить(ВыборкаДетальныеЗаписи.Группа);
	КонецЦикла;
	
	Возврат МассивГрупп;
		
КонецФункции

Функция ПоРаспоряжениюИСекцииЕстьОрдера(Распоряжение, Секция)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Проведен = ИСТИНА
		|	И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходныйОрдерНаТовары.Распоряжение) = &Распоряжение
		|	И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходныйОрдерНаТовары.РабочийУчасток) = &РабочийУчасток";
	
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();

КонецФункции

Процедура ОбработатьИмяФайла(Имя)	
	
	ЗапрещенныеСимволы = "/\[]:;|=?*<>" + Символ(34);
	Для Сч=1 По СтрДлина(Имя) Цикл
		Символ = Сред(Имя, Сч, 1);
		Если СтрНайти(ЗапрещенныеСимволы, Символ) Тогда 
			Имя = СтрЗаменить(Имя,Символ,"");
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры

