	ИначеЕсли НаименованиеСклада = "Склад (Бийск)" Тогда	
		ПапкаСклада = "СП Бийск\"; 
	Иначе 
		ПапкаСклада	= "";
	КонецЕсли; 
	
	ИмяФайла = "\\TG-Storage01\Склад\Общие\Отдел качества\" + ПапкаСклада + "Фото брака\" + ИмяФайла + ".png";

	СтруктураОтвета.Вставить("Путь",ИмяФайла);
	ОшибкаЗаписи = Ложь;
    ТекстОшибки = "";
	
    Попытка 
        Данные.Записать(ИмяФайла);  
    Исключение 
		Ошибка = ИнформацияОбОшибке();
		ПодробнаяОшибка = ПодробноеПредставлениеОшибки(Ошибка);
		ТекстОшибки = ПодробнаяОшибка;
		ОшибкаЗаписи = Истина;
    КонецПопытки;
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(ОшибкаЗаписи,ТекстОшибки,СтруктураОтвета);   
	
	Возврат Ответ;
	
