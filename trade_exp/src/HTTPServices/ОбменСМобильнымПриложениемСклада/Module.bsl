			НоваяСтрока.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения[Строка(Строка.Действие)];
		КонецЕсли;
	КонецЦикла;
	
	ТекстСообщения = "";
	Результат = ОбъектОбработки.ЗаписатьРезультатыПроверкиАХ(ТекстСообщения,"");

	СтруктураОтвета = Новый Структура;

