	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;   
