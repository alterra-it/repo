	СтруктураОтвета = Новый Структура;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ  
		|   СтатусыДокументовОбменТСД.ДокументОрдер КАК Ордер
		|	СтатусыДокументовОбменТСД.Сотрудник КАК Сотрудник
		|ИЗ
		|	РегистрСведений.СостоянияДокументовОбменМП КАК СтатусыДокументовОбменТСД
		|ГДЕ
		| СтатусыДокументовОбменТСД.Сотрудник = &Сотрудник
		| И СтатусыДокументовОбменТСД.ДокументОрдер.Дата >= &ТекущаяДата
		| И НЕ СтатусыДокументовОбменТСД.Обработано";
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
    Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДата()));
    
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		СтруктураОтвета.Вставить("ЕстьОшибка",XMLСтрока(Истина));
		
	Иначе
		
		СтруктураОтвета.Вставить("ЕстьОшибка",XMLСтрока(Ложь));
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
		
	Если Выборка.Следующий() Тогда
		
		СтруктураОтвета.Вставить("ОрдерГУИД", XMLСтрока(Выборка.Ордер));
				
	КонецЕсли;	
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
КонецФункции

