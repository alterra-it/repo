Функция ДобавитьПрисоединенныйФайл(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
	Данные = Base64Значение(ВходящиеДанные.Данные);
	
	ПриходныйОрдер = Документы.ПриходныйОрдерНаТовары.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.ОрдерУИД)); 
	ТипДокумента = ПолучитьИмяДокумента(ВходящиеДанные.Документ); 
	ТипСправочника = ТипДокумента+"ПрисоединенныеФайлы";
	Документ = Документы[ТипДокумента].ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.ДокументУИД));
	Склад = Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Склад));
	Если ВходящиеДанные.Свойство("НоменклатураУИД") Тогда
		Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.НоменклатураУИД)); 
	Иначе	
		Номенклатура = "";
	КонецЕсли;
	
	Если ВходящиеДанные.Свойство("Отправитель") Тогда
		Отправитель = ВходящиеДанные.Отправитель;
	ИначеЕсли ЗначениеЗаполнено(ПриходныйОрдер) Тогда
		Отправитель = ПриходныйОрдер.Отправитель;
	Иначе
		Отправитель = "";
	КонецЕсли;
	Команда = ВходящиеДанные.Команда;
		
	
	//ИмяФайла = ВходящиеДанные.ИмяФайла; 
	Расширение = ВходящиеДанные.Расширение;
	
	//Команда = ВходящиеДанные.ИмяКоманды;
	ПапкаОрдера = "";  
	
		
	Если Команда = "ДобавитьСканДокумента" Тогда
		ИмяФайла = "Scan_" + СтрЗаменить(Строка(Склад), " ", "_") + "_" + СтрЗаменить(Строка(Отправитель), " ", "_") + "_" + СтрЗаменить(Строка(ТекущаяДата()), " ", "_"); 
	ИначеЕсли Команда = "ДобавитьФотоТовара" Тогда
		Наименование = СтрРазделить(Строка(Номенклатура), " ");
		ЭлементМассива = 0;
		НоваяСтрока = "";
		Пока ЭлементМассива < 4 Цикл
			НоваяСтрока = НоваяСтрока + Наименование[ЭлементМассива] + "_";
			ЭлементМассива = ЭлементМассива + 1;
		КонецЦикла;
		ИмяФайла = СтрЗаменить(Строка(Склад), " ", "_") + "_" + СтрЗаменить(Строка(Отправитель), " ", "_") + "_"
		+ СтрЗаменить(НоваяСтрока, ",", "")
		+ СтрЗаменить(Строка(ТекущаяДата()), " ", "_");
	ИначеЕсли Команда = "ДобавитьФотоТС" Тогда
		ИмяФайла  = "ФотоТС_" + СтрЗаменить(Строка(Склад), " ", "_") + "_" + СтрЗаменить(Строка(Отправитель), " ", "_") + "_" +  СтрЗаменить(Строка(ТекущаяДата()), " ", "_");
	Иначе
		ИмяФайла = "Неопознанный файл "+ СтрЗаменить(Строка(ТекущаяДата()), " ", "_");
	КонецЕсли;
	
	ОбработатьИмяФайла(ИмяФайла); 
	
	Если ЗначениеЗаполнено(ПриходныйОрдер) Тогда
		
		ИмяПапки =  СтрЗаменить(СтрЗаменить(Строка(ПриходныйОрдер), ":", "_"), " ", "_");
		
		Если Не ЗначениеЗаполнено(Справочники[ТипСправочника].НайтиПоНаименованию(ИмяПапки, Истина)) Тогда
			ГруппаОрдера = Справочники[ТипСправочника].СоздатьГруппу();
			ГруппаОрдера.ВладелецФайла = Документ;
			ГруппаОрдера.Наименование = ИмяПапки;
			ГруппаОрдера.Записать();
		КонецЕсли;  
		
		ПапкаОрдера = Справочники[ТипСправочника].НайтиПоНаименованию(ИмяПапки, Истина);		
	КонецЕсли;
	
	ОшибкаЗаписи = Ложь;
	ТекстОшибки = "";
	
	Попытка 
		
		АдресВХранилище = ПоместитьВоВременноеХранилище(Данные);
		ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
		ПараметрыФайла.Автор = Сотрудник.Наименование;
		ПараметрыФайла.ВладелецФайлов = Документ;  
		
		Если ЗначениеЗаполнено(ПапкаОрдера) Тогда
			ПараметрыФайла.ГруппаФайлов = ПапкаОрдера;
		КонецЕсли;
		
		ПараметрыФайла.ИмяБезРасширения = ИмяФайла;
		ПараметрыФайла.РасширениеБезТочки = Расширение;
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресВХранилище);
		
	Исключение 
		
		Ошибка = ИнформацияОбОшибке();
		ТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
		ЗаписьЖурналаРегистрации("МобильноеПриложениеСклада", УровеньЖурналаРегистрации.Ошибка, , ,ТекстОшибки);
		ОшибкаЗаписи = Истина;
		
	КонецПопытки;
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(ОшибкаЗаписи,ТекстОшибки,Новый Структура);   
	
	Возврат Ответ;
	
КонецФункции

