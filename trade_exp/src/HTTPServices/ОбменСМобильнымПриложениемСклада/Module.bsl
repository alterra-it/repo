						//|			КОНЕЦ
						//|	КОНЕЦ КАК ОтметкаКассы 
						// временно убрала из-за зависаний
						|	Истина КАК ОтметкаКассы
						
						|ИЗ
						|	РегистрНакопления.ТоварыКПоступлению.ОстаткиИОбороты(&ДатаНачала, &ДатаОкончания, Авто, ДвиженияИГраницыПериода, ) КАК ТоварыКПоступлениюОстатки
						|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
						|		ПО (РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = ТоварыКПоступлениюОстатки.Номенклатура)
						|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ТоварыКПоступлениюОстатки.Склад)
						|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В (&РабочийУчасток))
						|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
						|ГДЕ
						|	НЕ(ТоварыКПоступлениюОстатки.ДокументПоступления ССЫЛКА Документ.ЗаказНаПеремещение
						|				ИЛИ ТоварыКПоступлениюОстатки.ДокументПоступления ССЫЛКА Документ.ЗаказНаСборку)
						|	И (ТоварыКПоступлениюОстатки.КОформлениюОрдеровКонечныйОстаток > 0
						|			ИЛИ ТоварыКПоступлениюОстатки.ПринимаетсяКонечныйОстаток > 0)
						|	И ТоварыКПоступлениюОстатки.ДокументПоступления.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
						|
						|СГРУППИРОВАТЬ ПО
						|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток,
						|	ТИПЗНАЧЕНИЯ(ТоварыКПоступлениюОстатки.ДокументПоступления),
						|	ТоварыКПоступлениюОстатки.ДокументПоступления,
						|	ТоварыКПоступлениюОстатки.ДокументПоступления.Дата,
						|	ТоварыКПоступлениюОстатки.ДокументПоступления.Номер,
						//|	ВЫБОР
						//|		КОГДА ТИПЗНАЧЕНИЯ(ТоварыКПоступлениюОстатки.ДокументПоступления) = ТИП(Документ.ВозвратТоваровОтКлиента)
						//|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКПоступлениюОстатки.ДокументПоступления) = ТИП(Документ.КорректировкаРеализации)
						//|			ТОГДА ВЫБОР
						//|					КОГДА ТоварыКПоступлениюОстатки.ДокументПоступления.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
						//|						ТОГДА ЛОЖЬ
						//|					ИНАЧЕ ИСТИНА
						//|				КОНЕЦ
						//|		ИНАЧЕ ВЫБОР
						//|				КОГДА ТИПЗНАЧЕНИЯ(ТоварыКПоступлениюОстатки.ДокументПоступления) = ТИП(Документ.ЧекККМВозврат)
						//|					ТОГДА ВЫБОР
						//|							КОГДА ТоварыКПоступлениюОстатки.ДокументПоступления.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
						//|								ТОГДА ИСТИНА
						//|							ИНАЧЕ ЛОЖЬ
						//|						КОНЕЦ
						//|				ИНАЧЕ ИСТИНА
						//|			КОНЕЦ
						//|	КОНЕЦ,
						|	ТоварыКПоступлениюОстатки.Отправитель,
						|	ТоварыКПоступлениюОстатки.ХозяйственнаяОперация"; 
						
						Запрос.УстановитьПараметр("РабочийУчасток", МассивСекций);
						Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаНачала));
						Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаОкончания));

						РезультатЗапроса = Запрос.Выполнить();
						
						ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
						
						ЖурналПриемки = Новый Массив();
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
							СтруктураСтрока = Новый Структура();
							СтруктураСтрока.Вставить("РабочийУчастокУИД",XMLСтрока(ВыборкаДетальныеЗаписи.РабочийУчасток)); 
							СтруктураСтрока.Вставить("РабочийУчасток",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.РабочийУчасток)));
							СтруктураСтрока.Вставить("Документ",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Документ)));
							СтруктураСтрока.Вставить("ДокументУИД",XMLСтрока(ВыборкаДетальныеЗаписи.ДокументУИД));
							СтруктураСтрока.Вставить("Номер",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Номер)));
							СтруктураСтрока.Вставить("Дата",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Дата)));
							СтруктураСтрока.Вставить("Отправитель",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Отправитель))); 
							СтруктураСтрока.Вставить("ОтправительУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Отправитель));
							СтруктураСтрока.Вставить("ХозяйственнаяОперация",XMLСтрока(ОбщегоНазначения.ИмяЗначенияПеречисления(ВыборкаДетальныеЗаписи.ХозяйственнаяОперация)));
						    СтруктураСтрока.Вставить("КПриемке",XMLСтрока(ВыборкаДетальныеЗаписи.КПриемке));
							СтруктураСтрока.Вставить("ПринятЧастично",XMLСтрока(ВыборкаДетальныеЗаписи.ПринятЧастично));
							СтруктураСтрока.Вставить("Принимается",XMLСтрока(ВыборкаДетальныеЗаписи.Принимается));
							СтруктураСтрока.Вставить("Перепоставка",XMLСтрока(ВыборкаДетальныеЗаписи.Перепоставка)); 
							СтруктураСтрока.Вставить("ОтметкаКассы",XMLСтрока(ВыборкаДетальныеЗаписи.ОтметкаКассы));
							
							ШестнадцатиричноеЧисло = СтрЗаменить(Строка(ВыборкаДетальныеЗаписи.ДокументУИД.УникальныйИдентификатор()),"-","");
							Штрихкод = ПреобразоватьИзШестнадцатеричнойСистемыСчисленияВДесятичноеЧисло(ШестнадцатиричноеЧисло);
							СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Штрихкод));

							ЖурналПриемки.Добавить(СтруктураСтрока);
						КонецЦикла;
						
						СтруктураОтвета.Вставить("ЖурналПриемки", ЖурналПриемки);
						
						Ордера = Новый Массив();
						
						Запрос = Новый Запрос;
						Запрос.Текст = 
						"ВЫБРАТЬ
						|	ПриходныйОрдерНаТовары.Ссылка КАК Ордер,
						|	ПриходныйОрдерНаТовары.Дата КАК Дата,
						|	ПриходныйОрдерНаТовары.Статус КАК Статус,
						|	ПриходныйОрдерНаТовары.Номер КАК Номер,
						|	ПриходныйОрдерНаТовары.Сотрудник КАК Сотрудник,
						|	ПриходныйОрдерНаТовары.Распоряжение КАК Документ,
						|	ПриходныйОрдерНаТовары.Отправитель КАК Партнер
						|ИЗ
						|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
						|ГДЕ
						|	ПриходныйОрдерНаТовары.Проведен
						|	И ПриходныйОрдерНаТовары.Дата МЕЖДУ &Дата И &Дата2
						|	И ПриходныйОрдерНаТовары.РабочийУчасток В(&РабочийУчасток)";
						
						Запрос.УстановитьПараметр("Дата", НачалоДня(ДатаНачала));
						Запрос.УстановитьПараметр("Дата2", КонецДня(ДатаОкончания));
						Запрос.УстановитьПараметр("РабочийУчасток", МассивСекций);  

						РезультатЗапроса = Запрос.Выполнить();
						
						ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
						
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
							СтруктураСтрока = Новый Структура();
							СтруктураСтрока.Вставить("ОрдерГУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Ордер)); 
							СтруктураСтрока.Вставить("ДокументУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Документ));
							СтруктураСтрока.Вставить("Дата",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Дата)));
							СтруктураСтрока.Вставить("Номер",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Номер)));
							СтруктураСтрока.Вставить("Статус",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Статус)));
							СтруктураСтрока.Вставить("Сотрудник",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Сотрудник))); 
							СтруктураСтрока.Вставить("Документ",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Документ)));
							СтруктураСтрока.Вставить("Партнер",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Партнер)));
							
							ШестнадцатиричноеЧисло = СтрЗаменить(Строка(ВыборкаДетальныеЗаписи.Документ.УникальныйИдентификатор()),"-","");
							Штрихкод = ПреобразоватьИзШестнадцатеричнойСистемыСчисленияВДесятичноеЧисло(ШестнадцатиричноеЧисло);
							СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Штрихкод));

							
							Ордера.Добавить(СтруктураСтрока);	
						КонецЦикла;
						
						СтруктураОтвета.Вставить("МассивОрдеров", Ордера);
						
						Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
						
						Возврат Ответ;          
						
					Иначе
						
						Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "У сотрудника не настроены секции в карточке сотрудника!");
						
						Возврат Ответ;   
						
					КонецЕсли; 
					
				КонецЕсли;	
				
			Иначе
				
				Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Штрихкод сотрудника начинается на 8888!");    
				
				Возврат Ответ; 
				
			КонецЕсли;  
			
		Иначе
			
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получена пустая структура");   
			
			Возврат Ответ; 
			
		КонецЕсли;	
		
	Исключение
		
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось аутентифицировать сотрудника!");
		ЗаписьЖурналаРегистрации("МобильноеПриложениеСклада", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось аутентифицировать сотрудника"); 
		
		Возврат Ответ;	
		
	КонецПопытки; 
			
КонецФункции

Функция ExchangeСписокПересчет(ДанныеJSON)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		
		Если ТипЗнч(ВходящиеДанные) = Тип("Структура") Тогда
			
			Штрихкод = ВходящиеДанные.ШтрихкодСотрудника;
			ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;
			ДатаНачала = Дата(СтрЗаменить(Лев(ВходящиеДанные.ДатаНачала,10),"-",""));
			ДатаОкончания = Дата(СтрЗаменить(Лев(ВходящиеДанные.ДатаОкончания,10),"-",""));

			Если Лев(Штрихкод, 4) = "8888" Тогда
				
				Сотрудник = Справочники.Сотрудники.НайтиПоКоду(Штрихкод);
								
				Если Сотрудник.Пустая() Тогда
					
					Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "По данному штрихкоду не удалось найти сотрудника!"); 
					
					Возврат Ответ;   
					
				Иначе     
					Если Сотрудник.РабочиеУчастки.Количество()>0 Тогда  
						
						//отгрузка
						СтруктураОтвета = Новый Структура;
						
						МассивСекций = Сотрудник.РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток");
						
						////пересчет
						Запрос = Новый Запрос;
						Запрос.Текст =" 
						|ВЫБРАТЬ  
						|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПересчетТоваров.Ссылка) КАК ДокументУИД,
						|	ТИПЗНАЧЕНИЯ(ПересчетТоваров.Ссылка) КАК Документ,
						|	ПересчетТоваров.Склад Как Склад, 
						|	ПересчетТоваров.ТипПересчета Как ТипПересчета,
						|	ПересчетТоваров.ТочкаПересчета Как ТочкаПересчета,
						|	ПересчетТоваров.Статус Как Статус,
						|	ПересчетТоваров.Ссылка Как Ссылка
						|ИЗ
						|	Документ.ПересчетТоваров КАК ПересчетТоваров
						|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары
						|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
						|			ПО ПересчетТоваровТовары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
						|				И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ПересчетТоваровТовары.Ссылка.Склад)
						|				И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
						|		ПО (ПересчетТоваровТовары.Ссылка = ПересчетТоваров.Ссылка)
						|ГДЕ
						|	 РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В (&РабочийУчасток)
						|	 И ПересчетТоваров.Дата Между &ДатаНачала и &ДатаОкончания 
						|    И НЕ ПересчетТоваров.ПометкаУдаления
						|    И ПересчетТоваров.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыПересчетовТоваров.Отменено)
						|    И ПересчетТоваров.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыПересчетовТоваров.Выполнено)";  
						
						Запрос.УстановитьПараметр("РабочийУчасток", МассивСекций);
						Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
						Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

						РезультатЗапроса = Запрос.Выполнить();
						
						ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
						
						ЖурналПересчета = Новый Массив();
						Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
							СтруктураСтрока = Новый Структура();
							СтруктураСтрока.Вставить("Документ",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Документ)));
							СтруктураСтрока.Вставить("ДокументУИД",XMLСтрока(ВыборкаДетальныеЗаписи.ДокументУИД));
							СтруктураСтрока.Вставить("Склад",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Склад))); 
						    СтруктураСтрока.Вставить("ТипПересчета",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.ТипПересчета)));
							СтруктураСтрока.Вставить("ТочкаПересчета",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.ТочкаПересчета)));
							СтруктураСтрока.Вставить("Статус",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Статус)));
							СтруктураСтрока.Вставить("Номер",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Ссылка.Номер)));
							СтруктураСтрока.Вставить("Дата",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Ссылка.Дата)));

							ШестнадцатиричноеЧисло = СтрЗаменить(Строка(ВыборкаДетальныеЗаписи.ДокументУИД.УникальныйИдентификатор()),"-","");
							Штрихкод = ПреобразоватьИзШестнадцатеричнойСистемыСчисленияВДесятичноеЧисло(ШестнадцатиричноеЧисло);
							СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Штрихкод));
							
							ЖурналПересчета.Добавить(СтруктураСтрока);
						КонецЦикла;
						
						СтруктураОтвета.Вставить("ЖурналПересчета", ЖурналПересчета);
						
						Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
						
						Возврат Ответ;          
						
					Иначе
						
						Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "У сотрудника не настроены секции в карточке сотрудника!");
						
						Возврат Ответ;   
						
					КонецЕсли; 
					
				КонецЕсли;	
				
			Иначе
				
				Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Штрихкод сотрудника начинается на 8888!");    
				
				Возврат Ответ; 
				
			КонецЕсли;  
			
		Иначе
			
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получена пустая структура");   
			
			Возврат Ответ; 
			
		КонецЕсли;	
		
	Исключение
		
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось аутентифицировать сотрудника!");
		ЗаписьЖурналаРегистрации("МобильноеПриложениеСклада", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось аутентифицировать сотрудника"); 
		
		Возврат Ответ;	
		
	КонецПопытки; 
			
КонецФункции

Функция ExchangeОтгрузка(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получена пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента; 
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
    Накладная = Новый УникальныйИдентификатор(ВходящиеДанные.Накладная);
	РабочийУчасток = Новый УникальныйИдентификатор(ВходящиеДанные.РабочийУчасток);
	
	СтруктураОтвета = Новый Структура;
	
	Запрос = Новый Запрос;
    
    Ордер = Неопределено;
    
	Если ВходящиеДанные.Свойство("Ордер") Тогда 
		
		Ордер = Документы.РасходныйОрдерНаТовары.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Ордер));
		
		Накладная = Ордер.Накладная;
		
		СтруктураОтвета.Вставить("Дата", XMLСтрока(Строка(Накладная.Дата)));
		СтруктураОтвета.Вставить("Номер", XMLСтрока(Строка(Накладная.Номер)));  
		СтруктураОтвета.Вставить("Документ", XMLСтрока(Строка(ТипЗнч(Накладная))));   
		СтруктураОтвета.Вставить("Получатель", XMLСтрока(Строка(Ордер.Получатель))); 
		СтруктураОтвета.Вставить("Статус", XMLСтрока(Строка(Ордер.Статус)));
		СтруктураОтвета.Вставить("НомерОрдера", XMLСтрока(Строка(Ордер.Номер))); 
		СтруктураОтвета.Вставить("ДатаОрдера", XMLСтрока(Строка(Ордер.Дата)));
		СтруктураОтвета.Вставить("РабочийУчастокУИД", XMLСтрока(Ордер.РабочийУчасток));
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура) КАК НоменклатураУИД,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Склад) КАК СкладУИД,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка) КАК ЯчейкаУИД,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.ЯчейкаПромежуточногоХранения КАК ЯПХ,
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Сотрудник КАК Сотрудник,
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура КАК Номенклатура,
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика КАК Характеристика,
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Назначение КАК Назначение,
		|   ВидыНоменклатуры.ПродукцияМаркируемаяДляГИСМ КАК Маркировка,
		|	ВЫБОР
		|		КОГДА РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.КОтгрузке)
		|				ИЛИ РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Отгружен)
		|			ТОГДА ЕСТЬNULL(ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток, 0) - ЕСТЬNULL(ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток, 0) - ЕСТЬNULL(ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток, 0) - ЕСТЬNULL(ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток, 0) + РасходныйОрдерНаТоварыОтгружаемыеТовары.КоличествоУпаковок
		|		ИНАЧЕ ВЫБОР
		|				КОГДА РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.КОтбору)
		|					ТОГДА ЕСТЬNULL(ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток, 0)
		|				ИНАЧЕ РасходныйОрдерНаТоварыОтгружаемыеТовары.КоличествоУпаковок
		|			КОНЕЦ
		|	КОНЕЦ КАК Количество,
		|	ВЫБОР
		|		КОГДА РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Подготовлен)
		|			ТОГДА 0
		|		ИНАЧЕ РасходныйОрдерНаТоварыОтгружаемыеТовары.КоличествоУпаковок + ЕСТЬNULL(СостоянияТоваровОбменМП.Количество, 0)
		|	КОНЕЦ КАК КоличествоФакт,
		|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0) КАК ОстатокНаСкладе
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ОтгружаемыеТовары КАК РасходныйОрдерНаТоварыОтгружаемыеТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО (РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияТоваровОбменМП КАК СостоянияТоваровОбменМП
		|		ПО (СостоянияТоваровОбменМП.Номенклатура = РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура)
		|			И (СостоянияТоваровОбменМП.Характеристика = РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика)
		|			И (СостоянияТоваровОбменМП.Назначение = РасходныйОрдерНаТоварыОтгружаемыеТовары.Назначение)
		|			И (СостоянияТоваровОбменМП.ДокументОрдер = РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка)
		|			И НЕ СостоянияТоваровОбменМП.Обработано
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузкеПоНакладным.Остатки КАК ТоварыКОтгрузкеПоНакладнымОстатки
		|		ПО (ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура = РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура)
		|			И (ТоварыКОтгрузкеПоНакладнымОстатки.Характеристика = РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика)
		|			И (ТоварыКОтгрузкеПоНакладнымОстатки.Назначение = РасходныйОрдерНаТоварыОтгружаемыеТовары.Назначение)
		|			И (ТоварыКОтгрузкеПоНакладнымОстатки.Накладная = РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Накладная)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ТоварыНаСкладахОстатки
		|		ПО РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
		|			И РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика = ТоварыНаСкладахОстатки.Характеристика
		|			И РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Склад = ТоварыНаСкладахОстатки.Склад
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
		|		ПО РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка
		|ГДЕ
		|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка = &Ордер
		|
		|УПОРЯДОЧИТЬ ПО
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Наименование";
		
		Запрос.УстановитьПараметр("Ордер", Ордер);
		
	Иначе
		
		Запрос.Текст = 
		
		"ВЫБРАТЬ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура) КАК НоменклатураУИД,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ТоварыКОтгрузкеПоНакладнымОстатки.Склад) КАК СкладУИД,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка) КАК ЯчейкаУИД,
		|	ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузкеПоНакладнымОстатки.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузкеПоНакладнымОстатки.Назначение КАК Назначение,
		|   ВидыНоменклатуры.ПродукцияМаркируемаяДляГИСМ КАК Маркировка,
		|   РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|   """" КАК ЯПХ,
		|   """" КАК Сотрудник,		
		|	ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток КАК Количество,
		|	ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток КАК КоличествоУпаковок,
		|   0 КАК КоличествоФакт,
		|   ЕстьNull(ТоварыНаСкладахОстатки.ВНаличииОстаток,0) КАК ОстатокНаСкладе
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузкеПоНакладным.Остатки КАК ТоварыКОтгрузкеПоНакладнымОстатки 
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО (РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ТоварыКОтгрузкеПоНакладнымОстатки.Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ТоварыНаСкладахОстатки
		|		ПО (ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
		|				И ТоварыКОтгрузкеПоНакладнымОстатки.Характеристика = ТоварыНаСкладахОстатки.Характеристика
		|				И ТоварыКОтгрузкеПоНакладнымОстатки.Склад = ТоварыНаСкладахОстатки.Склад)   
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
		|		ПО ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка
		|ГДЕ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ТоварыКОтгрузкеПоНакладнымОстатки.Накладная) = &Накладная
		|	И УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ТоварыКОтгрузкеПоНакладнымОстатки.РабочийУчасток) = &РабочийУчасток
		|	И ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Наименование";
		
		Запрос.УстановитьПараметр("Накладная", Накладная);	
		Запрос.УстановитьПараметр("РабочийУчасток", РабочийУчасток); 
		
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивОрдер = Новый Массив();
	МассивНоменклатура = Новый Массив(); 
	ЯПХ = "";
	Сотрудник = "";
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СтруктураСтрока = Новый Структура();
		СтруктураСтрока.Вставить("НоменклатураУИД",XMLСтрока(ВыборкаДетальныеЗаписи.НоменклатураУИД));
		СтруктураСтрока.Вставить("СкладУИД",XMLСтрока(ВыборкаДетальныеЗаписи.СкладУИД));
		СтруктураСтрока.Вставить("ЯчейкаУИД",XMLСтрока(ВыборкаДетальныеЗаписи.ЯчейкаУИД));
		СтруктураСтрока.Вставить("Номенклатура",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Номенклатура)));
		СтруктураСтрока.Вставить("ЕдиницаИзмерения",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Номенклатура.ЕдиницаИзмерения)));	
		СтруктураСтрока.Вставить("Характеристика",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Характеристика)));
		СтруктураСтрока.Вставить("Назначение",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Назначение))); 
		СтруктураСтрока.Вставить("Ячейка",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Ячейка)));
		СтруктураСтрока.Вставить("Количество",XMLСтрока(ВыборкаДетальныеЗаписи.Количество));
		СтруктураСтрока.Вставить("КоличествоФакт",XMLСтрока(ВыборкаДетальныеЗаписи.КоличествоФакт));
		СтруктураСтрока.Вставить("ОстатокНаСкладе",XMLСтрока(ВыборкаДетальныеЗаписи.ОстатокНаСкладе)); 
		СтруктураСтрока.Вставить("Маркировка",XMLСтрока(ВыборкаДетальныеЗаписи.Маркировка)); 
		МассивОрдер.Добавить(СтруктураСтрока);
		
		ЯПХ = ВыборкаДетальныеЗаписи.ЯПХ;
		Сотрудник = ВыборкаДетальныеЗаписи.Сотрудник;
		
		МассивНоменклатура.Добавить(ВыборкаДетальныеЗаписи.Номенклатура);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ШтрихкодыНоменклатуры.Номенклатура) КАК Номенклатура,
		|   ШтрихкодыНоменклатуры.Характеристика КАК Характеристика
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура В (&Номенклатура)";
	
	Запрос.УстановитьПараметр("Номенклатура", МассивНоменклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ШтрихкодыНоменклатуры = Новый Массив();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СтруктураСтрока = Новый Структура();
		СтруктураСтрока.Вставить("Характеристика",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Характеристика)));
		СтруктураСтрока.Вставить("НоменклатураУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Номенклатура));
		СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Штрихкод))); 
		
		ШтрихкодыНоменклатуры.Добавить(СтруктураСтрока);
	КонецЦикла;

    Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходныйОрдерНаТоварыШтрихкодыУпаковок.ШтрихкодУпаковки.ЗначениеШтрихкода КАК Штрихкод,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РасходныйОрдерНаТоварыШтрихкодыУпаковок.ШтрихкодУпаковки.Номенклатура) КАК Номенклатура,
		|	1 КАК Количество
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ШтрихкодыУпаковок КАК РасходныйОрдерНаТоварыШтрихкодыУпаковок
		|ГДЕ
		|	РасходныйОрдерНаТоварыШтрихкодыУпаковок.Ссылка = &Ордер
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	СостояниеМаркировкиОбменМП.ШтрихкодМаркировки.ЗначениеШтрихкода,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СостояниеМаркировкиОбменМП.ШтрихкодМаркировки.Номенклатура),
		|	1
		|ИЗ
		|	РегистрСведений.СостояниеМаркировкиОбменМП КАК СостояниеМаркировкиОбменМП
		|ГДЕ
		|	СостояниеМаркировкиОбменМП.ДокументОрдер = &Ордер
		|	И СостояниеМаркировкиОбменМП.Обработано = ЛОЖЬ
		|	И (СостояниеМаркировкиОбменМП.Действие = ЗНАЧЕНИЕ(Перечисление.ТипыЗаданий.Создание)
		|			ИЛИ СостояниеМаркировкиОбменМП.Действие = ЗНАЧЕНИЕ(Перечисление.ТипыЗаданий.ПустаяСсылка))
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	СостояниеМаркировкиОбменМП.ШтрихкодМаркировки.ЗначениеШтрихкода,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СостояниеМаркировкиОбменМП.ШтрихкодМаркировки.Номенклатура),
		|	-1
		|ИЗ
		|	РегистрСведений.СостояниеМаркировкиОбменМП КАК СостояниеМаркировкиОбменМП
		|ГДЕ
		|	СостояниеМаркировкиОбменМП.ДокументОрдер = &Ордер
		|	И СостояниеМаркировкиОбменМП.Обработано = ЛОЖЬ
		|	И СостояниеМаркировкиОбменМП.Действие = ЗНАЧЕНИЕ(Перечисление.ТипыЗаданий.Удаление)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Штрихкод КАК Штрихкод,
		|	ВТ.Номенклатура КАК Номенклатура,
		|	СУММА(ВТ.Количество) КАК Количество
		|ИЗ
		|	ВТ КАК ВТ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ.Штрихкод,
		|	ВТ.Номенклатура
		|
		|ИМЕЮЩИЕ
		|	СУММА(ВТ.Количество) > 0";
	
	Запрос.УстановитьПараметр("Ордер", Ордер);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ШтрихкодыУпаковокНакладной = Новый Массив();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СтруктураСтрока = Новый Структура();
		СтруктураСтрока.Вставить("НоменклатураУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Номенклатура));
		СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Штрихкод))); 
		
		ШтрихкодыУпаковокНакладной.Добавить(СтруктураСтрока);
	КонецЦикла;

	СтруктураОтвета.Вставить("ЯПХ", XMLСтрока(ЯПХ)); 
	СтруктураОтвета.Вставить("Сотрудник", XMLСтрока(Строка(Сотрудник)));
	СтруктураОтвета.Вставить("ШтрихкодыНоменклатуры", ШтрихкодыНоменклатуры);
	СтруктураОтвета.Вставить("ШтрихкодыУпаковокНакладной", ШтрихкодыУпаковокНакладной);
	СтруктураОтвета.Вставить("МассивОрдер", МассивОрдер); 
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
КонецФункции

Функция ExchangeStatus(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получена пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
    Накладная = Новый УникальныйИдентификатор(ВходящиеДанные.Накладная);
	РабочийУчасток = Новый УникальныйИдентификатор(ВходящиеДанные.РабочийУчасток);
	ТипЖурнала = ВходящиеДанные.ТипЖурнала; 
	
	ТекстСообщения = "";  
	ОрдерВРаботе = Неопределено;
    МассивВариантовОтвета = Новый Массив();
	МассивОрдеров = Новый Массив();		
	
	СтатусДокумента = ПолучитьСтатусДокументаПоРегистру(Накладная,РабочийУчасток); 
	
	Если  СтатусДокумента.Статус = Перечисления.СостоянияДокументовТСД.ВРаботе Тогда
		
		Если СтатусДокумента.Сотрудник = Сотрудник Тогда
			
			Если ТипЖурнала = "Приемка" Тогда
				ТекстСообщения =  "Ордер создан, вернуться к приемке?"; 
			Иначе
				ТекстСообщения =  "Документ у вас в работе. Вернуться к сборке?";  
			КонецЕсли;
			
			ОрдерВРаботе = СтатусДокумента.Ордер;
			МассивВариантовОтвета.Добавить("ПерейтиКОрдеру"); 
			МассивВариантовОтвета.Добавить("Отмена");
		Иначе
			ТекстСообщения =  "Документ уже в работе у сотрудника - " + Строка(СтатусДокумента.Сотрудник);
			МассивВариантовОтвета.Добавить("Отмена");
		КонецЕсли;      
		
	Иначе
		
		Если ТипЖурнала = "Приемка" Тогда
			
			Если ПоРаспоряжениюИСекцииЕстьОрдера(Накладная,РабочийУчасток) Тогда
				 ТекстСообщения="Найдены созданные ордера. Создать новый?"; 
			 Иначе
				 ТекстСообщения=""; 
			КонецЕсли;
			
		Иначе
			
		СтруктураОрдераПоДокументу = ПолучитьРасходныеОрдераПоНакладной(Накладная,РабочийУчасток); 
		
		ОрдераПоДокументу = СтруктураОрдераПоДокументу.МассивОрдеров;
		ПодготовленныеОрдераПоДокументу = СтруктураОрдераПоДокументу.ПодготовленныеОрдера;
		
		ОжидаетсяОтбор = СтруктураОрдераПоДокументу.ОжидаетсяОтбор;
		Набирается =  СтруктураОрдераПоДокументу.Набирается;
		Набран =  СтруктураОрдераПоДокументу.Набран;
		Отгружен =  СтруктураОрдераПоДокументу.Отгружен;
		
		ОрдерОдин = Ложь;
		Если ОрдераПоДокументу.Количество()=1 Тогда
			ОрдерОдин = Истина;
			ОрдерВРаботе = ОрдераПоДокументу[0];  
		КонецЕсли;
		
		Если ОжидаетсяОтбор Тогда
			
			Если Набирается ИЛИ Набран ИЛИ Отгружен Тогда
				ТекстСообщения = "Документ не собран полностью. Можно посмотреть товары или перейти к ордерам.";  
				МассивВариантовОтвета.Добавить("ПерейтиКОрдерам");  
			Иначе
				ТекстСообщения = "Документ не собирался. Посмотреть товары?";
			КонецЕсли;
			
			Если ПодготовленныеОрдераПоДокументу.Количество()=0 Тогда
				
				МассивВариантовОтвета.Добавить("НачатьСборку"); 
				
			ИначеЕсли ПодготовленныеОрдераПоДокументу.Количество()=1 Тогда
				ТекстСообщения = ТекстСообщения + "(есть ордер в статусе Подготовлено)";
				ОрдерВРаботе = ПодготовленныеОрдераПоДокументу[0];
				МассивВариантовОтвета.Добавить("ПерейтиКОрдеру"); 
				
			КонецЕсли;
			
			МассивВариантовОтвета.Добавить("Отмена");
			
		ИначеЕсли Набирается Тогда
			
			Если Отгружен Тогда
				ТекстСообщения = "Товар частично отгружен, но не собран полностью.";
			ИначеЕсли Набран Тогда
				ТекстСообщения = "Товар частично собран, но не полностью.";   
			Иначе
				ТекстСообщения = "Товар набирается.";   
			КонецЕсли;
			
			Если ОрдерОдин Тогда  
				Если ОрдерВРаботе.Сотрудник = Сотрудник Тогда 
					ТекстСообщения = "Документ у вас в работе. Вернуться к сборке?"; 
					МассивВариантовОтвета.Добавить("ПерейтиКОрдеру"); 
			        МассивВариантовОтвета.Добавить("Отмена");
				Иначе    
					ТекстСообщения =  "Документ уже в работе у сотрудника - " + Строка(ОрдерВРаботе.Сотрудник);
					МассивВариантовОтвета.Добавить("Отмена");
				КонецЕсли;
			Иначе 
				ТекстСообщения = "По документу несколько ордеров перейдите в список и выберите.";
				МассивВариантовОтвета.Добавить("ПерейтиКОрдерам"); 
				МассивВариантовОтвета.Добавить("Отмена");
			КонецЕсли;
			
		ИначеЕсли Набран Тогда
			
			Если Отгружен Тогда
								
				Если ОрдерОдин Тогда 
					ТекстСообщения = "Товар частично отгружен и собран. Статус документа 'К отгрузке'. Ячейка промежуточного хранения - " + Строка(ОрдерВРаботе.ЯчейкаПромежуточногоХранения);   
					МассивВариантовОтвета.Добавить("ПерейтиКОрдеру");
				Иначе  
					ТекстСообщения = "Товар частично отгружен и собран. Перейдите в список расходных ордеров для продолжения работы.";   
					МассивВариантовОтвета.Добавить("ПерейтиКОрдерам");
				КонецЕсли;    
				
				МассивВариантовОтвета.Добавить("Отмена"); 
				
			Иначе  
						
				Если ОрдерОдин Тогда 
					ТекстСообщения = "Товар собран. Статус документа 'К отгрузке'. Ячейка промежуточного хранения - " + Строка(ОрдерВРаботе.ЯчейкаПромежуточногоХранения);   
					МассивВариантовОтвета.Добавить("ПерейтиКОрдеру");
				Иначе  
					ТекстСообщения = "Товар собран. Перейдите в список расходных ордеров для продолжения работы.";   
					МассивВариантовОтвета.Добавить("ПерейтиКОрдерам");
				КонецЕсли;    
				
				МассивВариантовОтвета.Добавить("Отмена");   
				
			КонецЕсли;  
			
		ИначеЕсли Отгружен Тогда 
			
			ТекстСообщения = "Документ отгружен.";
			Если ОрдерОдин Тогда
				МассивВариантовОтвета.Добавить("ПерейтиКОрдеру");
			Иначе
				МассивВариантовОтвета.Добавить("ПерейтиКОрдерам"); 
			КонецЕсли;    
			
			МассивВариантовОтвета.Добавить("Отмена"); 
			
		КонецЕсли;  
	КонецЕсли;	
	КонецЕсли;

	СтруктураОтвета = Новый Структура;
			
	СтруктураОтвета.Вставить("ТекстСообщения", XMLСтрока(ТекстСообщения));
	СтруктураОтвета.Вставить("ОрдерВРаботе", XMLСтрока(ОрдерВРаботе));
	СтруктураОтвета.Вставить("НомерОрдера", XMLСтрока(?(НЕ ОрдерВРаботе = Неопределено,ОрдерВРаботе.Номер,"")));
	СтруктураОтвета.Вставить("МассивВариантовОтвета", МассивВариантовОтвета);
	СтруктураОтвета.Вставить("СтатусОрдера", XMLСтрока(?(НЕ ОрдерВРаботе = Неопределено,ОрдерВРаботе.Статус,"")));   
	СтруктураОтвета.Вставить("ЯПХ", XMLСтрока(?(НЕ ОрдерВРаботе = Неопределено И ТипЖурнала = "Отгрузка",Строка(ОрдерВРаботе.ЯчейкаПромежуточногоХранения),"")));   
	СтруктураОтвета.Вставить("Сотрудник", XMLСтрока(?(НЕ ОрдерВРаботе = Неопределено,Строка(ОрдерВРаботе.Сотрудник),""))); 
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
КонецФункции

Функция ExchangeПриемка(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;
    Накладная = Новый УникальныйИдентификатор(ВходящиеДанные.Накладная);
	РабочийУчасток = Новый УникальныйИдентификатор(ВходящиеДанные.РабочийУчасток);
	
	СтруктураОтвета = Новый Структура;
	
	Запрос = Новый Запрос;
	
	Если ВходящиеДанные.Свойство("Ордер") Тогда 
		
		Ордер = Документы.ПриходныйОрдерНаТовары.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Ордер));
		
		Документ = Ордер.Распоряжение;
		
		СтруктураОтвета.Вставить("ДатаВХ", XMLСтрока(Строка(Ордер.ДатаВходящегоДокумента)));
		СтруктураОтвета.Вставить("НомерВХ", XMLСтрока(Строка(Ордер.НомерВходящегоДокумента))); 
		СтруктураОтвета.Вставить("Дата", XMLСтрока(Строка(Документ.Дата)));
		СтруктураОтвета.Вставить("Номер", XMLСтрока(Строка(Документ.Номер))); 
		СтруктураОтвета.Вставить("ДокументУИД", XMLСтрока(Документ));
	    СтруктураОтвета.Вставить("Документ", XMLСтрока(Строка(ТипЗнч(Документ))));   
		СтруктураОтвета.Вставить("Отправитель", XMLСтрока(Строка(Ордер.Отправитель))); 
		СтруктураОтвета.Вставить("ОтправительУИД", XMLСтрока(Ордер.Отправитель)); 
		СтруктураОтвета.Вставить("Статус", XMLСтрока(Строка(Ордер.Статус)));
		СтруктураОтвета.Вставить("НомерОрдера", XMLСтрока(Строка(Ордер.Номер))); 
		СтруктураОтвета.Вставить("ДатаОрдера", XMLСтрока(Строка(Ордер.Дата)));
		СтруктураОтвета.Вставить("РабочийУчастокУИД", XMLСтрока(Ордер.РабочийУчасток));
	    СтруктураОтвета.Вставить("Сотрудник", XMLСтрока(Ордер.Сотрудник));
		СтруктураОтвета.Вставить("Комментарий", XMLСтрока(Ордер.Комментарий));
		
		Запрос.Текст = 
		
		"ВЫБРАТЬ
		|	ПриходныйОрдерНаТоварыТовары.Ссылка.Склад КАК Склад,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	ПриходныйОрдерНаТоварыТовары.Номенклатура КАК Номенклатура,
		|	ПриходныйОрдерНаТоварыТовары.Характеристика КАК Характеристика,
		|	ПриходныйОрдерНаТоварыТовары.Назначение КАК Назначение,
		|	ВидыНоменклатуры.ПродукцияМаркируемаяДляГИСМ КАК Маркировка,
		|ВЫБОР
		|	КОГДА ПриходныйОрдерНаТоварыТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПриходныхОрдеров.Принят)
		|		ТОГДА ЕСТЬNULL(ТоварыКПоступлению.КОформлениюОрдеровОстаток, 0) + ПриходныйОрдерНаТоварыТовары.КоличествоУпаковок
		|	ИНАЧЕ ЕСТЬNULL(ТоварыКПоступлению.КОформлениюОрдеровОстаток, 0)
		|КОНЕЦ КАК КоличествоПлан,
		|	ПриходныйОрдерНаТоварыТовары.КоличествоУпаковок + ЕСТЬNULL(СостоянияТоваровОбменМП.Количество, 0) КАК КоличествоФакт
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКПоступлению.Остатки КАК ТоварыКПоступлению
		|		ПО (ТоварыКПоступлению.Номенклатура = ПриходныйОрдерНаТоварыТовары.Номенклатура)
		|			И (ТоварыКПоступлению.Склад = ПриходныйОрдерНаТоварыТовары.Ссылка.Склад)
		|			И (ТоварыКПоступлению.ДокументПоступления = &Документ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО (РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = ПриходныйОрдерНаТоварыТовары.Номенклатура)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ПриходныйОрдерНаТоварыТовары.Ссылка.Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
		|		ПО ПриходныйОрдерНаТоварыТовары.Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияТоваровОбменМП КАК СостоянияТоваровОбменМП
		|		ПО (СостоянияТоваровОбменМП.Номенклатура = ПриходныйОрдерНаТоварыТовары.Номенклатура)
		|			И (СостоянияТоваровОбменМП.Характеристика = ПриходныйОрдерНаТоварыТовары.Характеристика)
		|			И (СостоянияТоваровОбменМП.Назначение = ПриходныйОрдерНаТоварыТовары.Назначение)
