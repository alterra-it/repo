	СтруктураОтвета = Новый Структура;
	
	НаименованиеСклада = Сотрудник.Склад.Наименование;
	
	Если НаименованиеСклада = "Центральный склад" Тогда
		ПапкаСклада = "СП ЦБ\";  		
	ИначеЕсли НаименованиеСклада = "Склад (Барнаул)" Тогда
		ПапкаСклада = "СП Барнаул\";
	ИначеЕсли НаименованиеСклада = "Склад (Выбор)" Тогда
