	СтруктураОтвета.Вставить("ШтрихкодыУпаковокНакладной", ШтрихкодыУпаковокНакладной);

	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;  
КонецФункции

Функция ExchangeПересчет(ДанныеJSON)
	
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;
    Накладная = Новый УникальныйИдентификатор(ВходящиеДанные.Накладная);
	
	СтруктураОтвета = Новый Структура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПересчетТоваровТовары.Номенклатура) КАК НоменклатураУИД,
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПересчетТоваровТовары.Ссылка.Склад) КАК СкладУИД,
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка) КАК ЯчейкаУИД,
	|	ПересчетТоваровТовары.Номенклатура КАК Номенклатура,
	|	ПересчетТоваровТовары.Характеристика КАК Характеристика,
	|	ПересчетТоваровТовары.Назначение КАК Назначение,
	|   РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
	|	ПересчетТоваровТовары.Количество КАК Количество,
	|	ПересчетТоваровТовары.КоличествоФакт КАК КоличествоФакт
	|ИЗ
	|	Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары 
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО (РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = ПересчетТоваровТовары.Номенклатура)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ПересчетТоваровТовары.Ссылка.Склад)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|ГДЕ
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПересчетТоваровТовары.Ссылка) = &Накладная";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивНоменклатура = Новый Массив();  
	
	РКО = Новый Массив();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СтруктураСтрока = Новый Структура();
		СтруктураСтрока.Вставить("Номенклатура",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Номенклатура)));
		СтруктураСтрока.Вставить("НоменклатураУИД",XMLСтрока(ВыборкаДетальныеЗаписи.НоменклатураУИД));
		СтруктураСтрока.Вставить("СкладУИД",XMLСтрока(ВыборкаДетальныеЗаписи.СкладУИД)); 
		СтруктураСтрока.Вставить("ЯчейкаУИД",XMLСтрока(ВыборкаДетальныеЗаписи.ЯчейкаУИД)); 
		СтруктураСтрока.Вставить("ЕдиницаИзмерения",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Номенклатура.ЕдиницаИзмерения)));	
		СтруктураСтрока.Вставить("Характеристика",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Характеристика)));
		СтруктураСтрока.Вставить("Назначение",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Назначение))); 
		СтруктураСтрока.Вставить("Ячейка",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Ячейка)));
		СтруктураСтрока.Вставить("Количество",XMLСтрока(ВыборкаДетальныеЗаписи.Количество));
		
		МассивНоменклатура.Добавить(ВыборкаДетальныеЗаписи.Номенклатура);    
		
		РКО.Добавить(СтруктураСтрока);
	КонецЦикла;
	
	СтруктураОтвета.Вставить("Пересчет", РКО);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ШтрихкодыНоменклатуры.Номенклатура) КАК Номенклатура
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Номенклатура В (&Номенклатура)";
	
	Запрос.УстановитьПараметр("Номенклатура", МассивНоменклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ШтрихкодыНоменклатуры = Новый Массив();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		
		СтруктураСтрока = Новый Структура();
		СтруктураСтрока.Вставить("НоменклатураУИД",XMLСтрока(ВыборкаДетальныеЗаписи.Номенклатура));
		СтруктураСтрока.Вставить("Штрихкод",XMLСтрока(Строка(ВыборкаДетальныеЗаписи.Штрихкод))); 
		
		ШтрихкодыНоменклатуры.Добавить(СтруктураСтрока);
	КонецЦикла;
	
	СтруктураОтвета.Вставить("ШтрихкодыНоменклатуры", ШтрихкодыНоменклатуры);

	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;  
КонецФункции

Функция СозданиеИзменениеОрдера(ДанныеJSON)
    Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;

	СтруктураОтвета = Новый Структура;

	ТипЖурнала = ВходящиеДанные.ТипЖурнала;

	ИдентификаторКлиента = Новый УникальныйИдентификатор(ВходящиеДанные.ИдентификаторКлиента); 
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
		
	Статус = ВходящиеДанные.Статус; 
	Действие = ВходящиеДанные.Действие;
	
	ТипОрдера = ?(ТипЖурнала="Отгрузка","РасходныйОрдерНаТовары","ПриходныйОрдерНаТовары");
	
	Ордер = Неопределено;
	Если ВходящиеДанные.Свойство("Ордер") Тогда
		Ордер = Документы[ТипОрдера].ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Ордер));
		Если Ордер.Пустая() Тогда
			ИмяДокумента = ПолучитьИмяДокумента(ВходящиеДанные.ТипДокумента);
			Накладная = Документы[ИмяДокумента].ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Накладная));
			РабочийУчасток = Справочники.РабочиеУчастки.ПолучитьСсылку(
				Новый УникальныйИдентификатор(ВходящиеДанные.РабочийУчасток));
		Иначе
			Накладная = ?(ТипОрдера = "РасходныйОрдерНаТовары",Ордер.Накладная,Ордер.Распоряжение);
			РабочийУчасток = Ордер.РабочийУчасток;
		КонецЕсли;
	КонецЕсли;
	
	//Проверяем в работе ли документ
	СтатусДокумента = ПолучитьСтатусДокументаПоРегистру(Накладная.УникальныйИдентификатор(),РабочийУчасток.УникальныйИдентификатор()); 
	
	Если СтатусДокумента.Статус = Перечисления.СостоянияДокументовТСД.ВРаботе Тогда

		Если Не СтатусДокумента.Сотрудник = Сотрудник Тогда
			СтруктураОтвета.Вставить("ТекстОшибки", XMLСтрока("Документ уже в работе у сотрудника - " + Строка(
				СтатусДокумента.Сотрудник)));
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, , СтруктураОтвета);
			Возврат Ответ;
		КонецЕсли;

	КонецЕсли; 
	
	//Проверяем созданные документы
	Если Ордер = Неопределено И ТипЖурнала="Отгрузка" Тогда
		
		СтруктураОрдераПоДокументу = ПолучитьРасходныеОрдераПоНакладной(Накладная.УникальныйИдентификатор(),РабочийУчасток.УникальныйИдентификатор()); 
		
		ОрдераПоДокументу = СтруктураОрдераПоДокументу.МассивОрдеров;
		КоличествоОрдеров = ОрдераПоДокументу.Количество();
		
		Если КоличествоОрдеров > 0 Тогда 
			
			Если КоличествоОрдеров = 1 Тогда
			
			ДокументОрдер = ОрдераПоДокументу[0];
				
			СтруктураОтвета.Вставить("ТекстОшибки", XMLСтрока("Документ уже в работе у сотрудника - " + Строка(
			ДокументОрдер.Сотрудник) + ". Статус документа - " + Строка(ДокументОрдер.Статус)));
				
			Иначе
				
			СтруктураОтвета.Вставить("ТекстОшибки", XMLСтрока("По документу уже есть несколько созданных ордеров, проверьте состояние документа на компьютере."));	
				
			КонецЕсли;
			
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, , СтруктураОтвета);
			Возврат Ответ;
			
		КонецЕсли;
		
	КонецЕсли;
		     
	Склад = РабочийУчасток.Владелец;	

	ЯПХ = Справочники.СкладскиеЯчейки.ПустаяСсылка();	
	Если ВходящиеДанные.Свойство("ЯПХ") Тогда
		ЯПХ = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.ЯПХ));
	КонецЕсли; 
	
	ДатаВХ = Дата(1,1,1);
    Если ВходящиеДанные.Свойство("ДатаВХ") Тогда
		ДатаВХ = Дата(СтрЗаменить(Лев(ВходящиеДанные.ДатаВХ,10),"-",""));
	КонецЕсли;

	НомерВХ = "";
    Если ВходящиеДанные.Свойство("НомерВХ") Тогда
		НомерВХ = Строка(ВходящиеДанные.НомерВХ);;
	КонецЕсли;
	
	ХозяйственнаяОперация = "";
    Если ВходящиеДанные.Свойство("ХозяйственнаяОперация") Тогда
		ХозяйственнаяОперация = Строка(ВходящиеДанные.ХозяйственнаяОперация);;
	КонецЕсли;
	
	Отмена = Ложь;
    Если ВходящиеДанные.Свойство("Отмена") Тогда
		Отмена = Булево(ВходящиеДанные.Отмена);;
	КонецЕсли; 
	
	Комментарий = "";
	Если ВходящиеДанные.Свойство("Комментарий") Тогда
		Комментарий = Строка(ВходящиеДанные.Комментарий);;
	КонецЕсли;

	ОрдерСсылка = Неопределено;

	Если Действие = "СоздатьДокумент" И (Ордер = Неопределено ИЛИ Ордер.Пустая()) Тогда
		
		Если ТипЖурнала = "Отгрузка" Тогда
			ОрдерСсылка = СоздатьРасходныйОрдерНаТовары(Накладная,РабочийУчасток,Сотрудник); 				
		ИначеЕсли ТипЖурнала = "Приемка" Тогда
			
			ДанныеЗаполнения = Новый Структура();
			ДанныеЗаполнения.Вставить("Склад",Склад); 
			ДанныеЗаполнения.Вставить("РабочийУчасток",РабочийУчасток);
			ДанныеЗаполнения.Вставить("Сотрудник",Сотрудник);
			ДанныеЗаполнения.Вставить("НомерВходящегоДокумента",НомерВХ);
			ДанныеЗаполнения.Вставить("ДатаВходящегоДокумента",ДатаВХ);
			ДанныеЗаполнения.Вставить("Распоряжение",Накладная);
			ДанныеЗаполнения.Вставить("Отправитель",?(ИмяДокумента="ПеремещениеТоваров",Накладная.СкладОтправитель,Накладная.Партнер)); 
			ДанныеЗаполнения.Вставить("ХозяйственнаяОперация",ПолучитьХозяйственнуюОперацию(ХозяйственнаяОперация));
			ДанныеЗаполнения.Вставить("Комментарий", Комментарий);
			
			
			ОрдерСсылка = СоздатьПриходныйОрдерНаТовары(ДанныеЗаполнения); 				

		Иначе
			
			ОрдерСсылка = Накладная;
			
		КонецЕсли;
		
	Иначе
		
		ОрдерСсылка = Ордер;

	КонецЕсли;
	
    ЗаписатьДанныеВРегистрСостоянияДокументовОбменМП(ОрдерСсылка,Накладная,Статус,Склад,РабочийУчасток,ЯПХ,Сотрудник,ИдентификаторКлиента);
	
	СтруктураДанныхФЗ = ПолучитьСтруктуруЗапускаФоновогоЗадания();
	СтруктураДанныхФЗ.ТипОбмена = "ОбменДокументами";
	СтруктураДанныхФЗ.Журнал = ТипЖурнала;
	СтруктураДанныхФЗ.Секция = РабочийУчасток;
	СтруктураДанныхФЗ.Накладная = Накладная;
	СтруктураДанныхФЗ.ДатаВХ = ДатаВХ;
	СтруктураДанныхФЗ.НомерВХ = НомерВХ;
	СтруктураДанныхФЗ.Отмена = Отмена; 
	СтруктураДанныхФЗ.Комментарий = Комментарий;
	
	ОбменУТМПСервер.ЗапуститьФоновоеВыполнение("",СтруктураДанныхФЗ);
	
	Альтерра_СкладСервер.ЗаписьВРегистрЖурналРаботыТСД(Перечисления.СобытияРаботыТСД.Документ,"Мобильное приложение",ОрдерСсылка,Сотрудник,ИдентификаторКлиента);
	
	СтруктураОтвета.Вставить("ОрдерВРаботе", XMLСтрока(ОрдерСсылка)); 
	СтруктураОтвета.Вставить("НомерОрдера", XMLСтрока(ОрдерСсылка.Номер)); 
	СтруктураОтвета.Вставить("Статус", XMLСтрока(Строка(ОрдерСсылка.Статус)));
	СтруктураОтвета.Вставить("ДатаОрдера", XMLСтрока(Строка(ОрдерСсылка.Дата)));
	СтруктураОтвета.Вставить("ТекстОшибки",XMLСтрока(""));
	
	Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
		
	Возврат Ответ;     
	
	
КонецФункции  

Функция УдалениеОрдера(ДанныеJSON)
    Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;

	СтруктураОтвета = Новый Структура;
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента; 
	КодСотрудника = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
	ТипДокумента = ВходящиеДанные.ТипДокумента; 
	
	Ордер = Документы[ТипДокумента].ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.Ордер));
	
	ТекстОшибки = "";
	Попытка
		ОбъектДок = Ордер.ПолучитьОбъект();
		ОбъектДок.Заблокировать();
		ОбъектДок.ПометкаУдаления = Истина;
		ОбъектДок.Записать(РежимЗаписиДокумента.ОтменаПроведения); 
	Исключение    
		ТекстОшибки = ОписаниеОшибки();
	КонецПопытки;
	
	СтруктураОтвета.Вставить("ТекстОшибки",XMLСтрока(ТекстОшибки));
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь,,СтруктураОтвета);   
	
	Возврат Ответ;     
	
	
КонецФункции 

Функция СозданиеИзменениеСтроки(ДанныеJSON)
    Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;

	СтруктураОтвета = Новый Структура;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента; 
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
	ТипОрдера = ВходящиеДанные.ТипОрдера;
	
	ДокументОрдер = Документы[ТипОрдера].ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.ОрдерГУИД)); 
	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.НоменклатураУИД));
	
	Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	Если Не ПустаяСтрока(ВходящиеДанные.Характеристика) Тогда
		Характеристика = Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию(ВходящиеДанные.Характеристика, , ,
			Номенклатура);
	КонецЕсли;

	Назначение = Справочники.Назначения.ПустаяСсылка();
	Если Не ПустаяСтрока(ВходящиеДанные.Назначение) Тогда
		Назначение = Справочники.Назначения.НайтиПоНаименованию(ВходящиеДанные.Назначение, , , );
	КонецЕсли;
	
    Факт = Число(ВходящиеДанные.Факт);	
	
	ЗаписатьДанныеВРегистрСостоянияТоваровОбменМП(ДокументОрдер,Номенклатура,Характеристика,Назначение,Факт,Сотрудник);
	
	Если ВходящиеДанные.Свойство("ШтрихкодыКодовМаркировки") Тогда
		
		
		СтрокаЛогов = "";
		Для Каждого Элемент Из ВходящиеДанные.ШтрихкодыКодовМаркировки Цикл 
			 
			Действие = Перечисления.ТипыЗаданий.ПустаяСсылка();
			Если ТипЗнч(Элемент) = Тип("Структура") Тогда
				Штрихкод = Элемент.Штрихкод;
				Действие = ?(Элемент.Состояние = "Удалить", Перечисления.ТипыЗаданий.Удаление, Перечисления.ТипыЗаданий.Создание);
			Иначе
				Штрихкод = Элемент;
			КонецЕсли;	
			СтрокаЛогов = СтрокаЛогов + Строка(Действие) + " " + Строка(Штрихкод) + Символы.ПС;				
			CcылкаНаШтрихкод = Справочники.ШтрихкодыУпаковокТоваров.ПолучитьПоЗначениюШтрихкода(Штрихкод);
			
			Если Не CcылкаНаШтрихкод = Неопределено Тогда
				ЗаписатьДанныеВРегистрСостояниеМаркировкиОбменМП(ДокументОрдер,CcылкаНаШтрихкод,Сотрудник, Действие);
			КонецЕсли;   
			
		КонецЦикла;
