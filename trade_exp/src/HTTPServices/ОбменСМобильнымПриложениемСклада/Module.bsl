		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	ИдентификаторКлиента = ВходящиеДанные.ИдентификаторКлиента;   
	
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(ВходящиеДанные.КодСотрудника);
	Ячейка = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(ВходящиеДанные.ЯчейкаУИД));
	Склад = Сотрудник.Склад;
	
	Если НЕ (ЗначениеЗаполнено(Сотрудник) И ЗначениеЗаполнено(Ячейка) И ЗначениеЗаполнено(Склад)) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не переданы критичные данные");
		Возврат Ответ;
	КонецЕсли;
	 
	 Если Сотрудник.Пустая() ИЛИ Ячейка.Пустая() ИЛИ Склад.Пустая() Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не переданы критичные данные");
		Возврат Ответ;
	 КонецЕсли;
	 	
	ОбъектОбработки = Обработки.ПроверкаАдресногоХранения.Создать();
	ОбъектОбработки.Склад = Склад;
	ОбъектОбработки.Ячейка = Ячейка;
	ОбъектОбработки.Сотрудник = Сотрудник;
	
	Для каждого Строка из ВходящиеДанные.Товары Цикл
	    Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.НоменклатураУИД));
		ИсходнаяЯчейка = Справочники.СкладскиеЯчейки.ПолучитьСсылку(Новый УникальныйИдентификатор(Строка.ИсходнаяЯчейкаУИД));
