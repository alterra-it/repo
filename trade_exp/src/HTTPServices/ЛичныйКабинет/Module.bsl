#Область ВходящиеHTTPЗапросы

Функция getClients(Запрос) 
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
	
	Попытка 
		
		ДанныеЗапроса = Новый Структура("МаксимумЗаписейНаСтранице, НомерСтраницы, Результат, Сообщение", 
            Запрос.ПараметрыЗапроса.Получить("count"),
			Запрос.ПараметрыЗапроса.Получить("page"),
			Истина, "");   
			
		УстановитьЧисловойПараметрHTTPЗапроса(ДанныеЗапроса.МаксимумЗаписейНаСтранице, 1000);
		УстановитьЧисловойПараметрHTTPЗапроса(ДанныеЗапроса.НомерСтраницы, 1);

		ПолучениеКлиентов = ПолучитьКлиентов(ДанныеЗапроса); 
		
		Если ПолучениеКлиентов.Результат Тогда                                         
			
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ПолучениеКлиентов);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПолучениеКлиентов.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;	 
	
КонецФункции

Функция getClient(Запрос)          
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
	
	Попытка 
		
		ДанныеЗапроса = Новый Структура("УИДКлиента, АдресЭП, НомерТелефона, Синхронизация, Результат, Сообщение", 
            Запрос.ПараметрыЗапроса.Получить("user_id"),
			Запрос.ПараметрыЗапроса.Получить("email"),
			Запрос.ПараметрыЗапроса.Получить("phone"),  
			?(Запрос.ПараметрыЗапроса.Получить("sync") = "1", 1, 0),  
			Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.УИДклиента, "");											
		Если Не ДанныеЗапроса.Результат  Тогда									
			ДанныеЗапроса.Результат = Истина;
			ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.АдресЭП, "");
			Если Не ДанныеЗапроса.Результат Тогда									
				ДанныеЗапроса.Результат = Истина;
				ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.НомерТелефона, "Отсутствуют УИД клиента, адрес электронной почты или номер телефона");
			КонецЕсли;
		КонецЕсли;  
		
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;
	
		ПолучениеКлиента = ПолучитьКлиента(ДанныеЗапроса); 
		
		Если ПолучениеКлиента.Результат Тогда                                         
			
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ПолучениеКлиента);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПолучениеКлиента.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;	 	
	
КонецФункции

Функция createClient(Запрос) 
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка                	
	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		
		ВходныеДанныеJSON= Запрос.ПолучитьТелоКакСтроку("UTF-8");
		
		Если ПустаяСтрока(ВходныеДанныеJSON) Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не переданы данные");			
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ВходныеДанныеJSON);
		ВходныеДанные = ПрочитатьJSON(ЧтениеJSON, Истина);
		
		Если ВходныеДанные.Количество() = 0 Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не удалось получить данные");
		КонецЕсли; 
		
		ДанныеЗапроса = Новый Структура("Результат, Сообщение", Истина, "");   
		
		ТипыИдентификаторов = ДопМодульСервер.ПолучитьТипыИдентификаторов(); 
		ТипыДействий = ДопМодульСервер.ПолучитьТипыДействий();  
		ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();  
		СтатусыДействий = ДопМодульСервер.ПолучитьСтатусыДействий();
		
		ИдентификаторПартнеры = ТипыИдентификаторов["client"].Код;
		ДействиеДобавление = ТипыДействий["create"].Код;
		СтатусОжидание = СтатусыДействий["wait"].Код;
		                                                         
		// Проверка на тип клиента
		ТипКлиента =  ВходныеДанные.Получить("type");     
		ПроверитьНаличие(ДанныеЗапроса, ТипКлиента, "Отсутствует тип");
		
		Если ЗначениеЗаполнено(ТипКлиента) И Не ТипыКлиентов.Свойство(ТипКлиента) Тогда    
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Некорректный тип");			
		КонецЕсли;   
		
		// Проверка на наименование 
		Имя = ВходныеДанные.Получить("first_name");
		Отчество = ВходныеДанные.Получить("second_name");
		Фамилия = ВходныеДанные.Получить("last_name"); 
		
		Если ТипыКлиентов[ТипКлиента].ЧастноеЛицо Или ТипыКлиентов[ТипКлиента].Бригадир Тогда 
			ПроверитьНаличие(ДанныеЗапроса, Имя, "Отсутствует имя");
			ПроверитьНаличие(ДанныеЗапроса, Фамилия, "Отсутствует фамилия");
		ИначеЕсли ТипыКлиентов[ТипКлиента].Компания Тогда 	
			ПроверитьНаличие(ДанныеЗапроса, Имя, "Отсутствует наименование");
		КонецЕсли;  

		Наименование = СокрЛП(?(ТипЗнч(Фамилия) = Тип("Строка"), Фамилия, "") + " " + 
		    ?(ТипЗнч(Имя) = Тип("Строка"), Имя, "") + " " + 
			?(ТипЗнч(Отчество) = Тип("Строка"), Отчество, ""));   
			
		ВходнаяДатаРождения = ВходныеДанные.Получить("birthday");
		ДатаРождения = "";
		Если ЗначениеЗаполнено(ВходнаяДатаРождения) Тогда
			ДатаРождения = Дата(Число(Прав(ВходнаяДатаРождения, 4)), Число(Сред(ВходнаяДатаРождения, 4, 2)), Число(Лев(ВходнаяДатаРождения, 2)));
		КонецЕсли;
			
		// Проверка на почту, телефон, активацию бонусной программы 
		АдресЭП = ВходныеДанные.Получить("email");
		НомерТелефона = ВходныеДанные.Получить("phone");
		АктивироватьБонуснуюПрограмму = ВходныеДанные.Получить("activate_loyalty");
		
		ПроверитьНаличие(ДанныеЗапроса, АдресЭП, "Отсутствует электронная почта");
		ПроверитьНаличие(ДанныеЗапроса, НомерТелефона, "Отсутствует номер телефона");
		ПроверитьНаличие(ДанныеЗапроса, АктивироватьБонуснуюПрограмму, "Отсутствуют данные об активации бонусной программы");
		
		// Бизнес-регион
		БизнесРегион = ВходныеДанные.Получить("shop");	 
		ПроверитьНаличие(ДанныеЗапроса, БизнесРегион, "Отсутствует бизнес-регион");     
		
		БизнесРегион =
			?(БизнесРегион = "barnaul", Справочники.БизнесРегионы.НайтиПоНаименованию("Барнаул"),
			?(БизнесРегион = "novoalt", Справочники.БизнесРегионы.НайтиПоНаименованию("Новоалтайск"),
			?(БизнесРегион = "biysk", Справочники.БизнесРегионы.НайтиПоНаименованию("Бийск"),
			?(БизнесРегион = "mayma", Справочники.БизнесРегионы.НайтиПоНаименованию("Майминский"), 
			ПредопределенноеЗначение("Справочник.БизнесРегионы.ПустаяСсылка")))));    
			
		ИНН = ВходныеДанные.Получить("requisites");
		ИНН = ?(ИНН = Неопределено, "", ИНН);
		
		// Результат проверок на наличие
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;     
		
		ДанныеЗапроса = Новый Структура("Результат, Сообщение, ТипИдентификатора, ТипДействия, ТипКлиента, СтатусДействия, 
			|Наименование, Имя, Отчество, Фамилия, ДатаРождения, АдресЭП, НомерТелефона, ИНН, БизнесРегион, АктивироватьБонуснуюПрограмму",
			Истина, "", ИдентификаторПартнеры, ДействиеДобавление, ТипКлиента, СтатусОжидание, 
			Наименование, Имя, Отчество, Фамилия, ДатаРождения, АдресЭП, НомерТелефона, ИНН, БизнесРегион, АктивироватьБонуснуюПрограмму);

		СозданиеКлиента = СоздатьКлиента(ДанныеЗапроса); 
		
		Если СозданиеКлиента.Результат Тогда     
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, СозданиеКлиента);    

		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, СозданиеКлиента.Сообщение);			
		КонецЕсли;
		
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;		

КонецФункции

Функция updateClient(Запрос)     
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка                	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		
		ВходныеДанныеJSON = Запрос.ПолучитьТелоКакСтроку("UTF-8");
		
		Если ПустаяСтрока(ВходныеДанныеJSON) Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не переданы данные");			
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ВходныеДанныеJSON);
		ВходныеДанные = ПрочитатьJSON(ЧтениеJSON, Истина);
		
		Если ВходныеДанные.Количество() = 0 Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не удалось получить данные");
		КонецЕсли;  
		
		ДанныеЗапроса = Новый Структура("Результат, Сообщение", Истина, "");
		
		УИДКлиента =  ВходныеДанные.Получить("user_id");     
		ПроверитьНаличие(ДанныеЗапроса, УИДКлиента, "Отсутствует УИД клиента");    
		
		АдресЭП = ВходныеДанные.Получить("email");
		НомерТелефона = ВходныеДанные.Получить("personal_phone");

		Имя = ВходныеДанные.Получить("first_name");
		Имя = ?(ТипЗнч(Имя) = Тип("Строка"), Имя, "");
		Отчество = ВходныеДанные.Получить("second_name");
		Отчество = ?(ТипЗнч(Отчество) = Тип("Строка"), Отчество, "");
		Фамилия = ВходныеДанные.Получить("last_name"); 
		Фамилия = ?(ТипЗнч(Фамилия) = Тип("Строка"), Фамилия, "");

		Наименование = СокрЛП(Фамилия + " " + Имя + " " + Отчество);   
		
		ВходнаяДатаРождения = ВходныеДанные.Получить("birthday");
		ДатаРождения = "";
		Если ЗначениеЗаполнено(ВходнаяДатаРождения) Тогда
			ДатаРождения = Дата(Число(Прав(ВходнаяДатаРождения, 4)), Число(Сред(ВходнаяДатаРождения, 4, 2)), Число(Лев(ВходнаяДатаРождения, 2)));
		КонецЕсли;
			
		ИНН = ВходныеДанные.Получить("requisites");
		ИНН = ?(ИНН = Неопределено, "", ИНН);
		
		Колбэк = ВходныеДанные.Получить("callback");
		
		СтартБП = ВходныеДанные.Получить("start_bp");
		СтартБП = ?(ЗначениеЗаполнено(СтартБП), СтартБП, Ложь);
			
		// Результат проверок на наличие
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;                                                      
		
		ТипыИдентификаторов = ДопМодульСервер.ПолучитьТипыИдентификаторов(); 
		ТипыДействий = ДопМодульСервер.ПолучитьТипыДействий();
		СтатусыДействий = ДопМодульСервер.ПолучитьСтатусыДействий();  
		
		ИдентификаторПартнеры = ТипыИдентификаторов["client"].Код;
		ДействиеИзменение = ТипыДействий["update"].Код;
		СтатусОжидание = СтатусыДействий["wait"].Код;
			
		ДанныеЗапроса = Новый Структура("Результат, Сообщение, УИДКлиента, АдресЭП,  НомерТелефона, 
			|Наименование, Фамилия, Имя, Отчество, ДатаРождения,
			|ИНН, Колбэк, СтартБП, ТипИдентификатора, ТипДействия, СтатусДействия", 
			Истина, "", УИДКлиента, АдресЭП, НомерТелефона, 
			Наименование, Фамилия, Имя, Отчество, ДатаРождения, 
			ИНН, Колбэк, СтартБП, ИдентификаторПартнеры, ДействиеИзменение, СтатусОжидание);			
		
		ИзменениеКлиента = ИзменитьКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		
		Если ИзменениеКлиента.Результат Тогда     
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ИзменениеКлиента);    

		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ИзменениеКлиента.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;		
	
КонецФункции

Функция approveClient(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
	
	Попытка 
		
		ДанныеЗапроса = Новый Структура("ТипДействия, УИДКлиента, ДатаСоздания, Статус, Комментарий, Результат, Сообщение", 
			Запрос.ПараметрыЗапроса.Получить("action"),     
			Запрос.ПараметрыЗапроса.Получить("user_id"),
			Запрос.ПараметрыЗапроса.Получить("create_date"),
			Запрос.ПараметрыЗапроса.Получить("status"),
			Запрос.ПараметрыЗапроса.Получить("comment"),  
			Истина, ""); 
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.ТипДействия, "Отсутствует тип действия action=update");
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.УИДКлиента, "Отсутствует УИД клиента");											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.ДатаСоздания, "Отсутствует дата внесения изменения");	
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.Статус, "Отсутствует статус изменения status=ok|cancel");	
		
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;            
		
		ДанныеЗапроса.ДатаСоздания = Дата(ДанныеЗапроса.ДатаСоздания);
	
		ЗавершениеДействияКлиента = ЗавершитьДействиеКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		
		Если ЗавершениеДействияКлиента.Результат Тогда                                         
			
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ЗавершениеДействияКлиента);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ЗавершениеДействияКлиента.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;	  
	
КонецФункции

Функция changePin(Запрос)
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка                	
		ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
		
		ВходныеДанныеJSON = Запрос.ПолучитьТелоКакСтроку("UTF-8");
		
		Если ПустаяСтрока(ВходныеДанныеJSON) Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не переданы данные");			
		КонецЕсли;
		
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(ВходныеДанныеJSON);
		ВходныеДанные = ПрочитатьJSON(ЧтениеJSON, Истина);
		
		Если ВходныеДанные.Количество() = 0 Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, "Не удалось получить данные");
		КонецЕсли;  
		
		ДанныеЗапроса = Новый Структура("Результат, Сообщение", Истина, "");
		
		УИДКлиента =  ВходныеДанные.Получить("user_id");     
		ПинКод =  ВходныеДанные.Получить("pin");
		ПроверитьНаличие(ДанныеЗапроса, УИДКлиента, "Отсутствует УИД клиента");    
		ПроверитьНаличие(ДанныеЗапроса, ПинКод, "Отсутствует пин-код");
		
		// Результат проверок на наличие
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли;                                                      
			
		ДанныеЗапроса = Новый Структура("Результат, Сообщение, УИДКлиента, ПинКод", 
			Истина, "", УИДКлиента, ПинКод);			
		
		ИзменениеПинКодаКлиента = ИзменитьПинКодКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса); 
		
		Если ИзменениеПинКодаКлиента.Результат Тогда     
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ИзменениеПинКодаКлиента);    

		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ИзменениеПинКодаКлиента.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;		
	
КонецФункции

Функция getOrders(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ПараметрыВходногоЗапроса = ПолучитьПараметрыHTTPЗапроса(Запрос);
	
	Попытка   
		
		ТелоСтрока = Запрос.ПолучитьТелоКакСтроку();
		ТелоСтруктура = АльтерраОбщегоНазначения.ДесериализоватьИзJSON(ТелоСтрока);	
		ЕстьФильтр = ТелоСтруктура.Свойство("filter");
		
		МаксимумЗаписейНаСтранице = ПолучитьЧисло(?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("count"), ТелоСтруктура.filter.count, Неопределено), 20);
		НомерСтраницы = ПолучитьЧисло(?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("page"), ТелоСтруктура.filter.page, Неопределено), 1);
		
		КоличествоТоваров = ПолучитьЧисло(?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("products_count"), ТелоСтруктура.filter.products_count, Неопределено), 0);
		КоличествоТоваров = ?(КоличествоТоваров < 0, 1000000, КоличествоТоваров); //  -1 - все товары
		
		// Проверка и изменение сумм документа на корректные
		НижняяГраница = 0; 
		НачальнаяСумма = ?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("amount") И 
				ТелоСтруктура.filter.amount.Свойство("from"), ТелоСтруктура.filter.amount.from, НижняяГраница);
		ВехняяГраница = 1000000000;	
		КонечнаяСумма =	?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("amount") И 
				ТелоСтруктура.filter.amount.Свойство("to"), ТелоСтруктура.filter.amount.to, ВехняяГраница);   
		ПолучитьДиапазон(НачальнаяСумма, НижняяГраница, КонечнаяСумма, ВехняяГраница);		

		ДанныеЗапроса = Новый Структура("УИДКлиента, АдресЭП, НачальнаяДата, КонечнаяДата, УИДДокумента, НомерНаСайте, НомерДокумента,
			|Грузополучатель, СпособПолучения, АдресДоставки, ТипДокумента, ВидДокумента, Статус, НачальнаяСумма, КонечнаяСумма,
			|МаксимумЗаписейНаСтранице, НомерСтраницы, КоличествоТоваров, Результат, Сообщение", 
				
		    ?(ТелоСтруктура.Свойство("user_id"), 								ТелоСтруктура.user_id, Неопределено), 
			?(ТелоСтруктура.Свойство("email"), 									ТелоСтруктура.email, Неопределено), 
			
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("date") И 
				ТелоСтруктура.filter.date.Свойство("from"), 					ТелоСтруктура.filter.date.from, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("date") И 
				ТелоСтруктура.filter.date.Свойство("to"), 						ТелоСтруктура.filter.date.to, Неопределено),   
				
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("id"), 				ТелоСтруктура.filter.id, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("order_id"), 			ТелоСтруктура.filter.order_id, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("document_id"), 		ТелоСтруктура.filter.document_id, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("consignee"), 			ТелоСтруктура.filter.consignee, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("delivery_type"), 		ТелоСтруктура.filter.delivery_type, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("delivery_address"),	ТелоСтруктура.filter.delivery_address, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("order_type"), 		ТелоСтруктура.filter.order_type, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("type"), 				ТелоСтруктура.filter.type, Неопределено), 
			?(ЕстьФильтр И ТелоСтруктура.filter.Свойство("status_code"), 		ТелоСтруктура.filter.status_code, Неопределено),
			НачальнаяСумма, КонечнаяСумма, 
			МаксимумЗаписейНаСтранице, НомерСтраницы, КоличествоТоваров,
			Истина, "");         
											
		ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.УИДклиента, "");											
		Если Не ДанныеЗапроса.Результат  Тогда									
			ДанныеЗапроса.Результат = Истина;
			ПроверитьНаличие(ДанныеЗапроса, ДанныеЗапроса.АдресЭП, "Отсутствуют GUID клиента или адрес электронной почты");
		КонецЕсли;
		
		Если Не ДанныеЗапроса.Результат Тогда     
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ДанныеЗапроса.Сообщение);			
		КонецЕсли; 
		
		ДанныеЗапроса.НачальнаяДата = ?(ЗначениеЗаполнено(ДанныеЗапроса.НачальнаяДата), Дата(Сред(ДанныеЗапроса.НачальнаяДата, 7, 4), Сред(ДанныеЗапроса.НачальнаяДата, 4, 2), Лев(ДанныеЗапроса.НачальнаяДата, 2)), Неопределено);
		ДанныеЗапроса.КонечнаяДата = ?(ЗначениеЗаполнено(ДанныеЗапроса.КонечнаяДата), Дата(Сред(ДанныеЗапроса.КонечнаяДата, 7, 4), Сред(ДанныеЗапроса.КонечнаяДата, 4, 2), Лев(ДанныеЗапроса.КонечнаяДата, 2), 23, 59, 59), Неопределено);
		
		ПолучениеДокументов = ПолучитьДокументы(ДанныеЗапроса); 
		
		Если ПолучениеДокументов.Результат Тогда                                         
			
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ПолучениеДокументов);    
			
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПолучениеДокументов.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;		
КонецФункции 

