	ЗаписьJSON.ЗаписатьИмяСвойства("delivery_to");
	ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Документ.ВремяДоставкиПо), Формат(Документ.ВремяДоставкиПо, "ДФ=ЧЧ:мм"), "")); 
	
	ЗаписьJSON.ЗаписатьИмяСвойства("amount");
	ЗаписьJSON.ЗаписатьЗначение(Документ.СуммаДокумента); 
	
	ЗаписьJSON.ЗаписатьИмяСвойства("order_type");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();

		ЗаписьJSON.ЗаписатьИмяСвойства("code");
