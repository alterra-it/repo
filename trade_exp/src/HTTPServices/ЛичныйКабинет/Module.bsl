		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	Партнер = &Партнер    
		|	И Проведен
		|УПОРЯДОЧИТЬ ПО 1";  
	
КонецФункции	

Функция ПолучитьДвоичныеДанныеДокумента(ДанныеЗапроса)
	
	ДвоичныеДанные = Неопределено;
	
	ПараметрыПечатнойФормы = Новый Структура("Обработка, Форма");

	Если Тип(ДанныеЗапроса.ПечатнаяФорма.ТипДокумента) = Тип("ДокументСсылка.ЧекККМ") 
		И Тип(ДанныеЗапроса.ПечатнаяФорма.ТипДокумента) = ТипЗнч(ДанныеЗапроса.СсылкаДокумента) 
		И ДанныеЗапроса.ПечатнаяФорма.Код = "receipt" Тогда
		
		ПараметрыПечатнойФормы.Обработка = 	"Печать чека";
		ПараметрыПечатнойФормы.Форма = 		"ПечатьТоварногоЧека";
	
	ИначеЕсли Тип(ДанныеЗапроса.ПечатнаяФорма.ТипДокумента) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
		И Тип(ДанныеЗапроса.ПечатнаяФорма.ТипДокумента) = ТипЗнч(ДанныеЗапроса.СсылкаДокумента) 
		И ДанныеЗапроса.ПечатнаяФорма.Код = "utd" Тогда
			
		ПараметрыПечатнойФормы.Обработка = 	"Печать УПД01102024";
		ПараметрыПечатнойФормы.Форма = 		"УПДНовый";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыПечатнойФормы.Обработка) Тогда
		ТабличныйДокумент = ПолучитьПечатнуюФормуОбработки(ДанныеЗапроса, ПараметрыПечатнойФормы);
		
		Если ТабличныйДокумент <> Неопределено И ТабличныйДокумент.ВысотаТаблицы <> 0 И ТабличныйДокумент.ШиринаТаблицы <> 0 Тогда
			Поток = Новый ПотокВПамяти;
			ТабличныйДокумент.Записать(Поток, ПолучитьТипТабличногоДокумента(ДанныеЗапроса.ФорматПечатнойФормы.Код));
			ДвоичныеДанные = Поток.ЗакрытьИПолучитьДвоичныеДанные();			 
		КонецЕсли;
		
	КонецЕсли;

	Возврат ДвоичныеДанные;
	
КонецФункции	

Функция ПолучитьПечатнуюФормуОбработки(ДанныеЗапроса, ПараметрыПечатнойФормы)
	
	ТабличныйДокумент = Неопределено;
	
	Попытка
		МассивДокументов = Новый Массив;
		МассивДокументов.Добавить(ДанныеЗапроса.СсылкаДокумента);  
		
		ПараметрыПечати = Новый Структура;
		
		ТабличныйДокумент = АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(
		МассивДокументов, 
		ПараметрыПечатнойФормы.Обработка, 
		ПараметрыПечатнойФормы.Форма, 
		ПараметрыПечати);
		   
	Исключение
		ТабличныйДокумент = Неопределено;
	КонецПопытки;
	
	Возврат ТабличныйДокумент;
	
КонецФункции	

Функция ПолучитьТипТабличногоДокумента(ФорматПечатнойФормы)
	
	ТипФайла = Неопределено;
	
	Если ФорматПечатнойФормы = "xlsx" Тогда
		ТипФайла =  ТипФайлаТабличногоДокумента.XLSX;
	ИначеЕсли ФорматПечатнойФормы = "pdf" Тогда
		ТипФайла =  ТипФайлаТабличногоДокумента.PDF;
	КонецЕсли;	
		
	Возврат ТипФайла; 
	 
КонецФункции

Функция ПолучитьСсылкуДокумента(УИД)

	СсылкаДокумента = Неопределено;
	
    Если ЗначениеЗаполнено(УИД) Тогда
    	
		СсылкаДокумента = Документы.ЗаказКлиента.ПолучитьСсылку(УИД);
		
		Если Не ЗначениеЗаполнено(СсылкаДокумента.Номер) Тогда 
			СсылкаДокумента = Документы.РеализацияТоваровУслуг.ПолучитьСсылку(УИД);
		КонецЕсли;  
		
		Если Не ЗначениеЗаполнено(СсылкаДокумента.Номер) Тогда 
			СсылкаДокумента = Документы.ЧекККМ.ПолучитьСсылку(УИД);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(СсылкаДокумента.Номер) Тогда
			СсылкаДокумента = Неопределено;	
		КонецЕсли;
		
    КонецЕсли;
    
    Возврат СсылкаДокумента;
    
КонецФункции    

#КонецОбласти

#Область Пагинация  

Функция РассчитатьПагинацию(ВсегоЗаписей, КоличествоЗаписейНаСтранице, МаксимумЗаписейНаСтранице, НомерСтраницы)   
	
	Пагинация = Новый Структура();
	Пагинация.Вставить("ВсегоЗаписей", ВсегоЗаписей);
	Пагинация.Вставить("МаксимумЗаписейНаСтранице", МаксимумЗаписейНаСтранице);
	Пагинация.Вставить("КоличествоЗаписейНаСтранице", КоличествоЗаписейНаСтранице);
	Пагинация.Вставить("ТекущаяСтраница", НомерСтраницы);
	Пагинация.Вставить("ПоследняяСтраница", 
		Цел(ВсегоЗаписей / МаксимумЗаписейНаСтранице) + ?(ВсегоЗаписей % МаксимумЗаписейНаСтранице > 0, 1, 0));
		
	Возврат Пагинация;
		
КонецФункции		

#КонецОбласти 	 

#Область СлужебныеФункции  

Функция ПолучитьЧисло(Значение, ЗначениеПоУмолчанию)
	
	Попытка
		Результат = Число(Значение);
	Исключение
		Результат = ЗначениеПоУмолчанию;	
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции	

Процедура ПолучитьДиапазон(НачальнаяСумма, НижняяГраница, КонечнаяСумма, ВерхняяГраница) 

	// Проверка и изменение сумм документа на корректные 
	НачальнаяСумма = ПолучитьЧисло(НачальнаяСумма, НижняяГраница);
	Если НачальнаяСумма < 0 Тогда
		НачальнаяСумма = НижняяГраница;
	КонецЕсли;
	
	КонечнаяСумма = ПолучитьЧисло(КонечнаяСумма, ВерхняяГраница);
	Если КонечнаяСумма < 0 Тогда
		КонечнаяСумма = ВерхняяГраница;
	КонецЕсли;
	
	Если НачальнаяСумма > 0 И ВерхняяГраница = 0 Тогда
		КонечнаяСумма = ВерхняяГраница;
	КонецЕсли;
	
КонецПроцедуры	

#КонецОбласти
