		|						// Доставка текущего дня
		|		 				ИЛИ ЕСТЬNULL(втДокументы.ОтметкаКассы, ИСТИНА) И Лист.Ссылка ЕСТЬ НЕ NULL
		|		 					И НАЧАЛОПЕРИОДА(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ЗаказНаДоставкуКлиентуРодителя.ПрибытиеНаОтгрузку), ДЕНЬ) >= НАЧАЛОПЕРИОДА(&ТекДата, ДЕНЬ) 
		|							И втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказДоставлен) 
		|						// Доставка прошедших дней
		|		 				ИЛИ ЕСТЬNULL(втДокументы.ОтметкаКассы, ИСТИНА) И Лист.Ссылка ЕСТЬ НЕ NULL
		|		 					И НАЧАЛОПЕРИОДА(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ЗаказНаДоставкуКлиентуРодителя.ПрибытиеНаОтгрузку), ДЕНЬ) < НАЧАЛОПЕРИОДА(&ТекДата, ДЕНЬ) 
		|		 				ТОГДА ИСТИНА
		|		 				ИНАЧЕ ЛОЖЬ						
		|		 			КОНЕЦ
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ
		|	КОНЕЦ КАК Оплачено, 
