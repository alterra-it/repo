#Область Очередь 

Функция ПолучитьКлиентаИзОчередиПоНомеруТелефона(ДанныеЗапроса) 
	
	ТипыИдентификаторов = ДопМодульСервер.ПолучитьТипыИдентификаторов(); 
	ТипыДействий = ДопМодульСервер.ПолучитьТипыДействий();               
	СтатусыДействий = ДопМодульСервер.ПолучитьСтатусыДействий();
	СтатусВыполнено = СтатусыДействий["ok"].Код;
	
	Запрос = Новый Запрос;
	Запрос.Текст =     
		"ВЫБРАТЬ
		|	Наименование КАК ПартнерНаименование
		|ИЗ                 
		|	РегистрСведений.ОчередьЛичныйКабинет  
		|ГДЕ          
		|	ТипИдентификатора = &ТипИдентификатора             
		|	И ТипДействия = &ТипДействия  
		|	И Статус <> &Статус		
		|	И НомерТелефона = &НомерТелефона";
	
	Запрос.УстановитьПараметр("ТипИдентификатора", ТипыИдентификаторов[ДанныеЗапроса.ТипИдентификатора].Код);  
	Запрос.УстановитьПараметр("ТипДействия", ТипыДействий[ДанныеЗапроса.ТипДействия].Код);  
	Запрос.УстановитьПараметр("Статус", СтатусВыполнено);  
	Запрос.УстановитьПараметр("НомерТелефона", ДанныеЗапроса.НомерТелефона);  
	
	Выборка = Запрос.Выполнить().Выбрать();      
	Если Выборка.Следующий() Тогда       
		Клиент = Новый Структура("Результат, Сообщение, ПартнерНаименование", Истина, "");
		ЗаполнитьЗначенияСвойств(Клиент, Выборка);
	Иначе                                    
		Клиент = Новый Структура("Результат, Сообщение", Ложь, "Клиент не найден");		
	КонецЕсли;
	
	Возврат Клиент;		
	
КонецФункции

Функция ПоставитьКлиентаВОчередьНаДобавление(ДанныеЗапроса)
	
	Попытка                         
		ТипыИдентификаторов = ДопМодульСервер.ПолучитьТипыИдентификаторов(); 
		ТипыДействий 		= ДопМодульСервер.ПолучитьТипыДействий();
		ТипыКлиентов 		= ДопМодульСервер.ПолучитьТипыКлиентов();
		СтатусыДействий 	= ДопМодульСервер.ПолучитьСтатусыДействий();		 
		
		ТипИдентификатора = ТипыИдентификаторов[ДанныеЗапроса.ТипИдентификатора].Код;
		ТипДействия = ТипыДействий[ДанныеЗапроса.ТипДействия].Код;
		ТипКлиента = ТипыКлиентов[ДанныеЗапроса.ТипКлиента].Код;
		Статус = СтатусыДействий[ДанныеЗапроса.СтатусДействия].Код;
		
		НаборЗаписей = РегистрыСведений.ОчередьЛичныйКабинет.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипИдентификатора.Установить(ТипИдентификатора);
		НаборЗаписей.Отбор.ТипДействия.Установить(ТипДействия);
		НаборЗаписей.Отбор.Идентификатор.Установить(ДанныеЗапроса.УИДКлиента);     
		
		НоваяЗапись = НаборЗаписей.Добавить();               
		НоваяЗапись.ТипИдентификатора = ТипИдентификатора;
		НоваяЗапись.ТипДействия = ТипДействия;
		НоваяЗапись.Идентификатор = ДанныеЗапроса.УИДКлиента;
		НоваяЗапись.ДатаСоздания = ТекущаяДата();
		НоваяЗапись.ДатаИзменения = НоваяЗапись.ДатаСоздания;
		НоваяЗапись.Статус = Статус;
		НоваяЗапись.ТипКлиента = ТипКлиента;
	   	НоваяЗапись.Наименование = ДанныеЗапроса.Наименование;  
	   	НоваяЗапись.Фамилия = ДанныеЗапроса.Фамилия;
	   	НоваяЗапись.Имя = ДанныеЗапроса.Имя;
	   	НоваяЗапись.Отчество = ДанныеЗапроса.Отчество;
	   	
	   	Если ЗначениеЗаполнено(ДанныеЗапроса.ДатаРождения) Тогда
	   		НоваяЗапись.ДатаРождения = ДанныеЗапроса.ДатаРождения;
	   	КонецЕсли;
	   	
		НоваяЗапись.АдресЭП = ДанныеЗапроса.АдресЭП;
		НоваяЗапись.НомерТелефона = ДанныеЗапроса.НомерТелефона;
		НоваяЗапись.ИНН = ДанныеЗапроса.ИНН;
		НоваяЗапись.БизнесРегион = ДанныеЗапроса.БизнесРегион;
		НоваяЗапись.АктивироватьБонуснуюПрограмму = ДанныеЗапроса.АктивироватьБонуснуюПрограмму;
		НаборЗаписей.Записать(Истина);   
		
		Возврат Новый Структура("Результат, Сообщение", Истина, "");
	
	Исключение
		Возврат Новый Структура("Результат, Сообщение", Ложь, "Клиент " + ДанныеЗапроса.Наименование + " не отправлен на создание: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));		
	КонецПопытки
	
КонецФункции     

