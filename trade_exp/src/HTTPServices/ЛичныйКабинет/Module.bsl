Функция ПолучитьВерсиюИзмененийОчереди(ДанныеЗапроса)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =  
		"ВЫБРАТЬ 
		|	ТипИдентификатора,
		|	ТипДействия,
		|	Идентификатор,
		|	ДатаСоздания,
		|	Наименование,
		|	ДатаРождения,		|
		|	АдресЭП,
		|	НомерТелефона
		|ПОМЕСТИТЬ
		|	втТекущееИзменение	
		|ИЗ 
		|	РегистрСведений.ОчередьЛичныйКабинет КАК ТекущееИзменение 
		|ГДЕ
		|	ТипИдентификатора = &ТипИдентификатора
		|	И ТипДействия = &ТипДействия
		|	И Идентификатор = &Идентификатор  
		|	И Статус = &СтатусОжидание        
		|	И ДатаСоздания = &ДатаСоздания   
		|;	
		|	                                          
		|///////////////////////////////////////////////////////////////	                                          
		|ВЫБРАТЬ 
		|	ТипИдентификатора,
		|	ТипДействия,
		|	Идентификатор,
		|	МАКСИМУМ(ДатаСоздания) КАК МаксДатаВыполнено
		|ПОМЕСТИТЬ
		|	втМаксИзменениеВыполнено
		|ИЗ 
		|	РегистрСведений.ОчередьЛичныйКабинет 
		|ГДЕ
		|	ТипИдентификатора = &ТипИдентификатора
		|	И ТипДействия = &ТипДействия
		|	И Идентификатор = &Идентификатор  
		|	И Статус = &СтатусВыполнено   
		|	И ДатаСоздания > &ДатаСоздания  
		|СГРУППИРОВАТЬ ПО
		|	ТипИдентификатора,
		|	ТипДействия,
		|	Идентификатор
		|;	
		|	                                          
		|///////////////////////////////////////////////////////////////		                                                
		|ВЫБРАТЬ 
		|	втТекущееИзменение.ТипИдентификатора,
		|	втТекущееИзменение.ТипДействия,
		|	втТекущееИзменение.Идентификатор,
		|	втТекущееИзменение.Наименование,
		|	втТекущееИзменение.АдресЭП,
		|	втТекущееИзменение.НомерТелефона,	
		|	втТекущееИзменение.ДатаСоздания,                      
		|	СледующееИзменение.Наименование КАК СледНаименование,
		|	СледующееИзменение.АдресЭП КАК СледАдресЭП,
		|	СледующееИзменение.НомерТелефона КАК СледНомерТелефона,
		|	СледующееИзменение.ДатаСоздания КАК СледДатаСоздания	
		|ИЗ
		|	втТекущееИзменение	                                                
		|	ЛЕВОЕ СОЕДИНЕНИЕ втМаксИзменениеВыполнено
		|		ПО втТекущееИзменение.ТипИдентификатора = втМаксИзменениеВыполнено.ТипИдентификатора 
		|		И втТекущееИзменение.ТипДействия = втМаксИзменениеВыполнено.ТипДействия 
		|		И втТекущееИзменение.Идентификатор = втМаксИзменениеВыполнено.Идентификатор
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЛичныйКабинет КАК СледующееИзменение
		|		ПО втМаксИзменениеВыполнено.ТипИдентификатора = СледующееИзменение.ТипИдентификатора 
		|		И втМаксИзменениеВыполнено.ТипДействия = СледующееИзменение.ТипДействия 
		|		И втМаксИзменениеВыполнено.Идентификатор = СледующееИзменение.Идентификатор 
		|		И втМаксИзменениеВыполнено.МаксДатаВыполнено = СледующееИзменение.ДатаСоздания";     
	
		Запрос.УстановитьПараметр("ТипИдентификатора", ДопМодульСервер.ПолучитьТипыИдентификаторов()["client"].Код);
		Запрос.УстановитьПараметр("ТипДействия", ДопМодульСервер.ПолучитьТипыДействий()[ДанныеЗапроса.ТипДействия].Код);
		Запрос.УстановитьПараметр("Идентификатор", ДанныеЗапроса.УИДКлиента);    
		Запрос.УстановитьПараметр("ДатаСоздания", ДанныеЗапроса.ДатаСоздания);    
		Запрос.УстановитьПараметр("СтатусОжидание", ДопМодульСервер.ПолучитьСтатусыДействий()["wait"].Код);
		Запрос.УстановитьПараметр("СтатусВыполнено", ДопМодульСервер.ПолучитьСтатусыДействий()["ok"].Код);  
		
		Выборка = Запрос.Выполнить().Выбрать();    
		
		Если Выборка.Следующий() Тогда    
			Если ЗначениеЗаполнено(Выборка.СледНаименование) Тогда
				Возврат Новый Структура("Результат, СледующийКлиентНайден, Сообщение", Ложь, Истина, СтрШаблон("У клиента %1 с состоянием от %2 уже приняты изменения, сделанные позже %3",  
					Выборка.Наименование, Выборка.ДатаСоздания, Выборка.СледДатаСоздания));
			Иначе    
				Возврат Новый Структура("Результат, СледующийКлиентНайден, Сообщение", Истина, Ложь, "");
			КонецЕсли;
		Иначе  
			Возврат Новый Структура("Результат, СледующийКлиентНайден, Сообщение", Ложь, Ложь, СтрШаблон("Не найден клиент с УИД %1 в очереди изменений", ДанныеЗапроса.УИДКлиента))
		КонецЕсли;
	
КонецФункции

Функция ПолучитьИзменениеКлиентаВОчереди(ИдентификаторКлиента);
	
	РезультатВыполнения = Новый Структура("ВСостоянииИзменения, ДатаИзменения", Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ    
		|	MAX(ДатаСоздания) КАК ДатаСоздания      
		|ПОМЕСТИТЬ
		|	втПоследнееОбновление	
		|ИЗ
		|	РегистрСведений.ОчередьЛичныйКабинет    
		|ГДЕ 
		|	ТипИдентификатора = &ТипИдентификатора
		|	И ТипДействия = &ТипДействия
		|	И Идентификатор = &Идентификатор  
		|	И Статус <> &СтатусОтменено
		|;   
		|ВЫБРАТЬ         
		|	ОчередьЛК.Статус = &СтатусОжидание КАК ВСостоянииИзменения,
		|	ВЫБОР 
		|		КОГДА ОчередьЛК.Статус = &СтатусОжидание
		|		ТОГДА ОчередьЛК.ДатаСоздания
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
		|	КОНЕЦ КАК ДатаИзменения
		|ИЗ
		|	РегистрСведений.ОчередьЛичныйКабинет ОчередьЛК  
		|	СОЕДИНЕНИЕ втПоследнееОбновление
		|		ПО ОчередьЛК.ДатаСоздания = втПоследнееОбновление.ДатаСоздания 
		|ГДЕ 
		|	ОчередьЛК.ТипИдентификатора = &ТипИдентификатора
		|	И ОчередьЛК.ТипДействия = &ТипДействия
		|	И ОчередьЛК.Идентификатор = &Идентификатор";   

	Запрос.УстановитьПараметр("ТипИдентификатора", ДопМодульСервер.ПолучитьТипыИдентификаторов()["client"].Код);
	Запрос.УстановитьПараметр("ТипДействия", ДопМодульСервер.ПолучитьТипыДействий()["update"].Код);
	Запрос.УстановитьПараметр("Идентификатор", ИдентификаторКлиента);    
	Запрос.УстановитьПараметр("СтатусОтменено", ДопМодульСервер.ПолучитьСтатусыДействий()["cancel"].Код);
	Запрос.УстановитьПараметр("СтатусОжидание", ДопМодульСервер.ПолучитьСтатусыДействий()["wait"].Код);
		  
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, Выборка);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции	

