	ЗаписьJSON.ЗаписатьИмяСвойства("payed_sum");
	ЗаписьJSON.ЗаписатьЗначение(Документ.СуммаОплаты); 	
	
	ЗаписьJSON.ЗаписатьИмяСвойства("payed");
	ЗаписьJSON.ЗаписатьЗначение(Документ.Оплачено); 	

	ЗаписьJSON.ЗаписатьИмяСвойства("date_create");
	ЗаписьJSON.ЗаписатьЗначение(Формат(Документ.Дата, "ДЛФ=Д")); 	
	
