Процедура ЗаписатьHTTPДостиженияСтатусов(ТипКлиента, ЗаписьJSON, РезультатЗапроса) 
	
	Если Не ТипКлиента.ЧастноеЛицо Тогда 
		Возврат;	
	КонецЕсли;
	
	КодТекущегоСтатуса = "";
	НаименованиеТекущегоСтатуса = "";
	
	СтатусыБП = ДопМодульСервер.ПолучитьСтатусыБП();
		
	ЗаписьJSON.ЗаписатьИмяСвойства("status_list");
	ЗаписьJSON.ЗаписатьНачалоМассива();	

	Для Каждого Статус Из РезультатЗапроса.ДостиженияСтатусов Цикл     
		ЗаписьJSON.ЗаписатьНачалоОбъекта();	
		
			ЗаписьJSON.ЗаписатьИмяСвойства("code");     
			ЗаписьJSON.ЗаписатьЗначение(СтатусыБП[Статус.НаименованиеСтатуса].Код);

			ЗаписьJSON.ЗаписатьИмяСвойства("name");     
			ЗаписьJSON.ЗаписатьЗначение(СтатусыБП[Статус.НаименованиеСтатуса].Наименование);    
			
			ЗаписьJSON.ЗаписатьИмяСвойства("is_active");     
			ЗаписьJSON.ЗаписатьЗначение(Статус.АктивныйСтатус);

			ЗаписьJSON.ЗаписатьИмяСвойства("to_reach_status");     
			ЗаписьJSON.ЗаписатьЗначение(Статус.ДоДостиженияСтатуса);
		
		ЗаписьJSON.ЗаписатьКонецОбъекта();
		
		Если Статус.АктивныйСтатус Тогда
			КодТекущегоСтатуса = СтатусыБП[Статус.НаименованиеСтатуса].Код;
			НаименованиеТекущегоСтатуса = СтатусыБП[Статус.НаименованиеСтатуса].Наименование;	
		КонецЕсли;
	КонецЦикла;	

	ЗаписьJSON.ЗаписатьКонецМассива();
	    
	ЗаписьJSON.ЗаписатьИмяСвойства("current_status");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();	

		ЗаписьJSON.ЗаписатьИмяСвойства("code");     
		ЗаписьJSON.ЗаписатьЗначение(КодТекущегоСтатуса);
		
		ЗаписьJSON.ЗаписатьИмяСвойства("name");     
		ЗаписьJSON.ЗаписатьЗначение(НаименованиеТекущегоСтатуса);    
			
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	
КонецПроцедуры

Процедура ЗаписатьHTTPСозданиеКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "client.create" Тогда 
		Возврат;
	КонецЕсли;         
	
	ЗаписьJSON.ЗаписатьИмяСвойства("user_id");
	ЗаписьJSON.ЗаписатьЗначение(Строка(РезультатЗапроса.УИДКлиента));
	
КонецПроцедуры  

Процедура ЗаписатьHTTPИзменениеКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса) 
	
	Если Не (ПараметрыВходногоЗапроса.ТипЗапроса = "client.update" Или ПараметрыВходногоЗапроса.ТипЗапроса = "client.changePin") Тогда 
		Возврат;
	КонецЕсли;    
	
	Если РезультатЗапроса.Сообщение <> "" Тогда
		ЗаписьJSON.ЗаписатьИмяСвойства("description");
		ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.Сообщение);   
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьHTTPЗавершениеДействияКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса); 

	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "client.approve" Тогда 
		Возврат;
	КонецЕсли;       
	
	СтатусыДействий = ДопМодульСервер.ПолучитьСтатусыДействий(); 
	
	ЗаписьJSON.ЗаписатьИмяСвойства("status"); 
	ЗаписьJSON.ЗаписатьНачалоОбъекта();     
	
	ЗаписьJSON.ЗаписатьИмяСвойства("code");
	ЗаписьJSON.ЗаписатьЗначение(СтатусыДействий[РезультатЗапроса.Статус].Код);
	
	ЗаписьJSON.ЗаписатьИмяСвойства("name");
	ЗаписьJSON.ЗаписатьЗначение(СтатусыДействий[РезультатЗапроса.Статус].Наименование);   
	
	Если РезультатЗапроса.Сообщение <> "" Тогда
		ЗаписьJSON.ЗаписатьИмяСвойства("description");
		ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.Сообщение);   
	КонецЕсли;
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();     

КонецПроцедуры
	
Процедура ЗаписатьHTTPПолучениеДокументов(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "orders.get" Тогда 
		Возврат;
	КонецЕсли;             
	
	ЗаписатьHTTPПагинацию(ЗаписьJSON, РезультатЗапроса.Пагинация);
	ЗаписатьHTTPСтатусыДоставки(ЗаписьJSON);
	ЗаписатьHTTPАдресаДоставки(ЗаписьJSON, РезультатЗапроса);
	
	ЗаписьJSON.ЗаписатьИмяСвойства("documents");
	ЗаписьJSON.ЗаписатьНачалоМассива();	
	
	Для Каждого Документ Из РезультатЗапроса.Документы Цикл   
		
		ЗаписьJSON.ЗаписатьНачалоОбъекта();      
		
		ЗаписатьHTTPПараметрыДокумента(ЗаписьJSON, Документ);
			
			ВсегоТоваров = РезультатЗапроса.ВсегоТоваров.НайтиСтроки(Новый Структура("ДокументПродажи", Документ.ДокументПродажи));
			ЗаписьJSON.ЗаписатьИмяСвойства("total_products"); 
			ЗаписьJSON.ЗаписатьЗначение(?(ВсегоТоваров.Количество() > 0, ВсегоТоваров[0].ВсегоТоваров, 0)); 
			
			Товары = РезультатЗапроса.Товары.НайтиСтроки(Новый Структура("ДокументПродажи", Документ.ДокументПродажи));
			ЗаписатьHTTPТовары(ЗаписьJSON, Товары);
			
			Такском = РезультатЗапроса.Такском.НайтиСтроки(Новый Структура("ДокументПродажи", Документ.ДокументПродажи));
			ЗаписатьHTTPТакском(ЗаписьJSON, Такском);
			//ЗаписатьHTTPПечатныеФормы(ЗаписьJSON, Документ.ДокументПродажи);
			ЗаписатьHTTPПечатныеФормы(ЗаписьJSON, Документ);
		
		ЗаписьJSON.ЗаписатьКонецОбъекта();     

	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецМассива();
	
КонецПроцедуры 

Процедура ЗаписатьHTTPПолучениеДокумента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "order.get" Тогда 
		Возврат;
	КонецЕсли;            
	
	Если РезультатЗапроса.Документ.Количество() > 0 Тогда
		ЗаписатьHTTPПараметрыДокумента(ЗаписьJSON, РезультатЗапроса.Документ[0]);
		ЗаписатьHTTPТовары(ЗаписьJSON, РезультатЗапроса.Товары);
		ЗаписатьHTTPТакском(ЗаписьJSON, РезультатЗапроса.Такском);
//		ЗаписатьHTTPПечатныеФормы(ЗаписьJSON, РезультатЗапроса.Документ[0].ДокументПродажи);
		ЗаписатьHTTPПечатныеФормы(ЗаписьJSON, РезультатЗапроса.Документ[0]);
	КонецЕсли;

КонецПроцедуры 

Процедура ЗаписатьHTTPПараметрыДокумента(ЗаписьJSON, Документ)
	
	ТипыДокументов 			= ДопМодульСервер.ПолучитьТипыДокументов();
	ВидыДокументов 			= ДопМодульСервер.ПолучитьВидыДокументов();  
	СпособыПолученияЗаказов = ДопМодульСервер.ПолучитьСпособыПолученияЗаказов();
	СтатусыДокументов 		= ДопМодульСервер.ПолучитьСтатусыДокументов();
	
