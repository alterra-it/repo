	ЗаписьJSON.ЗаписатьЗначение(Строка(Документ.ДокументПродажи)); 
	
	ЗаписьJSON.ЗаписатьИмяСвойства("canceled");
	ЗаписьJSON.ЗаписатьЗначение(Документ.ДокументОтменен);
	
	ЗаписьJSON.ЗаписатьИмяСвойства("status");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();     
	
		ЗаписьJSON.ЗаписатьИмяСвойства("code");
		ЗаписьJSON.ЗаписатьЗначение(СтатусыДокументов[Документ.СтатусОтгрузки].Код); 
		
		ЗаписьJSON.ЗаписатьИмяСвойства("name");
		ЗаписьJSON.ЗаписатьЗначение(СтатусыДокументов[Документ.СтатусОтгрузки].Наименование); 
		
	ЗаписьJSON.ЗаписатьКонецОбъекта(); 

	ЗаписьJSON.ЗаписатьИмяСвойства("tracking_url");
	ЗаписьJSON.ЗаписатьЗначение(Документ.ТрекингДоставки);
	
	ЗаписьJSON.ЗаписатьИмяСвойства("delivery_date");
	ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Документ.ДатаДоставки), Формат(Документ.ДатаДоставки, "ДЛФ=Д"), "")); 
	 
	ЗаписьJSON.ЗаписатьИмяСвойства("delivery_from");
