Функция ПолучитьСоглашение(Партнер)
	
	Запрос = Новый Запрос;
	Запрос.Текст =	      
		"ВЫБРАТЬ
		|	ПартнерыСегмента.Партнер КАК Партнер,
		|	ПартнерыСегмента.Сегмент КАК Сегмент
		|ПОМЕСТИТЬ втПартнерСегмент
		|ИЗ  
		|	РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента         
		|ГДЕ		               
		|	Партнер = &Партнер
		|;
		|/////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ 
		|	СоглашенияСКлиентами.Партнер КАК Партнер,
		|	СоглашенияСКлиентами.Ссылка КАК Соглашение,
		|	ВидыЦен.Ссылка КАК ВидЦен,
		|	1 КАК Порядок
		|ИЗ
		|	Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
		|	СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ДополнительныеРеквизиты КАК СоглашенияРеквизиты
		|		ПО СоглашенияСКлиентами.Ссылка = СоглашенияРеквизиты.Ссылка
		|		И СоглашенияСКлиентами.Партнер = &Партнер
		|	СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|		ПО СоглашенияСКлиентами.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
		|		И ВидыЦен.ФорматПодразделения = &ФорматПодразделения
		|	СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ПО СтруктураПредприятия.РегионПрисутствия = ВидыЦен.РегионПрисутствия
		|		И СтруктураПредприятия.ФорматПодразделения = ВидыЦен.ФорматПодразделения
		|ГДЕ
		|	СоглашенияРеквизиты.Свойство.Наименование = &СвойствоСоглашения 
		|	И СоглашенияРеквизиты.Значение = ИСТИНА
		|	И СоглашенияРеквизиты.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
		|
		|ОБЪЕДИНИТЬ 
		|
		|ВЫБРАТЬ 
		|	втПартнерСегмент.Партнер,
		|	МАКСИМУМ(СоглашенияСКлиентами.Ссылка),
		|	МАКСИМУМ(ВидыЦен.Ссылка),
		|	2
		|ИЗ
		|	Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
		|	СОЕДИНЕНИЕ втПартнерСегмент 
		|		ПО втПартнерСегмент.Сегмент = СоглашенияСКлиентами.СегментПартнеров
		|	СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|		ПО СоглашенияСКлиентами.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
		|		И ВидыЦен.ФорматПодразделения = &ФорматПодразделения     
		|	СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия  
		|		ПО СтруктураПредприятия.РегионПрисутствия = ВидыЦен.РегионПрисутствия
		|		И СтруктураПредприятия.ФорматПодразделения = ВидыЦен.ФорматПодразделения
		|ГДЕ
		|	СоглашенияСКлиентами.Типовое
		|	И СоглашенияСКлиентами.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
		|СГРУППИРОВАТЬ ПО
		|	втПартнерСегмент.Партнер,
		|	СтруктураПредприятия.ИдентификаторСайта 
        |
		|УПОРЯДОЧИТЬ ПО 4";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);  
	Запрос.УстановитьПараметр("ФорматПодразделения", Справочники.ФорматыПодразделений.НайтиПоНаименованию("ТСК"));
	Запрос.УстановитьПараметр("СвойствоСоглашения", "Выгружать на сайт (Соглашения об условиях продаж)");
	
	Клиент = Новый Структура("Соглашение, ВидЦен");
	
	Выборка = Запрос.Выполнить().Выбрать();     
	Если Выборка.Следующий() Тогда       
		ЗаполнитьЗначенияСвойств(Клиент, Выборка);
	КонецЕсли;
	
	Возврат Клиент;		
	
КонецФункции

