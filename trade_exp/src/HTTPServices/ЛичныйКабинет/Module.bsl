#Область ОбработкаВходныхЗапросов     

Функция ПолучитьКлиентов(ДанныеЗапроса)
	
	Попытка  
		
		ОсновныеДанные = Новый Структура("Результат, Сообщение, ПагинацияСтраниц, ОсновныеДанные", Истина, "");	
		
		ОсновныеДанные.ПагинацияСтраниц = ПолучитьКлиентовПагинацияСтраниц(ДанныеЗапроса);  
		
		Если ОсновныеДанные.ПагинацияСтраниц.ТекущаяСтраница <= ОсновныеДанные.ПагинацияСтраниц.ПоследняяСтраница Тогда
			ОсновныеДанные.ОсновныеДанные = ПолучитьКлиентовТекущаяСтраница( ОсновныеДанные.ПагинацияСтраниц);
		КонецЕсли;			
		
		Возврат ОсновныеДанные;
	
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
		
КонецФункции	

Функция ПолучитьКлиента(ДанныеЗапроса)
	
	Попытка  
		
		ОсновныеДанные = Новый Структура("Результат, Сообщение", Ложь, "Клиент не найден");		
		
		// Поиск клиента по УИД
		Если ЗначениеЗаполнено(ДанныеЗапроса.УИДКлиента) Тогда
			Партнер = Неопределено;
			
			Попытка
				Партнер = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.УИДклиента));
			Исключение   
			КонецПопытки;  
			
			Если ЗначениеЗаполнено(Партнер) Тогда       
				ОсновныеДанные = ПолучитьКлиентаПоПараметру(Новый Структура("Партнер", Партнер));
			КонецЕсли;
		КонецЕсли;
		
		// Поиск клиента по адресу ЭП
		Если ЗначениеЗаполнено(ДанныеЗапроса.АдресЭП) И Не ОсновныеДанные.Результат Тогда
			ОсновныеДанные = ПолучитьКлиентаПоПараметру(Новый Структура("АдресЭП", ДанныеЗапроса.АдресЭП));
		КонецЕсли;      
		
		// Поиск клиента по номеру телефона
		Если ЗначениеЗаполнено(ДанныеЗапроса.НомерТелефона) И Не ОсновныеДанные.Результат Тогда
			ОсновныеДанные = ПолучитьКлиентаПоПараметру(Новый Структура("НомерТелефона", ДанныеЗапроса.НомерТелефона));
		КонецЕсли;   		
		
		Если Не ОсновныеДанные.Результат Тогда
			Возврат ОсновныеДанные;
		КонецЕсли;      
		
		Клиент = Новый Структура("Результат, Сообщение, ОсновныеДанные, Синхронизация, Награды, ТипКлиента, УсловияПродаж, БалансБонусныхБаллов, ДостиженияСтатусов, ИзмененияВОчереди", 
			Истина, "", ОсновныеДанные, ДанныеЗапроса.Синхронизация, Новый Массив);		
		
		// Определение типа клиента  
		Клиент.ТипКлиента = ПолучитьТипКлиента(ОсновныеДанные.ЮрФизЛицо, ОсновныеДанные.Партнер);
		Для Каждого Дубль Из Клиент.ОсновныеДанные.Дубли Цикл 
			Дубль.Вставить("ТипКлиента", ПолучитьТипКлиента(Дубль.ЮрФизЛицо, Дубль.Партнер));
		КонецЦикла;
		
		// Для синхронизации минимальный набор по клиенту
		Если ЗначениеЗаполнено(ДанныеЗапроса.Синхронизация) Тогда 
			Возврат Клиент;
		КонецЕсли;   
		
		ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();
		
		// Соглашения      
		УсловияПродаж = ПолучитьУсловияПродажФЛ(Клиент.ТипКлиента, Клиент.ОсновныеДанные.Партнер);
		Клиент.УсловияПродаж = ?(ЗначениеЗаполнено(УсловияПродаж), УсловияПродаж, 
			ПолучитьУсловияПродажЮЛ(Клиент.ТипКлиента, Клиент.ОсновныеДанные.Партнер, 
				?(ЗначениеЗаполнено(Клиент.ОсновныеДанные.ОсновнойМенеджер), Клиент.ОсновныеДанные.ОсновнойМенеджер, Клиент.ОсновныеДанные.МАП)));
		
		// Бонусные баллы
		Если ТипыКлиентов[Клиент.ТипКлиента].УчастиеБП Тогда	
			Клиент.БалансБонусныхБаллов = ПолучитьБалансБонусныхБаллов(ОсновныеДанные.Партнер);      
		КонецЕсли;            
		
		// Достижения статусов
		Если ТипыКлиентов[Клиент.ТипКлиента].ЧастноеЛицо Тогда	
			Клиент.ДостиженияСтатусов = ПолучитьДостиженияСтатусов(ОсновныеДанные.Партнер);
		КонецЕсли;
		
		// Награды
		НаградаСвойЧеловек = ПолучитьНаградуСвойЧеловек(ОсновныеДанные.Партнер);
		Если ЗначениеЗаполнено(НаградаСвойЧеловек) Тогда
			Клиент.Награды.Добавить(НаградаСвойЧеловек);
		КонецЕсли;
		
		// Из очереди получить состояние изменения данных
		Клиент.ИзмененияВОчереди = ПолучитьИзменениеКлиентаВОчереди(XMLСтрока(ОсновныеДанные.Партнер));
						
		Возврат Клиент;
		
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции    

Функция СоздатьКлиента(ДанныеЗапроса)
	
	Попытка         
		
		// Поиск клиента по номеру телефона
		ПолучениеКлиента = ПолучитьКлиентаПоПараметру(Новый Структура("НомерТелефона", ДанныеЗапроса.НомерТелефона));
		
		Если ПолучениеКлиента.Результат Тогда         
			Возврат Новый Структура("Результат, Сообщение", Ложь, "По номеру телефона " + ДопМодульСервер.ФорматированныйНомерТелефона(ДанныеЗапроса.НомерТелефона) + " найден клиент " + ПолучениеКлиента.ПартнерНаименование);
		КонецЕсли;       
		
		// Поиск клиента по почте
		ПолучениеКлиента = ПолучитьКлиентаПоПараметру(Новый Структура("АдресЭП", ДанныеЗапроса.АдресЭП));
		
		Если ПолучениеКлиента.Результат Тогда         
			Возврат Новый Структура("Результат, Сообщение", Ложь, "По электронной почте " + ДанныеЗапроса.АдресЭП + " найден клиент " + ПолучениеКлиента.ПартнерНаименование);
		КонецЕсли;  	
		
		// Поиск клиента по ИНН
		Если ЗначениеЗаполнено(ДанныеЗапроса.ИНН) Тогда
			ПолучениеКлиента = ПолучитьКлиентаПоИНН(ДанныеЗапроса.ИНН);
			
			Если ПолучениеКлиента.Результат Тогда         
				Возврат Новый Структура("Результат, Сообщение", Ложь, "По ИНН " + ДанныеЗапроса.ИНН + " найден клиент " + ПолучениеКлиента.КонтрагентНаименование);
			КонецЕсли;  			
		КонецЕсли;
		
		ПолучениеКлиентаИзОчереди = ПолучитьКлиентаИзОчередиПоНомеруТелефона(ДанныеЗапроса);
		
		Если ПолучениеКлиентаИзОчереди.Результат Тогда         
			Возврат Новый Структура("Результат, Сообщение", Ложь, "По номеру телефона " + ДопМодульСервер.ФорматированныйНомерТелефона(ДанныеЗапроса.НомерТелефона) + " клиент " + ПолучениеКлиентаИзОчереди.ПартнерНаименование + " находится в процессе создания");
		КонецЕсли; 		
		
		УИДНовогоКлиента = Строка(Справочники.Партнеры.ПолучитьСсылку().УникальныйИдентификатор());     
		ДанныеЗапроса.Вставить("УИДКлиента", УИДНовогоКлиента);       
		
		ДобавлениеВОЧередь = ПоставитьКлиентаВОчередьНаДобавление(ДанныеЗапроса);     
		Если Не ДобавлениеВОЧередь.Результат Тогда      
			 Возврат ДобавлениеВОЧередь;
		 КонецЕсли;           
		 
		 ЗапуститьСозданиеКлиента(УИДНовогоКлиента);
		
		Возврат  Новый Структура("Результат, УИДКлиента, Сообщение", Истина, УИДНовогоКлиента, "");
		
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции 

Функция ИзменитьКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса)
	
	Попытка                             
		
		ОсновныеДанные = Новый Структура("Результат, Сообщение", Ложь, "Клиент не найден");		
		
		// Поиск клиента по УИД
		Если ЗначениеЗаполнено(ДанныеЗапроса.УИДКлиента) Тогда
			Партнер = Неопределено;
			Попытка
				Партнер = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.УИДклиента));
			Исключение   
			КонецПопытки;  
			
			Если ЗначениеЗаполнено(Партнер) Тогда       
				ОсновныеДанные = ПолучитьКлиентаПоПараметру(Новый Структура("Партнер", Партнер));
			КонецЕсли;
		КонецЕсли;
		
		Если Не ОсновныеДанные.Результат Тогда
			Возврат ОсновныеДанные;
		КонецЕсли;  		
		
		// Поиск клиента по номеру телефона
		Если ЗначениеЗаполнено(ДанныеЗапроса.НомерТелефона) Тогда
			ПолучениеКлиента = ПолучитьКлиентаПоПараметру(Новый Структура("НомерТелефона", ДанныеЗапроса.НомерТелефона));
			
			Если ПолучениеКлиента.Результат И ПолучениеКлиента.Партнер <> ОсновныеДанные.Партнер Тогда         
				Возврат Новый Структура("Результат, Сообщение", Ложь, "По номеру телефона " + ДопМодульСервер.ФорматированныйНомерТелефона(ДанныеЗапроса.НомерТелефона) + " найден клиент " + ПолучениеКлиента.ПартнерНаименование);
			КонецЕсли;
		КонецЕсли;
		
		// Поиск клиента по почте
		Если ЗначениеЗаполнено(ДанныеЗапроса.АдресЭП) Тогда
			ПолучениеКлиента = ПолучитьКлиентаПоПараметру(Новый Структура("АдресЭП", ДанныеЗапроса.АдресЭП));
			
			Если ПолучениеКлиента.Результат И ПолучениеКлиента.Партнер <> ОсновныеДанные.Партнер Тогда         
				Возврат Новый Структура("Результат, Сообщение", Ложь, "По электронной почте " + ДанныеЗапроса.АдресЭП + " найден клиент " + ПолучениеКлиента.ПартнерНаименование);
			КонецЕсли;  	
		КонецЕсли;
		
		// Поиск клиента по ИНН
		Если ЗначениеЗаполнено(ДанныеЗапроса.ИНН) Тогда
			ПолучениеКлиента = ПолучитьКлиентаПоИНН(ДанныеЗапроса.ИНН);
			
			Если ПолучениеКлиента.Результат И ПолучениеКлиента.Партнер <> ОсновныеДанные.Партнер Тогда         
				Возврат Новый Структура("Результат, Сообщение", Ложь, "По ИНН " + ДанныеЗапроса.ИНН + " найден клиент " + ПолучениеКлиента.КонтрагентНаименование);
			КонецЕсли;  			
		КонецЕсли;    
		
		// Определение типа клиента     
		ДанныеЗапроса.Вставить("ТипКлиента", ПолучитьТипКлиента(ОсновныеДанные.ЮрФизЛицо, ОсновныеДанные.Партнер));
		
		ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();  
		
		ЕстьИзменения = Истина;
		Если ((ДанныеЗапроса.Наименование = ОсновныеДанные.ПартнерНаименование Или Не ЗначениеЗаполнено(ДанныеЗапроса.Наименование))
			 И (ДанныеЗапроса.АдресЭП = ОсновныеДанные.АдресЭП Или Не ЗначениеЗаполнено(ДанныеЗапроса.АдресЭП))
			 И (ДанныеЗапроса.НомерТелефона = ОсновныеДанные.НомерТелефона Или Не ЗначениеЗаполнено(ДанныеЗапроса.НомерТелефона))
			 И (ДанныеЗапроса.ДатаРождения = ОсновныеДанные.ДатаРождения Или Не ЗначениеЗаполнено(ДанныеЗапроса.ДатаРождения))) Тогда
			 
			 	ЕстьИзменения = Ложь;	
			 
				//Если ДанныеЗапроса.ТипКлиента = ТипыКлиентов["wholesale"].Код И ЗначениеЗаполненое(ДанныеЗапроса.ИНН) И ДанныеЗапроса.ИНН <> ОсновныеДанные.ИНН Тогда
				//	ЕстьИзменения = Истина;	
				//КонецЕсли;
		 КонецЕсли;      
		 
		Если Не ЕстьИзменения Тогда                                  
			 Возврат Новый Структура("Результат, Сообщение", Ложь, "Изменения не применились");
		КонецЕсли;
		
		ИзменениеВОчередь = ПоставитьКлиентаВОчередьНаИзменение(ДанныеЗапроса);     
		Если Не ИзменениеВОчередь.Результат Тогда      
			 Возврат ИзменениеВОчередь;
		 КонецЕсли;           
	 
	 	РезультатВыполнения = Новый Структура("Результат, Сообщение", Истина, "");
	 	Если ДанныеЗапроса.СтартБП Тогда
			ЗапуститьПодтверждениеИзмененияКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса, ОсновныеДанные);
			РезультатВыполнения.Сообщение = "Запущен бизнес-процесс на подтверждение изменений клиента";
	 	Иначе
	 		ПодтверждениеИзменений = Новый Структура("УИДКлиента, ДатаСоздания, Статус, ТекстОшибки, Комментарий",
	 			ДанныеЗапроса.УИДКлиента, ИзменениеВОчередь.ДатаСоздания, "ok", "", "Без БП");
	 		ЗапуститьИзменениеКлиента(ПодтверждениеИзменений);
	 		РезультатВыполнения.Сообщение = "Выполняются изменения клиента";
	 	КонецЕсли;
		
		Возврат РезультатВыполнения;
		
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции  

Функция ЗавершитьДействиеКлиента(ПараметрыВыходногоЗапроса, ДанныеЗапроса)        
	
	Попытка   
		
		СтатусыДействий = ДопМодульСервер.ПолучитьСтатусыДействий(); 
		ДанныеЗапроса.Вставить("ТекстОшибки", "");

		Если СтатусыДействий[ДанныеЗапроса.Статус].Код = СтатусыДействий["ok"].Код Тогда 
			
			ПоследняяВерсия = ПолучитьВерсиюИзмененийОчереди(ДанныеЗапроса); 
			
			Если Не ПоследняяВерсия.Результат Тогда 
				
				// Если утверждены не последние изменения при утвержденных последних
				Если ПоследняяВерсия.СледующийКлиентНайден Тогда  
					// Сменить статус с Выполнено на Ошибка 
					ДанныеЗапроса.Статус = СтатусыДействий["error"].Код;	
					ДанныеЗапроса.ТекстОшибки = ПоследняяВерсия.Сообщение;  
				Иначе
					Возврат ПоследняяВерсия;	
				КонецЕсли;
			
			КонецЕсли;
			
		КонецЕсли; 
		
		// Фоновое задание
		ЗапуститьИзменениеКлиента(ДанныеЗапроса); 
		
		Возврат  Новый Структура("Результат, Статус, Сообщение", Истина, ДанныеЗапроса.Статус, ДанныеЗапроса.ТекстОшибки);
		
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции

Функция ИзменитьПинКодКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса)
	
	Попытка                             
		
		ОсновныеДанные = Новый Структура("Результат, Сообщение", Ложь, "Клиент не найден");		
		
		// Поиск клиента по УИД
		Если ЗначениеЗаполнено(ДанныеЗапроса.УИДКлиента) Тогда
			Партнер = Неопределено;
			Попытка
				Партнер = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.УИДклиента));
			Исключение   
			КонецПопытки;  
			
			Если ЗначениеЗаполнено(Партнер) Тогда       
				ОсновныеДанные = ПолучитьКлиентаПоПараметру(Новый Структура("Партнер", Партнер));
			КонецЕсли;
		КонецЕсли;
		
		Если Не ОсновныеДанные.Результат Тогда
			Возврат ОсновныеДанные;
		КонецЕсли;  		

		ПартнерОбъект = Партнер.ПолучитьОбъект();
		ПартнерОбъект.ПИН_Код = ДанныеЗапроса.ПинКод;
		ПартнерОбъект.Записать();
		
		Возврат  ОсновныеДанные;
		
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;	
	
КонецФункции	

Функция ПолучитьДокументы(ДанныеЗапроса)
	
	Попытка  	

		// Поиск клиента по УИД
		Если ЗначениеЗаполнено(ДанныеЗапроса.УИДКлиента) Тогда
			Партнер = Неопределено;
			Попытка
				Партнер = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.УИДклиента));
			Исключение   
			КонецПопытки;  
		КонецЕсли;
		
		// Поиск клиента по адресу ЭП
		Если Не ЗначениеЗаполнено(Партнер) И ЗначениеЗаполнено(ДанныеЗапроса.АдресЭП) Тогда
			ОсновныеДанныеКлиента = ПолучитьКлиентаПоПараметру(Новый Структура("АдресЭП", ДанныеЗапроса.АдресЭП));

			Если ОсновныеДанныеКлиента.Результат Тогда
				Партнер = ОсновныеДанныеКлиента.Партнер;
			Иначе
				Возврат ОсновныеДанныеКлиента;
			КонецЕсли;   
		КонецЕсли; 
		
		ДокументыКлиента = ПолучитьДокументыКлиента(Партнер, ДанныеЗапроса);   
		Пагинация = РассчитатьПагинацию(?(ДокументыКлиента.ВсегоДокументов.Количество() > 0, ДокументыКлиента.ВсегоДокументов[0].ВсегоДокументов, 0), 
			ДокументыКлиента.Документы.Количество(), ДанныеЗапроса.МаксимумЗаписейНаСтранице, ДанныеЗапроса.НомерСтраницы);
		
		ДокументыКлиента.Вставить("Пагинация", Пагинация);
		ДокументыКлиента.Вставить("Результат", Истина);
		ДокументыКлиента.Вставить("Сообщение", "");
		
		Возврат ДокументыКлиента;

	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции

Функция ПолучитьДокумент(ДанныеЗапроса)
	
	Попытка
		
		РезультатСОшибкой = Новый Структура("Результат, Сообщение", Ложь, "Документ по %1 %2 не найден", ДанныеЗапроса.УИДДокумента);
		
		// Поиск по УИД
		Если СтрДлина(ДанныеЗапроса.УИДДокумента) > 10 Тогда
			Попытка
				УИД = Новый УникальныйИдентификатор(ДанныеЗапроса.УИДДокумента);
			Исключение 
				РезультатСОшибкой.Сообщение = СтрШаблон(РезультатСОшибкой.Сообщение, "идентификатору", ДанныеЗапроса.УИДДокумента);
				Возврат РезультатСОшибкой;
			КонецПопытки;
			
			ДокументКлиента = ПолучитьДокументКлиента(УИД);	

		// Поиск по номеру на сайте
		Иначе
			ДокументКлиента = ПолучитьДокументКлиента(, ДанныеЗапроса.УИДДокумента);
		КонецЕсли;
		
		Если ДокументКлиента.Документ.Количество() = 0 Тогда	
			РезультатСОшибкой.Сообщение = СтрШаблон(РезультатСОшибкой.Сообщение, 
				?(СтрДлина(ДанныеЗапроса.УИДДокумента) > 10, "идентификатору", "номеру на сайте"), ДанныеЗапроса.УИДДокумента);
			Возврат РезультатСОшибкой;
		КонецЕсли;

		ДокументКлиента.Вставить("Результат", Истина);
		ДокументКлиента.Вставить("Сообщение", "");
		Возврат ДокументКлиента;   

	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции

Функция ПолучитьПечатнуюФорму(ДанныеЗапроса)
	
	Попытка	
		РезультатВыполнения = Новый Структура("Результат, Сообщение, ДвоичныеДанные", Ложь, "");
		УИД = Неопределено;
		
		Попытка
			УИД = Новый УникальныйИдентификатор(ДанныеЗапроса.УИДДокумента);
		Исключение 
			РезультатВыполнения.Сообщение = СтрШаблон("Документ с УИД %1 не найден", ДанныеЗапроса.УИДДокумента);
			Возврат РезультатВыполнения; 	
		КонецПопытки;
		
		ДанныеЗапроса.Вставить("СсылкаДокумента", ПолучитьСсылкуДокумента(УИД));
		Если Не ЗначениеЗаполнено(ДанныеЗапроса.СсылкаДокумента) Тогда
			РезультатВыполнения.Сообщение = СтрШаблон("Документ по УИД %1 не определен", ДанныеЗапроса.УИДДокумента);
			Возврат РезультатВыполнения; 	
		КонецЕсли;
			
		ПечатныеФормы = ДопМодульСервер.ПолучитьПечатныеФормы();
		Если Не ЗначениеЗаполнено(ДанныеЗапроса.ТипПечатнойФормы) Тогда
			ДанныеЗапроса.ТипПечатнойФормы = ДопМодульСервер.ПолучитьПечатнуюформуПоУмолчанию(ДанныеЗапроса.СсылкаДокумента);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДанныеЗапроса.ТипПечатнойФормы) 
			Или Не ПечатныеФормы.Свойство(ДанныеЗапроса.ТипПечатнойФормы) Тогда
			РезультатВыполнения.Сообщение = СтрШаблон("Печатная форма для документа %1 не найдена", Строка(ДанныеЗапроса.СсылкаДокумента));
			Возврат РезультатВыполнения;
		КонецЕсли;
		ДанныеЗапроса.Вставить("ПечатнаяФорма", ПечатныеФормы[ДанныеЗапроса.ТипПечатнойФормы]);
		
		ФорматыПечатныеФормы = ДопМодульСервер.ПолучитьФорматыПечатныеФормы();
		Если Не ЗначениеЗаполнено(ДанныеЗапроса.ФорматПечатнойФормы) Тогда
			ДанныеЗапроса.ФорматПечатнойФормы = ДопМодульСервер.ПолучитьФорматПечатнойформыПоУмолчанию();
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДанныеЗапроса.ФорматПечатнойФормы) 
			Или Не ФорматыПечатныеФормы.Свойство(ДанныеЗапроса.ФорматПечатнойФормы) Тогда
			РезультатВыполнения.Сообщение = СтрШаблон("Формат печатной формы %1 для документа %2 не распознан", 
				ДанныеЗапроса.ФорматПечатнойФормы, Строка(ДанныеЗапроса.СсылкаДокумента));
			Возврат РезультатВыполнения;
		КонецЕсли;
		ДанныеЗапроса.Вставить("ФорматПечатнойФормы", ФорматыПечатныеФормы[ДанныеЗапроса.ФорматПечатнойФормы]);
		
		РезультатВыполнения.ДвоичныеДанные = ПолучитьДвоичныеДанныеДокумента(ДанныеЗапроса);
		Если Не ЗначениеЗаполнено(РезультатВыполнения.ДвоичныеДанные) Тогда
			
			МассивСообщений = ПолучитьСообщенияПользователю(Истина);   
			ТекстСообщения = "";
			Для Каждого Сообщение Из МассивСообщений Цикл
				ТекстСообщения = ТекстСообщения + ?(ЗначениеЗаполнено(ТекстСообщения), " ", "") + Сообщение.Текст;
			КонецЦикла;			
			
			РезультатВыполнения.Сообщение = ?(ЗначениеЗаполнено(ТекстСообщения),  ТекстСообщения, 
				СтрШаблон("Печатная форма ""%1"" для документа %2 не сформирована", ДанныеЗапроса.ПечатнаяФорма.Наименование, Строка(ДанныеЗапроса.СсылкаДокумента)));
			Возврат РезультатВыполнения;
		КонецЕсли;
		
		РезультатВыполнения.Результат = Истина;
		Возврат РезультатВыполнения;
	
	Исключение 
		Возврат Новый Структура("Результат, Сообщение", Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;	
	
КонецФункции

