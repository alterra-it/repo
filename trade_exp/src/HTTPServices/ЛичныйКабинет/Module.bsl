	ПечатныеФормы = ДопМодульСервер.ПолучитьПечатныеФормы();
	ТипДокумента = ТипЗнч(Документ["ДокументПродажи"]);
	
	Для Каждого Элемент Из ПечатныеФормы Цикл
		
		Если Тип(Элемент.Значение.ТипДокумента) = ТипДокумента Тогда
			
			Если Не ЗначениеЗаполнено(Элемент.Значение.Условие) 
				Или ЗначениеЗаполнено(Элемент.Значение.Условие)
					И Документ[Элемент.Значение.Условие] Тогда
			
					ЗаписьJSON.ЗаписатьНачалоОбъекта();
					
						ЗаписьJSON.ЗаписатьИмяСвойства("type");
						ЗаписьJSON.ЗаписатьЗначение(Элемент.Значение.Код);
						
						ЗаписьJSON.ЗаписатьИмяСвойства("name");
						ЗаписьJSON.ЗаписатьЗначение(Элемент.Значение.Наименование); 
					
					ЗаписьJSON.ЗаписатьКонецОбъекта();	

			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 	 
	
	ЗаписьJSON.ЗаписатьКонецМассива();
	
