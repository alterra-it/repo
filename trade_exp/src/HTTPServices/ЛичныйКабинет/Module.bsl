		ЗаписьJSON.ЗаписатьИмяСвойства("name");
		ЗаписьJSON.ЗаписатьЗначение(ТипыДокументов[Документ.ТипДокумента].Наименование); 
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();		
	
	ЗаписьJSON.ЗаписатьИмяСвойства("type");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	
		ЗаписьJSON.ЗаписатьИмяСвойства("code");
		ЗаписьJSON.ЗаписатьЗначение(ВидыДокументов[Документ.ВидДокумента].Код); 
		
		ЗаписьJSON.ЗаписатьИмяСвойства("name");
		ЗаписьJSON.ЗаписатьЗначение(ВидыДокументов[Документ.ВидДокумента].Наименование); 
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	
	ЗаписьJSON.ЗаписатьИмяСвойства("shop");
