		|	СУММА(ЕСТЬNULL(втРасчеты.ДолгКлиентаПросрочено, 0)) КАК ДолгКлиентаПросрочено,
		|	СУММА(ЕСТЬNULL(втРасчеты.НашДолг, 0)) КАК Баланс,
		|	ДоговорыКонтрагентов.ДопустимаяСуммаЗадолженности + 
		|		СУММА(ЕСТЬNULL(втРасчеты.НашДолг, 0)) - СУММА(ЕСТЬNULL(втРасчеты.ДолгКлиента, 0)) КАК ДоступноДляОтгрузки 
		|ИЗ 		
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|	СОЕДИНЕНИЕ втКонтрагенты 
		|		ПО ДоговорыКонтрагентов.Контрагент = втКонтрагенты.Контрагент 
		|		И ДоговорыКонтрагентов.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДоговоровКонтрагентов.Действует)
		|		И Не ДоговорыКонтрагентов.ПометкаУдаления
		|		И ТипДоговора = ЗНАЧЕНИЕ(Перечисление.ТипыДоговоров.СПокупателем) 
		|		И КоличествоДнейПросрочки > 0 
		|	ЛЕВОЕ СОЕДИНЕНИЕ втРасчеты
		|		ПО ДоговорыКонтрагентов.Контрагент = втРасчеты.Контрагент 
		|		И ДоговорыКонтрагентов.Ссылка = втРасчеты.Договор  
		|СГРУППИРОВАТЬ ПО
		|	ДоговорыКонтрагентов.Контрагент,
		|	ДоговорыКонтрагентов.Ссылка, 
		|	ДоговорыКонтрагентов.КоличествоДнейПросрочки,
		|	ДоговорыКонтрагентов.ДопустимаяСуммаЗадолженности
		|УПОРЯДОЧИТЬ ПО
		|	1, 2";      		
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ЭтоБригадир", ТипыКлиентов[ТипКлиента].Бригадир);
	Запрос.УстановитьПараметр("Менеджер", Менеджер);
	Запрос.УстановитьПараметр("ФорматПодразделения", Справочники.ФорматыПодразделений.НайтиПоНаименованию("ТСК"));		
	Запрос.УстановитьПараметр("ВыгружатьНаСайт", "ВыгружатьНаСайт");
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.УстановитьПараметр("Бригадиры", "%Бригадиры%");
	Запрос.УстановитьПараметр("Выгодный", "Выгодный");
	Запрос.УстановитьПараметр("Стандартный", "Стандартный");
	Запрос.УстановитьПараметр("Оптовый", "Оптовый");
	Запрос.УстановитьПараметр("ПустаяСтрока", "");   
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
		
	РезультатВыполнения = Новый Структура("ВсеСоглашенияПоВсемВидамЦен, Соглашение, Соглашения, ВидыЦен, 
		|УточненияПоЦеновымГруппам, УточненияПоТоварам, 
		|Менеджер, КонтактныеЛица, Контрагенты, Договоры", 
		ПакетЗапросов[3].Выгрузить(), ПакетЗапросов[8].Выгрузить(), ПакетЗапросов[6].Выгрузить(), ПакетЗапросов[9].Выгрузить(), 
		ПакетЗапросов[10].Выгрузить(), ПакетЗапросов[11].Выгрузить(), ПакетЗапросов[12].Выгрузить(), 
		ПакетЗапросов[13].Выгрузить(), ПакетЗапросов[17].Выгрузить(), ПакетЗапросов[18].Выгрузить());
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьБалансБонусныхБаллов(Партнер)      
	
	Запрос = Новый Запрос;
	Запрос.Текст =  	
		"ВЫБРАТЬ 
		|	СУММА(ДоступноБаллов),
		|	СУММА(ДоступноЧерезТриДня - ДоступноБаллов) КАК БаллыРезерв	
		|ИЗ 	
		|	(ВЫБРАТЬ    
		|		ЕСТЬNULL(БонусныеБаллыОстатки.НачисленоОстаток - БонусныеБаллыОстатки.ВРезервеОстаток, 0) КАК ДоступноБаллов,
		|		0 КАК ДоступноЧерезТриДня 
		|	ИЗ                 
		|		РегистрНакопления.БонусныеБаллы.Остатки(&ТекущаяДата, Партнер = &Партнер) КАК БонусныеБаллыОстатки
		|	ОБЪЕДИНИТЬ ВСЕ
		|	ВЫБРАТЬ   
		|		0 КАК ДоступноБаллов,
		|		ЕСТЬNULL(БонусныеБаллыОстатки.НачисленоОстаток - БонусныеБаллыОстатки.ВРезервеОстаток, 0) КАК ДоступноЧерезТриДня  
		|	ИЗ                 
		|		РегистрНакопления.БонусныеБаллы.Остатки(КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, 3), ДЕНЬ), Партнер = &Партнер) КАК БонусныеБаллыОстатки) КАК ББ
		|;
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Штрихкод КАК НомерКарты
		|ИЗ 
		|	Справочник.КартыЛояльности
		|ГДЕ
		|	Партнер = &Партнер
		|	И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКартЛояльности.Действует)
		|	И Владелец.Наименование = &ВидКарты";
		
	
	Запрос.УстановитьПараметр("Партнер", Партнер);  
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса()); 
	Запрос.УстановитьПараметр("ВидКарты", "Бонусная карта");
	
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	Клиент = Новый Структура("ДоступноБаллов, БаллыРезерв, НомерКарты", 0, 0, "");
	
	БонусныеБаллы = ПакетЗапросов[0].Выгрузить();
	Если БонусныеБаллы.Количество() > 0 ТОГДА
		ЗаполнитьЗначенияСвойств(Клиент, БонусныеБаллы[0]);
	КонецЕсли;
	
	БонуснаяКарта = ПакетЗапросов[1].Выгрузить();
	Если БонуснаяКарта.Количество() > 0 ТОГДА
		ЗаполнитьЗначенияСвойств(Клиент, БонуснаяКарта[0]);
	КонецЕсли;	
	
	Возврат Клиент;				
			
КонецФункции

Функция ПолучитьДостиженияСтатусов(Партнер)   
	
	Запрос = Новый Запрос;
	Запрос.Текст =     
		"ВЫБРАТЬ
		|	СУММА(ЕСТЬNULL(ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот, 0)) КАК Оборот
		|ПОМЕСТИТЬ втТекущийОборот
		|ИЗ            
		|  	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(, , Регистратор, ) КАК ВыручкаИСебестоимостьПродажОбороты
		|	ГДЕ	
		|		ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаПоПартнерам.Партнер = &Партнер
		|		И
		|		ВЫБОР
		|			КОГДА НЕ ТИПЗНАЧЕНИЯ(ВыручкаИСебестоимостьПродажОбороты.Регистратор) = ТИП(Документ.ОтчетОРозничныхПродажах)
		|				И НЕ ТИПЗНАЧЕНИЯ(ВыручкаИСебестоимостьПродажОбороты.Регистратор) = ТИП(Документ.КорректировкаРегистров)
		|			ТОГДА ВыручкаИСебестоимостьПродажОбороты.Регистратор.Кассир <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ                           
		|;	
		|//////////////////////////////////////////////////////////////////////////////////////     	
		|ВЫБРАТЬ      
		|	СтатусыПрограммыЛояльности.Наименование КАК НаименованиеСтатуса,               
		|	ЕСТЬNULL(СтатусыПартнеров.Статус = СтатусыПрограммыЛояльности.Ссылка, ЛОЖЬ) КАК АктивныйСтатус,
		|	ВЫБОР 
		|		КОГДА СтатусыПрограммыЛояльности.Ссылка <> ЗНАЧЕНИЕ(Справочник.СтатусыПартнеровВПрограммеЛояльности_Альтерра.Умелец)  
		|			И СтатусыПрограммыЛояльности.НижнийПорог - ЕСТЬNULL(втТекущийОборот.Оборот, 0) > 0 
		|		ТОГДА СтатусыПрограммыЛояльности.НижнийПорог - ЕСТЬNULL(втТекущийОборот.Оборот, 0)		
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ДоДостиженияСтатуса
		|ИЗ 
		|	Справочник.СтатусыПартнеровВПрограммеЛояльности_Альтерра КАК СтатусыПрограммыЛояльности 
		|	ПОЛНОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СрезПоследних(&ТекущаяДата, Партнер = &Партнер) КАК СтатусыПартнеров
		|		ПО Истина
		|	ПОЛНОЕ СОЕДИНЕНИЕ втТекущийОборот
		|		ПО Истина
		|ГДЕ
		|	СтатусыПрограммыЛояльности.Ссылка <> ЗНАЧЕНИЕ(Справочник.СтатусыПартнеровВПрограммеЛояльности_Альтерра.Бригадир)  
		|УПОРЯДОЧИТЬ ПО
		|	СтатусыПрограммыЛояльности.НижнийПорог";
		
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	Для Каждого Строка Из ТЗ Цикл
		Если Строка.ДоДостиженияСтатуса > 0 Тогда
			Строка.ДоДостиженияСтатуса = 0;
		КонецЕсли;
		Если Строка.АктивныйСтатус Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	                                                                    
	Возврат ТЗ;     
	
КонецФункции

Функция ПолучитьНаградуСвойЧеловек(Партнер)  
	
