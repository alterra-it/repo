Процедура ЗаписатьHTTPТовары(ЗаписьJSON, Товары)

	ЗаписьJSON.ЗаписатьИмяСвойства("products"); 
	ЗаписьJSON.ЗаписатьНачалоМассива(); 

		Для Каждого Товар Из Товары Цикл
		
		    ЗаписьJSON.ЗаписатьНачалоОбъекта();     
			
				ЗаписьJSON.ЗаписатьИмяСвойства("id");
				ЗаписьJSON.ЗаписатьЗначение(Строка(Товар.Номенклатура.УникальныйИдентификатор()));       
				
				ЗаписьJSON.ЗаписатьИмяСвойства("name");
				ЗаписьJSON.ЗаписатьЗначение(Товар.НаименованиеПолное);
				
				ЗаписьJSON.ЗаписатьИмяСвойства("articul");
				ЗаписьJSON.ЗаписатьЗначение(Товар.Код); 
				
				ЗаписьJSON.ЗаписатьИмяСвойства("service");
				ЗаписьJSON.ЗаписатьЗначение(Товар.ЭтоУслуга); 
				
				ЗаписьJSON.ЗаписатьИмяСвойства("unit");
				ЗаписьJSON.ЗаписатьЗначение(Строка(Товар.ЕдиницаИзмерения)); 
				
				ЗаписьJSON.ЗаписатьИмяСвойства("weight");
				ЗаписьJSON.ЗаписатьЗначение(Товар.Вес); 

				ЗаписьJSON.ЗаписатьИмяСвойства("weight_unit");
				ЗаписьJSON.ЗаписатьЗначение(Строка(Товар.ЕдиницаИзмеренияВеса)); 
				
