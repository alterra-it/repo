		|	ЕСТЬNULL(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.ВремяДоставкиС, ЗаказНаДоставкуКлиентуРодителя.ВремяДоставкиС) , &ПустаяСтрока) КАК ВремяДоставкиС,
		|	ЕСТЬNULL(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.ВремяДоставкиПо, ЗаказНаДоставкуКлиентуРодителя.ВремяДоставкиПо), &ПустаяСтрока) КАК ВремяДоставкиПо,
		| 	ВЫБОР 
