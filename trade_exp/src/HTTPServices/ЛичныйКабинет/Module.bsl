Функция ПолучитьКлиентовПагинацияСтраниц(ДанныеЗапроса)   
	
	ПагинацияСтраниц = Новый Структура("ВсегоЗаписей, МаксимумЗаписейНаСтранице, ТекущаяСтраница, ПоследняяСтраница, 
		|КоличествоЗаписейНаПоследнейСтранице, НомерПоследнейЗаписи", 
		0, ДанныеЗапроса.МаксимумЗаписейНаСтранице, ДанныеЗапроса.НомерСтраницы, 0, 0, 0);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ 
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Партнер) КАК Количество   
		|ИЗ      
		|	Документ.ЗаказКлиента 
		|ГДЕ
		|	НомерНаСайте <> &ПустаяСтрока";
	
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда  
		ПагинацияСтраниц.ВсегоЗаписей = Выборка.Количество;	
	КонецЕсли;     
	
	ПагинацияСтраниц.ПоследняяСтраница = Цел(ПагинацияСтраниц.ВсегоЗаписей / ПагинацияСтраниц.МаксимумЗаписейНаСтранице) +
		?(ПагинацияСтраниц.ВсегоЗаписей % ПагинацияСтраниц.МаксимумЗаписейНаСтранице > 0, 1, 0);
		
	ПагинацияСтраниц.КоличествоЗаписейНаПоследнейСтранице = 
		?(ПагинацияСтраниц.ТекущаяСтраница < ПагинацияСтраниц.ПоследняяСтраница, ПагинацияСтраниц.МаксимумЗаписейНаСтранице, 
			?(ПагинацияСтраниц.ВсегоЗаписей % ПагинацияСтраниц.МаксимумЗаписейНаСтранице > 0, 
				ПагинацияСтраниц.ВсегоЗаписей % ПагинацияСтраниц.МаксимумЗаписейНаСтранице, ПагинацияСтраниц.МаксимумЗаписейНаСтранице)); 
		
	ПагинацияСтраниц.НомерПоследнейЗаписи = ПагинацияСтраниц.ТекущаяСтраница * ПагинацияСтраниц.МаксимумЗаписейНаСтранице;
	
	Возврат ПагинацияСтраниц;
	
КонецФункции

Функция ПолучитьКлиентовТекущаяСтраница(ПагинацияСтраниц)   
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ 
		|	ПЕРВЫЕ %КоличествоЗаписейНаПоследнейСтранице *
		|ПОМЕСТИТЬ 
		|	втПартнерыПагинация
		|ИЗ 		
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ 
		|		ПЕРВЫЕ %НомерПоследнейЗаписи 
		|		Заказ.Партнер,
		|		Партнеры.НаименованиеПолное КАК ПартнерНаименование,	
		|		Партнеры.ЮрФизЛицо,
		|	    Партнеры.ПометкаУдаления       
		|	ИЗ      
		|		Документ.ЗаказКлиента КАК Заказ
		|		СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры 
		|			ПО Заказ.Партнер = Партнеры.Ссылка
		|	ГДЕ
		|		Заказ.НомерНаСайте <> &ПустаяСтрока 
		|	УПОРЯДОЧИТЬ ПО 	
		|		Партнеры.ЮрФизЛицо УБЫВ, Партнеры.НаименованиеПолное  
		|) КАК ИсходныйНабор	
		|УПОРЯДОЧИТЬ 
		|	ПО ЮрФизЛицо ВОЗР, ПартнерНаименование УБЫВ 
		|;
		|ВЫБРАТЬ
		|	ТипПокупателя.Тип,
		|	ТипПокупателя.Код
		|ПОМЕСТИТЬ
		|	втТипПокупателя
		|ИЗ
		|	&ТипПокупателя КАК ТипПокупателя		  
		|;	
		|ВЫБРАТЬ
		|	ГруппыПартнеров.Группа,
		|	ГруппыПартнеров.Код
		|ПОМЕСТИТЬ
		|	втГруппыПартнеров	
		|ИЗ
		|	&ГруппыПартнеров КАК ГруппыПартнеров		  
		|;	    
		|ВЫБРАТЬ
		|	втПартнерыПагинация.Партнер,
		|	втПартнерыПагинация.ПартнерНаименование,	
		|	ЕСТЬNULL(ПартнерыТелефон.НомерТелефона, &ПустаяСтрока) КАК НомерТелефона, 
		|	ЕСТЬNULL(ПартнерыАдресЭП.АдресЭП, &ПустаяСтрока) КАК АдресЭП,
		|	ВЫБОР 
		|		КОГДА втПартнерыПагинация.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.КомпанияЧастноеЛицо.Компания) 
		|		ТОГДА 
		|			ВЫБОР 
		|				КОГДА втТипПокупателя.Тип ЕСТЬ НЕ NULL ТОГДА втТипПокупателя.Код
		|				ИНАЧЕ &ТипПокупателяПоУмолчанию
		|			КОНЕЦ
		|		ИНАЧЕ 
		|			ВЫБОР 
		|				КОГДА втГруппыПартнеров.Группа ЕСТЬ НЕ NULL ТОГДА втГруппыПартнеров.Код 
		|				ИНАЧЕ &ТипПокупателяПоУмолчанию
		|			КОНЕЦ
		|	КОНЕЦ КАК ТипКлиента,    
		|	втПартнерыПагинация.ПометкаУдаления
		|ИЗ    
		|	втПартнерыПагинация
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыТелефон 
		|	   	ПО втПартнерыПагинация.Партнер = ПартнерыТелефон.Ссылка
		|		И ПартнерыТелефон.НомерТелефона <> &ПустаяСтрока    
		|		И ПартнерыТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыАдресЭП
		|		ПО втПартнерыПагинация.Партнер = ПартнерыАдресЭП.Ссылка
		|		И ПартнерыАдресЭП.АдресЭП <> &ПустаяСтрока   
		|		И ПартнерыАдресЭП.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера) 
		|    ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ТипПокупателяСведения
		|		ПО втПартнерыПагинация.Партнер = ТипПокупателяСведения.Ссылка
		|		И ТипПокупателяСведения.Свойство.Имя = &ИмяТипПокупателя
		|    ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ГруппыПартнеровСведения
		|		ПО втПартнерыПагинация.Партнер = ГруппыПартнеровСведения.Ссылка
		|		И ГруппыПартнеровСведения.Свойство.Имя = &ИмяГруппыПартнеров
		|	ЛЕВОЕ СОЕДИНЕНИЕ втТипПокупателя
		|		ПО ТипПокупателяСведения.Значение.Наименование = втТипПокупателя.Тип 
		|	ЛЕВОЕ СОЕДИНЕНИЕ втГруппыПартнеров
		|		ПО ГруппыПартнеровСведения.Значение.Наименование = втГруппыПартнеров.Группа 
		|УПОРЯДОЧИТЬ ПО
		|	втПартнерыПагинация.ЮрФизЛицо УБЫВ, втПартнерыПагинация.ПартнерНаименование";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%КоличествоЗаписейНаПоследнейСтранице", Формат(ПагинацияСтраниц.КоличествоЗаписейНаПоследнейСтранице, "ЧГ="));
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%НомерПоследнейЗаписи", Формат(ПагинацияСтраниц.НомерПоследнейЗаписи, "ЧГ="));

	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	
	Запрос.УстановитьПараметр("ИмяГруппыПартнеров", "ГруппыПартнеров");
	Запрос.УстановитьПараметр("ИмяТипПокупателя", "ТипПокупателя");
	
	Запрос.УстановитьПараметр("ГруппыПартнеров", ДопМодульСервер.ПолучитьГруппыПартнеров());    
	Запрос.УстановитьПараметр("ТипПокупателя", ДопМодульСервер.ПолучитьТипыПокупателей());    
	
	Запрос.УстановитьПараметр("ГруппыПартнеровПоУмолчанию", ДопМодульСервер.ПолучитьГруппуПартнеровПоУмолчанию());    
	Запрос.УстановитьПараметр("ТипПокупателяПоУмолчанию", ДопМодульСервер.ПолучитьТипПокупателяПоУмолчанию());    
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ПолучитьКлиентаПоПараметру(ПараметрКлиента)
	
	Запрос = Новый Запрос;
	Запрос.Текст =     
		"ВЫБРАТЬ
		|	Партнеры.Ссылка КАК Партнер,
		|	Партнеры.НаименованиеПолное КАК ПартнерНаименование,
		|	Партнеры.ДатаРождения,
		|	Партнеры.ЮрФизЛицо,
		|	Партнеры.БонуснаяПрограммаАктивна,
		|	Партнеры.ПИН_Код,
		|	Партнеры.БизнесРегион,		
		|	Партнеры.ОсновнойМенеджер,				
		|	Партнеры.МАП,	
		|	ЕСТЬNULL(ПартнерыТелефон.НомерТелефона, &ПустаяСтрока) КАК НомерТелефона, 
		|	ЕСТЬNULL(ПартнерыАдресЭП.АдресЭП, &ПустаяСтрока) КАК АдресЭП     
		|ИЗ 
		|	%Условие";    
	
	Если ПараметрКлиента.Свойство("Партнер") Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие", 
			"Справочник.Партнеры КАК Партнеры
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыТелефон 
		|     	ПО Партнеры.Ссылка = ПартнерыТелефон.Ссылка
		|		И ПартнерыТелефон.НомерТелефона <> &ПустаяСтрока    
//		|		И ПартнерыТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)
		|		И Партнеры.Ссылка = &Партнер	
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыАдресЭП
		|		ПО Партнеры.Ссылка = ПартнерыАдресЭП.Ссылка
		|		И ПартнерыАдресЭП.АдресЭП <> &ПустаяСтрока   
		|		И ПартнерыАдресЭП.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера) 
		|		И Партнеры.Ссылка = &Партнер	  
		|ГДЕ 
		|	Партнеры.Ссылка = &Партнер
		|	И НЕ Партнеры.ПометкаУдаления");                 
		
		Запрос.УстановитьПараметр("Партнер", ПараметрКлиента.Партнер);  
		
	ИначеЕсли ПараметрКлиента.Свойство("АдресЭП") Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие",
			"Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыАдресЭП
		|	СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры    
		|		ПО ПартнерыАдресЭП.АдресЭП = &АдресЭП
		|		И ПартнерыАдресЭП.Ссылка = Партнеры.Ссылка  
		|		И ПартнерыАдресЭП.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера) 
		|		И НЕ Партнеры.ПометкаУдаления	    		
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыТелефон  
		|		ПО Партнеры.Ссылка = ПартнерыТелефон.Ссылка
		|		И ПартнерыТелефон.НомерТелефона <> &ПустаяСтрока    
//		|		И ПартнерыТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)
		|ГДЕ				  
		|	ПартнерыАдресЭП.АдресЭП = &АдресЭП");
		
		Запрос.УстановитьПараметр("АдресЭП", ПараметрКлиента.АдресЭП);  
		
	ИначеЕсли ПараметрКлиента.Свойство("НомерТелефона") Тогда
			
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие",
			"Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыТелефон 
		|	СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		|      	ПО ПартнерыТелефон.НомерТелефона = &НомерТелефона
		|		И ПартнерыТелефон.Ссылка = Партнеры.Ссылка     
//		|		И ПартнерыТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)
		|		И НЕ Партнеры.ПометкаУдаления	    		
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыАдресЭП
		|		ПО Партнеры.Ссылка = ПартнерыАдресЭП.Ссылка
		|		И ПартнерыАдресЭП.АдресЭП <> &ПустаяСтрока 
		|		И ПартнерыАдресЭП.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера) 
		|ГДЕ
		|	ПартнерыТелефон.НомерТелефона = &НомерТелефона");	
		
		Запрос.УстановитьПараметр("НомерТелефона", ПараметрКлиента.НомерТелефона);  
	
	КонецЕсли;   
	
	Запрос.Текст = Запрос.Текст + "
		|УПОРЯДОЧИТЬ ПО
		|	Партнеры.ЮрФизЛицо УБЫВ, 
		|	Партнеры.Наименование";      
	
	Запрос.УстановитьПараметр("ПустаяСтрока", ""); 

	РезультатЗапроса = Запрос.Выполнить();         
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Структура("Результат, Сообщение", Ложь, "Клиент не найден");		
	КонецЕСли;
	
	Выборка = РезультатЗапроса.Выбрать();      
	
	Клиент = Новый Структура("Результат, Сообщение, Дубли, 
		|Партнер, ПартнерНаименование, ДатаРождения, ЮрФизЛицо, БонуснаяПрограммаАктивна, ПИН_Код, БизнесРегион, ОсновнойМенеджер, МАП, АдресЭП, НомерТелефона", 
		Истина, "", Новый Массив);	
		
	КлиентЗаписан = Ложь;
	Пока Выборка.Следующий() Цикл      
		Если Не КлиентЗаписан Тогда	
			ЗаполнитьЗначенияСвойств(Клиент, Выборка);
			КлиентЗаписан = Истина;
		Иначе     
			Дубль = Новый Структура("Партнер, ПартнерНаименование, ЮрФизЛицо, АдресЭП, НомерТелефона");
			ЗаполнитьЗначенияСвойств(Дубль, Выборка);
			Клиент.Дубли.Добавить(Дубль);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Клиент;		
	
КонецФункции

Функция ПолучитьКлиентаПоИНН(ИНН)
	
	Запрос = Новый Запрос;
	Запрос.Текст =     
		"ВЫБРАТЬ   
		|	Наименование КАК КонтрагентНаименование
		|ИЗ 
		|	Справочник.Контрагенты
		|ГДЕ 
		|	ИНН = &ИНН";
	
	Запрос.УстановитьПараметр("ИНН", ИНН);  
	
	Выборка = Запрос.Выполнить().Выбрать();      
	Если Выборка.Следующий() Тогда       
		Клиент = Новый Структура("Результат, Сообщение, КонтрагентНаименование", Истина, "");
		ЗаполнитьЗначенияСвойств(Клиент, Выборка);
	Иначе                                    
		Клиент = Новый Структура("Результат, Сообщение", Ложь, "Клиент не найден");		
	КонецЕсли;
	
	Возврат Клиент;		
	
КонецФункции

Функция ПолучитьТипКлиента(ЮрФизЛицо, Партнер)                                                 
	
	Если ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.КомпанияЧастноеЛицо.Компания") Тогда
		ТипПокупателя = ПолучитьДопРеквизитыПартнера(Партнер, "ТипПокупателя");         
		ТипКлиента = ДопМодульСервер.ПолучитьТипКлиентаПоТипуПокупателя(ТипПокупателя);     
	Иначе
		ГруппаПартнера = ПолучитьДопРеквизитыПартнера(Партнер, "ГруппыПартнеров");         
		ТипКлиента = ДопМодульСервер.ПолучитьТипКлиентаПоГруппеПартнера(ГруппаПартнера);
	КонецЕсли; 
	
	Возврат ТипКлиента;
	
КонецФункции

Функция ПолучитьДопРеквизитыПартнера(Партнер, ИмяДопРеквизита) 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДопРеквизитыПартнеры.Значение.Наименование КАК ГруппаПартнера
		|ИЗ                 
		|	Справочник.Партнеры.ДополнительныеРеквизиты КАК ДопРеквизитыПартнеры
		|ГДЕ 
		|	ДопРеквизитыПартнеры.Ссылка = &Партнер
		|	И ДопРеквизитыПартнеры.Свойство.Имя = &ИмяДопРеквизита";
			
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ИмяДопРеквизита", ИмяДопРеквизита); 
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ГруппаПартнера;		
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьУсловияПродажФЛ(ТипКлиента, Партнер)     
	
	// Соглашение/вид цены - один из списка вариантов (полный список отдельным запросом)
	
	ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();        
	
	Если Не (ТипыКлиентов[ТипКлиента].ЧастноеЛицо Или ТипыКлиентов[ТипКлиента].Сотрудник) Тогда
		Возврат Неопределено;
	КонецЕсли;		
	
	Запрос = Новый Запрос;
	
	Если ТипыКлиентов[ТипКлиента].ЧастноеЛицо Тогда      
		
		Запрос.Текст = 	
			"ВЫБРАТЬ ПЕРВЫЕ 1         
			|	Подразделение.ФорматПодразделения, 
			|	Подразделение.РегионПрисутствия,
			|	СоглашенияСКлиентами.Ссылка КАК Соглашение,
			|	СоглашенияСКлиентами.Наименование КАК СоглашениеНаименование,
			|	СоглашенияСКлиентами.ГруппаВидовЦен
			|ПОМЕСТИТЬ
			|	втСоглашение
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК Подразделение
			|	СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
			|		ПО ФорматПодразделения = &ФорматПодразделения   
			|		И Подразделение.%ВидСоглашения = СоглашенияСКлиентами.Ссылка   
			|		И СоглашенияСКлиентами.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
			|		И (СоглашенияСКлиентами.ДатаОкончанияДействия >= &ДатаДействия
			|			ИЛИ СоглашенияСКлиентами.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
			|		И (СоглашенияСКлиентами.ДатаНачалаДействия <= &ДатаДействия
			|			ИЛИ СоглашенияСКлиентами.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1))
			|УПОРЯДОЧИТЬ ПО 
			|	РегионПрисутствия
			|;";      		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ВидСоглашения", ?(ТипыКлиентов[ТипКлиента].ЧастноеЛицо, "СоглашениеСКлиентомЦенаПоКарте", "СоглашениеДляБригадиров"));
		
	ИначеЕсли ТипыКлиентов[ТипКлиента].Сотрудник Тогда 
		
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1   
			|	Подразделение.ФорматПодразделения, 
			|	Подразделение.РегионПрисутствия, 
			|	СоглашенияСКлиентами.ГруппаВидовЦен,
			|	СоглашенияСКлиентами.Соглашение,
			|	СоглашенияСКлиентами.СоглашениеНаименование
			|ПОМЕСТИТЬ
			|	втСоглашение	
			|ИЗ
			|	(ВЫБРАТЬ ПЕРВЫЕ 1 
			|		СоглашенияСКлиентами.Ссылка КАК Соглашение,
			|		СоглашенияСКлиентами.Наименование КАК СоглашениеНаименование,
			|		СоглашенияСКлиентами.ГруппаВидовЦен
			|	ИЗ 
			|		Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
			|	ГДЕ 
			|		СоглашенияСКлиентами.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
			|			И (СоглашенияСКлиентами.ДатаОкончанияДействия >= &ДатаДействия
			|				ИЛИ СоглашенияСКлиентами.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
			|			И (СоглашенияСКлиентами.ДатаНачалаДействия <= &ДатаДействия
			|				ИЛИ СоглашенияСКлиентами.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1))  
			|		И Партнер = &Партнер    
			|		
			|	ОБЪЕДИНИТЬ ВСЕ 
            |
			|	ВЫБРАТЬ ПЕРВЫЕ 1 
			|		СоглашенияСКлиентами.Ссылка КАК Соглашение,
			|		СоглашенияСКлиентами.Наименование КАК СоглашениеНаименование,
			|		СоглашенияСКлиентами.ГруппаВидовЦен
			|	ИЗ 
			|		Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
			|		СОЕДИНЕНИЕ РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента  
			|			ПО СоглашенияСКлиентами.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
			|			И (СоглашенияСКлиентами.ДатаОкончанияДействия >= &ДатаДействия
			|				ИЛИ СоглашенияСКлиентами.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
			|			И (СоглашенияСКлиентами.ДатаНачалаДействия <= &ДатаДействия
			|				ИЛИ СоглашенияСКлиентами.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1))  
			|			И СоглашенияСКлиентами.СегментПартнеров = ПартнерыСегмента.Сегмент  	
			|			И ПартнерыСегмента.Партнер = &Партнер) КАК СоглашенияСКлиентами   
			|	ПОЛНОЕ СОЕДИНЕНИЕ
			|		(ВЫБРАТЬ
			|			ФорматПодразделения, 
			|			РегионПрисутствия
			|        ИЗ
			|         	Справочник.СтруктураПредприятия
			|         ГДЕ 
			|         	ФорматПодразделения = &ФорматПодразделения
			|         	И РегионПрисутствия.Наименование = &РегионПрисутствияБарнаул) КАК Подразделение
			|		ПО ИСТИНА
			|;";     
		
		Запрос.УстановитьПараметр("Партнер", Партнер);
		Запрос.УстановитьПараметр("РегионПрисутствияБарнаул", "Барнаул");
		
	КонецЕсли;  
	
	Запрос.Текст = Запрос.Текст + 
			"ВЫБРАТЬ       
			|	втСоглашение.Соглашение,
			|	втСоглашение.СоглашениеНаименование,
			|	ВидыЦен.Ссылка КАК ВидЦены,
			|	ВидыЦен.Наименование КАК ВидЦеныНаименование
			|ИЗ
			|	втСоглашение
			|	СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
			|		ПО втСоглашение.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
			|		И втСоглашение.ФорматПодразделения = ВидыЦен.ФорматПодразделения
			|		И втСоглашение.РегионПрисутствия = ВидыЦен.РегионПрисутствия";
	
	Запрос.УстановитьПараметр("ФорматПодразделения", Справочники.ФорматыПодразделений.НайтиПоНаименованию("ТСК"));		
	Запрос.УстановитьПараметр("ДатаДействия", ТекущаяДата());				
	
	РезультатВыполнения = Новый Структура("Соглашение, СоглашениеНаименование, ВидЦены, ВидЦеныНаименование", 
		ПредопределенноеЗначение("Справочник.СоглашенияСКлиентами.ПустаяСсылка"), "", ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка"), "");
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, Выборка);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьУсловияПродажЮЛ(ТипКлиента, Партнер, Менеджер)  
	
	ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();        
	
	Если Не (ТипыКлиентов[ТипКлиента].Компания Или ТипыКлиентов[ТипКлиента].Бригадир) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 	
		"ВЫБРАТЬ
		|	Партнер,
		|	Сегмент 
