КонецФункции

#КонецОбласти   

#Область ДействияHTTPЗапросы

Функция УстановитьHTTPЗаголовки()   
	
	 Заголовки = Новый Соответствие;
	 Заголовки.Вставить("Content-Type", "application/json");
	 Заголовки.Вставить("charset", "utf-8");
	 Возврат Заголовки 
	 
 КонецФункции 
 
Функция ПолучитьПараметрыHTTPЗапроса(Запрос)           

	Параметры = Новый Структура;
	Параметры.Вставить("ТипЗапроса", Сред(Запрос.ОтносительныйURL, 2)); 
	Параметры.Вставить("БазовыйURL", Запрос.БазовыйURL); 
	Параметры.Вставить("Запрос", ПолучитьHTTPЗапрос(Запрос.БазовыйURL, Запрос.ОтносительныйURL, Запрос.ПараметрыЗапроса)); 
	Параметры.Вставить("Тело", Запрос.ПолучитьТелоКакСтроку());
	Параметры.Вставить("ДатаЗапроса", Формат(ТекущаяДатаСеанса(), "ДФ=дд.ММ.гггг ЧЧ:мм:сс"));
	Параметры.Вставить("ДатаМс", ТекущаяУниверсальнаяДатаВМиллисекундах());
	Возврат Параметры;
	
КонецФункции   

Процедура УстановитьЧисловойПараметрHTTPЗапроса(ЗначениеПараметра, ПоУмолчанию, НеМеньшеЗначения = 0);
	
	Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
		Попытка       
			ЗначениеПараметра = Число(ЗначениеПараметра);     
			Если ЗначениеПараметра <= НеМеньшеЗначения Тогда
				ЗначениеПараметра = ПоУмолчанию;	
			КонецЕсли;
		Исключение                                    
			ЗначениеПараметра = ПоУмолчанию;
		КонецПопытки;  
	Иначе
		ЗначениеПараметра = ПоУмолчанию;
	КонецЕсли;

КонецПроцедуры
 
Функция ПолучитьHTTPЗапрос(БазовыйURL, ОтносительныйURL, ПараметрыЗапроса)
	
	Запрос = БазовыйURL + ОтносительныйURL;
	
	СписокПараметров = "";
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		Если СписокПараметров = "" Тогда 
			СписокПараметров = "?"
		Иначе                   
			СписокПараметров = СписокПараметров + "&";
		КонецЕсли;
		
		СписокПараметров = СписокПараметров + ПараметрЗапроса.Ключ + "=" + СтрЗаменить(ПараметрЗапроса.Значение, " ", "%20");
	КонецЦикла;

	Запрос = Запрос + СписокПараметров;
	Возврат Запрос   
	
КонецФункции 

Функция ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, РезультатЗапроса)   
	
	Ответ = Новый HTTPСервисОтвет(200);   
	Ответ.Заголовки = УстановитьHTTPЗаголовки();
	
	ЗаписьJSON = Новый ЗаписьJSON;                                                                   
	ЗаписьJSON.ПроверятьСтруктуру = Ложь;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( , Символы.Таб);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);

	ЗаписьJSON.ЗаписатьНачалоОбъекта();
		
		ЗаписьJSON.ЗаписатьИмяСвойства("error");
		ЗаписьJSON.ЗаписатьЗначение(Ложь);
		
		ЗаписьJSON.ЗаписатьИмяСвойства("data");
		ЗаписьJSON.ЗаписатьНачалоОбъекта();  
		
		ЗаписатьHTTPПолучениеКлиентов(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);
		ЗаписатьHTTPПолучениеКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);
		ЗаписатьHTTPСозданиеКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);           
		ЗаписатьHTTPИзменениеКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса); 
		ЗаписатьHTTPЗавершениеДействияКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса); 
		ЗаписатьHTTPПолучениеДокументов(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);
		ЗаписатьHTTPПолучениеДокумента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);
			
		ЗаписьJSON.ЗаписатьКонецОбъекта();
	ЗаписьJSON.ЗаписатьКонецОбъекта();			
		 
	СтрокаJSON = ЗаписьJSON.Закрыть();   

	ДопМодульСервер.ЗаписатьЛогЛК(ПараметрыВходногоЗапроса, СтрокаJSON);
	
	Ответ.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);
	Возврат Ответ; 
	
КонецФункции   

Процедура ЗаписатьHTTPПолучениеКлиентов(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "clients.get" Тогда 
		Возврат;
	КонецЕсли;    
	
	ЗаписатьHTTPПагинацию(ЗаписьJSON, РезультатЗапроса.ПагинацияСтраниц);
	ЗаписатьHTTPПолучениеИнформацииКлиента(ЗаписьJSON, РезультатЗапроса);
	
КонецПроцедуры  

Процедура ЗаписатьHTTPПолучениеИнформацииКлиента(ЗаписьJSON, РезультатЗапроса)
	
	ЗаписьJSON.ЗаписатьИмяСвойства("clients");
	ЗаписьJSON.ЗаписатьНачалоМассива();    
	
	ОсновныеДанные = РезультатЗапроса.ОсновныеДанные; 
	
	Если ЗначениеЗаполнено(ОсновныеДанные) Тогда
		
		Для Каждого Клиент Из ОсновныеДанные Цикл  
			
			ЗаписьJSON.ЗаписатьНачалоОбъекта(); 
		
			ЗаписьJSON.ЗаписатьИмяСвойства("type");
			ЗаписьJSON.ЗаписатьЗначение(Клиент.ТипКлиента);         
			
			ЗаписьJSON.ЗаписатьИмяСвойства("user_id");
			ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(Клиент.Партнер));

			ЗаписьJSON.ЗаписатьИмяСвойства("name");
			ЗаписьJSON.ЗаписатьЗначение(Клиент.ПартнерНаименование);
			
			ЗаписьJSON.ЗаписатьИмяСвойства("email");
			ЗаписьJSON.ЗаписатьЗначение(Клиент.АдресЭП);

			ЗаписьJSON.ЗаписатьИмяСвойства("phone");     
			ЗаписьJSON.ЗаписатьЗначение(Клиент.НомерТелефона);  
			
			Если Клиент.ПометкаУдаления Тогда
				ЗаписьJSON.ЗаписатьИмяСвойства("del_mark");     
				ЗаписьJSON.ЗаписатьЗначение(Клиент.ПометкаУдаления);  
			КонецЕсли;			
			
			ЗаписьJSON.ЗаписатьКонецОбъекта(); 
		КонецЦикла;
	КонецЕсли;

	ЗаписьJSON.ЗаписатьКонецМассива();
	
КонецПроцедуры

Процедура ЗаписатьHTTPПолучениеКлиента(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "client.get" Тогда 
		Возврат;
	КонецЕсли;         
	
	ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();      
	ТипКлиента = ТипыКлиентов[РезультатЗапроса.ТипКлиента];
	
	ЗаписьJSON.ЗаписатьИмяСвойства("type");
	ЗаписьJSON.ЗаписатьЗначение(ТипКлиента.Код);         
	
	ОсновныеДанные = РезультатЗапроса.ОсновныеДанные; 
	
	ЗаписьJSON.ЗаписатьИмяСвойства("user_id");
	ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(ОсновныеДанные.Партнер));

	ЗаписьJSON.ЗаписатьИмяСвойства("name");
	ЗаписьJSON.ЗаписатьЗначение(ОсновныеДанные.ПартнерНаименование);
	
	Если ЗначениеЗаполнено(ОсновныеДанные.ДатаРождения) Тогда
		ЗаписьJSON.ЗаписатьИмяСвойства("birthday");
		ЗаписьJSON.ЗаписатьЗначение(Формат(ОсновныеДанные.ДатаРождения, "ДФ=дд.ММ.гггг"));
	КонецЕсли;
	
	ЗаписьJSON.ЗаписатьИмяСвойства("email");
	ЗаписьJSON.ЗаписатьЗначение(ОсновныеДанные.АдресЭП);

	ЗаписьJSON.ЗаписатьИмяСвойства("phone");     
	ЗаписьJSON.ЗаписатьЗначение(ОсновныеДанные.НомерТелефона);  
	
	ЗаписатьHTTPИзмененияКлиентаВОчереди(ЗаписьJSON, РезультатЗапроса);
	
	ЗаписатьДублиКлиента(ЗаписьJSON, РезультатЗапроса);
	
	Если ЗначениеЗаполнено(РезультатЗапроса.Синхронизация) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьHTTPНаграды(ТипКлиента, ЗаписьJSON, РезультатЗапроса);
	ЗаписатьHTTPБонуснуюПрограмму(ТипКлиента, ЗаписьJSON, РезультатЗапроса);
	ЗаписатьHTTPУсловияПродажЮЛ(ТипКлиента, ЗаписьJSON, РезультатЗапроса);
	
КонецПроцедуры    

Процедура ЗаписатьHTTPИзмененияКлиентаВОчереди(ЗаписьJSON, РезультатЗапроса)
	
	ИзмененияВОчереди = РезультатЗапроса.ИзмененияВОчереди;
	
	Если ТипЗнч(ИзмененияВОчереди) = Тип("Структура") И ИзмененияВОчереди.Свойство("ВСостоянииИзменения") Тогда
	
	ЗаписьJSON.ЗаписатьИмяСвойства("in_changing");
	ЗаписьJSON.ЗаписатьЗначение(ИзмененияВОчереди.ВСостоянииИзменения);
	
	Если ИзмененияВОчереди.ВСостоянииИзменения И Значениезаполнено(ИзмененияВОчереди.ДатаИзменения) Тогда
		ЗаписьJSON.ЗаписатьИмяСвойства("in_changing_date");
		ЗаписьJSON.ЗаписатьЗначение(Формат(ИзмененияВОчереди.ДатаИзменения, "ДФ=дд.ММ.гггг ЧЧ:мм:сс")); ;
	КонецЕсли;
	
	КонецЕсли; 
	
КонецПроцедуры	

Процедура ЗаписатьДублиКлиента(ЗаписьJSON, РезультатЗапроса)
	
	Если РезультатЗапроса.ОсновныеДанные.Дубли.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;       
	
	ТипыКлиентов = ДопМодульСервер.ПолучитьТипыКлиентов();      
	
	ЗаписьJSON.ЗаписатьИмяСвойства("doubles");
	ЗаписьJSON.ЗаписатьНачалоМассива();
	
		Для Каждого Дубль Из РезультатЗапроса.ОсновныеДанные.Дубли Цикл
			
			ЗаписьJSON.ЗаписатьНачалоОбъекта(); 
				
				ТипКлиента = ТипыКлиентов[Дубль.ТипКлиента];
			
				ЗаписьJSON.ЗаписатьИмяСвойства("type");
				ЗаписьJSON.ЗаписатьЗначение(ТипКлиента.Код);         
				
				ЗаписьJSON.ЗаписатьИмяСвойства("user_id");
				ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(Дубль.Партнер));

				ЗаписьJSON.ЗаписатьИмяСвойства("name");
				ЗаписьJSON.ЗаписатьЗначение(Дубль.ПартнерНаименование);
				
				ЗаписьJSON.ЗаписатьИмяСвойства("email");
				ЗаписьJSON.ЗаписатьЗначение(Дубль.АдресЭП);

				ЗаписьJSON.ЗаписатьИмяСвойства("phone");     
				ЗаписьJSON.ЗаписатьЗначение(Дубль.НомерТелефона);  
			
			ЗаписьJSON.ЗаписатьКонецОбъекта();				
			
		КонецЦикла;
		
	ЗаписьJSON.ЗаписатьКонецМассива()
	
КонецПроцедуры	

Процедура ЗаписатьHTTPНаграды(ТипКлиента, ЗаписьJSON, РезультатЗапроса) 
	
	ЗаписьJSON.ЗаписатьИмяСвойства("awards");      
	ЗаписьJSON.ЗаписатьНачалоМассива();     
	
	Для Каждого Награда Из РезультатЗапроса.Награды Цикл

		ЗаписьJSON.ЗаписатьНачалоОбъекта();     
	
			ЗаписьJSON.ЗаписатьИмяСвойства("name"); 
			ЗаписьJSON.ЗаписатьЗначение(Награда.Наименование);
			
		ЗаписьJSON.ЗаписатьКонецОбъекта();
						
	КонецЦикла;
			
	ЗаписьJSON.ЗаписатьКонецМассива();	
	
КонецПроцедуры   

Процедура ЗаписатьHTTPБонуснуюПрограмму(ТипКлиента, ЗаписьJSON, РезультатЗапроса) 
	
	Если Не ТипКлиента.ФЛ Тогда 
		Возврат;	
	КонецЕсли;
		
	ЗаписьJSON.ЗаписатьИмяСвойства("loyalty");      
	ЗаписьJSON.ЗаписатьНачалоОбъекта();     
	
		ЗаписьJSON.ЗаписатьИмяСвойства("active"); 
		ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.ОсновныеДанные.БонуснаяПрограммаАктивна);
		
		Если ТипКлиента.УчастиеБП Тогда  
			
			ЗаписьJSON.ЗаписатьИмяСвойства("card_number"); 
			ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.БалансБонусныхБаллов.НомерКарты);
			
			ЗаписьJSON.ЗаписатьИмяСвойства("balance");     
			ЗаписьJSON.ЗаписатьНачалоОбъекта();     
			
				ЗаписьJSON.ЗаписатьИмяСвойства("active");     
				ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.БалансБонусныхБаллов.ДоступноБаллов);
				
				ЗаписьJSON.ЗаписатьИмяСвойства("non_active");     
				ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.БалансБонусныхБаллов.БаллыРезерв);
			
			ЗаписьJSON.ЗаписатьКонецОбъекта();				
		КонецЕсли;
			
		Если ТипКлиента.ЧастноеЛицо Тогда
			ЗаписьJSON.ЗаписатьИмяСвойства("pin");     
			ЗаписьJSON.ЗаписатьЗначение(Ложь);     
			
		ИначеЕсли ТипКлиента.Бригадир Тогда
			ЗаписьJSON.ЗаписатьИмяСвойства("pin");     
			ЗаписьJSON.ЗаписатьЗначение(РезультатЗапроса.ОсновныеДанные.ПИН_Код);  
		КонецЕсли;	                    
		
		ЗаписатьHTTPУсловияПродажФЛ(ТипКлиента, ЗаписьJSON, РезультатЗапроса); 
		ЗаписатьHTTPДостиженияСтатусов(ТипКлиента, ЗаписьJSON, РезультатЗапроса);
			
	ЗаписьJSON.ЗаписатьКонецОбъекта();	
	
КонецПроцедуры    

Процедура ЗаписатьHTTPУсловияПродажФЛ(ТипКлиента, ЗаписьJSON, РезультатЗапроса)           
	
	Если Не (ТипКлиента.ЧастноеЛицо Или ТипКлиента.Сотрудник) Тогда 
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РезультатЗапроса.УсловияПродаж) Тогда
		Возврат;
	КонецЕсли;

	УсловияПродаж = РезультатЗапроса.УсловияПродаж;
	
	ЗаписьJSON.ЗаписатьИмяСвойства("tariff");     
	ЗаписьJSON.ЗаписатьНачалоОбъекта(); 
	
		ЗаписьJSON.ЗаписатьИмяСвойства("code");     
		ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(УсловияПродаж.Соглашение));
		
		ЗаписьJSON.ЗаписатьИмяСвойства("code_name");     
		ЗаписьJSON.ЗаписатьЗначение(УсловияПродаж.СоглашениеНаименование);      
		
		ЗаписьJSON.ЗаписатьИмяСвойства("price_code");     
		ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(УсловияПродаж.ВидЦены));  
		
		ЗаписьJSON.ЗаписатьИмяСвойства("price_code_name");     
		ЗаписьJSON.ЗаписатьЗначение(УсловияПродаж.ВидЦеныНаименование);      
		
	ЗаписьJSON.ЗаписатьКонецОбъекта()
	
КонецПроцедуры

Процедура ЗаписатьHTTPУсловияПродажЮЛ(ТипКлиента, ЗаписьJSON, РезультатЗапроса) 
	
	Если Не (ТипКлиента.Компания Или ТипКлиента.Бригадир) Тогда 
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(РезультатЗапроса.УсловияПродаж) Или РезультатЗапроса.УсловияПродаж.Соглашение.Количество() = 0  Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьJSON.ЗаписатьИмяСвойства("business_region");     
	ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(РезультатЗапроса.ОсновныеДанные.БизнесРегион));  
	
	ЗаписьJSON.ЗаписатьИмяСвойства("business_region_name");     
	ЗаписьJSON.ЗаписатьЗначение(Строка(РезультатЗапроса.ОсновныеДанные.БизнесРегион));  
	
	ЗаписьJSON.ЗаписатьИмяСвойства("legal_entity");     
	ЗаписьJSON.ЗаписатьЗначение(Истина);
	
	Соглашение = ?(РезультатЗапроса.УсловияПродаж.Соглашение.Количество() > 0, РезультатЗапроса.УсловияПродаж.Соглашение[0], "");
	
	ЗаписьJSON.ЗаписатьИмяСвойства("agreement");     
	ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), XMLСтрока(Соглашение.Соглашение), ""));
	
	ЗаписьJSON.ЗаписатьИмяСвойства("agreement_name");     
	ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), Соглашение.СоглашениеНаименование, ""));
	
	ЗаписьJSON.ЗаписатьИмяСвойства("price_type");     
	ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), XMLСтрока(Соглашение.ВидЦены), ""));
	
	ЗаписьJSON.ЗаписатьИмяСвойства("price_type_name");     
	ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), Соглашение.ВидЦеныНаименование, ""));
	
	ЗаписьJSON.ЗаписатьИмяСвойства("extra");      
	ЗаписьJSON.ЗаписатьНачалоОбъекта();   
		
		ЗаписьJSON.ЗаписатьИмяСвойства("card");     
		ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), Соглашение.ОплатаКартой, ""));
		
		ЗаписьJSON.ЗаписатьИмяСвойства("delay");     
		ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), Соглашение.Отсрочка, ""));
		
		ЗаписьJSON.ЗаписатьИмяСвойства("delivery");     
		ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), Соглашение.Доставка, ""));

	ЗаписьJSON.ЗаписатьКонецОбъекта();      
	
    // Менеджер
	ЗаписьJSON.ЗаписатьИмяСвойства("personal_manager");   
	ЗаписьJSON.ЗаписатьНачалоОбъекта();      
	
	Для Каждого Менеджер Из РезультатЗапроса.УсловияПродаж.Менеджер Цикл                            	

			ЗаписьJSON.ЗаписатьИмяСвойства("name");     
			ЗаписьJSON.ЗаписатьЗначение(Менеджер.Наименование);  
			
			ЗаписьJSON.ЗаписатьИмяСвойства("phone");     
			ЗаписьJSON.ЗаписатьЗначение(Менеджер.НомерТелефона);
			
			ЗаписьJSON.ЗаписатьИмяСвойства("email");     
			ЗаписьJSON.ЗаписатьЗначение(Менеджер.АдресЭП);   
			
			ЗаписьJSON.ЗаписатьИмяСвойства("office");     
			ЗаписьJSON.ЗаписатьЗначение(Менеджер.Адрес);   
	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();      
	
    // Контрагенты
	ЗаписьJSON.ЗаписатьИмяСвойства("counterparties");   
	ЗаписьJSON.ЗаписатьНачалоМассива(); 
	
	Для Каждого Контрагент Из РезультатЗапроса.УсловияПродаж.Контрагенты Цикл                            	
		
		ЗаписьJSON.ЗаписатьНачалоОбъекта();   
		
			ЗаписьJSON.ЗаписатьИмяСвойства("user_id");     
			ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(Контрагент.Контрагент));  
			
			ЗаписьJSON.ЗаписатьИмяСвойства("name");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.КонтрагентНаименование);  
			
			ЗаписьJSON.ЗаписатьИмяСвойства("shipment_limit");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.ДопустимаяСуммаЗадолженности);   

			ЗаписьJSON.ЗаписатьИмяСвойства("shipment_delay_days");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.КоличествоДнейПросрочки);   
			
			ЗаписьJSON.ЗаписатьИмяСвойства("balance");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.Баланс);   

			ЗаписьJSON.ЗаписатьИмяСвойства("available_for_shipment");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.ДоступноДляОтгрузки);   

			ЗаписьJSON.ЗаписатьИмяСвойства("debt");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.ДолгКлиента);   

			ЗаписьJSON.ЗаписатьИмяСвойства("overdue_debt");     
			ЗаписьJSON.ЗаписатьЗначение(Контрагент.ДолгКлиентаПросрочено); 
			
			// Добавление договоров контрагента по этому контрагенту
			ДоговорыКонтрагента = РезультатЗапроса.УсловияПродаж.Договоры.НайтиСтроки(Новый Структура("Контрагент", Контрагент.Контрагент));
			Если ДоговорыКонтрагента.Количество() > 1 Тогда
				
				ЗаписьJSON.ЗаписатьИмяСвойства("contracts");   
				ЗаписьJSON.ЗаписатьНачалоМассива(); 
				
					Для Каждого Договор Из ДоговорыКонтрагента Цикл
				
						ЗаписьJSON.ЗаписатьНачалоОбъекта();  
						
							ЗаписьJSON.ЗаписатьИмяСвойства("id");     
							ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(Договор.Договор));  
							
							ЗаписьJSON.ЗаписатьИмяСвойства("name");     
							ЗаписьJSON.ЗаписатьЗначение(Строка(Договор.Договор));    
							
							ЗаписьJSON.ЗаписатьИмяСвойства("shipment_limit");     
							ЗаписьJSON.ЗаписатьЗначение(Договор.ДопустимаяСуммаЗадолженности);   

							ЗаписьJSON.ЗаписатьИмяСвойства("shipment_delay_days");     
							ЗаписьJSON.ЗаписатьЗначение(Договор.КоличествоДнейПросрочки);   
							
							ЗаписьJSON.ЗаписатьИмяСвойства("balance");     
							ЗаписьJSON.ЗаписатьЗначение(Договор.Баланс);   

							ЗаписьJSON.ЗаписатьИмяСвойства("available_for_shipment");     
							ЗаписьJSON.ЗаписатьЗначение(Договор.ДоступноДляОтгрузки);   

							ЗаписьJSON.ЗаписатьИмяСвойства("debt");     
							ЗаписьJSON.ЗаписатьЗначение(Договор.ДолгКлиента);   

							ЗаписьJSON.ЗаписатьИмяСвойства("overdue_debt");     
							ЗаписьJSON.ЗаписатьЗначение(Договор.ДолгКлиентаПросрочено); 
					
						ЗаписьJSON.ЗаписатьКонецОбъекта();
						
					КонецЦикла;	
				
				ЗаписьJSON.ЗаписатьКонецМассива(); 
			КонецЕсли;
			
		ЗаписьJSON.ЗаписатьКонецОбъекта();      

	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецМассива();	
	
    // Контактные лица
	ЗаписьJSON.ЗаписатьИмяСвойства("contacts");   
	ЗаписьJSON.ЗаписатьНачалоМассива(); 
	
	Для Каждого КонтактноеЛицо Из РезультатЗапроса.УсловияПродаж.КонтактныеЛица Цикл                            	
		
		ЗаписьJSON.ЗаписатьНачалоОбъекта();   
		
			//ЗаписьJSON.ЗаписатьИмяСвойства("id");     
			//ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(КонтактноеЛицо.КонтактноеЛицо));  
			
			ЗаписьJSON.ЗаписатьИмяСвойства("name");     
			ЗаписьJSON.ЗаписатьЗначение(КонтактноеЛицо.КонтактноеЛицоНаименование);   
			
			ЗаписьJSON.ЗаписатьИмяСвойства("phone");     
			ЗаписьJSON.ЗаписатьЗначение(КонтактноеЛицо.НомерТелефона);  
			
			ЗаписьJSON.ЗаписатьИмяСвойства("role");     
			ЗаписьJSON.ЗаписатьЗначение(Строка(КонтактноеЛицо.Роль));  
		
		ЗаписьJSON.ЗаписатьКонецОбъекта();      

	КонецЦикла;
	
	ЗаписьJSON.ЗаписатьКонецМассива();      
	
	// Все соглашения с приоритетами
	ЗаписьJSON.ЗаписатьИмяСвойства("agreements");      
	ЗаписьJSON.ЗаписатьНачалоМассива();     
	
	Для Каждого СоглашениеСПриоритетом Из РезультатЗапроса.УсловияПродаж.Соглашения Цикл
		
		ЗаписьJSON.ЗаписатьНачалоОбъекта();   
		
			ЗаписьJSON.ЗаписатьИмяСвойства("id");     
			ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(СоглашениеСПриоритетом.Соглашение));
			
			ЗаписьJSON.ЗаписатьИмяСвойства("name");     
			ЗаписьJSON.ЗаписатьЗначение(СоглашениеСПриоритетом.СоглашениеНаименование);
		
			ЗаписьJSON.ЗаписатьИмяСвойства("price_type");     
			ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), XMLСтрока(СоглашениеСПриоритетом.ВидЦены), ""));
			
			ЗаписьJSON.ЗаписатьИмяСвойства("price_type_name");     
			ЗаписьJSON.ЗаписатьЗначение(?(ЗначениеЗаполнено(Соглашение), СоглашениеСПриоритетом.ВидЦеныНаименование, ""));     
			
			// Все виды цен для соглашений бригадиров
			Если ТипКлиента.Бригадир Тогда
				
				ЗаписьJSON.ЗаписатьИмяСвойства("price_type_list");      
				ЗаписьJSON.ЗаписатьНачалоМассива();     
				
				ВсеСоглашенияПоВсемВидамЦен = РезультатЗапроса.УсловияПродаж.ВсеСоглашенияПоВсемВидамЦен;
				ВидыЦен = ВсеСоглашенияПоВсемВидамЦен.НайтиСтроки(Новый Структура("Соглашение", СоглашениеСПриоритетом.Соглашение));

				Для Каждого ВидЦены Из ВидыЦен Цикл          
					
					ЗаписьJSON.ЗаписатьНачалоОбъекта(); 
					
						ЗаписьJSON.ЗаписатьИмяСвойства("shop");     
						ЗаписьJSON.ЗаписатьЗначение(ВидЦены.ИдентификаторСайта);

						ЗаписьJSON.ЗаписатьИмяСвойства("price_type");     
						ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(ВидЦены.ВидЦены));

						ЗаписьJSON.ЗаписатьИмяСвойства("price_type_name");     
						ЗаписьJSON.ЗаписатьЗначение(ВидЦены.ВидЦеныНаименование);
						
					ЗаписьJSON.ЗаписатьКонецОбъекта();  
					
				КонецЦикла;					
					
				ЗаписьJSON.ЗаписатьКонецМассива();

			КонецЕсли;		
			
			ЗаписьJSON.ЗаписатьИмяСвойства("priority");     
			ЗаписьJSON.ЗаписатьЗначение(СоглашениеСПриоритетом.Приоритет);
			
			Если ТипКлиента.Бригадир Тогда
				ЗаписатьHTTPУточнения(СоглашениеСПриоритетом, ЗаписьJSON, РезультатЗапроса);
			КонецЕсли;		
	
		 ЗаписьJSON.ЗаписатьКонецОбъекта();      
	 
	КонецЦикла;
	 
	ЗаписьJSON.ЗаписатьКонецМассива();  	
	
	// Виды цен по магазину (идентификатору сайта)
	ЗаписьJSON.ЗаписатьИмяСвойства("default_prices");      
	ЗаписьJSON.ЗаписатьНачалоМассива();     
	
