		|ВЫБРАТЬ
		|	ДокументПродажи,
		|	СуммаФискальнойОплаты,
		|	ФискальныйНомер, 
		|	ФискальныйДокумент,
		|	СсылкаКассовыйЧек
		|ИЗ 
		|	втДокументыОплаты	
		|;		
		|
		|// Товары документов
		|////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ  
		|	втДокументыИтог.ДокументПродажи,
		|	ТоварыДокумента.НомерСтроки,
		|	ТоварыДокумента.Номенклатура,
		|	СпрНоменклатура.НаименованиеПолное,
		|	СпрНоменклатура.Код,
		|	ВЫБОР 
		|		КОГДА
		|			СпрНоменклатура.ВесЗнаменатель <> 0 
		|		ТОГДА
		|			СпрНоменклатура.ВесЧислитель/СпрНоменклатура.ВесЗнаменатель
		|		ИНАЧЕ 0 
		|	КОНЕЦ КАК Вес,
		|	СпрНоменклатура.ВесЕдиницаИзмерения КАК ЕдиницаИзмеренияВеса,
		|	СпрНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,    
		|	СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга) КАК ЭтоУслуга,
		|	ВЫБОР     
		|		КОГДА втДокументыИтог.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 0
		|				ИНАЧЕ ВЫРАЗИТЬ((ТоварыДокумента.Сумма + ТоварыДокумента.СуммаРТ) / ТоварыДокумента.КоличествоУпаковок КАК ЧИСЛО(15,2))
		|			КОНЕЦ
		|		ИНАЧЕ ВЫРАЗИТЬ(ТоварыДокумента.Сумма / ТоварыДокумента.КоличествоУпаковок КАК ЧИСЛО(15,2))
		|	КОНЕЦ КАК Цена,
		|	ВЫБОР     
		|		КОГДА втДокументыИтог.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 1
		|				ИНАЧЕ ТоварыДокумента.КоличествоУпаковок
		|			КОНЕЦ
		|		ИНАЧЕ ТоварыДокумента.КоличествоУпаковок
		|	КОНЕЦ КАК Количество,
		|	ВЫБОР     
		|		КОГДА втДокументыИтог.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 0
		|				ИНАЧЕ ТоварыДокумента.Сумма + ТоварыДокумента.СуммаРТ
		|			КОНЕЦ
		|		ИНАЧЕ ТоварыДокумента.Сумма
		|	КОНЕЦ КАК Сумма
		|%втТоварыПоместить	
		|//ПОМЕСТИТЬ втТовары	
		|ИЗ 
		|	втДокументыИтог	     
		|	СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ТоварыДокумента
		|		ПО втДокументыИтог.ТипДокумента = &Заказ
		|		И втДокументыИтог.ДокументПродажи = ТоварыДокумента.Ссылка   
		|		И НЕ ТоварыДокумента.Отменено    
		|	СОЕДИНЕНИЕ 
		|		Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО ТоварыДокумента.Номенклатура = СпрНоменклатура.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|			СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТовары
		|				ПО Реализация.Ссылка = РеализацияТовары.Ссылка
		|			ПО втДокументыИтог.ДокументПродажи = Реализация.ЗаказКлиента
		|				И Реализация.Проведен
		|				И ТоварыДокумента.КодСтроки = РеализацияТовары.КодСтроки
		|ГДЕ 
		|	РеализацияТовары.КодСтроки ЕСТЬ NULL
		|		
		|ОБЪЕДИНИТЬ ВСЕ  
		|
		|ВЫБРАТЬ  
		|	втДокументыИтог.ДокументПродажи,    
		|	ТоварыДокумента.НомерСтроки,
		|	ТоварыДокумента.Номенклатура, 
		|	СпрНоменклатура.НаименованиеПолное,
		|	СпрНоменклатура.Код,
		|	ВЫБОР 
		|		КОГДА
		|			СпрНоменклатура.ВесЗнаменатель <> 0 
		|		ТОГДА
		|			СпрНоменклатура.ВесЧислитель/СпрНоменклатура.ВесЗнаменатель
		|		ИНАЧЕ 0 
		|	КОНЕЦ КАК Вес,
		|	СпрНоменклатура.ВесЕдиницаИзмерения КАК ЕдиницаИзмеренияВеса,
		|	СпрНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения, 
		|	СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга) КАК ЭтоУслуга,
		|	ВЫБОР     
		|		КОГДА втДокументыИтог.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 0
		|				ИНАЧЕ ВЫРАЗИТЬ((ТоварыДокумента.Сумма + ТоварыДокумента.СуммаРТ) / ТоварыДокумента.КоличествоУпаковок КАК ЧИСЛО(15, 2))
		|			КОНЕЦ
		|		ИНАЧЕ ВЫРАЗИТЬ(ТоварыДокумента.Сумма / ТоварыДокумента.КоличествоУпаковок КАК ЧИСЛО(15, 2))
		|	КОНЕЦ КАК Цена,
		|	ВЫБОР     
		|		КОГДА втДокументыИтог.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 1
		|				ИНАЧЕ ТоварыДокумента.КоличествоУпаковок
		|			КОНЕЦ
		|		ИНАЧЕ ТоварыДокумента.КоличествоУпаковок
		|	КОНЕЦ КАК Количество,
		|	ВЫБОР     
		|		КОГДА втДокументыИтог.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 0
		|				ИНАЧЕ ТоварыДокумента.Сумма + ТоварыДокумента.СуммаРТ
		|			КОНЕЦ
		|		ИНАЧЕ ТоварыДокумента.Сумма
		|	КОНЕЦ КАК Сумма
		|ИЗ 
		|	втДокументыИтог	     
		|	СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК ТоварыДокумента
		|		ПО втДокументыИтог.ТипДокумента = &Реализация
		|		И втДокументыИтог.ДокументПродажи = ТоварыДокумента.Ссылка    
		|	СОЕДИНЕНИЕ 
		|		Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО ТоварыДокумента.Номенклатура = СпрНоменклатура.Ссылка
		|		
		|ОБЪЕДИНИТЬ ВСЕ		
		|		
		|ВЫБРАТЬ  
		|	втДокументыИтог.ДокументПродажи,  
		|	ТоварыДокумента.НомерСтроки,
		|	ТоварыДокумента.Номенклатура, 
		|	СпрНоменклатура.НаименованиеПолное,  
		|	СпрНоменклатура.Код,  
		|	ВЫБОР 
		|		КОГДА
		|			СпрНоменклатура.ВесЗнаменатель <> 0 
		|		ТОГДА
		|			СпрНоменклатура.ВесЧислитель/СпрНоменклатура.ВесЗнаменатель
		|		ИНАЧЕ 0 
		|	КОНЕЦ КАК Вес,
		|	СпрНоменклатура.ВесЕдиницаИзмерения КАК ЕдиницаИзмеренияВеса,
		|	СпрНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,  
		|	СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга) КАК ЭтоУслуга,
		|	ВЫРАЗИТЬ(ТоварыДокумента.Сумма / ТоварыДокумента.КоличествоУпаковок КАК ЧИСЛО(15,2)) КАК Цена,
		|	ТоварыДокумента.КоличествоУпаковок КАК Количество,	
		|	ТоварыДокумента.Сумма КАК Сумма
		|ИЗ 
		|	втДокументыИтог	     
		|	СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ТоварыДокумента
		|		ПО втДокументыИтог.ТипДокумента = &Чек
		|		И втДокументыИтог.ДокументПродажи = ТоварыДокумента.Ссылка      
		|	СОЕДИНЕНИЕ 
		|		Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО ТоварыДокумента.Номенклатура = СпрНоменклатура.Ссылка  
		|%втТоварыУпорядочить
		|//УПОРЯДОЧИТЬ ПО 2
		|;" 
		+ ?(ВсеДокументы, ПолучитьТекстТоварыАдреса(), ""); 	
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрПартнер" , ?(ВсеДокументы, "И Документы.Партнер = &Партнер", ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрДокументОтменен" , ?(ВсеДокументы, "И Документы.Партнер = &Партнер", 
			"И Документы.Партнер В (ВЫБРАТЬ РАЗЛИЧНЫЕ Партнер ИЗ втДокументы)"));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%втТоварыПоместить", ?(ВсеДокументы, "ПОМЕСТИТЬ втТовары", ""));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%втТоварыУпорядочить", ?(ВсеДокументы, "", "УПОРЯДОЧИТЬ ПО 2"));
		
		
		Возврат ТекстЗапроса;	

КонецФункции

Функция ПолучитьТекстСтатусОтгрузки()
	
	Возврат
		" 	
		| 	// Статус отгрузки
		| 	ВЫБОР               
		| 		// Без доставки
		| 		КОГДА ЕСТЬNULL(ЗаказНаДоставкуКлиенту.Ссылка, ЗаказНаДоставкуКлиентуРодителя.Ссылка) ЕСТЬ NULL ТОГДА
		| 			ВЫБОР      
		| 				// Заказ
		| 				КОГДА втДокументы.ТипДокумента = &Заказ 
		| 					И втДокументы.СтатусЗаказа ЕСТЬ НЕ NULL
		| 				ТОГДА втДокументы.СтатусЗаказа
		| 				КОГДА втДокументы.ТипДокумента В (&Заказ, &Реализация)
		| 					И втДокументы.СостояниеЗаказа = ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказовКлиентов.Закрыт)
		| 				ТОГДА &СтатусОтгружен
		| 				КОГДА втДокументы.ТипДокумента = &Заказ 
		| 				ТОГДА &СтатусЖдетОтгрузки     
		| 				// Реализация
		| 				КОГДА втДокументы.ТипДокумента = &Реализация И втДокументы.ОтметкаКассы
		| 				ТОГДА &СтатусОтгружен
		| 				КОГДА втДокументы.ТипДокумента = &Реализация
		| 				ТОГДА &СтатусЖдетОтгрузки    
		| 				// Чек
		| 				КОГДА втДокументы.ТипДокумента = &Чек
		| 					И втДокументы.СтатусЧека = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
		| 				ТОГДА &СтатусОтгружен                  
		| 				КОГДА втДокументы.ТипДокумента = &Чек  
		| 				ТОГДА &СтатусЖдетОтгрузки
		| 			КОНЕЦ    
		| 		// С доставкой
		| 		ИНАЧЕ   
		| 			ВЫБОР      
		| 				// Доставка текущего дня с Яндексом
		| 				КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ЗаказНаДоставкуКлиентуРодителя.ПрибытиеНаОтгрузку), ДЕНЬ) >= НАЧАЛОПЕРИОДА(&ТекДата, ДЕНЬ) 
		| 					И втДоставкаЯндекс.ЗаказНаДоставку ЕСТЬ НЕ NULL 
		| 				ТОГДА 
		| 					ВЫБОР 
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПереданоВДоставку)
		| 						ТОГДА &СтатусПереданоВДоставку
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказОтправленСоСклада)
		| 						ТОГДА &СтатусЗаказОтправленСоСклада
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПредыдущийЗаказДоставлен)
		| 						ТОГДА &СтатусПредыдущийЗаказДоставлен
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказПодъезжает)
		| 						ТОГДА &СтатусЗаказПодъезжает
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказПриехал)
		| 						ТОГДА &СтатусЗаказПриехал
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказОтложен)
		| 						ТОГДА &СтатусЗаказОтложен
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказДоставленЧастично)
		| 						ТОГДА &СтатусЗаказДоставленЧастично
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказДоставлен)
		| 						ТОГДА &СтатусЗаказДоставлен
		| 						КОГДА втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказОтменен)
		| 						ТОГДА &СтатусЗаказОтменен
		|						ИНАЧЕ &СтатусВПути
		| 					КОНЕЦ     
		| 				// Доставка текущего дня без Яндекса
		| 				КОГДА НАЧАЛОПЕРИОДА(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ЗаказНаДоставкуКлиентуРодителя.ПрибытиеНаОтгрузку), ДЕНЬ) >= НАЧАЛОПЕРИОДА(&ТекДата, ДЕНЬ) 
		| 					И втДоставкаЯндекс.ЗаказНаДоставку ЕСТЬ NULL 
		| 				ТОГДА
		| 				    ВЫБОР 
		|						КОГДА втДокументы.ТипДокумента В (&Заказ, &Реализация)
		| 							И втДокументы.СостояниеЗаказа = ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказовКлиентов.Закрыт) 				
		| 						ТОГДА &СтатусОтгружен
		| 						ИНАЧЕ &СтатусВПути
		| 					КОНЕЦ
		| 				// Доставка прошедших дней
		| 				ИНАЧЕ
		| 				    ВЫБОР 
		|						КОГДА втДокументы.ТипДокумента В (&Заказ, &Реализация) 
		| 								И втДокументы.СостояниеЗаказа = ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказовКлиентов.ГотовКОтгрузке) 				
		| 						ТОГДА &СтатусЖдетОтгрузки
		| 						КОГДА втДоставкаЯндекс.ЗаказНаДоставку ЕСТЬ НЕ NULL
		| 							И втДоставкаЯндекс.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказОтменен)
		| 						ТОГДА &СтатусЗаказОтменен
		| 						ИНАЧЕ &СтатусОтгружен 
		| 					КОНЕЦ
		|			КОНЕЦ 		
		| 	КОНЕЦ "
		
КонецФункции

Функция ПолучитьТекстТоварыАдреса()
	
	Возврат
		"// Всего товаров - выборка
		|////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ    
		|	ДокументПродажи,
		|	КОЛИЧЕСТВО(Номенклатура) КАК ВсегоТоваров
		|ИЗ
		|	втТовары
		|СГРУППИРОВАТЬ ПО
		|	ДокументПродажи	
		|;
		|	
		|// Товары документов - выборка
		|////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ   
		|	втТовары.ДокументПродажи,   
		|	КОЛИЧЕСТВО(втТоварыПорядок.НомерСтроки) КАК НомерПоПорядку,
		|	втТовары.НомерСтроки,
		|	втТовары.Номенклатура,  
		|	втТовары.НаименованиеПолное,
		|	втТовары.Код,
		|	втТовары.Вес,
		|	втТовары.ЕдиницаИзмеренияВеса,
		|	втТовары.ЕдиницаИзмерения,
		|	втТовары.ЭтоУслуга,
		|	втТовары.Цена,	
		|	втТовары.Количество,	
		|	втТовары.Сумма
		|ИЗ
		|	втТовары
		|	СОЕДИНЕНИЕ втТовары КАК втТоварыПорядок
		|		ПО втТовары.ДокументПродажи = втТоварыПорядок.ДокументПродажи
		|		И  втТовары.НомерСтроки >= втТоварыПорядок.НомерСтроки  
		|СГРУППИРОВАТЬ ПО
		|	втТовары.ДокументПродажи,    
		|	втТовары.НомерСтроки,
		|	втТовары.Номенклатура,
		|	втТовары.НаименованиеПолное, 
		|	втТовары.Код,
		|	втТовары.Вес,
		|	втТовары.ЕдиницаИзмеренияВеса,
		|	втТовары.ЕдиницаИзмерения,
		|	втТовары.ЭтоУслуга,
		|	втТовары.Цена,	
		|	втТовары.Количество,	
		|	втТовары.Сумма	   
		|ИМЕЮЩИЕ                  
		|	КОЛИЧЕСТВО(втТоварыПорядок.НомерСтроки) <= &КоличествоТоваров 
		|УПОРЯДОЧИТЬ ПО 1, 2		
		|;
		|     
		|// Адреса доставки - выборка
