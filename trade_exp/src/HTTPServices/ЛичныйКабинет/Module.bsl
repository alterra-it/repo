Функция ПолучитьДокументыКлиента(Партнер, ДанныеЗапроса)   
	
	ТипыДокументов 			= ДопМодульСервер.ПолучитьТипыДокументов();
	ВидыДокументов 			= ДопМодульСервер.ПолучитьВидыДокументов();  
	СпособыПолученияЗаказов = ДопМодульСервер.ПолучитьСпособыПолученияЗаказов();
	СтатусыДокументов 		= ДопМодульСервер.ПолучитьСтатусыДокументов();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапросаДокументыКлиента();
	
	Для Каждого Элемент Из ТипыДокументов Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;

	Для Каждого Элемент Из ВидыДокументов Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;
	
	Для Каждого Элемент Из СпособыПолученияЗаказов Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;
	
	Для Каждого Элемент Из СтатусыДокументов Цикл
		Запрос.УстановитьПараметр("Статус" + Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("Партнер", Партнер);          
	Запрос.УстановитьПараметр("ПустаяСтрока", "");          
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());          
	Запрос.УстановитьПараметр("ФизическоеЛицо", Справочники.Контрагенты.НайтиПоНаименованию("ФИЗИЧЕСКОЕ ЛИЦО"));
	Запрос.УстановитьПараметр("ФизическоеЛицоНаименование", "Физическое лицо");
	Запрос.УстановитьПараметр("МаксимумЗаписейНаСтранице", ДанныеЗапроса.МаксимумЗаписейНаСтранице);
	Запрос.УстановитьПараметр("НомерСтраницы", ДанныеЗапроса.НомерСтраницы);
	Запрос.УстановитьПараметр("КоличествоТоваров", ДанныеЗапроса.КоличествоТоваров);
	
	Фильтры = ПолучитьФильтрыДокументов();   
	                                                 
	// Фильтр по периоду
	Если ЗначениеЗаполнено(ДанныеЗапроса.НачальнаяДата) Или ЗначениеЗаполнено(ДанныеЗапроса.КонечнаяДата) Тогда
		Фильтры.ФильтрПериод = Фильтры.ФильтрПериод + Символы.ПС + 
			?(ЗначениеЗаполнено(ДанныеЗапроса.НачальнаяДата), "И Документы.Дата >= &НачальнаяДата ", "") + Символы.ПС + 
			?(ЗначениеЗаполнено(ДанныеЗапроса.КонечнаяДата),  "И Документы.Дата <= &КонечнаяДата   ", "") + Символы.ПС;
					
		Если ЗначениеЗаполнено(ДанныеЗапроса.НачальнаяДата) Тогда
			Запрос.УстановитьПараметр("НачальнаяДата", ДанныеЗапроса.НачальнаяДата);     					
		КонецЕсли;
		Если ЗначениеЗаполнено(ДанныеЗапроса.КонечнаяДата) Тогда
			Запрос.УстановитьПараметр("КонечнаяДата", ДанныеЗапроса.КонечнаяДата);     					
		КонецЕсли;
	КонецЕсли;                  
	
	// Фильтр по ссылке документа
	Если ЗначениеЗаполнено(ДанныеЗапроса.УИДДокумента) Тогда          
		УИД = Новый УникальныйИдентификатор(ДанныеЗапроса.УИДДокумента);   
		СсылкаДокумента = ПолучитьСсылкуДокумента(УИД);
		Фильтры.ФильтрСсылка = "И Документы.Ссылка = &СсылкаДокумента";
		
		Запрос.УстановитьПараметр("СсылкаДокумента", СсылкаДокумента);     					
	КонецЕсли;  
	
	// Фильтр по номеру документа
	Если ЗначениеЗаполнено(ДанныеЗапроса.НомерДокумента) Тогда             
		Фильтры.ФильтрНомер = "И Документы.Номер = &НомерДокумента";
		Запрос.УстановитьПараметр("НомерДокумента", ДанныеЗапроса.НомерДокумента);     					
	КонецЕсли; 
	  	
	// Фильтр по типу документа
	Если ЗначениеЗаполнено(ДанныеЗапроса.ТипДокумента) Тогда
		
		Если ДанныеЗапроса.ТипДокумента = ТипыДокументов["Заказ"].Код Тогда
			Фильтры.ФильтрЗаказ = 		"И &ТипДокумента = &Заказ";
			Фильтры.ФильтрРеализация = 	"И 0 = 1";
			Фильтры.ФильтрЧек = 		"И 0 = 1";
			Запрос.УстановитьПараметр("ТипДокумента", "Заказ"); 
			    					
		ИначеЕсли ДанныеЗапроса.ТипДокумента = ТипыДокументов["Реализация"].Код Тогда
			Фильтры.ФильтрЗаказ = 		"И 0 = 1";
			Фильтры.ФильтрРеализация = 	"И &ТипДокумента = &Реализация";
			Фильтры.ФильтрЧек = 		"И 0 = 1";
			Запрос.УстановитьПараметр("ТипДокумента", "Реализация");     					
		
		ИначеЕсли ДанныеЗапроса.ТипДокумента = ТипыДокументов["Чек"].Код Тогда
			Фильтры.ФильтрЗаказ = 		"И 0 = 1";
			Фильтры.ФильтрРеализация = 	"И 0 = 1";
			Фильтры.ФильтрЧек = 		"И &ТипДокумента = &Чек";
			Запрос.УстановитьПараметр("ТипДокумента", "Чек");   

		Иначе 
			Фильтры.ФильтрЗаказ = 		"И 0 = 1";
			Фильтры.ФильтрРеализация = 	"И 0 = 1";
			Фильтры.ФильтрЧек = 		"И 0 = 1";
		КонецЕсли;
	КонецЕсли; 	
	  	
	// Фильтр по виду документа
	Если ЗначениеЗаполнено(ДанныеЗапроса.ВидДокумента) Тогда
		
		Если ДанныеЗапроса.ВидДокумента = ВидыДокументов["Онлайн"].Код 
		Или ДанныеЗапроса.ВидДокумента = ВидыДокументов["Оффлайн"].Код Тогда
			Фильтры.ФильтрССайта = "И Документы.ССайта = &ССайта";
			Фильтры.ФильтрССайтаРеализация = "И ЕСТЬNULL(Заказ.ССайта, Реализация.ССайта) = &ССайта";
			Запрос.УстановитьПараметр("ССайта", ДанныеЗапроса.ВидДокумента = ВидыДокументов["Онлайн"].Код);
		Иначе
			Фильтры.ФильтрССайта = "И 0 = 1";
			Фильтры.ФильтрССайтаРеализация = "И 0 = 1";
		КонецЕсли;		
	КонецЕсли;
	
	// Фильтр по номеру на сайте
	Если ЗначениеЗаполнено(ДанныеЗапроса.НомерНаСайте) Тогда
		Фильтры.ФильтрНомерНаСайте = "И (Документы.НомерНаСайте ПОДОБНО &НомерНаСайте ИЛИ Документы.Номер ПОДОБНО &НомерНаСайте)";
		Фильтры.ФильтрНомерНаСайтеРеализация = "И (ЕСТЬNULL(Заказ.НомерНаСайте, &ПустаяСтрока) ПОДОБНО &НомерНаСайте 
			|ИЛИ ЕСТЬNULL(Заказ.Номер, &ПустаяСтрока) ПОДОБНО &НомерНаСайте ИЛИ Реализация.Номер ПОДОБНО &НомерНаСайте)";
		Фильтры.ФильтрНомерНаСайтеЧек = "И Документы.Номер ПОДОБНО &НомерНаСайте";
		Запрос.УстановитьПараметр("НомерНаСайте", "%" + ДанныеЗапроса.НомерНаСайте + "%");
	КонецЕсли;
	
	// Фильтр по сумме документа
	Если ЗначениеЗаполнено(ДанныеЗапроса.НачальнаяСумма) Или ЗначениеЗаполнено(ДанныеЗапроса.КонечнаяСумма) Тогда
		Фильтры.ФильтрСуммаДокумента = "И Документы.СуммаДокумента МЕЖДУ &НачальнаяСумма И &КонечнаяСумма";
		Фильтры.ФильтрСуммаДокументаЗаказ = "И втЗаказыПериод.СуммаДокумента - СУММА(ЕСТЬNULL(Реализация.СуммаДокумента, 0)) МЕЖДУ &НачальнаяСумма И &КонечнаяСумма";
		Запрос.УстановитьПараметр("НачальнаяСумма", ДанныеЗапроса.НачальнаяСумма);
		Запрос.УстановитьПараметр("КонечнаяСумма", ДанныеЗапроса.КонечнаяСумма);
	КонецЕсли;

	// Фильтр по способу получения
	Если ЗначениеЗаполнено(ДанныеЗапроса.СпособПолучения) Тогда
		Фильтры.ФильтрСпособПолучения = 
		 	"И ВЫБОР 
		 	|	КОГДА ЕСТЬNULL(ЗаказНаДоставкуКлиенту.Ссылка, ЗаказНаДоставкуКлиентуРодителя.Ссылка) ЕСТЬ NULL
		 	|	ТОГДА &Самовывоз
		 	|	ИНАЧЕ &Доставка  
		 	|КОНЕЦ = &СпособПолучения";
		Запрос.УстановитьПараметр("СпособПолучения", 
			?(ДанныеЗапроса.СпособПолучения = СпособыПолученияЗаказов["Самовывоз"].Код, "Самовывоз",
			?(ДанныеЗапроса.СпособПолучения = СпособыПолученияЗаказов["Доставка"].Код, "Доставка", ""))); 
 	КонецЕсли;
	
	// Фильтр по адресу доставки
	Если ЗначениеЗаполнено(ДанныеЗапроса.АдресДоставки) Тогда
		Фильтры.ФильтрАдресДоставки =
		 	"И ВЫБОР 
		 	|	КОГДА ЗаказНаДоставкуКлиенту.Ссылка ЕСТЬ NULL
		 	|	ТОГДА &ПустаяСТрока
		 	|	ИНАЧЕ ЗаказНаДоставкуКлиенту.АдресДоставки
		 	|КОНЕЦ ПОДОБНО &АдресДоставки"; 
		 	Запрос.УстановитьПараметр("АдресДоставки",  "%" + ДанныеЗапроса.АдресДоставки + "%");
	КонецЕсли; 
	
	// Фильтр по грузополучателю
	Если ЗначениеЗаполнено(ДанныеЗапроса.Грузополучатель) Тогда
		Фильтры.ФильтрГрузополучатель =
		 	"И ВЫБОР 
			| КОГДА ЕСТЬNULL(ЕСТЬNULL(ЗаказНаДоставкуКлиенту.Контрагент, ЗаказНаДоставкуКлиентуРодителя.Контрагент), ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)) В (ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка), &ФизическоеЛицо)	
			| ТОГДА
			| 	ВЫБОР 
			| 		КОГДА втДокументы.Контрагент В (ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка), &ФизическоеЛицо)
			| 		ТОГДА
			| 			ВЫБОР 
			| 				КОГДА втДокументы.Партнер.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.КомпанияЧастноеЛицо.Компания)	
			| 				ТОГДА &ФизическоеЛицоНаименование 
			| 				ИНАЧЕ втДокументы.Партнер.НаименованиеПолное
			| 			КОНЕЦ
			| 		ИНАЧЕ втДокументы.Контрагент.НаименованиеПолное
			| 	КОНЕЦ
			| ИНАЧЕ ЕСТЬNULL(ЗаказНаДоставкуКлиенту.Контрагент.НаименованиеПолное, ЗаказНаДоставкуКлиентуРодителя.Контрагент.НаименованиеПолное)
			|КОНЕЦ ПОДОБНО &Грузополучатель"; 
		 	Запрос.УстановитьПараметр("Грузополучатель", "%" + ДанныеЗапроса.Грузополучатель + "%");
	КонецЕсли; 	
	
	// Фильтр по статусу
	Если ЗначениеЗаполнено(ДанныеЗапроса.Статус) Тогда  
		Фильтры.ФильтрСтатус = 
			"И " +
			ПолучитьТекстСтатусОтгрузки() + 
			"В (&СтатусОтгрузки)";
			
			// Определение статусов доставки
			СтатусДокумента = "";
			ОсновнойСтатусДоставки = "";
			СтатусыДоставки = Новый Массив();
			Для Каждого Элемент Из СтатусыДокументов Цикл
				Если ДанныеЗапроса.Статус = Элемент.Значение.Код Тогда
					СтатусДокумента = Элемент.Ключ;
				КонецЕсли;				
				Если Элемент.Значение.Доставка И Не Элемент.Значение.Яндекс Тогда
					ОсновнойСтатусДоставки = Элемент.Ключ;
				КонецЕсли;
				Если Элемент.Значение.Доставка Тогда
					СтатусыДоставки.Добавить(Элемент.Ключ);	
				КонецЕсли;
			КонецЦикла;
						
			// Статус ВПути фильтрует по всем статусам доставки						
			Если СтатусДокумента = ОсновнойСтатусДоставки Тогда					    
				Запрос.УстановитьПараметр("СтатусОтгрузки", СтатусыДоставки);
			Иначе
				СтатусыДокумента = Новый Массив;
				СтатусыДокумента.Добавить(СтатусДокумента);
				Запрос.УстановитьПараметр("СтатусОтгрузки", СтатусыДокумента);
			КонецЕсли;										   
	КонецЕсли;

	ПрименитьФильтрыДокументов(Запрос.Текст, Фильтры);
	ПакетЗапросов = Запрос.ВыполнитьПакет();
		
	РезультатВыполнения = Новый Структура("ВсегоДокументов, Документы, ВсегоТоваров, Товары, АдресаДоставки, Такском", 
		ПакетЗапросов[6].Выгрузить(), ПакетЗапросов[14].Выгрузить(), ПакетЗапросов[17].Выгрузить(), 
		ПакетЗапросов[18].Выгрузить(), ПакетЗапросов[19].Выгрузить(), ПакетЗапросов[15].Выгрузить());
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьДокументКлиента(УИД = Неопределено, НомерНаСайте = Неопределено)    
	
	ТипыДокументов 			= ДопМодульСервер.ПолучитьТипыДокументов();
	ВидыДокументов 			= ДопМодульСервер.ПолучитьВидыДокументов();  
	СпособыПолученияЗаказов = ДопМодульСервер.ПолучитьСпособыПолученияЗаказов();
	СтатусыДокументов 		= ДопМодульСервер.ПолучитьСтатусыДокументов();
	
	Запрос = Новый Запрос;
	Запрос.Текст = ПолучитьТекстЗапросаДокументыКлиента(Ложь);
	
	Для Каждого Элемент Из ТипыДокументов Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;

	Для Каждого Элемент Из ВидыДокументов Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;
	
	Для Каждого Элемент Из СпособыПолученияЗаказов Цикл
		Запрос.УстановитьПараметр(Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;
	
	Для Каждого Элемент Из СтатусыДокументов Цикл
		Запрос.УстановитьПараметр("Статус" + Элемент.Ключ, Элемент.Ключ);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ПустаяСтрока", "");          
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());          
	Запрос.УстановитьПараметр("ФизическоеЛицо", Справочники.Контрагенты.НайтиПоНаименованию("ФИЗИЧЕСКОЕ ЛИЦО"));
	Запрос.УстановитьПараметр("ФизическоеЛицоНаименование", "Физическое лицо");
	Запрос.УстановитьПараметр("МаксимумЗаписейНаСтранице", 1);
	Запрос.УстановитьПараметр("НомерСтраницы", 1);
	
	Фильтры = ПолучитьФильтрыДокументов();
     
    Если ЗначениеЗаполнено(УИД) Тогда
		СсылкаДокумента = ПолучитьСсылкуДокумента(УИД);    	
		Фильтры.ФильтрСсылка = "И Документы.Ссылка = &СсылкаДокумента";
		Запрос.УстановитьПараметр("СсылкаДокумента", СсылкаДокумента);
    Иначе
		Фильтры.ФильтрЗаказ = 		"И &ТипДокумента = &Заказ";
		Фильтры.ФильтрРеализация = 	"И 0 = 1";
		Фильтры.ФильтрЧек = 		"И 0 = 1";
		Запрос.УстановитьПараметр("ТипДокумента", "Заказ");
		 
		Фильтры.ФильтрНомерНаСайте = "И Документы.НомерНаСайте = &НомерНаСайте";
		Фильтры.ФильтрНомерНаСайтеРеализация = "И ЕСТЬNULL(Заказ.НомерНаСайте, &ПустаяСтрока) = &НомерНаСайте";
		Фильтры.ФильтрНомерНаСайтеЧек = "И 0 = 1";
		Запрос.УстановитьПараметр("НомерНаСайте", НомерНаСайте);
	КонецЕсли;     					
	
	ПрименитьФильтрыДокументов(Запрос.Текст, Фильтры);
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	РезультатВыполнения = Новый Структура("Документ, Товары, Такском", 
		РезультатыЗапроса[14].Выгрузить(), РезультатыЗапроса[16].Выгрузить(), РезультатыЗапроса[15].Выгрузить());
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьФильтрыДокументов()
	
	Фильтры = Новый Структура;
	Фильтры.Вставить("ФильтрПериод", 					"");
	Фильтры.Вставить("ФильтрСсылка", 					"");
	Фильтры.Вставить("ФильтрНомер", 					"");
	Фильтры.Вставить("ФильтрЗаказ", 					"");
	Фильтры.Вставить("ФильтрРеализация", 				"");
	Фильтры.Вставить("ФильтрЧек", 						"");
	Фильтры.Вставить("ФильтрССайта",					"");
	Фильтры.Вставить("ФильтрССайтаРеализация", 			"");    
	Фильтры.Вставить("ФильтрНомерНаСайте", 				"");    
	Фильтры.Вставить("ФильтрНомерНаСайтеРеализация",	"");    
	Фильтры.Вставить("ФильтрНомерНаСайтеЧек", 			""); 
	Фильтры.Вставить("ФильтрСуммаДокумента", 			"");    
	Фильтры.Вставить("ФильтрСуммаДокументаЗаказ", 		"");    
	Фильтры.Вставить("ФильтрСпособПолучения", 			"");    
	Фильтры.Вставить("ФильтрАдресДоставки", 			"");    
	Фильтры.Вставить("ФильтрГрузополучатель", 			"");    
	Фильтры.Вставить("ФильтрСтатус", 					"");   	
	Возврат Фильтры;
	
КонецФункции	

Процедура ПрименитьФильтрыДокументов(ТекстЗапроса, Фильтры)

	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрПериод", 					Фильтры.ФильтрПериод);    
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрСсылка", 					Фильтры.ФильтрСсылка);    
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрЗаказ", 					Фильтры.ФильтрЗаказ);    
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрРеализация", 				Фильтры.ФильтрРеализация);    
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрЧек", 						Фильтры.ФильтрЧек);  
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрССайтаРеализация", 		Фильтры.ФильтрССайтаРеализация);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрССайта", 					Фильтры.ФильтрССайта);
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрНомерНаСайтеРеализация",	Фильтры.ФильтрНомерНаСайтеРеализация);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрНомерНаСайтеЧек",			Фильтры.ФильтрНомерНаСайтеЧек); 
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрНомерНаСайте", 			Фильтры.ФильтрНомерНаСайте);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрНомер", 					Фильтры.ФильтрНомер);    
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрСуммаДокументаЗаказ",		Фильтры.ФильтрСуммаДокументаЗаказ);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрСуммаДокумента",			Фильтры.ФильтрСуммаДокумента);
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрСпособПолучения", 			Фильтры.ФильтрСпособПолучения);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрАдресДоставки", 			Фильтры.ФильтрАдресДоставки);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрГрузополучатель", 			Фильтры.ФильтрГрузополучатель);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "%ФильтрСтатус", 					Фильтры.ФильтрСтатус);
	
КонецПроцедуры	

Функция ПолучитьТекстЗапросаДокументыКлиента(ВсеДокументы = Истина)
	
	ТекстЗапроса = 		
		"// Все заказы за период 
		|//////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Документы.Ссылка КАК ДокументПродажи,    
		|	Документы.Номер,  
		|	Документы.НомерНаСайте,  		
		|	Документы.Дата,  
		|	ВЫБОР 
		|		КОГДА Документы.ДатаСоздания <> ДАТАВРЕМЯ(1, 1, 1)	
		|	    ТОГДА Документы.ДатаСоздания
		|	    ИНАЧЕ Документы.Дата
		|	КОНЕЦ КАК ДатаСоздания,            
		|	&Заказ КАК ТипДокумента,    
		|	Документы.ССайта,
		|	Документы.ПередатьНаСайт,
		|	Документы.СуммаДокумента,  
		|	Документы.РаспределитьТранспортные, 
		|	Документы.Партнер,
		|	Документы.Контрагент,
		|	Документы.ИспользуетсяДоговор И Документы.Контрагент <> &ФизическоеЛицо КАК ИспользуетсяДоговор,
		|	Подразделение.Наименование КАК Магазин,
		|	ВЫБОР
		|		КОГДА Документы.Магазин.Адрес <> &ПустаяСтрока
		|		ТОГДА Документы.Магазин.Адрес
		|		ИНАЧЕ ЕСТЬNULL(Документы.Магазин.Родитель.Адрес, &ПустаяСтрока)
		|	КОНЕЦ КАК АдресМагазина,
		|	ВЫБОР 
		|		КОГДА Документы.ССайта И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.НеСогласован)
		|		ТОГДА &СтатусЖдетОбработки 
		|		КОГДА Документы.ССайта И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.КОбеспечению)
		|		ТОГДА &СтатусВОбработке
		|		ИНАЧЕ NULL
		|	КОНЕЦ КАК СтатусЗаказа,
		|	СостоянияЗаказовКлиентов.Состояние КАК СостояниеЗаказа,   
		|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентОплаты, 0) = 100 КАК Оплачено,
		|	ЕСТЬNULL(СостоянияЗаказовКлиентов.СуммаОплаты, 0) КАК СуммаОплаты
		|ПОМЕСТИТЬ
		|	втЗаказыПериод
		|ИЗ
		|	Документ.ЗаказКлиента КАК Документы 
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|		ПО Документы.Ссылка = СостоянияЗаказовКлиентов.Заказ
		|ГДЕ 
		|	(Документы.Проведен ИЛИ НЕ Документы.Проведен И Документы.ССайта И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.НеСогласован))
		|	И Документы.СуммаДокумента > 0
		|	%ФильтрПартнер
		|	//И Документы.Партнер = &Партнер  
		|	%ФильтрПериод     
		|	//И Документы.Дата >= &НачальнаяДата
		|	//И Документы.Дата <= &КонечнаяДата  
		|	%ФильтрСсылка     
		|	//И Документы.Ссылка = &СсылкаДокумента
		|	%ФильтрНомер
		|	//И Документы.Номер = &НомерДокумента  
		|	%ФильтрЗаказ
		|	//И &ТипДокумента = &Заказ     
		|	%ФильтрССайта
		|	//И Документы.ССайта = &ССайта
		|	%ФильтрНомерНаСайте
		|	//И (Документы.НомерНаСайте ПОДОБНО &НомерНаСайте ИЛИ Документы.Номер ПОДОБНО &НомерНаСайте)
		|;        
		|
		|// Все реализации за период 
		|//////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ  
		|	Документы.Ссылка КАК ДокументПродажи,
		|	Документы.Номер,   
		|	Документы.Дата,
		|  	ВЫБОР 
		|		КОГДА Документы.ДатаСоздания <> ДАТАВРЕМЯ(1, 1, 1)	
		|    	ТОГДА Документы.ДатаСоздания
		|    	ИНАЧЕ Документы.Дата
		| 	КОНЕЦ КАК ДатаСоздания, 
		|	&Реализация КАК ТипДокумента, 
		| 	Документы.ССайта,
		|	Подразделение.Наименование КАК Магазин,
		|	ВЫБОР
		|		КОГДА Документы.Магазин.Адрес <> &ПустаяСтрока
		|		ТОГДА Документы.Магазин.Адрес
		|		ИНАЧЕ ЕСТЬNULL(Документы.Магазин.Родитель.Адрес, &ПустаяСтрока)
		|	КОНЕЦ КАК АдресМагазина,
		|	Документы.СуммаДокумента,
		|	Документы.РаспределитьТранспортные,
		|	Документы.Партнер,
		|	Документы.Контрагент,
		|	Документы.ИспользуетсяДоговор И Документы.Контрагент <> &ФизическоеЛицо КАК ИспользуетсяДоговор,   
		|	Документы.Кассир <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка) КАК ОтметкаКассы,
		|	Документы.ЗаказКлиента
		|ПОМЕСТИТЬ 
		|	втРеализацииПериод	
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК Документы
		|ГДЕ
		|	Документы.Проведен
		|	%ФильтрПартнер
		|	//И Документы.Партнер = &Партнер       
		|	%ФильтрПериод
		|	//И Документы.Дата >= &НачальнаяДата
		|	//И Документы.Дата <= &КонечнаяДата  
		|	%ФильтрСсылка     
		|	//И Документы.Ссылка = &СсылкаДокумента
		|	%ФильтрНомер
		|	//И Документы.Номер = &НомерДокумента  
		|	%ФильтрРеализация
		|	//И &ТипДокумента = &Реализация
		|	%ФильтрСуммаДокумента
		|	//И Документы.СуммаДокумента МЕЖДУ &НачальнаяСумма И &КонечнаяСумма
		|;        
		|
		|// Заказы, реализации, чеки
		|////////////////////////////////////////////////////////////////////// 
		|// Заказы без реализаций, заказы частично реализованные
		|ВЫБРАТЬ                       
		|	втЗаказыПериод.ДокументПродажи КАК Родитель,    
		|	втЗаказыПериод.ДокументПродажи,    
		|	втЗаказыПериод.Номер,  
		|	втЗаказыПериод.НомерНаСайте, 
		|	втЗаказыПериод.Дата,  
		|	втЗаказыПериод.ДатаСоздания,            
		|	втЗаказыПериод.ТипДокумента,    
		|	втЗаказыПериод.ССайта,
		|	втЗаказыПериод.СуммаДокумента - СУММА(ЕСТЬNULL(Реализация.СуммаДокумента, 0)) КАК СуммаДокумента,
		|	втЗаказыПериод.РаспределитьТранспортные,
		|	втЗаказыПериод.Партнер,
		|	втЗаказыПериод.Контрагент,
		|	втЗаказыПериод.ИспользуетсяДоговор,
		|	втЗаказыПериод.Магазин,
		|	втЗаказыПериод.АдресМагазина,
		|	втЗаказыПериод.СтатусЗаказа,
		|	втЗаказыПериод.СостояниеЗаказа, 
		|	втЗаказыПериод.Оплачено,
		|	втЗаказыПериод.СуммаОплаты,
		|	NULL КАК ОтметкаКассы,
		|	NULL КАК СтатусЧека,
		|	ЛОЖЬ КАК ЕстьСчетФактура
		|ПОМЕСТИТЬ
		|	втДокументы
		|ИЗ
		|	втЗаказыПериод 
		|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|		ПО втЗаказыПериод.ДокументПродажи = Реализация.ЗаказКлиента 
		|		И Реализация.Проведен   
		|СГРУППИРОВАТЬ ПО
		|	втЗаказыПериод.ДокументПродажи,    
		|	втЗаказыПериод.Номер,  
		|	втЗаказыПериод.НомерНаСайте, 
		|	втЗаказыПериод.Дата,  
		|	втЗаказыПериод.ДатаСоздания,            
		|	втЗаказыПериод.ТипДокумента,    
		|	втЗаказыПериод.ССайта,
		|	втЗаказыПериод.ПередатьНаСайт,
		|	втЗаказыПериод.СуммаДокумента,
		|	втЗаказыПериод.РаспределитьТранспортные,
		|	втЗаказыПериод.Партнер,
		|	втЗаказыПериод.Контрагент,
		|	втЗаказыПериод.ИспользуетсяДоговор,
		|	втЗаказыПериод.Магазин,
		|	втЗаказыПериод.АдресМагазина,
		|	втЗаказыПериод.СтатусЗаказа,
		|	втЗаказыПериод.СостояниеЗаказа,
		|	втЗаказыПериод.Оплачено,
		|	втЗаказыПериод.СуммаОплаты
		|ИМЕЮЩИЕ 
		|	втЗаказыПериод.СуммаДокумента > СУММА(ЕСТЬNULL(Реализация.СуммаДокумента, 0)) + 1 
		|	И ВЫБОР         
		|		КОГДА СУММА(ЕСТЬNULL(Реализация.СуммаДокумента, 0)) = 0 
		|		ТОГДА втЗаказыПериод.ССайта ИЛИ НЕ втЗаказыПериод.ССайта И втЗаказыПериод.ПередатьНаСайт
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ
		|	%ФильтрСуммаДокументаЗаказ
		|	//И втЗаказыПериод.СуммаДокумента - СУММА(ЕСТЬNULL(Реализация.СуммаДокумента, 0)) МЕЖДУ &НачальнаяСумма И &КонечнаяСумма
		|
		|ОБЪЕДИНИТЬ ВСЕ   
		|
		|// Реализации с заказами и без заказов      
		|ВЫБРАТЬ РАЗЛИЧНЫЕ                      
		|	ЕСТЬNULL(Заказы.Ссылка, &ПустаяСтрока) КАК Родитель,
		|	Реализация.ДокументПродажи,
		|	Реализация.Номер,   
		|	ЕСТЬNULL(Заказы.НомерНаСайте, &ПустаяСтрока) КАК НомерНаСайте,   
		|	Реализация.Дата,
		|	Реализация.ДатаСоздания, 
		|	&Реализация КАК ТипДокумента, 
		|	ЕСТЬNULL(Заказы.ССайта, Реализация.ССайта) КАК ССайта,  
		|	Реализация.СуммаДокумента,
		|	Реализация.РаспределитьТранспортные,
		|	Реализация.Партнер, 
		|	Реализация.Контрагент, 
		|	Реализация.ИспользуетсяДоговор,
		|	Реализация.Магазин, 
		|	Реализация.АдресМагазина, 
		|	NULL СтатусЗаказа,   
		|	СостоянияЗаказовКлиентов.Состояние КАК СостояниеЗаказа,
		|	ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентОплаты, 0) = 100 КАК Оплачено, 
		|	ВЫБОР 
		|		КОГДА ЕСТЬNULL(СостоянияЗаказовКлиентов.ПроцентОплаты, 0) = 100 
		|		ТОГДА Реализация.СуммаДокумента
		|		ИНАЧЕ 0                                                
		|	КОНЕЦ КАК СуммаОплаты,
		|	Реализация.ОтметкаКассы,
		|	NULL КАК СтатусЧека,
		|	СчетФактура.ДокументОснование ЕСТЬ НЕ NULL КАК ЕстьСчетФактура
		|ИЗ
		|	втРеализацииПериод КАК Реализация 
		|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказы
		|		ПО Реализация.ЗаказКлиента = Заказы.Ссылка  
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияЗаказовКлиентов КАК СостоянияЗаказовКлиентов
		|		ПО Заказы.Ссылка = СостоянияЗаказовКлиентов.Заказ
		|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактура
		|		ПО Реализация.ДокументПродажи = СчетФактура.ДокументОснование
		|		И СчетФактура.Проведен
		|ГДЕ
		|	1 = 1 
		|	%ФильтрССайтаРеализация
		|	//И ЕСТЬNULL(Заказ.ССайта, Реализация.ССайта) = &ССайта
		|	%ФильтрНомерНаСайтеРеализация
		|	//И (ЕСТЬNULL(Заказ.НомерНаСайте, &ПустаяСтрока) ПОДОБНО &НомерНаСайте 
		|	//	ИЛИ ЕСТЬNULL(Заказ.Номер, &ПустаяСтрока) ПОДОБНО &НомерНаСайте
		|	//	ИЛИ Реализация.Номер ПОДОБНО &НомерНаСайте)
		|	
		|ОБЪЕДИНИТЬ ВСЕ
		|	        
		|// Чеки
		|ВЫБРАТЬ        
		|	&ПустаяСтрока Родитель,
		|	Документы.Ссылка КАК ДокументПродажи, 
		|	Документы.Номер,  
		|	&ПустаяСтрока КАК НомерНаСайте,  
		|	Документы.Дата,                 
		|	ВЫБОР 
		|		КОГДА Документы.ДатаСоздания <> ДАТАВРЕМЯ(1, 1, 1)	
		|	    ТОГДА Документы.ДатаСоздания
		|	    ИНАЧЕ Документы.Дата
		|	 КОНЕЦ КАК ДатаСоздания, 
		|	&Чек КАК ТипДокумента,
		|	Документы.ССайта,
		|	Документы.СуммаДокумента,
		|	Документы.РаспределитьТранспортные,
		|	Документы.Партнер,
		|	Документы.Контрагент,
		|	ЛОЖЬ ИспользуетсяДоговор,
		|	Подразделение.Наименование КАК Магазин,
		|	ВЫБОР
		|		КОГДА Документы.Магазин.Адрес <> &ПустаяСтрока
		|		ТОГДА Документы.Магазин.Адрес
		|		ИНАЧЕ ЕСТЬNULL(Документы.Магазин.Родитель.Адрес, &ПустаяСтрока)
		|	КОНЕЦ КАК АдресМагазина,
		|	NULL СтатусЗаказа,
		|	NULL СостояниеЗаказа,
		|	ИСТИНА КАК Оплачено, 
		|	Документы.СуммаДокумента КАК СуммаОплаты,
		|	NULL ОтметкаКассы,  
		|	Документы.Статус КАК СтатусЧека,
		|	ЛОЖЬ КАК ЕстьСчетФактура
		|ИЗ
		|	Документ.ЧекККМ КАК Документы 
		|ГДЕ
		|	Документы.Проведен
		|	%ФильтрПартнер
		|	//И Документы.Партнер = &Партнер  	
		|	%ФильтрПериод     
		|	//И Документы.Дата >= &НачальнаяДата
		|	//И Документы.Дата <= &КонечнаяДата  
		|	%ФильтрСсылка     
		|	//И Документы.Ссылка = &СсылкаДокумента
		|	%ФильтрНомер
		|	//И Документы.Номер = &НомерДокумента  
		|	%ФильтрЧек
		|	//И &ТипДокумента = &Чек     
		|	%ФильтрССайта
		|	//И Документы.ССайта = &ССайта
		|	%ФильтрНомерНаСайтеЧек
		|	//И Документы.Номер ПОДОБНО &НомерНаСайте  
		|	%ФильтрСуммаДокумента
		|	//И Документы.СуммаДокумента МЕЖДУ &НачальнаяСумма И &КонечнаяСумма
		|;        
		|
		|// Все события доставки Яндекс 
		|//////////////////////////////////////////////////////////////////////  
		|ВЫБРАТЬ
		|	ДоставкаЯндекс.ЗаказНаДоставку,	
		|	ДоставкаЯндекс.ВремяСобытия,	
		|	ДоставкаЯндекс.СтатусДоставки,	
		|	ДоставкаЯндекс.СтатусДоставки.Порядок КАК ПорядокДоставки,	
		|	ДоставкаЯндекс.Трекинг      
		|ПОМЕСТИТЬ втСобытияЯндекс	
