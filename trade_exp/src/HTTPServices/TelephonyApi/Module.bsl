Функция phone_duty_logistician(Запрос)
	
	ИмяСобытияДляЖурналаРегистрации = "/asterisk";
	
	ТелоЗапроса = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);
	ТелефонияПереопределяемый.ЗаписатьЗапросВЖурналРегистрации(ИмяСобытияДляЖурналаРегистрации, ТелоЗапроса);

	ПараметрыТела = ПолучитьПараметрыИзСтроки(ТелоЗапроса, "&");
	
	ТелефонияПереопределяемый.ЗаписатьЗапросВЖурналРегистрации(ИмяСобытияДляЖурналаРегистрации, ПараметрыТела.id);
	
	НомерТелефона = "";
	
	Если СтрДлина(ПараметрыТела.id)>1 Тогда
		НомерТелефона = ПараметрыТела.id;
	Иначе	
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Сотрудники.Телефон КАК Телефон
		|ИЗ
		|	Документ.ГрафикДежурств.ДежурныеПоПодразделениям КАК ГрафикДежурствДежурныеПоПодразделениям
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		|		ПО ГрафикДежурствДежурныеПоПодразделениям.Сотрудник = Сотрудники.Ссылка
		|ГДЕ
		|	ГрафикДежурствДежурныеПоПодразделениям.Дата = &Дата
		|	И ГрафикДежурствДежурныеПоПодразделениям.Подразделение.ИдентификаторАстерикс = &Филиал";
		
		Запрос.УстановитьПараметр("Дата", НачалоДня(ТекущаяДата()));
		Запрос.УстановитьПараметр("Филиал", Число(ПараметрыТела.id));
		
		УстановитьПривилегированныйРежим(Истина);
		РезультатЗапроса = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			НомерТелефона = ВыборкаДетальныеЗаписи.Телефон;
		КонецЦикла;
	КонецЕсли;
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.УстановитьТелоИзСтроки(Строка(НомерТелефона));
	Возврат Ответ;
	
КонецФункции

Функция is_driver_phone(Запрос)
	
	//1 - Да
	//2 - Нет
	
	ИмяСобытияДляЖурналаРегистрации = "/asterisk";
	
	ТелоЗапроса = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);
	ТелефонияПереопределяемый.ЗаписатьЗапросВЖурналРегистрации(ИмяСобытияДляЖурналаРегистрации, ТелоЗапроса);
	
	ПараметрыТела = ПолучитьПараметрыИзСтроки(ТелоЗапроса, "&");
	
	ОбязательныеПараметры = "phone";
	Если НЕ ЕстьОбязательныеПараметры(ПараметрыТела,ОбязательныеПараметры) Тогда
		Возврат СообщениеОбОшибке(
		400,
		ИмяСобытияДляЖурналаРегистрации,
		СтрШаблон(НСтр("ru='Отсутствует обязательные параметры: %1'"), ОбязательныеПараметры));
	КонецЕсли;
	
	Попытка
		
		НомерВодителя      =ПараметрыТела.phone;
		НомерВодителяДлина =СтрДлина(НомерВодителя); 
		
		Если НомерВодителяДлина=12 Тогда
			НомерВодителя=Сред(НомерВодителя,3,10);	
		ИначеЕсли НомерВодителяДлина=11 Тогда	
			НомерВодителя=Сред(НомерВодителя,2,10);	
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Подразделение.ИдентификаторАстерикс КАК Подразделение
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
		|		ПО (Сотрудники.ФизическоеЛицо = ФизическиеЛицаКонтактнаяИнформация.Ссылка)
		|ГДЕ
		|	Сотрудники.Должность.ЭтоДолжностьВодителя
		|	И ФизическиеЛицаКонтактнаяИнформация.НомерТелефона = &НомерТелефона
		|	И НЕ Сотрудники.ПометкаУдаления
		|	И НЕ ФизическиеЛицаКонтактнаяИнформация.Ссылка.ПометкаУдаления";
		
		Запрос.УстановитьПараметр("НомерТелефона", НомерВодителя);
		
		УстановитьПривилегированныйРежим(Истина);
		РезультатЗапроса = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
		
		Если РезультатЗапроса.Пустой() Тогда
			
			ЭтоНомерВодителя = 0;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПартнерыКонтактнаяИнформация.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТ_Партнер
			|ИЗ
			|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|ГДЕ
			|	ПартнерыКонтактнаяИнформация.НомерТелефона = &НомерТелефона
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ЗаданиеНаПеревозкуРейс.Водитель КАК Водитель
			|ПОМЕСТИТЬ ВТ_Водитель
			|ИЗ
			|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеНаПеревозкуРейс
			|		ПО ЗаданиеНаПеревозкуРейсОснования.Ссылка = ЗаданиеНаПеревозкуРейс.Ссылка
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Партнер КАК ВТ_Партнер
			|		ПО ЗаданиеНаПеревозкуРейсОснования.Документ.Партнер = ВТ_Партнер.Ссылка
			|ГДЕ
			|	ЗаданиеНаПеревозкуРейсОснования.Ссылка.Дата >= &Дата
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ФизическиеЛица.НомерТелефона КАК НомерТелефона
			|ИЗ
			|	ВТ_Водитель КАК ВТ_Водитель
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛица
			|		ПО ВТ_Водитель.Водитель = ФизическиеЛица.Ссылка
			|
			|УПОРЯДОЧИТЬ ПО
			|	НомерТелефона УБЫВ";
			
			Запрос.УстановитьПараметр("НомерТелефона", НомерВодителя);
			Запрос.УстановитьПараметр("Дата", НачалоДня(ТекущаяДата()));
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			ИдентификаторПодразделения = 1;
			
			Если ВыборкаДетальныеЗаписи.Следующий() Тогда
				ИдентификаторПодразделения = ВыборкаДетальныеЗаписи.НомерТелефона;
			КонецЕсли;
			
			
		Иначе
			
			ЭтоНомерВодителя = 1;
			
			Выборка = РезультатЗапроса.Выбрать();
			Выборка.Следующий();
			
			ИдентификаторПодразделения  = Выборка.Подразделение;
			
		КонецЕсли;
		
		ТелефонияПереопределяемый.ЗаписатьЗапросВЖурналРегистрации(ИмяСобытияДляЖурналаРегистрации, ЭтоНомерВодителя);
		
		Запись_JSON = New ЗаписьJSON;
		Запись_JSON.УстановитьСтроку();
		Запись_JSON.ЗаписатьНачалоОбъекта();
		
		Запись_JSON.ЗаписатьИмяСвойства ("is_driver_phone");
		ЗаписатьJSON(Запись_JSON, ЭтоНомерВодителя);
		
		Запись_JSON.ЗаписатьИмяСвойства ("id");
		ЗаписатьJSON(Запись_JSON, ИдентификаторПодразделения);

		Запись_JSON.ЗаписатьКонецОбъекта();
		
		JОтвет = Запись_JSON.Закрыть();
		
		Ответ = New HTTPСервисОтвет(200);
		Ответ.Заголовки.Вставить("Content-type", "application/json;  charset=utf-8");
		Ответ.УстановитьТелоИзСтроки(JОтвет, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
		
		Возврат Ответ;

		
	Исключение
		
		Возврат СообщениеОбОшибке(
		500,
		ИмяСобытияДляЖурналаРегистрации,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
КонецФункции

Функция request_callback(Запрос)
	
	ИмяСобытияДляЖурналаРегистрации = "/asterisk";
	
	ТелоЗапроса = РаскодироватьСтроку(Запрос.ПолучитьТелоКакСтроку(), СпособКодированияСтроки.КодировкаURL);
	ТелефонияПереопределяемый.ЗаписатьЗапросВЖурналРегистрации(ИмяСобытияДляЖурналаРегистрации, ТелоЗапроса);
	
	ПараметрыТела = ПолучитьПараметрыИзСтроки(ТелоЗапроса, "&");
	
	ОбязательныеПараметры = "id";
	Если НЕ ЕстьОбязательныеПараметры(ПараметрыТела,ОбязательныеПараметры) Тогда
		Возврат СообщениеОбОшибке(
		400,
		ИмяСобытияДляЖурналаРегистрации,
		СтрШаблон(НСтр("ru='Отсутствует обязательные параметры: %1'"), ОбязательныеПараметры));
	КонецЕсли;
	
	НомерТелефона = ПараметрыТела.phone;
	ИдентификаторПодразделения = ПараметрыТела.id;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка 
		
		ДатаЗвонка = ТекущаяДата();
		Подразделение = ПолучитьПодразделениеОтдел(Число(ИдентификаторПодразделения));
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);	
		Партнер = АльтерраОбщегоНазначения.ПолучитьПартнераПоТелефону(НомерТелефона);
		
		Если Не ЗначениеЗаполнено(Партнер) Тогда
			Партнер = Справочники.Партнеры.НеизвестныйПартнер;
		КонецЕсли;
		
		
		МенеджерЗаписи = РегистрыСведений.ОчередьЗапросовНаОбратныйЗвонок.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.ДатаЗвонка = ДатаЗвонка;
		МенеджерЗаписи.Подразделение = Подразделение;
		МенеджерЗаписи.Партнер = Партнер;
		МенеджерЗаписи.НомерТелефона = НомерТелефона;	
		МенеджерЗаписи.Выполнен = Ложь;
		
		МенеджерЗаписи.Записать();
			
				
	Исключение 
		
		
	КонецПопытки;

	УстановитьПривилегированныйРежим(Ложь);

	Попытка
		
		Ответ = Новый HTTPСервисОтвет(200);
		Ответ.УстановитьТелоИзСтроки("OK");
		Возврат Ответ;
		
	Исключение
		
		Возврат СообщениеОбОшибке(
		500,
		ИмяСобытияДляЖурналаРегистрации,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
КонецФункции

