Функция РасчитатьВремяРаботы(Пользователь, Событие)
	ТекущаяДата = ТекущаяДата();
	ФиксированноеВремя = Дата(01,01,0001,0,0,0);
	//+++Собысия о работе 
	
	Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВыходСЛинии
		ИЛИ Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВходНаЛинию  Тогда
			
		Запрос = ТекстЗапросаФиксацииВремениНаЛинии();
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		Запрос.УстановитьПараметр("НачалоПереода", ТекущаяДата - 2592000);
		Запрос.УстановитьПараметр("КонецПереода", ТекущаяДата);
	
		МассивРезультатов = Запрос.ВыполнитьПакет();
		Выборка = МассивРезультатов[0].Выбрать();
		
		Пока Выборка.Следующий() Цикл		
			Если ФиксированноеВремя < Выборка.Период Тогда
				ФиксированноеВремя = Выборка.Период;	
			КонецЕсли;
		КонецЦикла;
		Если ПроверкаНаПервуюЗапись(Пользователь) Тогда
			Возврат 0;
		КонецЕсли;
		Возврат ТекущаяДата - ФиксированноеВремя;		
	КонецЕсли;
	
	Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВключениеМикросип 
		ИЛИ Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ОтключениеМикросип Тогда
			Начало = ТекущаяДата - 2592000;
		Запрос = ТекстЗапросаФиксацииВремениНаЛинии();
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		Запрос.УстановитьПараметр("НачалоПереода", Начало);
		Запрос.УстановитьПараметр("КонецПереода", ТекущаяДата);
		МассивРезультатов = Запрос.ВыполнитьПакет();
		Выборка = МассивРезультатов[1].Выбрать();
		
		Пока Выборка.Следующий() Цикл	 
			Если ФиксированноеВремя < Выборка.Период Тогда
				ФиксированноеВремя = Выборка.Период;	
			КонецЕсли;
		КонецЦикла;
		Если ПроверкаНаПервуюЗапись(Пользователь) Тогда
			Возврат 0;
		КонецЕсли;
		Возврат ТекущаяДата - ФиксированноеВремя;
	КонецЕсли;
	//---События о работе
	//+++Событие о звонке
	Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокОператору 
		ИЛИ Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВзятиеТрубки 
		ИЛИ Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокЗавершен
		ИЛИ Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ИсходящийЗвонок  Тогда
			
		Запрос = ТекстЗапросаФиксацииВремениЗвонка();
		Запрос.УстановитьПараметр("Пользователь", Пользователь);
		Запрос.УстановитьПараметр("НачалоПереода", ТекущаяДата - 2592000);
		Запрос.УстановитьПараметр("КонецПереода", ТекущаяДата);
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокОператору Тогда	
				Если Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокЗавершен ИЛИ
				 	 Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВходНаЛинию ИЛИ
				 	 Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВключениеМикросип Тогда
					//Фиксация времени простоя
					Если Выборка.Период > ФиксированноеВремя Тогда
                        ФиксированноеВремя = Выборка.Период;
                    КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВзятиеТрубки Тогда	
				Если Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокОператору
				ИЛИ Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ИсходящийЗвонок
				ИЛИ Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВходНаЛинию Тогда
					//Фиксация времени простоя
					Если Выборка.Период > ФиксированноеВремя Тогда
						ФиксированноеВремя = Выборка.Период;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ИсходящийЗвонок Тогда	
				Если Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокЗавершен ИЛИ
				 	 Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВходНаЛинию ИЛИ
				 	 Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВключениеМикросип Тогда
					//Фиксация времени простоя
					Если Выборка.Период > ФиксированноеВремя Тогда
                        ФиксированноеВремя = Выборка.Период;
                    КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокЗавершен Тогда    
                Если Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВзятиеТрубки ИЛИ
                      Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ИсходящийЗвонок ИЛИ
                      Выборка.Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокОператору Тогда
                    //Фиксация времени простоя
                    Если Выборка.Период > ФиксированноеВремя Тогда
                        ФиксированноеВремя = Выборка.Период;
                    КонецЕсли;
                КонецЕсли;
            КонецЕсли;
		КонецЦикла;
		Если ПроверкаНаПервуюЗапись(Пользователь) Тогда
			Возврат 0;
		КонецЕсли;	
	КонецЕсли;
	//---Событие о звонке   ИсходящийЗвонок
	Возврат ТекущаяДата - ФиксированноеВремя;
КонецФункции

Функция ПроверкаНаПервуюЗапись(Пользователь)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ИзмерениеРаботыКонтактногоЦентраСрезПоследних.Событие КАК Событие
	|ИЗ
	|	РегистрСведений.ИзмерениеРаботыКонтактногоЦентра.СрезПоследних КАК ИзмерениеРаботыКонтактногоЦентраСрезПоследних
	|ГДЕ
	|	 ИзмерениеРаботыКонтактногоЦентраСрезПоследних.Период > &Период
	|	И ИзмерениеРаботыКонтактногоЦентраСрезПоследних.Пользователь = &Пользователь";
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Период",НачалоДня(ТекущаяДата()));
	Возврат Запрос.Выполнить().Пустой();
КонецФункции

Функция ТекстЗапросаФиксацииВремениЗвонка()
	Запрос = Новый Запрос;
	Запрос.Текст = "
