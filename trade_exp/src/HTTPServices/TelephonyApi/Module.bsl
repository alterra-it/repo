	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДанныеЗвонков.ВходящееИсходящее = &ТипЗвонка
	|			ТОГДА ДанныеЗвонков.НомерКому
	|		ИНАЧЕ ДанныеЗвонков.НомерОтКого
	|	КОНЕЦ КАК НомерТелефона
	|ПОМЕСТИТЬ ВременнаяТаблица
	|ИЗ
	|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
	|ГДЕ
	|	ДанныеЗвонков.ИдентификаторЗвонкаВАТС = &ИдентификаторЗвонкаВАТС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СтруктураПредприятия.Ссылка КАК Ссылка,
	|	ВременнаяТаблица.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВременнаяТаблица КАК ВременнаяТаблица
	|		ПО (СтруктураПредприятия.ВнутренниеНомераНачинаютсяС = ПОДСТРОКА(ВременнаяТаблица.НомерТелефона, 1, 1))
	|ГДЕ
	|	НЕ СтруктураПредприятия.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ИдентификаторЗвонкаВАТС", ИдентификаторЗвонка);
	Запрос.УстановитьПараметр("ТипЗвонка", Перечисления.ВходящееИсходящееСобытие.Входящее);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		Если СтрДлина(ВыборкаДетальныеЗаписи.НомерТелефона)=4 Тогда
			Подразделение = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Подразделение;
	
КонецФункции

