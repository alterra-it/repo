Процедура ЗаписьВРегистрИзмирениеРаботы(Пользователь, Событие)
	УстановитьПривилегированныйРежим(Истина);
	Дублирование = Ложь;
	Если Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ВключениеМикросип ИЛИ
		 Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокЗавершен ИЛИ
		  Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокОператору ИЛИ
		  Событие = Перечисления.СтатусыОператоровКонтактногоЦента.ЗвонокОператору Тогда 
		Дублирование = ПроверкаСобытияНаДублирование(Событие,Пользователь);
	КонецЕсли;
	ФиксацияВремени = РасчитатьВремяРаботы(Пользователь, Событие);
	Если Не Дублирование Тогда
		Попытка
			МенеджерЗаписи = РегистрыСведений.ИзмерениеРаботыКонтактногоЦентра.СоздатьМенеджерЗаписи(); 
			МенеджерЗаписи.Пользователь = Пользователь; 
			МенеджерЗаписи.Событие = Событие; 
			МенеджерЗаписи.Период = ТекущаяДата(); 
			МенеджерЗаписи.ФиксацияВремени = ФиксацияВремени;
			МенеджерЗаписи.Записать();
		Исключение
		КонецПопытки;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

