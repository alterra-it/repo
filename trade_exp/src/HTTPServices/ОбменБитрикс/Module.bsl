Функция ВернутьДатуИзСтроки(Значение) 
	//разбор строки
	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		Если ЗначениеЗаполнено(Значение) Тогда 
			РазделительДатыИВремени = " ";
			РазделительДаты = ".";
			РазделительВремени = ":";
			
			МассивДатаВремя = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Значение, РазделительДатыИВремени);
			МассивДата = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(МассивДатаВремя[0], РазделительДаты);
			МассивВремя = Неопределено;
			Если МассивДатаВремя.Количество() > 1 Тогда
				МассивВремя = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(МассивДатаВремя[1], РазделительВремени);
			КонецЕсли;
			День = Число(МассивДата[0]);
			Месяц = Число(МассивДата[1]);
			Год = Число(МассивДата[2]);
			Если МассивВремя <> Неопределено Тогда
				Час = Число(МассивВремя[0]);
				Минута = Число(МассивВремя[1]);
				Секунда = Число(МассивВремя[2]);
			Иначе
				Час = 0;
				Минута = 0;
				Секунда = 0;
			КонецЕсли;
			
			Возврат Дата(Год, Месяц, День, Час, Минута, Секунда);
		Иначе
			Возврат Дата(1, 1, 1, 0, 0, 0);
		КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

