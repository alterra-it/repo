Функция BudgetApplication(ДанныеJSON)
     УстановитьПривилегированныйРежим(Истина);
     ТекстОшибкиЭтапОбработкиДанных = "";
     СтрокаJSON = Строка(ДанныеJSON);
     //Попытка
         ВходящиеДанные = ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);    
         Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
             ТекстОшибкиЭтапОбработкиДанных = "Получена пустая структура";
             Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, ТекстОшибкиЭтапОбработкиДанных);
             ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЭтапОбработкиДанных + ", строка json: "+СтрокаJSON);
             Возврат Ответ;
         КонецЕсли;
        
        //ВходящиеДанные = УдалитьЭкранирование(ВходящиеДанные);
        //ВходящиеДанные = ЗаполнитьНедостающиеСвойстваПустыми(ВходящиеДанные);
        
        ПроцессЗавершен = Ложь;
        
         //Поиск документа
         ИДБизнесПроцесса = СтрЗаменить(ВходящиеДанные["ИДБизнесПроцесса"]," ","");
         ДокСсылка = Документы.ЗаявкаНаРасходованиеДенежныхСредств.НайтиПоРеквизиту("ИДЭлементаВБитриксе", ИДБизнесПроцесса);
        
         Если ДокСсылка = Неопределено ИЛИ ДокСсылка = Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПустаяСсылка() Тогда
             Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Документ Заявка на расходование денежных средств не найден в 1С");
             Возврат "";//Ответ;
         КонецЕсли;
        
         ДокЗаявка = ДокСсылка.ПолучитьОбъект();
        
         //Изменение документа
        Если ВходящиеДанные["Статус"] = "Отклонена" Тогда //Отклонена
            ДокЗаявка.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена;
            ДокЗаявка.Комментарий = ДокЗаявка.Комментарий + Символы.ПС+ВходящиеДанные["Комментарий"];
        ИначеЕсли ВходящиеДанные["Статус"] = "Доработка" Тогда //Отправлено на исправления
            НовыйСогласователь1 = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь1"]); //Справочник.Пользователи
            НовыйСогласователь2 = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь2"]); //Справочник.Пользователи
            НовыйСогласователь3 = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь3"]); //Справочник.Пользователи
            НовыйСогласователь4 = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь4"]); //Справочник.Пользователи
            НоваяОрганизацияСтрока = ВходящиеДанные["Организация"]; //Строка
            НоваяОрганизация = ПолучитьОрганизацию(НоваяОрганизацияСтрока);
            НовыйПолучатель = ВходящиеДанные["Получатель"]; //Строка
            НоваяСтавкаНДС = ВходящиеДанные["СтавкаНДС"]; //Строка
            НоваяВалюта = ВходящиеДанные["Валюта"]; //Строка
            НовоеНазначениеПлатежа = ВходящиеДанные["НазначениеПлатежа"]; //Строка
            НоваяСумма = ВходящиеДанные["Сумма"]; //Строка
            НоваяДатаПлатежаМассив = СтрРазделить(ВходящиеДанные["ДатаПлатежа"], "."); //Массив, где [0]-день, [1]-месяц, [2]-год полностью
            НоваяДатаПлатежа = Дата(НоваяДатаПлатежаМассив[2], НоваяДатаПлатежаМассив[1], НоваяДатаПлатежаМассив[0]);
            НовыйБанковскийСчет = ВходящиеДанные["БанковскийСчет"]; //Строка
            НовыйФайлПриУстраненииЗамечаний = ВходящиеДанные["Файл"]; //Строка (ИД файла)
            
            Если НовыйСогласователь1<>ДокЗаявка.Утверждающий1 Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Утверждающий 1,";
                ДокЗаявка.Утверждающий1 = НовыйСогласователь1;
            КонецЕсли;
            Если НовыйСогласователь2<>ДокЗаявка.Утверждающий2 Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Утверждающий 2,";
                ДокЗаявка.Утверждающий2 = НовыйСогласователь2;
            КонецЕсли;
            Если НовыйСогласователь3<>ДокЗаявка.Утверждающий3 Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Утверждающий 3,";
                ДокЗаявка.Утверждающий3 = НовыйСогласователь3;
            КонецЕсли;
            Если НовыйСогласователь4<>ДокЗаявка.Утверждающий4 Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Утверждающий 4,";
                ДокЗаявка.Утверждающий4 = НовыйСогласователь4;
            КонецЕсли;
            Если НоваяОрганизация<>ДокЗаявка.Организация Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Организация";
                Если Типзнч(НоваяОрганизация) = Тип("СправочникСсылка.Организации") Тогда
                    ДокЗаявка.Организация = НоваяОрганизация;
                    ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+",";
                Иначе
                    ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" (Новая:"+Строка(НоваяОрганизация)+"),";
                КонецЕсли;
            КонецЕсли;
            Если НовыйПолучатель<>ДокЗаявка.ОрганизацияПолучатель.Наименование
                И НовыйПолучатель <> ДокЗаявка.Контрагент.Наименование
                И НовыйПолучатель<>ДокЗаявка.ПолучательРучнойВвод Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Получатель(поправить),";
                ДокЗаявка.ПолучательРучнойВвод = Строка(НовыйПолучатель)+", р/с:"+Строка(НовыйБанковскийСчет);
            КонецЕсли;
            Если НоваяСтавкаНДС<>ДокЗаявка.РасшифровкаПлатежа[0].СтавкаНДС.Наименование Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Ставка НДС(новая:"+Строка(НоваяСтавкаНДС)+", проверить расшифровку платежа),";
            КонецЕсли;
            Если НоваяВалюта = "Руб" Тогда
                Если Справочники.Валюты.НайтиПоКоду("643")<>ДокЗаявка.РасшифровкаПлатежа[0].ВалютаВзаиморасчетов Тогда
                    ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Валюта(новая:"+Строка(НоваяВалюта)+", проверить расшифровку платежа),";
                КонецЕсли;
            ИначеЕсли НоваяВалюта = "USD" Тогда
                Если Справочники.Валюты.НайтиПоКоду("840")<>ДокЗаявка.РасшифровкаПлатежа[0].ВалютаВзаиморасчетов Тогда
                    ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Валюта(новая:"+Строка(НоваяВалюта)+", проверить расшифровку платежа),";
                КонецЕсли;
            КонецЕсли;
            Если НовоеНазначениеПлатежа<>ДокЗаявка.НазначениеПлатежа Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Назначение платежа,";
                ДокЗаявка.НазначениеПлатежа = НовоеНазначениеПлатежа;
            КонецЕсли;
            Если Число(НоваяСумма)<>ДокЗаявка.СуммаДокумента Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Сумма(Проверить расшифровку платежа),";
                ДокЗаявка.СуммаДокумента = Число(НоваяСумма);
            КонецЕсли;
            Если НоваяДатаПлатежа<>ДокЗаявка.ЖелательнаяДатаПлатежа Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Дата платежа,";
                ДокЗаявка.ЖелательнаяДатаПлатежа = НоваяДатаПлатежа;
            КонецЕсли;
            Если НовыйБанковскийСчет<>ДокЗаявка.БанковскийСчет.НомерСчета
                И НовыйБанковскийСчет<>ДокЗаявка.БанковскийСчетКонтрагента.НомерСчета Тогда
                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Банковский счет получателя(поправить),";
                ДокЗаявка.ПолучательРучнойВвод = Строка(НовыйПолучатель)+", р/с:"+Строка(НовыйБанковскийСчет);
            КонецЕсли;
            Если НовыйФайлПриУстраненииЗамечаний<>"" Тогда
            	//Удалить старые файлы
            	Запрос = Новый Запрос;
            	Запрос.Текст =
            		"ВЫБРАТЬ
            		|	ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.Ссылка КАК Ссылка,
            		|	ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.Наименование КАК Наименование,
            		|	ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.ВладелецФайла КАК ВладелецФайла
            		|ИЗ
            		|	Справочник.ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы КАК
            		|		ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы
            		|ГДЕ
            		|	ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла";
            	
            	Запрос.УстановитьПараметр("ВладелецФайла", ДокЗаявка.Ссылка);
            	
            	РезультатЗапроса = Запрос.Выполнить();
            	
            	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
            	
            	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
            		ФайлОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
            		ФайлОбъект.Удалить();
            	КонецЦикла;
            	
            	//Прикрепить новый файл
            	СтруктураПолученияФайла = АльтерраВзаимодействиеСБитрикс24.ПолучитьФайлИзКорневогоХранилища(НовыйФайлПриУстраненииЗамечаний);
            	СсылкаНаСкачиваниеФайла = СтруктураПолученияФайла.URL;
            	РезультатСохраненияФайла = ПолучениеФайловИзИнтернета.СкачатьФайлНаСервере(СтруктураПолученияФайла.URL); // Результат.путь
            	
            	ПозицияТочки = СтрНайти(СтруктураПолученияФайла.URL, ".", НаправлениеПоиска.СКонца);
				Расширение = Прав(СтруктураПолученияФайла.URL, СтрДлина(СтруктураПолученияФайла.URL)-ПозицияТочки);
	
				ИмяФайлаНаДиске = РезультатСохраненияФайла.Путь;	
				ДвоичныеДанные = Новый ДвоичныеДанные(ИмяФайлаНаДиске);
				ВременноеХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
				// Подготоваливаем описание файла заполнив все необходимые параметры
				ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
				ПараметрыФайла.Автор = Пользователи.ТекущийПользователь();
				ПараметрыФайла.ВладелецФайлов = ДокСсылка;
				ПараметрыФайла.ИмяБезРасширения = СтрЗаменить(СтруктураПолученияФайла.ORIGINAL_NAME, "."+Строка(Расширение), "");
				ПараметрыФайла.РасширениеБезТочки = Строка(Расширение);
				// Используем функцию БСП и добавляем файл к объекту
				РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ВременноеХранилище);

                ДокЗаявка.Комментарий = ДокЗаявка.Комментарий+" Файл(Ссылка на файл: "+Строка(СсылкаНаСкачиваниеФайла)+"),";
            КонецЕсли;
        ИначеЕсли ВходящиеДанные["Статус"] = "Завершена" Тогда //Завершена
            ДокЗаявка.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате;
            ДокЗаявка.Утверждающий = Справочники.Пользователи.ПустаяСсылка();
            Если ВходящиеДанные["Согласователь4"] <> "" Тогда
                ДокЗаявка.Утверждающий = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь4"]);
            ИначеЕсли ВходящиеДанные["Согласователь3"] <> "" Тогда
                ДокЗаявка.Утверждающий = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь3"]);
            ИначеЕсли ВходящиеДанные["Согласователь2"] <> "" Тогда
                ДокЗаявка.Утверждающий = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь2"]);
            Иначе
                ДокЗаявка.Утверждающий = ВернутьПользователяПоКоду(ВходящиеДанные["Согласователь1"]);
            КонецЕсли;
        КонецЕсли;
                 
         //Запись
         ДокЗаявка.Записать(РежимЗаписиДокумента.Проведение);
        
         Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Данные получены в 1С");
        
    //Исключение
    //     Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Ошибка чтения полученных данных в 1С");
    //     ДанныеОшибки = ИнформацияОбОшибке();
    //     ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить данные по НачислениюСписаниюББ." + Символы.ПС + ДанныеОшибки.Описание + " (Модуль: " + ДанныеОшибки.ИмяМодуля + ", номер строки: " + ДанныеОшибки.НомерСтроки + ")");
    //КонецПопытки;
    
     Возврат Ответ;    
КонецФункции

