	     Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
	         ТекстОшибкиЭтапОбработкиДанных =  "Получена пустая структура";
	         Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, ТекстОшибкиЭтапОбработкиДанных);
	         ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЭтапОбработкиДанных + ", строка json: "+СтрокаJSON);
	         Возврат Ответ;
	     КонецЕсли;
	     
		 ИДБизнесПроцесса = ВходящиеДанные["ИДБизнесПроцесса"];
	     СлужебнаяЗаписка = ПолучитьСсылкуНаСлужебнуюЗаписку(ИДБизнесПроцесса);
	     Если СлужебнаяЗаписка = Неопределено Тогда
	         Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Служебная записка не найдена в 1С");
	         Возврат Ответ;
	     КонецЕсли;
	     ЗапискаОбъект = СлужебнаяЗаписка.ПолучитьОбъект();
		 ЗапискаОбъект.Статус = ВходящиеДанные["Статус"];
		 ЗапискаОбъект.Записать();
		 
		 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Данные получены в 1С");
		 
	 Исключение
		 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Ошибка чтения полученных данных.");
		 ДанныеОшибки = ИнформацияОбОшибке();
		 ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить данные по служебной записке." + Символы.ПС + ДанныеОшибки.Описание + " (Модуль: " + ДанныеОшибки.ИмяМодуля + ", номер строки: " + ДанныеОшибки.НомерСтроки + ")");
	 КонецПопытки;
	 
	 Возврат Ответ;			
 КонецФункции  
  
Функция ПолучитьСсылкуНаСлужебнуюЗаписку(Идентификатор)
	  Запрос = Новый Запрос;
	  Запрос.Текст = 
	  "ВЫБРАТЬ
	  |	СлужебнаяЗаписка.Ссылка КАК Ссылка
	  |ИЗ
	  |	Документ.СлужебнаяЗаписка КАК СлужебнаяЗаписка
	  |ГДЕ
	  |	СлужебнаяЗаписка.ИДБизнесПроцесса = &ИДБизнесПроцесса";
	  Запрос.УстановитьПараметр("ИДБизнесПроцесса", Строка(Число(Формат(Идентификатор, "ЧДЦ=0; ЧРГ=' '"))));
	  РезультатЗапроса = Запрос.Выполнить();
	  ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	  Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		  Возврат ВыборкаДетальныеЗаписи.Ссылка;
	  КонецЕсли;
	  Возврат Неопределено;
  КонецФункции
 
