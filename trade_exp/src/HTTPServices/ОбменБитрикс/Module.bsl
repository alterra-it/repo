Функция DriverRequestCreateData(ДанныеJSON)	    
	
	УстановитьПривилегированныйРежим(Истина);
	
	ИмяСобытия = "Автоматическая регистрация перевозчика с сайта";
	СтрокаJSON = Строка(ДанныеJSON);
	СтруктураДанных = Неопределено;
	
	Попытка            
		ВходящиеДанные = ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
			ТекстОшибкиЭтапОбработкиДанных = "Получена пустая структура";
			Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, ТекстОшибкиЭтапОбработкиДанных);
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЭтапОбработкиДанных + ", строка json: " + СтрокаJSON);
			Возврат Ответ;
		КонецЕсли;            
	
		СтруктураДанных = ПолучитьОбработанныеДанные(ВходящиеДанные, DriverRequestСтруктураДанных()); 
		
		Если ЗначениеЗаполнено(СтруктураДанных) И ТипЗнч(СтруктураДанных) = Тип("Структура") Тогда
			ФизЛицо = СоздатьФизЛицо(СтруктураДанных);
			СоздатьПаспортРФ(ФизЛицо, СтруктураДанных);
			СоздатьВодительскоеУдостоверение(ФизЛицо, СтруктураДанных);
			ТС = СоздатьТС(СтруктураДанных);
			Партнер = СоздатьПартнера(СтруктураДанных, ФизЛицо, ТС);
			Сотрудник = СоздатьСотрудника(СтруктураДанных, ФизЛицо, Партнер);
			КонтактноеЛицо = СоздатьКонтактноеЛицо(СтруктураДанных, Партнер);
			Контрагент = СоздатьКонтрагента(СтруктураДанных, Партнер);
			БанковскийСчет = СоздатьБанковскийСчет(СтруктураДанных, Контрагент);
			СвязьВодителейТСПартнеров(СтруктураДанных, ФизЛицо, ТС, Партнер, Контрагент);
			
			Ответ1С = "Данные получены в 1С:  " + Символы.ПС + Символы.ПС +
				" ФизЛицо: " 	    + ФизЛицо        + Символы.ПС +
				" ТС: " 		    + ТС             + Символы.ПС +
				" Партнер: " 	    + Партнер        + Символы.ПС +
				" Сотрудник: " 	    + Сотрудник      + Символы.ПС +
				" КонтактноеЛицо: " + КонтактноеЛицо + Символы.ПС +
				" Контрагент: " 	+ Контрагент     + Символы.ПС +
				" БанковскийСчет: " + БанковскийСчет + Символы.ПС;
			
			Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, Ответ1С);
		КонецЕсли;		                                            
	Исключение
		ИнформацияОбОшибке_(СтруктураДанных, ИмяСобытия, "Не удалось получить данные!", СтрокаJSON);
	КонецПопытки;
	
	Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Ошибка чтения полученных данных!");
КонецФункции
 
Функция ПолучитьДату(Знач Дата)
	Попытка
		Возврат Дата(Дата);
	Исключение                         
		Дата = СтрЗаменить(Дата, ",", ".");
		Дата = СтрЗаменить(Дата, " ", ".");
		Дата = СтрЗаменить(Дата, "-", ".");
		Дата = СтрЗаменить(Дата, "/", ".");
		МассивСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Дата, ".");
		Дата = "";
		Для Каждого Стр Из МассивСтрок Цикл
			Дата = Стр + Дата;  
		КонецЦикла; 
	КонецПопытки;
	
	Возврат Дата(Дата);
КонецФункции

Функция СоздатьФизЛицо(СтруктураДанных)
	Наименование = СтруктураДанных.ФИОВодителя;
	ГруппаДоступа = Справочники.ГруппыДоступаФизическихЛиц.НайтиПоНаименованию("Водители");
	ДатаРождения = ?(ЗначениеЗаполнено(СтруктураДанных.ДатаРождения), ПолучитьДату(СтруктураДанных.ДатаРождения), Дата("00010101"));
	ИНН = СтруктураДанных.НомерИНН;
	АдресЭП = СтруктураДанных.ЭлектроннаяПочта;
	Телефон = СтруктураДанных.Телефон; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФизическиеЛица.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.Наименование = &Наименование
		|	И ФизическиеЛица.ГруппаДоступа = &ГруппаДоступа
		|	И ФизическиеЛица.ИНН = &ИНН
		|	И ФизическиеЛица.ДатаРождения = &ДатаРождения";
	
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Запрос.УстановитьПараметр("ГруппаДоступа", ГруппаДоступа);
	Запрос.УстановитьПараметр("ИНН", ИНН);
	Запрос.УстановитьПараметр("ДатаРождения", ДатаРождения);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();	
	Если РезультатЗапроса.Следующий() Тогда
		ФизЛицо = РезультатЗапроса.Ссылка.ПолучитьОбъект();
	Иначе
		ФизЛицо = Справочники.ФизическиеЛица.СоздатьЭлемент();
	КонецЕсли;
	
	ФизЛицо.Наименование = Наименование; 
	ФизЛицо.ГруппаДоступа = ГруппаДоступа;
	ФизЛицо.ДатаРождения = ДатаРождения; 
	ФизЛицо.ИНН = ИНН;     
	
	ФизЛицо.КонтактнаяИнформация.Очистить();
	АльтерраОбщегоНазначения.ЗаполнитьКонтакты(ФизЛицо, Телефон, АдресЭП);
		
	Возврат ЗаписатьОбъект(СтруктураДанных, ФизЛицо, "Создано Физ. лицо", "Ошибка при создании Физ. лица!", Справочники.ФизическиеЛица.ПустаяСсылка());
КонецФункции

Функция СоздатьСотрудника(СтруктураДанных, ФизическоеЛицо, Партнер)
	Если ЗначениеЗаполнено(ФизическоеЛицо) И ЗначениеЗаполнено(Партнер) Тогда
		Наименование = СтруктураДанных.ФИОВодителя;
		Отдел = Справочники.Отделы.НайтиПоНаименованию("Водители");
		Должность = Справочники.Должности.НайтиПоНаименованию("Наемные водители");
		ПотребностьВСлужебномТранспорте = Перечисления.ДаНет.Нет;

		Если Найти(СтруктураДанных.Филиал, "Бийск") > 0 Тогда
			Подразделение = Справочники.СтруктураПредприятия.НайтиПоНаименованию("Филиал Бийск");
		ИначеЕсли Найти(СтруктураДанных.Филиал, "Барнаул") > 0 Тогда
			Подразделение = Справочники.СтруктураПредприятия.НайтиПоНаименованию("Филиал Барнаул");
		ИначеЕсли Найти(СтруктураДанных.Филиал, "Новоалтайск") > 0 Тогда
			Подразделение = Справочники.СтруктураПредприятия.НайтиПоНаименованию("Центральный офис");
		Иначе
			Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка();
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Сотрудники.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Сотрудники КАК Сотрудники
			|ГДЕ
			|	Сотрудники.Наименование = &Наименование
			|	И Сотрудники.Отдел = &Отдел
			|	И Сотрудники.Должность = &Должность
			|	И ФизическоеЛицо = &ФизическоеЛицо
			|	И Партнер = &Партнер";
		
		Запрос.УстановитьПараметр("Наименование", Наименование);
		Запрос.УстановитьПараметр("Отдел", Отдел);
		Запрос.УстановитьПараметр("Должность", Должность);
		Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
		Запрос.УстановитьПараметр("Партнер", Партнер);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();	
		Если РезультатЗапроса.Следующий() Тогда
			Сотрудник = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		Иначе
			Сотрудник = Справочники.Сотрудники.СоздатьЭлемент();
		КонецЕсли;
		
		Сотрудник.Наименование = Наименование; 
		Сотрудник.Отдел = Отдел;
		Сотрудник.Должность = Должность;
		Сотрудник.ФизическоеЛицо = ФизическоеЛицо;
		Сотрудник.Партнер = Партнер;
		Сотрудник.ДатаПриема = ТекущаяДата();
		Сотрудник.ПотребностьВСлужебномТранспорте = ПотребностьВСлужебномТранспорте;
		Сотрудник.Подразделение = Подразделение;
		
		Возврат ЗаписатьОбъект(СтруктураДанных, Сотрудник, "Создан Сотрудник", "Ошибка при создании Сотрудника!", Справочники.ФизическиеЛица.ПустаяСсылка());
	Иначе
		Возврат Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Процедура СоздатьПаспортРФ(ФизЛицо, СтруктураДанных)
	Если ЗначениеЗаполнено(ФизЛицо) Тогда   
		Период = ТекущаяДата();
		
		НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(Период);
		НаборЗаписей.Отбор.Физлицо.Установить(ФизЛицо);
		НаборЗаписей.Отбор.ВидДокумента.Установить(Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ);
		
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			НоваяЗапись = НаборЗаписей.Добавить();
		Иначе
			НоваяЗапись = НаборЗаписей[0];
		КонецЕсли;
		
		НоваяЗапись.Период = Период; 
		НоваяЗапись.Физлицо = Физлицо;               
		НоваяЗапись.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ;
		НоваяЗапись.Серия = СтруктураДанных.СерияПаспорт;
		НоваяЗапись.Номер = СтруктураДанных.НомерПаспорта;
		НоваяЗапись.ДатаВыдачи = ?(ЗначениеЗаполнено(СтруктураДанных.ДатаВыдачи), ПолучитьДату(СтруктураДанных.ДатаВыдачи), Дата("00010101"));
		НоваяЗапись.КемВыдан = СтруктураДанных.КемВыдан;
		НоваяЗапись.КодПодразделения = СтруктураДанных.КодПодразделения;		
		НоваяЗапись.ЯвляетсяДокументомУдостоверяющимЛичность = Истина;
		НоваяЗапись.ФамилияЛатиницей = СтруктураДанных.ФамилияЛатиницей;
		НоваяЗапись.ИмяЛатиницей = СтруктураДанных.ИмяЛатиницей;
		НоваяЗапись.СтранаВыдачи = Справочники.СтраныМира.НайтиПоНаименованию(СтруктураДанных.СтранаВыдачи);
		
		ЗаписатьОбъект(СтруктураДанных, НаборЗаписей, "Добавлена запись в регистр 'ДокументыФизическихЛиц'", "Ошибка добавления записи в регистр 'ДокументыФизическихЛиц'!");
	КонецЕсли;
КонецПроцедуры

Процедура СоздатьВодительскоеУдостоверение(ФизЛицо, СтруктураДанных)
	Если ЗначениеЗаполнено(ФизЛицо) Тогда 
		Период = ТекущаяДата();
		
		НаборЗаписей = РегистрыСведений.ДокументыФизическихЛиц.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Период.Установить(Период);
		НаборЗаписей.Отбор.Физлицо.Установить(ФизЛицо);
		НаборЗаписей.Отбор.ВидДокумента.Установить(Справочники.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение);
		
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			НоваяЗапись = НаборЗаписей.Добавить();
		Иначе
			НоваяЗапись = НаборЗаписей[0];
		КонецЕсли;
		
		НоваяЗапись.Период = Период;
		НоваяЗапись.Физлицо = Физлицо;
		НоваяЗапись.ВидДокумента = Справочники.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение;		
		НоваяЗапись.ЯвляетсяДокументомУдостоверяющимЛичность = Ложь;
		НоваяЗапись.ФамилияЛатиницей = СтруктураДанных.ФамилияЛатиницей;
		НоваяЗапись.ИмяЛатиницей = СтруктураДанных.ИмяЛатиницей;
		НоваяЗапись.СтранаВыдачи = Справочники.СтраныМира.НайтиПоНаименованию(СтруктураДанных.СтранаВыдачи);	
		
		ЗаписатьОбъект(СтруктураДанных, НаборЗаписей, "Добавлена запись в регистр 'ДокументыФизическихЛиц'", "Ошибка добавления записи в регистр 'ДокументыФизическихЛиц'!");
	КонецЕсли;
КонецПроцедуры

Функция ВернутьЧислоИзСтроки(Строка)
	Попытка
		Возврат Число(Строка);
	Исключение
		Возврат 0;
	КонецПопытки;
КонецФункции

Функция СоздатьТС(СтруктураДанных)
	Код = СтруктураДанных.ГосНомер;
	Марка = СтруктураДанных.МаркаМашины;
	Наименование = Код + " " + Марка;
	
	ГрузоподъемностьВТоннах = ВернутьЧислоИзСтроки(СтруктураДанных.Грузоподъемность);
	ВместимостьВКубическихМетрах = ВернутьЧислоИзСтроки(СтруктураДанных.Вместимость);
	МаксимальнаяДлинаГруза = ВернутьЧислоИзСтроки(СтруктураДанных.МаксимальнаяДлинаГруза);
	НормаРасходаТоплива = ВернутьЧислоИзСтроки(СтруктураДанных.НормаРасходаТоплива);
	
	ТипТС = Справочники.ТипыТранспортныхСредств.НайтиПоНаименованию(СтруктураДанных.ТипТС);
	Если Не ЗначениеЗаполнено(ТипТС) Тогда
		ТипТС = Справочники.ТипыТранспортныхСредств.ПустаяСсылка(); 
	КонецЕсли;
	
	Если СокрЛП(ВРег(СтруктураДанных.ВидТоплива)) = ВРег("Бензин") Тогда
		ВидТоплива = Перечисления.ВидыТоплива.Бензин;
	ИначеЕсли СокрЛП(ВРег(СтруктураДанных.ВидТоплива)) = ВРег("ДТ") Тогда
		ВидТоплива = Перечисления.ВидыТоплива.ДТ;
	ИначеЕсли СокрЛП(ВРег(СтруктураДанных.ВидТоплива)) = ВРег("Газ") Тогда
		ВидТоплива = Перечисления.ВидыТоплива.Газ;
	Иначе
		ВидТоплива = Перечисления.ВидыТоплива.ПустаяСсылка();
	КонецЕсли;
	
	Запрос = Новый Запрос; // Значение реквизита "Код" должно быть уникальным во всем справочнике
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТС.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ТранспортныеСредства КАК ТС
		|ГДЕ
		|	ТС.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", Код);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();	
	Если РезультатЗапроса.Следующий() Тогда
		ТС = РезультатЗапроса.Ссылка.ПолучитьОбъект();
	Иначе
		ТС = Справочники.ТранспортныеСредства.СоздатьЭлемент();			
	КонецЕсли;        
	
	ТС.Наименование = Наименование;
	ТС.Марка = Марка;
	ТС.ГрузоподъемностьВТоннах = ГрузоподъемностьВТоннах;
	ТС.ВместимостьВКубическихМетрах = ВместимостьВКубическихМетрах;
	ТС.МаксимальнаяДлинаГруза = МаксимальнаяДлинаГруза;
	ТС.ВидТоплива = ВидТоплива;
	ТС.НормаРасходаТоплива = НормаРасходаТоплива;
	ТС.Тип = ТипТС;
	
	ТС.Фотографии.Очистить();
	
	Если СтруктураДанных.ТипЛица = "Индивидуальный предприниматель" ИЛИ СтруктураДанных.ТипЛица = "ИП" Тогда
		ЗаписатьФото("Фото Автомобиля", ТС, СтруктураДанных.ФотоАвтомобиляИП);
		ЗаписатьФото("Фото Автомобиля 2", ТС, СтруктураДанных.ФотоАвтомобиляИП2);
		ЗаписатьФото("Фото Автомобиля 3", ТС, СтруктураДанных.ФотоАвтомобиляИП3);
	Иначе
		ЗаписатьФото("Фото Автомобиля", ТС, СтруктураДанных.ФотоАвтомобиля);
		ЗаписатьФото("Фото Автомобиля 2", ТС, СтруктураДанных.ФотоАвтомобиля2);
		ЗаписатьФото("Фото Автомобиля 3", ТС, СтруктураДанных.ФотоАвтомобиля3);
	КонецЕсли;
	
	Возврат ЗаписатьОбъект(СтруктураДанных, ТС, "Создано Транспортное средство", "Ошибка при создании Транспортного средства!", Справочники.ТранспортныеСредства.ПустаяСсылка());
КонецФункции

Процедура ЗаписатьФото(ИмяФайла, Объект, Адрес)	
	Адрес = СтрЗаменить(Адрес, "https:", "");
	Адрес = СтрЗаменить(Адрес, "http:", "");
	Адрес = СтрЗаменить(Адрес, "//", "");
	
	ПоискСтроки = СтрНайти(Адрес, "/", НаправлениеПоиска.СНачала);
	Если ПоискСтроки <> 0 Тогда
		АдресСервера = Сред(Адрес, 1, ПоискСтроки - 1);
		АдресРесурса = Сред(Адрес, ПоискСтроки);
		
		ПоискСтроки = СтрНайти(АдресРесурса, ".", НаправлениеПоиска.СКонца);
		Если ПоискСтроки <> 0 Тогда
			ИмяВременногоФайла = ПолучитьИмяВременногоФайла(Сред(АдресРесурса, ПоискСтроки + 1));
			
			HTTP = Новый HTTPСоединение(АдресСервера, 443,,,,,Новый ЗащищенноеСоединениеOpenSSL());
		  	HTTP.Получить(АдресРесурса, ИмяВременногоФайла);
			
			Фото = Новый Картинка(ИмяВременногоФайла);        
			ХранилищеКартинки = Новый ХранилищеЗначения(Фото);  
			
			НоваяСтрока = Объект.Фотографии.Добавить();	
			НоваяСтрока.Название = ИмяФайла;
			НоваяСтрока.Фотография = ХранилищеКартинки;
		КонецЕсли;	
	КонецЕсли;	
КонецПроцедуры

Функция СоздатьПартнера(СтруктураДанных, ФизЛицо, ТС)
	Если ЗначениеЗаполнено(ФизЛицо) И ЗначениеЗаполнено(ТС) Тогда          
		БизнесРегион = Справочники.БизнесРегионы.НайтиПоНаименованию(СтруктураДанных.БизнесРегион);
		Если Не ЗначениеЗаполнено(БизнесРегион) Тогда
			БизнесРегион = Справочники.БизнесРегионы.ПустаяСсылка(); 
		КонецЕсли;
	
		ДатаРождения = ?(ЗначениеЗаполнено(СтруктураДанных.ДатаРождения), ПолучитьДату(СтруктураДанных.ДатаРождения), Дата("00010101"));
		Поставщик = Истина;
		Перевозчик = Истина;
		
		АдресЭП = СтруктураДанных.ЭлектроннаяПочта;
		Телефон = СтруктураДанных.Телефон; 
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(Телефон);
		
		Если СтруктураДанных.ТипЛица = "Индивидуальный предприниматель" ИЛИ СтруктураДанных.ТипЛица = "ИП" Тогда
			ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания;
			Наименование = СтруктураДанных.НазваниеЮридическогоЛица; 
			НаименованиеПолное = СтруктураДанных.НазваниеЮридическогоЛица;
		Иначе
			ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;
			Наименование = СтруктураДанных.ФИОВодителя;
			НаименованиеПолное = СтруктураДанных.ФИОПолностью;
		КонецЕсли;               
		
		// Запрещено вводить партнеров-частные лица с одинаковыми номерами
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	КИ.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТТелефон
			|ИЗ
			|	Справочник.Партнеры.КонтактнаяИнформация КАК КИ
			|ГДЕ
			|	КИ.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
			|	И КИ.НомерТелефона = &Телефон
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Партнеры.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Партнеры КАК Партнеры
			|ГДЕ
			|	(Партнеры.Наименование = &Наименование
			|				И Партнеры.НаименованиеПолное = &НаименованиеПолное
			|				И Партнеры.ДатаРождения = &ДатаРождения
			|				И Партнеры.Поставщик = &Поставщик
			|				И Партнеры.Перевозчик = &Перевозчик
			|			ИЛИ Партнеры.Ссылка В
			|				(ВЫБРАТЬ
			|					ВТТелефон.Ссылка
			|				ИЗ
			|					ВТТелефон))";
		
		Запрос.УстановитьПараметр("Наименование", Наименование);
		Запрос.УстановитьПараметр("НаименованиеПолное", НаименованиеПолное);
		Запрос.УстановитьПараметр("ДатаРождения", ДатаРождения);
		Запрос.УстановитьПараметр("Поставщик", Поставщик);
		Запрос.УстановитьПараметр("Перевозчик", Перевозчик);
		Запрос.УстановитьПараметр("Телефон", Телефон);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();	
		Если РезультатЗапроса.Следующий() Тогда
			Партнер = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		Иначе
			Партнер = Справочники.Партнеры.СоздатьЭлемент();
		КонецЕсли;
		
		Партнер.Наименование = Наименование;
		Партнер.НаименованиеПолное = НаименованиеПолное;
		Партнер.ДатаРождения = ДатаРождения;
		Партнер.Поставщик = Поставщик; 
		Партнер.Перевозчик = Перевозчик;
		Партнер.ДатаРегистрации = ТекущаяДата();
		Партнер.БизнесРегион = БизнесРегион; 
		Партнер.ЮрФизЛицо = ЮрФизЛицо; 
		
		Партнер.КонтактнаяИнформация.Очистить();
		АльтерраОбщегоНазначения.ЗаполнитьКонтакты(Партнер, Телефон, АдресЭП);  
		
		Партнер = ЗаписатьОбъект(СтруктураДанных, Партнер, "Создан Партнер", "Ошибка при создании Партнера!", Справочники.Партнеры.ПустаяСсылка());
		
		// Заполняется группа партнеров
		Если ЗначениеЗаполнено(Партнер) Тогда
			Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров");
			ЗначениеСвойства = АльтерраОбщегоНазначения.ПолучитьДобавитьЗначениеСвойства(Свойство, "Сотрудники");
			СвойствоОбъекта = АльтерраОбщегоНазначения.ПолучитьДополнительныйРеквизитПоСвойству(Партнер, Свойство);
			Если Не ЗначениеСвойства = СвойствоОбъекта Тогда
				АльтерраОбщегоНазначения.УстановитьДополнительныйРеквизитПоСвойству(Партнер, Свойство, ЗначениеСвойства);
			КонецЕсли;                           
		КонецЕсли;
		
		Возврат Партнер;
	Иначе
		Возврат Справочники.Партнеры.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция СоздатьКонтактноеЛицо(СтруктураДанных, Партнер)
	Если ЗначениеЗаполнено(Партнер) Тогда         
		Наименование = СтруктураДанных.ФИОВодителя;
		АдресЭП = СтруктураДанных.ЭлектроннаяПочта;
		Телефон = СтруктураДанных.Телефон; 
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|	КонтактныеЛицаПартнеров.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
			|ГДЕ
			|	КонтактныеЛицаПартнеров.Наименование = &Наименование
			|	И КонтактныеЛицаПартнеров.Владелец = &Партнер";
		
		Запрос.УстановитьПараметр("Наименование", Наименование);
		Запрос.УстановитьПараметр("Партнер", Партнер);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();	
		Если РезультатЗапроса.Следующий() Тогда
			КонтактноеЛицо = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		Иначе
			КонтактноеЛицо = Справочники.КонтактныеЛицаПартнеров.СоздатьЭлемент();
		КонецЕсли;
		
		КонтактноеЛицо.ДатаРегистрацииСвязи = ТекущаяДата();
		КонтактноеЛицо.Наименование = Наименование;
		КонтактноеЛицо.Владелец = Партнер;
		
		КонтактноеЛицо.КонтактнаяИнформация.Очистить();
		АльтерраОбщегоНазначения.ЗаполнитьКонтакты(КонтактноеЛицо, Телефон, АдресЭП);
		
		Возврат ЗаписатьОбъект(СтруктураДанных, КонтактноеЛицо, "Создано Контактное лицо партнера", "Ошибка при создании Контактного лица партнера!", Справочники.КонтактныеЛицаПартнеров.ПустаяСсылка());
	Иначе
		Возврат Справочники.КонтактныеЛицаПартнеров.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция СоздатьКонтрагента(СтруктураДанных, Партнер)
	Если ЗначениеЗаполнено(Партнер) Тогда
		Наименование = Партнер.Наименование;
		НаименованиеПолное	= Партнер.Наименование; 
		
		АдресЭП = СтруктураДанных.ЭлектроннаяПочта;
		Телефон = СтруктураДанных.Телефон; 
		
		Если СтруктураДанных.ТипЛица = "Индивидуальный предприниматель" ИЛИ СтруктураДанных.ТипЛица = "ИП" Тогда // ТипВодителяФЛиИП
			ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;	
			ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
		Иначе
			ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;	
			ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
		КонецЕсли;  
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Контрагенты.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Контрагенты КАК Контрагенты
			|ГДЕ
			|	Контрагенты.Партнер = &Партнер
			|	И Контрагенты.Наименование = &Наименование
			|	И Контрагенты.НаименованиеПолное = &НаименованиеПолное";

		
		Запрос.УстановитьПараметр("Партнер", Партнер);
		Запрос.УстановитьПараметр("Наименование", Наименование);
		Запрос.УстановитьПараметр("НаименованиеПолное", НаименованиеПолное);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();	
		Если РезультатЗапроса.Следующий() Тогда
			Контрагент = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		Иначе
			Контрагент = Справочники.Контрагенты.СоздатьЭлемент();
		КонецЕсли;
			
		Контрагент.Партнер = Партнер;
		Контрагент.Наименование = Наименование; 
		Контрагент.НаименованиеПолное = НаименованиеПолное;
		Контрагент.ЮридическоеФизическоеЛицо = ЮридическоеФизическоеЛицо; 
		Контрагент.ЮрФизЛицо = ЮрФизЛицо; 
		
		Контрагент.КонтактнаяИнформация.Очистить();
		АльтерраОбщегоНазначения.ЗаполнитьКонтакты(Контрагент, Телефон, АдресЭП);
		
		Возврат ЗаписатьОбъект(СтруктураДанных, Контрагент, "Создан Контрагент", "Ошибка при создании Контрагента!", Справочники.Контрагенты.ПустаяСсылка());
	Иначе
		Возврат Справочники.Контрагенты.ПустаяСсылка();	
	КонецЕсли;
КонецФункции

Функция СоздатьБанковскийСчет(СтруктураДанных, Контрагент)
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Наименование = СтруктураДанных.НаименованиеБанка;
		НомерСчета = СтруктураДанных.НомерРасчётногоСчёта;  
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	БанковскиеСчетаКонтрагентов.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.БанковскиеСчетаКонтрагентов КАК БанковскиеСчетаКонтрагентов
			|ГДЕ
			|	БанковскиеСчетаКонтрагентов.Наименование = &Наименование
			|	И БанковскиеСчетаКонтрагентов.Владелец = &Контрагент
			|	И БанковскиеСчетаКонтрагентов.НомерСчета = &НомерСчета";
		
		Запрос.УстановитьПараметр("Наименование", Наименование);
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		Запрос.УстановитьПараметр("НомерСчета", НомерСчета);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();	
		Если РезультатЗапроса.Следующий() Тогда
			Возврат РезультатЗапроса.Ссылка;
		Иначе
			БанковскийСчет = Справочники.БанковскиеСчетаКонтрагентов.СоздатьЭлемент();
		КонецЕсли;
		
		БанковскийСчет.Наименование = Наименование;
		БанковскийСчет.Владелец = Контрагент; 
		БанковскийСчет.НомерСчета = НомерСчета;
		
		Возврат ЗаписатьОбъект(СтруктураДанных, БанковскийСчет, "Создан Банковский счет контрагента", "Ошибка при создании Банковского счета контрагента!", Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка());
	Иначе
		Возврат Справочники.БанковскиеСчетаКонтрагентов.ПустаяСсылка();	
	КонецЕсли;
КонецФункции

Процедура СвязьВодителейТСПартнеров(СтруктураДанных, ФизЛицо, ТС, Партнер, Контрагент)
	Если ЗначениеЗаполнено(ФизЛицо) И ЗначениеЗаполнено(ТС) И ЗначениеЗаполнено(Партнер) И ЗначениеЗаполнено(Контрагент) Тогда
		НаборЗаписей = РегистрыСведений.СвязьВодителейТСПартнеров.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Водитель.Установить(ФизЛицо);
		НаборЗаписей.Отбор.Автомобиль.Установить(ТС);
		
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			НоваяЗапись = НаборЗаписей.Добавить();
		Иначе
			НоваяЗапись = НаборЗаписей[0];
		КонецЕсли;
		
		НоваяЗапись.Водитель = ФизЛицо;
		НоваяЗапись.Автомобиль = ТС;
		НоваяЗапись.ПеревозчикПартнер = Партнер;
		НоваяЗапись.ПеревозчикКонтрагент = Контрагент;
		
		ЗаписатьОбъект(СтруктураДанных, НаборЗаписей, "Добавлена запись в регистр 'СвязьВодителейТСПартнеров'", "Ошибка добавления записи в регистр 'СвязьВодителейТСПартнеров'!");
	КонецЕсли;
КонецПроцедуры

Функция ЗаписатьОбъект(СтруктураДанных, Объект, Комментарий, ТекстОшибки, ПустаяСсылка = Неопределено) 
	ИмяСобытия = "Автоматическая регистрация перевозчика с сайта";
	
	Попытка                 
		Объект.Записать(); 	
		
		Если ПустаяСсылка = Неопределено Тогда // Запись набора записей
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация, , , Комментарий);
		Иначе                               // Запись объекта
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Информация, , , Комментарий + ": " + Объект.Ссылка);
			
			Возврат Объект.Ссылка;
		КонецЕсли;
	Исключение
		ИнформацияОбОшибке_(СтруктураДанных, ИмяСобытия, ТекстОшибки);
	КонецПопытки;
	
	Возврат ПустаяСсылка;
КонецФункции

Процедура ИнформацияОбОшибке_(СтруктураДанных, ИмяСобытия, ТекстОшибки, СтрокаJSON = Неопределено) 
	ДанныеОшибки = ИнформацияОбОшибке();
	ДанныеСтрокой = "";
	Если ЗначениеЗаполнено(СтруктураДанных) Тогда
		Для Каждого ПолученныйЭлемент Из СтруктураДанных Цикл
			ДанныеСтрокой = ДанныеСтрокой + ПолученныйЭлемент.Ключ + ": " + ПолученныйЭлемент.Значение + "; ";
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеСтрокой) Тогда
		ИнформацияОПолученныхДанных = "Полученные данные: " + ДанныеСтрокой;
	ИначеЕсли ЗначениеЗаполнено(СтрокаJSON) Тогда
		ИнформацияОПолученныхДанных = "Строка json: " + СтрокаJSON;
	Иначе
		ИнформацияОПолученныхДанных = "";
	КонецЕсли;

	ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки + Символы.ПС + ДанныеОшибки.Описание + " (Модуль: " + ДанныеОшибки.ИмяМодуля + ", номер строки: " + ДанныеОшибки.НомерСтроки + ")" + Символы.ПС + ИнформацияОПолученныхДанных);
КонецПроцедуры

