 #Область  Bonus 
 
//Изменяет документ начисление и списание бонусных баллов
Функция Bonus(ДанныеJSON)
	
	 УстановитьПривилегированныйРежим(Истина);
	 ТекстОшибкиЭтапОбработкиДанных = "";
	 СтрокаJSON = Строка(ДанныеJSON);
	 Попытка
		 ВходящиеДанные = ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);	
		 Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
			 ТекстОшибкиЭтапОбработкиДанных =  "Получена пустая структура";
			 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, ТекстОшибкиЭтапОбработкиДанных);
			 ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЭтапОбработкиДанных + ", строка json: "+СтрокаJSON);
			 Возврат Ответ;
		 КонецЕсли;  
		 
		ВходящиеДанные = УдалитьЭкранирование(ВходящиеДанные);
		ВходящиеДанные = ЗаполнитьНедостающиеСвойстваПустыми(ВходящиеДанные);
		
		ПроцессЗавершен = Ложь; 
		
		 //Поиск документа
		 ИДБизнесПроцесса = СтрЗаменить(ВходящиеДанные["ИДБизнесПроцесса"]," ","");
		 ДокСсылка = ПолучитьСсылкуНаНачислениеСписаниеББ(ИДБизнесПроцесса);
		 
		 Если ДокСсылка = Неопределено Тогда
			 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Документ Начисления и списания бонусных баллов не найден в 1С");
			 Возврат Ответ;
		 КонецЕсли;
		 
		 ДокОбъект = ДокСсылка.ПолучитьОбъект(); 
		 Если ДокСсылка.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление  Тогда	
			 СтрокаТаблицы = ДокОбъект.Начисление[0];
		 ИначеЕсли ДокСсылка.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание Тогда 
			 СтрокаТаблицы = ДокОбъект.Списание[0];
		 КонецЕсли;    
		 
		 //Клиент
		 Если ЗначениеЗаполнено(ВходящиеДанные["КодКлиента"]) Тогда
			 КодКлиента = СокрЛП(ВходящиеДанные["КодКлиента"]);
			 Клиент = Справочники.Партнеры.НайтиПоКоду(КодКлиента);
			 Если ЗначениеЗаполнено(Клиент) Тогда 
				 СтрокаТаблицы.Партнер = Клиент;
			 КонецЕсли;
		 КонецЕсли;
		 
		 //Сумма
		 Если ЗначениеЗаполнено(ВходящиеДанные["Сумма"]) Тогда 
			 СуммаДокумента = Число(ВходящиеДанные["Сумма"]); 
			 СтрокаТаблицы.Баллы = Макс(-СуммаДокумента, СуммаДокумента); 
		 КонецЕсли; 
		 
		 //Статус
		 СтатусДокумента = ВходящиеДанные["Статус"];
		 
		 
		 Если ЗначениеЗаполнено(СтатусДокумента) Тогда
			 Если СтатусДокумента = "На доработке" Тогда
				 ДокОбъект.Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Доработка;
			 ИначеЕсли СтатусДокумента = "Согласован" Тогда
				 ДокОбъект.Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Согласован; 
			 ИначеЕсли СтатусДокумента = "Отклонен"  Тогда //Отклонен) Или СтатусДокумента = "Отклонен" Тогда
				 ДокОбъект.Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Отклонен; 
				 ПроцессЗавершен = Истина;
			 ИначеЕсли СтатусДокумента = "Исполнен" Тогда
				 ДокОбъект.Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Исполнен; 
				 ПроцессЗавершен = Истина;
			 Иначе
				 ДокОбъект.Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.НаСогласовании;  
			 КонецЕсли; 
		 КонецЕсли;		
		 

		 //Комментарий
		 Если ЗначениеЗаполнено(ВходящиеДанные["Комментарий"]) Тогда
			 ДокОбъект.Комментарий = ВходящиеДанные["Комментарий"];
		 КонецЕсли; 
		 
		 //Причина   
		 Причина = ВходящиеДанные["ВидНачисления"]; 
		 Если ЗначениеЗаполнено(Причина) Тогда
			 Если Причина = "Списание бонусов"  Тогда 	 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Списание бонусов (по бп)")  	
				 
			 ИначеЕсли  Причина = "Доначисление по продажам"  Тогда 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Доначисление (по бп)")   
				 
			 ИначеЕсли	Причина = "Неверный ценник"  Тогда 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Неверный ценник (по бп)")     
				 
			 ИначеЕсли 	Причина = "Обмен в ТЗ"  Тогда 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Обмен в ТЗ (по БП)")     
				 
			 ИначеЕсли  Причина = "За отзыв"  Тогда 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("За отзыв (по бп)")    
				 
			 ИначеЕсли  Причина = "Прочее"  Тогда 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Прочее (по бп)")      
				 
			 ИначеЕсли  Причина = "Начисление по жалобе"  Тогда 
				 ДокОбъект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("По жалобе (по БП)")    
				 
			 КонецЕсли;
		 КонецЕсли;
			 		 
		 //Утверждающие
		 
		 Для Ин = 1 По 2 Цикл 
			 
			 ИмяРеквизита = "Утверждающий" + Ин;
			 
			 Если ЗначениеЗаполнено(ВходящиеДанные[ИмяРеквизита]) Тогда   
				 
				 Пользователь = АльтерраВзаимодействиеСБитрикс24.ПолучитьПользователяПоИд(ВходящиеДанные[ИмяРеквизита]);  
				 
				 Если ЗначениеЗаполнено(Пользователь) Тогда    
					 
					 УтверждающийСотрудник = АльтерраОбщегоНазначения.ПолучитьСотрудника(Пользователь);
					 
					 Если ЗначениеЗаполнено(УтверждающийСотрудник) Тогда
						 ДокОбъект[ИмяРеквизита] = УтверждающийСотрудник; 
					 КонецЕсли; 
					 
				 КонецЕсли;     
				 
			 КонецЕсли;
			 
		 КонецЦикла; 
		 
		 		 
		 //ТекСогласователь Исполнитель
		 Если ДопМодуль.НужноСогласованиеАналитиков(ДокСсылка.Причина)  Тогда 
			 Если ЗначениеЗаполнено(ВходящиеДанные["Исполнитель"]) Тогда   		 
				 Исполнитель = АльтерраВзаимодействиеСБитрикс24.ПолучитьПользователяПоИд(ВходящиеДанные["Исполнитель"]);  			 
			 КонецЕсли; 
		 Иначе
			 Если ЗначениеЗаполнено(ВходящиеДанные["ТекСогласователь"]) Тогда   		 
				 Исполнитель = АльтерраВзаимодействиеСБитрикс24.ПолучитьПользователяПоИд(ВходящиеДанные["ТекСогласователь"]);  			 
			 КонецЕсли; 
		 КонецЕсли;
		 
		 Если ЗначениеЗаполнено(Исполнитель) Тогда    					 
			 ДокОбъект.Исполнитель = Исполнитель;		 
		 КонецЕсли;
	 		 
		 //История переписки
		 Если ПроцессЗавершен И ЗначениеЗаполнено(ВходящиеДанные["Переписка"]) Тогда
			 ДокОбъект.Комментарий = ДокОбъект.Комментарий + "
			 |История переписки в Битриксе: " + "
			 |" + ВходящиеДанные["Переписка"];
		 КонецЕсли;
		 		 
		 //Запись
		 ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
		 
		 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Данные получены в 1С");
		 Если СтатусДокумента = "Исполнен" Тогда
	    	Документы.НачислениеИСписаниеБонусныхБаллов.ОтправкаСМСОНачисленныхБонусах(ДокСсылка, ИДБизнесПроцесса);
	     КонецЕсли
	Исключение
		 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Ошибка чтения полученных данных в 1С");
		 ДанныеОшибки = ИнформацияОбОшибке();
		 ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить данные по НачислениюСписаниюББ." + Символы.ПС + ДанныеОшибки.Описание + " (Модуль: " + ДанныеОшибки.ИмяМодуля + ", номер строки: " + ДанныеОшибки.НомерСтроки + ")");
    КонецПопытки;
	 
	 Возврат Ответ;	
	 
 КонецФункции  
 
