 Функция ПолучитьСсылкуНаНачислениеСписаниеББ(ИДБизнесПроцесса)
	 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НачислениеИСписаниеБонусныхБаллов.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА НЕ Альтерра_ИдентификаторыОбъектовБ24.Идентификатор ЕСТЬ NULL
		|				И Альтерра_ИдентификаторыОбъектовБ24.Идентификатор <> """"
		|			ТОГДА Альтерра_ИдентификаторыОбъектовБ24.Идентификатор
		|		ИНАЧЕ НачислениеИСписаниеБонусныхБаллов.ИДЭлементаВБитриксе
		|	КОНЕЦ КАК ИДЭлементаВБитриксе
		|ИЗ
		|	Документ.НачислениеИСписаниеБонусныхБаллов КАК НачислениеИСписаниеБонусныхБаллов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Альтерра_ИдентификаторыОбъектовБ24 КАК Альтерра_ИдентификаторыОбъектовБ24
		|		ПО НачислениеИСписаниеБонусныхБаллов.Ссылка = Альтерра_ИдентификаторыОбъектовБ24.Объект
		|ГДЕ
		|	ВЫБОР
		|			КОГДА НЕ Альтерра_ИдентификаторыОбъектовБ24.Идентификатор ЕСТЬ NULL
		|					И Альтерра_ИдентификаторыОбъектовБ24.Идентификатор <> """"
		|				ТОГДА Альтерра_ИдентификаторыОбъектовБ24.Идентификатор
		|			ИНАЧЕ НачислениеИСписаниеБонусныхБаллов.ИДЭлементаВБитриксе
		|		КОНЕЦ = &ИДЭлементаВБитриксе";
	
	Запрос.УстановитьПараметр("ИДЭлементаВБитриксе", ИДБизнесПроцесса);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат  Выборка.Ссылка;   
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
 КонецФункции
 
 Функция ЗаполнитьНедостающиеСвойстваПустыми(ВходящиеДанные); 
	 
	 
	 МассивИмен = Новый Массив;
	 
	 МассивИмен.Добавить("ИДБизнесПроцесса");   
	 МассивИмен.Добавить("Статус");
	 МассивИмен.Добавить("Сумма");
	 МассивИмен.Добавить("Комментарий");
	 МассивИмен.Добавить("ВидНачисления");
	 МассивИмен.Добавить("Утверждающий1");
	 МассивИмен.Добавить("Утверждающий2");
	 МассивИмен.Добавить("КодКлиента");
	 МассивИмен.Добавить("ТекСогласователь");
	 МассивИмен.Добавить("Переписка");
	 МассивИмен.Добавить("ТолькоСтатус"); 
	 МассивИмен.Добавить("Исполнитель"); 

	 Для Каждого Имя Из МассивИмен Цикл
		 Если Не ВходящиеДанные.Свойство(Имя) Тогда 
			 ВходящиеДанные.Вставить(Имя,"");
		 КонецЕсли;
	 КонецЦикла;
	 
	Возврат ВходящиеДанные;
	 
 КонецФункции                   
 
 Функция УдалитьЭкранирование(ВходящиеДанные)
	 
	Для Каждого Свойство Из ВходящиеДанные Цикл  
		ВходящиеДанные[Свойство.Ключ] = СтрЗаменить(Свойство.Значение,"\", "");   
	КонецЦикла;  
	  
	Возврат ВходящиеДанные;
	
 КонецФункции
	 
