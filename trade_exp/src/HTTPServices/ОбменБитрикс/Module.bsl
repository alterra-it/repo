
Функция FinishAppeal(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеJSON= Запрос.ПолучитьТелоКакСтроку("UTF-8");
	 	 //а = АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитриксПоИДЧата("FinishAppeal", "6987");
	Метод = ПолучитьМетод(Запрос); 
	Док = Неопределено;
	Если Метод = "/CustomerAppeal/Finish" Тогда
		Ответ = Finish(ДанныеJSON);
	ИначеЕсли Метод = "/Pretend/Status" Тогда
		Ответ = Status(ДанныеJSON, Ложь);
	ИначеЕсли Метод = "/Pretend/Executor" Тогда
		Ответ = Status(ДанныеJSON, Истина);
	ИначеЕсли Метод = "/Pretend/Memo" Тогда
		Ответ = Memo(ДанныеJSON);
	ИначеЕсли Метод = "/DriverRequestCreateData" Тогда
		Ответ = DriverRequestCreateData(ДанныеJSON); 
	ИначеЕсли Метод = "/Bonus" Тогда
		Ответ = Bonus(ДанныеJSON); 
	ИначеЕсли Метод = "/Bonus/approvers" Тогда
		Ответ = BonusApprovers(ДанныеJSON);
	ИначеЕсли Метод = "/BudgetApplication" Тогда
		Ответ = BudgetApplication(ДанныеJSON);
	Иначе
		Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Передан неверный метод");
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

#Область Finish

Функция Finish(ДанныеJSON)

	 	УстановитьПривилегированныйРежим(Истина);
		ТекстОшибкиЭтапОбработкиДанных = "";
		СтрокаJSON = Строка(ДанныеJSON);
		ДанныеОбращения = Новый Структура;
		ОбращениеОбъект = Неопределено;
		Попытка
			ВходящиеДанные = ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
			Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
				ТекстОшибкиЭтапОбработкиДанных =  "Получена пустая структура";
				Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, ТекстОшибкиЭтапОбработкиДанных);
				ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЭтапОбработкиДанных + ", строка json: "+СтрокаJSON);
				Возврат Ответ;
			КонецЕсли;
			
			СтруктураДанныхОбращения = Новый Структура;
			СтруктураДанныхОбращения = ПолучитьСтруктуруДанных();
			ДанныеОбращения = ПолучитьОбработанныеДанные(ВходящиеДанные, СтруктураДанныхОбращения);
			
			ИдОбращения = ВходящиеДанные["ИдОбращения"];
 			ОбращениеСсылка = ПолучитьСсылкуНаОбращение(ИдОбращения);
			Если ОбращениеСсылка=Неопределено Тогда
				Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Документ обращения не найден в 1С");
				Возврат Ответ;
			КонецЕсли;
			ОбращениеОбъект = ОбращениеСсылка.ПолучитьОбъект();
			ЗаполнитьЗначенияСвойств(ОбращениеОбъект, 	ДанныеОбращения);
			
			ОбращениеОбъект.Статус = Перечисления.СтатусыОбращенийКлиентов.Решена;

			ТаблицаВиновныхЛиц = ОбращениеОбъект.ВиновныеЛица;
			ВиновныеСтрокой = ДанныеОбращения["ВиновныеЛица_СписокСтрокой"];
			МассивПользователей = АльтерраВзаимодействиеСБитрикс24.НайтиПользователей1СПоНаименованию(ВиновныеСтрокой); 
			ПользователиСтроками = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ВиновныеСтрокой, ",",,Истина);
			НомерПольз = 0;
			ПустойПользователь = Справочники.Пользователи.ПустаяСсылка();
			Если ПользователиСтроками.Количество()>1 Тогда 
				Для НомерСтр=0 по ПользователиСтроками.Количество()-1 Цикл
					Пользователь = МассивПользователей[НомерПольз];
					ИмяПользователяМ = ?(ЗначениеЗаполнено(Пользователь.ФизическоеЛицо), Пользователь.ФизическоеЛицо.Наименование, Пользователь.Наименование); 
					Если ПользователиСтроками[НомерСтр]  = ИмяПользователяМ Тогда 
						Стр = ТаблицаВиновныхЛиц.Добавить();
						Стр.Пользователь = Пользователь;
						НомерПольз = НомерПольз+1;
					Иначе
						ТаблицаВиновныхЛиц.Добавить(ПустойПользователь);
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
			 
			ОбращениеОбъект.ВиновныеЛица_СписокСтрокой = ВиновныеСтрокой; 
			ОбращениеОбъект.Записать();
			
			////test {
			//СтруктураДанныхОбращения.Вставить("Дата", ВернутьДатуИзСтроки(ВходящиеДанные["ДатаТест"]));
			//СтруктураДанныхОбращения.Вставить("Флажок", ВернутьБулевоИзСтроки(ВходящиеДанные["Флажок"]));
			//
			//Примечание = "Данные получены" + Символы.ПС + "Ид: " + Строка(ИдОбращения) + Символы.ПС + "Дата: " + ВернутьДатуИзСтроки(ВходящиеДанные["ДатаТест"]) + Символы.ПС + "Флажок: " + ВернутьБулевоИзСтроки(ВходящиеДанные["Флажок"]) 
			//+Символы.ПС + "Пользователь: "+ ВходящиеДанные["Пользователь"] +Символы.ПС +  "Количество: " + Строка(ВходящиеДанные["Количество"]); 
			//ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Информация, , , Примечание);
			////} test
				
			Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Данные получены в 1С");
			
		Исключение
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Ошибка чтения полученных данных.");
			ДанныеОшибки = ИнформацияОбОшибке();
			ДанныеОбращенияСтрокой = "";
			Если ДанныеОбращения.Количество() > 0 Тогда
				Для каждого ПолученныйЭлемент из ДанныеОбращения Цикл
					ДанныеОбращенияСтрокой = ДанныеОбращенияСтрокой + ПолученныйЭлемент.Ключ + ": " + ПолученныйЭлемент.Значение + "; ";
				КонецЦикла;
			КонецЕсли;
			
			Если ДанныеОбращенияСтрокой<>"" Тогда
				ИнформацияОПолученныхДанных = "Полученные данные: " + ДанныеОбращенияСтрокой;
			Иначе
				ИнформацияОПолученныхДанных = "Строка json: "+СтрокаJSON;
			КонецЕсли;
			
			ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить данные обращения." + Символы.ПС + ДанныеОшибки.Описание + " (Модуль: " + ДанныеОшибки.ИмяМодуля + ", номер строки: " + ДанныеОшибки.НомерСтроки + ")" + Символы.ПС + ДанныеОбращенияСтрокой);
		КонецПопытки;
		
		Если ОбращениеОбъект<>Неопределено Тогда
			Попытка
				ОбращениеОбъект.Записать();
			Исключение
			КонецПопытки;
		КонецЕсли;
		Возврат Ответ;			
КонецФункции // ()
	
