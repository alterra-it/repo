	  СтруктураДанных.Вставить("ОтделОбращения", Тип("СправочникСсылка.ПолучателиОбращенийКлиентов"));
	  СтруктураДанных.Вставить("ТипОбращения", Тип("СправочникСсылка.ТипыОбращенийКлиентов"));
