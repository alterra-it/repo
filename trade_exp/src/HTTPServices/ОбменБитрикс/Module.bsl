	  //
	  Возврат СтруктураДанных;
 КонецФункции
 
Функция ОбработатьДанныеБитрикса(Значение, ТипЗначения)
	Если ТипЗначения = Тип("Число") Тогда
		Если Значение = "" Тогда
			Возврат 0;
		Иначе
			Возврат Число(Значение);
		КонецЕсли;
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		Возврат ВернутьБулевоИзСтроки(Значение);
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		Возврат Значение;
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		Возврат ВернутьДатуИзСтроки(Значение);
	ИначеЕсли ТипЗначения = Тип("СправочникСсылка.Пользователи") Тогда
		Возврат ВернутьПользователяПоКоду(Значение);
	//	
	ИначеЕсли ТипЗначения = Тип("СправочникСсылка.ПолучателиОбращенийКлиентов") 
			  или ТипЗначения = Тип("СправочникСсылка.ТипыОбращенийКлиентов") 
			  или ТипЗначения = Тип("СправочникСсылка.СтруктураПредприятия") 
			  или ТипЗначения = Тип("СправочникСсылка.ВидыОбращенийКлиентов")
	Тогда
		Возврат ВернутьЗначениеСправочникаПоНаименованию(Значение, ТипЗначения);
	//	
	Иначе	
		Возврат Неопределено;
	КонецЕсли;
КонецФункции
 
Функция ВернутьЗначениеСправочникаПоНаименованию(Значение, ТипЗначения)
	Если ЗначениеЗаполнено(Значение) Тогда
		Возврат Справочники[Метаданные.НайтиПоТипу(ТипЗначения).Имя].НайтиПоНаименованию(Значение).Ссылка;
	Иначе
		Возврат Справочники[Метаданные.НайтиПоТипу(ТипЗначения).Имя].ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция ПолучитьМетод(Запрос)
	ОтносительныйURL= Запрос.ОтносительныйURL;
	Возврат ОтносительныйURL;
КонецФункции

Функция ПолучитьСсылкуНаОбращение(Идентификатор)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Альтерра_ИдентификаторыОбъектовБ24.Объект КАК Объект
		|ИЗ
		|	РегистрСведений.Альтерра_ИдентификаторыОбъектовБ24 КАК Альтерра_ИдентификаторыОбъектовБ24
		|ГДЕ
		|	Альтерра_ИдентификаторыОбъектовБ24.Идентификатор = &Идентификатор";
	Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Объект;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции // ПолучитьСсылкуНаОбращение()
	
