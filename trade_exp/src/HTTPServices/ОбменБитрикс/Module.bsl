#Область Status

Функция Status(ДанныеJSON, ЗаписатьТолькоИсполнителя)
	 
	 УстановитьПривилегированныйРежим(Истина);
	 ТекстОшибкиЭтапОбработкиДанных = "";
	 СтрокаJSON = Строка(ДанныеJSON);
	 ОбращениеОбъект = Неопределено;
	 Попытка
	     ВходящиеДанные = ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	     Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
	         ТекстОшибкиЭтапОбработкиДанных =  "Получена пустая структура";
	         Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, ТекстОшибкиЭтапОбработкиДанных);
	         ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибкиЭтапОбработкиДанных + ", строка json: "+СтрокаJSON);
	         Возврат Ответ;
	     КонецЕсли;
	     
	     ИДБизнесПроцесса = ВходящиеДанные["ИДБизнесПроцесса"];
	     ПретензияСсылка = ПолучитьСсылкуНаПретензию(ИДБизнесПроцесса);
	     Если ПретензияСсылка = Неопределено Тогда
	         Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Документ обращения не найден в 1С");
	         Возврат Ответ;
		 КонецЕсли;
		 
	     ПретензияОбъект = ПретензияСсылка.ПолучитьОбъект();
		 
		 Если ЗаписатьТолькоИсполнителя Тогда
			 Если ЗначениеЗаполнено(ВходящиеДанные["Исполнитель"]) Тогда
			 	 Исполнитель = АльтерраВзаимодействиеСБитрикс24.ПолучитьПользователяПоИд(ВходящиеДанные["Исполнитель"]);
				 Если ЗначениеЗаполнено(Исполнитель) Тогда
					 ПретензияОбъект.Исполнитель = Исполнитель; 
				 КонецЕсли;
			 КонецЕсли;		 
		 Иначе		 
		     Если ВходящиеДанные["Статус"] = "Удовлетворена" Тогда
		         ПретензияОбъект.Статус = Перечисления.СтатусыПретензийКлиентов.Удовлетворена;
		     ИначеЕсли ВходящиеДанные["Статус"] = "Не удовлетворена" Тогда
		         ПретензияОбъект.Статус = Перечисления.СтатусыПретензийКлиентов.НеУдовлетворена;
		     Иначе
		         ПретензияОбъект.Статус = Перечисления.СтатусыПретензийКлиентов.Обрабатывается;
		     КонецЕсли; 
		     
			 Если Не ВходящиеДанные["ДатаОкончания"] = "" Тогда
				 ПретензияОбъект.ДатаОкончания = ВернутьДатуИзСтроки(ВходящиеДанные["ДатаОкончания"]);
			 КонецЕсли; 
			 
		     ПретензияОбъект.РезультатыОтработки = ВходящиеДанные["РезультатыОтработки"];		 
		 КонецЕсли;
	     
		 ПретензияОбъект.Записать();
		 
		 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Данные получены в 1С");
		 
	 Исключение
		 Ответ = ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Ошибка чтения полученных данных.");
		 ДанныеОшибки = ИнформацияОбОшибке();
		 ЗаписьЖурналаРегистрации("ОбменБитрикс", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить данные по претензии." + Символы.ПС + ДанныеОшибки.Описание + " (Модуль: " + ДанныеОшибки.ИмяМодуля + ", номер строки: " + ДанныеОшибки.НомерСтроки + ")");
	 КонецПопытки;
	 
	 Возврат Ответ;			
 КонецФункции  
  
Функция ПолучитьСсылкуНаПретензию(Идентификатор)
	  Запрос = Новый Запрос;
	  Запрос.Текст = 
	  "ВЫБРАТЬ
	  |	Претензии.Ссылка КАК Ссылка
	  |ИЗ
	  |	Справочник.Претензии КАК Претензии
	  |ГДЕ
	  |	Претензии.ИДБизнесПроцесса = &ИДБизнесПроцесса";
	  Запрос.УстановитьПараметр("ИДБизнесПроцесса", Формат(Идентификатор, "ЧРГ=' '"));
	  РезультатЗапроса = Запрос.Выполнить();
	  ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	  Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		  Возврат ВыборкаДетальныеЗаписи.Ссылка;
	  КонецЕсли;
	  Возврат Неопределено;
  КонецФункции
 
