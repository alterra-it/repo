	Исключение
		
		Отказ= Истина;
		Текст= "Не удалось создать ПКО на оплату по "+ЗаказНаДоставку.Ссылка;
		ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , , Текст);
		ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст, ИнформацияОбОшибке().Описание);
