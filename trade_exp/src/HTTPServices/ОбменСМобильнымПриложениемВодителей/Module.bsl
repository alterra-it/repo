#Область Маршруты
Функция MobDeliveryEcho(Запрос)
	Ответ = Новый HTTPСервисОтвет(200);
	
	Метод= ПолучитьМетод(Запрос);
	
	Ответ.УстановитьТелоИзСтроки("Всё ОК! Метод: "+Метод, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	
	Возврат Ответ;
КонецФункции

Функция MobDeliveryОбмен(Запрос)
	УстановитьПривилегированныйРежим(Истина);  
	
	Если Константы.ИспользоватьОбработчикМетодаСервисаМобильногоПриложения.Получить() Тогда
	
		ДанныеJSON= Запрос.ПолучитьТелоКакСтроку("UTF-8");
		
		Метод= ПолучитьМетод(Запрос);
		
		//Маршрутизация
		Если Метод = "/Registration" Тогда
			ОтветHTTP= Registration(ДанныеJSON);
			
		ИначеЕсли Метод = "/ConfirmRegistration" Тогда
			ОтветHTTP= ConfirmRegistration(ДанныеJSON);
			
		ИначеЕсли Метод = "/Exchange" Тогда
			ОтветHTTP= Exchange(ДанныеJSON);
			
		ИначеЕсли Метод = "/Print" Тогда
			ОтветHTTP= Print(ДанныеJSON);
			
		ИначеЕсли Метод = "/Pay" Тогда
			ОтветHTTP= Pay(ДанныеJSON);		
			
		Иначе
			ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Передан неверный метод");
		КонецЕсли;
		
		Возврат ОтветHTTP; 
		
	Иначе 
		ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Сервис перенесен в приложение ЯндексКурьер. Для работы необходимо скачать и установить указанное приложение");
		Возврат ОтветHTTP;
	КонецЕсли;
	
КонецФункции
#КонецОбласти

#Область ОбработкаМаршрутов
Функция Registration(ДанныеJSON)
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		
		Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получена пустая структура");
			Возврат Ответ;
		КонецЕсли;
		
		Если ПустаяСтрока(ВходящиеДанные.Телефон) Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан телефон");
			Возврат Ответ;
		КонецЕсли;
		
		Если СтрДлина(ВходящиеДанные.Телефон) <> 10 Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Телефон должен быть 10 цифр");
			Возврат Ответ;
		КонецЕсли;		
		
		//Получаем водителя
		Водитель= АльтерраОбщегоНазначения.ПолучитьВодителяПоТелефону(ВходящиеДанные.Телефон);
		Если Не ЗначениеЗаполнено(Водитель) Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не обноружен водитель с таким номером в базе 1С");
			Возврат Ответ;
		КонецЕсли;
		
		//Пробуем без этого
		//Если Не ПустаяСтрока(Водитель.ИдентификаторМобильногоПриложения) Тогда
		//	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Телефон уже зарегестрирован");
		//	Возврат Ответ;
		//КонецЕсли;
		
		//Делаем проверку кода
		Если ВходящиеДанные.ЭтоТестовыйРежим Тогда
			КодОтправленный= "555";
		Иначе
			КодОтправленный= ОтправитьКодПодтверждения(ВходящиеДанные.Телефон);
		КонецЕсли;
		Если ПустаяСтрока(КодОтправленный) Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось сгенерировать код подтверждения");
			Возврат Ответ;
		КонецЕсли;
		
		Данные= Новый Структура("КодПодверждения", КодОтправленный);
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Отправлен СМС скодом подтверждения", Данные);
		Возврат Ответ;			
		
	Исключение
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось отправить код подтверждения");
		ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось отправить код подтверждения");
		Возврат Ответ;			
	КонецПопытки;
КонецФункции

Функция ConfirmRegistration(ДанныеJSON)
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
		
		Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
			Возврат Ответ;
		КонецЕсли;
		
		Если ПустаяСтрока(ВходящиеДанные.КодПодтверждения) Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан код подтверждения");
			Возврат Ответ;
		КонецЕсли;
		
		Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
			Возврат Ответ;
		КонецЕсли;			
		
		//Получаем водителя
		Водитель= АльтерраОбщегоНазначения.ПолучитьВодителяПоТелефону(ВходящиеДанные.Телефон);
		Если Не ЗначениеЗаполнено(Водитель) Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не обноружен водитель с таким номером в базе 1С");
			Возврат Ответ;
		КонецЕсли;
		
		//Если Не ПустаяСтрока(Водитель.ИдентификаторМобильногоПриложения) Тогда
		//	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Телефон уже зарегестрирован");
		//	Возврат Ответ;
		//КонецЕсли;
		
		//Делаем проверку кода
		Если ВходящиеДанные.КодПодтверждения <> ВходящиеДанные.КодОтправленный Тогда
			Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Неверный код подтверждения");
			Возврат Ответ;	
		КонецЕсли;
		
		
		//Регистрация
		НачатьТранзакцию();
		
		ОбнаруженыОшибки= Ложь;
		ВодительОбъект= Водитель.ПолучитьОбъект();
		ВодительОбъект.ИдентификаторМобильногоПриложения= ВходящиеДанные.ИдентификаторКлиента;
		ВодительОбъект.Записать();
		
		ВходящиеДанные.Вставить("Сотрудник", ВодительОбъект.Ссылка);
		
		//Ответ= ПланыОбмена.МобильноеПриложениеВодителей.ИнициализацияУзлаМобильногоУстройства(ВходящиеДанные);
		//Если Ответ.Ошибка Тогда
		//	ОбнаруженыОшибки= Истина;
		//КонецЕсли;
		
		УзелВодителя= ПланыОбмена.МобильноеПриложениеВодителей.ИнициализацияУзлаМобильногоУстройства(ВходящиеДанные);
		Если УзелВодителя = Неопределено Тогда
			ОбнаруженыОшибки= Истина;
		КонецЕсли;		
		
		//Зарегестрируем к обмену начальные данные
		ПланыОбмена.МобильноеПриложениеВодителей.ЗарегестрироватьКОбменуНачальныеДанные(УзелВодителя);
	Исключение
		ОбнаруженыОшибки= Истина;
	КонецПопытки;
	
	Если ОбнаруженыОшибки Тогда
		ОтменитьТранзакцию();
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось зарегестрировать телефон");
		ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось зарегестрировать телефон");
		Возврат Ответ;			
	Иначе
		ЗафиксироватьТранзакцию();
		
		Данные= Новый Структура;
		Данные.Вставить("Подразделение", Водитель.Подразделение.Наименование);
		Данные.Вставить("Водитель", Водитель.Наименование);
		
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Телефон успешно зарегестрирован", Данные);
		Возврат Ответ;
	КонецЕсли;
КонецФункции

Функция Exchange(ДанныеJSON)
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	//ПОЛУЧЕНИЕ
	ПланыОбмена.МобильноеПриложениеВодителей.ПринятьПакет1СДанными(ВходящиеДанные, Отказ);
	//ОТПРАВКА
	ДанныеКОтправке= ПланыОбмена.МобильноеПриложениеВодителей.ПодготовитьПакет1СКОтправке(ВходящиеДанные.ИдентификаторКлиента, Отказ);
	
	Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Обмен выполнен успешно", ДанныеКОтправке);
	Возврат Ответ;
	
	//Исключение
	//Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не удалось выполнить обмен");
	//ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , ИнформацияОбОшибке().Описание, "Не удалось выполнить обмен");
	//Возврат Ответ;			
	//КонецПопытки;
КонецФункции

Функция Print(ДанныеJSON)
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	Если Не ВходящиеДанные.Свойство("Ссылка") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передана ссылка на документ");
		Возврат Ответ;
	КонецЕсли;
	
	Ссылка= ВходящиеДанные.Ссылка;
	УИД= Новый УникальныйИдентификатор(Ссылка);
	Документ= Документы.ЗаданиеНаПеревозкуРейс.ПолучитьСсылку(УИД);
	
	Если Документ.Пустая() Тогда 
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Документ не найден в центральной базе");
		Возврат Ответ;
	КонецЕсли;
	
	Сотрудник= Справочники.Сотрудники.ПолучитьВодителяПоИдентификатору(ВходящиеДанные.ИдентификаторКлиента);
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не найден водитель");
		Возврат Ответ;
	КонецЕсли;
	
	Рейс= АльтерраОбщегоНазначения.ПолучитьПодготовленныйРейс(Сотрудник, Перечисления.СтатусыРейсов.ДокументыНаПогрузкуГотовы);
	
	Если Документ <> Рейс Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Нет подготовленных документов к печати");
		Возврат Ответ;
	КонецЕсли;
	
	Если НачалоДня(Документ.ВремяВыезда) <> НачалоДня(ТекущаяДата()) Тогда 
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Дата выезда рейса не подошла");
		Возврат Ответ;
	Иначе
		РегистрыСведений.ОчередьПечати.ДобавитьВОчередь(Документ);
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Документ отправлен на печать");
		Возврат Ответ;
	КонецЕсли;
КонецФункции

Функция Pay(ДанныеJSON)
	Отказ= Ложь;
	
	УстановитьПривилегированныйРежим(Истина);
	
	//Попытка
	ВходящиеДанные= ОбщийHTTPСервер.ДесериализоватьИзJSON(ДанныеJSON);
	
	Если ТипЗнч(ВходящиеДанные) <> Тип("Структура") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Получина пустая структура");
		Возврат Ответ;
	КонецЕсли;
	
	Если ПустаяСтрока(ВходящиеДанные.ИдентификаторКлиента) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передан идентификатор клиента");
		Возврат Ответ;
	КонецЕсли;
	
	Если Не ВходящиеДанные.Свойство("Ссылка") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передана ссылка на документ");
		Возврат Ответ;
	КонецЕсли;
	
	Если Не ВходящиеДанные.Свойство("СуммаОплаты") Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не передана сумма оплаты");
		Возврат Ответ;
	КонецЕсли;
	
	
	Сотрудник= Справочники.Сотрудники.ПолучитьВодителяПоИдентификатору(ВходящиеДанные.ИдентификаторКлиента);
	Если Не ЗначениеЗаполнено(Сотрудник) Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Не найден водитель");
		Возврат Ответ;
	КонецЕсли;
	
	Ссылка= ВходящиеДанные.Ссылка;
	СуммаОплаты= ВходящиеДанные.СуммаОплаты;
	
	Если СуммаОплаты = 0 Тогда 
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Сумма оплаты равна нулю");
		Возврат Ответ;
	КонецЕсли;
	
	УИД= Новый УникальныйИдентификатор(Ссылка);
	ЗаказНаДоставку= Документы.ЗаказНаДоставкуКлиенту.ПолучитьСсылку(УИД);

	Если Не ЗначениеЗаполнено(ЗаказНаДоставку) ИЛИ ЗаказНаДоставку.Пустая() Тогда 
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Документ не найден в центральной базе");
		Возврат Ответ;
	КонецЕсли;
	
	Адрес= ЗаказНаДоставку.Подразделение.КассаДоставка.IP;
	Порт= ЗаказНаДоставку.Подразделение.КассаДоставка.Порт;
	ИДУстройства= ЗаказНаДоставку.Подразделение.КассаДоставка.ИДУстройства;
	
	ПараметрыПодключения= АТОЛСревер.ПолучитьПараметрыСоединения(Адрес, Порт, , , Ложь, ИДУстройства);
	
	ПараметрыАТОЛ= АТОЛСревер.ШаблонПараметровАТОЛ();
	ПараметрыАТОЛ.ПараметрыПодключения= ПараметрыПодключения;
	ПараметрыАТОЛ.ИДУстройства= ПараметрыПодключения.ИДУстройства;
	ПараметрыАТОЛ.Кассир= ЗаказНаДоставку.Подразделение.КассаДоставка.Кассир;
	ПараметрыАТОЛ.НеПечататьЧек= ЗаказНаДоставку.Подразделение.КассаДоставка.НеПечататьЧек;
	ПараметрыАТОЛ.СуммаОплаты= СуммаОплаты;
	
	
	//Информация о кассовой смене
	ИнформацияОКассовойСмене= АТОЛСревер.ИнформацияОКассовойСмене(ПараметрыАТОЛ);
	Если ИнформацияОКассовойСмене.state = "expired" Тогда
		Текст= "Истек срок открытия кассовой смены";
		ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителейОплата", УровеньЖурналаРегистрации.Ошибка, , , Текст);
		ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст, );
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, Текст);
		Возврат Ответ;
	КонецЕсли;
	//ПараметрыАТОЛ.ИнформацияОКассовойСмене= ИнформацияОКассовойСмене;
	
	//Информация О ККТ
	ИнформацияККТ= АТОЛСревер.ИнформацияОККТ(ПараметрыАТОЛ);
	ПараметрыАТОЛ.Вставить("ИнформацияККТ", ИнформацияККТ);
	
	
	//ОПЛАТА
	ПолучитьТЗКОплате= Документы.ЗаказНаДоставкуКлиенту.ПолучитьТЗКОплате(ЗаказНаДоставку);
	
	Если ПолучитьТЗКОплате.Количество() = 0 Тогда
		Ответ= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "У клиента нет долгов по оплате!");
		Возврат Ответ;
	КонецЕсли;      
	
	НачатьТранзакцию();
	
	Для Каждого стрОплаты Из ПолучитьТЗКОплате Цикл
		Если ЗаказНаДоставку.ОплатаБанковскойКартой Тогда 
			ДокументОплаты = СоздатьЭквайринговуюОперацию(ЗаказНаДоставку, стрОплаты.ЗаказКлиента, Сотрудник, Отказ);
		Иначе
			ДокументОплаты = СоздатьПКО(ЗаказНаДоставку, стрОплаты.ЗаказКлиента, Сотрудник, Отказ);
		КонецЕсли;
		
		//Листы согласования
		Попытка
			//Оплатим Лист согласования
			ВыборкаЛистовСогласования= ЛистыСогласованияСервер.ПолучитьЛистыСогласования(стрОплаты.ЗаказКлиента);
			СуммаОплатыПоЛистам= СуммаОплаты;
			Пока ВыборкаЛистовСогласования.Следующий() Цикл
				Если ВыборкаЛистовСогласования.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности Тогда
					ЛистСогласования= ВыборкаЛистовСогласования.Ссылка.ПолучитьОбъект();
					ЛистСогласования.СуммаОплаты= Мин(ЛистСогласования.СуммаСогласования, СуммаОплатыПоЛистам);
					Если ЛистСогласования.СуммаСогласования = ЛистСогласования.СуммаОплаты Тогда
						ЛистСогласования.Исполнен= Истина;
						ЛистСогласования.Исполнитель= Пользователи.ТекущийПользователь();
						СуммаОплатыПоЛистам= СуммаОплатыПоЛистам-ЛистСогласования.СуммаОплаты;
					КонецЕсли;
					ЛистСогласования.Записать(РежимЗаписиДокумента.Проведение);
				КонецЕсли;
			КонецЦикла;
		Исключение
			Текст= "Не удалось исполнить лист согласования на задолженность";
			ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителейОплата", УровеньЖурналаРегистрации.Ошибка, , , Текст);
			ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст, );
			Отказ= Истина;
		КонецПопытки;
		
		//Создаим лист на доставку по звонку//изменить на "Деньги в пути"
		Попытка
			ЛистДоставкаПоЗвонку = Документы.ЛистСогласования.СоздатьДокумент();
			Документы.ЛистСогласования.ЗаполнитьДанныеПоОснованию(стрОплаты.ЗаказКлиента, ЛистДоставкаПоЗвонку, Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления);
			//ЛистДоставкаПоЗвонку.Согласовано = ЛистыСогласованияСервер.ПолучитьСогласователя(ЛистДоставкаПоЗвонку.Подразделение.Родитель);
			//ЛистДоставкаПоЗвонку.Согласован = Истина;
			ЛистДоставкаПоЗвонку.Проблема = Справочники.Проблемы.НайтиПоКоду("000000001");//Доставка по звонку//изменить на "Деньги в пути"
			ЛистДоставкаПоЗвонку.Комментарий = "Доставка с оплатой ч/з мобильное приложение";
			ЛистДоставкаПоЗвонку.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления;
			ЛистДоставкаПоЗвонку.ОсновнойМенеджер = ЗаказНаДоставку.Автор;
			ЛистДоставкаПоЗвонку.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			Текст= "Не удалось создать лист согласования: Доставка";
			ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителейОплата", УровеньЖурналаРегистрации.Ошибка, , , Текст + " " + ОписаниеОшибки());
			ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст,
			);
			Отказ= Истина;
		КонецПопытки;
		
		//-
		Если Не Отказ Тогда
			ЗафиксироватьТранзакцию();
			
			//пробитие чека
			ПараметрыАТОЛ.ДокументПродажи= стрОплаты.ЗаказКлиента;
			ПараметрыАТОЛ.ДокументОплаты= ДокументОплаты;
			
			Ответ= ПробитьЧек(ПараметрыАТОЛ, Сотрудник, Отказ);
			
			//Проверить пробит ли чек
			Если Ответ.Ошибка Тогда
				Текст= Ответ.ТекстСообщения;
				ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителейОплата", УровеньЖурналаРегистрации.Ошибка, , , Текст);
				ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, "Оплата по данному документу уже была произведена", );
				Отказ= Истина;
			КонецЕсли;
			УИД= Ответ.Данные.uuid;
			Ответ= АТОЛСревер.РезультатПробитияЧека(ПараметрыАТОЛ, УИД);
			
			Если Не Ответ.Ошибка Тогда
				ДанныеФН= Ответ.Данные;
				//ЗаписатьФискальнуюОперацию
				ПараметрыФискализации= АТОЛСревер.ПодготовитьДанныеФискализацииЧека(ПараметрыАТОЛ, ДанныеФН);
				МенеджерОборудованияВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации);
				
				ДанныеQR= АТОЛСревер.ПолучитьФНДанныеДляQRКода(ПараметрыАТОЛ, ДанныеФН);
				ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Чек пробит", ДанныеQR);
				
				
				Возврат ОтветHTTP;
			Иначе
				Текст= Ответ.ТекстСообщения;
				ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , Ответ.ТекстСообщения, Текст);
				ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст, Ответ.ТекстСообщения);
				
				ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, Текст, Ответ.Данные);
				
				ОтменитьТранзакцию();
				
				Возврат ОтветHTTP;
			КонецЕсли;
		КонецЕсли;

	КонецЦикла;
	
	//Если Не Отказ Тогда 
	//	ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Чек пробит");
	//	ЗафиксироватьТранзакцию();
	Если Отказ Тогда 
		ОтветHTTP= ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Истина, "Чек не пробит");
		ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, "Отмена транзакции оплаты", );
		ОтменитьТранзакцию();
	КонецЕсли;
	
	Возврат ОтветHTTP;

КонецФункции

#КонецОбласти

#Область Оплата
Функция СоздатьЭквайринговуюОперацию(ЗаказНаДоставку, ДокПродажи, Сотрудник, Отказ)
	УстановитьПривилегированныйРежим(Истина);
	
	//Эквайринг= ПолучитьЭквайринговуюОперацию(Заказ);
	
	Попытка
		Док= Документы.ОперацияПоПлатежнойКарте.СоздатьДокумент();
		Док.Заполнить(ДокПродажи);
		Док.Дата= ТекущаяДата();
		Док.НомерПлатежнойКарты= "0101";
		Док.ЭквайринговыйТерминал= ДокПродажи.Подразделение.ЭквайринговыйТерминалДоставка;
		Док.Комментарий= "Создан из мобильного приложения";
		Док.Записать(РежимЗаписиДокумента.Проведение);
		//Док.Записать(РежимЗаписиДокумента.Запись);
		
	Исключение
		
		Отказ= Истина;
		Текст= "Не удалось создать Эквайринговую операцию на оплату по "+ЗаказНаДоставку.Ссылка;
		ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , , Текст);
		ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст, ИнформацияОбОшибке().Описание);
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Док.Ссылка;
	
КонецФункции

Функция СоздатьПКО(ЗаказНаДоставку, ДокПродажи, Сотрудник, Отказ)
	Попытка
		Док= Документы.ПриходныйКассовыйОрдер.СоздатьДокумент();
