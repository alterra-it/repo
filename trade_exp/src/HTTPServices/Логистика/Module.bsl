#Область ВходящиеHTTPЗапросы

Функция getDuty(Запрос)
	
	УстановитьПривилегированныйРежим(Истина);  
	
	ПараметрыВходногоЗапроса = ИнтеграцияREST.ПолучитьПараметрыHTTPЗапроса(Запрос);
	
	Попытка                               
	
		ДатаДежурства = Запрос.ПараметрыЗапроса.Получить("date");
		
		ДатаДежурства = ?(ЗначениеЗаполнено(ДатаДежурства), 
			Дата(Сред(ДатаДежурства, 7, 4), Сред(ДатаДежурства, 4, 2), Лев(ДатаДежурства, 2)), 
			ТекущаяДатаСеанса());
		
		ГрафикДежурства = ПолучитьГрафикНаДату(ДатаДежурства);
		
		Возврат
			?(ЗначениеЗаполнено(ГрафикДежурства), 
				ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ГрафикДежурства),
				ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, СтрШаблон("График дежурств на %1 не определен", Формат(ДатаДежурства, "ДФ=dd.MM.yyyy;"))));  
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции

Функция getDeliveryVariants(Запрос) 
	
	УстановитьПривилегированныйРежим(Истина);  
	
	Попытка
		ПараметрыВходногоЗапроса = ИнтеграцияREST.ПолучитьПараметрыHTTPЗапроса(Запрос);   
		
		ВходныеДанные = ИнтеграцияREST.ПолучитьТелоHTTPЗапроса(Запрос.ПолучитьТелоКакСтроку("UTF-8"));
		Если Не ВходныеДанные.Результат Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ВходныеДанные.Тело);
		КонецЕсли;
		
		ВходныеДанныеСтруктура = ДанныеЗапросаgetDeliveryVariants(ВходныеДанные.Тело);     
		Если Не ВходныеДанныеСтруктура.Результат Тогда
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ВходныеДанныеСтруктура.ДанныеЗапроса);
		КонецЕсли;              
		
		ПолучениеТарифовИнтервалов = ПолучитьТарифыИнтервалыДоставки(ВходныеДанныеСтруктура.ДанныеЗапроса);
			
		Если ПолучениеТарифовИнтервалов.Результат Тогда                                         
			Возврат ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, ПолучениеТарифовИнтервалов);    
		Иначе                           
			Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ПолучениеТарифовИнтервалов.Сообщение);			
		КонецЕсли;
	
	Исключение
		Возврат ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));			
	КонецПопытки;	 
	
КонецФункции

#КонецОбласти

#Область ДействияHTTPЗапросы

Функция ЗаписатьНТТPОтвет(ПараметрыВходногоЗапроса, РезультатЗапроса)   
	
	Ответ = Новый HTTPСервисОтвет(200);   
	Ответ.Заголовки = УстановитьHTTPЗаголовки();
	
	ЗаписьJSON = Новый ЗаписьJSON;   
	ЗаписьJSON.ПроверятьСтруктуру = Ложь;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( , Символы.Таб);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);

	ЗаписьJSON.ЗаписатьНачалоОбъекта();
		
		ЗаписьJSON.ЗаписатьИмяСвойства("error");
		ЗаписьJSON.ЗаписатьЗначение(Ложь);
		
		ЗаписатьHTTPГрафикДежурств(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);
		ЗаписатьHTTPТарифыИнтервалыДоставки(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса);

	ЗаписьJSON.ЗаписатьКонецОбъекта();			
		 
	СтрокаJSON = ЗаписьJSON.Закрыть();   
	
	Ответ.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);
	Возврат Ответ; 
	
КонецФункции	

Процедура ЗаписатьHTTPГрафикДежурств(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)  
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "getDuty" Тогда 
		Возврат;
	КонецЕсли;   
	
	ЗаписьJSON.ЗаписатьИмяСвойства("data");
	ЗаписьJSON.ЗаписатьНачалоМассива();

		Для Каждого СтрГрафик Из РезультатЗапроса Цикл
			
			ЗаписьJSON.ЗаписатьНачалоОбъекта();
			
				ЗаписьJSON.ЗаписатьИмяСвойства("name");
				ЗаписьJSON.ЗаписатьЗначение(Строка(СтрГрафик.name));
				
				ЗаписьJSON.ЗаписатьИмяСвойства("phone");
				ЗаписьJSON.ЗаписатьЗначение(Строка(СтрГрафик.phone));
				
				ЗаписьJSON.ЗаписатьИмяСвойства("branch");
				ЗаписьJSON.ЗаписатьЗначение(Строка(СтрГрафик.filial));
				
			ЗаписьJSON.ЗаписатьКонецОбъекта();
		КонецЦикла;

	ЗаписьJSON.ЗаписатьКонецМассива();
	
КонецПроцедуры        

Процедура ЗаписатьHTTPТарифыИнтервалыДоставки(ПараметрыВходногоЗапроса, ЗаписьJSON, РезультатЗапроса)  
	
	Если ПараметрыВходногоЗапроса.ТипЗапроса <> "getDeliveryVariants" Тогда 
		Возврат;
	КонецЕсли;   
	
	ЗаписьJSON.ЗаписатьИмяСвойства("data");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();       

		ЗаписьJSON.ЗаписатьИмяСвойства("max_delivery_date");
		ЗаписьJSON.ЗаписатьЗначение(Формат(РезультатЗапроса.МаксимальнаяДатаДоставки, "ДФ=dd.MM.yyyy"));
	
		ЗаписьJSON.ЗаписатьИмяСвойства("tarrifs");
		ЗаписьJSON.ЗаписатьНачалоМассива();

			Для Каждого Тариф Из РезультатЗапроса.Тарифы Цикл
				
				ЗаписьJSON.ЗаписатьНачалоОбъекта();
				
					ЗаписьJSON.ЗаписатьИмяСвойства("id");
					ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(Тариф.Тариф));
				
					ЗаписьJSON.ЗаписатьИмяСвойства("name");
					ЗаписьJSON.ЗаписатьЗначение(Строка(Тариф.Тариф));
					
					ЗаписьJSON.ЗаписатьИмяСвойства("delivery_name");
					ЗаписьJSON.ЗаписатьЗначение(Строка(Тариф.ТипДоставки));

					ЗаписьJSON.ЗаписатьИмяСвойства("price");
					ЗаписьJSON.ЗаписатьЗначение(Тариф.СтоимостьДоставки); 

					ЗаписьJSON.ЗаписатьИмяСвойства("intervals");
					ЗаписьJSON.ЗаписатьНачалоМассива();
						
						ИнтервалыТарифа = РезультатЗапроса.Интервалы.НайтиСтроки(Новый Структура("Тариф", Тариф.Тариф));
						Для Каждого Интервал Из ИнтервалыТарифа Цикл    
							
							ЗаписьJSON.ЗаписатьНачалоОбъекта();
							
								ЗаписьJSON.ЗаписатьИмяСвойства("id");
								ЗаписьJSON.ЗаписатьЗначение(XMLСтрока(Интервал.Интервал));
								
								ЗаписьJSON.ЗаписатьИмяСвойства("name");
								ЗаписьJSON.ЗаписатьЗначение(Строка(Интервал.Интервал)); 
								
								ЗаписьJSON.ЗаписатьИмяСвойства("label");
								ЗаписьJSON.ЗаписатьЗначение(Интервал.ИнтервалНаименованиеНаСайте); 
								
								ЗаписьJSON.ЗаписатьИмяСвойства("active");
								ЗаписьJSON.ЗаписатьЗначение(Интервал.Доступно); 
								
								ЗаписьJSON.ЗаписатьИмяСвойства("from");
								ЗаписьJSON.ЗаписатьЗначение(Час(Интервал.ВремяС)); 
								
								ЗаписьJSON.ЗаписатьИмяСвойства("to");
								ЗаписьJSON.ЗаписатьЗначение(Час(Интервал.ВремяПо)); 
								
								ЗаписьJSON.ЗаписатьИмяСвойства("range");
								ЗаписьJSON.ЗаписатьЗначение((Интервал.ВремяПо - Интервал.ВремяС) / 3600); 
								
								//ЗаписьJSON.ЗаписатьИмяСвойства("week_day");
								//ЗаписьJSON.ЗаписатьЗначение(Интервал.ДеньНедели); 
								
								ЗаписьJSON.ЗаписатьИмяСвойства("unloading");
								ЗаписьJSON.ЗаписатьЗначение(Интервал.ДоступноРазгрузка); 
								
							ЗаписьJSON.ЗаписатьКонецОбъекта();
							
						КонецЦикла;  
						
						ЗаписьJSON.ЗаписатьКонецМассива();
					
				ЗаписьJSON.ЗаписатьКонецОбъекта();
			КонецЦикла;

		ЗаписьJSON.ЗаписатьКонецМассива();
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	
КонецПроцедуры

Функция ЗаписатьHTTPОшибку(ПараметрыВходногоЗапроса, ТекстОшибки = "", Статус = 400)
	
	Ответ = Новый HTTPСервисОтвет(Статус);
	Ответ.Заголовки = УстановитьHTTPЗаголовки();		
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.ПроверятьСтруктуру = Ложь;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( , Символы.Таб);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);
	
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
	
	ЗаписьJSON.ЗаписатьИмяСвойства("error");
	ЗаписьJSON.ЗаписатьЗначение(Истина);	
	
	ЗаписьJSON.ЗаписатьИмяСвойства("response");
	ЗаписьJSON.ЗаписатьНачалоОбъекта();
		ЗаписьJSON.ЗаписатьИмяСвойства("status");
		ЗаписьJSON.ЗаписатьЗначение(Статус);
		
		ЗаписьJSON.ЗаписатьИмяСвойства("description");
		ЗаписьJSON.ЗаписатьЗначение(ТекстОшибки); 
		
	ЗаписьJSON.ЗаписатьКонецОбъекта();
	
	ЗаписьJSON.ЗаписатьКонецОбъекта();  
	
	СтрокаJSON = ЗаписьJSON.Закрыть();    

	Ответ.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);	
	Возврат Ответ; 
	
КонецФункции  

Функция УстановитьHTTPЗаголовки()   
	
	 Заголовки = Новый Соответствие;
	 Заголовки.Вставить("Content-Type", "application/json");
	 Заголовки.Вставить("charset", "utf-8");
	 Возврат Заголовки 
	 
 КонецФункции 
 
 #КонецОбласти
 
 #Область ОбработкаВходныхЗапросов  
  
Функция ПолучитьГрафикНаДату(НаДату = Неопределено)
	
	НаДату = ?(ЗначениеЗаполнено(НаДату), НаДату, ТекущаяДата());
	
	График = Новый ТаблицаЗначений();
	График.Колонки.Добавить("duty_date");
	График.Колонки.Добавить("filial");
	График.Колонки.Добавить("name");
	График.Колонки.Добавить("phone");
	
	ОбозначенияФилиалов = Новый ТаблицаЗначений();
	ОбозначенияФилиалов.Колонки.Добавить("Обозначение");
	ОбозначенияФилиалов.Колонки.Добавить("Филиал");
	Стр1 = ОбозначенияФилиалов.Добавить();
	Стр1.Обозначение = "а";
	Стр1.Филиал = "Центральная база";
	Стр2 = ОбозначенияФилиалов.Добавить();
	Стр2.Обозначение = "б";
	Стр2.Филиал = "Выбор";
	Стр3 = ОбозначенияФилиалов.Добавить();
	Стр3.Обозначение = "с";
	Стр3.Филиал = "Барнаул";
	Стр4 = ОбозначенияФилиалов.Добавить();
	Стр4.Обозначение = "д";
	Стр4.Филиал = "Бийск";
	Стр5 = ОбозначенияФилиалов.Добавить();
	Стр5.Обозначение = "з";
	Стр5.Филиал = "Документооборот";     
	Стр6 = ОбозначенияФилиалов.Добавить();
	Стр6.Обозначение = "м";
	Стр6.Филиал = "Майма";
	
	СтруктураГрафикаНаДату = ПолучитьСтруктуруГрафикаНаДату(НаДату);
	
	Если Не ЗначениеЗаполнено(СтруктураГрафикаНаДату) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НаДатуДень = День(НаДату);
		
	Для Каждого ДежурстваСотрудника Из СтруктураГрафикаНаДату Цикл
		
		ОбозначенияДежурств = ДежурстваСотрудника["Примечание" + НаДатуДень];
		СписокФилиалов = "";
		
		Для НомерСимвола = 1 По СтрДлина(ОбозначенияДежурств) Цикл
			
			ТекущийСимвол = Сред(НРег(ОбозначенияДежурств), НомерСимвола, 1);
			ОбозначениеФилиала = ОбозначенияФилиалов.Найти(ТекущийСимвол, "Обозначение");
			
			Если ЗначениеЗаполнено(ОбозначениеФилиала) Тогда
				СписокФилиалов = СписокФилиалов + ?(ЗначениеЗаполнено(СписокФилиалов), ", ", "") + ОбозначениеФилиала.Филиал;	
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЗначениеЗаполнено(СписокФилиалов) Тогда
		
			СтрГрафик = График.Добавить();
			СтрГрафик.duty_date = Формат(НаДату, "ДФ=dd.MM.yyyy");
			СтрГрафик.filial = СписокФилиалов;
			СтрГрафик.name = ДежурстваСотрудника.Сотрудник;
			
			Телефон = "Нет телефона";
			Телефон = ?(ЗначениеЗаполнено(ДежурстваСотрудника.КорпоративныйТелефон), ДежурстваСотрудника.КорпоративныйТелефон, Телефон);
			Телефон = ?(ЗначениеЗаполнено(ДежурстваСотрудника.ВнутреннийТелефон), ДежурстваСотрудника.ВнутреннийТелефон, Телефон);
			СтрГрафик.phone = Телефон;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат График;
	
КонецФункции

