 Функция ПолучитьТарифыИнтервалыДоставки(ДанныеЗапроса)
	 
	РезультатВыполнения = Новый Структура("Результат, Сообщение, Тарифы, Интервалы, МаксимальнаяДатаДоставки", Ложь, "");
	
	Попытка 
		// Расчет объема
		ДанныеЗапроса.Объем = УправлениеЛогистикойСервер.ПолучитьОбъем(ДанныеЗапроса.Товары); 
		ДанныеЗапроса.ОбъемСУчетомСкрутокПоликарбоната = УправлениеЛогистикойСервер.ПолучитьОбъемСУчетомСкрутокПоликарбоната(ДанныеЗапроса.Товары);   	
		ДанныеЗапроса.ОбъемСУчетомСкрутокПоликарбоната = ?(ДанныеЗапроса.ОбъемСУчетомСкрутокПоликарбоната = 0, ДанныеЗапроса.Объем, ДанныеЗапроса.ОбъемСУчетомСкрутокПоликарбоната);	
		Если ДанныеЗапроса.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда 
			 ДанныеЗапроса.Объем = ДанныеЗапроса.ОбъемСУчетомСкрутокПоликарбоната;		
		КонецЕсли;
		
		// Получение типов ТС по весу, длине, объему
		ТипыТС = УправлениеЛогистикойСервер.ПолучитьТипыТС(ДанныеЗапроса); 
		Если ТипыТС.Количество() = 0 Тогда
			РезультатВыполнения.Сообщение = "В розничной доставке нет подходящего типа транспорта";
			Возврат РезультатВыполнения;
		КонецЕсли;   
		
		// Получение интервалов доставки по филиалу и виду доставки на дату
        Интервалы = ПолучитьИнтервалы(ДанныеЗапроса);
		Если ТипыТС.Количество() = 0 Тогда
			РезультатВыполнения.Сообщение = "В розничной доставке нет подходящих интервалов доставки";
			Возврат РезультатВыполнения;
		КонецЕсли;   
		
		// Получение тарифов и интервалов тарифов соответсвующих интервалам доставки
		ПолучениеТарифов = ПолучитьТарифы(ТипыТС, Интервалы, ДанныеЗапроса);
		Если ПолучениеТарифов.Тарифы.Количество() = 0 Тогда
			РезультатВыполнения.Сообщение = "В розничной доставке нет подходящего тарифа";
			Возврат РезультатВыполнения;
		КонецЕсли;           
		Если ПолучениеТарифов.Интервалы.Количество() = 0 Тогда
			РезультатВыполнения.Сообщение = "В розничной доставке подходящих интервалов доставки";
			Возврат РезультатВыполнения;
		КонецЕсли;           
		
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, ПолучениеТарифов);
		РезультатВыполнения.МаксимальнаяДатаДоставки = ДанныеЗапроса.МаксимальнаяДатаДоставки;
		РезультатВыполнения.Результат = Истина;
		
	Исключение   
		РезультатВыполнения.Сообщение = СтрШаблон("Ошибка получения тарифов и интервалов: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));		
	КонецПопытки;
	
	Возврат РезультатВыполнения;
	 
КонецФункции	 

#КонецОбласти         

 #Область ВходныеДанные   
 
 Функция ДанныеЗапросаgetDeliveryVariants(ВходныеДанные)   
	 
	РезультатВыполнения = Новый Структура("Результат, ДанныеЗапроса", Ложь, ""); 
	
	Попытка
		ДанныеЗапроса = Новый Структура;  
		
		date = ВходныеДанные.Получить("date");
		Попытка
			ДанныеЗапроса.Вставить("ДатаДоставки", Дата(Число(Прав(date, 4)), Число(Сред(date, 4, 2)), Число(Лев(date, 2))));	
		Исключение                                                              
			РезультатВыполнения.ДанныеЗапроса = "Не определена дата доставки";
			Возврат РезультатВыполнения;
		КонецПопытки;   

		Если ДанныеЗапроса.ДатаДоставки < НачалоДня(ТекущаяДата()) Тогда
			РезультатВыполнения.ДанныеЗапроса = "Дата доставки меньше текущей";
			Возврат РезультатВыполнения;
		КонецЕсли;
		
		ДанныеЗапроса.Вставить("МаксимальнаяДатаДоставки", НачалоДня(ТекущаяДата()) + Константы.ОграничениеПериодаДоставки.Получить() * 24*60*60);
		Если ДанныеЗапроса.ДатаДоставки >= ДанныеЗапроса.МаксимальнаяДатаДоставки Тогда
			РезультатВыполнения.ДанныеЗапроса = СтрШаблон("Максимальная дата доставки %1", Формат(ДанныеЗапроса.МаксимальнаяДатаДоставки, "ДФ=dd.MM.yyyy"));
			Возврат РезультатВыполнения;
		КонецЕсли;
		
		ДанныеЗапроса.Вставить("Адрес", ВходныеДанные.Получить("address"));
		
		coords = ВходныеДанные.Получить("coords");
		ДанныеЗапроса.Вставить("Коодинаты", Новый Структура("Широта, Долгота", coords[0], coords[1]));
		
		zone_id = ВходныеДанные.Получить("zone_id");         
		Попытка
			ДанныеЗапроса.Вставить("ЗонаДоставки", Справочники.ЗоныДоставкиДоКлиента.ПолучитьСсылку(Новый УникальныйИдентификатор(zone_id)));
		Исключение   
			РезультатВыполнения.ДанныеЗапроса = "Не определена зона доставки";    
			Возврат РезультатВыполнения;
		КонецПопытки;
		
		store = ВходныеДанные.Получить("store");
		Попытка
			ДанныеЗапроса.Вставить("Склад", Справочники.Склады.ПолучитьСсылку(Новый УникальныйИдентификатор(store)));
			ДанныеЗапроса.Вставить("Подразделение", ДанныеЗапроса.Склад.Подразделение);
		Исключение
			РезультатВыполнения.ДанныеЗапроса = "Не определен склад"; 
			Возврат РезультатВыполнения;
		КонецПопытки;                              
		
		delivery_type = ВходныеДанные.Получить("delivery_type");  
		ДанныеЗапроса.Вставить("ВидДоставки");
		Если delivery_type = "retail" Тогда   
			ДанныеЗапроса.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная");
		Иначе
			ДанныеЗапроса.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.СборнаяОРК");
		КонецЕсли;
		
		Товары = Новый ТаблицаЗначений;
		Товары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));     
		КвалификаторЧисла = Новый КвалификаторыЧисла(15,3, ДопустимыйЗнак.Неотрицательный);
		Товары.Колонки.Добавить("КоличествоУпаковок", Новый ОписаниеТипов("Число", КвалификаторЧисла));      
		
		Для Каждого product Из ВходныеДанные.Получить("products") Цикл   
			Товар = Товары.Добавить();    
			
			Товар.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(product.Получить("id")));
			Товар.КоличествоУпаковок = product.Получить("count");
		КонецЦикла;  
		
		ДанныеЗапроса.Вставить("Товары", Товары);
		
		ДанныеЗапроса.Вставить("МаксимальнаяДлина", Число(ВходныеДанные.Получить("max_length")) / 1000 ); // мм в мм
		ДанныеЗапроса.Вставить("Вес",Число(ВходныеДанные.Получить("total_weight")) / 1000); // г в кг        
		
		ДанныеЗапроса.Вставить("Объем");
		ДанныеЗапроса.Вставить("ОбъемСУчетомСкрутокПоликарбоната");
		
		РезультатВыполнения.Результат = Истина;
		РезультатВыполнения.ДанныеЗапроса = ДанныеЗапроса;
	
	Исключение
		РезультатВыполнения.ДанныеЗапроса = СтрШаблон("Ошибка преобразования входного JSON: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));		
	КонецПопытки;
	
	Возврат РезультатВыполнения;
	
КонецФункции	 
 
 #КонецОбласти   
 
 #Область ПолучениеДанныхДоставки              
 
 Функция ПолучитьИнтервалы(Данные)    
	 
	Запрос = Новый Запрос(Справочники.ИнтервалыДоставки.ПолучитьТекстЗапросаДляВыбораИнтервала());
	Запрос.УстановитьПараметр("ДатаОтгрузки",        Данные.ДатаДоставки);
	Запрос.УстановитьПараметр("Подразделение",       Данные.Подразделение);
	Запрос.УстановитьПараметр("ВидДоставки",         Данные.ВидДоставки);
	Запрос.УстановитьПараметр("ДоставкаСРазгрузкой", Истина);
	Запрос.УстановитьПараметр("КорИнтервала",        0);
	Запрос.УстановитьПараметр("ТекДата",             ТекущаяДата());
	
	Если ДеньНедели(Данные.ДатаДоставки) < 6  И Данные.ВидДоставки <> Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
		Запрос.УстановитьПараметр("ДеньНедели", 0);
	Иначе
		Запрос.УстановитьПараметр("ДеньНедели", ДеньНедели(Данные.ДатаДоставки));
	КонецЕсли;	
	
	Возврат Запрос.Выполнить().Выгрузить();
	 
КонецФункции	 
 
 Функция ПолучитьТарифы(ТипыТС, Интервалы, Данные)
	 
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТипыТС.ТипТС КАК ТипТС
		|ПОМЕСТИТЬ втТипыТС
		|ИЗ
		|	&ТипыТС КАК ТипыТС
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НастройкиТарифов.ТипТС КАК ТипТС,
		|	НастройкиТарифов.Тариф КАК Тариф
		|ПОМЕСТИТЬ втТарифы
		|ИЗ
		|	&НастройкиТарифов КАК НастройкиТарифов 
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ГлобальнаяЗона           
		|ПОМЕСТИТЬ втГлобальныеЗоны	
		|ИЗ
		|	РегистрСведений.ГлобальныеЗоныПоЗонамДоставкиДоКлиента
		|ГДЕ
		|	Подразделение = &Подразделение
		|	И Зона = &ЗонаДоставки
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТарифыПеревозчиков.Ссылка КАК Тариф,
		|	ТипыДоставок.Ссылка КАК ТипДоставки
		|ПОМЕСТИТЬ втНастройкиТарифов
		|ИЗ
		|	втТипыТС 
		|	СОЕДИНЕНИЕ втТарифы
		|		ПО втТипыТС.ТипТС = втТарифы.ТипТС
		|	СОЕДИНЕНИЕ Справочник.ТипыТранспортныхСредств КАК ТипыТС
		|		ПО втТарифы.ТипТС = ТипыТС.Ссылка 
		|	СОЕДИНЕНИЕ Справочник.ТарифыПеревозчиков КАК ТарифыПеревозчиков
		|		ПО втТарифы.Тариф = ТарифыПеревозчиков.Ссылка 
		|	СОЕДИНЕНИЕ Справочник.ТипыДоставок КАК ТипыДоставок
		|		ПО ТарифыПеревозчиков.ТипДоставки = ТипыДоставок.Ссылка 
		|	СОЕДИНЕНИЕ втГлобальныеЗоны
		|		ПО ИСТИНА
		|ГДЕ
		|	ВЫБОР
		|		КОГДА втГлобальныеЗоны.ГлобальнаяЗона = ЗНАЧЕНИЕ(Перечисление.ЗоныДоставкиКлиента.Зона2)
		|		ТОГДА ТарифыПеревозчиков.ЗонаДействияТарифа = втГлобальныеЗоны.ГлобальнаяЗона 
		|			ИЛИ ТарифыПеревозчиков.ЗонаДействияТарифа = ЗНАЧЕНИЕ(Перечисление.ЗоныДоставкиКлиента.ПустаяСсылка)
		|       ИНАЧЕ ИСТИНА    
		|	КОНЕЦ
		|	И ТарифыПеревозчиков.Подразделение В
		|		(&Подразделение, ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка))
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	втНастройкиТарифов.Тариф,
		|	втНастройкиТарифов.ТипДоставки,
		|	СтоимостьДоставкиПоЗонам.СтоимостьДляКлиента КАК СтоимостьДоставки 
		|ПОМЕСТИТЬ втТарифыСтоимость	
		|ИЗ
		|	втНастройкиТарифов
		|	СОЕДИНЕНИЕ РегистрСведений.СтоимостьДоставкиПоЗонам.СрезПоследних(
		|			&ДатаДоставки,
		|			ЗонаДоставки = &ЗонаДоставки
		|			И Филиал = &Подразделение) КАК СтоимостьДоставкиПоЗонам
		|		ПО втНастройкиТарифов.Тариф = СтоимостьДоставкиПоЗонам.Тариф    
		|;       
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Интервалы.Ссылка КАК Интервал,
		|	Интервалы.Наименование КАК ИнтервалНаименование,
		|	Интервалы.НаименованиеНаСайте КАК ИнтервалНаименованиеНаСайте,
		|	Интервалы.ДеньНедели,
		|	Интервалы.ВремяС,
		|	Интервалы.ВремяПо,
		|	Интервалы.МожноВыбрать,
		|	Интервалы.ДоступноНаСегодня,   
		|	Интервалы.МожноВыбратьРазгрузка,
		|	Интервалы.ДоступноНаСегодняСРазгрузкой
		|ПОМЕСТИТЬ втИнтервалы
		|ИЗ
		|	&Интервалы КАК Интервалы 
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ                         
		|	втТарифыСтоимость.Тариф,                     
		|	втТарифыСтоимость.ТипДоставки,   
		|	втТарифыСтоимость.СтоимостьДоставки,
		|	втИнтервалы.Интервал,
		|	втИнтервалы.ИнтервалНаименованиеНаСайте,
		|	втИнтервалы.ДеньНедели,
		|	втИнтервалы.ВремяС,
		|	втИнтервалы.ВремяПо,
		|	втИнтервалы.МожноВыбрать И втИнтервалы.ДоступноНаСегодня > 0 КАК Доступно,   
		|	втИнтервалы.МожноВыбратьРазгрузка И втИнтервалы.ДоступноНаСегодняСРазгрузкой > 0 КАК ДоступноРазгрузка
		|ПОМЕСТИТЬ втИнтервалыТарифов	
		|ИЗ
		|	втТарифыСтоимость 
		|	СОЕДИНЕНИЕ Справочник.ТарифыПеревозчиков.Интервалы КАК ИнтервалыПеревозчиков
		|		ПО втТарифыСтоимость.Тариф = ИнтервалыПеревозчиков.Ссылка                
		|	СОЕДИНЕНИЕ Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
		|		ПО ИнтервалыПеревозчиков.Интервал = ИнтервалыДоставки.Ссылка
		|		И ИнтервалыДоставки.Подразделение = &Подразделение
		|		И ИнтервалыДоставки.ВидДоставки = &ВидДоставки   
		|	СОЕДИНЕНИЕ втИнтервалы
		|		ПО ИнтервалыПеревозчиков.Интервал = втИнтервалы.Интервал
		|;	                                                                
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТипДоставки,
		|	МИНИМУМ(СтоимостьДоставки) КАК СтоимостьДоставки
		|ПОМЕСТИТЬ
		|	втМинимальнаяСтоимостьПоТипуДоставки
		|ИЗ     
		|	втИнтервалыТарифов  
		|СГРУППИРОВАТЬ ПО
		|	ТипДоставки		
		|;	
		|////////////////////////////////////////////////////////////////////////////////	
		|ВЫБРАТЬ
		|	втМинимальнаяСтоимостьПоТипуДоставки.ТипДоставки,
		|	втМинимальнаяСтоимостьПоТипуДоставки.СтоимостьДоставки,   
		|	МИНИМУМ(Тариф) КАК Тариф
		|ПОМЕСТИТЬ
		|	втМинимальныеТарифы
		|ИЗ     
		|	втМинимальнаяСтоимостьПоТипуДоставки 
		|	СОЕДИНЕНИЕ втИнтервалыТарифов
		|		ПО втМинимальнаяСтоимостьПоТипуДоставки.ТипДоставки = втИнтервалыТарифов.ТипДоставки
		|		И втМинимальнаяСтоимостьПоТипуДоставки.СтоимостьДоставки = втИнтервалыТарифов.СтоимостьДоставки
		|СГРУППИРОВАТЬ ПО
		|	втМинимальнаяСтоимостьПоТипуДоставки.ТипДоставки,
		|	втМинимальнаяСтоимостьПоТипуДоставки.СтоимостьДоставки
		|;	   
		|////////////////////////////////////////////////////////////////////////////////	
		|ВЫБРАТЬ * 
		|ИЗ
		|	втМинимальныеТарифы      
		|УПОРЯДОЧИТЬ ПО
		|	СтоимостьДоставки	
		|;
		|////////////////////////////////////////////////////////////////////////////////	       
		|ВЫБРАТЬ РАЗЛИЧНЫЕ                         
		|	втИнтервалыТарифов.Тариф,                     
		|	втИнтервалыТарифов.Интервал,
		|	втИнтервалыТарифов.ИнтервалНаименованиеНаСайте,
		|	втИнтервалыТарифов.ДеньНедели,
		|	втИнтервалыТарифов.ВремяС,
		|	втИнтервалыТарифов.ВремяПо,
		|	втИнтервалыТарифов.Доступно,   
		|	втИнтервалыТарифов.ДоступноРазгрузка
		|ИЗ 
		|	втИнтервалыТарифов
		|	СОЕДИНЕНИЕ втМинимальныеТарифы
		|		ПО втИнтервалыТарифов.Тариф = втМинимальныеТарифы.Тариф
		|УПОРЯДОЧИТЬ ПО
		|	втИнтервалыТарифов.Тариф,
		|	втИнтервалыТарифов.ВремяС,
		|	втИнтервалыТарифов.ВремяПо,
		|	втИнтервалыТарифов.ДеньНедели";
	
	Запрос.УстановитьПараметр("НастройкиТарифов",	УправлениеЛогистикойСервер.ПолучитьНастройкиАвтоопределения().НастройкиТарифов); 
	Запрос.УстановитьПараметр("ТипыТС", 			ТипыТС); 
