
Функция ПолучитьСотрудниковПолучитьСоттрудников(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	
	Ответ = Новый HTTPСервисОтвет(200);
	//Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.Заголовки.Вставить("Content-Type", "text/html");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Methods", "OPTIONS, GET"); 
	
	ДанныеJSON= ПолучитьJSON();
	стрJSON= АльтерраОбщегоНазначения.СформироватьСтрокуJSON(ДанныеJSON);
	Ответ.УстановитьТелоИзСтроки(стрJSON);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Ответ;
КонецФункции

 Функция ПолучитьJSON() 
	 ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаСотрудниковJSON", УровеньЖурналаРегистрации.Примечание, , , "Начало формирования прайса");

	 ПакетЗапросов= ПолучитьДанныеВыгрузки();
	 
	 //ВЫГРУЗКА
	 ДанныеJSON= Новый Соответствие;
	 
	 //Должности
	 Выборка= ПакетЗапросов[1].Выбрать();
	 мДолжности= Новый Массив;
	 Пока Выборка.Следующий() Цикл
		 Данные= Новый Структура;
		 Данные.Вставить("Код", XMLСтрока(Выборка.Код));
		 Данные.Вставить("Наименование", XMLСтрока(Выборка.Наименование));
		 
		 мДолжности.Добавить(Данные);
	 КонецЦикла;
	 
	 //Отделы
	 Выборка= ПакетЗапросов[2].Выбрать();
	 мОтделы= Новый Массив;
	 Пока Выборка.Следующий() Цикл
		 Данные= Новый Структура;
		 Данные.Вставить("Код", XMLСтрока(Выборка.Код));
		 Данные.Вставить("Наименование", XMLСтрока(Выборка.Наименование));
		 
		 мОтделы.Добавить(Данные);
	 КонецЦикла;
	 
	 //Подразделения
	 Выборка= ПакетЗапросов[3].Выбрать();
	 мПодразделений= Новый Массив;
	 Пока Выборка.Следующий() Цикл
		 Данные= Новый Структура;
		 Данные.Вставить("Код", XMLСтрока(Выборка.Код));
		 Данные.Вставить("Наименование", XMLСтрока(Выборка.Наименование));
		 
		 мПодразделений.Добавить(Данные);
	 КонецЦикла;
	 
	 //Сотрудники
	 Выборка= ПакетЗапросов[0].Выбрать();
	 мСотрудников= Новый Массив;
	 Пока Выборка.Следующий() Цикл
		 Данные= Новый Структура;
		 Данные.Вставить("Код", XMLСтрока(Выборка.Код));
		 Данные.Вставить("ФИО", XMLСтрока(Выборка.Наименование));
		 Данные.Вставить("Должность", XMLСтрока(Выборка.ДолжностьКод));
		 Данные.Вставить("Отдел", XMLСтрока(Выборка.ОтделКод));
		 Данные.Вставить("Подразделение", XMLСтрока(Выборка.ПодразделениеКод));
		 Данные.Вставить("Телефон", XMLСтрока(Выборка.Телефон));
		 Данные.Вставить("Пароль", XMLСтрока(Выборка.Пароль));
		 Данные.Вставить("Рководитель", XMLСтрока(Выборка.ОтделРуководительКод));
		 Данные.Вставить("Уволен", XMLСтрока(Выборка.Уволен));
		 Данные.Вставить("ДатаОкончанияДоступа", XMLСтрока(Формат(Выборка.ДатаУвольнения, "ДФ=dd.MM.yyyy")));
		 Если ЗначениеЗаполнено(Выборка.Партнер) Тогда
			 Данные.Вставить("Роль", XMLСтрока(0));
		 Иначе
			 Данные.Вставить("Роль", XMLСтрока(1));
		 КонецЕсли;
		 
		 мСотрудников.Добавить(Данные);
	 КонецЦикла;
	 
	 ДанныеJSON.Вставить("Должности", мДолжности);
	 ДанныеJSON.Вставить("Отделы", мОтделы);
	 ДанныеJSON.Вставить("Подразделения", мПодразделений);
	 ДанныеJSON.Вставить("Сотрудники", мСотрудников);
	 
	 //////// Записать в JSON /////////////////
	 Папка= "C:\Bitrix\Прайсы";
	 //КаталогНаСайте= "/include/JSON/";
	 КаталогНаСайте= "~";
	 ИмяФайла= "workers.json";
	 
	 ИмяВременногоФайла= Папка+"\"+ИмяФайла;
	 
	 JSON= Новый ЗаписьJSON;
	 ПараметрыЗаписи= Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Windows, Символы.Таб);
	 JSON.ОткрытьФайл(ИмяВременногоФайла, "UTF-8 ", , ПараметрыЗаписи);
	 ЗаписатьJSON(JSON, ДанныеJSON); 	
	 JSON.Закрыть();
	 
	 Возврат ДанныеJSON;
 КонецФункции

 Функция ПолучитьДанныеВыгрузки()
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	Сотрудники.Ссылка КАК Ссылка,
	 |	Сотрудники.Код КАК Код,
	 |	Сотрудники.Наименование КАК Наименование,
	 |	Сотрудники.Должность.Код КАК ДолжностьКод,
	 |	Сотрудники.Отдел.Код КАК ОтделКод,
	 |	Сотрудники.Подразделение.Код КАК ПодразделениеКод,
	 |	Сотрудники.Телефон КАК Телефон,
	 |	Сотрудники.Пароль КАК Пароль,
	 |	Сотрудники.Уволен КАК Уволен,
	 |	Сотрудники.ДатаУвольнения КАК ДатаУвольнения,
	 |	Сотрудники.Партнер КАК Партнер,
	 |	Сотрудники.Отдел.Руководитель.Код КАК ОтделРуководительКод
	 |ИЗ
	 |	Справочник.Сотрудники КАК Сотрудники
	 |ГДЕ
	 |	Сотрудники.ВыгружатьНаСайт = ИСТИНА
	 |	И НЕ Сотрудники.ПометкаУдаления
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Должности.Ссылка КАК Ссылка,
	 |	Должности.Код КАК Код,
	 |	Должности.Наименование КАК Наименование
	 |ИЗ
	 |	Справочник.Должности КАК Должности
	 |ГДЕ
	 |	НЕ Должности.ПометкаУдаления
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Отделы.Ссылка КАК Ссылка,
	 |	Отделы.Код КАК Код,
	 |	Отделы.Наименование КАК Наименование
	 |ИЗ
	 |	Справочник.Отделы КАК Отделы
	 |ГДЕ
	 |	НЕ Отделы.ПометкаУдаления
	 |	И Отделы.ЭтоГруппа = ЛОЖЬ
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	СтруктураПредприятия.Ссылка КАК Ссылка,
	 |	СтруктураПредприятия.Код КАК Код,
	 |	СтруктураПредприятия.Наименование КАК Наименование
	 |ИЗ
	 |	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
	 |ГДЕ
	 |	НЕ СтруктураПредприятия.ПометкаУдаления";
	 
	 Пакет = Запрос.ВыполнитьПакет();
	 Возврат Пакет;
 КонецФункции

Функция ПолучитьПользователей(Запрос)
	УстановитьПривилегированныйРежим(Истина);
	
	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.Заголовки.Вставить("Content-Type", "text/html");
	Ответ.Заголовки.Вставить("Access-Control-Allow-Methods", "OPTIONS, GET"); 
	
	ИмяПользователя = Запрос.ПараметрыURL["UserName"];
	ДанныеJSON = ПолучитьПользователейJSON(ИмяПользователя);
	стрJSON = АльтерраОбщегоНазначения.СформироватьСтрокуJSON(ДанныеJSON);
	Ответ.УстановитьТелоИзСтроки(стрJSON);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Ответ;
КонецФункции

Функция ПолучитьПользователейJSON(ИмяПользователя) 
	//ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаСотрудниковJSON", УровеньЖурналаРегистрации.Примечание, , , "Начало формирования прайса");

	ПакетЗапросов= ПолучитьДанныеПользователейВыгрузки(ИмяПользователя);
	 
	//ВЫГРУЗКА
	ДанныеJSON= Новый Соответствие;
	 
	//Пользователи ИБ
	Выборка = ПакетЗапросов[0].Выбрать();
	мПользователиИБ = Новый Массив;
	Пока Выборка.Следующий() Цикл
		ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПользователяИБ);
		Если ПользовательИБ <> Неопределено Тогда
			 
			ОписаниеПользователяИБ = Пользователи.НовоеОписаниеПользователяИБ();
			ПрочитанныеСвойства = Неопределено;
				
			ПрочитанныеСвойства = Пользователи.СвойстваПользователяИБ(ПользовательИБ.УникальныйИдентификатор);
			Если ПрочитанныеСвойства <> Неопределено Тогда		
					// Копирование свойств и ролей пользователяИБ.
					ЗаполнитьЗначенияСвойств(
						ОписаниеПользователяИБ,
						ПрочитанныеСвойства,
						"АутентификацияОС,
						|АутентификацияOpenID,
						|ЗапрещеноИзменятьПароль,
						|Имя,
						|ОсновнойИнтерфейс,
						|ПолноеИмя,
						|ПоказыватьВСпискеВыбора,
						|ПользовательОС,
						|РежимЗапуска,
						|Язык,
						|Роли");
			КонецЕсли;
		
			Отделы = УправлениеСвойствами.ЗначениеСвойства(Выборка.Пользователь, ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Отделы"));
			Если Отделы = Неопределено Тогда
				Отдел = "";
			Иначе	
				Отдел = Отделы.Наименование;
			КонецЕсли;
			ОписаниеПользователяИБ.Вставить("Отдел", Отдел);
			ОписаниеПользователяИБ.Вставить("Подразделение", Выборка.Подразделение);
			ОписаниеПользователяИБ.Удалить("УникальныйИдентификатор");
			ОписаниеПользователяИБ.Удалить("СтарыйПароль");
			ОписаниеПользователяИБ.Удалить("Пароль");
			ОписаниеПользователяИБ.Удалить("СохраняемоеЗначениеПароля");
			мПользователиИБ.Добавить(ОписаниеПользователяИБ);
		КонецЕсли;	
	КонецЦикла;
	 
	 //Группы доступа
	 Выборка= ПакетЗапросов[1].Выбрать();
	 мГруппыДоступа = Новый Массив;
	 Пока Выборка.Следующий() Цикл
		 Данные = Новый Структура;
	     Данные.Вставить("ГруппаДоступа", Выборка.ГруппаДоступа);
		 Данные.Вставить("ПрофильГруппыДоступа", Выборка.ПрофильГруппыДоступа);
	     мГруппыДоступа.Добавить(Данные);
	 КонецЦикла;
	 
	 //Группы пользователей
	 Выборка= ПакетЗапросов[2].Выбрать();
	 мГруппыПользователя = Новый Массив;
	 Пока Выборка.Следующий() Цикл
	     мГруппыПользователя.Добавить(Выборка.ГруппаПользователя);
	 КонецЦикла;
	 
	 //Профили групп доступа
	 мПрофилиГруппДоступа = Новый Массив;
	 ВыборкаПрофили = ПакетЗапросов[3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	 Пока ВыборкаПрофили.Следующий() Цикл
		 Данные = Новый Структура;
	     Данные.Вставить("ПрофильГруппыДоступа", ВыборкаПрофили.ПрофильГруппыДоступа);
		 ВыборкаРоли = ВыборкаПрофили.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		 МассивРолей = Новый Массив;
		 Пока ВыборкаРоли.Следующий() Цикл
			 МассивРолей.Добавить(ВыборкаРоли.Роль); 
		 КонецЦикла;
		 Данные.Вставить("Роли", МассивРолей);
		 мПрофилиГруппДоступа.Добавить(Данные);	 
	 КонецЦикла;	 
	 
	 ДанныеJSON.Вставить("ПрофилиГруппДоступа", мПрофилиГруппДоступа);
	 ДанныеJSON.Вставить("ГруппыПользователя", мГруппыПользователя);
	 ДанныеJSON.Вставить("ГруппыДоступа", мГруппыДоступа);
	 ДанныеJSON.Вставить("Пользователи", мПользователиИБ);
	 
	 ПараметрыJSON = ОбщийHTTPСервер.СериализоватьВJSON(ДанныеJSON);
	 
	 Возврат ПараметрыJSON;
 КонецФункции

Функция ПолучитьДанныеПользователейВыгрузки(ИмяПользователя)
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	Пользователи.ИдентификаторПользователяИБ КАК ИдентификаторПользователяИБ,
	 |	ПРЕДСТАВЛЕНИЕ(Пользователи.Подразделение) КАК Подразделение,
	 |	Пользователи.Ссылка КАК Пользователь
	 |ИЗ
	 |	Справочник.Пользователи КАК Пользователи
	 |ГДЕ
	 |	НЕ Пользователи.ПометкаУдаления
	 |	И Пользователи.Недействителен = ЛОЖЬ
	 |	И Пользователи.Ссылка = &Пользователь
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ПРЕДСТАВЛЕНИЕ(ГруппыДоступаПользователи.Ссылка) КАК ГруппаДоступа,
	 |	ПРЕДСТАВЛЕНИЕ(ПрофилиГруппДоступа.Ссылка) КАК ПрофильГруппыДоступа
	 |ИЗ
	 |	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа КАК ПрофилиГруппДоступа
	 |		ПО ГруппыДоступаПользователи.Ссылка.Профиль = ПрофилиГруппДоступа.Ссылка
	 |ГДЕ
	 |	ГруппыДоступаПользователи.Пользователь = &Пользователь
	 |	И НЕ ГруппыДоступаПользователи.Ссылка.ПометкаУдаления
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ПРЕДСТАВЛЕНИЕ(ГруппыПользователейПользователиГруппы.Ссылка) КАК ГруппаПользователя
	 |ИЗ
	 |	Справочник.ГруппыПользователей.Состав КАК ГруппыПользователейПользователиГруппы
	 |ГДЕ
	 |	ГруппыПользователейПользователиГруппы.Пользователь = &Пользователь
	 |	И НЕ ГруппыПользователейПользователиГруппы.Ссылка.ПометкаУдаления
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ПрофилиГруппДоступаРоли.Ссылка.Представление КАК ПрофильГруппыДоступа,
	 |	ПрофилиГруппДоступаРоли.Роль.Представление КАК Роль
	 |ИЗ
	 |	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПрофилиГруппДоступа.Роли КАК ПрофилиГруппДоступаРоли
	 |		ПО ГруппыДоступаПользователи.Ссылка.Профиль = ПрофилиГруппДоступаРоли.Ссылка
	 |ГДЕ
	 |	ГруппыДоступаПользователи.Пользователь = &Пользователь
	 |	И НЕ ПрофилиГруппДоступаРоли.Ссылка.ПометкаУдаления
	 |ИТОГИ
	 |	МИНИМУМ(Роль)
	 |ПО
	 |	ПрофильГруппыДоступа";
	 
	 ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоИмени(ИмяПользователя);
	 Запрос.УстановитьПараметр("Пользователь", Справочники.Пользователи.НайтиПоРеквизиту("ИдентификаторПользователяИБ", ПользовательИБ.УникальныйИдентификатор));
	 Пакет = Запрос.ВыполнитьПакет();
	 Возврат Пакет;
 КонецФункции
