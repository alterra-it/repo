		НовЗадача.Проверяющий 	= Справочники.Пользователи.НайтиПоНаименованию("Рябушкина Мария Николаевна", Истина);
	КонецЕсли;	
	НовЗадача.Предмет			= Заказ.Ссылка;
	НовЗадача.Содержание			= Заказ.Комментарий;
