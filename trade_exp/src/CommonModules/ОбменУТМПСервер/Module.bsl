Функция ПолучитьСкладскуюОперацию(Накладная) Экспорт 
	
	СкладскаяОперация = Перечисления.СкладскиеОперации.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = СкладыСервер.ТекстЗапросаСкладскаяОперацияТипДокумента()+ " 
	|ВЫБРАТЬ
	|	СкладскаяОперацияТипДокумента.СкладскаяОперация КАК СкладскаяОперация
	|ИЗ
	|	СкладскаяОперацияТипДокумента КАК СкладскаяОперацияТипДокумента
	|ГДЕ
	|	СкладскаяОперацияТипДокумента.Тип = &Тип";
	
	Запрос.УстановитьПараметр("Тип",ТипЗнч(Накладная));
	
	Результат = Запрос.Выполнить().Выбрать();  
	Результат.Следующий();
	
	СкладскаяОперация = Результат.СкладскаяОперация;
	
	Возврат  СкладскаяОперация;
	
КонецФункции 

Функция ОтправительДляЗаполнения(Накладная)    

	Возврат ?(ТипЗнч(Накладная) = Тип("ДокументСсылка.ПеремещениеТоваров"), Накладная.СкладОтправитель, Накладная.Партнер);
	
КонецФункции

Процедура УдалитьСвязанныеЗаписиОбменМП(Документ) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	СостоянияДокументовОбменМП = РегистрыСведений.СостоянияДокументовОбменМП;
	НаборЗапись = СостоянияДокументовОбменМП.СоздатьНаборЗаписей();
			 
	НаборЗапись.Отбор.ДокументОрдер.Установить(Документ);
	НаборЗапись.Записать();
	
	СостоянияТоваровОбменМП = РегистрыСведений.СостоянияТоваровОбменМП;
	НаборЗапись = СостоянияТоваровОбменМП.СоздатьНаборЗаписей();
			 
	НаборЗапись.Отбор.ДокументОрдер.Установить(Документ);
	НаборЗапись.Записать();

	УстановитьПривилегированныйРежим(Ложь);  

КонецПроцедуры

Процедура ЗафиксироватьСтатусВыполненияОперацииВРегистре(ВыборкаДетальныеЗаписи)
	
	МенеджерЗаписи = РегистрыСведений.СостоянияДокументовОбменМП.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ВыборкаДетальныеЗаписи);
	МенеджерЗаписи.Обработано = Истина;
	
	МенеджерЗаписи.Записать();  
	
КонецПроцедуры

Функция ОрдерЗаполнялсяВМП(Ордер, Накладная) Экспорт
	УстановитьПривилегированныйРежим(Истина);	
	Запрос = Новый Запрос;
	Запрос.Текст =  
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СостоянияДокументовОбменМП.ДокументНакладная КАК ДокументНакладная,
	|	СостоянияДокументовОбменМП.ДокументОрдер КАК ДокументОрдер
	|ИЗ
	|	РегистрСведений.СостоянияДокументовОбменМП КАК СостоянияДокументовОбменМП
	|ГДЕ
	|	СостоянияДокументовОбменМП.ДокументНакладная = &ДокументНакладная
	|	И СостоянияДокументовОбменМП.ДокументОрдер = &ДокументОрдер";
	
	Запрос.УстановитьПараметр("ДокументНакладная", Накладная);
	Запрос.УстановитьПараметр("ДокументОрдер", Ордер);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
КонецФункции 

Функция ПолучитьТоварыИзРегистра(Ордер, Обработанные = Ложь) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст =  
	"ВЫБРАТЬ
	|	СостоянияТоваровОбменМП.ДокументОрдер,
	|	СостоянияТоваровОбменМП.Номенклатура,
	|	СостоянияТоваровОбменМП.Назначение,
	|	СостоянияТоваровОбменМП.Характеристика,
	|	СостоянияТоваровОбменМП.Количество КАК Количество
	|ИЗ
	|	РегистрСведений.СостоянияТоваровОбменМП КАК СостоянияТоваровОбменМП
	|ГДЕ
	|	СостоянияТоваровОбменМП.ДокументОрдер = &ДокументОрдер
	|	И СостоянияТоваровОбменМП.Обработано = &Обработано";
	
	Запрос.УстановитьПараметр("ДокументОрдер", Ордер);
	Запрос.УстановитьПараметр("Обработано", Обработанные);
	
	ТЗ = Запрос.Выполнить().Выгрузить(); 
	Возврат ТЗ;
		
КонецФункции 

Функция ЗаполнитьОрдер(ОрдерОбъект, ИмяТЧ, Отработаные) Экспорт
    УстановитьПривилегированныйРежим(Истина);
	КоличествоЗаполнено = Ложь;
		
	Запрос = Новый Запрос;
	Запрос.Текст =  
	"ВЫБРАТЬ
	|	СостоянияТоваровОбменМП.ДокументОрдер,
	|	СостоянияТоваровОбменМП.Номенклатура,
	|	СостоянияТоваровОбменМП.Назначение,
	|	СостоянияТоваровОбменМП.Характеристика,
	|	СостоянияТоваровОбменМП.Количество КАК Количество
	|ИЗ
	|	РегистрСведений.СостоянияТоваровОбменМП КАК СостоянияТоваровОбменМП
	|ГДЕ
	|	СостоянияТоваровОбменМП.ДокументОрдер = &ДокументОрдер
	|	И СостоянияТоваровОбменМП.Обработано = &Обработано";
	
	Запрос.УстановитьПараметр("ДокументОрдер", ОрдерОбъект.Ссылка);
	Запрос.УстановитьПараметр("Обработано", Отработаные);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл

		Количество = 0;
		Количество = ВыборкаДетальныеЗаписи.Количество;

		МассивСтрок = ОрдерОбъект[ИмяТЧ].НайтиСтроки(Новый Структура("Номенклатура, Характеристика, Назначение",ВыборкаДетальныеЗаписи.Номенклатура,ВыборкаДетальныеЗаписи.Характеристика,ВыборкаДетальныеЗаписи.Назначение));
		
		Если МассивСтрок.Количество() > 0 Тогда
			Для Каждого Строка Из МассивСтрок Цикл
				Строка.КоличествоУпаковок = Количество;
				Строка.Количество = Количество;
			КонецЦикла;
		Иначе 
			НоваяСтрока = ОрдерОбъект[ИмяТЧ].Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
			Если ИмяТЧ = "ОтгружаемыеТовары" Тогда
				НоваяСтрока.Действие = Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку.Отобрать;
			КонецЕсли;
			НоваяСтрока.КоличествоУпаковок = Количество;
		КонецЕсли;
		
		МенеджерЗаписи = РегистрыСведений.СостоянияТоваровОбменМП.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(МенеджерЗаписи, ВыборкаДетальныеЗаписи);
		МенеджерЗаписи.Обработано = Истина;

		МенеджерЗаписи.Записать();
		
		КоличествоЗаполнено = Истина;
		
     КонецЦикла;

     Возврат КоличествоЗаполнено;
     УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции

