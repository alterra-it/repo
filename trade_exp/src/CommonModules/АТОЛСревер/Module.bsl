#Область ФорматноЛогическийКонтроль

Функция ПровестиФорматноЛогическийКонтрольСумм(ПараметрыАТОЛ) Экспорт

	//проверка на необходимость форматно-логического контроля для ККТ
	//получаем параметры
	ПараметрыФискализацииЧека = ПолучитьПараметрыФискализацииЧека(ПараметрыАТОЛ);
	ПараметрыФискализацииЧека.Вставить("СпособФорматноЛогическогоКонтроля", Перечисления.СпособыФорматноЛогическогоКонтроля.РазделятьСтроки);
	
	//проводим контроль
	ФорматноЛогическийКонтрольКлиентСервер.ПровестиФорматноЛогическийКонтроль(ПараметрыФискализацииЧека);

	Возврат ПараметрыФискализацииЧека;
	
КонецФункции

Функция ПолучитьПараметрыФискализацииЧека(ПараметрыАТОЛ)

	ПараметрыОперацииФискализацииЧека = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.ПараметрыОперацииФискализацииЧека();
	
	ПараметрыОперацииФискализацииЧека.Электронно = ПараметрыАТОЛ.НеПечататьЧек;
	ПараметрыОперацииФискализацииЧека.Отправляет1СSMS = ПараметрыАТОЛ.Отправляет1СSMS;
	ПараметрыОперацииФискализацииЧека.ПокупательНомер = ПараметрыАТОЛ.EmailИлиТелефон;
	ПараметрыОперацииФискализацииЧека.Отправляет1СEmail = ПараметрыАТОЛ.Отправляет1СEmail;
	ПараметрыОперацииФискализацииЧека.ПокупательEmail = ПараметрыАТОЛ.EmailИлиТелефон;	
	ПараметрыОперацииФискализацииЧека.ДокументОснование = ПараметрыАТОЛ.ДокументПродажи;
	
	Если ПараметрыАТОЛ.ТипОперации = "sell" Тогда
		
		Если ТипЗнч(ПараметрыАТОЛ.ДокументПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда

			ПараметрыОперацииФискализацииЧека.ТипРасчета = ПредопределенноеЗначение("Перечисление.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств");
			ЗаполнитьЗначенияСвойств(ПараметрыОперацииФискализацииЧека,ФормированиеПараметровФискальногоЧекаСервер.ПараметрыОперацииФискализацииЧекаПакетныйРежим(ПараметрыАТОЛ.ДокументОплаты),,"ТипРасчета,Электронно,Отправляет1СSMS,ПокупательНомер,Отправляет1СEmail,ПокупательEmail");
			
			Возврат ПараметрыОперацииФискализацииЧека;
						
		Иначе
			ПараметрыОперацииФискализацииЧека.ПозицииЧека = ДанныеДляПробитияЧека(ПараметрыАТОЛ.ДокументПродажи, ПараметрыАТОЛ.ДокументОплаты);	
			
			ПараметрыОперацииФискализацииЧека.ТипРасчета = ПредопределенноеЗначение("Перечисление.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств");
			ИнформацияОбОплате = ИнформацияОбОплате(ПараметрыАТОЛ.ДокументПродажи, ПараметрыАТОЛ.ДокументОплаты);
		КонецЕсли;
				
	Иначе  
		Если ТипЗнч(ПараметрыАТОЛ.ДокументОплаты) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") Тогда
			
			ПараметрыОперацииФискализацииЧека.ТипРасчета = ПредопределенноеЗначение("Перечисление.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств");
			ЗаполнитьЗначенияСвойств(ПараметрыОперацииФискализацииЧека,ФормированиеПараметровФискальногоЧекаСервер.ПараметрыОперацииФискализацииЧекаПакетныйРежим(ПараметрыАТОЛ.ДокументОплаты),,"ТипРасчета,Электронно,Отправляет1СSMS,ПокупательНомер,Отправляет1СEmail,ПокупательEmail");

			Возврат ПараметрыОперацииФискализацииЧека;
		Иначе
			ПараметрыОперацииФискализацииЧека.ПозицииЧека = ДанныеДляПробитияЧекаВозврата(ПараметрыАТОЛ.ДокументПродажи);	
			
			ПараметрыОперацииФискализацииЧека.ТипРасчета = ПредопределенноеЗначение("Перечисление.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств");
			ИнформацияОбОплате = ИнформацияОВозвратеОплаты(ПараметрыАТОЛ.ДокументПродажи, ПараметрыАТОЛ.ДокументОплаты);
		КонецЕсли;
		
	КонецЕсли;
	
	// Наличные
	СтрокаОплаты = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.ПараметрыСтрокиОплаты();
	СтрокаОплаты.Вставить("ТипОплаты", ПредопределенноеЗначение("Перечисление.ТипыОплатыККТ.Наличные"));
	СтрокаОплаты.Вставить("Сумма",     ИнформацияОбОплате.Наличные);
	ПараметрыОперацииФискализацииЧека.ТаблицаОплат.Добавить(СтрокаОплаты);
	
	// Безналичные
	СтрокаОплаты = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.ПараметрыСтрокиОплаты();
	СтрокаОплаты.Вставить("ТипОплаты", ПредопределенноеЗначение("Перечисление.ТипыОплатыККТ.Электронно"));
	СтрокаОплаты.Вставить("Сумма",     ИнформацияОбОплате.ПлатежныеКарты);
	ПараметрыОперацииФискализацииЧека.ТаблицаОплат.Добавить(СтрокаОплаты);
	
	// Сертификатом
	СтрокаОплаты = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.ПараметрыСтрокиОплаты();
	СтрокаОплаты.Вставить("ТипОплаты", ПредопределенноеЗначение("Перечисление.ТипыОплатыККТ.Предоплата"));
	СтрокаОплаты.Вставить("Сумма",     ИнформацияОбОплате.ПодарочныеСертификаты);
	ПараметрыОперацииФискализацииЧека.ТаблицаОплат.Добавить(СтрокаОплаты);
	
	Возврат ПараметрыОперацииФискализацииЧека;  
	
КонецФункции

Функция ДанныеДляПробитияЧека(ДокументПродажи, ДокументОплаты)
	
	МассивСтрок = Новый Массив;
	
	ЕстьРеквизитОтменено = Неопределено;
	ЕстьРеквизитСумма = Неопределено;
	Если ДокументПродажи.СуммаДокумента > ДокументОплаты.СуммаДокумента Тогда
		ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПередачаСЧастичнойОплатой");
	Иначе
		ПризнакСпособаРасчета = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПередачаСПолнойОплатой");
	КонецЕсли;
	
	// КСО маркировка
	Маркировка = Ложь;
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекСамообслуживания") И ДокументПродажи.Маркировка Тогда
		Маркировка = Истина;
	КонецЕсли;
	
	Для каждого СтрокаТЧ из ДокументПродажи.Товары Цикл   
		ЕстьРеквизитОтменено = ?(ЕстьРеквизитОтменено = Неопределено, ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "Отменено"), ЕстьРеквизитОтменено);
		Если  (ЕстьРеквизитОтменено И Не СтрокаТЧ.Отменено) Или Не ЕстьРеквизитОтменено Тогда

			СтрокаПозицииЧека = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.ПараметрыФискальнойСтрокиЧека();
			
			// Общие данные строки чека
			СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПризнакСпособаРасчета;
			СтрокаПозицииЧека.ПризнакПредметаРасчета = РозничныеПродажиКлиентСервер.ПризнакПредметаРасчетаФискальнойОперации(
			СтрокаТЧ.Номенклатура.ТипНоменклатуры, СтрокаТЧ.Номенклатура.ПодакцизныйТовар);
			
			СтрокаПозицииЧека.Наименование = СтрокаТЧ.Номенклатура.НаименованиеПолное;
			
			СтрокаПозицииЧека.Цена = СтрокаТЧ.Цена;
			СтрокаПозицииЧека.СтавкаНДС = СтрокаТЧ.СтавкаНДС;
			
			// Расчетные данные строки чека
			СтрокаПозицииЧека.Количество = СтрокаТЧ.КоличествоУпаковок;
			СтрокаПозицииЧека.Сумма = СтрокаТЧ.СуммаСНДС;          
			
			Если СтрокаПозицииЧека.Сумма = 0 Тогда       
				ЕстьРеквизитСумма = ?(ЕстьРеквизитСумма = Неопределено, ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "Сумма"), ЕстьРеквизитСумма);
				Если ЕстьРеквизитСумма Тогда
					СтрокаПозицииЧека.Сумма	= СтрокаТЧ.Сумма;
				КонецЕсли;
			КонецЕсли;
			
			Если СтрокаПозицииЧека.Количество <> 0 Тогда
				СтрокаПозицииЧека.ЦенаСоСкидками = Окр(СтрокаПозицииЧека.Сумма / СтрокаТЧ.КоличествоУпаковок, 2);
				СтрокаПозицииЧека.СуммаСкидок    = СтрокаТЧ.СуммаАвтоматическойСкидки + СтрокаТЧ.СуммаРучнойСкидки + СтрокаТЧ.СуммаБонусныхБалловКСписаниюВВалюте;//СтрокаТЧ.СуммаСкидки;
			КонецЕсли;	
			
			Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "Штрихкод") Тогда
				СтрокаПозицииЧека.Штрихкод                           = СтрокаТЧ.Штрихкод;
				Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "КодВидаНоменклатурнойКлассификации") Тогда
					СтрокаПозицииЧека.КодВидаНоменклатурнойКлассификации = СтрокаТЧ.КодВидаНоменклатурнойКлассификации;
				КонецЕсли;
			КонецЕсли;
			
			СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.ТипМаркировки                          = Неопределено;
			СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.КонтрольныйИдентификационныйЗнак       = Неопределено;
			СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.ГлобальныйИдентификаторТорговойЕдиницы = Неопределено;
			СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.СерийныйНомер                          = Неопределено;
			
			// КСО маркировка
			СтрокаПозицииЧека.Вставить("Маркировка", ?(Маркировка, СтрокаТЧ.Маркировка, Ложь));
			СтрокаПозицииЧека.Вставить("ПолныйКодМаркировки", ?(Маркировка, СтрокаТЧ.ПолныйКодМаркировки, ""));
			СтрокаПозицииЧека.Вставить("ПроверкаМаркировки", ?(Маркировка, СтрокаТЧ.ПроверкаМаркировки, ""));
			СтрокаПозицииЧека.Вставить("ПродажаМаркировки", ?(Маркировка, Истина, Ложь));
			
			Если ЗначениеЗаполнено(СтрокаТЧ.Упаковка) Тогда
				СтрокаПозицииЧека.ЕдиницаИзмерения = СтрокаТЧ.Упаковка.Наименование;
				СтрокаПозицииЧека.КодЕдиницыИзмерения = РозничныеПродажи.КодЕдиницыИзмеренияПараметраЧека(СтрокаТЧ.Упаковка);
			Иначе
				СтрокаПозицииЧека.ЕдиницаИзмерения = СтрокаТЧ.Номенклатура.ЕдиницаИзмерения.Наименование; 
				СтрокаПозицииЧека.КодЕдиницыИзмерения = РозничныеПродажи.КодЕдиницыИзмеренияПараметраЧека(СтрокаТЧ.Номенклатура.ЕдиницаИзмерения);
			КонецЕсли;
			
			МассивСтрок.Добавить(СтрокаПозицииЧека);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивСтрок;
	
КонецФункции

Функция ДанныеДляПробитияЧекаВозврата(ДокументПродажи)
	
	МассивСтрок = Новый Массив;
	
	// КСО маркировка
	Маркировка = Ложь;
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекСамообслуживания") И ДокументПродажи.Маркировка Тогда
		Маркировка = Истина;
	КонецЕсли;
	
	Для Каждого СтрокаТЧ из ДокументПродажи.Товары Цикл
		
		СтрокаПозицииЧека = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.ПараметрыФискальнойСтрокиЧека();
		СтрокаПозицииЧека.Вставить("РезультатРаспределенияВрем");
		
		// Общие данные строки чека
		СтрокаПозицииЧека.ПризнакСпособаРасчета  = ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.ПередачаСПолнойОплатой");
		СтрокаПозицииЧека.ПризнакПредметаРасчета = РозничныеПродажиКлиентСервер.ПризнакПредметаРасчетаФискальнойОперации(
		СтрокаТЧ.Номенклатура.ТипНоменклатуры, СтрокаТЧ.Номенклатура.ПодакцизныйТовар);
		
		СтрокаПозицииЧека.Наименование = СтрокаТЧ.Номенклатура.НаименованиеПолное;
			  
		Упаковка = СтрокаТЧ.Упаковка;
		
		Если НЕ ЗначениеЗаполнено(Упаковка) Тогда
			Упаковка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТЧ.Номенклатура, "ЕдиницаИзмерения");
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Упаковка) Тогда
			СтрокаПозицииЧека.ЕдиницаИзмерения = СокрЛП(Упаковка);
			СтрокаПозицииЧека.КодЕдиницыИзмерения = РозничныеПродажи.КодЕдиницыИзмеренияПараметраЧека(Упаковка);
		Иначе
			СтрокаПозицииЧека.ЕдиницаИзмерения = СтрокаТЧ.Номенклатура.ЕдиницаИзмерения.Наименование;
			СтрокаПозицииЧека.КодЕдиницыИзмерения = РозничныеПродажи.КодЕдиницыИзмеренияПараметраЧека(СтрокаТЧ.Номенклатура.ЕдиницаИзмерения);
		КонецЕсли;
					
		СтрокаПозицииЧека.НомерСекции            = 1;
		СтрокаПозицииЧека.Цена                   = СтрокаТЧ.Цена;
		СтрокаПозицииЧека.СтавкаНДС              = СтрокаТЧ.СтавкаНДС;
		СтрокаПозицииЧека.СуммаНДС               = СтрокаТЧ.СуммаНДС;
		
		// Расчетные данные строки чека
		СтрокаПозицииЧека.Количество = СтрокаТЧ.КоличествоУпаковок;
		СтрокаПозицииЧека.Сумма      = СтрокаТЧ.Сумма;
				
		Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "Штрихкод") Тогда
			СтрокаПозицииЧека.Штрихкод = СтрокаТЧ.Штрихкод;
			Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаТЧ, "КодВидаНоменклатурнойКлассификации") Тогда
				СтрокаПозицииЧека.КодВидаНоменклатурнойКлассификации = СтрокаТЧ.КодВидаНоменклатурнойКлассификации;
			КонецЕсли;
		КонецЕсли;
			
		СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.ТипМаркировки                          = Неопределено;
		СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.КонтрольныйИдентификационныйЗнак       = Неопределено;
		СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.ГлобальныйИдентификаторТорговойЕдиницы = Неопределено;
		СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.СерийныйНомер                          = Неопределено;
		
		// КСО маркировка
		СтрокаПозицииЧека.Вставить("Маркировка", ?(Маркировка, СтрокаТЧ.Маркировка, Ложь));
		СтрокаПозицииЧека.Вставить("ПолныйКодМаркировки", ?(Маркировка, СтрокаТЧ.ПолныйКодМаркировки, ""));
		СтрокаПозицииЧека.Вставить("ПроверкаМаркировки", ?(Маркировка, СтрокаТЧ.ПроверкаМаркировки, ""));
		СтрокаПозицииЧека.Вставить("ПродажаМаркировки", ?(Маркировка, Ложь, Ложь));
						
		МассивСтрок.Добавить(СтрокаПозицииЧека);
		
	КонецЦикла;
	
	Возврат МассивСтрок; 
	
КонецФункции

Функция ИнформацияОбОплате(ДокументПродажи, ДокументОплаты)

	СуммаОплаты = ДокументОплаты.СуммаДокумента;
	СуммаСкидки = ДокументПродажи.Товары.Итог("СуммаРучнойСкидки")
	+ ДокументПродажи.Товары.Итог("СуммаАвтоматическойСкидки");
	СуммаСкидкиБонусныеБаллы = ДокументПродажи.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
		
	Если ДокументПродажи.ЦенаВключаетНДС Тогда
		СуммаБезСкидки = ДокументПродажи.СуммаДокумента + СуммаСкидки + СуммаСкидкиБонусныеБаллы;
	Иначе
		СуммаБезСкидки = ДокументПродажи.СуммаДокумента - ДокументПродажи.Товары.Итог("СуммаНДС") + СуммаСкидки + СуммаСкидкиБонусныеБаллы;
	КонецЕсли;
	
	СуммаКОплате = СуммаБезСкидки - СуммаСкидки;
	
	ИнформацияОбОплате = Новый Структура;
	ИнформацияОбОплате.Вставить("Документ",              ДокументПродажи);
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") 
		Или (ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМ") И ДокументОплаты.ОплатаПлатежнымиКартами.Количество() > 0) 
		Или (ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекСамообслуживания") И ДокументОплаты.ОплатаПлатежнымиКартами.Количество() > 0) Тогда
		ИнформацияОбОплате.Вставить("Наличные",              0);
		ИнформацияОбОплате.Вставить("ПлатежныеКарты",        СуммаОплаты);
	Иначе
		ИнформацияОбОплате.Вставить("Наличные",              СуммаОплаты);
		ИнформацияОбОплате.Вставить("ПлатежныеКарты",        0);
	КонецЕсли;
	
	ИнформацияОбОплате.Вставить("ПодарочныеСертификаты", 0);
	
	ИнформацияОбОплате.Вставить("БонусныеБаллы",         СуммаСкидкиБонусныеБаллы);
	ИнформацияОбОплате.Вставить("СуммаДокумента",        ДокументПродажи.СуммаДокумента);
	ИнформацияОбОплате.Вставить("СуммаБезСкидки",        СуммаБезСкидки);
	ИнформацияОбОплате.Вставить("СуммаКОплате",          СуммаКОплате);
	ИнформацияОбОплате.Вставить("СуммаСкидки",           СуммаСкидки);
	ИнформацияОбОплате.Вставить("ИтогоОплачено",         ИнформацияОбОплате.Наличные + ИнформацияОбОплате.ПлатежныеКарты + ИнформацияОбОплате.ПодарочныеСертификаты + ИнформацияОбОплате.БонусныеБаллы);
		
	Возврат ИнформацияОбОплате;
	
КонецФункции

Функция ИнформацияОВозвратеОплаты(ДокументПродажи, ДокументОплаты)
	
	ОплатаПлатежнымиКартамиОтменено = 0;
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
		
		Для Каждого СтрокаТЧ Из ДокументПродажи.ОплатаПлатежнымиКартами Цикл
			Если СтрокаТЧ.ОплатаОтменена Тогда
				ОплатаПлатежнымиКартамиОтменено = ОплатаПлатежнымиКартамиОтменено + СтрокаТЧ.Сумма;
			КонецЕсли;
		КонецЦикла; 
		
		СуммаДокумента = ЦенообразованиеКлиентСервер.ПолучитьСуммуДокумента(ДокументПродажи.Товары, ДокументПродажи.ЦенаВключаетНДС);
		
		Если ДокументПродажи.ЦенаВключаетНДС Тогда
			СуммаБезСкидки = СуммаДокумента;
		Иначе
			СуммаБезСкидки = СуммаДокумента - ДокументПродажи.Товары.Итог("СуммаНДС");
		КонецЕсли;
		
	КонецЕсли;
	
	ИнформацияОбОплате = Новый Структура;
	ИнформацияОбОплате.Вставить("Документ",               ДокументОплаты.Ссылка);
	
	ИнформацияОбОплате.Вставить("Наличные",               ДокументОплаты.ВыданоНаличными);
	ИнформацияОбОплате.Вставить("ПлатежныеКарты",         ДокументОплаты.ОплатаПлатежнымиКартами.Итог("Сумма"));
	ИнформацияОбОплате.Вставить("ПлатежныеКартыОтменено", ОплатаПлатежнымиКартамиОтменено);
	ИнформацияОбОплате.Вставить("ПодарочныеСертификаты",  0);
	ИнформацияОбОплате.Вставить("БонусныеБаллы",          0);
	
	ИнформацияОбОплате.Вставить("СуммаДокумента",        СуммаДокумента);
	ИнформацияОбОплате.Вставить("СуммаКОплате",          СуммаБезСкидки);
	ИнформацияОбОплате.Вставить("СуммаСкидки",           0);
	ИнформацияОбОплате.Вставить("ИтогоОплачено",         ИнформацияОбОплате.Наличные + ОплатаПлатежнымиКартамиОтменено);
		
	Возврат ИнформацияОбОплате;  
	
КонецФункции

Процедура ЗаполнитьСтрокуПоДаннымРазбораШтрихкода(СтрокаПозицииЧека, СтрокаДляДобавленияВЧек)
	
	ВидПродукции = Неопределено;
	Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(СтрокаДляДобавленияВЧек, "ОсобенностьУчета")
		И ЗначениеЗаполнено(СтрокаДляДобавленияВЧек.ОсобенностьУчета)
		И ЗначениеЗаполнено(СтрокаДляДобавленияВЧек.Штрихкод) Тогда
		ВидПродукции = ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(СтрокаДляДобавленияВЧек.ОсобенностьУчета);
	КонецЕсли;
	
	Если Не (ЗначениеЗаполнено(ВидПродукции) И ИнтеграцияИСПовтИсп.ЭтоПродукцияИСМП(ВидПродукции, Истина)) Тогда
		Возврат;
	КонецЕсли;
	
	ТипМаркировкиККТ = ИнтеграцияИСКлиентСервер.ТипМаркировкиККТПоВидуПродукции(ВидПродукции);
	Если Не ЗначениеЗаполнено(ТипМаркировкиККТ) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеРазбора = РазборКодаМаркировкиИССлужебный.РазобратьКодМаркировки(СтрокаДляДобавленияВЧек.Штрихкод, ВидПродукции);
	Если ДанныеРазбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаПозицииЧека.Штрихкод                                                              = СтрокаДляДобавленияВЧек.Штрихкод;
	СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.ТипМаркировки                          = ТипМаркировкиККТ;
	СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.ГлобальныйИдентификаторТорговойЕдиницы = ДанныеРазбора.СоставКодаМаркировки.GTIN;
	СтрокаПозицииЧека.ДанныеКодаТоварнойНоменклатуры.СерийныйНомер                          = ДанныеРазбора.СоставКодаМаркировки.СерийныйНомер;
	
КонецПроцедуры

#КонецОбласти

#Область ЛогированиеСобытийОплаты

Процедура ЗаписатьЛогВФайл(Знач ЛогируемаяКасса, Знач ОбъектЛогирования, Знач ОтветHTTP=Неопределено, Знач ТекстОписание=Неопределено) Экспорт
	
	ПолныйПутьКФайлу = ЛогируемаяКасса.АдресХраненияЛогов;
	Если ПолныйПутьКФайлу <> "" Тогда
		ВремяЗаписи = ТекущаяДата();
		Попытка
			ФайлПолученный = Новый ЧтениеТекста(ПолныйПутьКФайлу);
			ТекстЗаписиВФайле = ФайлПолученный.Прочитать();
			ФайлПолученный.Закрыть();
		Исключение
		КонецПопытки;
		
		ДатаНачалаЗаписейСтрокой = СтрЗаменить(СтрЗаменить(СтрЗаменить(СтрЗаменить(Лев(ТекстЗаписиВФайле, 20), "[",""),"/",""), ":", ""), " ", "");
		Если ДатаНачалаЗаписейСтрокой <> "" Тогда
			ДатаНачалаЗаписей = Дата(ДатаНачалаЗаписейСтрокой);
			СтираемСтарыеЛоги = НачалоДня(ВремяЗаписи)- НачалоДня(ДатаНачалаЗаписей) >= ЛогируемаяКасса.ВремяХраненияВДнях*24*3600;
		Иначе
			СтираемСтарыеЛоги = Ложь;
		КонецЕсли;
		
		СтрокаОтвета = "";
		Если ТипЗнч(ОтветHTTP)=Тип("HTTPСервисОтвет") Тогда
			СтрокаОтвета = ОтветHTTP.ПолучитьТелоКакСтроку();
		Иначе
			Если ТипЗнч(ОтветHTTP)=Тип("Структура") Тогда
				РасшифровкаОтвета = "";
				Для каждого Стр из ОтветHTTP Цикл
					РасшифровкаОтвета = РасшифровкаОтвета + Стр.Ключ + ":" + Строка(Стр.Значение) + "; ";
				КонецЦикла;
			Иначе
				РасшифровкаОтвета = Строка(ОтветHTTP);
			КонецЕсли;
			СтрокаОтвета = "Полученный результат: " + РасшифровкаОтвета;
		КонецЕсли;
		
		СтрокаЗаписи = "[" + Формат(ВремяЗаписи, "ДФ='yyyy/MM/dd HH:mm:ss'") + "]" + Символы.ПС 
		+ "[" + Строка(ОбъектЛогирования) + "]" 
		+ "[" + СтрокаОтвета + "]" + Символы.ПС 
		+ "[Прим.: " + ТекстОписание + "]" + Символы.ПС;                                                      
		
		Попытка
			Если СтираемСтарыеЛоги И ЛогируемаяКасса.СохранятьПредыдущиеЛоги Тогда
				ПереместитьФайл(ПолныйПутьКФайлу, Лев(ПолныйПутьКФайлу, СтрДлина(ПолныйПутьКФайлу) - 4) + Лев(ДатаНачалаЗаписейСтрокой, 8) + Прав(ПолныйПутьКФайлу, 4));	
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		Попытка                                    
			ФайлЛогов = Новый ЗаписьТекста(ПолныйПутьКФайлу, КодировкаТекста.UTF8,,Не СтираемСтарыеЛоги);
			ФайлЛогов.ЗаписатьСтроку(СтрокаЗаписи);
			ФайлЛогов.Закрыть();
		Исключение
			ЗаписьЖурналаРегистрации("ЗаписьВЛог", УровеньЖурналаРегистрации.Ошибка, ОбъектЛогирования,"Ошибка записи в лог", ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

