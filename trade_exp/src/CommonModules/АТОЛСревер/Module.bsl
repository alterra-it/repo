Функция ИнформацияОККТ(ПараметрыАТОЛ) Экспорт
	
	Данные = Новый Структура("deviceID", ПараметрыАТОЛ.ПараметрыПодключения.ИДУстройства);
	ДанныеJSON = ОбщийHTTPСервер.СериализоватьВJSON(Данные);
	
	Ответ = ПослатьЗапросАТОЛ("/api/v2/operations/queryDeviceInfo", ПараметрыАТОЛ, "POST", ДанныеJSON);
	
	Если Ответ.Ошибка Тогда
		Отказ = Истина;
		Текст = "Не удалось получить информацию о ККТ";
		Возврат Ответ;
	КонецЕсли;	
	
	ИнформацияККТ= Ответ.Данные.deviceinfo;		
	Возврат ИнформацияККТ;
	
КонецФункции

Функция ИнформацияОКассовойСмене(ПараметрыАТОЛ) Экспорт
	
	Данные = Новый Структура("deviceID", ПараметрыАТОЛ.ПараметрыПодключения.ИДУстройства);
	ДанныеJSON = ОбщийHTTPСервер.СериализоватьВJSON(Данные);
	Ответ = ПослатьЗапросАТОЛ("/api/v2/operations/queryShiftStatus", ПараметрыАТОЛ, "POST", ДанныеJSON);
	
	Если Ответ.Ошибка Тогда
		Текст = "Не удалось получить информацию о кассовой смене";
		Возврат Ответ;
	КонецЕсли;	
	
	ИнформацияОКассовойСмене = Ответ.Данные.shiftStatus;
	
	Возврат ИнформацияОКассовойСмене;
	
КонецФункции

Функция РезультатПробитияЧека(ПараметрыАТОЛ, УИД) Экспорт
	
	Для Сч = 1 По 1000 Цикл
		//Таймаут 1 с
		Б_ОбменССайтомСервер.Таймаут(1);
		
		ОтветЗадания = АТОЛСревер.ПроверитьЗадание(ПараметрыАТОЛ, УИД);
		
		Если ОтветЗадания.Ошибка Тогда
			Текст = "Не удалось получить результат пробития чека";
			ЗаписьЖурналаРегистрации("АвтоПробитиеБезналичнойОплаты", УровеньЖурналаРегистрации.Ошибка, , , Текст);
			Возврат ОтветЗадания;
		КонецЕсли;	
		
		Результаты= ОтветЗадания.Данные.results;
		
		Если ТипЗнч(Результаты) = Тип("Массив") И Результаты.Количество() > 0 Тогда
			
			Для Каждого Результат Из Результаты Цикл
				
				Если Результат.Свойство("error") И Результат.error.code <> 0 Тогда
				КонецЕсли;
				
				Если Результат.Свойство("status") Тогда
					
					Если Результат.status = "canceled" Тогда
						Ответ= ПодготовитьОтвет(Истина, "Оплата прервана", ОтветЗадания.Данные)
						
					ИначеЕсли Результат.status = "blocked" Тогда
						Ответ= ПодготовитьОтвет(Истина, "Результат задачи неизвестен, очередь выполнения остановлена", ОтветЗадания.Данные)
						
					ИначеЕсли Результат.status = "interrupted" Тогда
						Ответ= ПодготовитьОтвет(Истина, "Задача не выполнялась, т.к. предыдущие задачи в задании выполнены с ошибкой", ОтветЗадания.Данные)
						
					ИначеЕсли Результат.status = "inProgress" Тогда
						Продолжить;
						
					ИначеЕсли Результат.status = "wait" Тогда
						Продолжить;
						
					ИначеЕсли Результат.status = "error" Тогда
						Ответ= ПодготовитьОтвет(Истина, "Задача выполнена с ошибкой", ОтветЗадания.Данные) 	
											
					ИначеЕсли Результат.status = "ready" Тогда
						
						Попытка
							// Получение ФД	
							Если Результат.result.Свойство("fiscalParams") Тогда
								
								ВыходнаяИнформацияОФД = Результат.result.fiscalParams;
								
								Если ВыходнаяИнформацияОФД.Свойство("fiscalDocumentSign") Тогда
									НомерФПД = ВыходнаяИнформацияОФД.fiscalDocumentSign;
								Иначе
									НомерФПД = 0;
								КонецЕсли;
								
								РНМ = ВыходнаяИнформацияОФД.registrationNumber;
								НомерСмены = ВыходнаяИнформацияОФД.shiftNumber;
								
								// Будут когда подключен ФН
								Если ВыходнаяИнформацияОФД.Свойство("fnNumber") Тогда
									НомерФН= ВыходнаяИнформацияОФД.fnNumber; //Номер накопителя
								Иначе
									НомерФН= "";
								КонецЕсли;
								Если ВыходнаяИнформацияОФД.Свойство("fnsUrl") Тогда
									АдресСайтаФНС= ВыходнаяИнформацияОФД.fnsUrl; // Адрес ОФД
								Иначе
									АдресСайтаФНС= "";
								КонецЕсли;
								Если ВыходнаяИнформацияОФД.Свойство("total") Тогда
									СуммаИтого= ВыходнаяИнформацияОФД.total; // Общая сумма
								Иначе
									СуммаИтого= 0;
								КонецЕсли;
								Если ВыходнаяИнформацияОФД.Свойство("fiscalDocumentNumber") Тогда
									// Номер чека ФД, раньше был просто номер чека
									НомерЧекаФД = ВыходнаяИнформацияОФД.fiscalDocumentNumber;
								Иначе
									НомерЧекаФД= 0;
								КонецЕсли;
								Если ВыходнаяИнформацияОФД.Свойство("fiscalReceiptNumber") Тогда
									НомерЧека= ВыходнаяИнформацияОФД.fiscalReceiptNumber; // Номер чека в смене
								Иначе
									НомерЧека= 0;
								КонецЕсли;
								Если ВыходнаяИнформацияОФД.Свойство("shiftNumber") Тогда
									НомерСмены= ВыходнаяИнформацияОФД.shiftNumber; // Номер накопителя  
								Иначе
									НомерСмены= 0;
								КонецЕсли;
								Если ВыходнаяИнформацияОФД.Свойство("fiscalDocumentDateTime") Тогда
									ДатаВремяПробития= ВыходнаяИнформацияОФД.fiscalDocumentDateTime; // Дата время
								Иначе
									ДатаВремяПробития = ТекущаяДата();
								КонецЕсли;
								
								ДанныеФн = Новый Структура;
								ДанныеФн.Вставить("НомерФПД",НомерФПД);
								ДанныеФн.Вставить("НомерСмены",НомерСмены);
								ДанныеФн.Вставить("ПриходРасход",1);
								ДанныеФн.Вставить("ДатаВремяПробития", ДатаВремяПробития);
								
								//Будут когда подключен ФН
								ДанныеФн.Вставить("АдресСайтаФНС", АдресСайтаФНС);
								ДанныеФн.Вставить("НомерФН", НомерФН);
								ДанныеФн.Вставить("НомерЧекаФД", НомерЧекаФД);
								ДанныеФн.Вставить("НомерСмены", НомерСмены);
								ДанныеФн.Вставить("СуммаИтого", СуммаИтого);
								ДанныеФн.Вставить("ЗаводскойНомерФН", РНМ);
								Ответ = ПодготовитьОтвет(Ложь, "Данные ФН", ДанныеФн);
								Возврат Ответ;
							Иначе
								Текст= "Не удалось получить структуру fiscalParams";
								ЗаписьЖурналаРегистрации("АвтоПробитиеБезналичнойОплаты", УровеньЖурналаРегистрации.Ошибка, , Текст, Текст);
								Ответ = ПодготовитьОтвет(Истина, Текст, Ответ.Данные);
								Возврат Ответ;
							КонецЕсли;
						Исключение
							Текст = "Не удалось получить фискальные данные";
							ЗаписьЖурналаРегистрации("АвтоПробитиеБезналичнойОплаты", УровеньЖурналаРегистрации.Ошибка, , Текст, ОписаниеОшибки());
							Ответ= ПодготовитьОтвет(Истина, Текст, ОтветЗадания.Данные);
							Возврат Ответ;
						КонецПопытки;
					Иначе
						Возврат Ответ;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Если Ответ = Неопределено Тогда
		Возврат ОтветЗадания;
	Иначе
		Возврат Ответ;
	КонецЕсли;
	
КонецФункции

Функция ПодготовитьДанныеФискализацииЧека(ПараметрыАТОЛ, ДанныеФН) Экспорт
	
	ИнформацияККТ = ПараметрыАТОЛ.ИнформацияККТ;
	ДокументОплаты = ПараметрыАТОЛ.ДокументОплаты;
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") Тогда
		ВидОплаты = "Картой";
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМ") Или ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекСамообслуживания") Тогда
		
		Если ДокументОплаты.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта Тогда
			ВидОплаты = "Картой";
		Иначе
			ВидОплаты = "Наличные"; 
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда 
		
		Если ДокументОплаты.ЧекККМ.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта Тогда
			ВидОплаты = "Картой";
		Иначе
			ВидОплаты = "Наличные";
		КонецЕсли;
		
	Иначе
		ВидОплаты = "Наличные"; 
	КонецЕсли;
	
	ПараметрыФискализации = ОборудованиеЧекопечатающиеУстройства.ПараметрыФискализацииЧека();
	ПараметрыФискализации.РегистрационныйНомерККТ = ДанныеФН.ЗаводскойНомерФН;
	ПараметрыФискализации.ДатаВремяЧека= ДанныеФН.ДатаВремяПробития;
	ПараметрыФискализации.НомерЧекаККТ  = ДанныеФН.НомерЧекаФД;
	ПараметрыФискализации.НомерСменыККТ  = ДанныеФН.НомерСмены;
	ПараметрыФискализации.ФискальныйПризнак  = ДанныеФН.НомерФПД;
	
	Если ПараметрыАТОЛ.ТипОперации = "sell" Тогда
		ПараметрыФискализации.ТипРасчета  = Перечисления.ТипыРасчетаДенежнымиСредствами.ПриходДенежныхСредств; 
	Иначе
		ПараметрыФискализации.ТипРасчета  = Перечисления.ТипыРасчетаДенежнымиСредствами.ВозвратДенежныхСредств; 
	КонецЕсли; 
	
	ПараметрыФискализации.СуммаЧека  = ПараметрыАТОЛ.ДокументОплаты.СуммаДокумента;
	Если ВидОплаты = "Наличные" Тогда
		ПараметрыФискализации.ОплатаНаличные  = ПараметрыФискализации.СуммаЧека;
		ПараметрыФискализации.Электронно   = Ложь;
	ИначеЕсли ВидОплаты = "Картой" Тогда
		ПараметрыФискализации.ОплатаЭлектронно  = ПараметрыФискализации.СуммаЧека;
		ПараметрыФискализации.Электронно   = Истина;
	КонецЕсли;
	
	ПараметрыФискализации.ОплатаПостоплата  = 0;
	ПараметрыФискализации.ОплатаПредоплата  = 0;
	ПараметрыФискализации.ЗаводскойНомерФН  = ИнформацияККТ.serial;
	ПараметрыФискализации.ШиринаСтроки      = ИнформацияККТ.receiptLineLengthPix;
	ПараметрыФискализации.АвтономныйРежим   = Ложь;
	ПараметрыФискализации.ДокументОснование = ПараметрыАТОЛ.ДокументОплаты;
	ПараметрыФискализации.Организация       = ПараметрыАТОЛ.ДокументОплаты.Организация;
	ПараметрыФискализации.Кассир       		= ПараметрыАТОЛ.Кассир;
	ПараметрыФискализации.Отправляет1СSMS   = ПараметрыАТОЛ.Отправляет1СSMS;
	ПараметрыФискализации.Отправляет1СEmail = ПараметрыАТОЛ.Отправляет1СEmail;
	ПараметрыФискализации.ВерсияФФДККТ11    = ПараметрыАТОЛ.ВерсияФФДККТ11;
	ПараметрыФискализации.ТипДокумента = Перечисления.ТипыФискальныхДокументовККТ.КассовыйЧек;
	
	Возврат ПараметрыФискализации;	
	
КонецФункции

