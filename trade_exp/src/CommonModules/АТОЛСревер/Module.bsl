Функция ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные) Экспорт 
	
	ДанныеJSON = ОбщийHTTPСервер.СериализоватьВJSON(Данные);
	
	Ответ = ПослатьЗапросАТОЛ("/api/v2/requests", ПараметрыАТОЛ, "POST", ДанныеJSON);
	Возврат Ответ;
	
КонецФункции

Функция ПодготовитьЗапросВОчередь(УИД, Задание) Экспорт
	
	Данные = Новый Структура;
	Данные.Вставить("uuid", УИД);
	
	МассивЗаданий = Новый Массив;
	МассивЗаданий.Добавить(Задание);
	
	Данные.Вставить("request", МассивЗаданий);
	Возврат Данные;
	
КонецФункции

