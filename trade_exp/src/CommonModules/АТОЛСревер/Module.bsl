Функция ЗаданиеПробитьЧек_СКонтролем(ПараметрыАТОЛ)
	
	ДокументПродажи= ПараметрыАТОЛ.ДокументПродажи;
	ДокументОплаты= ПараметрыАТОЛ.ДокументОплаты;
	EmailИлиТелефон = ПараметрыАТОЛ.EmailИлиТелефон; 
	
	Если ПараметрыАТОЛ.Свойство("ОтправлятьЧекИзОФД") И ПараметрыАТОЛ.ОтправлятьЧекИзОФД Тогда
		ОтправлятьЧекИзОФД = ПараметрыАТОЛ.ОтправлятьЧекИзОФД;
	Иначе
		ОтправлятьЧекИзОФД = Ложь;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") Тогда
		Оплата = "Картой";
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМ") Или ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекСамообслуживания") Тогда
		Если ДокументОплаты.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта Тогда
			Оплата = "Картой";
		Иначе
			Оплата = "Наличные"; 
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда 
		Если ДокументОплаты.ЧекККМ.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта Тогда
			Оплата = "Картой";
		Иначе
			Оплата = "Наличные";
		КонецЕсли;
	Иначе
		Оплата = "Наличные"; 
	КонецЕсли;
	
	Задание= Новый Структура;
	
	Задание.Вставить("type", ПараметрыАТОЛ.ТипОперации);  
	
	Если ПараметрыАТОЛ.Свойство("ПечататьБумажныйЧек") Тогда	
		Задание.Вставить("electronically", Не ПараметрыАТОЛ.ПечататьБумажныйЧек); 	
	Иначе
		Задание.Вставить("electronically", ПараметрыАТОЛ.НеПечататьЧек); 
	КонецЕсли;
	
	Если ПараметрыАТОЛ.Свойство("ИнтернетЭквайринг") Тогда
		Задание.Вставить("internet", ПараметрыАТОЛ.ИнтернетЭквайринг);	
	КонецЕсли; 
	
	Если ПараметрыАТОЛ.Свойство("МестоРасчетов") Тогда
		Задание.Вставить("paymentsPlace", ПараметрыАТОЛ.МестоРасчетов);	
	КонецЕсли; 
	
	Если ПараметрыАТОЛ.Свойство("АдресРасчетов") Тогда
		Задание.Вставить("paymentsAddress", ПараметрыАТОЛ.АдресРасчетов);	
	КонецЕсли;
	
	// При переплате сумма чека равна сумме оплаты
	Если ДокументОплаты.СуммаДокумента > ДокументПродажи.СуммаДокумента Тогда
		Задание.Вставить("total", ДокументОплаты.СуммаДокумента);
	Иначе
		Задание.Вставить("total", ДокументПродажи.СуммаДокумента);
	КонецЕсли;
	
	// Шапка
	Задание.Вставить("ignoreNonFiscalPrintErrors", Ложь); // Игнорировать ошибки при печати нефискальных элементов из items
	ЗаполнитьПоНалогам(Задание, ДокументПродажи.Организация, ДокументПродажи.Дата);           

	Кассир = "Администратор";
	Если ПараметрыАТОЛ.Свойство("КассирВЧеке") Тогда
		Кассир = ПараметрыАТОЛ.КассирВЧеке;
	КонецЕсли;
	Задание.Вставить("operator", Новый Структура("name,vatin", Кассир));
	
	МассивОплат= Новый Массив;
	ДанныеОплаты= Новый Структура;
	Если Оплата = "Наличные" Тогда
		ДанныеОплаты.Вставить("type", "cash");
	ИначеЕсли Оплата = "Картой" Тогда
		ДанныеОплаты.Вставить("type", "electronically");   
	КонецЕсли;
	СуммаОплатыКартой = ДокументОплаты.СуммаДокумента;
	ДанныеОплаты.Вставить("sum", СуммаОплатыКартой);
	МассивОплат.Добавить(ДанныеОплаты);
	
	// Недоплата
	Если ДокументОплаты.СуммаДокумента < ДокументПродажи.СуммаДокумента Тогда
		ДанныеОплаты= Новый Структура;
		ДанныеОплаты.Вставить("type", "3");
		ДанныеОплаты.Вставить("sum", ДокументПродажи.СуммаДокумента-ДокументОплаты.СуммаДокумента);
		МассивОплат.Добавить(ДанныеОплаты);
	КонецЕсли;
	
	Задание.Вставить("payments", МассивОплат);
	
	// КСО маркировка
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекСамообслуживания") И ДокументПродажи.Маркировка Тогда
		Задание.Вставить("validateMarkingCodes", Истина);			
	КонецЕсли; 
	
	//Информация об организации
	ЗаполнитьИнформациюОбОрганизации(Задание, ДокументПродажи.Организация);
	
	//Информация о клиенте
	ЗаполнитьИнформациюОПокупателе(Задание, ДокументПродажи, EmailИлиТелефон, ОтправлятьЧекИзОФД);
	
	//Информация о товарах
	ЗаполнитьИнформациюItemsПоКонтролю(Задание, ПараметрыАТОЛ.ПараметрыСФорматнымКонтролем);	
	
	Возврат Задание;
	
КонецФункции

Процедура ЗаполнитьИнформациюItemsПоКонтролю(Задание, ПараметрыПродажи) Экспорт
	
	ПозицииЧека = ПараметрыПродажи.ПозицииЧека;	
	МассивПозиций= Новый Массив;
	СуммаДокументаПродажи = ПараметрыПродажи.ДокументОснование.СуммаДокумента;

	Если СуммаДокументаПродажи > 0 Тогда
		
		// Обработать уже пересчитанные значения	
		Для Каждого стрТовар из ПозицииЧека Цикл		
			Позиция= Новый Структура;
			Позиция.Вставить("type", "position");
			Позиция.Вставить("name", стрТовар.Наименование);		
			
			Позиция.Вставить("price", стрТовар.ЦенаСоСкидками);
			Позиция.Вставить("quantity",  стрТовар.Количество);
			Позиция.Вставить("amount", стрТовар.Сумма);          
			
			Позиция.Вставить("infoDiscountAmount", стрТовар.СуммаСкидок); 
			
			МераКоличестваПредметаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.МераКоличестваПредметаРасчетаПоКодуЕдиницыИзмерения(стрТовар.КодЕдиницыИзмерения);
			МераКоличестваПредметаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.КодМерыКоличестваПредметаРасчетаККТ(МераКоличестваПредметаРасчета);
			
			ИспользоватьДопПроверку = ДопМодуль.ПолучитьНастройкиХранилища("ВключенияИзмененияВыводаТега2108ВЧеках").ВключитьВыводТега;
			
			Если ИспользоватьДопПроверку тогда 
				Позиция.Вставить("measurementUnit", XMLСтрока(МераКоличестваПредметаРасчета));
			Иначе
				Позиция.Вставить("measurementUnit", "0");
			КонецЕсли;  
			
			Налог= ПолучитьСтавкуНалога(стрТовар);
			Позиция.Вставить("tax", Налог);
			
			КодПризнакаСпособаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.КодПризнакаСпособаРасчета(стрТовар.ПризнакСпособаРасчета);
			Позиция.Вставить("paymentMethod", Строка(КодПризнакаСпособаРасчета));		
			
			
			// КСО маркировка
			Если стрТовар.Свойство("Маркировка") И стрТовар.Маркировка Тогда
				
				Позиция.Вставить("paymentObject", "commodityWithMarking");
				
				ПараметрыМаркировки = Новый Структура;
				ПараметрыМаркировки.Вставить("imcType", "auto");
				ПараметрыМаркировки.Вставить("imc", стрТовар.ПолныйКодМаркировки);
				ПараметрыМаркировки.Вставить("itemEstimatedStatus", ?(стрТовар.ПродажаМаркировки, "itemPieceSold", "itemPieceReturn"));
				ПараметрыМаркировки.Вставить("imcModeProcessing", 0);
				Позиция.Вставить("imcParams", ПараметрыМаркировки);
				
				РазрешительныйРежим = Новый Структура;
				РазрешительныйРежим.Вставить("fois", "030");
				РазрешительныйРежим.Вставить("date", "2023.11.21");
				РазрешительныйРежим.Вставить("number", "1944");
				РазрешительныйРежим.Вставить("industryAttribute", стрТовар.ПроверкаМаркировки);
				МассивРежимов = Новый Массив;
				МассивРежимов.Добавить(РазрешительныйРежим);
				Позиция.Вставить("industryInfo", МассивРежимов);
			
			Иначе
				КодПризнакаПредметаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.КодПризнакаПредметаРасчета(стрТовар.ПризнакПредметаРасчета);
				Позиция.Вставить("paymentObject", Строка(КодПризнакаПредметаРасчета));
				
				Позиция.Вставить("imcType", "0");
				Позиция.Вставить("imc", "0");
				Позиция.Вставить("itemEstimatedStatus", "1");	
				Позиция.Вставить("itemUnits", "0");	
			КонецЕсли;
			
			МассивПозиций.Добавить(Позиция);
		КонецЦикла;
	КонецЕсли;
	
	СуммаОплат = Задание.payments[0].sum;
	
	// Сумма оплат отличается от документа продажи
	Если СуммаОплат > СуммаДокументаПродажи Тогда
		// Переплата
		Позиция= Новый Структура;
		Позиция.Вставить("type", "position");
		Если Задание.Свойство("clientInfo") И Задание.clientInfo.Свойство("name") Тогда 
			Позиция.Вставить("name", "Оплата от: " + Задание.clientInfo.name);
		Иначе
			Позиция.Вставить("name", "Оплата от клиента");
		КонецЕсли;
		Позиция.Вставить("price", СуммаОплат - СуммаДокументаПродажи);
		Позиция.Вставить("quantity", 1);
		Позиция.Вставить("amount", СуммаОплат - СуммаДокументаПродажи);
		
		Позиция.Вставить("infoDiscountAmount", 0);  
		Позиция.Вставить("imcType", "0");
		Позиция.Вставить("imc", "0");
		Позиция.Вставить("itemEstimatedStatus", "1");	
		Позиция.Вставить("itemUnits", "0");	  
		
		Позиция.Вставить("tax", Новый Структура("type", "vat120"));
		КодПризнакаСпособаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.КодПризнакаСпособаРасчета(ПредопределенноеЗначение("Перечисление.ПризнакиСпособаРасчета.Аванс"));
		Позиция.Вставить("paymentMethod", Строка(КодПризнакаСпособаРасчета));
		КодПризнакаПредметаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.КодПризнакаПредметаРасчета(ПредопределенноеЗначение("Перечисление.ПризнакиПредметаРасчета.Платеж"));
		Позиция.Вставить("paymentObject", Строка(КодПризнакаПредметаРасчета)); 
		Позиция.Вставить("measurementUnit", "255");
		
		МассивПозиций.Добавить(Позиция);
	КонецЕсли;
	
	Задание.Вставить("items", МассивПозиций);
	
КонецПроцедуры

Процедура ЗаполнитьПоНалогам(Задание, Организация, Дата) Экспорт
	
	СистемаНалогообложения= УчетнаяПолитикаПереопределяемый.СистемаНалогообложения(Организация, Дата);
	
	Если СистемаНалогообложения= Перечисления.СистемыНалогообложения.Общая Тогда
		Задание.Вставить("taxationType", "osn");
		
	ИначеЕсли СистемаНалогообложения= Перечисления.СистемыНалогообложения.Упрощенная Тогда
		
		Если УчетнаяПолитикаПереопределяемый.ПрименяетсяУСНДоходыМинусРасходы(Организация, Дата) Тогда
			Задание.Вставить("taxationType", "usnIncomeOutcome");
		ИначеЕсли УчетнаяПолитикаПереопределяемый.ПрименяетсяУСНДоходы(Организация, Дата) Тогда
			Задание.Вставить("taxationType", "usnIncome");
		ИначеЕсли УчетнаяПолитикаПереопределяемый.ПрименяетсяПСН(Организация, Дата) Тогда
			Задание.Вставить("taxationType", "patent");
		КонецЕсли;	
		
	Иначе
		Задание.Вставить("taxationType", "osn");
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьИнформациюОбОрганизации(Задание, Организация) Экспорт
	
	ИнформацияОбОрганизации= Новый Структура;
	ИнформацияОбОрганизации.Вставить("name", Организация.Наименование);
	ИнформацияОбОрганизации.Вставить("vatin", Организация.ИНН);
	
	Задание.Вставить("companyInfo", ИнформацияОбОрганизации);
	
КонецПроцедуры

Процедура ЗаполнитьИнформациюОПокупателе(Задание, ДокументПродажи, EmailИлиТелефон = "", НужнаОтправкаЧекаОФД = Ложь) Экспорт
	
	ИнформацияОКлиенте= Новый Структура;
	
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекККМ") Или
		 ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекККМВозврат") Или
	 	 ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекСамообслуживания")
	Тогда
		Если НужнаОтправкаЧекаОФД И (EmailИлиТелефон <> "") Тогда
			ИнформацияОКлиенте.Вставить("emailOrPhone", EmailИлиТелефон);
			Задание.Вставить("clientInfo", ИнформацияОКлиенте);          
		КонецЕсли;
	Иначе
		Если ДокументПродажи.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель 
			Или ДокументПродажи.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Или НужнаОтправкаЧекаОФД Тогда
	   		
	   		Если ДокументПродажи.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель 
	   			Или ДокументПродажи.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо Тогда 
					ИнформацияОКлиенте.Вставить("name", ДокументПродажи.Контрагент.Наименование);
					ИнформацияОКлиенте.Вставить("vatin", ДокументПродажи.Контрагент.ИНН);
	   		КонецЕсли;
	   		
		ИнформацияОКлиенте.Вставить("emailOrPhone", EmailИлиТелефон);
		Задание.Вставить("clientInfo", ИнформацияОКлиенте);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// МестоВывода: preItems, postItems
Процедура ДобавитьДополнительныйТекст(Задание, МестоВывода, text, alignment="left", wrap="words", font=1, doubleWidth=Ложь, doubleHeight=Ложь)
	
	СтрокаТекста= ПодготовитьСсрокуТекста(text, alignment, wrap, font, doubleWidth, doubleHeight);
	
	МассивСтрок= Новый Массив;
	МассивСтрок.Добавить(СтрокаТекста);
	
	Задание.Вставить(МестоВывода, МассивСтрок);
	
КонецПроцедуры

Функция ПодготовитьСсрокуТекста(text, alignment="left", wrap="words", font=1, doubleWidth=Ложь, doubleHeight=Ложь)
	
	СтрокаТекста= Новый Структура;
	
	СтрокаТекста.Вставить("type", "text");
	СтрокаТекста.Вставить("text", text);
	СтрокаТекста.Вставить("alignment", alignment); //Выравнивание
	СтрокаТекста.Вставить("wrap", wrap); // Перенос
	СтрокаТекста.Вставить("font", font); // Шрифт
	СтрокаТекста.Вставить("doubleWidth", doubleWidth); //Текст двойной ширины
	СтрокаТекста.Вставить("doubleHeight", doubleHeight); //Текст двойной высоты
	
	Возврат СтрокаТекста;
	
КонецФункции

Функция ПолучитьСтавкуНалога(стрТовар)     
	
	СтавкаНДС = стрТовар.СтавкаНДС;
	
	Если ЗначениеЗаполнено(СтавкаНДС) Тогда
		
		Если ТипЗнч(СтавкаНДС) = Тип("ПеречислениеСсылка.СтавкиНДС") Тогда
			
			Если стрТовар.СтавкаНДС = Перечисления.СтавкиНДС.НДС20 Тогда
				стрСтавка= "vat20";
			ИначеЕсли стрТовар.СтавкаНДС = Перечисления.СтавкиНДС.НДС18 Тогда
				стрСтавка= "vat18";
			ИначеЕсли стрТовар.СтавкаНДС = Перечисления.СтавкиНДС.НДС10 Тогда
				стрСтавка= "vat10";
			ИначеЕсли стрТовар.СтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
				стрСтавка= "vat0";
			ИначеЕсли стрТовар.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
				стрСтавка= "none";
			Иначе 
				стрСтавка= "vat20";
			КонецЕсли;	
			
		ИначеЕсли ТипЗнч(СтавкаНДС) = Тип("СправочникСсылка.СтавкиНДС") Тогда
			
			ПроцентНДС = СтавкаНДС.Ставка;
			Если ПроцентНДС > 0 Тогда
				стрСтавка = "vat" + Format(ПроцентНДС, "ЧГ=0;ЧДЦ=0");  
			Иначе 
				Если СтавкаНДС.ПеречислениеСтавкаНДС = Перечисления.СтавкиНДС.НДС0 Тогда
					стрСтавка= "vat0";
				Иначе
					стрСтавка= "none";
				КонецЕсли;     
			КонецЕсли; 
			
		ИначеЕсли ТипЗнч(СтавкаНДС) = Тип("Число") Тогда
			
			Если СтавкаНДС > 0 Тогда
				стрСтавка = "vat" + Format(СтавкаНДС, "ЧГ=0;ЧДЦ=0");  
			Иначе 
				стрСтавка = "none";    
			КонецЕсли; 
			
		Иначе
			стрСтавка = "vat20";                                
		КонецЕсли;
	Иначе 
		стрСтавка= "vat20";                                
	КонецЕсли;
	
	Налог= Новый Структура("type", стрСтавка);
	
	Возврат Налог;
	
КонецФункции

