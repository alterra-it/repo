Функция ПослатьЗапросАТОЛ(Запрос, ПараметрыАТОЛ, ТипЗапроса = "GET", Данные = Неопределено) Экспорт
	
	Соединение = ПолучитьHTTPСоединение(ПараметрыАТОЛ.ПараметрыПодключения);
	
	Если ЗначениеЗаполнено(ПараметрыАТОЛ.ПараметрыПодключения.ИДУстройства) Тогда
		Запрос = Запрос+СтрШаблон("?deviceID=%1", ПараметрыАТОЛ.ПараметрыПодключения.ИДУстройства);
	КонецЕсли;
	
	Ответ= ПослатьHTTPЗапрос(Запрос, Соединение, ТипЗапроса, Данные);
	
	Возврат Ответ;
	
КонецФункции	                            

