#Область HTTP

Функция ПолучитьПараметрыСоединения(АдресСервера, Порт=Неопределено, Логин=Неопределено, Пароль=Неопределено, ИспользоватьSSL=Ложь, ИДУстройства="") Экспорт
	
	ПараметрыПодключения = Новый Структура;
	
	ПараметрыПодключения.Вставить("Логин", Логин);	
	ПараметрыПодключения.Вставить("Пароль",	Пароль);	
	ПараметрыПодключения.Вставить("АдресСервера", АдресСервера);	 
	ПараметрыПодключения.Вставить("Порт", Порт);	
	ПараметрыПодключения.Вставить("ИспользоватьSSL", ИспользоватьSSL);	
	ПараметрыПодключения.Вставить("ИДУстройства", ИДУстройства);
	ПараметрыПодключения.Вставить("Таймаут", 0);
	
	Возврат ПараметрыПодключения;
	
КонецФункции

Функция ПолучитьHTTPСоединение(ПараметрыПодключения) Экспорт
	
	ssl = ?(ПараметрыПодключения.ИспользоватьSSL,Новый ЗащищенноеСоединениеOpenSSL, Неопределено);
	
	Соединение = Новый HTTPСоединение(
	ПараметрыПодключения.АдресСервера, // сервер (хост)
	ПараметрыПодключения.Порт, // порт, по умолчанию для http используется 80, для https 443
	ПараметрыПодключения.Логин, // пользователь для доступа к серверу (если он есть)
	ПараметрыПодключения.Пароль, // пароль для доступа к серверу (если он есть)
	, // здесь указывается прокси, если он есть
	ПараметрыПодключения.Таймаут, // таймаут в секундах, 0 или пусто - не устанавливать
	ssl  // защищенное соединение, если используется https
	);
	
	Возврат Соединение;
	
КонецФункции

Функция ПослатьHTTPЗапрос(АдресЗапроса, HTTPСоединение, ТипЗапроса="GET", Данные=Неопределено) Экспорт
	
	ЕстьОшибка = Ложь;
	ОтветТело = "";
	
	Попытка
		HTTPЗапрос= Новый HTTPЗапрос(АдресЗапроса);
		HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
		
		HTTPЗапрос.УстановитьТелоИзСтроки(Данные);
		
		Если ТипЗапроса="GET" Тогда
			Ответ = HTTPСоединение.Получить(HTTPЗапрос);
		ИначеЕсли ТипЗапроса="POST" Тогда
			Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		ИначеЕсли ТипЗапроса="PUT" Тогда
			Ответ = HTTPСоединение.Записать(HTTPЗапрос);
		ИначеЕсли ТипЗапроса="DELETE" Тогда
			Ответ = HTTPСоединение.Удалить(HTTPЗапрос);
		КонецЕсли;
				
		ОтветТело= Ответ.ПолучитьТелоКакСтроку();
		
		ДанныеОтвета= ОбщийHTTPСервер.ДесериализоватьИзJSON(ОтветТело);
		
		Текст= ОтветТело;
		
	Исключение
		Текст= СтрШаблон("Ошибка выполнения %1 запроса: %2", ТипЗапроса, АдресЗапроса);
		Ответ= ПодготовитьОтвет(Истина, Текст, Данные, ОтветТело);
		Возврат Ответ;
	КонецПопытки;
	
	Если ТипЗнч(ДанныеОтвета) = Тип("Структура") Тогда
		Если ДанныеОтвета.Свойство("error") Тогда
			ЕстьОшибка= Истина;
			Текст= СтрШаблон("Ошибка: %1 ""%2""", ДанныеОтвета.error.code, ДанныеОтвета.error.description);
			
		КонецЕсли;
		
		Если ДанныеОтвета.Свойство("results") Тогда
			
			Если ТипЗнч(ДанныеОтвета.results) = Тип("Массив") И ДанныеОтвета.results.Количество() Тогда
				
				Результат = ДанныеОтвета.results[0]; 
				Если ТипЗнч(Результат) = Тип("Структура") Тогда
					Если Результат.Свойство("error") И Результат.error.code > 0 Тогда
						ЕстьОшибка = Истина;
						Текст = СтрШаблон("Ошибка: %1 ""%2""", Результат.error.code, Результат.error.description);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	Ответ = ПодготовитьОтвет(ЕстьОшибка, Текст, ДанныеОтвета, ОтветТело);
	Возврат Ответ;
	
КонецФункции

#КонецОбласти

#Область Служебные
Функция ПодготовитьHTTPОтвет(Ошибка, ТекстСообщения="", Данные=Неопределено)  Экспорт
	
	Ответ = ПодготовитьОтвет(Ошибка, ТекстСообщения, Данные);
	ДанныеОтправки= ОбщийHTTPСервер.СериализоватьВJSON(Ответ);
	
	HTTPОтвет = Новый HTTPСервисОтвет(200);
	HTTPОтвет.УстановитьТелоИзСтроки(ДанныеОтправки, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
	Возврат HTTPОтвет;
	
КонецФункции

Функция ПодготовитьОтвет(Ошибка, ТекстСообщения="", Данные=Неопределено, JSONТело = "")  Экспорт
	
	Если Данные = Неопределено Тогда
		Данные= Новый Структура();
	КонецЕсли;
	
	Ответ= Новый Структура("Ошибка, ТекстСообщения, Данные, ОтветТело", Ошибка, ТекстСообщения, Данные, JSONТело);
	Возврат Ответ;
	
КонецФункции

Функция ПолучитьФНДанныеДляQRКода(ПараметрыАТОЛ, ДанныеФН) Экспорт
	
	QRКод = СтрШаблон("t=%1&s=%2&fn=%3&i=%4&fp=%5&n=%6", Формат(ДанныеФН.ДатаВремяПробития, "ДФ=ггггммддТччмм"), ДанныеФН.СуммаИтого, ДанныеФН.НомерФН, ДанныеФН.НомерЧекаФД, ДанныеФН.НомерФПД, ДанныеФН.ПриходРасход);
	ДанныеQR =  Новый Структура("QRКод", QRКод);
	Возврат ДанныеQR;
	
КонецФункции

