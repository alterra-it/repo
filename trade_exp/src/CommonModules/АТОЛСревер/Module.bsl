Функция ОткрытьСмену(ПараметрыАТОЛ) Экспорт
	
	УИД = "0" + Формат(ТекущаяДата(), "ДФ=ггггММддччммсс");
	
	Задание = ЗаданиеОткрытьСмену(ПараметрыАТОЛ);
	Данные = ПодготовитьЗапросВОчередь(УИД, Задание);
	ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);
	
	Ответ = ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);
	Возврат Ответ;
	
КонецФункции

Функция ЗакрытьСмену(ПараметрыАТОЛ) Экспорт
	
	УИД = "1" + Формат(ТекущаяДата(), "ДФ=ггггММддччммсс");
	
	Задание = ЗаданиеЗакрытьСмену(ПараметрыАТОЛ);
	Данные = ПодготовитьЗапросВОчередь(УИД, Задание);
	ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);

	Ответ= ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);
	Возврат Ответ;
	
КонецФункции

Функция ПробитьЧек(ПараметрыАТОЛ, ИдентификаторДокумента = "", ПолучениеЗадания = Ложь, ПолучениеJSON = Ложь) Экспорт
	
	УИД = ?(Не ЗначениеЗаполнено(ИдентификаторДокумента), XMLСтрока(ПараметрыАТОЛ.ДокументПродажи), ИдентификаторДокумента); 
	
	ПараметрыСФорматнымКонтролем = ПровестиФорматноЛогическийКонтрольСумм(ПараметрыАТОЛ);
	ПараметрыАТОЛ.Вставить("ПараметрыСФорматнымКонтролем", ПараметрыСФорматнымКонтролем); 
	
	Задание = ЗаданиеПробитьЧек_СКонтролем(ПараметрыАТОЛ);

	Данные = ПодготовитьЗапросВОчередь(УИД, Задание);
	
	// Выполнить запрос
	Если Не ПолучениеЗадания Тогда
		
		Ответ= ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);
		
		// Тексты запроса и ответа JSON
		Если ПолучениеJSON Тогда
			Ответ.Вставить("Запрос", ДопМодульСервер.ФорматироватьJsonТекст(ОбщийHTTPСервер.СериализоватьВJSON(Данные)));
		Иначе
			Если Ответ.Свойство("ОтветТело") Тогда
				Ответ.Удалить("ОтветТело");
			КонецЕсли;
		КонецЕсли;
		
		Возврат Ответ; 
	
	// Получить только тело запроса
	Иначе     
		Возврат Данные;
	КонецЕсли;
	
КонецФункции    

Функция ХОтчет(ПараметрыАТОЛ) Экспорт
	
	УИД= ПолучитьУИД();
	
	Задание = ЗаданиеХОтчет();
	Данные = ПодготовитьЗапросВОчередь(УИД, Задание);
	ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);
	
	Ответ = ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, Данные);
	Возврат Ответ;
	
КонецФункции

