Функция ПроверитьСтатусДинамическойСсылки(ПараметрыДС, Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Проверка статуса ДС %1", ?(ПараметрыДС.Свойство("ИдентификаторСсылки") И ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки), 
				ПараметрыДС.ИдентификаторСсылки, ПараметрыДС.Документ))); 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ *                                                 
		|ИЗ 
		|	РегистрСведений.ДинамическиеСсылки  
		|ГДЕ
		|	НЕ Возврат
		|	%УсловиеОтбора";
	
	УсловиеОтбора = "";
	Для Каждого ПараметрДС ИЗ ПараметрыДС Цикл                                
		Если ЗначениеЗаполнено(ПараметрДС.Значение) Тогда
			ЭтоМассив = ТипЗнч(ПараметрДС.Значение) = Тип("Массив");
			УсловиеОтбора = УсловиеОтбора + СтрШаблон("И %1 %2 &%3%4", ПараметрДС.Ключ, ?(ЭтоМассив, " В (", " = "), ПараметрДС.Ключ, ?(ЭтоМассив, ")", "")) + Символы.ПС;
			Запрос.УстановитьПараметр(ПараметрДС.Ключ, ПараметрДС.Значение);
		КонецЕсли;
	КонецЦикла;		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%УсловиеОтбора", УсловиеОтбора);
		
	ТЗ = Запрос.Выполнить().Выгрузить();
	КоличествоДС = ТЗ.Количество();
	
	РезультатВыполнения.Ответ = ПараметрыЗаписиДинамическойСсылки();
	РезультатВыполнения.Ответ.Вставить("Количество", КоличествоДС);
	
	Если КоличествоДС = 1 Тогда
		
		РезультатВыполнения.Результат = Истина;
		ДС = ТЗ[0];
		ЗаполнитьЗначенияСвойств(РезультатВыполнения.Ответ, ДС);        
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Найдена динамическая ссылка: %1 ", 
			?(ПараметрыДС.Свойство("ИдентификаторСсылки") И ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки),
				"идентификатор  " + ПараметрыДС.ИдентификаторСсылки, "документ " + ПараметрыДС.Документ)) + Символы.ПС);
			
	ИначеЕсли КоличествоДС > 1 Тогда
		
		 ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Найдено более одной динамической ссылки по заданному условию:  %1 ", 
			?(ПараметрыДС.Свойство("ИдентификаторСсылки") И ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки), 
				"идентификатор  " + ПараметрыДС.ИдентификаторСсылки, "документ " + ПараметрыДС.Документ)) + Символы.ПС);
			
		СписокСсылок = "";
		 Для Каждого ДС ИЗ ТЗ Цикл
		 	СписокСсылок = СписокСсылок + 
		 		СтрШаблон("Идентификатор динамической ссылки %1 для документа %2 на сумму %3", ДС.ИдентификаторСсылки, ДС.Документ, ДС.Сумма) + Символы.ПС; 
		КонецЦикла;                  
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СписокСсылок);
		 
	Иначе
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Не найдена динамическая ссылка" + Символы.ПС);
	КонецЕсли;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);  
	Если Логирование Тогда
		ЗаписатьЛоги(ПолучитьНастройкиДинамическиеСсылки().Ответ, РезультатВыполнения);
	КонецЕсли;
		
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ПроверитьОчередьДинамическойСсылки(ПараметрыДС, Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Проверка очереди ДС %1", 
		?(ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки), ПараметрыДС.ИдентификаторСсылки, Строка(ПараметрыДС.Документ))), Логирование); 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ *
		|ИЗ 
		|	РегистрСведений.ОчередьЧековКПробитию  
		|ГДЕ
		|	%УсловиеОтбора
		|	И Обработано
		|	И НЕ Возврат";
		
	Если ПараметрыДС.Свойство("ИдентификаторСсылки") И ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки) Тогда  
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%УсловиеОтбора", "ДинамическаяСсылка = &ИдентификаторСсылки");
		Запрос.УстановитьПараметр("ИдентификаторСсылки", ПараметрыДС.ИдентификаторСсылки);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%УсловиеОтбора", "ЗаказКлиента = &Документ");
		Запрос.УстановитьПараметр("Документ", ПараметрыДС.Документ);
	КонецЕсли;
		
	ТЗ = Запрос.Выполнить().Выгрузить();
	КоличествоДС = ТЗ.Количество();
	
	РезультатВыполнения.Ответ = ПараметрыЗаписиДинамическойСсылки();
	РезультатВыполнения.Ответ.Вставить("Количество", КоличествоДС);
	
	Если КоличествоДС = 1 Тогда
		
		РезультатВыполнения.Результат = Истина;
		ДС = ТЗ[0];

		РезультатВыполнения.Ответ.ИдентификаторСсылки 	= ДС.ДинамическаяСсылка;
		РезультатВыполнения.Ответ.Документ 				= ДС.ЗаказКлиента;
		РезультатВыполнения.Ответ.ДокументОперации 		= ДС.ЗаказКлиента;
		РезультатВыполнения.Ответ.Дата 					= ДС.ДатаПостановки;
		РезультатВыполнения.Ответ.ДатаОперации 			= ДС.ДатаПостановки;
		РезультатВыполнения.Ответ.Сумма 				= ДС.СуммаОплаты;
		РезультатВыполнения.Ответ.СуммаОперации 		= ДС.СуммаОплаты;
		
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Найден идентификатор ссылки: %1 ", 
			?(ПараметрыДС.Свойство("ИдентификаторСсылки") И ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки),
				"идентификатор  " + ПараметрыДС.ИдентификаторСсылки, "документ " + ПараметрыДС.Документ)));
			
	ИначеЕсли КоличествоДС > 1 Тогда
		
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Найдено более одного идентификатора ссылки по заданному условию:  %1 ", 
			?(ПараметрыДС.Свойство("ИдентификаторСсылки") И ЗначениеЗаполнено(ПараметрыДС.ИдентификаторСсылки), 
				"идентификатор  " + ПараметрыДС.ИдентификаторСсылки, "документ " + ПараметрыДС.Документ)) + Символы.ПС);
				
		 Для Каждого ДС ИЗ ТЗ Цикл
		 	ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Идентификатор ссылки  %1 для документа %2 на сумму %3", 
				ДС.ИдентификаторСсылки, ДС.Документ, ДС.Сумма) + Символы.ПС); 
		 КонецЦикла;
		 
	 Иначе                                                 
		 ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Не найден идентификатор ссылки для возврата");
	КонецЕсли;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);  
	Если Логирование Тогда
		ЗаписатьЛоги(ПолучитьНастройкиДинамическиеСсылки().Ответ, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьАктивированнуюДинамическуюСсылку(Документ, Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения("Получение активированной динамической ссылки", Истина);
	 
	ПараметрыДС = ПараметрыПолученияДинамическиеСсылки();
	ПараметрыДС.Документ = Документ;
	ПараметрыДС.Статус.Добавить(ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация"));
	ПроверкаСтатусаАктивации = ПроверитьСтатусДинамическойСсылки(ПараметрыДС);
	
	Если ПроверкаСтатусаАктивации.Ответ.Количество = 1 Тогда
		РезультатВыполнения.Результат = Истина;
	КонецЕсли;
	
	РезультатВыполнения.Ответ = ПроверкаСтатусаАктивации.Ответ;             
	ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаАктивации.Сообщение);
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);                         
	Если Логирование Тогда
		ЗаписатьЛоги(ПолучитьНастройкиДинамическиеСсылки().Ответ, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция НужнаПереактивацияДинамическойСсылки(Документ, Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Проверка активации ДС по %1", Документ) , Логирование);
	
	// Получение активированной ссылки по документу 
	ПараметрыДС = ПараметрыПолученияДинамическиеСсылки();
	ПараметрыДС.Документ = Документ;
	ПараметрыДС.Статус.Добавить(ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация"));
	ПроверкаСтатусаАктивации = ПроверитьСтатусДинамическойСсылки(ПараметрыДС);
	
	// Определение суммы документа
	ПараметрыДокумента = ПолучениеПараметровДокумента(Документ);

	// Необходимость переактивации	
	Если ПроверкаСтатусаАктивации.Ответ.Количество = 1 И ПараметрыДокумента.Количество() > 0 
		И ПроверкаСтатусаАктивации.Ответ.Сумма <> ПараметрыДокумента[0].СуммаДокумента Тогда
			РезультатВыполнения.Результат = Истина;
	КонецЕсли;
	
	РезультатВыполнения.Ответ = ПроверкаСтатусаАктивации.Ответ;    
	ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаАктивации.Сообщение);
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);   
	Если Логирование Тогда
		ЗаписатьЛоги(ПолучитьНастройкиДинамическиеСсылки().Ответ, РезультатВыполнения);
	КонецЕсли;
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ПолучитьПараметрыВозвратаДинамическойСсылки(ТипСсылки, ДинамическаяСсылка, Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);            
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Получение параметров возврата ДС %1", Строка(ДинамическаяСсылка)), Логирование);
	
	РезультатВыполнения.Ответ = ПараметрыСостоянияДинамическиеСсылки();

	ПроверкаСостоянияДС = ПроверитьСостояниеДинамическойСсылки(ТипСсылки, ДинамическаяСсылка);
	ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСостоянияДС.Сообщение);

	Если ПроверкаСостоянияДС.Результат Тогда
		
		ЗаполнитьЗначенияСвойств(РезультатВыполнения.Ответ, ПроверкаСостоянияДС.Ответ);
		
		Если ПроверкаСостоянияДС.Ответ.Сумма > 0 Тогда
			 РезультатВыполнения.Результат = Истина;	
		
			Возвраты = ПолучитьОснованияВозвратов(ПроверкаСостоянияДС.Ответ.Документ);
			Если Возвраты.Количество() > 0 Тогда
				РезультатВыполнения.Ответ.ДокументыВозврата	= Возвраты;
			КонецЕсли;
		Иначе               
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Сумма идентификатора ссылки %1 по документу %2 равна нулю",
				ПроверкаСостоянияДС.Ответ.ИдентификаторСсылки, ПроверкаСостоянияДС.Ответ.Документ));
		КонецЕсли;
	КонецЕсли;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);        
	Если Логирование Тогда
		ЗаписатьЛоги(ПолучитьНастройкиДинамическиеСсылки().Ответ, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ЗаписатьДинамическуюСсылку(ПараметрыЗаписиДС, ПараметрыИзмененияДС = Неопределено, Логирование = Ложь)
	
	РезультатВыполнения = ПараметрыВыполнения("Запись активированной ДС");
	РезультатВыполнения.Ответ = ПараметрыЗаписиДинамическойСсылки();
	
	Попытка
		НаборЗаписей = РегистрыСведений.ДинамическиеСсылки.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ИдентификаторСсылки.Установить(ПараметрыЗаписиДС.ИдентификаторСсылки);	
		НаборЗаписей.Отбор.ТипСсылки.Установить(ПараметрыЗаписиДС.ТипСсылки);	
		НаборЗаписей.Отбор.Банк.Установить(ПараметрыЗаписиДС.Банк);
		НаборЗаписей.Отбор.Документ.Установить(ПараметрыЗаписиДС.Документ);
		НаборЗаписей.Отбор.Дата.Установить(ПараметрыЗаписиДС.Дата);
		НаборЗаписей.Прочитать();
		
		// Изменение существующей ДС 
		Если ЗначениеЗаполнено(ПараметрыИзмененияДС) Тогда
			
			// Изменение одной найденной динамической ссылки 
			Если НаборЗаписей.Количество() = 1 Тогда
				ЗаполнитьЗначенияСвойств(НаборЗаписей[0], ПараметрыИзмененияДС);
				НаборЗаписей.Записать();                         
				
				РезультатВыполнения.Результат = Истина;	         
				ЗаполнитьЗначенияСвойств(РезультатВыполнения.Ответ, НаборЗаписей[0]);
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Идентификатор ссылки %1 по документу %2 на сумму %3 руб. изменен",
					ПараметрыЗаписиДС.ИдентификаторСсылки, ПараметрыЗаписиДС.Документ, Формат(ПараметрыЗаписиДС.Сумма, "ЧДЦ=2")));	
			
			// Изменение невозможно из-за отсутствия динамической ссылки
			ИначеЕсли НаборЗаписей.Количество() = 0 Тогда
				ЗаписатьИнформациюВыполнения(РезультатВыполнения,СтрШаблон("Идентификатор ссылки %1 по документу %2 на сумму %3 руб. не найден",
					ПараметрыЗаписиДС.ИдентификаторСсылки, ПараметрыЗаписиДС.Документ, Формат(ПараметрыЗаписиДС.Сумма, "ЧДЦ=2")));	
					
			// Изменение невозможно ссылок больше чем одна
			Иначе
				 ЗаписатьИнформациюВыполнения(РезультатВыполнения,"Изменение не выполнено: найдено более одной динамической ссылки" + Символы.ПС);
				 Для Каждого ДС ИЗ НаборЗаписей Цикл
				 	ЗаписатьИнформациюВыполнения(РезультатВыполнения, 
				 		СтрШаблон("Идентификатор ссылки %1 для документа %2 на сумму %3 руб.", ДС.ИдентификаторСсылки, ДС.Документ, Формат(ПараметрыЗаписиДС.Сумма, "ЧДЦ=2")) + Символы.ПС); 
				 КонецЦикла;
			КонецЕсли; 
			
		// Добавление новой ДС
		Иначе
			
			// Добавление новой динамической ссылки  
			Если НаборЗаписей.Количество() = 0 Тогда
				НоваяЗапись = НаборЗаписей.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяЗапись, ПараметрыЗаписиДС);
				НаборЗаписей.Записать();              
				
				РезультатВыполнения.Результат = Истина;
				ЗаполнитьЗначенияСвойств(РезультатВыполнения.Ответ, НоваяЗапись);
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка %1 по документу %2 на сумму %3 руб. добавлена",
					ПараметрыЗаписиДС.ИдентификаторСсылки, ПараметрыЗаписиДС.Документ, Формат(ПараметрыЗаписиДС.Сумма)));	
				
			// Добавление невозможно из-за уже существования динамической ссыки
			Иначе
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Добавление не выполнено: динамическая ссылка %1 по документу %2 на сумму %3 руб. уже существует",
					ПараметрыЗаписиДС.ИдентификаторСсылки, ПараметрыЗаписиДС.Документ, Формат(ПараметрыЗаписиДС.Сумма)));	
			КонецЕсли;
			
		КонецЕсли;
		
	Исключение
		ЗаписатьИнформациюВыполнения(РезультатВыполнения,"Динамическая ссылка не записана в регистр:" + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;	
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);          
	Если Логирование Тогда
		ЗаписатьЛоги(ПолучитьНастройкиДинамическиеСсылки().Ответ, РезультатВыполнения);
	КонецЕсли;	
		
	Возврат РезультатВыполнения;	
	
КонецФункции	

#КонецОбласти

#Область Документы

Функция ПолучениеПараметровДокумента(Документ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номер, Дата, СуммаДокумента
		|ИЗ 
		|	%ТипДокумента
		|ГДЕ
		|	Ссылка = &Документ";
	
	ТипДокумента = Метаданные.НайтиПоТипу(ТипЗнч(Документ)).ПолноеИмя();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента", ТипДокумента);
	Запрос.УстановитьПараметр("Документ", Документ);  
	
	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции			

Функция ПолучениеПараметровРегистрацииДокумента(НастройкиДС, Документ)
	
	ПараметрыРегистрацииДС = ПараметрыРегистрацииДинамическиеСсылки(Документ);

	ПараметрыДокумента = ПолучениеПараметровДокумента(Документ);
	
	Если ПараметрыДокумента.Количество() > 0 Тогда
		
		ДанныеДокумента = ПараметрыДокумента[0];
		
		ПараметрыРегистрацииДС.Номер 	= ПолучитьЗаказПоФормату(НастройкиДС.ФорматНомера, СтроковыеФункции.СтрокаЛатиницей(ДанныеДокумента.Номер), ДанныеДокумента.Дата);
		ПараметрыРегистрацииДС.Описание = ПолучитьЗаказПоФормату(НастройкиДС.ФорматОписания, ДанныеДокумента.Номер, ДанныеДокумента.Дата);
		ПараметрыРегистрацииДС.Сумма 	= ?(ЗначениеЗаполнено(ПараметрыРегистрацииДС.Сумма), ПараметрыРегистрацииДС.Сумма, ДанныеДокумента.СуммаДокумента);  
	КонецЕсли;
	
	Возврат ПараметрыРегистрацииДС;
	
КонецФункции

#КонецОбласти

#Область Возвраты

Функция ПолучитьОснованияВозвратов(Заказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ       
		|	Заказ.Ссылка КАК ДокументВозврата
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ    
		|ГДЕ               
		|	Заказ.Ссылка = &Заказ
		|	И Заказ.Проведен        
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ       
		|	Возврат.Ссылка КАК ДокументВозврата 
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ
		|	СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|		ПО Заказ.Ссылка = Реализация.ЗаказКлиента
		|		И Реализация.Проведен
		|	СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента КАК Возврат
		|		ПО Реализация.Ссылка = Возврат.ДокументРеализации
		|		И Возврат.Проведен   
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыБезнал
		|		СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК РасшифровкаБезнал
		|			ПО ОбъектыБезнал.Ссылка = РасшифровкаБезнал.ОбъектРасчетов 
		|		СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО
		|			ПО РасшифровкаБезнал.Ссылка = ЭО.Ссылка 
		|			И ЭО.Проведен
		|		ПО Возврат.Ссылка = ОбъектыБезнал.Объект 
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыНал
		|		СОЕДИНЕНИЕ Документ.РасходныйКассовыйОрдер.РасшифровкаПлатежа КАК РасшифровкаНал
		|			ПО ОбъектыНал.Ссылка = РасшифровкаНал.ОбъектРасчетов 
		|		СОЕДИНЕНИЕ Документ.РасходныйКассовыйОрдер КАК РКО
		|			ПО РасшифровкаНал.Ссылка = РКО.Ссылка 
		|			И РКО.Проведен
		|		ПО Возврат.Ссылка = ОбъектыНал.Объект    
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыВзаимозачет
		|		СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности.КредиторскаяЗадолженность КАК ВзаимозачетКредит
		|			ПО ОбъектыВзаимозачет.Ссылка = ВзаимозачетКредит.ОбъектРасчетов 
		|		СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности КАК Взаимозачет
		|			ПО ВзаимозачетКредит.Ссылка = Взаимозачет.Ссылка 
		|			И Взаимозачет.Проведен
		|		ПО Возврат.Ссылка = ОбъектыВзаимозачет.Объект
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
		|		ПО ЕСТЬNULL(ЭО.Ссылка, ЕСТЬNULL(РКО.Ссылка, Взаимозачет.Ссылка)) = ФискальныеОперации.ДокументОснование
		|ГДЕ               
		|	Заказ.Ссылка = &Заказ
		|	И Заказ.Проведен	  
		|	И ФискальныеОперации.ДокументОснование ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ       
		|	Возврат.Ссылка КАК ДокументВозврата 
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК Реализация
		|	СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента КАК Возврат
		|		ПО Реализация.Ссылка = Возврат.ДокументРеализации
		|		И Возврат.Проведен   
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыБезнал
		|		СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК РасшифровкаБезнал
		|			ПО ОбъектыБезнал.Ссылка = РасшифровкаБезнал.ОбъектРасчетов 
		|		СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО
		|			ПО РасшифровкаБезнал.Ссылка = ЭО.Ссылка 
		|			И ЭО.Проведен
		|		ПО Возврат.Ссылка = ОбъектыБезнал.Объект 
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыНал
		|		СОЕДИНЕНИЕ Документ.РасходныйКассовыйОрдер.РасшифровкаПлатежа КАК РасшифровкаНал
		|			ПО ОбъектыНал.Ссылка = РасшифровкаНал.ОбъектРасчетов 
		|		СОЕДИНЕНИЕ Документ.РасходныйКассовыйОрдер КАК РКО
		|			ПО РасшифровкаНал.Ссылка = РКО.Ссылка 
		|			И РКО.Проведен
		|		ПО Возврат.Ссылка = ОбъектыНал.Объект    
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыВзаимозачет
		|		СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности.КредиторскаяЗадолженность КАК ВзаимозачетКредит
		|			ПО ОбъектыВзаимозачет.Ссылка = ВзаимозачетКредит.ОбъектРасчетов 
		|		СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности КАК Взаимозачет
		|			ПО ВзаимозачетКредит.Ссылка = Взаимозачет.Ссылка 
		|			И Взаимозачет.Проведен
		|		ПО Возврат.Ссылка = ОбъектыВзаимозачет.Объект
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
		|		ПО ЕСТЬNULL(ЭО.Ссылка, ЕСТЬNULL(РКО.Ссылка, Взаимозачет.Ссылка)) = ФискальныеОперации.ДокументОснование
		|ГДЕ               
		|	Реализация.Ссылка = &Заказ
		|	И Реализация.Проведен	  
		|	И ФискальныеОперации.ДокументОснование ЕСТЬ NULL";
		
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ДокументВозврата");
	
КонецФункции	

Функция ПолучитьОплатуДинамическойСсылки(ДокументОснование, ДокументОплаты = Неопределено, ДатаПостановки = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ОплатаДинамическиеСсылки = ПараметрыВозвратаДинамическиеССылки(); 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ 
		|	ЭО.Ссылка КАК Документ, 
		|	ЭО.Дата, 
		|	ЭО.СуммаДокумента,
		|	ФискальныеОперации.ДокументОснование ЕСТЬ НЕ NULL КАК Оформление
		|ПОМЕСТИТЬ 
		|	втВозвраты	
		|ИЗ
		|	Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ЭОРасшифровка
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО 
		|		ПО ЭОРасшифровка.Ссылка = ЭО.Ссылка
		|		И ЭО.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту)
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
		|		ПО ЭО.Ссылка = ФискальныеОперации.ДокументОснование
		|ГДЕ
		|	ЭОРасшифровка.ОснованиеПлатежа = &Документ    
		|	И НЕ ЭО.ПометкаУдаления
		|;            
		|ВЫБРАТЬ * 
		|ПОМЕСТИТЬ втОформленныеВозвраты
		|ИЗ втВозвраты  
		|ГДЕ Оформление
		|;          
		|ВЫБРАТЬ * 
		|ИЗ втОформленныеВозвраты
		|УПОРЯДОЧИТЬ ПО Дата УБЫВ
		|;
		|ВЫБРАТЬ * 
		|ИЗ втВозвраты  
		|ГДЕ НЕ Оформление       
		|УПОРЯДОЧИТЬ ПО Дата УБЫВ
		|;
		|ВЫБРАТЬ           
		|	Ссылка КАК Документ,
		|	Дата,
		|	СуммаДокумента 
		|ПОМЕСТИТЬ втОформленныеРеализации	
		|ИЗ 
		|	Документ.РеализацияТоваровУслуг
		|ГДЕ 
		|	ТИПЗНАЧЕНИЯ(&Документ) = ТИП(Документ.ЗаказКлиента)
		|	И ЗаказКлиента = &Документ
		|	И Проведен
		|;	
		|ВЫБРАТЬ *
		|ИЗ втОформленныеРеализации
		|УПОРЯДОЧИТЬ ПО Дата УБЫВ
		|;
		|ВЫБРАТЬ 
		|	СУММА(Т.СуммаДокумента) КАК Сумма
		|ПОМЕСТИТЬ 
		|	втОплатыВозвраты
		|ИЗ
		|	(ВЫБРАТЬ СуммаДокумента
		|	ИЗ втОформленныеВозвраты
		|		
		|	ОБЪЕДИНИТЬ ВСЕ	
		|		
		|	ВЫБРАТЬ СуммаДокумента
		|	ИЗ втОформленныеРеализации) КАК Т
  		|;
		|ВЫБРАТЬ    
		|	ОчередьЧеков.СуммаОплаты - ЕСТЬNULL(втОплатыВозвраты.Сумма, 0) > 0 ТребуетсяВозврат,   
		|	ОчередьЧеков.ЗаказКлиента КАК ДокументОснование,
		|	Заказ.Ссылка КАК ДокументВозврата,
		|	ВЫБОР 
		|		КОГДА ОчередьЧеков.СуммаОплаты - ЕСТЬNULL(втОплатыВозвраты.Сумма, 0) >= 0
		|		ТОГДА ОчередьЧеков.СуммаОплаты - ЕСТЬNULL(втОплатыВозвраты.Сумма, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК СуммаДокументаВозврата,
		|	ЭОРасшифровка.ОбъектРасчетов.Объект КАК ОбъектРасчетов,		
		|	ОчередьЧеков.ТипСсылки,		
		|	ОчередьЧеков.ДинамическаяСсылка,				
		|	ОчередьЧеков.Касса,				
		|	ОчередьЧеков.СуммаОплаты,          
		|	ОчередьЧеков.АдресУведомленияКлиента,		
		|	ОчередьЧеков.ЭквайринговыйТерминал,
		|	ОчередьВозвратов.Обработано КАК ВозвратОбработан, 
		|	ОчередьВозвратов.Информация КАК Информация
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ    
		|	СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьЧеков
		|		ПО Заказ.Ссылка = ОчередьЧеков.ЗаказКлиента  
		|		И ОчередьЧеков.Обработано
		|		И НЕ ОчередьЧеков.Возврат
		|		И ОчередьЧеков.ДинамическаяСсылка <> &ПустаяСтрока      
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО                                                                                                           
		|		ПО ОчередьЧеков.ЭквайринговаяОперация = ЭО.ССылка
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ЭОРасшифровка
		|		ПО ЭО.ССылка = ЭОРасшифровка.ССылка
		|		И НомерСтроки = 1            
		|	ЛЕВОЕ СОЕДИНЕНИЕ втОплатыВозвраты
		|		ПО ИСТИНА
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьВозвратов
		|		ПО %ФильтрВозврата
		|		И ОчередьВозвратов.Возврат
		|ГДЕ               
		|	Заказ.Ссылка = &Документ    
		|
		|ОБЪЕДИНИТЬ ВСЕ 
		|
		|ВЫБРАТЬ  
		|	ИСТИНА ТребуетсяВозврат,     
		|	ОчередьЧеков.ЗаказКлиента КАК ДокументОснование,
		|	ВозвратТоваров.Ссылка КАК ДокументВозврата,
		|	ВозвратТоваров.СуммаДокумента КАК СуммаДокументаВозврата,
		|	ЭОРасшифровка.ОбъектРасчетов.Объект КАК ОбъектРасчетов,		
		|	ОчередьЧеков.ТипСсылки,		
		|	ОчередьЧеков.ДинамическаяСсылка,				
		|	ОчередьЧеков.Касса,				
		|	ОчередьЧеков.СуммаОплаты,          
		|	ОчередьЧеков.АдресУведомленияКлиента,		
		|	ОчередьЧеков.ЭквайринговыйТерминал,
		|	ОчередьВозвратов.Обработано КАК ВозвратОбработан,
		|	ОчередьВозвратов.Информация КАК Информация
		|ИЗ 
		|	Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваров
		|	СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|		ПО ВозвратТоваров.ДокументРеализации = Реализация.Ссылка
		|		И Реализация.Проведен      
		|	СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ	
		|		ПО Реализация.ЗаказКлиента = Заказ.Ссылка
		|		И Заказ.Проведен 
		|	СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьЧеков
		|		ПО Заказ.Ссылка = ОчередьЧеков.ЗаказКлиента  
		|		И ОчередьЧеков.Обработано
		|		И НЕ ОчередьЧеков.Возврат 
		|		И ОчередьЧеков.ДинамическаяСсылка <> &ПустаяСтрока   
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО
		|		ПО ОчередьЧеков.ЭквайринговаяОперация = ЭО.ССылка
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ЭОРасшифровка
		|		ПО ЭО.ССылка = ЭОРасшифровка.ССылка
		|		И НомерСтроки = 1
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьВозвратов
		|		ПО %ФильтрВозврата
		|		И ОчередьВозвратов.Возврат
		|ГДЕ		                                                     
		|	ВозвратТоваров.Ссылка = &Документ
		|	И ВозвратТоваров.Проведен     
		|
		|ОБЪЕДИНИТЬ ВСЕ 
		|
		|ВЫБРАТЬ  
		|	ИСТИНА ТребуетсяВозврат,     
		|	ОчередьЧеков.ЗаказКлиента КАК ДокументОснование,
		|	ВозвратТоваров.Ссылка КАК ДокументВозврата,
		|	ВозвратТоваров.СуммаДокумента КАК СуммаДокументаВозврата,
		|	ЭОРасшифровка.ОбъектРасчетов.Объект КАК ОбъектРасчетов,		
		|	ОчередьЧеков.ТипСсылки,		
		|	ОчередьЧеков.ДинамическаяСсылка,				
		|	ОчередьЧеков.Касса,				
		|	ОчередьЧеков.СуммаОплаты,          
		|	ОчередьЧеков.АдресУведомленияКлиента,		
		|	ОчередьЧеков.ЭквайринговыйТерминал,
		|	ОчередьВозвратов.Обработано КАК ВозвратОбработан,
		|	ОчередьВозвратов.Информация КАК Информация
		|ИЗ 
		|	Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваров
		|	СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|		ПО ВозвратТоваров.ДокументРеализации = Реализация.Ссылка
		|		И Реализация.Проведен      
		|	СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьЧеков
		|		ПО Реализация.Ссылка = ОчередьЧеков.ЗаказКлиента  
		|		И ОчередьЧеков.Обработано
		|		И НЕ ОчередьЧеков.Возврат 
		|		И ОчередьЧеков.ДинамическаяСсылка <> &ПустаяСтрока   
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО
		|		ПО ОчередьЧеков.ЭквайринговаяОперация = ЭО.ССылка
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ЭОРасшифровка
		|		ПО ЭО.ССылка = ЭОРасшифровка.ССылка
		|		И НомерСтроки = 1
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьВозвратов
		|		ПО %ФильтрВозврата
		|		И ОчередьВозвратов.Возврат
		|ГДЕ		                                                     
		|	ВозвратТоваров.Ссылка = &Документ
		|	И ВозвратТоваров.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ 
		|
		|ВЫБРАТЬ  
		|	ИСТИНА ТребуетсяВозврат,     
		|	ОчередьЧеков.ЗаказКлиента КАК ДокументОснование,
		|	ВозвратТоваров.Ссылка КАК ДокументВозврата,
		|	ВозвратТоваров.СуммаДокумента КАК СуммаДокументаВозврата,
		|	ЭОРасшифровка.ОбъектРасчетов.Объект КАК ОбъектРасчетов,		
		|	ОчередьЧеков.ТипСсылки,		
		|	ОчередьЧеков.ДинамическаяСсылка,				
		|	ОчередьЧеков.Касса,				
		|	ОчередьЧеков.СуммаОплаты,          
		|	ОчередьЧеков.АдресУведомленияКлиента,		
		|	ОчередьЧеков.ЭквайринговыйТерминал,
		|	ОчередьВозвратов.Обработано КАК ВозвратОбработан,
		|	ОчередьВозвратов.Информация КАК Информация     
		|ИЗ 
		|	Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваров
		|	СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|		ПО ВозвратТоваров.ДокументРеализации = Реализация.Ссылка
		|		И Реализация.Проведен
		|	СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектДебет
		|		ПО Реализация.Ссылка = ОбъектДебет.Объект
		|	СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности.ДебиторскаяЗадолженность КАК ЗадолженностьДебет
		|		ПО ОбъектДебет.Ссылка = ЗадолженностьДебет.ОбъектРасчетов
		|	СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности КАК Задолженность
		|		ПО ЗадолженностьДебет.Ссылка = Задолженность.Ссылка
		|		И Задолженность.Проведен
		|	СОЕДИНЕНИЕ Документ.ВзаимозачетЗадолженности.КредиторскаяЗадолженность КАК ЗадолженностьКредит
		|		ПО Задолженность.Ссылка = ЗадолженностьКредит.Ссылка
		|	СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектКредит
		|		ПО ЗадолженностьКредит.ОбъектРасчетов = ОбъектКредит.Ссылка
		|	СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ	
		|		ПО ОбъектКредит.Объект = Заказ.Ссылка
		|		И Заказ.Проведен 
		|	СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьЧеков
		|		ПО Заказ.Ссылка = ОчередьЧеков.ЗаказКлиента  
		|		И ОчередьЧеков.Обработано
		|		И НЕ ОчередьЧеков.Возврат 
		|		И ОчередьЧеков.ДинамическаяСсылка <> &ПустаяСтрока     
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте КАК ЭО
		|		ПО ОчередьЧеков.ЭквайринговаяОперация = ЭО.ССылка
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК ЭОРасшифровка
		|		ПО ЭО.ССылка = ЭОРасшифровка.ССылка
		|		И ЭОРасшифровка.НомерСтроки = 1
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОчередьЧековКПробитию КАК ОчередьВозвратов
		|		ПО %ФильтрВозврата       
		|		И ОчередьВозвратов.Возврат
		|ГДЕ		                                                     
		|	ВозвратТоваров.Ссылка = &Документ
		|	И ВозвратТоваров.Проведен";
		
	Запрос.УстановитьПараметр("Документ", ДокументОснование);   
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	
	Если ЗначениеЗаполнено(ДокументОплаты) Тогда     
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ФильтрВозврата", "ОчередьВозвратов.ЭквайринговаяОперация = &ЭквайринговаяОперация");
		Запрос.УстановитьПараметр("ЭквайринговаяОперация", ДокументОплаты);
	Иначе     
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ФильтрВозврата", "ОчередьВозвратов.ДатаПостановки = &ДатаПостановки");
		Запрос.УстановитьПараметр("ДатаПостановки", ДатаПостановки);
	КонецЕсли;                      
	
	МассивЗапросов = Запрос.ВыполнитьПакет();
	ВыборкаОсновная = МассивЗапросов[7].Выбрать();
	
	Если ВыборкаОсновная.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(ОплатаДинамическиеСсылки, ВыборкаОсновная);	   
		
		ВыборкаНеоформленныеВозвратныеЭО = МассивЗапросов[3].Выбрать();
		Пока ВыборкаНеоформленныеВозвратныеЭО.Следующий() Цикл     
			Документ = ПараметрыДокументы();
			ЗаполнитьЗначенияСвойств(Документ, ВыборкаНеоформленныеВозвратныеЭО);
			ОплатаДинамическиеСсылки.НеоформленныеВозвратныеЭО.Добавить(Документ);	
		КонецЦикла;
		
		ВыборкаОформленныеВозвратныеЭО = МассивЗапросов[2].Выбрать();
		Пока ВыборкаОформленныеВозвратныеЭО.Следующий() Цикл     
			Документ = ПараметрыДокументы();
			ЗаполнитьЗначенияСвойств(Документ, ВыборкаОформленныеВозвратныеЭО);
			ОплатаДинамическиеСсылки.ОформленныеВозвратныеЭО.Добавить(Документ);	
		КонецЦикла;
		
		ВыборкаОформленныеРеализации = МассивЗапросов[5].Выбрать();
		Пока ВыборкаОформленныеРеализации.Следующий() Цикл     
			Документ = ПараметрыДокументы();
			ЗаполнитьЗначенияСвойств(Документ, ВыборкаОформленныеРеализации);
			ОплатаДинамическиеСсылки.ОформленныеРеализации.Добавить(Документ);	
		КонецЦикла;
		
	КонецЕсли;
	
	Возврат ОплатаДинамическиеСсылки;
	
КонецФункции	

