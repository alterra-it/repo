#Область ПараметрыДинамическиеСсылки

Функция ПараметрыРегистрацииДинамическиеСсылки(Документ) Экспорт 
		
	Параметры = Новый Структура;
	Параметры.Вставить("Документ",			Документ);
	Параметры.Вставить("ДокументОперации",	Документ);
	Параметры.Вставить("Сумма", 			0);
	Параметры.Вставить("СуммаОперации", 	0);
	Параметры.Вставить("Номер", 			"");
	Параметры.Вставить("Описание", 			"");
	Параметры.Вставить("ОтменаАктивнойСсылки", Истина);
	Возврат Параметры;
	
КонецФункции

