Функция ПараметрыВыполнения(Заголовок = "", Выделить = Ложь) Экспорт 
	
	Дата = ТекущаяДатаСеанса();
		
	Параметры = Новый Структура;
	Параметры.Вставить("Результат", 	Ложь);
	Параметры.Вставить("ДатаНачала", 	Дата);
	Параметры.Вставить("ДатаОкончания");      
	Параметры.Вставить("ДатаОперации");
	Параметры.Вставить("Ответ", 		"");
	Параметры.Вставить("JsonОтвет", 	"");
	Параметры.Вставить("Заголовок", 	Заголовок);
	Параметры.Вставить("Сообщение", 	"");
	Параметры.Вставить("Лог", 
		?(ЗначениеЗаполнено(Заголовок), 
			?(Выделить, ВРег(Заголовок), Заголовок) + Символы.ПС, "") + 
		Строка(Дата) + Символы.ПС + 
		?(Выделить, "-------------------------------------" + Символы.ПС + Символы.ПС, ""));
	Возврат Параметры;
	
КонецФункции

Процедура ЗакрытьПараметрыВыполнения(ПараметрыВыполнения) Экспорт
	
	ПараметрыВыполнения.ДатаОкончания = Строка(ТекущаяДатаСеанса());
	ПараметрыВыполнения.Лог = ПараметрыВыполнения.Лог + 
		?(ЗначениеЗаполнено(ПараметрыВыполнения.JsonОтвет), ПараметрыВыполнения.JsonОтвет + Символы.ПС, "") +
		?(ПараметрыВыполнения.Результат, "Успешное выполнение", "Неуспешное выполнение") + Символы.ПС +
		Строка(ПараметрыВыполнения.ДатаОкончания) + Символы.ПС; 
	
КонецПроцедуры	

#КонецОбласти

#Область Настройки

Функция ПолучитьНастройкиДинамическиеСсылки(Идентификатор = Неопределено) Экспорт
	
	РезультатВыполнения = ПараметрыВыполнения();  
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		Настройки = НастройкиДинамическиеСсылки();	
	Иначе
		Настройки = Новый Соответствие;	 
	КонецЕсли;
	
	ДополнительнаяОбработка = ПолучитьОбработку();
	Если Не ДополнительнаяОбработка.Пустая() Тогда

		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда    
			
			Если НастройкиХранилища.Свойство("НастройкаДинамическиеСсылки") 
				И НастройкиХранилища.НастройкаДинамическиеСсылки.Количество() > 0 Тогда   
				
				Для Каждого СтрокаНастроек Из НастройкиХранилища.НастройкаДинамическиеСсылки Цикл
					
					Если ЗначениеЗаполнено(Идентификатор) И СтрокаНастроек.Идентификатор <> Идентификатор Тогда
						Продолжить;
					КонецЕсли;
					
					Настройка = НастройкиДинамическиеСсылки();	
					
					ЗаполнитьЗначенияСвойств(Настройка, СтрокаНастроек, , "ДокументыАктивации");     
					Настройка.ДокументыАктивации = СтрРазделить(СтрокаНастроек.ДокументыАктивации, ";", Ложь);
					
					Если НастройкиХранилища.Свойство("НастройкаДоступ") Тогда 
						Строка = НастройкиХранилища.НастройкаДоступ.Найти(Настройка.ИдентификаторДоступа, "Идентификатор");
				        Если Строка <> Неопределено Тогда
							ЗаполнитьЗначенияСвойств(Настройка, Строка, , "Идентификатор");     
						КонецЕсли;
					КонецЕсли;	
					
					Если НастройкиХранилища.Свойство("НастройкаБанки") Тогда 
						Строка = НастройкиХранилища.НастройкаБанки.Найти(Настройка.ИдентификаторБанка, "Идентификатор");
				        Если Строка <> Неопределено Тогда
							ЗаполнитьЗначенияСвойств(Настройка, Строка, , "Идентификатор");     
							РезультатВыполнения.Результат = Истина;    
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Настройки динамических ссылок получены");
						КонецЕсли;
					КонецЕсли;					
					
					Если ЗначениеЗаполнено(Идентификатор) Тогда
						ЗаполнитьЗначенияСвойств(Настройки, Настройка);	
					Иначе
						Настройки.Вставить(Настройка.Идентификатор, Настройка) ;	 
					КонецЕсли;

				КонецЦикла;
			КонецЕсли; 

		Иначе
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Сохраненные настройки отсутствуют");
		КонецЕсли;    
	Иначе                                                                                           
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Обработка для определения настроек не найдена");
	КонецЕсли; 
	
	Если Не РезультатВыполнения.Результат Тогда                                                    
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, "По идентификатору ""%1"" настройки не определены", Идентификатор);
	КонецЕсли;
	
	РезультатВыполнения.Ответ = Настройки;
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);  
	
	Возврат РезультатВыполнения;
	
КонецФункции         

Функция ПолучитьПапкуЛоговКолбэков(ИдентификаторБанка = "") Экспорт
	
	РезультатВыполнения = ПараметрыВыполнения();  
	ПапкаЛоговКолбэков = "";
	
	ДополнительнаяОбработка = ПолучитьОбработку();
	Если Не ДополнительнаяОбработка.Пустая() Тогда

		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда    
			
			Если ЗначениеЗаполнено(ИдентификаторБанка) Тогда            
				
				Если НастройкиХранилища.Свойство("НастройкаБанки") Тогда
					Строка = НастройкиХранилища.НастройкаБанки.Найти(ИдентификаторБанка, "Идентификатор");
					
					Если Строка <> Неопределено Тогда
						ПапкаЛоговКолбэков = Строка.ПапкаЛоговКолбэков;

						РезультатВыполнения.Результат = Истина;    
						ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Папка логов колбэков получена");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
			Если Не ЗначениеЗаполнено(ПапкаЛоговКолбэков) И НастройкиХранилища.Свойство("ПапкаЛоговКолбэковПоУмолчанию") Тогда
				ПапкаЛоговКолбэков = НастройкиХранилища.ПапкаЛоговКолбэковПоУмолчанию;
			КонецЕсли;

		Иначе
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Сохраненные настройки отсутствуют");
		КонецЕсли;    
	Иначе                                                                                           
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Обработка для определения настроек не найдена");
	КонецЕсли; 
	
	Если Не РезультатВыполнения.Результат Тогда                                                    
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, "По идентификатору банка ""%1"" папка логов не определена", ИдентификаторБанка);
	КонецЕсли;
	
	РезультатВыполнения.Ответ = ПапкаЛоговКолбэков;
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);   
	
	Возврат РезультатВыполнения;
	
КонецФункции  

Функция ПолучитьОбработку()
	
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", "ИнтеграцияБанки.epf");			
	Возврат ДополнительнаяОбработка;
	
КонецФункции 	 

#КонецОбласти

#Область Логи

Процедура ЗаписатьЛоги(НастройкиДС, ПараметрыВыполнения)
	
	Если ТипЗнч(НастройкиДС) <> Тип("Структура")
		Или ТипЗнч(НастройкиДС) = Тип("Структура") И Не НастройкиДС.Свойство("ПапкаЛогов") 
		Или ТипЗнч(НастройкиДС) = Тип("Структура") И НастройкиДС.Свойство("ПапкаЛогов") И Не ЗначениеЗаполнено(НастройкиДС.ПапкаЛогов) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКаталога = НастройкиДС.ПапкаЛогов + ?(Прав(НастройкиДС.ПапкаЛогов, 1) <> "\", "\", "") + 
		Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=ггггММдд"); 
	
	Попытка 
		КаталогЛогов = Новый Файл(ИмяКаталога);
		Если Не КаталогЛогов.Существует() Тогда
			СоздатьКаталог(ИмяКаталога);
		КонецЕсли;   
		
		Заголовок = СтрЗаменить(СтрЗаменить(СтрЗаменить(ПараметрыВыполнения.Заголовок, " ", "_"), ".", "_"), ":", "_");
		
		ИмяЛога = "log" + "_" + Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=ггггММдд") + "_" + Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=ЧЧммсс") + "_" + 
			Заголовок + ?(Не ПараметрыВыполнения.Результат, "_error", "") + ".txt";   
		
		ФайлЛогов = Новый ЗаписьТекста(ИмяКаталога + "\" + ИмяЛога, КодировкаТекста.UTF8, , Истина);
		ФайлЛогов.ЗаписатьСтроку(ПараметрыВыполнения.Лог);
		ФайлЛогов.Закрыть();

	Исключение
		ФайлЛогов = Неопределено;
	КонецПопытки;    

КонецПроцедуры

Процедура ЗаписатьИнформациюВыполнения(РезультатВыполнения, Сообщение, Лог = "")
	
	РезультатВыполнения.Сообщение = Сообщение;
	РезультатВыполнения.Лог = РезультатВыполнения.Лог + ?(ЗначениеЗаполнено(Лог), Лог, Сообщение) + Символы.ПС;

КонецПроцедуры	

