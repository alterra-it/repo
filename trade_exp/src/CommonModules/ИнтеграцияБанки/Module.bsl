		СтрЗаменить(СтрЗаменить(СтрЗаменить(Формат,
			"%Номер", 		Номер), 
			"%Дата", 		Формат(Дата, "ДФ=дд.ММ.гггг")), 
			"%ТекущаяДата", Формат(ТекущаяДатаСеанса(), "ДФ=дд.ММ.гггг ЧЧ:мм:сс"));
			
