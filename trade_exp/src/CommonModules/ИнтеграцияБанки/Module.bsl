#Область ДинамическиеСсылки

#Область REST

Функция АктивироватьДинамическуюСсылку(Документ, ТипСсылки, Логирование = Истина) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Активация ДС %1", Документ), Логирование);
	
	НастройкиДС = Неопределено;
	СтатусАктивация = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация");
	СтатусОплата = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Оплата");
		
	Попытка
		// Получение настроек
		НастройкиДинамическиеСсылки = ПолучитьНастройкиДинамическиеСсылки(ТипСсылки);
		НастройкиДС = НастройкиДинамическиеСсылки.Ответ;
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, НастройкиДинамическиеСсылки.Сообщение);
		
		Если НастройкиДинамическиеСсылки.Результат Тогда
			
			Если Не НастройкиДС.ССайта Тогда
				
				// Проверка на соответствие типа документа
				МетаданныеДокумента = Метаданные.НайтиПоТипу(ТипЗнч(Документ));
				Если НастройкиДС.ДокументыАктивации.Найти(МетаданныеДокумента.Имя) <> Неопределено Тогда
				
					ПараметрыРегистрацииДС = ПолучениеПараметровРегистрацииДокумента(НастройкиДС, Документ);
					
					// Проверка на статусы Активация и Оплата    
					ПолучениеДС = ПараметрыПолученияДинамическиеСсылки();
					ПолучениеДС.Документ  = Документ;
					ПолучениеДС.ТипСсылки = ТипСсылки;
					ПолучениеДС.Статус.Добавить(СтатусАктивация);
					ПолучениеДС.Статус.Добавить(СтатусОплата);
					
					ПроверкаСтатусаДС = ПроверитьСтатусДинамическойСсылки(ПолучениеДС); 
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаДС.Сообщение);
					
					// Отменить текущую активную ссылку, если у нее сумма не совпадает с суммой документа 
					Если ПроверкаСтатусаДС.Ответ.Количество = 1 И ПроверкаСтатусаДС.Ответ.Статус = СтатусАктивация
						И ПроверкаСтатусаДС.Ответ.Сумма <> ПараметрыРегистрацииДС.Сумма Тогда                           
						
							ПараметрыОтменыДС = ПараметрыПолученияДинамическиеСсылки();
							ПараметрыОтменыДС.ИдентификаторСсылки = ПроверкаСтатусаДС.Ответ.ИдентификаторСсылки;
							ПараметрыОтменыДС.ТипСсылки = ТипСсылки;
						
							ОтменаДС = ОтменитьДинамическуюСсылку(ПараметрыОтменыДС, Ложь);
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, ОтменаДС.Сообщение, ОтменаДС.Лог);
							Если ОтменаДС.Результат Тогда 
								ПроверкаСтатусаДС.Ответ.Количество = 0;
							КонецЕсли;	
					КонецЕсли;
					
					// Нет динамических ссылок на документ 
					Если ПроверкаСтатусаДС.Ответ.Количество = 0 Тогда
					
						// Мможно активировать ненулевую ссылку
						Если ПараметрыРегистрацииДС.Сумма > 0 Тогда 
						
							// Регистрация динамической ссылки
							РегистрацияДС = ЗарегистрироватьДинамическуюСсылку(НастройкиДС, ПараметрыРегистрацииДС);
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, РегистрацияДС.Сообщение, РегистрацияДС.Лог);
							
							Если РегистрацияДС.Результат Тогда
							
								// Заполнение параметров для записи в регистр
								ПараметрыЗаписиДС 			= ПараметрыЗаписиДинамическойСсылки();
								ПараметрыЗаписиДС.ТипСсылки	= ТипСсылки;
								ПараметрыЗаписиДС.Статус	= СтатусАктивация;
								ЗаполнитьЗначенияСвойств(ПараметрыЗаписиДС, НастройкиДС);
								ЗаполнитьЗначенияСвойств(ПараметрыЗаписиДС, ПараметрыРегистрацииДС);
								ЗаполнитьЗначенияСвойств(ПараметрыЗаписиДС, РегистрацияДС.Ответ);
							
								// Получение QR-кода        
								Если Не НастройкиДС.ГенерацияQR Тогда
									
									ПолучениеДС.ИдентификаторСсылки = РегистрацияДС.Ответ.ИдентификаторСсылки;
									ПолучениеQRКода = ПолучитьQRКод(НастройкиДС, ПолучениеДС);
									
									ЗаполнитьЗначенияСвойств(ПараметрыЗаписиДС, ПолучениеQRКода.Ответ);    
									ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПолучениеQRКода.Сообщение, ПолучениеQRКода.Лог);
								КонецЕсли;
								
								Если НастройкиДС.ГенерацияQR Или (Не НастройкиДС.ГенерацияQR И ПолучениеQRКода.Результат) Тогда

									ЗаписьАктивированнойДС = ЗаписатьДинамическуюСсылку(ПараметрыЗаписиДС);
									ЗаписатьИнформациюВыполнения(РезультатВыполнения, ЗаписьАктивированнойДС.Сообщение, ЗаписьАктивированнойДС.Лог);
									
									// Успешное выполнение активации
									Если ЗаписьАктивированнойДС.Результат Тогда
										РезультатВыполнения.Результат = Истина;
										РезультатВыполнения.Ответ = ЗаписьАктивированнойДС.Ответ;
									КонецЕсли;           
									
								Иначе
									ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка не записана в регистр. Генерация QR: %1. %2",  
										НастройкиДС.ГенерацияQR, ?(Не НастройкиДС.ГенерацияQR, ПолучениеQRКода.Сообщение, "")));
								КонецЕсли;      
						КонецЕсли;
						
						// Если сума документа 0 (закрыт заказ), то достаточно отмены без активации
						Иначе
							РезультатВыполнения.Результат = Истина;	
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Динамическая ссылка отменена, новая не активирована из-за нулевой суммы");
						КонецЕсли;
						
					// Новая динамическая ссылка не может быть активирована из-за существования другой такой же активной 
					// Но нужно выдать QR этой текущей активной ссылки
					ИначеЕсли ПроверкаСтатусаДС.Ответ.Количество = 1 И ПроверкаСтатусаДС.Ответ.Статус = СтатусАктивация Тогда

						РезультатВыполнения.Результат = Истина;
						РезультатВыполнения.Ответ = ПроверкаСтатусаДС.Ответ;    
						ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка для документа %1 уже активирована", Документ));
					
					// Динамических ссылок больше одной (некорректная ситуация) или одна, но оплаченная
					Иначе                                 
						ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаДС.Сообщение, ПроверкаСтатусаДС.Лог);
					КонецЕсли;
					
				// Для данной динамической ссылки не предусмотрен это тип документа активации
				Иначе              
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Для документов ""%1"" не применяется %2", МетаданныеДокумента.Синоним, ТипСсылки));
				КонецЕсли;
				
			// Это внешняя динамическая ссылка с сайта, для нее не предусмотрена регистрация
			Иначе              
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Внешняя динамическая сссылка ""%1"" активируется только на сайте", ТипСсылки));
			КонецЕсли
				
		КонецЕсли;
	
	Исключение
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка не активирована: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
	КонецПопытки;
	
	ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка %1", ?(РезультатВыполнения.Результат, "активирована", "не активирована: " + РезультатВыполнения.Сообщение)));
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Если Логирование Тогда
		ЗаписатьЛоги(НастройкиДС, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ОтменитьДинамическуюСсылку(ДинамическаяСсылка, Логирование = Истина) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	НастройкиДС = Неопределено;
	ПараметрыОтменыДС = ПараметрыПолученияДинамическиеСсылки();
	ОпределитьПараметрыДинамическойСсылки(ПараметрыОтменыДС, ДинамическаяСсылка);
	
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Отмена ДС %1", 
		?(ЗначениеЗаполнено(ПараметрыОтменыДС.ИдентификаторСсылки), ПараметрыОтменыДС.ИдентификаторСсылки, 
			?(ЗначениеЗаполнено(ПараметрыОтменыДС.Документ), Строка(ПараметрыОтменыДС.Документ), ПараметрыОтменыДС.Номер))), Логирование);
		
	Попытка
		// Проверка на статус активации
		ПараметрыОтменыДС.Статус.Добавить(ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация"));
		ПроверкаСтатусаДС = ПроверитьСтатусДинамическойСсылки(ПараметрыОтменыДС); 
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаДС.Сообщение);
		
		Если ПроверкаСтатусаДС.Ответ.Количество = 1 Тогда 
		
			// Получение настроек
			НастройкиДинамическиеСсылки = ПолучитьНастройкиДинамическиеСсылки(ПроверкаСтатусаДС.Ответ.ТипСсылки);
			НастройкиДС = НастройкиДинамическиеСсылки.Ответ;                           
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, НастройкиДинамическиеСсылки.Сообщение);
			
			Если НастройкиДинамическиеСсылки.Результат Тогда
				
				// Отмена динамической ссылки
				ОтменаДС = ОтменитьАктивациюДинамическойСсылки(НастройкиДС, ПараметрыОтменыДС);      
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, ОтменаДС.Сообщение);
				
				Если ОтменаДС.Результат Тогда
					
					// Запись в регистр
					ПараметрыИзмененияДС = ПараметрыИзмененияДинамическойСсылки(ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Отмена"), 
						ОтменаДС.Ответ);
					
					ЗаписьОтменыДС = ЗаписатьДинамическуюСсылку(ПроверкаСтатусаДС.Ответ, ПараметрыИзмененияДС);
					
					Если ЗаписьОтменыДС.Результат Тогда
						РезультатВыполнения.Результат = Истина;
					КонецЕсли;   
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, ЗаписьОтменыДС.Сообщение);
				КонецЕсли;
			КонецЕсли
		КонецЕсли; 
	
	Исключение                                                        
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка не отменена: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
	КонецПопытки;

	ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Динамическая ссылка %1", ?(РезультатВыполнения.Результат, "отменена", "не отменена")));	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения); 
	Если Логирование Тогда
		ЗаписатьЛоги(НастройкиДС, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции 

Функция ОбработатьОперациюДинамическойСсылки(ПараметрыОперации, Логирование = Истина) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения("Колбэк ДС", Истина);     
	НастройкиДС = НастройкиДинамическиеСсылки();	
	НастройкиДС.ПапкаЛогов = ПолучитьПапкуЛоговКолбэков(ПараметрыОперации.ИдентификаторБанка).Ответ;
	
	Попытка        
		КолбэкОперации = ПолучитьКолбэкОперации(ПараметрыОперации, ПараметрыОперации);
		ПолучениеДС = КолбэкОперации.Ответ.ПолучениеДС;
		ИзменениеДС = КолбэкОперации.Ответ.ИзменениеДС;   
		
		РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Колбэк ДС %1", ПолучениеДС.ИдентификаторСсылки), Истина);
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, КолбэкОперации.Сообщение);  
		
		Если КолбэкОперации.Результат Тогда
		
			ПолучениеДС.Статус.Добавить(ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация"));
			ПроверкаСтатусаДС = ПроверитьСтатусДинамическойСсылки(ПолучениеДС); 
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаДС.Сообщение); 
			
			ПараметрыДС = ПроверкаСтатусаДС.Ответ;
			Если ПараметрыДС.Количество = 1 Тогда 	
				
				// Получение настроек
				НастройкиДинамическиеСсылки = ПолучитьНастройкиДинамическиеСсылки(ПараметрыДС.ТипСсылки);
				НастройкиДС = НастройкиДинамическиеСсылки.Ответ;
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, НастройкиДинамическиеСсылки.Сообщение);
				
				Если НастройкиДинамическиеСсылки.Результат Тогда
					
					// Для Оплаты и Отмены по таймауту ссылка должна быть активирована (возвраты инициируются пользователями, колбэки пропускаем)
					Если ПараметрыДС.Статус = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация") Тогда
						
						// Сумма операции берется из суммы активации
				    	ИзменениеДС.СуммаОперации = ПараметрыДС.Сумма;   
			
						НачатьТранзакцию();
						Попытка                                           
							
							ЗаписьОплатыДС = ЗаписатьДинамическуюСсылку(ПараметрыДС, ИзменениеДС);
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, ЗаписьОплатыДС.Сообщение);
							
							// Успешный результат при записи отмены по таймауту
							РезультатВыполнения.Результат = ЗаписьОплатыДС.Результат И ИзменениеДС.Статус = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.ИстекСрокДействия");  
							
							// Постановка в очередь к пробитию оплаченной ссылки
							Если ЗаписьОплатыДС.Результат И ИзменениеДС.Статус = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Оплата") Тогда       
									
								ПараметрыЗаписиДС = ЗаписьОплатыДС.Ответ;
								
								// Получение типа оплаты: СБП или карта    
								СостояниеДС = ПолучитьСостояниеДинамическойСсылки(НастройкиДС, ПолучениеДС);
								
								ПараметрыЗаписиВОчередь = ДопМодульСервер.ПараметрыЗаписиВОчередь();                       
								ПараметрыЗаписиВОчередь.ТипСсылки 				= ПараметрыЗаписиДС.ТипСсылки;
								ПараметрыЗаписиВОчередь.ДинамическаяСсылка		= ПараметрыЗаписиДС.ИдентификаторСсылки;
								ПараметрыЗаписиВОчередь.Касса 					= НастройкиДС.ККТ;
								ПараметрыЗаписиВОчередь.ДатаПостановки			= ПараметрыЗаписиДС.ДатаОперации;
								ПараметрыЗаписиВОчередь.ЗаказКлиента			= ПараметрыЗаписиДС.ДокументОперации;
								ПараметрыЗаписиВОчередь.СуммаОплаты				= ПараметрыЗаписиДС.СуммаОперации;
								ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал	= ?(СостояниеДС.Ответ.СБП, НастройкиДС.ЭквайринговыйТерминалСБП, НастройкиДС.ЭквайринговыйТерминалКарта);
								
								ЗаписьВОчередьКПробитию = ДопМодульСервер.ЗаписатьВОчередьКПробитию(ПараметрыЗаписиВОчередь);
									
								РезультатВыполнения.Результат = ЗаписьВОчередьКПробитию.Результат;
								ЗаписатьИнформациюВыполнения(РезультатВыполнения, ЗаписьВОчередьКПробитию.Сообщение);
								
							КонецЕсли;                                                                               
							
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Колбэк динамической ссылки %1 обработан %2успешно", 
							ПолучениеДС.ИдентификаторСсылки, ?(РезультатВыполнения.Результат, "", "не ")));
						
							ЗафиксироватьТранзакцию(); 
						Исключение         
							ОтменитьТранзакцию();  
						КонецПопытки;

						// Сразу пробить чек
						Попытка
							ДопМодульСервер.ВыполнитьПробитиеЧека(ПараметрыЗаписиДС.ДатаОперации, ПроверкаСтатусаДС.Ответ.Документ);
						Исключение
						КонецПопытки;
						
					КонецЕсли;    
				КонецЕсли;
			КонецЕсли;
		Иначе
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Колбэк операции не обработан");  
		КонецЕсли;
			
	Исключение                                                                                         
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Колбэк операции не обработан: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));  
	КонецПопытки;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);       
	Если Логирование Тогда
		ЗаписатьЛоги(НастройкиДС, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПроверитьСостояниеДинамическойСсылки(ТипСсылки, ДинамическаяСсылка, Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Проверка состояния ДС %1", Строка(ДинамическаяСсылка)), Истина);
	
	НастройкиДС = Неопределено;
	ПараметрыПолученияДС = ПараметрыПолученияДинамическиеСсылки();
	ОпределитьПараметрыДинамическойСсылки(ПараметрыПолученияДС, ДинамическаяСсылка);
		
	Попытка     
		Если ТипСсылки = ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт") Тогда
			// Проверка на наличие в очереди
			ПроверкаДС = ПроверитьОчередьДинамическойСсылки(ПараметрыПолученияДС);  

		Иначе		
			// Проверка на статус оплаты
			ПараметрыПолученияДС.Статус.Добавить(ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Оплата"));
			ПроверкаДС = ПроверитьСтатусДинамическойСсылки(ПараметрыПолученияДС); 
		КонецЕсли;                                                                                            
		
		РезультатВыполнения.Ответ = ПараметрыСостоянияДинамическиеСсылки();
		ЗаполнитьЗначенияСвойств(РезультатВыполнения.Ответ, ПроверкаДС.Ответ);
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаДС.Сообщение);
		
		Если ПроверкаДС.Ответ.Количество = 1 Тогда 
		
			// Получение настроек
			НастройкиДинамическиеСсылки = ПолучитьНастройкиДинамическиеСсылки(ТипСсылки);
			НастройкиДС = НастройкиДинамическиеСсылки.Ответ;
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, НастройкиДинамическиеСсылки.Сообщение);
			
			Если НастройкиДинамическиеСсылки.Результат Тогда
				
				// Получение состояния динамической ссылки
				ЗаполнитьЗначенияСвойств(ПараметрыПолученияДС, ПроверкаДС.Ответ);    
				
				ПолучениеСостоянияДС = ПолучитьСостояниеДинамическойСсылки(НастройкиДС, ПараметрыПолученияДС);
				ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПолучениеСостоянияДС.Сообщение);
				
				Если ПолучениеСостоянияДС.Результат Тогда                                         
					РезультатВыполнения.Результат = Истина;   
					ЗаполнитьЗначенияСвойств(РезультатВыполнения.Ответ, ПолучениеСостоянияДС.Ответ, "Сумма, СБП");                       
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Состояние динамической ссылки на сумму %1 ₽ получено", ПолучениеСостоянияДС.Ответ.Сумма));
				КонецЕсли;
			КонецЕсли
		КонецЕсли; 
	
	Исключение                                                                                    
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Состояние динамической ссылки не получено: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
	КонецПопытки;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);      
	Если Логирование Тогда
		ЗаписатьЛоги(НастройкиДС, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ВыполнитьВозвратДинамическойСсылки(ДокументОснование, ДокументВозврата, СуммаВозврата, 
		ДокументОплаты = Неопределено, ЭквайринговыйТерминалОплаты = Неопределено, Логирование = Истина) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Возврат ДС %1", Строка(ДокументОснование)), Логирование);   
	
	НастройкиДС = Неопределено;
	ДатаОперации = Неопределено;
	ПараметрыЗапросаВозвратаДС = ПараметрыСостоянияДинамическиеСсылки();
	ОпределитьПараметрыДинамическойСсылки(ПараметрыЗапросаВозвратаДС, ДокументОснование);
	ПараметрыЗапросаВозвратаДС.Сумма = СуммаВозврата;
	
	СтатусОплата = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Оплата");
	СтатусВозврат = ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Возврат");
		
	Попытка
		// Проверка суммы возврата с учетом возвратов и документов реализаций
		ОплатаСучетомДокументов = ПолучитьОплатуДинамическойСсылки(ДокументВозврата, ДокументОплаты);
		
		Если ОплатаСучетомДокументов.СуммаДокументаВозврата < СуммаВозврата Тогда      
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Сумма возврата %1 ₽ не может быть больше остатка суммы от оплаты %2 ₽", СуммаВозврата, ОплатаСучетомДокументов.СуммаДокументаВозврата));

		Иначе
			// Проверка суммы возврата оплат-возвратов только по динамической ссылке           
			ТипСсылки = ОплатаСучетомДокументов.ТипСсылки;
	 		ПараметрыВозвратаДС = ПолучитьПараметрыВозвратаДинамическойСсылки(ТипСсылки, ДокументОснование);   
			ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПараметрыВозвратаДС.Сообщение);
			
			Если ПараметрыВозвратаДС.Результат Тогда                   
				
				Если СуммаВозврата > ПараметрыВозвратаДС.Ответ.Сумма Тогда      
					ПараметрыВозвратаДС.Результат = Ложь;                                    
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Сумма возврата %1 ₽ не может быть больше остатка суммы оплаты %2 ₽", СуммаВозврата, ПараметрыВозвратаДС.Ответ.Сумма));
		 		
				ИначеЕсли СуммаВозврата <= 0 Тогда       
					ПараметрыВозвратаДС.Результат = Ложь;                                    
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Сумма возврата %1 ₽ должна быть больше нуля", СуммаВозврата));
		 		КонецЕсли;
		 		
				Если Не ЗначениеЗаполнено(ДокументВозврата) Тогда
					ПараметрыВозвратаДС.Результат = Ложь;                                    
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Не определен документ возврата");
		 		КонецЕсли;
			  
		 		Если ПараметрыВозвратаДС.Результат Тогда		
				
					// Получение настроек
					НастройкиДинамическиеСсылки = ПолучитьНастройкиДинамическиеСсылки(ТипСсылки);
					НастройкиДС = НастройкиДинамическиеСсылки.Ответ;                                    
					ЗаписатьИнформациюВыполнения(РезультатВыполнения, НастройкиДинамическиеСсылки.Сообщение);
					
					Если НастройкиДинамическиеСсылки.Результат Тогда
						
						// Выполнение возврата динамической ссылки                                     
						ЗаполнитьЗначенияСвойств(ПараметрыЗапросаВозвратаДС, ПараметрыВозвратаДС.Ответ, , "Сумма");
						
						ВыполнениеВозвратаДС = ВыполнитьВозвратПоОплатеДинамическойСсылки(НастройкиДС, ПараметрыЗапросаВозвратаДС);
						ЗаписатьИнформациюВыполнения(РезультатВыполнения, ВыполнениеВозвратаДС.Сообщение);
						
						Если ВыполнениеВозвратаДС.Результат Тогда
							
							ДатаОперации = ТекущаяДатаСеанса();
							ЗаписьВОчередьКПробитию = Неопределено;
							
							НачатьТранзакцию();
							Попытка      
								ПоставитьВОчередьКПробитию = Ложь;      
								
								// Сайт
								Если ТипСсылки = ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт") Тогда
									ПоставитьВОчередьКПробитию = Истина;      
								
								// Динамические ссылки 
								Иначе
									// 1. Регистр ДС: Запись измененной оплаченной динамической ссылки
									// Получить изменяемую оплаченную динамическую ссылку          
									ПроверкаСтатусаДС = ПараметрыПолученияДинамическиеССылки();
									ЗаполнитьЗначенияСвойств(ПроверкаСтатусаДС, ПараметрыВозвратаДС.Ответ, "ИдентификаторСсылки");
									ПроверкаСтатусаДС.Статус.Добавить(СтатусОплата);                       
									
									ПроверкаСтатусаДС = ПроверитьСтатусДинамическойСсылки(ПроверкаСтатусаДС);  
									ЗаписатьИнформациюВыполнения(РезультатВыполнения, ПроверкаСтатусаДС.Сообщение);
									
									Если ПроверкаСтатусаДС.Ответ.Количество = 1 Тогда
										
										// Новые данные с учетом возврата оплаченой динамической ссылки
										НоваяСумма = ПроверкаСтатусаДС.Ответ.Сумма - СуммаВозврата;
										НовыйСтатус = СтатусОплата;
									
										ПараметрыИзмененияОплаченнойДС = ПараметрыИзмененияПриВозвратеДинамическойСсылки(
											НовыйСтатус, ДатаОперации, НоваяСумма, ДокументВозврата);
										
										ЗаписьОплаченнойДС = ЗаписатьДинамическуюСсылку(ПроверкаСтатусаДС.Ответ, ПараметрыИзмененияОплаченнойДС);    
										ЗаписатьИнформациюВыполнения(РезультатВыполнения, ЗаписьОплаченнойДС.Сообщение);
										
										// 2. Регистр ДС: Запись отдельной строкой операции возврата динамической ссылки
										ПараметрыОперацииВозвратаДС = ПараметрыЗаписиДинамическойСсылки();
										ЗаполнитьЗначенияСвойств(ПараметрыОперацииВозвратаДС, ПроверкаСтатусаДС.Ответ, "ТипСсылки, ИдентификаторСсылки, Банк, Документ");
										ПараметрыОперацииВозвратаДС.ДокументОперации 	= ДокументВозврата;
										ПараметрыОперацииВозвратаДС.Дата 				= ДатаОперации;				
										ПараметрыОперацииВозвратаДС.ДатаОперации 		= ДатаОперации;
										ПараметрыОперацииВозвратаДС.Сумма 				= СуммаВозврата;
										ПараметрыОперацииВозвратаДС.СуммаОперации 		= -СуммаВозврата;
										ПараметрыОперацииВозвратаДС.Статус 				= СтатусВозврат;
										ПараметрыОперацииВозвратаДС.Возврат 			= Истина;
										
										ЗаписьВозвратаДС = ЗаписатьДинамическуюСсылку(ПараметрыОперацииВозвратаДС);      
										ЗаписатьИнформациюВыполнения(РезультатВыполнения, ЗаписьОплаченнойДС.Сообщение);
										
										Если ЗаписьОплаченнойДС.Результат И ЗаписьВозвратаДС.Результат Тогда
											ПоставитьВОчередьКПробитию = Истина;       
										КонецЕсли;
									КонецЕсли;
								КонецЕсли;
								
								// Постановка в очередь
								Если ПоставитьВОчередьКПробитию Тогда;    

									ПараметрыЗаписиВОчередь = ДопМодульСервер.ПараметрыЗаписиВОчередь();  
									ЗаполнитьЗначенияСвойств(ПараметрыЗаписиВОчередь, ОплатаСучетомДокументов);  
									ПараметрыЗаписиВОчередь.ДатаПостановки 			= ДатаОперации;
									ПараметрыЗаписиВОчередь.ЗаказКлиента 			= ДокументВозврата;
									ПараметрыЗаписиВОчередь.ЭквайринговаяОперация 	= ДокументОплаты; 
									ПараметрыЗаписиВОчередь.СуммаОплаты				= СуммаВозврата;
									ПараметрыЗаписиВОчередь.Возврат 				= Истина;
									 
									Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") 
										И ЗначениеЗаполнено(ДокументОплаты.ЭквайринговыйТерминал) Тогда
										ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал = ДокументОплаты.ЭквайринговыйТерминал
									ИначеЕсли ЗначениеЗаполнено(ЭквайринговыйТерминалОплаты) Тогда
										ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал = ЭквайринговыйТерминалОплаты
									ИначеЕсли ПараметрыВозвратаДС.Ответ.СБП Тогда
										ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал = НастройкиДС.ЭквайринговыйТерминалСБП;
									Иначе
										ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал = НастройкиДС.ЭквайринговыйТерминалКарта;
									КонецЕсли;

									ЗаписьВОчередьКПробитию = ДопМодульСервер.ЗаписатьВОчередьКПробитию(ПараметрыЗаписиВОчередь);
								
									Если ЗаписьВОчередьКПробитию.Результат Тогда
										РезультатВыполнения.Результат = Истина; 
										РезультатВыполнения.ДатаОперации = ДатаОперации;
									КонецЕсли;
								КонецЕсли;
								
								ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Возврат " + ?(РезультатВыполнения.Результат, "выполнен", "не выполнен"));
							
								ЗафиксироватьТранзакцию(); 
								                                                                              
							Исключение         
								ОтменитьТранзакцию();  
							КонецПопытки;
			
							// Сразу пробить чек
							Если ТипЗнч(ЗаписьВОчередьКПробитию) = Тип("Структура") И ЗаписьВОчередьКПробитию.Результат Тогда
								Попытка
									ДопМодульСервер.ВыполнитьПробитиеЧека(ДатаОперации, ДокументВозврата);    
									ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Чек возврата по ДС сразу пробит");
								Исключение                                                                               
									ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Чек возврата по ДС сразу не пробит: %1", КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
								КонецПопытки;
							КонецЕсли;
							
							ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтрШаблон("Выполнен возврат на сумму %1 ₽", СуммаВозврата));
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	
	Исключение              
		ЗаписатьИнформациюВыполнения(РезультатВыполнения, "Не выполнен возврат по динамической ссылке: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Если Логирование Тогда
		ЗаписатьЛоги(НастройкиДС, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьСтатистикуДинамическихСсылок(НастройкиДС, ПараметрыСтатистикиДС, ОтборПоНомеру = "", Логирование = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения(СтрШаблон("Получение статистики динамических ссылок за период с %1 по %2", 
		ПараметрыСтатистикиДС.ДатаНачала, ПараметрыСтатистикиДС.ДатаОкончания), Истина);
	
	СтатистикаЗаПериод = ПолучитьСтатистикуЗаПериодДинамическихСсылок(НастройкиДС, ПараметрыСтатистикиДС);
	
	РезультатВыполнения.Результат = СтатистикаЗаПериод.Результат;
	РезультатВыполнения.Ответ = СтатистикаЗаПериод.Ответ;           
	ЗаписатьИнформациюВыполнения(РезультатВыполнения, СтатистикаЗаПериод.Сообщение);

	Если ЗначениеЗаполнено(ОтборПоНомеру) Тогда
		
		СписокЗаказов = РезультатВыполнения.Ответ;
		
		НайденныйЗаказ = Неопределено;
		Для Каждого Заказ Из СписокЗаказов Цикл 
			
			Если Заказ.Номер = ОтборПоНомеру Тогда
				НайденныйЗаказ = Заказ;
				Прервать;	
			КонецЕсли;
		
		КонецЦикла;
		
		РезультатВыполнения.Результат = ЗначениеЗаполнено(НайденныйЗаказ);
		РезультатВыполнения.Ответ = НайденныйЗаказ;

	КонецЕсли;
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);  
	Если Логирование Тогда
