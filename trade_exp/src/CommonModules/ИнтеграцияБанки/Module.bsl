Функция ПараметрыИзмененияДинамическойСсылки(Статус = Неопределено, ДатаОперации = Неопределено, СуммаОперации = 0) Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("Статус", 		Статус);
	Параметры.Вставить("ДатаОперации", 	?(ЗначениеЗаполнено(ДатаОперации), ДатаОперации, ТекущаяДатаСеанса()));
	Параметры.Вставить("СуммаОперации", СуммаОперации);
	Возврат Параметры;
	
