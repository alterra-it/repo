#Область Настройки

Функция ПолучитьМетодДоставки(Рейс)
	
	ЗапросСклад = Новый Запрос;
	ЗапросСклад.Текст =
		"ВЫБРАТЬ 
		|	УникальныйИдентификатор(СтруктураПредприятия.СкладПоУмолчанию) КАК GUIDСклада
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс КАК Рейс   
		|	СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ПО Рейс.Подразделение = СтруктураПредприятия.Ссылка
		|ГДЕ 
		|	Рейс.Ссылка = &Рейс
		|	И НАЧАЛОПЕРИОДА(Рейс.ВремяВыезда, ДЕНЬ) = НАЧАЛОПЕРИОДА(&ТекДата, ДЕНЬ)";
	
	ЗапросСклад.УстановитьПараметр("Рейс", Рейс);
	ЗапросСклад.УстановитьПараметр("ТекДата", ТекущаяДатаСеанса());
	ВыборкаСклад = ЗапросСклад.Выполнить().Выбрать();

	Если ВыборкаСклад.Следующий() Тогда
		
		ЗапросМетодДоставки = Новый Запрос;
		ЗапросМетодДоставки.Текст = 
			"ВЫБРАТЬ 
			|	МетодыДоставки.Код КАК МетодДоставки
			|ИЗ 
			|	Справочник.Ozon_Склады КАК Склады
			|	СОЕДИНЕНИЕ Справочник.Ozon_СсылкиНаСправочники КАК СсылкиНаСправочники
			|		ПО Склады.СсылкаНаСклад = СсылкиНаСправочники.Ссылка                               
			|		И СсылкиНаСправочники.GUID = &GUIDСклада		                                
			|	СОЕДИНЕНИЕ Справочник.Ozon_МетодыДоставки КАК МетодыДоставки		
			|		ПО Склады.Ссылка = МетодыДоставки.Владелец";
			 
		ЗапросМетодДоставки.УстановитьПараметр("GUIDСклада", Строка(ВыборкаСклад.GUIDСклада));
		ВыборкаМетодДоставки = ЗапросМетодДоставки.Выполнить().Выбрать();

		Если ВыборкаМетодДоставки.Следующий() Тогда
			
			Возврат ВыборкаМетодДоставки.МетодДоставки;
		КонецЕсли;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции	

