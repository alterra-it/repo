Функция ПолучитьНастройкиАвторизации()
	
	ПараметрыыАвторизации = ПараметрыАвторизации();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Ozon_Константы.Значение КАК АдресСервера,
		|	Ozon_Аккаунты.ClientId КАК ClientId,
		|	Ozon_Аккаунты.ApiKey КАК ApiKey
		|ИЗ
		|	Справочник.Ozon_Аккаунты КАК Ozon_Аккаунты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Ozon_Константы КАК Ozon_Константы
		|			ПО ИСТИНА
		|ГДЕ
		|	Ozon_Аккаунты.Ссылка = &Аккаунт
		|	И Ozon_Константы.Константа = &Константа";
	
	Запрос.УстановитьПараметр("Аккаунт", Справочники.Ozon_Аккаунты.НайтиПоНаименованию("Альтерра ООО"));
	Запрос.УстановитьПараметр("Константа", ПредопределенноеЗначение("Перечисление.Ozon_Константы.АдресСервера"));
		
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ПараметрыыАвторизации, Выборка);
		ПараметрыыАвторизации.ClientId = Формат(ПараметрыыАвторизации.ClientId, "ЧГ=");
	КонецЕсли;
	
	
	Возврат ПараметрыыАвторизации;
	
КонецФункции

