#Область Дополнительно

Функция ПолучитьТекстОшибки(ОтветСоответствие)
	
	ТекстОшибки = "";

	// Общее сообщение об ошибкке
	Если ЗначениеЗаполнено(ОтветСоответствие.Получить("message")) Тогда
		ТекстОшибки = ОтветСоответствие.Получить("message");
	КонецЕсли;
	
	// Переписать общее сообщение об ошибкке детальным
	Если ЗначениеЗаполнено(ОтветСоответствие.Получить("details")) 
		И ТипЗнч(ОтветСоответствие.Получить("details")) = Тип("Массив") Тогда
			
		ДетальныеСообщения = ""; 
		Для Каждого Сообщение Из ОтветСоответствие.Получить("details") Цикл
			Если ТипЗнч(Сообщение) = Тип("Соответствие") И ЗначениеЗаполнено(Сообщение.Получить("message")) Тогда
				ДетальныеСообщения = ДетальныеСообщения + Сообщение.Получить("message") + " ";
			КонецЕсли;							 
		КонецЦикла;	
																					
		ТекстОшибки = ?(ЗначениеЗаполнено(ДетальныеСообщения), ДетальныеСообщения, ТекстОшибки);																			
	КонецЕсли; 

	Возврат ТекстОшибки;
	
Конецфункции

Функция СформироватьЛог(РезультатВыполненияRest)
	
	Лог = РезультатВыполненияRest.Сообщение + Символы.ПС + 
		РезультатВыполненияRest.Метод + Символы.ПС + 
		"Тело:" + Символы.ПС + РезультатВыполненияRest.Тело + Символы.ПС + 
		?(ТипЗнч(РезультатВыполненияRest.JSONОтвет) = Тип("Строка"), 
			"Ответ:" + Символы.ПС + РезультатВыполненияRest.JSONОтвет + Символы.ПС, "");

	Возврат Лог;
	
Конецфункции		

