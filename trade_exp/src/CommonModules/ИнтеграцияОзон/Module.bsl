#Область Отгрузки

Функция СформироватьОтгрузку(Рейс, ВозвратТовара) Экспорт

	ПараметрыОтгрузки = ПараметрыПолученияОтгрузки();
	НастройкиАвторизации = ПолучитьНастройкиАвторизации();
	
	МетодДоставки = ПолучитьМетодДоставки(Рейс);
	Если ЗначениеЗаполнено(МетодДоставки) Тогда
		
		СозданиеОтгрузки = ?(Не ВозвратТовара, СоздатьОтгрузку(НастройкиАвторизации, МетодДоставки), 
			ПолучитьВозвраты(НастройкиАвторизации));
		
		ПараметрыОтгрузки.Результат = СозданиеОтгрузки.Результат;
		ПараметрыОтгрузки.Отгрузка = СозданиеОтгрузки.Отгрузка;
		ПараметрыОтгрузки.Сообщение = ПараметрыОтгрузки.Сообщение + СозданиеОтгрузки.Сообщение;
		ПараметрыОтгрузки.Лог = ПараметрыОтгрузки.Лог + СформироватьЛог(СозданиеОтгрузки);
		
		Если ПараметрыОтгрузки.Результат Тогда
			
			Таймаут = 3;
			// Несколько попыток получения ШК через таймауты (создание отгрузки требует времени)
			Для Счетчик = 1 По 3 Цикл
				Б_ОбменССайтомСервер.Таймаут(Таймаут);
				
				ПолучениеШтрихкода = ?(Не ВозвратТовара, ПолучитьШтрихкодОтгрузки(НастройкиАвторизации, ПараметрыОтгрузки.Отгрузка),
					ПолучитьШтрихкодВозврата(НастройкиАвторизации));	
				
				ПараметрыОтгрузки.Результат = ПолучениеШтрихкода.Результат;
				ПараметрыОтгрузки.Штрихкод = ПолучениеШтрихкода.Штрихкод;
				ПопыткаПробития = ?(Счетчик > 1, СтрШаблон("Попытка получения штрихкода отгрузки %1", Счетчик) + Символы.ПС, "");
				ПараметрыОтгрузки.Сообщение = ПараметрыОтгрузки.Сообщение + Символы.ПС + ПопыткаПробития + ПолучениеШтрихкода.Сообщение;
				ПараметрыОтгрузки.Лог = ПараметрыОтгрузки.Лог + ПопыткаПробития + СформироватьЛог(ПолучениеШтрихкода);
			
				Если ПараметрыОтгрузки.Результат Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	Иначе
		ПараметрыОтгрузки.Сообщение = "Не определен метод доставки. Возможно, нет рейса Озон с временем выезда сегодняшней датой.";
		ПараметрыОтгрузки.Лог = ПараметрыОтгрузки.Сообщение + Символы.ПС; 	
	КонецЕсли;
	
	Возврат ПараметрыОтгрузки;
	
КонецФункции

Функция СоздатьОтгрузку(НастройкиАвторизации, МетодДоставки)
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = 		НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод = 		"/v2/posting/fbs/act/create";
	ПараметрыRest.ТипМетода = 	"POST";
	
	ПараметрыRest.Заголовки = 	ПолучитьЗаголовкиАвторизации(НастройкиАвторизации);
	ПараметрыRest.Тело = Новый Структура("delivery_method_id", МетодДоставки); 
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	RestЗапрос.Вставить("Отгрузка", "");
	
	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("result") 
			И RestЗапрос.ОтветСтруктура.result.Свойство("id") 
			И RestЗапрос.ОтветСтруктура.result.id > 0 Тогда
				
				RestЗапрос.Результат = Истина;
				RestЗапрос.Отгрузка = RestЗапрос.ОтветСтруктура.result.id;
				RestЗапрос.Сообщение = СтрШаблон("Создана отгрузка %1", RestЗапрос.Отгрузка);				
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСоответствие);
		КонецЕсли;

	КонецЕсли;
	
	Возврат RestЗапрос;	
	
КонецФункции

Функция ПолучитьВозвраты(НастройкиАвторизации)
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = 		НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод = 		"/v1/returns/company/fbs/info";
	ПараметрыRest.ТипМетода = 	"POST";
	
	ПараметрыRest.Заголовки = 	ПолучитьЗаголовкиАвторизации(НастройкиАвторизации);
	ПараметрыRest.Тело = Новый Структура("pagination", 
							Новый Структура("last_id, limit", 500, 500)); 
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	// Для тестов
	//RestЗапрос = МокВозврат();
	
	RestЗапрос.Вставить("Отгрузка", "");
	
	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("drop_off_points") 
			И ТипЗнч(RestЗапрос.ОтветСтруктура.drop_off_points) = Тип("Массив") 
			И RestЗапрос.ОтветСтруктура.drop_off_points.Количество() > 0 
			И RestЗапрос.ОтветСтруктура.drop_off_points[0].Свойство("id")
			И RestЗапрос.ОтветСтруктура.drop_off_points[0].id > 0 Тогда
				
				RestЗапрос.Результат = Истина;
				RestЗапрос.Отгрузка = RestЗапрос.ОтветСтруктура.drop_off_points[0].id;
				RestЗапрос.Сообщение = СтрШаблон("Создана отгрузка %1", RestЗапрос.Отгрузка);				
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСоответствие);
		КонецЕсли;

	КонецЕсли;
	
	Возврат RestЗапрос;	
	
КонецФункции		
	
