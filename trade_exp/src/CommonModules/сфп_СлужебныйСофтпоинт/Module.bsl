Функция PerfExpert_УзнатьПараметрыПодключения() экспорт

	Настройки = ХранилищеСистемныхНастроек.Загрузить("Общее/НастройкиКлиентскогоПриложения");

	возврат новый структура
	(
		"Пользователь, Сеанс, РежимСовместимости, РежимСовместимостиИнтерфейса, РежимОткрытияФормПриложения, ВариантИнтерфейсаКлиентскогоПриложения",
		ИмяПользователя(),
		НомерСеансаИнформационнойБазы(),
	    Строка(Метаданные.РежимСовместимости),
		Строка(Метаданные.РежимСовместимостиИнтерфейса),
		Строка(Настройки.РежимОткрытияФормПриложения),
		Строка(Настройки.ВариантИнтерфейсаКлиентскогоПриложения)
	);
	
КонецФункции