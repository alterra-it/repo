#Область ПодпискаНаСобытие
Процедура ОбменСМобильнымПриложениемВодителйПроведениеОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	ТипОбъекта = ТипЗнч(Источник);
	
	Если ТипОбъекта = Тип("ДокументОбъект.ЗаданиеНаПеревозкуРейс") Тогда
		Если ЗначениеЗаполнено(Источник.Водитель) Тогда
			УзелВодителя= ПланыОбмена.МобильноеПриложениеВодителей.ПолучитьУзелВодителя(Источник.Водитель);
			
			Если ЗначениеЗаполнено(УзелВодителя) Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(УзелВодителя, Источник.Ссылка);
				
				Для Каждого Основание Из Источник.Основания Цикл
					ПланыОбмена.ЗарегистрироватьИзменения(УзелВодителя, Основание.Документ);	
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбменСМобильнымПриложениемВодителйЗаписьПриЗаписи(Источник, Отказ, Замещение) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	ТипОбъекта = ТипЗнч(Источник);
	
	Если ТипОбъекта = Тип("РегистрСведенийНаборЗаписей.СтатусыВодителей") Тогда
		Водитель= Неопределено;
		Для Каждого Отбор Из Источник.Отбор Цикл
			Если Отбор.ПутьКДанным = "Водитель" Тогда
				Водитель=  Отбор.Значение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(Водитель) Тогда
			УзелВодителя= ПланыОбмена.МобильноеПриложениеВодителей.ПолучитьУзелВодителя(Водитель);
			
			Если ЗначениеЗаполнено(УзелВодителя) Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(УзелВодителя, Источник);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбменСМобильнымПриложениемВодителейУдалениеОбработкаУдаленияПроведения(Источник, Отказ) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	ТипОбъекта = ТипЗнч(Источник);
	Если ТипОбъекта = Тип("ДокументОбъект.ЗаданиеНаПеревозкуРейс") Тогда
		Если ЗначениеЗаполнено(Источник.Водитель) Тогда
			УзелВодителя= ПланыОбмена.МобильноеПриложениеВодителей.ПолучитьУзелВодителя(Источник.Водитель);
			Если ЗначениеЗаполнено(УзелВодителя) Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(УзелВодителя, Источник.Ссылка);
				Для Каждого Основание Из Источник.Основания Цикл
					ПланыОбмена.ЗарегистрироватьИзменения(УзелВодителя, Основание.Документ);	
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли ТипОбъекта = Тип("ДокументОбъект.ЗаказНаДоставкуКлиенту") Тогда
		//найти рейс
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсОснования.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейсОснования.Документ = &Документ
		|	И ЗаданиеНаПеревозкуРейсОснования.Ссылка.Проведен = ИСТИНА
		|	И ЗаданиеНаПеревозкуРейсОснования.Ссылка.ПометкаУдаления = ЛОЖЬ";
		Запрос.УстановитьПараметр("Документ", Источник.Ссылка);		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Рейс = Неопределено;
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			 Рейс = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЕсли;
		
		Если Рейс<>Неопределено Тогда
			//найти водителя
			УзелВодителя= ПланыОбмена.МобильноеПриложениеВодителей.ПолучитьУзелВодителя(Рейс.Водитель);
			//зарегистрировать изменения
			Если ЗначениеЗаполнено(УзелВодителя) Тогда
				ПланыОбмена.ЗарегистрироватьИзменения(УзелВодителя, Источник.Ссылка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ЗаписьОшибок

Процедура ЗарегестрироватьОшибку(Сотрудник, Текст, ОписаниеОшибки="") Экспорт
	ТипСообщения= Перечисления.ТипыСообщенийМобильногоПриложения.Ошибка;
	
	ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , , Текст);
	
	ДобавитьЗаписьВЖурнал(Сотрудник, ТипСообщения, Текст, ОписаниеОшибки);
КонецПроцедуры

Процедура ЗарегестрироватьИнформацию(Сотрудник, Текст) Экспорт
	ТипСообщения= Перечисления.ТипыСообщенийМобильногоПриложения.Информация;
	
	ДобавитьЗаписьВЖурнал(Сотрудник, ТипСообщения, Текст)
КонецПроцедуры

Процедура ДобавитьЗаписьВЖурнал(Водитель, ТипСообщения, Текст, ОписаниеОшибки="")
	ГСЧ= Новый ГенераторСлучайныхЧисел;
	Версия= ГСЧ.СлучайноеЧисло(0, 999);
	
	Если ТипЗнч(Водитель) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Сотрудник = АльтерраОбщегоНазначения.ПолучитьСотрудникаПоФизЛицу(Водитель);
	Иначе
		Сотрудник = Водитель;
	КонецЕсли;
	
	Попытка
		НоваяЗапись = РегистрыСведений.ЖурналРаботыМобильногоУстройства.СоздатьМенеджерЗаписи();
		НоваяЗапись.Сотрудник= Сотрудник;
		НоваяЗапись.Период = ТекущаяДата();
		НоваяЗапись.ТипСообщения = ТипСообщения;
		НоваяЗапись.Текст = "ЦБ: "+Текст;
		НоваяЗапись.ОписаниеОшибки = ОписаниеОшибки;
		НоваяЗапись.Версия= Версия;
		НоваяЗапись.Записать();
	Исключение
		ЗаписьЖурналаРегистрации("МобильноеПриложениеВодителей", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось записать ошибку ЦБ. " + ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры

#КонецОбласти