

//Заполняет регистр сведений объектами, вошедшими в сегмент.
//
// Параметры:
//   СегментСсылка - СправочникСсылка.СегментыПартнеров, СправочникСсылка.СегментыНоменклатуры - сегмент, элементы входящие в который получаются.
//
Процедура Сформировать(ПоказательСсылка) Экспорт

	ПР = ПривилегированныйРежим();
	Если НЕ ПР Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Если ТипЗнч(ПоказательСсылка) = Тип("СправочникСсылка.оп_ПоказателиРасчета") Тогда
		ПараметрыРасчета = Новый Структура("Показатель",ПоказательСсылка);
		Справочники.оп_ПоказателиРасчета.РассчитатьПоказатель(ПараметрыРасчета);		
	КонецЕсли;

	Если НЕ ПР Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;

КонецПроцедуры

//Удаляет из регистра сведений записи, относящиеся к сегменту
//
// Параметры:
//   СегментСсылка - СправочникСсылка.СегментыПартнеров, СправочникСсылка.СегментыНоменклатуры - сегмент, элементы входящие в который получаются.
//
Процедура Очистить(ПоказательСсылка) Экспорт

	НаборСегмента = РегистрыСведений.оп_РезультатРасчетаПоказателей.СоздатьНаборЗаписей();
	НаборСегмента.Отбор.Показатель.Установить(ПоказательСсылка);
	НаборСегмента.Записать();

КонецПроцедуры

Процедура СформироватьПересчетыТоваров(ПоказательСсылка) Экспорт

	ПР = ПривилегированныйРежим();
	Если НЕ ПР Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Если ТипЗнч(ПоказательСсылка) = Тип("СправочникСсылка.РегламентныеЗаданияПересчетовТоваров") Тогда
		ПараметрыРасчета = Новый Структура("Показатель",ПоказательСсылка);
		Справочники.РегламентныеЗаданияПересчетовТоваров.СформироватьПересчетыТоваров(ПараметрыРасчета);		
	КонецЕсли;

	Если НЕ ПР Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;

КонецПроцедуры
