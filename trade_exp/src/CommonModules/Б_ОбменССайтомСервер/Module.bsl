Процедура ЗарегистрироватьРасхожденияРегистраРаспределенияЗапасов(НаборСтарый,НаборНовый,МассивУзловТовары)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтарыйРегистр.Номенклатура КАК Номенклатура,
		|	СтарыйРегистр.НомерСтроки КАК НомерСтроки,
		|	СтарыйРегистр.Отгрузить + СтарыйРегистр.Резервировать + СтарыйРегистр.РезервироватьПоМереПоступления + СтарыйРегистр.КОбеспечениюБезРезерва + СтарыйРегистр.Поступило + СтарыйРегистр.ПоступитКДате + СтарыйРегистр.ПоставкаНаСогласовании + СтарыйРегистр.ЗакрытьГрафикПоступления + СтарыйРегистр.ЗакрытьГрафикОтгрузки КАК КонтрСумма
		|ПОМЕСТИТЬ ВР_СтарыйРегистр
		|ИЗ
		|	&СтарыйРегистр КАК СтарыйРегистр
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НовыйРегистр.Номенклатура КАК Номенклатура,
		|	НовыйРегистр.НомерСтроки КАК НомерСтроки,
		|	НовыйРегистр.Отгрузить + НовыйРегистр.Резервировать + НовыйРегистр.РезервироватьПоМереПоступления + НовыйРегистр.КОбеспечениюБезРезерва + НовыйРегистр.Поступило + НовыйРегистр.ПоступитКДате + НовыйРегистр.ПоставкаНаСогласовании + НовыйРегистр.ЗакрытьГрафикПоступления + НовыйРегистр.ЗакрытьГрафикОтгрузки КАК КонтрСумма
		|ПОМЕСТИТЬ ВР_НовыйРегистр
		|ИЗ
		|	&НовыйРегистр КАК НовыйРегистр
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЕСТЬNULL(ВР_НовыйРегистр.Номенклатура, ВР_СтарыйРегистр.Номенклатура) КАК Номенклатура
		|ИЗ
		|	ВР_СтарыйРегистр КАК ВР_СтарыйРегистр
		|		ПОЛНОЕ СОЕДИНЕНИЕ ВР_НовыйРегистр КАК ВР_НовыйРегистр
		|		ПО ВР_СтарыйРегистр.Номенклатура = ВР_НовыйРегистр.Номенклатура
		|			И ВР_СтарыйРегистр.НомерСтроки = ВР_НовыйРегистр.НомерСтроки
		|ГДЕ
		|	ЕСТЬNULL(ВР_НовыйРегистр.КонтрСумма, 0) <> ЕСТЬNULL(ВР_СтарыйРегистр.КонтрСумма, 0)";
	
	Запрос.УстановитьПараметр("СтарыйРегистр",НаборСтарый.Выгрузить());
	Запрос.УстановитьПараметр("НовыйРегистр",НаборНовый.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ПланыОбмена.ЗарегистрироватьИзменения(МассивУзловТовары, ВыборкаДетальныеЗаписи.Номенклатура);

	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти