КонецПроцедуры

&ИзменениеИКонтроль("СообщитьПодробно")
Процедура Док_СообщитьПодробно(пСобытие, ОсновныеПараметры, Логирование, СообщатьОбОшибке, ЗаписьВЖурналРегистрации)

	//#Если Клиент Тогда
	Сообщить(пСобытие);
	//#КонецЕсли

	Б_ОбщиеПроцедурыИФункцииСервер.ОтображениеСостояния(пСобытие);

	Если ЗаписьВЖурналРегистрации тогда
		ЗаписьЖурналаРегистрации("СобытияОбменаДанныхМодуляБитрикс", УровеньЖурналаРегистрации.Информация,,, пСобытие);
	КонецЕсли;

	Если СообщатьОбОшибке и НЕ ОсновныеПараметры = Неопределено Тогда

		ОсновныеПараметры.ЕстьКритичныеОшибкиВОбмене		= Истина;	
		ДобавитьИнформациюООшибкеВОбмене(ОсновныеПараметры.Ссылка, пСобытие);		

	КонецЕсли;

	Если Логирование и НЕ ОсновныеПараметры = Неопределено Тогда

		Если ОсновныеПараметры.ИмяФайлаЛога <> "" тогда

			лКодировка = КодировкаТекста.ANSI; 
			Если ОсновныеПараметры.КодировкаФайлаЛога = "ANSI" Тогда
				лКодировка = КодировкаТекста.ANSI; 
			ИначеЕсли ОсновныеПараметры.КодировкаФайлаЛога = "OEM" Тогда
				лКодировка = КодировкаТекста.OEM; 
			ИначеЕсли ОсновныеПараметры.КодировкаФайлаЛога = "UTF16" Тогда
				лКодировка = КодировкаТекста.UTF16; 
			ИначеЕсли ОсновныеПараметры.КодировкаФайлаЛога = "UTF8" Тогда
				лКодировка = КодировкаТекста.UTF8; 
			ИначеЕсли ОсновныеПараметры.КодировкаФайлаЛога = "Системная" Тогда
				лКодировка = КодировкаТекста.Системная; 
			КонецЕсли;	

			Текст = Новый ЗаписьТекста(ОсновныеПараметры.ИмяФайлаЛога, лКодировка,, Истина);
#Удаление
			Текст.ЗаписатьСтроку(Строка(ОсновныеПараметры.ДатаФормирования) + "--" + пСобытие);
#КонецУдаления
#Вставка
			Текст.ЗаписатьСтроку(Строка(ТекущаяДата()) + "--" + пСобытие);
#КонецВставки

			Текст.Закрыть(); 

		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

