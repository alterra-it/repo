Функция ПолучитьВидВремениПоБуквенномуКоду(Текст) Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ВидыИспользованияРабочегоВремени.Ссылка,
	|	ВидыИспользованияРабочегоВремени.Наименование,
	|	ВидыИспользованияРабочегоВремени.ПолноеНаименование,
	|	ВидыИспользованияРабочегоВремени.Сотрировка КАК Сотрировка,
	|	ВидыИспользованияРабочегоВремени.БуквенныйКод,
	|	ВидыИспользованияРабочегоВремени.ЦифровойКод
	|ИЗ
	|	Справочник.ВидыИспользованияРабочегоВремени КАК ВидыИспользованияРабочегоВремени
	|ГДЕ
	|	ВидыИспользованияРабочегоВремени.ПометкаУдаления = ЛОЖЬ
	|	И ВидыИспользованияРабочегоВремени.БуквенныйКод = &БуквенныйКод
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сотрировка" ;
	
	Запрос.УстановитьПараметр("БуквенныйКод",Текст);
	Результат= Запрос.Выполнить();
	Выборка= Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Сообщить("Не верно введен Вид рабочего времени!");
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Процедура ЗаполнитьМесяцПоДате(РедактируемыйОбъект, ПутьРеквизита, ПутьРеквизитаПредставления) Экспорт
	
	Значение = ОбщегоНазначенияКлиентСервер.ПолучитьРеквизитФормыПоПути(РедактируемыйОбъект, ПутьРеквизита);
	ОбщегоНазначенияКлиентСервер.УстановитьРеквизитФормыПоПути(РедактируемыйОбъект, ПутьРеквизитаПредставления, Формат(Значение, "ДФ='ММММ гггг'"));
	
КонецПроцедуры

