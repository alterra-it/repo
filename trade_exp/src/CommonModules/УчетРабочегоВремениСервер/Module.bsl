Функция ПолучитьКоличествоСотрудниковВПодразделении(Отдел)  Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сотрудники.Ссылка) КАК Кол
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Отдел = &Отдел
	|	И Сотрудники.Уволен = ЛОЖЬ
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ" ;
	
	Запрос.УстановитьПараметр("Отдел",Отдел);
	Результат= Запрос.Выполнить();
	Выборка= Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Кол;
	Иначе
		Возврат 0;
	КонецЕсли; 
	
КонецФункции

Функция ПолучитьВидДня(Дата)  Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ДанныеПроизводственногоКалендаря.Дата,
	|	ДанныеПроизводственногоКалендаря.ВидДня
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.Дата = &Дата
	|	И ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &ПроизводственныйКалендарь" ;
	
	Запрос.УстановитьПараметр("Дата",НачалоДня(Дата));
	Запрос.УстановитьПараметр("ПроизводственныйКалендарь", Справочники.ПроизводственныеКалендари.НайтиПоКоду("РФ"));
	Результат= Запрос.Выполнить();
	Выборка= Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ВидДня;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьКоличествоДнейВМесяц(ДатаНачала, ДатаОкончания, ВидДня=Неопределено)  Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеПроизводственногоКалендаря.Дата) КАК ДатаКол,
	|	ДанныеПроизводственногоКалендаря.ВидДня
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &ПроизводственныйКалендарь
	|	И ДанныеПроизводственногоКалендаря.ВидДня = &ВидДня
	|	И ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|
	|СГРУППИРОВАТЬ ПО
	|	ДанныеПроизводственногоКалендаря.ВидДня" ;
	
	Запрос.УстановитьПараметр("ПроизводственныйКалендарь", КалендарныеГрафики.ПроизводственныйКалендарьРоссийскойФедерации());
	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	Если ВидДня = Неопределено Тогда
		Запрос.Текст=СтрЗаменить(Запрос.Текст, "И ДанныеПроизводственногоКалендаря.ВидДня = &ВидДня", "");
	Иначе 
		Запрос.УстановитьПараметр("ВидДня", ВидДня);
	КонецЕсли;
	Результат= Запрос.Выполнить();
	Выборка= Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ДатаКол;
	Иначе
		Возврат 0;
	КонецЕсли; 
	
КонецФункции

Функция ПолучитьРаботающихСотрудников(Отдел=Неопределено, ДатаНачалаПериода)  Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Сотрудник,
	|	Сотрудники.Пользователь КАК Пользователь,
	|	Сотрудники.Должность КАК Должность,
	|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
	|	Сотрудники.ДатаПриема КАК ДатаПриема,
	|	Сотрудники.Отдел КАК Отдел,
	|	Сотрудники.Подразделение КАК Подразделение
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.Отдел В ИЕРАРХИИ(&Отдел)
	|	И ВЫБОР
	|			КОГДА Сотрудники.Уволен = ИСТИНА
	|				ТОГДА Сотрудники.ДатаУвольнения >= &ДатаНачалаПериода
	|			ИНАЧЕ Сотрудники.Уволен = ЛОЖЬ
	|		КОНЕЦ" ;
	
	Запрос.УстановитьПараметр("ДатаНачалаПериода",ДатаНачалаПериода);

	Если Отдел = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И Сотрудники.Отдел В ИЕРАРХИИ(&Отдел)", "");
	Иначе
		Запрос.УстановитьПараметр("Отдел",Отдел);
	КонецЕсли;
	Результат= Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	МассивСотрудников = Новый Массив;
	Пока Выборка.Следующий()Цикл
		СтрукСотрудника = Новый Структура("Сотрудник, Должность, Отдел, Подразделение");
		ЗаполнитьЗначенияСвойств(СтрукСотрудника, Выборка);
		МассивСотрудников.Добавить(СтрукСотрудника);
	КонецЦикла;
	
	Возврат МассивСотрудников;	
КонецФункции

Функция ПолучитьЧасыработыОрганизации(Календарь,КонецГрафика)  Экспорт
	
	ДатаНачала = НачалоМесяца(КонецГрафика);
	ДатаОкончания = КонецМесяца(КонецГрафика);

	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	// Создаем временную таблицу расписаний.
	ГрафикиРаботы.СоздатьВТРасписанияРаботыНаПериод(МенеджерВременныхТаблиц, Календарь, ДатаНачала, ДатаОкончания);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДЕНЬ(РасписанияРаботы.ДатаГрафика) КАК НомерДня,
	|	СУММА(РАЗНОСТЬДАТ(РасписанияРаботы.ВремяНачала, РасписанияРаботы.ВремяОкончания, ЧАС)) КАК Часов
	|ИЗ
	|	ВТРасписанияРаботы КАК РасписанияРаботы
	|
	|СГРУППИРОВАТЬ ПО
	|	ДЕНЬ(РасписанияРаботы.ДатаГрафика)
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерДня" ;

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Результат = Запрос.Выполнить().Выгрузить();
	
	мРасписание = Новый Массив(Число(День(ДатаОкончания)));
	Для ДН = Число(День(ДатаНачала)) По Число(День(ДатаОкончания)) Цикл
		НовыйДень = Результат.Найти(ДН, "НомерДня");
		Если НовыйДень <> Неопределено Тогда
			мРасписание[ДН-1] = НовыйДень.Часов;
		Иначе
			мРасписание[ДН-1] = 0;
		КонецЕсли;
	КонецЦикла;
	Возврат мРасписание; 
	
КонецФункции

Функция ПолучитьНормыРабочегоВремени(ДатаСреза, Отдел, ГрафикРаботы)  Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	НормыРабочегоВремениСрезПоследних.ДеньНедели КАК ДеньНедели,
	|	НормыРабочегоВремениСрезПоследних.НормаЧасовРаботыНаЧеловекаВДень КАК НормаЧасов,
	|	НормыРабочегоВремениСрезПоследних.ДеньНеделиСтрокой
	|ИЗ
	|	РегистрСведений.НормыРабочегоВремени.СрезПоследних(
	|			&ДатаСреза,
	|			Отдел = &Отдел
	|				И ГрафикРаботы = &ГрафикРаботы) КАК НормыРабочегоВремениСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДеньНедели" ;
	
	Запрос.УстановитьПараметр("ДатаСреза", ДатаСреза);
	Запрос.УстановитьПараметр("Отдел", Отдел);
	Запрос.УстановитьПараметр("ГрафикРаботы", ГрафикРаботы);
	
	мНормы= Новый Массив;
	
	Результат= Запрос.Выполнить();
	Выборка= Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		мНормы.Добавить(Выборка.НормаЧасов);
	КонецЦикла;
	Возврат мНормы;
	
КонецФункции

Функция ЗрегестрироватьСотрудникаПоШтрихкодуСервер(Штрихкод) Экспорт
	
	Ошибка= Ложь;
	Сотрудник= Справочники.Сотрудники.НайтиПоКоду(Штрихкод);
	Событие= Перечисления.СостоянияСотрудников.Вышел;
	Результат= СотрудникВОфисе(Сотрудник);
	ПредыдущееСостояние= Результат.Состояние;
	ПериодПредудущегоСобытия= Результат.Период;
	
	Если (ПериодПредудущегоСобытия+5*60) >= ТекущаяДата() Тогда
		Ошибка= Истина;
		Сообщить("Между последним сконированием прошло меньше 5 минут!");
		Событие= ПредыдущееСостояние;
		Возврат  Новый Структура("Событие, Ошибка", Событие, Ошибка);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		
		НаборЗаписей= РегистрыСведений.УчетРабочегоВремениСотрудников.СоздатьНаборЗаписей();
		НоваяЗапись= НаборЗаписей.Добавить();
		НоваяЗапись.Период= ТекущаяДата();
		НоваяЗапись.Сотрудник= Сотрудник;
		НоваяЗапись.Пользователь= Сотрудник.Пользователь;
		НоваяЗапись.Подразделение= ?(ЗначениеЗаполнено(Сотрудник.Подразделение), Сотрудник.Подразделение, Сотрудник.Пользователь.ТекущееПодразделение);
		
		//Если последнее событие было вчера или позднее тогда всегда зашел
		Если НачалоДня(ПериодПредудущегоСобытия) < НачалоДня(ТекущаяДата()) Тогда
			НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Зашел;
		Иначе
			// Общая проверка
			Если  ПредыдущееСостояние = Перечисления.СостоянияСотрудников.Вышел Тогда//Вышел или ещё не было
				НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Зашел;
			Иначе
				НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Вышел;
			КонецЕсли;
		КонецЕсли;
		Событие= НоваяЗапись.Событие;
		
		НаборЗаписей.Записать(Ложь);
	Иначе 
		Ошибка= Истина;
		Сообщить("Сотрудник со штрихкодом "+Штрихкод+" не найден!")
	КонецЕсли;
	
	Возврат  Новый Структура("Событие, Ошибка", Событие, Ошибка);
	
КонецФункции

Функция СотрудникВОфисе(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УчетРабочегоВремениСотрудниковСрезПоследних.Событие,
	|	УчетРабочегоВремениСотрудниковСрезПоследних.Период КАК Период
	|ИЗ
	|	РегистрСведений.УчетРабочегоВремениСотрудников.СрезПоследних(
	|			,
	|			Сотрудник = &Сотрудник
	|				И Подразделение = &Подразделение
	|				И Пользователь = &Пользователь) КАК УчетРабочегоВремениСотрудниковСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период";
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Подразделение", Сотрудник.Подразделение);
	Запрос.УстановитьПараметр("Пользователь", Сотрудник.Пользователь);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Если  ВыборкаДетальныеЗаписи.Событие = Перечисления.СостоянияСотрудников.Зашел Тогда
			Состояние= Перечисления.СостоянияСотрудников.Зашел;
			Период= ВыборкаДетальныеЗаписи.Период;
		Иначе
			Состояние= Перечисления.СостоянияСотрудников.Вышел;
			Период= ВыборкаДетальныеЗаписи.Период;
		КонецЕсли;
	Иначе
		Состояние= Перечисления.СостоянияСотрудников.Вышел;
		Период= Дата(0001,01,01);;
	КонецЕсли;
		Рез= Новый Структура("Состояние,Период", Состояние, Период);
	Возврат  Рез;
	
КонецФункции	

//Дополнительные процедуры и функции
Процедура ТабельЗаполнитьДанныеПоСотрудникам(Объект, СписокСотрудников, СтрокиПоСотрудникам, ДатаОкончанияРасчета, ПоГрафику) Экспорт
	
	КодыВидовВремени = КодыВидовВремени(Объект.ПериодРегистрации);
	
	Если ПоГрафику Тогда
		ВыборкаДанныхОВремени = ВыборкаДанныхПоГрафику(СписокСотрудников, ДатаОкончанияРасчета,Объект.ГрафикРаботы);	
	Иначе
		ВыборкаДанныхОВремени = ВыборкаДанныхОВремени(Объект, СписокСотрудников, ДатаОкончанияРасчета);
	КонецЕсли;
	
	ТекущийСотрудник = Неопределено;
	ДанныеОВремениПоСотруднику = Новый Массив;
	НомерСтрокиСотрудник = 1;
	ИТ = Объект.Отделы.НайтиСтроки(Новый Структура("Отдел", Справочники.Отделы.НайтиПоКоду("000000148"))).Количество() > 0; 
	
	ДанныеОВремениПоСотруднику = Новый ТаблицаЗначений;
	ДанныеОВремениПоСотруднику.Колонки.Добавить("Сотрудник");
	ДанныеОВремениПоСотруднику.Колонки.Добавить("ВидУчетаВремени");
	ДанныеОВремениПоСотруднику.Колонки.Добавить("Дата");
	ДанныеОВремениПоСотруднику.Колонки.Добавить("ДатаНачалаРаботы");
	ДанныеОВремениПоСотруднику.Колонки.Добавить("Часы");
	
	Пока ВыборкаДанныхОВремени.СледующийПоЗначениюПоля("Сотрудник") Цикл
		ДанныеОВремениПоСотруднику.Очистить();
		Пока ВыборкаДанныхОВремени.Следующий() Цикл
			СтрокаТаблицыДанныхОВремени = ДанныеОВремениПоСотруднику.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаТаблицыДанныхОВремени, ВыборкаДанныхОВремени)
		КонецЦикла;	
		
		Если СтрокиПоСотрудникам <> Неопределено Тогда					
			МассивСтрокПоСотруднику = СтрокиПоСотрудникам[ВыборкаДанныхОВремени.Сотрудник];
		КонецЕсли;	
		
		ТабельЗаполнитьСтрокиПоСотруднику(
		    Объект.ДанныеОВремени,
			ДанныеОВремениПоСотруднику, 
			МассивСтрокПоСотруднику, 
			КодыВидовВремени, ПоГрафику, Объект.ГрафикРаботы, Объект.Ссылка, ИТ);
	КонецЦикла;
		
КонецПроцедуры	

Функция КодыВидовВремени(Месяц = Неопределено) Экспорт  
	
	Выборка = СформироватьЗапросПоВидамВремени().Выбрать();
	
	КодыВидовВремени = Новый Соответствие;
	
	БуквенныйКодИмяРеквизита = "БуквенныйКод";
	
	Пока Выборка.Следующий() Цикл 
		КодыВидовВремени.Вставить(Выборка.ВидВремени, Выборка[БуквенныйКодИмяРеквизита]);
	КонецЦикла;	
	
	КодыВидовВремени.Вставить(Справочники.ВидыИспользованияРабочегоВремени.ПустаяСсылка(), "");
	
	Возврат КодыВидовВремени; 
	
КонецФункции

Функция СформироватьЗапросПоВидамВремени() Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыИспользованияРабочегоВремени.Ссылка КАК ВидВремени,
	|	ВидыИспользованияРабочегоВремени.БуквенныйКод, 
	|	ВидыИспользованияРабочегоВремени.Целосменное,
	|	ВидыИспользованияРабочегоВремени.Наименование
	|ИЗ
	|	Справочник.ВидыИспользованияРабочегоВремени КАК ВидыИспользованияРабочегоВремени";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ВыборкаДанныхПоГрафику(СписокСотрудников = Неопределено, ДатаОкончанияРасчета, График);	
	УстановитьПривилегированныйРежим(истина);	
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Дата",Новый ОписаниеТипов("Дата"));
	ТЗ.Колонки.Добавить("Часы",Новый ОписаниеТипов("Число"));
	
	мЧасыРаботыПоГрафику = ПолучитьЧасыработыОрганизации(График,ДатаОкончанияРасчета); 
	КолДнейВМес = День(ДатаОкончанияРасчета);

	Для НомерДня = 1 По КолДнейВМес Цикл
		ТекДата = Дата(Год(ДатаОкончанияРасчета),Месяц(ДатаОкончанияРасчета), НомерДня);
		ДеньНедели = ДеньНедели(ТекДата);
			
		НоваяСтрока = ТЗ.Добавить();
		НоваяСтрока.Дата = ТекДата;
		НоваяСтрока.Часы = мЧасыРаботыПоГрафику[НомерДня-1];
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблица.Дата КАК Дата,
		|	ВнешняяТаблица.Часы КАК Часы
		|ПОМЕСТИТЬ ВнешняяТаблица
		|ИЗ
		|	&ВнешняяТаблица КАК ВнешняяТаблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	Сотрудники.Пользователь КАК Пользователь,
		|	Сотрудники.Подразделение КАК Подразделение,
		|	ВнешняяТаблица.Дата КАК Дата,
		|	ВнешняяТаблица.Часы КАК Часы
		|ПОМЕСТИТЬ ВР_СотрудникиВремя
		|ИЗ
		|	ВнешняяТаблица КАК ВнешняяТаблица,
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Ссылка В(&Ссылка)
		|	И ВнешняяТаблица.Дата >= Сотрудники.ДатаПриема
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_СотрудникиВремя.Сотрудник КАК Сотрудник,
		|	ВР_СотрудникиВремя.Пользователь КАК Пользователь,
		|	ВР_СотрудникиВремя.Подразделение КАК Подразделение,
		|	ВР_СотрудникиВремя.Дата КАК Дата,
		|	ВР_СотрудникиВремя.Часы КАК Часы,
		|	ВЫБОР
		|		КОГДА НЕ СостоянияСотрудников.Состояние ЕСТЬ NULL
		|			ТОГДА ВЫБОР
		|					КОГДА СостоянияСотрудников.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСотрудника.ОтпускПоУходуЗаРебенком)
		|						ТОГДА ""ОЖ""
		|					КОГДА СостоянияСотрудников.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСотрудника.ОтпускПоБеременностиИРодам)
		|						ТОГДА ""Р""
		|				КОНЕЦ
		|	КОНЕЦ КАК ВидУчетаВремени
		|ИЗ
		|	ВР_СотрудникиВремя КАК ВР_СотрудникиВремя
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияСотрудников КАК СостоянияСотрудников
		|		ПО ВР_СотрудникиВремя.Сотрудник = СостоянияСотрудников.Сотрудник
		|			И (СостоянияСотрудников.Период = НАЧАЛОПЕРИОДА(&Период, МЕСЯЦ))
		|			И (ВР_СотрудникиВремя.Дата МЕЖДУ СостоянияСотрудников.ДатаНачала И СостоянияСотрудников.ДатаОкончания)";
	//	|			И (СостоянияСотрудников.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСотрудника.ОтпускПоУходуЗаРебенком))";
	
	Запрос.УстановитьПараметр("Ссылка", СписокСотрудников);  
	Запрос.УстановитьПараметр("Период", ДатаОкончанияРасчета);
    Запрос.УстановитьПараметр("ВнешняяТаблица", ТЗ);
	УстановитьПривилегированныйРежим(ложь);
	Возврат Запрос.Выполнить().Выбрать(); 
	
КонецФункции

