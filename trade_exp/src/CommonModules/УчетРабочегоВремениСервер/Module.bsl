#Область СлужебныеПроцедурыИФункции

Функция ПолучитьСписокВидовВремениБуквенныйКод() Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ВидыИспользованияРабочегоВремени.Ссылка КАК Ссылка,
	|	ВидыИспользованияРабочегоВремени.Наименование КАК Наименование,
	|	ВидыИспользованияРабочегоВремени.ПолноеНаименование КАК ПолноеНаименование,
	|	ВидыИспользованияРабочегоВремени.Сотрировка КАК Сотрировка,
	|	ВидыИспользованияРабочегоВремени.БуквенныйКод КАК БуквенныйКод,
	|	ВидыИспользованияРабочегоВремени.ЦифровойКод КАК ЦифровойКод
	|ИЗ
	|	Справочник.ВидыИспользованияРабочегоВремени КАК ВидыИспользованияРабочегоВремени
	|ГДЕ
	|	ВидыИспользованияРабочегоВремени.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сотрировка" ;
	
	Список= Новый СписокЗначений;
	
	Выборка= Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Список.Добавить(Выборка.Ссылка, Выборка.БуквенныйКод);
	КонецЦикла;
	Возврат Список;
	
КонецФункции

Функция ПолучитьСписокВидовВремениСтруктурой(Текст) Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ВидыИспользованияРабочегоВремени.Ссылка КАК Ссылка,
	|	ВидыИспользованияРабочегоВремени.Наименование КАК Наименование,
	|	ВидыИспользованияРабочегоВремени.ПолноеНаименование КАК ПолноеНаименование,
	|	ВидыИспользованияРабочегоВремени.Сотрировка КАК Сотрировка,
	|	ВидыИспользованияРабочегоВремени.БуквенныйКод КАК БуквенныйКод,
	|	ВидыИспользованияРабочегоВремени.ЦифровойКод КАК ЦифровойКод
	|ИЗ
	|	Справочник.ВидыИспользованияРабочегоВремени КАК ВидыИспользованияРабочегоВремени
	|ГДЕ
	|	ВидыИспользованияРабочегоВремени.ПометкаУдаления = ЛОЖЬ
	|	И ВидыИспользованияРабочегоВремени.БуквенныйКод ПОДОБНО &БуквенныйКод
	|
	|УПОРЯДОЧИТЬ ПО
	|	Сотрировка" ;
	
	Если Не ПустаяСтрока(Текст) Тогда
		Запрос.УстановитьПараметр("БуквенныйКод",Текст);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ВидыИспользованияРабочегоВремени.БуквенныйКод ПОДОБНО &БуквенныйКод", "");
	КонецЕсли;
	Результат= Запрос.Выполнить();
	Выборка= Результат.Выбрать();
	
	СП= Новый СписокЗначений;	
	Пока Выборка.Следующий() Цикл 
		СтркДанныеВыбора= Новый Структура("ВидВремени, БуквенноеОбозначение, Часы, ЕстьРазделитель", Выборка.Ссылка, Выборка.БуквенныйКод);
		СП.Добавить(СтркДанныеВыбора, "["+Выборка.БуквенныйКод+"] "+Выборка.Наименование);
	КонецЦикла;
	Возврат СП;
	
КонецФункции

