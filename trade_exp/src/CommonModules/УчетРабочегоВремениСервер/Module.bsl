		|			ТОГДА ""ОЖ""
		|		КОГДА СостоянияСотрудников.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСотрудника.ОтпускПоБеременностиИРодам)
		|			ТОГДА ""Р""
		|	КОНЕЦ
		|ИЗ
		|	РегистрСведений.СостоянияСотрудников КАК СостоянияСотрудников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ТаблицаДат КАК ВТ_ТаблицаДат
		|		ПО (ВТ_ТаблицаДат.Период МЕЖДУ СостоянияСотрудников.ДатаНачала И СостоянияСотрудников.ДатаОкончания)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Сотрудники КАК Сотр
		|		ПО СостоянияСотрудников.Сотрудник = Сотр.Сотрудник
		|ГДЕ
		|	СостоянияСотрудников.Период = &нПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ТаблицаДат.Период КАК Дата,
		|	ВТ_Сотрудники.Сотрудник КАК Сотрудник,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
		|				ТОГДА ВременнаяТаблица.ДатаНачалаРаботы
		|		КОНЕЦ) КАК ДатаНачалаРаботы,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
		|				ТОГДА ВременнаяТаблица.ДатаОкончанияРаботы
		|		КОНЕЦ) КАК ДатаОкончанияРаботы,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА НЕ ВременнаяТаблица.ВидУчетаВремени ЕСТЬ NULL
		|				ТОГДА 0
		|			КОГДА ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
		|				ТОГДА ВЫБОР
		|						КОГДА ВременнаяТаблица.ДатаНачалаРаботы ЕСТЬ NULL
		|								ИЛИ ВременнаяТаблица.ДатаОкончанияРаботы ЕСТЬ NULL
		|							ТОГДА 0
		|						ИНАЧЕ ВЫРАЗИТЬ((РАЗНОСТЬДАТ(ВременнаяТаблица.ДатаНачалаРаботы, ВременнаяТаблица.ДатаОкончанияРаботы, МИНУТА) - 60) / 60 - 0.49 КАК ЧИСЛО(10, 0))
		|					КОНЕЦ
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Часы,
		|	ВременнаяТаблица.ВидУчетаВремени КАК ВидУчетаВремени
		|ИЗ
		|	ВТ_ТаблицаДат КАК ВТ_ТаблицаДат
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Сотрудники КАК ВТ_Сотрудники
		|		ПО ВТ_ТаблицаДат.Период >= ВТ_Сотрудники.Сотрудник.ДатаПриема
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВременнаяТаблица КАК ВременнаяТаблица
		|		ПО ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
		|			И ВТ_Сотрудники.Сотрудник = ВременнаяТаблица.Сотрудник
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ТаблицаДат.Период,
		|	ВТ_Сотрудники.Сотрудник,
		|	ВременнаяТаблица.ВидУчетаВремени";
	
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;

	Запрос.УстановитьПараметр("кПериода", ДатаОкончанияРасчета);
	Запрос.УстановитьПараметр("нПериода", НачалоМесяца(ДанныеТабеля.ПериодРегистрации));
	Запрос.УстановитьПараметр("Сотрудник", СписокСотрудников);

	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Процедура ТабельЗаполнитьСтрокиПоСотруднику(ДанныеОВремени, ДанныеОВремениПоСотруднику, МассивСтрокПоСотруднику, КодыВидовВремени, ПоГрафику, Календарь = Ложь, ДокументСсылка = Неопределено, ИТ = Ложь) Экспорт 
	
	Календарь_Ссылка = Справочники.Календари.ПолучитьСсылку(Новый УникальныйИдентификатор("91df52ef-4f67-11e4-80c7-002590e168ab"));
	УстановленПлавающийГрафик = Календарь.Ссылка = Справочники.Календари.НайтиПоНаименованию("Плавающий график");
	Явка = Справочники.ВидыИспользованияРабочегоВремени.Явка;
	Выходной = Справочники.ВидыИспользованияРабочегоВремени.ВыходныеДни;
	Декрет=Справочники.ВидыИспользованияРабочегоВремени.ОтпускПоУходуЗаРебенком; 
	ПоБеременности=Справочники.ВидыИспользованияРабочегоВремени.ОтпускПоБеременностиИРодам; 
	Табель = ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ТабельУчетаРабочегоВремени");   
	ЗапретИзмененияДо15Числа = Табель И ДокументСсылка.Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.УтвержденКАвансу");
	
	ВидВремени = Справочники.ВидыИспользованияРабочегоВремени.ПустаяСсылка();
	
	Для Каждого СтрокаДанныхОВремени Из ДанныеОВремениПоСотруднику Цикл  
		
		НомерДня = День(СтрокаДанныхОВремени.Дата);
		
		Если ЗапретИзмененияДо15Числа И НомерДня <= 15 Тогда
			Продолжить;
		КонецЕсли;
			
		НомерВидаВремениНаДату = 1;
		СтрокаТабеля = МассивСтрокПоСотруднику[НомерВидаВремениНаДату - 1];
		
		Если Не РучнаяКорректировкаВремени(СтрокаДанныхОВремени, ДанныеОВремени, ПоГрафику, Табель, УстановленПлавающийГрафик, ИТ) Тогда
			если СтрокаДанныхОВремени.ВидУчетаВремени="ОЖ" тогда
				ВидВремени = Декрет; 
				СтрокаДанныхОВремени.Часы = 0;                   
			иначеесли СтрокаДанныхОВремени.ВидУчетаВремени="Р" тогда	
				ВидВремени = ПоБеременности; 
				СтрокаДанныхОВремени.Часы = 0;                   
			иначеЕсли ЗначениеЗаполнено(СтрокаДанныхОВремени.Часы) Тогда
				ВидВремени = Явка;           
			Иначеесли не ЗначениеЗаполнено(СтрокаДанныхОВремени.ВидУчетаВремени) и не ЗначениеЗаполнено(СтрокаДанныхОВремени.Часы) тогда
				ВидВремени = Выходной;
				СтрокаДанныхОВремени.Часы = 0;
			КонецЕсли;
			
			Если ПоГрафику и (Календарь.Ссылка = Календарь_Ссылка) Тогда
				ВидДня = УчетРабочегоВремениСервер.ПолучитьВидДня(СтрокаДанныхОВремени.Дата);
				Если ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Рабочий") Тогда
				ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Предпраздничный") Тогда
					Если (СтрокаДанныхОВремени.Часы >= 1) тогда
					 СтрокаДанныхОВремени.Часы = СтрокаДанныхОВремени.Часы - 1;
					Конецесли; 
				Иначеесли не ЗначениеЗаполнено(СтрокаДанныхОВремени.ВидУчетаВремени) тогда
					ВидВремени = Выходной;
					СтрокаДанныхОВремени.Часы = 0;
				Конецесли;
			Конецесли;
			
			ЗаполняетсяПлан = ?(Табель И ПоГрафику И УстановленПлавающийГрафик И НЕ ИТ, Истина, Ложь);
			
			Если НЕ ЗаполняетсяПлан Тогда
				СтрокаТабеля["ВидВремени" + НомерДня] = ВидВремени;
			КонецЕсли;
			
			ДополнениеИмениКолонки = ?(ЗаполняетсяПлан, "План", "");
			СтрокаТабеля["Часов" + ДополнениеИмениКолонки + НомерДня] = СтрокаДанныхОВремени.Часы;
			СтрокаТабеля["Представление" + ДополнениеИмениКолонки + НомерДня] = ТабельПредставлениеВремениПоВиду(КодыВидовВремени.Получить(ВидВремени), СтрокаДанныхОВремени.Часы);  
		КонецЕсли;
		
		НачалоСмены = СтрокаДанныхОВремени.ДатаНачалаРаботы;
		Если Табель И Не ПоГрафику И ЗначениеЗаполнено(НачалоСмены) Тогда
			СтрокаТабеля["НачалоСмены" + НомерДня] = Дата('00010101') + (НачалоСмены - НачалоДня(НачалоСмены)) ;
		КонецЕсли;
		
	КонецЦикла;	
		
	КоличествоСтрокПоСотруднику = МассивСтрокПоСотруднику.Количество();
	
	Сотрудник = МассивСтрокПоСотруднику[0].Сотрудник;
	
	Для Каждого СтрокаПоСотруднику Из МассивСтрокПоСотруднику Цикл
		СтрокаПоСотруднику.Сотрудник = Сотрудник;		
	КонецЦикла;	
	
КонецПроцедуры	

Функция РучнаяКорректировкаВремени(ДанныеПоСтроке, ДанныеОВремени, ПоГрафику = Неопределено, Табель = Неопределено, Плавающий = Ложь, ИТ = Ложь) Экспорт
	
	Представление = ?(Табель И ПоГрафику И Плавающий И НЕ ИТ, "ПредставлениеПлан", "Представление");
	Отбор = Новый Структура;
	Отбор.Вставить("Сотрудник",ДанныеПоСтроке.Сотрудник);
	МассивСтрок = ДанныеОВремени.НайтиСтроки(Отбор);
	Для каждого Строка из МассивСтрок Цикл	
		Если ЗначениеЗаполнено(Строка[Представление + День(ДанныеПоСтроке.Дата)]) Тогда
			Возврат Истина;
			Прервать;
		Иначе
			Возврат Ложь;
			Прервать;
		КонецЕсли;
	КонецЦикла; 
	
КонецФункции

Функция ТабельПредставлениеВремениПоВиду(ОбозначениеВремени, КоличествоЧасов) Экспорт 
	
	Если Не ПустаяСтрока(ОбозначениеВремени) Или КоличествоЧасов <> 0 Тогда
		Возврат ОбозначениеВремени + Формат(КоличествоЧасов, "ЧГ=");
	Иначе
		Возврат "";
	КонецЕсли;
	
КонецФункции

#КонецОбласти

