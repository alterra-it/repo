		НаборЗапись.Отбор.КонецОтсчета.Установить(Выборка.КонецОтсчета);
		НаборЗапись.Записать();
		 
		
		Запись = РегистрыСведений.УчетВремениВодителей.СоздатьМенеджерЗаписи();
		Запись.Период = Выборка.Период;  
		Запись.Водитель = Выборка.Водитель;
		Запись.НачалоОтсчета = Выборка.НачалоОтсчета;
		Запись.КонецОтсчета = дата('00010101') + (ТекущаяДата()-НачалоДня(ТекущаяДата()));
		Запись.ВидЗанятости = Выборка.ВидЗанятости;
		Запись.ТранспортноеСредство = Выборка.ТранспортноеСредство;
		Запись.ОснованиеВремени = Выборка.ОснованиеВремени;	
		Запись.НужнаКорректировка = Ложь;
		
		Запись.Записать(Истина);   
		УстановитьПривилегированныйРежим(Ложь);  
	КонецЕсли;
КонецПроцедуры
					
