КонецФункции

Функция ПолучитьДокументыПродажиСервер(Ссылка) Экспорт
	
	Перем мДокументовПродажи;
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|   РеализацияТоваровУслуг.Проведен = Истина
		|	И РеализацияТоваровУслуг.ЗаказКлиента = &ЗаказКлиента";
		
		Запрос.УстановитьПараметр("ЗаказКлиента", Ссылка);
		мДокументовПродажи = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	Иначе
		мДокументовПродажи = Документы.ЗаданиеНаПеревозкуРейс.ПолучитьДокументыПродажи(Ссылка);
	КонецЕсли;
	
	Возврат мДокументовПродажи;
	
КонецФункции

Функция ПолучитьСтатус(Ссылка)
	
	Возврат Ссылка.Статус;
	
КонецФункции

Функция ОшибочнаяРегистрацияНаВъезд(Документ)
	
	ТекущееВремя = ТекущаяДата();
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостояниеОтгрузкиДокументаСрезПоследних.Период КАК Период
		|ИЗ
		|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(
		|			&Период,
		|			Документ = &Документ
		|				И Состояние = &Статус) КАК СостояниеОтгрузкиДокументаСрезПоследних";
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("Период", ТекущееВремя);
	Запрос.УстановитьПараметр("Статус", Перечисления.СостоянияОтгрузкиДокумента.Заехал);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ?(ТекущееВремя - ВыборкаДетальныеЗаписи.Период <= 30, Истина, Ложь);
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

Функция МашинаНаСкладе(Ссылка)
	
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостояниеОтгрузкиДокументаСрезПоследних.Период
	|ИЗ
	|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(, Документ = &Ссылка) КАК СостояниеОтгрузкиДокументаСрезПоследних
	|ГДЕ
	|	СостояниеОтгрузкиДокументаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Заехал)";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьЗонуДоступаДатчика(Датчик) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗоныДоступаДатчики.Ссылка КАК ЗонаДоступа
	|ИЗ
	|	Справочник.ЗоныДоступа.Датчики КАК ЗоныДоступаДатчики
	|ГДЕ
	|	ЗоныДоступаДатчики.Датчик = &Датчик ";
	Запрос.УстановитьПараметр("Датчик", Датчик);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий(); 
	
	Возврат Выборка.ЗонаДоступа;
	
КонецФункции

