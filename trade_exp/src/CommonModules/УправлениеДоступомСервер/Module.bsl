Процедура ВнестиВТабельВнутреннегоВодителя(Ссылка) 
	Запрос = Новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
                    |	Сотрудники.Ссылка КАК Ссылка,
                    |	ЗаданиеНаПеревозкуРейс.Автомобиль КАК Автомобиль,
					|	ЗаданиеНаПеревозкуРейс.Статус КАК Статус
                    |ИЗ
                    |	Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеНаПеревозкуРейс
                    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
                    |		ПО ЗаданиеНаПеревозкуРейс.Водитель.Наименование = Сотрудники.Наименование
                    |ГДЕ
                    |	ЗаданиеНаПеревозкуРейс.Ссылка = &Ссылка
                    |	И Сотрудники.Водитель = ИСТИНА"; 
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда
		Погрузка = Перечисления.ВидЗанятостиВодителей.Погрузка;
		Рейс = Перечисления.ВидЗанятостиВодителей.Рейс;  
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИсторияДоступа.Событие КАК Событие,
		|	ИсторияДоступа.ДатаСобытия КАК ДатаСобытия
		|ИЗ
		|	РегистрСведений.ИсторияДоступа КАК ИсторияДоступа
		|ГДЕ
		|	ИсторияДоступа.Объект = &Объект
		|	И ИсторияДоступа.Событие <> ЗНАЧЕНИЕ(Перечисление.СобытиеСКУД.Отказ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСобытия УБЫВ";
		Запрос.УстановитьПараметр("Объект", Ссылка);

		Результат = Запрос.Выполнить();
		ВыборкаРезультатов = Результат.Выбрать();
		Если не ВыборкаРезультатов.Следующий() Тогда
			СоздатьЗаписьВодителя(Выборка.Ссылка, Выборка.Автомобиль, Погрузка, Ссылка); 
		Иначе  
			ОбновитьЗаписьВодителя(Выборка.Ссылка, Выборка.Автомобиль, Погрузка);
			СоздатьЗаписьВодителя(Выборка.Ссылка, Выборка.Автомобиль, Рейс, Ссылка);
		КонецЕсли;
	КонецЕсли; 
	  
КонецПроцедуры

Функция ОбработатьСканированиеПропуска(Документ, Датчик, Зона, Штрихкод, ТипСканераКПП) 
		
	Если Документ.Прекращен Тогда 
		Комментарий = "Действие пропуска прекращено";  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ОбъектПросрочен; 
		ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	ИначеЕсли НЕ(ТекущаяДата() >= Документ.ДатаНачала И ТекущаяДата() <= Документ.ДатаОкончания) Тогда
		Комментарий = "Текущая дата не входит в период действия пропуска";  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ОбъектПросрочен; 
		ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;	
	ИначеЕсли Зона <> Документ.Доступ Тогда
		Комментарий = "Зона доступа документа не входит в зону доступа датчика";  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.НетДоступа; 
		ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли;

	//Проверяем на повторное использование пропуска
	Если Документ.ТипПропуска = Перечисления.ТипыПропусков.Разовый Тогда
		// Проверяем был ли выход по регистру «История доступа»
		БылВыход = ПроверитьВыходВИсторииДоступа(Документ, Зона);
		Если БылВыход Тогда 
			Комментарий = "Повторный вход";  
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ПовторныйВход; 
			ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
			Возврат РезультатСканированияКПП;
		КонецЕсли;
	КонецЕсли;
	
	//Проверяем на повторное сканирование пропуска
	ПоследняяЗапись = ПолучитьПоследнююЗаписьРегистраИсторияДосупа(Зона, Документ); 
	Если ПоследняяЗапись.ДатаСобытия <> Неопределено Тогда 
		Если (ТекущаяДата() - ПоследняяЗапись.ДатаСобытия) <= 60 Тогда
			Комментарий = "Повторное сканирование"; 
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ПовторноеСканирование;
			ЗарегистрироватьСобытиеВИсторииДоступа(Документ, Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
			Возврат РезультатСканированияКПП;	
		КонецЕсли; 
	КонецЕсли;
	
	//Определяем ВходВыход
	Если ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВъезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Вход; 
	ИначеЕсли ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВыезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Выход; 
	Иначе //Ручной или стационарный для сотрудников
		Если ПоследняяЗапись.ДатаСобытия = Неопределено Тогда //Сотрудник впервые отсканировался 
			Событие = Перечисления.СобытиеСКУД.Вход; 
		Иначе
			Если НачалоДня(ПоследняяЗапись.ДатаСобытия) < НачалоДня(ТекущаяДата()) Тогда //Последнее событие было вчера
				Событие = Перечисления.СобытиеСКУД.Вход; 
			Иначе
				// Общая проверка
				Если  ПоследняяЗапись.Событие = Перечисления.СобытиеСКУД.Выход Тогда // Вышел или ещё не было
					Событие = Перечисления.СобытиеСКУД.Вход; 
				Иначе
					Событие = Перечисления.СобытиеСКУД.Выход; 
				КонецЕсли;
			КонецЕсли;    
		КонецЕсли;
	КонецЕсли;
	
	Комментарий = "";
	Если Событие = Перечисления.СобытиеСКУД.Вход Тогда 
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВход; 
	Иначе
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВыход;   
	КонецЕсли;
	ЗарегистрироватьСобытиеВИсторииДоступа(Документ, Датчик, Зона, Событие,РезультатСканированияКПП, Комментарий, ТипСканераКПП);
	Состояние = ?(Событие = Перечисления.СобытиеСКУД.Вход, Перечисления.СостоянияОтгрузкиДокумента.Заехал, Перечисления.СостоянияОтгрузкиДокумента.Выехал); 
	РегистрацияСостояния(Документ, Состояние, Штрихкод, Неопределено);
	Возврат РезультатСканированияКПП;
	
КонецФункции

Функция ОбработатьСканированиеПечатнойФормыДокумента(Документ, Датчик, Зона, Штрихкод, ТипСканераКПП)
	
	Если Зона <> Документ.Подразделение.ЗонаДоступа Тогда
		Комментарий = "Зона доступа документа не входит в зону доступа датчика";  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.НетДоступа; 
		ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли;
	
	// Считаем что вход Одноразовый и проверяем был ли выход по регистру «История доступа»
	БылВыход = ПроверитьВыходВИсторииДоступа(Документ, Зона);
	Если БылВыход Тогда
		Комментарий = "Повторный вход";  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ПовторныйВход; 
		ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли;
	
	//Проверяем на повторное сканирование документа
	ПоследняяЗапись = ПолучитьПоследнююЗаписьРегистраИсторияДосупа(Зона, Документ); 
	Если ПоследняяЗапись.ДатаСобытия <> Неопределено Тогда 
		Если (ТекущаяДата() - ПоследняяЗапись.ДатаСобытия) <= 60 Тогда
			Комментарий = "Повторное сканирование"; 
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ПовторноеСканирование;
			ЗарегистрироватьСобытиеВИсторииДоступа(Документ, Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
			Возврат РезультатСканированияКПП;	
		КонецЕсли; 
	КонецЕсли;
	
	ТЗ_Документов = Новый ТаблицаЗначений();
	ТЗ_Документов.Колонки.Добавить("Документ");
	ТЗ_Документов.Колонки.Добавить("Штрихкод");
	ТЗ_Документов.Колонки.Добавить("Ошибка"); 	

	
	ЗаказыОтПоставщика = ПолучитьВсеЗаказыПоРейсуОтПоставщика(Документ);
	Если ЗначениеЗаполнено(ЗаказыОтПоставщика) Тогда
		Для Каждого Заказ Из ЗаказыОтПоставщика Цикл	
			ОбработатьДокументНаВъездВыезд(Заказ, Штрихкод, Ложь, ТЗ_Документов);
		КонецЦикла;
	Иначе
		ОбработатьДокументНаВъездВыезд(Документ, Штрихкод, ,ТЗ_Документов);
	КонецЕсли;	
	
	
	ТЗ_Ошибки = Новый ТаблицаЗначений();
	ТЗ_Ошибки.Колонки.Добавить("Документ");
	ТЗ_Ошибки.Колонки.Добавить("Ошибка"); 	
	
	Для Каждого Стр Из ТЗ_Документов Цикл
		Если Стр.Ошибка <> Неопределено Тогда
			Если Стр.Ошибка = "По заказу клиента нет реализации" Тогда  
				Комментарий = "По заказу клиента нет реализации";  
				РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.Ошибка; 
				ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
				Возврат РезультатСканированияКПП;
			КонецЕсли;
			СтрокаОшибки = ТЗ_Ошибки.Добавить();
			СтрокаОшибки.Документ = Стр.Документ;
			СтрокаОшибки.Ошибка = Стр.Ошибка;
		КонецЕсли;
	КонецЦикла;
	
  	Если ТЗ_Ошибки.Количество() > 0 Тогда
		Если Датчик.СКУД Тогда
			ТекстОшибки = "";
			Для Каждого Стр Из ТЗ_Ошибки Цикл
				ТекстОшибки = ТекстОшибки + Строка(Стр.Ошибка) + " " + Стр.Документ + "; "; 
			КонецЦикла; 
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.Ошибка; 
			ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, ТекстОшибки, ТипСканераКПП);
			Возврат РезультатСканированияКПП;	
		Иначе 
			Для Каждого Стр Из ТЗ_Документов Цикл
				Если Стр.Ошибка <> Неопределено Тогда
					РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.Ошибка; 
					ЗарегистрироватьСобытиеВИсторииДоступа(Документ , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Стр.Ошибка, ТипСканераКПП);
					Возврат РезультатСканированияКПП;
				КонецЕсли;
				РегистрацияСостоянияЗаезда(Стр.Документ, Стр.Штрихкод, Стр.Ошибка);
			КонецЦикла;
		КонецЕсли;
	Иначе 
		Для Каждого Стр Из ТЗ_Документов Цикл
			РегистрацияСостоянияЗаезда(Стр.Документ, Стр.Штрихкод, Стр.Ошибка);
		КонецЦикла;
	КонецЕсли;
	                     
		
	//Определяем ВходВыход
	Если ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВъезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Вход; 
	ИначеЕсли ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВыезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Выход; 
	Иначе //Ручной или стационарный для сотрудников
		Если ПоследняяЗапись.ДатаСобытия = Неопределено Тогда //Документ впервые отсканирован 
			Событие = Перечисления.СобытиеСКУД.Вход; 
		Иначе
			Событие = Перечисления.СобытиеСКУД.Выход;   
		КонецЕсли;
	КонецЕсли;
	
	Комментарий = "";           
	Если Событие = Перечисления.СобытиеСКУД.Вход Тогда 
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВход; 
	Иначе
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВыход;   
	КонецЕсли; 
	
	Если (ТипЗНЧ(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ ТипЗНЧ(Документ) = Тип("ДокументСсылка.ЧекККМ")) И Событие = Перечисления.СобытиеСКУД.Вход Тогда
		РегистрыСведений.ЭлектроннаяОчередьКлиентов.ПоставитьОтметкуКПП(Документ);
	КонецЕсли;
	
	ЗарегистрироватьСобытиеВИсторииДоступа(Документ, Датчик, Зона, Событие,РезультатСканированияКПП, Комментарий, ТипСканераКПП);
	Возврат РезультатСканированияКПП;
КонецФункции

#КонецОбласти

#Область РегистрацияВъездаВыезда
//ГЛАВНАЯ
Процедура ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод = "", ЭтоРейс = Ложь, ТЗ_Документов) Экспорт
	
	//Если машина на складе регестрируем выезд без проверок
	Если МашинаНаСкладе(Ссылка) Тогда
		РегистрацияСостоянияВыезда(Ссылка, Штрихкод);
		Возврат;
	КонецЕсли;
					
	//ОБРАБОТКА ДОКУМЕНТОВ			
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОбработатьРеализацию(Ссылка, Штрихкод, ЭтоРейс, ТЗ_Документов);
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		ОбработатьЧек(Ссылка, Штрихкод, ЭтоРейс, ТЗ_Документов);

	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда 
		ОбработатьЗаказПоставщику(Ссылка, Штрихкод, ТЗ_Документов);
		ВнестиВТабельВнутреннегоВодителяРейсОтПоставщика(Ссылка); 
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаданиеНаПеревозкуРейс") Тогда   
		ЗарегистрироватьСостояниеПоРейсу(Ссылка, Штрихкод, Истина, ТЗ_Документов);
		ВнестиВТабельВнутреннегоВодителя(Ссылка); 
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМВозврат") 
		ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.БлокировкаДвиженияТоваров") 
		или ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОбращениеКлиента") или ТипЗнч(Ссылка) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда 
		СтрокаТЗ = ТЗ_Документов.Добавить();
		СтрокаТЗ.Документ = Ссылка;	
		СтрокаТЗ.Штрихкод = Штрихкод;	
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда     
		ОбработатьЗаказКлиента(Ссылка, Штрихкод, ТЗ_Документов);
		
	Иначе
		Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.НеПредусмотренДляСканирования");
		СтрокаТЗ = ТЗ_Документов.Добавить();
		СтрокаТЗ.Документ = Ссылка;
		СтрокаТЗ.Ошибка = Ошибка;
	КонецЕсли;
		
КонецПроцедуры

//ОБРАБОТКА ДОКУМЕНТОВ
Функция ЗарегистрироватьСостояниеПоРейсу(Рейс, Штрихкод, ЭтоРейс = Ложь, ТЗ_Документов)
	
	мДокументовПродажи = ПолучитьДокументыПродажиСервер(Рейс);
	
	Для Каждого Ссылка Из мДокументовПродажи Цикл	
		ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод, ЭтоРейс, ТЗ_Документов);	
	КонецЦикла;
	
	УстановитьСтатусРейса(Рейс);

КонецФункции

Процедура УстановитьСтатусРейса(Ссылка)
	
	Рейс = Ссылка.ПолучитьОбъект();
	Если Ссылка.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ДокументыНаПогрузкуГотовы") ИЛИ Ссылка.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ВодительДокументыПолучил") Тогда
		Рейс.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСНаПогрузке");
	ИначеЕсли Ссылка.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСНаПогрузке") Тогда
		Рейс.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСВПути");
	КонецЕсли;
	Рейс.Записать(РежимЗаписиДокумента.Проведение);
	
	АльтерраОбщегоНазначения.УстановитьСтатусВодителю(Рейс.Водитель, Перечисления.СтатусыВодителей.ВРейсе, "установлен из КПП",, Рейс.Ссылка);
	
КонецПроцедуры

Процедура ОбработатьРеализацию(Ссылка, Штрихкод, ЭтоРейс = Ложь, ТЗ_Документов)
	
	Ошибка = Неопределено; 
	
	Если Не ЭтоРейс Тогда
		Рейс = ПолучитьРейс(Ссылка);
		Если ЗначениеЗаполнено(Рейс) Тогда
			Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДолженСканироватсяМаршрутныйЛист");
		КонецЕсли;
	КонецЕсли;
	
	Если Не ДокументОплачен(Ссылка) Тогда
		Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументНеОплачен");
	ИначеЕсли ДокументОтгружен(Ссылка) Тогда
		Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументПолностьюОтгружен");
	КонецЕсли;
		
	СтрокаТЗ = ТЗ_Документов.Добавить();
	СтрокаТЗ.Документ = Ссылка;
	СтрокаТЗ.Штрихкод = Штрихкод;
	СтрокаТЗ.Ошибка = Ошибка;
	
КонецПроцедуры

Процедура ОбработатьЧек(Ссылка, Штрихкод, ЭтоРейс = Ложь, ТЗ_Документов)
	
	Ошибка = Неопределено; 
	
	Если Не ЭтоРейс Тогда
		Рейс = ПолучитьРейс(Ссылка);
		Если ЗначениеЗаполнено(Рейс) Тогда
			Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДолженСканироватсяМаршрутныйЛист");
		КонецЕсли;
	КонецЕсли;

	Если Не ЧекПробит(Ссылка) Тогда
		Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументНеОплачен");
	ИначеЕсли ДокументОтгружен(Ссылка) Тогда
		Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументПолностьюОтгружен");
	КонецЕсли;
	
	СтрокаТЗ = ТЗ_Документов.Добавить();
	СтрокаТЗ.Документ = Ссылка;
	СтрокаТЗ.Штрихкод = Штрихкод;
	СтрокаТЗ.Ошибка = Ошибка;

КонецПроцедуры

Процедура ОбработатьЗаказПоставщику(Ссылка, Штрихкод, ТЗ_Документов)

	Ошибка = Неопределено;
	СтатусДокумента = ПолучитьСтатус(Ссылка);
	Если СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.НеСогласован") ИЛИ СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.Закрыт") Тогда
		Ошибка = ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.СтатусЗаказаНеКПоступлению");
	КонецЕсли;
	
	СтрокаТЗ = ТЗ_Документов.Добавить();
	СтрокаТЗ.Документ = Ссылка;
	СтрокаТЗ.Штрихкод = Штрихкод;
	СтрокаТЗ.Ошибка = Ошибка;
		
КонецПроцедуры

Процедура ОбработатьЗаказКлиента(Ссылка, Штрихкод, ТЗ_Документов)
	
	мДокументовПродажи = ПолучитьДокументыПродажиСервер(Ссылка); 
	
	Если мДокументовПродажи.Количество() <= 1 Тогда
		СтрокаТЗ = ТЗ_Документов.Добавить();
		СтрокаТЗ.Документ = Ссылка;
		СтрокаТЗ.Штрихкод = Штрихкод;
		СтрокаТЗ.Ошибка = "По заказу клиента нет реализации";
	КонецЕсли;
	
	Для Каждого Ссылка Из мДокументовПродажи Цикл	
		ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод, , ТЗ_Документов);
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

#Область ЗаписьВРегистр
Функция РегистрацияСостоянияЗаезда(Ссылка, Штрихкод = "", Ошибка = Неопределено)
	
	Если НЕ РегистрацияСостояния(Ссылка, Перечисления.СостоянияОтгрузкиДокумента.Заехал, Штрихкод, Ошибка) Тогда
		ЗафиксироватьОшибку(Ссылка, ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ОшибкаРегистрацииЗаезда"), Штрихкод);					;					
	КонецЕсли;
	
КонецФункции

Процедура РегистрацияСостоянияВыезда(Ссылка, Штрихкод = "", Ошибка = Неопределено)  
	
	Если ОшибочнаяРегистрацияНаВъезд(Ссылка) Тогда
		Возврат ;
	КонецЕсли;
	Если НЕ РегистрацияСостояния(Ссылка, Перечисления.СостоянияОтгрузкиДокумента.Выехал, Штрихкод, Ошибка) Тогда
		ЗафиксироватьОшибку(Ссылка, ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ОшибкаРегистрацииВыезда"), Штрихкод);				
	КонецЕсли;
	
КонецПроцедуры

Функция РегистрацияСостояния(Ссылка, Состояние, Штрихкод = "", Ошибка)
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Истина;
	
	ДатаСобытия = ТекущаяДата() + 1 ;
	
	Запись = РегистрыСведений.СостояниеОтгрузкиДокумента.СоздатьМенеджерЗаписи();
	
	Запись.Документ	= Ссылка;
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", Ссылка.Метаданные()) Тогда
		Запись.Филиал = Ссылка.Подразделение;
	КонецЕсли;
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.БлокировкаДвиженияТоваров") Тогда
		Запись.Филиал = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка.Склад,"Подразделение");
	КонецЕсли;
	Запись.Период = ДатаСобытия;	
	Запись.Состояние = Состояние;
	Запись.Штрихкод	= Штрихкод;
	Запись.Ошибка = Ошибка;
	Запись.НомерЗаезда = ПолучитьНомерЗаезда(Ссылка)+1;
	
	Попытка
		Запись.Записать(Ложь);
	Исключение
		Результат = Ложь;	
	КонецПопытки;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПоставщику")И Состояние = Перечисления.СостоянияОтгрузкиДокумента.Заехал Тогда
		ДокументОбъект = Ссылка.ПолучитьОбъект();
		ДокументОбъект.ДатаОтгрузки = ДатаСобытия;
		ДокументОбъект.ДатаПоступления = ДокументОбъект.ДатаОтгрузки + ДокументОбъект.ДлительностьДоставки*86400;
		Для Каждого Товар Из ДокументОбъект.Товары Цикл
		    Товар.ДатаПоступления = ДокументОбъект.ДатаПоступления;
		    Товар.ДатаОтгрузки = ДокументОбъект.ДатаОтгрузки;
	    КонецЦикла;
 		Попытка
			ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
 		Исключение
 		КонецПопытки;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Результат;
	
КонецФункции 

Функция РегистрацияСостоянияОшибка(Ссылка, Ошибка, Штрихкод = "")
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Истина;
	
	ДатаСобытия = ТекущаяДата();
	
	Запись = РегистрыСведений.СостояниеОтгрузкиДокумента.СоздатьМенеджерЗаписи();
	Если ЗначениеЗаполнено(Ссылка) Тогда 
		Запись.Документ	= Ссылка;
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", Ссылка.Метаданные()) Тогда
			Запись.Филиал = Ссылка.Подразделение;
		КонецЕсли;
	КонецЕсли;
	Запись.Период = ДатаСобытия;	
	Запись.Состояние = Перечисления.СостоянияОтгрузкиДокумента.Ошибка;
	Запись.Ошибка = Ошибка;
	Запись.Штрихкод = Штрихкод;
	
	Попытка
		Запись.Записать(Ложь);
	Исключение
		Результат = Ложь;	
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Результат;
	
КонецФункции

Функция ПолучитьНомерЗаезда(Документ)

	МассивСтатусов = Новый Массив();
	МассивСтатусов.Добавить(Перечисления.СостоянияОтгрузкиДокумента.Заехал);
	МассивСтатусов.Добавить(Перечисления.СостоянияОтгрузкиДокумента.Выехал);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостояниеОтгрузкиДокументаСрезПоследних.НомерЗаезда КАК НомерЗаезда
		|ИЗ
		|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(
		|			&Период,
		|			Документ = &Документ
		|				И Состояние В (&МассивСтатусов)) КАК СостояниеОтгрузкиДокументаСрезПоследних";
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.НомерЗаезда;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции 	
	
Процедура ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод = "")
	
	РегистрацияСостоянияОшибка(Ссылка, Ошибка, Штрихкод);
	
КонецПроцедуры

Процедура ЗарегистрироватьСобытиеВУчетеРабочегоВремениСотрудников(Сотрудник, Событие)
	НаборЗаписей = РегистрыСведений.УчетРабочегоВремениСотрудников.СоздатьНаборЗаписей();
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.Период = ТекущаяДата();
	НоваяЗапись.Сотрудник = Сотрудник;
	НоваяЗапись.Пользователь = Сотрудник.Пользователь;
	НоваяЗапись.Подразделение = ?(ЗначениеЗаполнено(Сотрудник.Подразделение), Сотрудник.Подразделение, Сотрудник.Пользователь.ТекущееПодразделение);
	НоваяЗапись.Событие = Событие;

	НаборЗаписей.Записать(Ложь);	
КонецПроцедуры

Процедура ЗарегистрироватьСобытиеВИсторииДоступа(Объект = неопределено, Датчик, ЗонаДоступа, Событие, РезультатСканированияКПП, Комментарий, ТипСканераКПП) Экспорт
	НаборЗаписей = РегистрыСведений.ИсторияДоступа.СоздатьНаборЗаписей();
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.ДатаСобытия = ТекущаяДата();
	НоваяЗапись.Объект = Объект;
	НоваяЗапись.Датчик = Датчик;  
	НоваяЗапись.ЗонаДоступа = ЗонаДоступа;
	НоваяЗапись.Событие = Событие;  
	НоваяЗапись.РезультатСканированияКПП = РезультатСканированияКПП;
	НоваяЗапись.ТипСканераКПП = ТипСканераКПП;
	НоваяЗапись.Комментарий = Комментарий;
	Если ТипЗнч(Объект) = Тип("ДокументСсылка.Пропуск") Тогда
		НоваяЗапись.ФИО = Объект.ФИО;
		НоваяЗапись.ЦельПосещения = Объект.ЦельПосещения;
	КонецЕсли;
	
	НаборЗаписей.Записать(Ложь);
КонецПроцедуры

