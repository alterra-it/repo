Функция ПроверитьВыходВИсторииДоступа(Объект, ЗонаДоступа)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсторияДоступа.Объект КАК Объект
	|ИЗ
	|	РегистрСведений.ИсторияДоступа КАК ИсторияДоступа
	|ГДЕ
	|	ИсторияДоступа.Объект = &Объект
	|	И ИсторияДоступа.ЗонаДоступа = &ЗонаДоступа
	|	И ИсторияДоступа.Событие = &Событие";
	Запрос.УстановитьПараметр("Объект", Объект);   
	Запрос.УстановитьПараметр("ЗонаДоступа", ЗонаДоступа);
	Запрос.УстановитьПараметр("Событие", Перечисления.СобытиеСКУД.Выход);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли; 	
КонецФункции

Функция ПолучитьПоследнююЗаписьРегистраИсторияДосупа(ЗонаДоступа, Объект)
	 			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсторияДоступа.Событие КАК Событие,
	|	ИсторияДоступа.ДатаСобытия КАК ДатаСобытия
	|ИЗ
	|	РегистрСведений.ИсторияДоступа КАК ИсторияДоступа
	|ГДЕ
	|	ИсторияДоступа.Объект = &Объект
	|	И ИсторияДоступа.ЗонаДоступа = &ЗонаДоступа
	|	И ИсторияДоступа.Событие <> ЗНАЧЕНИЕ(Перечисление.СобытиеСКУД.Отказ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСобытия УБЫВ";
	Запрос.УстановитьПараметр("Объект", Объект);
	Запрос.УстановитьПараметр("ЗонаДоступа", ЗонаДоступа);

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка;
	
КонецФункции

Функция ПолучитьРейсОтПоставщика(ЗаказПоставщику) 
		
	Запрос = Новый Запрос;
	Запрос.Текст =
			"ВЫБРАТЬ
			|	Рейсы.Ссылка КАК Ссылка
			|ИЗ
			|	(ВЫБРАТЬ
			|		Рейс.Ссылка КАК Ссылка
			|	ИЗ
			|		Документ.РейсОтПоставщика.РасчетДоставки КАК Рейс
			|	ГДЕ
			|		Рейс.ДокументОснование = &ЗаказПоставщику
			|		И Рейс.Ссылка.Проведен
			|		И Рейс.ДокументОснование ССЫЛКА Документ.ЗаказПоставщику
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		Рейс.Ссылка
			|	ИЗ
			|		Документ.РейсСиламиПоставщика.Основания КАК Рейс
			|	ГДЕ
			|		Рейс.Документ = &ЗаказПоставщику
			|		И Рейс.Ссылка.Проведен) КАК Рейсы
			|
			|СГРУППИРОВАТЬ ПО
			|	Рейсы.Ссылка
			|;";
		
	Запрос.УстановитьПараметр("ЗаказПоставщику", ЗаказПоставщику);
			
	Выборка = Запрос.Выполнить().Выбрать();     

	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка; 
	Иначе 
		Возврат Неопределено;  
	КонецЕсли;
КонецФункции

Функция ПолучитьВсеЗаказыПоРейсуОтПоставщика(ЗаказПоставщику) Экспорт	
	
	
	МассивЗаказов = Новый Массив;
	ПодразделениеТекущегоПользователя = ПользователиКлиентСервер.ТекущийПользователь().Подразделение;
	
	Если ЗначениеЗаполнено(ПодразделениеТекущегоПользователя) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|	Рейсы.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТРейсы
			|ИЗ
			|	(ВЫБРАТЬ
			|		Рейс.Ссылка КАК Ссылка
			|	ИЗ
			|		Документ.РейсОтПоставщика.РасчетДоставки КАК Рейс
			|	ГДЕ
			|		Рейс.ДокументОснование = &ЗаказПоставщику
			|		И Рейс.Ссылка.Проведен
			|		И Рейс.ДокументОснование ССЫЛКА Документ.ЗаказПоставщику
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ
			|		Рейс.Ссылка
			|	ИЗ
			|		Документ.РейсСиламиПоставщика.Основания КАК Рейс
			|	ГДЕ
			|		Рейс.Документ = &ЗаказПоставщику
			|		И Рейс.Ссылка.Проведен) КАК Рейсы
			|
			|СГРУППИРОВАТЬ ПО
			|	Рейсы.Ссылка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Рейс.ДокументОснование КАК Ссылка
			|ПОМЕСТИТЬ ВТЗаказы
			|ИЗ
			|	Документ.РейсОтПоставщика.РасчетДоставки КАК Рейс
			|ГДЕ
			|	Рейс.Ссылка В
			|			(ВЫБРАТЬ
			|				Рейсы.Ссылка
			|			ИЗ
			|				ВТРейсы КАК Рейсы)
			|	И Рейс.ДокументОснование ССЫЛКА Документ.ЗаказПоставщику
			|	И Рейс.ДокументОснование.Подразделение = &Подразделение
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	Рейс.Документ
			|ИЗ
			|	Документ.РейсСиламиПоставщика.Основания КАК Рейс
			|ГДЕ
			|	Рейс.Ссылка В
			|			(ВЫБРАТЬ
			|				Рейсы.Ссылка
			|			ИЗ
			|				ВТРейсы КАК Рейсы)
			|	И Рейс.Документ.Подразделение = &Подразделение
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ПРЕДСТАВЛЕНИЕ(Рейсы.Ссылка) КАК Ссылка
			|ИЗ
			|	ВТРейсы КАК Рейсы
			|
			|СГРУППИРОВАТЬ ПО
			|	Рейсы.Ссылка
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Заказы.Ссылка КАК Ссылка
			|ИЗ
			|	ВТЗаказы КАК Заказы
			|
			|СГРУППИРОВАТЬ ПО
			|	Заказы.Ссылка";
		
		Запрос.УстановитьПараметр("ЗаказПоставщику", ЗаказПоставщику);
		Запрос.УстановитьПараметр("Подразделение", ПодразделениеТекущегоПользователя);
		
		МассивРезультатов = Запрос.ВыполнитьПакет();     

		Выборка = МассивРезультатов[0].Выбрать();
		Если Выборка.Следующий() И Выборка.Количество > 0 Тогда
			Если Выборка.Количество > 1 Тогда
				Сообщение = "Найдено несколько рейсов по данному заказу:";
				
				Выборка = МассивРезультатов[2].Выбрать();
				Пока Выборка.Следующий() Цикл
					Сообщение = Сообщение + Символы.ПС + Выборка.Ссылка;
				КонецЦикла;
				
				ОбщегоНазначения.СообщитьПользователю(Сообщение);
			КонецЕсли;
			
			Выборка = МассивРезультатов[3].Выбрать();
			Пока Выборка.Следующий() Цикл
				МассивЗаказов.Добавить(Выборка.Ссылка);
			КонецЦикла;
		КонецЕсли;
	Иначе
		ОбщегоНазначения.СообщитьПользователю("Необходимо указать подразделение для текущего пользователя!");
	КонецЕсли;

	Возврат МассивЗаказов; 
	
КонецФункции

