#Область ВспомогательныеФункции   

Функция ПолучитьДокументПоQRКоду(ТипДокумента, QRКод) 
	
	Запрос = Новый Запрос;
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
			      |	Документ.Ссылка КАК Ссылка,
			      |	Документ.QRкод КАК QRкод,
			      |	Документ.Дата КАК Дата
			      |ИЗ
			      |	Документ.&ТипДокумента КАК Документ
			      |ГДЕ
			      |	Документ.QRкод = &QRкод
			      |
			      |УПОРЯДОЧИТЬ ПО
			      |	Дата УБЫВ"; 
	
	ТекстЗапроса = СтрЗАменить(ТекстЗапроса, "&ТипДокумента", ТипДокумента);
	
	Запрос.Текст = ТекстЗапроса; 
	Запрос.УстановитьПараметр("QRкод", QRкод); 
	Выборка = Запрос.Выполнить().Выбрать();	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка; 
	Иначе
		Возврат Неопределено; 
	КонецЕсли;	
	
КонецФункции

Функция ДокументОплачен(Ссылка)
	
	Возврат (Ссылка.Проведен И Не Ссылка.Кассир.Пустая()) Или ОплаченоНаКСО(Ссылка);
	
КонецФункции

Функция ЧекПробит(Ссылка)
	
	Возврат (Ссылка.Статус = Перечисления.СтатусыЧековККМ.Пробит) Или ОплаченоНаКСО(Ссылка);
	
КонецФункции    

Функция ОплаченоНаКСО(Ссылка)
	
	Запрос = Новый Запрос;  
	
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	&Ссылка	
		|ИЗ
		|	Документ.ЧекСамообслуживания       
		|ГДЕ 
		|	%Документ = &Ссылка	
		|	И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
		|	И ТипПродажи В (11, 21)
		|	И (ДатаОтправкиНаПробитие = ДАТАВРЕМЯ(1, 1, 1) 
		|		ИЛИ ДатаРезультатаПробития = ДАТАВРЕМЯ(1, 1, 1) 
		|		ИЛИ ОшибкаЗаписиДокумента <> &ПустаяСтрока)";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Документ", ?(ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ"), "ЧекККМ", "Реализация"));
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");   
	
	Возврат Не Запрос.Выполнить().Пустой();
				
КонецФункции				

Функция ДокументОтгружен(Ссылка)
	
	флДокументОтгружен = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Кладовщик = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|	И РеализацияТоваровУслугТовары.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Ссылка
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|ГДЕ
	|	ЧекККМТовары.Кладовщик = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|	И ЧекККМТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		флДокументОтгружен = Ложь;
	КонецЕсли;
	
	Возврат флДокументОтгружен;
	
КонецФункции

Функция ПолучитьРейс(Ссылка)
	
	Рейс = Документы.ЗаданиеНаПеревозкуРейс.ПолучитьРейсПоДокументуПродажи(Ссылка);
