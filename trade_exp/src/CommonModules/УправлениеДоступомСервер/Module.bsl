Процедура ВнестиВТабельВнутреннегоВодителяРейсОтПоставщика(Ссылка)  
	Рейс = ПолучитьРейсОтПоставщика(Ссылка); 
	Если Рейс <> неопределено и ТипЗнч(Рейс) = Тип("ДокументСсылка.РейсОтПоставщика") Тогда  
		Запрос = Новый запрос; 
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
                    |	Сотрудники.Ссылка КАК Ссылка,
                    |	РейсОтПоставщика.Автомобиль КАК Автомобиль,
					|	РейсОтПоставщика.Статус КАК Статус
                    |ИЗ
                    |	Документ.РейсОтПоставщика КАК РейсОтПоставщика
                    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
                    |		ПО РейсОтПоставщика.Водитель.Наименование = Сотрудники.Наименование
                    |ГДЕ
                    |	РейсОтПоставщика.Ссылка = &Ссылка
                    |	И Сотрудники.Водитель = ИСТИНА"; 
		Запрос.УстановитьПараметр("Ссылка", Рейс); 
		Выборка = Запрос.Выполнить().Выбрать(); 
		Если Выборка.Следующий() Тогда  
			Погрузка = Перечисления.ВидЗанятостиВодителей.Погрузка;
			Если не НашВодительОтПоставщикаНаСкладе(Рейс, Выборка.Ссылка)  Тогда 
				СоздатьЗаписьВодителя(Выборка.Ссылка, Выборка.Автомобиль, Погрузка, Рейс); 
			Иначе 
				ОбновитьЗаписьВодителя(Выборка.Ссылка, Выборка.Автомобиль, Погрузка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
