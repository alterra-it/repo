Функция ОбработатьЗапросSKUD(Ид, Штрихкод, Датчик = Неопределено, Зона = Неопределено, ТипСканераКПП = неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ЗначениеЗаполнено(Датчик) Тогда 
		Датчик = Справочники.ДатчикиСКУД.НайтиПоКоду(Ид, Истина);
		Если Датчик <> Справочники.ДатчикиСКУД.ПустаяСсылка() Тогда
			Зона = ПолучитьЗонуДоступаДатчика(Датчик);
		Иначе 
			Сообщить("Не найден датчик по ID: "+Ид);
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.НеНайденДатчик;
			Возврат РезультатСканированияКПП;
	КонецЕсли;
	КонецЕсли;     
	
	
	Результат = Неопределено;
	СсылкаДокумент = Неопределено; 
	
	Если Лев(Штрихкод, 4) = "8888" Тогда // Это сотрудник 
		Результат = ОбработатьСканированиеБейджикаСотрудника(Датчик, Зона, Штрихкод, ТипСканераКПП); 
	ИначеЕсли  Лев(Штрихкод, 4) = "9999" и СтрДлина(Штрихкод) = 14 Тогда // Это БейджВодителя 
		Результат = ОбработатьСканированиеБейджикаВодителя(Датчик, Зона, Штрихкод, ТипСканераКПП); 
	
	//Обрабатываем QR-код документа 
	ИначеЕсли Лев(Штрихкод,3) = "110" и СтрДлина(Штрихкод) = 14 Тогда //Это QR код 
		Если Лев(Штрихкод,4) = "1101" Тогда //Это разовый пропуск 
			СсылкаДокумент = ПолучитьДокументПоQRКоду("Пропуск", Штрихкод);			 
		КонецЕсли; 
		
		Если Лев(Штрихкод,4) = "1102" Тогда //Это заказ поставщику 
			СсылкаДокумент = ПолучитьДокументПоQRКоду("ЗаказПоставщику", Штрихкод); 
		КонецЕсли;      
		
		Если Лев(Штрихкод,4) = "1103" или Лев(Штрихкод,4) = "1104" Тогда //Это печать по секциям
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ШтрихкодыПоСекциямДокумента.Документ КАК Документ,
			|	ШтрихкодыПоСекциямДокумента.ДатаФормирования КАК ДатаФормирования
			|ИЗ
			|	РегистрСведений.ШтрихкодыПоСекциямДокумента КАК ШтрихкодыПоСекциямДокумента
			|ГДЕ
			|	ШтрихкодыПоСекциямДокумента.QRкод = &QRкод
			|
			|УПОРЯДОЧИТЬ ПО
			|	ДатаФормирования УБЫВ";
			
			Запрос.УстановитьПараметр("QRкод", Штрихкод);
			
			Выборка = Запрос.Выполнить().Выбрать();	
			Если Выборка.Следующий() Тогда
				СсылкаДокумент = Выборка.Документ; 
			КонецЕсли;
			
		КонецЕсли;
		
		Если Лев(Штрихкод,4) = "1105" Тогда //Это рейс
			СсылкаДокумент = ПолучитьДокументПоQRКоду("ЗаданиеНаПеревозкуРейс", Штрихкод);
		КонецЕсли;		
		Если Лев(Штрихкод,4) = "1106" Тогда //Это печать по секциям
			СсылкаДокумент = ПолучитьДокументПоQRКоду("КорректировкаРеализации", Штрихкод);			
		КонецЕсли;
	КонецЕсли; 
	
	Если Результат = неопределено Тогда //Это документ. Бейджик уже был бы обработан 
		
		Если СсылкаДокумент = Неопределено Тогда //Отсканировали штрихкод
			МассивСсылок = СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод);
			Если МассивСсылок.Количество() = 0 Тогда //Не нашли ничего по отсканированной строке				
				Если СтрДлина(Штрихкод) = 14 Тогда 
					Комментарий = "На стойке считан штрихкод: " + Штрихкод;
					РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.СчитанШтрихкодНаСтойке; 
					ЗарегистрироватьСобытиеВИсторииДоступа("ОбъектНеНайден" , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
					Возврат РезультатСканированияКПП;	
				Иначе 
					Комментарий = "Документ не найден: " + Штрихкод;
					РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ОбъектНеНайден; 
					ЗарегистрироватьСобытиеВИсторииДоступа("ОбъектНеНайден" , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
					Возврат РезультатСканированияКПП; 
				КонецЕсли; 
			Иначе
				Документ = МассивСсылок[0];
			КонецЕсли;
		Иначе
			Документ = СсылкаДокумент; 
		КонецЕсли;
		
		ПоследняяЗапись = ПолучитьПоследнююЗаписьРегистраИсторияДосупа(Зона, Документ); 
		
		// Исключаем ошибочное сканирование
		Если ПоследняяЗапись.ДатаСобытия <> Неопределено Тогда
			Если ТекущаяДата()- ПоследняяЗапись.ДатаСобытия <= 60 Тогда
				РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ПовторноеСканирование;
				Возврат РезультатСканированияКПП;
			КонецЕсли;
		КонецЕсли;
							
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.Пропуск") Тогда	
			Результат = ОбработатьСканированиеПропуска(Документ, Датчик, Зона, Штрихкод, ТипСканераКПП); 	
		Иначе	
			Результат = ОбработатьСканированиеПечатнойФормыДокумента(Документ, Датчик, Зона, Штрихкод, ТипСканераКПП);	
		КонецЕсли;	
	
	КонецЕсли; 
	УстановитьПривилегированныйРежим(Ложь);  
	
	
	Возврат Результат;
	
КонецФункции

#Область События
Функция ОбработатьСканированиеБейджикаСотрудника(Датчик, Зона, Штрихкод, ТипСканераКПП)
	
	//БЛОК ПРОВЕРОК 
	
	//Проверяем корректность бейджа
	Сотрудник = Справочники.Сотрудники.НайтиПоКоду(Штрихкод);
	Если Сотрудник = Справочники.Сотрудники.ПустаяСсылка() Тогда
		Комментарий = "Не найден сотрудник: " + Штрихкод ;  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ОбъектНеНайден; 
		ЗарегистрироватьСобытиеВИсторииДоступа("ОбъектНеНайден" , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли;
	
	// Проверяем вхождение зоны доступа сотрудника в зону датчика
	Если ЗначениеЗаполнено(Сотрудник.УровеньДоступа) Тогда
		ЗоныДоступа = Сотрудник.УровеньДоступа.ЗоныДоступа.Выгрузить();
	Иначе 
		Если ЗначениеЗаполнено(Сотрудник.Отдел.УровеньДоступа)Тогда
			ЗоныДоступа = Сотрудник.Отдел.УровеньДоступа.ЗоныДоступа.Выгрузить();
		Иначе
			Комментарий = "Не найдена зона доступа сотрудника";
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.НетДоступа;
			ЗарегистрироватьСобытиеВИсторииДоступа(Сотрудник, Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
			Возврат РезультатСканированияКПП;
		КонецЕсли;
	КонецЕсли;
	
	ТЗ_ЗонаД = Новый ТаблицаЗначений();
	ТЗ_ЗонаД.Колонки.Добавить("ЗонаД");
	Для Каждого Стр Из ЗоныДоступа Цикл
		Если Зона = Стр.ЗонаДоступа Тогда 
			СтрокаТЗ = ТЗ_ЗонаД.Добавить();
			СтрокаТЗ.ЗонаД = Стр.ЗонаДоступа;
		КонецЕсли;
	КонецЦикла;
	
	Если ТЗ_ЗонаД.Количество() = 0 Тогда
		Комментарий = "Зона доступа сотрудника не входит в зону доступа датчика"; 
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.НетДоступа;
		ЗарегистрироватьСобытиеВИсторииДоступа(Сотрудник, Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли; 
	
	
	//Проверяем не уволен ли сотрудник
	Если Сотрудник.Уволен Или Сотрудник.ПометкаУдаления Тогда
		Комментарий = "Сотрудник уволен"; 
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ОбъектУдален;
		ЗарегистрироватьСобытиеВИсторииДоступа(Сотрудник, Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли; 
	
	//Проверяем на повторное сканирование
	ПоследняяЗапись = ПолучитьПоследнююЗаписьРегистраИсторияДосупа(Зона, Сотрудник); 
	Если ПоследняяЗапись.ДатаСобытия <> Неопределено Тогда 
		Если (ТекущаяДата() - ПоследняяЗапись.ДатаСобытия) <= 60 Тогда
			Комментарий = "Повторное сканирование"; 
			РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ПовторноеСканирование;
			ЗарегистрироватьСобытиеВИсторииДоступа(Сотрудник, Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
			Возврат РезультатСканированияКПП;	
		КонецЕсли; 
	КонецЕсли; 
	
	//Определяем ВходВыход
	Если ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВъезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Вход; 
		СобытиеДляТабеля = Перечисления.СостоянияСотрудников.Зашел;
	ИначеЕсли ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВыезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Выход; 
		СобытиеДляТабеля = Перечисления.СостоянияСотрудников.Вышел;
	Иначе //Ручной или стационарный для сотрудников
		Если ПоследняяЗапись.ДатаСобытия = Неопределено Тогда //Сотрудник впервые отсканировался 
			Событие = Перечисления.СобытиеСКУД.Вход; 
			СобытиеДляТабеля = Перечисления.СостоянияСотрудников.Зашел;
		Иначе
			Если НачалоДня(ПоследняяЗапись.ДатаСобытия) < НачалоДня(ТекущаяДата()) Тогда //Последнее событие было вчера
				Событие = Перечисления.СобытиеСКУД.Вход; 
				СобытиеДляТабеля = Перечисления.СостоянияСотрудников.Зашел;
			Иначе
				// Общая проверка
				Если  ПоследняяЗапись.Событие = Перечисления.СобытиеСКУД.Выход Тогда // Вышел или ещё не было
					Событие = Перечисления.СобытиеСКУД.Вход; 
					СобытиеДляТабеля = Перечисления.СостоянияСотрудников.Зашел;
				Иначе
					Событие = Перечисления.СобытиеСКУД.Выход; 
					СобытиеДляТабеля = Перечисления.СостоянияСотрудников.Вышел;
				КонецЕсли;
			КонецЕсли;    
		КонецЕсли;
	КонецЕсли; 
		
	Если Датчик.УчитыватьВТабеле Тогда
		//Добавляем запись о входе или выходе в регистр УчетРабочегоВремениСотрудников
		ЗарегистрироватьСобытиеВУчетеРабочегоВремениСотрудников(Сотрудник, СобытиеДляТабеля);
	КонецЕсли;
	
	//Фиксируем результат сканирования.
	Комментарий = ""; 
	Если Событие = Перечисления.СобытиеСКУД.Вход Тогда 
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВход; 
	Иначе
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВыход;   
	КонецЕсли;    
	
	Если Сотрудник.Водитель Тогда 
		Если ВодительОбслуживаетТС(Сотрудник,Перечисления.ВидЗанятостиВодителей.ОбслуживаниеТС) Тогда 
			ОбновитьЗаписьВодителя(Сотрудник, Неопределено, Перечисления.ВидЗанятостиВодителей.ОбслуживаниеТС); 
		Иначе
			СоздатьЗаписьВодителя(Сотрудник, Неопределено, Перечисления.ВидЗанятостиВодителей.ОбслуживаниеТС, ""); 
		КонецЕсли;
	КонецЕсли;

	//Регистрируем успешный входВыход в истории доступа
	ЗарегистрироватьСобытиеВИсторииДоступа(Сотрудник, Датчик, Зона, Событие, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
	Возврат РезультатСканированияКПП;
	
КонецФункции    

функция ВодительОбслуживаетТС(Водитель, ВидЗанятости)  
	Запрос = Новый Запрос; 
	Запрос.Текст =  "ВЫБРАТЬ ПЕРВЫЕ 1
	                |	УчетВремениВодителей.Период КАК Период,
	                |	УчетВремениВодителей.Водитель КАК Водитель,
	                |	УчетВремениВодителей.КонецОтсчета КАК КонецОтсчета,
	                |	УчетВремениВодителей.НачалоОтсчета КАК НачалоОтсчета,
	                |	УчетВремениВодителей.ТранспортноеСредство КАК ТранспортноеСредство,
	                |	УчетВремениВодителей.ВидЗанятости КАК ВидЗанятости,
	                |	УчетВремениВодителей.ОснованиеВремени КАК ОснованиеВремени,
	                |	УчетВремениВодителей.Комментарий КАК Комментарий,
	                |	УчетВремениВодителей.НужнаКорректировка КАК НужнаКорректировка
	                |ИЗ
	                |	РегистрСведений.УчетВремениВодителей КАК УчетВремениВодителей
	                |ГДЕ
	                |	УчетВремениВодителей.ВидЗанятости = &ВидЗанятости 
	                |	И УчетВремениВодителей.Водитель = &Водитель 
					|	И УчетВремениВодителей.НужнаКорректировка = ИСтина
					|	И УчетВремениВодителей.Период >= &Период
					|
	                |УПОРЯДОЧИТЬ ПО
	                |	Период УБЫВ"; 
					
	Запрос.УстановитьПараметр("Водитель", Водитель);  
	Запрос.УстановитьПараметр("ВидЗанятости", ВидЗанятости);
	Запрос.УстановитьПараметр("Период", НачалоДня(ТекущаяДата()));
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
		Возврат Истина; 
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция ОбработатьСканированиеБейджикаВодителя(Датчик, Зона, Штрихкод, ТипСканераКПП)
 
	// Ищем водителя
	Запрос = Новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ
	                 |	Сотрудники.Ссылка КАК Ссылка,
	                 |	СотрудникиБейджыВодителя.Наименование КАК Наименование,
					 |	СотрудникиБейджыВодителя.ТранспортноеСредство КАК ТранспортноеСредство
	                 |ИЗ
	                 |	Справочник.Сотрудники.БейджыВодителя КАК СотрудникиБейджыВодителя
	                 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	                 |		ПО СотрудникиБейджыВодителя.Ссылка = Сотрудники.Ссылка
	                 |ГДЕ
	                 |	СотрудникиБейджыВодителя.Штрихкод = &Штрихкод" ; 
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод); 
	Выборка = ЗАпрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 
		Сотрудник = Выборка.Ссылка; 
		ВодительТС = Выборка.Наименование;
		ТранспортноеСредство = ВЫборка.ТранспортноеСредство; 
	Иначе
		Комментарий = "Не найден сотрудник: " + Штрихкод;  
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.ОбъектНеНайден; 
		ЗарегистрироватьСобытиеВИсторииДоступа("ОбъектНеНайден" , Датчик, Зона, Перечисления.СобытиеСКУД.Отказ, РезультатСканированияКПП, Комментарий, ТипСканераКПП);
		Возврат РезультатСканированияКПП;
	КонецЕсли;
	
	//ПолучаемПоследнююЗапись
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	                |	УчетВремениВодителей.Период КАК Период,
	                |	УчетВремениВодителей.Водитель КАК Водитель,
	                |	УчетВремениВодителей.КонецОтсчета КАК КонецОтсчета,
	                |	УчетВремениВодителей.НачалоОтсчета КАК НачалоОтсчета,
	                |	УчетВремениВодителей.ТранспортноеСредство КАК ТранспортноеСредство,
	                |	УчетВремениВодителей.ВидЗанятости КАК ВидЗанятости,
	                |	УчетВремениВодителей.ОснованиеВремени КАК ОснованиеВремени,
	                |	УчетВремениВодителей.Комментарий КАК Комментарий,
	                |	УчетВремениВодителей.НужнаКорректировка КАК НужнаКорректировка
	                |ИЗ
	                |	РегистрСведений.УчетВремениВодителей КАК УчетВремениВодителей
	                |ГДЕ
	                |	УчетВремениВодителей.ТранспортноеСредство = &ТранспортноеСредство 
	                |	И УчетВремениВодителей.Водитель = &Водитель  
					|	И УчетВремениВодителей.НужнаКорректировка = ИСтина
					|	И УчетВремениВодителей.Период >= &Период
					|
	                |УПОРЯДОЧИТЬ ПО
	                |	Период УБЫВ";
	Запрос.УстановитьПараметр("ТранспортноеСредство", ТранспортноеСредство);
	Запрос.УстановитьПараметр("Водитель", Сотрудник); 
	Запрос.УстановитьПараметр("Период", НачалоДня(ТекущаяДата()));

	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();

	
	Если не Выборка.Следующий() Тогда // Нет записей в регистре
		НачалоРейса = Истина; 
	Иначе
		НачалоРейса = Ложь;
	КонецЕсли; 
	
	//Регистрируем учет времени водителей 
	Если НачалоРейса Тогда 
		ВидЗанятости = Перечисления.ВидЗанятостиВодителей.Рейс;
		СоздатьЗаписьВодителя(Сотрудник, ТранспортноеСредство, ВидЗанятости, ""); 
	Иначе   
		ВидЗанятости = Перечисления.ВидЗанятостиВодителей.Рейс;
		ОбновитьЗаписьВодителя(Сотрудник, ТранспортноеСредство, ВидЗанятости);
	КонецЕсли;        
	
	//Определяем ВходВыход
	Если ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВъезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Вход; 
	ИначеЕсли ТипСканераКПП = Перечисления.ТипСканераКПП.СтационарныйВыезд Тогда 
		Событие = Перечисления.СобытиеСКУД.Выход; 
	Иначе //Ручной или стационарный для сотрудников
		Если НачалоРейса Тогда //Сотрудник впервые отсканировался 
			Событие = Перечисления.СобытиеСКУД.Вход; 
		Иначе
			Событие = Перечисления.СобытиеСКУД.Выход;   
		КонецЕсли;
	КонецЕсли; 
			
	//Фиксируем результат сканирования.
	Комментарий = ""; 
	Если Событие = Перечисления.СобытиеСКУД.Вход Тогда 
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВход; 
	Иначе
		РезультатСканированияКПП = Перечисления.РезультатСканированияКПП.УспешныйВыход;   
	КонецЕсли;    
	
	//Регистрируем успешный входВыход в истории доступа
	ЗарегистрироватьСобытиеВИсторииДоступа(Сотрудник, Датчик, Зона, Событие, РезультатСканированияКПП, ВодительТС, ТипСканераКПП);
	Возврат РезультатСканированияКПП;	
КонецФункции 

