	                |	УчетВремениВодителей.НужнаКорректировка КАК НужнаКорректировка
	                |ИЗ
	                |	РегистрСведений.УчетВремениВодителей КАК УчетВремениВодителей
	                |ГДЕ
	                |	УчетВремениВодителей.НужнаКорректировка = ИСТИНА
	                |	И УчетВремениВодителей.Водитель = &Водитель
	                |	И УчетВремениВодителей.ТранспортноеСредство = &ТранспортноеСредство   
					|	И УчетВремениВодителей.ВидЗанятости = &ВидЗанятости
	                |
	                |УПОРЯДОЧИТЬ ПО
	                |	Период УБЫВ"; 
					
	Запрос.УстановитьПараметр("Водитель", Водитель);  
	Запрос.УстановитьПараметр("ТранспортноеСредство", ТранспортноеСредство); 
	Запрос.УстановитьПараметр("ВидЗанятости", ВидЗанятости);
