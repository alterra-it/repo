	 |			ТОГДА 0
	 |		ИНАЧЕ ВЫБОР
	 |				КОГДА ВТ_ТоварыИтоги.Длина > 0
	 |					ТОГДА ВТ_ТоварыИтоги.Длина
	 |				ИНАЧЕ &ТекстЗапросаДлинаНоменклатуры
	 |			КОНЕЦ / ВнешняяТаблицаНарезки.КоличествоРезов
	 |	КОНЕЦ КАК МаксимальныйОтрезок,
	 |	ВЫБОР
	 |		КОГДА ВТ_ТоварыИтоги.Длина > 0
	 |			ТОГДА ВТ_ТоварыИтоги.Длина
	 |		ИНАЧЕ &ТекстЗапросаДлинаНоменклатуры
	 |	КОНЕЦ / ЕСТЬNULL(ВнешняяТаблицаНарезки.КоличествоРезов, 1) КАК Длина,
	 |	ВЫРАЗИТЬ(ВЫБОР
	 |			КОГДА ГабаритыТовара.Ширина ЕСТЬ NULL
	 |					ИЛИ ГабаритыТовара.Ширина = НЕОПРЕДЕЛЕНО
	 |				ТОГДА -1
	 |			ИНАЧЕ ВЫБОР
	 |					КОГДА ГабаритыТовара.Ширина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
	 |						ТОГДА ВТ_ТоварыИтоги.Количество
	 |					ИНАЧЕ ГабаритыТовара.Ширина
	 |				КОНЕЦ
	 |		КОНЕЦ КАК ЧИСЛО) КАК Ширина,
	 |	ВЫРАЗИТЬ(ВЫБОР
	 |			КОГДА ГабаритыТовара.Высота ЕСТЬ NULL
	 |					ИЛИ ГабаритыТовара.Высота = НЕОПРЕДЕЛЕНО
	 |				ТОГДА -1
	 |			ИНАЧЕ ВЫБОР
	 |					КОГДА ГабаритыТовара.Высота = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
	 |						ТОГДА ВТ_ТоварыИтоги.Количество
	 |					ИНАЧЕ ГабаритыТовара.Высота
	 |				КОНЕЦ
	 |		КОНЕЦ КАК ЧИСЛО) КАК Высота,
	 |	ВЫРАЗИТЬ(ВЫБОР
	 |			КОГДА ГабаритыТовара.Вес ЕСТЬ NULL
	 |					ИЛИ ГабаритыТовара.Вес = НЕОПРЕДЕЛЕНО
	 |				ТОГДА -1
	 |			ИНАЧЕ ВЫБОР
	 |					КОГДА ГабаритыТовара.Вес = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
	 |						ТОГДА ВТ_ТоварыИтоги.Количество
	 |					ИНАЧЕ ГабаритыТовара.Вес
	 |				КОНЕЦ
	 |		КОНЕЦ КАК ЧИСЛО) КАК Вес
	 |ПОМЕСТИТЬ ВТ_ТоварыНарезка
	 |ИЗ
	 |	ВТ_ТоварыИтоги КАК ВТ_ТоварыИтоги
	 |		ЛЕВОЕ СОЕДИНЕНИЕ ВнешняяТаблицаНарезки КАК ВнешняяТаблицаНарезки
	 |		ПО (ВнешняяТаблицаНарезки.Номенклатура = ВТ_ТоварыИтоги.Номенклатура)
	 |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГабаритыТовара КАК ГабаритыТовара
	 |		ПО ВТ_ТоварыИтоги.Номенклатура = ГабаритыТовара.Номенклатура
	 |;
	 |	
	 |////////////////////////////////////////////////////////////////////////////////
	 |";

	Возврат Текст;
	
КонецФункции

