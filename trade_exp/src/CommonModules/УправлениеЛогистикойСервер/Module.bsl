Функция ПолучитьТаблицуРазгрузкиТовара(Объект) Экспорт
	  
	Запрос = Новый Запрос;

	ТекстЗапроса = "";
		
	Если ТипЗнч(Объект) = Тип("ДокументСсылка.ЗаказНаДоставкуКлиенту") Тогда		
		ТекстЗапроса = ТекстЗапросаТоварыСУчетомНарезкиПоОснованиям();
		Запрос.УстановитьПараметр("МассивДокументов", Объект.Основания.Выгрузить(,"Документ"));
	ИначеЕсли ТипЗнч(Объект) = Тип("Структура") Тогда
		ТекстЗапроса = ТекстЗапросаТоварыСУчетомНарезкиДляСайта();
		Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры", Объект.Товары);
		Запрос.УстановитьПараметр("ВнешняяТаблицаНарезки", Объект.Нарезка); 
	Иначе
		Если Объект.Свойство("Основания") Тогда
			ТекстЗапроса = ТекстЗапросаТоварыСУчетомНарезкиПоОснованиям();
			Запрос.УстановитьПараметр("МассивДокументов", Объект.Основания.Выгрузить(,"Документ"));
		ИначеЕсли Объект.Свойство("ОснованияДоставки")  И Объект.ОснованияДоставки.Количество() >0 Тогда 
			ТекстЗапроса = ТекстЗапросаТоварыСУчетомНарезкиПоОснованиям(Истина);
			Запрос.УстановитьПараметр("МассивДокументов", Объект.ОснованияДоставки.Выгрузить(,"Документ"));
            Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры", Объект.Товары.Выгрузить());
			Запрос.УстановитьПараметр("ВнешняяТаблицаНарезки", Объект.Нарезка.Выгрузить());
		Иначе 
			ТекстЗапроса = ТекстЗапросаТоварыСУчетомНарезкиПоОбъекту();
			Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры", Объект.Товары.Выгрузить());
			Запрос.УстановитьПараметр("ВнешняяТаблицаНарезки", Объект.Нарезка.Выгрузить());
		КонецЕсли;
	КонецЕсли;
		
	Запрос.Текст = ТекстЗапроса +
	
		"ВЫБРАТЬ Различные
		|	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	    |	&ТекстЗапросаВесНоменклатуры КАК Вес
		|   Поместить ВесОбычный
	    |ИЗ
	    |	ВТ_ТоварыНарезка КАК ТаблицаНоменклатуры 
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |  ВЫБРАТЬ
	    |	ТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	    |	ТаблицаНоменклатуры.Количество КАК Количество,
	    |	ТаблицаНоменклатуры.Длина КАК Длина,
        |	ВЫБОР 
		|       КОГДА ТаблицаНоменклатуры.Вес <0 ТОГДА
		|           ВесОбычный.Вес 
		|       ИНАЧЕ 
		|           ТаблицаНоменклатуры.Вес
		|   КОНЕЦ КАК ВесЕдиницыДляРазгрузки,
	    |	ВесОбычный.Вес КАК Вес,
	    |	ВЫБОР
	    |		КОГДА ТаблицаНоменклатуры.Высота < 0
	    |			ТОГДА &ТекстЗапросаОбъемНоменклатуры
	    |		ИНАЧЕ ТаблицаНоменклатуры.Длина * ТаблицаНоменклатуры.Ширина * ТаблицаНоменклатуры.Высота
	    |	КОНЕЦ * ТаблицаНоменклатуры.Количество КАК Объем,
	    |	ВЫБОР
	    |		КОГДА ТаблицаНоменклатуры.Ширина < 0
	    |			ТОГДА &ТекстЗапросаПлощадьНоменклатуры
	    |		КОГДА ТаблицаНоменклатуры.МаксимальныйОтрезок = 0
	    |			ТОГДА ТаблицаНоменклатуры.Ширина * ТаблицаНоменклатуры.Длина
	    |		ИНАЧЕ ТаблицаНоменклатуры.Ширина * ТаблицаНоменклатуры.МаксимальныйОтрезок
	    |	КОНЕЦ КАК Площадь
	    |ПОМЕСТИТЬ ВТ_ХарактеристикиТовара
	    |ИЗ
	    |	ВТ_ТоварыНарезка КАК ТаблицаНоменклатуры 
		|   Левое Соединение ВесОбычный КАК ВесОбычный 
		|   ПО  (ТаблицаНоменклатуры.Номенклатура = ВесОбычный.Номенклатура)
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ
	    |	ВТ_ВесОбъем.Номенклатура КАК Номенклатура,
	    |	ВТ_ВесОбъем.Длина КАК Длина,
	    |	ВТ_ВесОбъем.Площадь КАК Площадь,
	    |	ВТ_ВесОбъем.Объем КАК Объем,
	    |	ВТ_ВесОбъем.Количество КАК Количество,
	    |	ВЫБОР
	    |		КОГДА ВТ_ВесОбъем.Объем > 0
	    |			ТОГДА ВЫБОР
	    |					КОГДА (ВТ_ВесОбъем.Вес * ВТ_ВесОбъем.Количество) / (ВТ_ВесОбъем.Объем * 1000) < 0.1
	    |						ТОГДА &Коэффициент * ВТ_ВесОбъем.Объем * 1000
	    |					ИНАЧЕ ВТ_ВесОбъем.Вес * ВТ_ВесОбъем.Количество
	    |				КОНЕЦ
	    |		ИНАЧЕ ВТ_ВесОбъем.Вес * ВТ_ВесОбъем.Количество
	    |	КОНЕЦ КАК Вес,
	    |	ВЫБОР
	    |		КОГДА Лифт.Lmax >= ВТ_ВесОбъем.Длина
	    |				И Лифт.Smax >= ВТ_ВесОбъем.Площадь 
		|               И  Лифт.ВесМакс >= ВТ_ВесОбъем.ВесЕдиницыДляРазгрузки
	    |			ТОГДА ИСТИНА
	    |		ИНАЧЕ ЛОЖЬ
	    |	КОНЕЦ КАК Лифт,
	    |	ВЫБОР
	    |		КОГДА Лестница.Lmax >= ВТ_ВесОбъем.Длина
	    |				И Лестница.Smax >= ВТ_ВесОбъем.Площадь
		|               И Лестница.ВесМакс >= ВТ_ВесОбъем.ВесЕдиницыДляРазгрузки
	    |			ТОГДА ИСТИНА
	    |		ИНАЧЕ ЛОЖЬ
	    |	КОНЕЦ КАК Лестница,
	    |	ВЫБОР
	    |		КОГДА Разгрузка.Lmax >= ВТ_ВесОбъем.Длина
	    |				И Разгрузка.Smax >= ВТ_ВесОбъем.Площадь 
		|               И Разгрузка.ВесМакс >= ВТ_ВесОбъем.ВесЕдиницыДляРазгрузки
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Разгрузка,
		|	ВЫБОР
		|		КОГДА ВТ_ВесОбъем.Длина > &ДлинаНегабарита ИЛИ ВТ_ВесОбъем.Площадь > &ПлощадьНегабарита 
		|              ИЛИ ВТ_ВесОбъем.ВесЕдиницыДляРазгрузки > &ВесНегабарита
		|			ТОГДА 1
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Негабарит,
		|	ВЫБОР
		|		КОГДА ЛифтГруз.Lmax >= ВТ_ВесОбъем.Длина
	    |				И ЛифтГруз.Smax >= ВТ_ВесОбъем.Площадь
		|               И ЛифтГруз.ВесМакс >= ВТ_ВесОбъем.ВесЕдиницыДляРазгрузки
	    |			ТОГДА ИСТИНА
	    |		ИНАЧЕ ЛОЖЬ
	    |	КОНЕЦ КАК ЛифтГрузовой,
		|	ВЫБОР
		|		КОГДА ВТ_ВесОбъем.Объем > 0
		|			ТОГДА ВЫБОР
		|				КОГДА ВТ_ВесОбъем.Вес * ВТ_ВесОбъем.Количество / (ВТ_ВесОбъем.Объем * 1000) < 0.1
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК КрупногабаритныйМаловесныйТовар,
		|	ВТ_ВесОбъем.Вес * ВТ_ВесОбъем.Количество КАК ВесФакт,
		|   ВТ_ВесОбъем.ВесЕдиницыДляРазгрузки  КАК ВесЕдиницыДляРазгрузки
	    |ПОМЕСТИТЬ ВТ_ДоступныеВидыРазгрузки
	    |ИЗ
	    |	ВТ_ХарактеристикиТовара КАК ВТ_ВесОбъем
	    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыРазгрузкиКлиента КАК Разгрузка
	    |		ПО (НЕ Разгрузка.ПометкаУдаления)
	    |			И (Разгрузка.Способ = ЗНАЧЕНИЕ(Перечисление.СпособыРазгрузки.Разгрузка))
	    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыРазгрузкиКлиента КАК Лестница
	    |		ПО (НЕ Лестница.ПометкаУдаления)
	    |			И (Лестница.Способ = ЗНАЧЕНИЕ(Перечисление.СпособыРазгрузки.Лестница))
	    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыРазгрузкиКлиента КАК Лифт
	    |		ПО (НЕ Лифт.ПометкаУдаления)
	    |			И (Лифт.Способ = ЗНАЧЕНИЕ(Перечисление.СпособыРазгрузки.Лифт))
	    |			И (НЕ Лифт.ЛифтГрузовой)
	    |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыРазгрузкиКлиента КАК ЛифтГруз
	    |		ПО (НЕ ЛифтГруз.ПометкаУдаления)
	    |			И (ЛифтГруз.ЛифтГрузовой)
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
		|&ТекстЗапросаРезультат";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаВесНоменклатуры",Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"ТаблицаНоменклатуры.Номенклатура.ЕдиницаИзмерения",
	"ТаблицаНоменклатуры.Номенклатура"));
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаОбъемНоменклатуры",Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"ТаблицаНоменклатуры.Номенклатура.ЕдиницаИзмерения",
	"ТаблицаНоменклатуры.Номенклатура"));
    Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаДлинаНоменклатуры",Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаДлинаУпаковки(
	"ВТ_ТоварыИтоги.Номенклатура.ЕдиницаИзмерения",
	"ВТ_ТоварыИтоги.Номенклатура"));
    Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаПлощадьНоменклатуры",Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаПлощадьУпаковки(
	"ТаблицаНоменклатуры.Номенклатура.ЕдиницаИзмерения",
	"ТаблицаНоменклатуры.Номенклатура"));  
	
	Если ТипЗнч(Объект) = Тип("Структура") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаРезультат", ТекстЗапросаРезультатРазгрузкаДляСайта());
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаРезультат", ТекстЗапросаРезультатРазгрузка()); 
		Запрос.УстановитьПараметр("ТаблицаВариантовРазгрузки", Объект.ВариантыРазгрузкиВРучную.Выгрузить());
	КонецЕсли;

	Запрос.УстановитьПараметр("Коэффициент", КоэффициентДляРасчетаВеса());
	Запрос.УстановитьПараметр("ДлинаНегабарита", ДлинаНегабарит());
    Запрос.УстановитьПараметр("ВесНегабарита", ВесНегабарит());
	Запрос.УстановитьПараметр("ПлощадьНегабарита", ПлощадьНегабарит());

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса;
	
КонецФункции   

Функция ТекстЗапросаТоварыСУчетомНарезкиПоОснованиям(ДопОснованияИзПомощникаПродаж = Ложь) Экспорт 
	
Если ДопОснованияИзПомощникаПродаж Тогда
	Текст =
	"ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК Количество
	|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
	|ИЗ
	|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнешняяТаблицаНарезки.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНарезки.Отрезок1 КАК Отрезок1,
	|	ВнешняяТаблицаНарезки.Отрезок2 КАК Отрезок2,
	|	ВнешняяТаблицаНарезки.Отрезок3 КАК Отрезок3,
	|	ВнешняяТаблицаНарезки.Отрезок4 КАК Отрезок4,
	|	ВнешняяТаблицаНарезки.Отрезок5 КАК Отрезок5,
	|	ВнешняяТаблицаНарезки.Отрезок6 КАК Отрезок6,
	|	ВнешняяТаблицаНарезки.Отрезок7 КАК Отрезок7,
	|	ВнешняяТаблицаНарезки.Отрезок8 КАК Отрезок8,
	|	ВнешняяТаблицаНарезки.Отрезок9 КАК Отрезок9,
	|	ВнешняяТаблицаНарезки.Отрезок10 КАК Отрезок10,
	|	ВнешняяТаблицаНарезки.Отрезок11 КАК Отрезок11,
	|	ВнешняяТаблицаНарезки.Отрезок12 КАК Отрезок12,
	|   ВнешняяТаблицаНарезки.Количество КАК Количество
	|ПОМЕСТИТЬ ВнешняяТаблицаНарезки 
	|ИЗ
	|	&ВнешняяТаблицаНарезки КАК ВнешняяТаблицаНарезки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|";
Иначе
	Текст = "";
КонецЕсли;
 
	Текст = Текст + 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Ссылка КАК Документ,
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	СУММА(РеализацияТоваровУслугТовары.КоличествоУпаковок) КАК Количество
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка В (&МассивДокументов)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|СГРУППИРОВАТЬ ПО
	|	РеализацияТоваровУслугТовары.Ссылка,
	|	РеализацияТоваровУслугТовары.Номенклатура,
	|	РеализацияТоваровУслугТовары.Склад
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Ссылка,
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	СУММА(ПеремещениеТоваровТовары.КоличествоУпаковок)
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка В (&МассивДокументов)
	|	И ПеремещениеТоваровТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Ссылка,
	|	ПеремещениеТоваровТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровПоставщикуТовары.Ссылка,
	|	ВозвратТоваровПоставщикуТовары.Номенклатура,
	|	СУММА(ВозвратТоваровПоставщикуТовары.КоличествоУпаковок)
	|ИЗ
	|	Документ.ВозвратТоваровПоставщику.Товары КАК ВозвратТоваровПоставщикуТовары
	|ГДЕ
	|	ВозвратТоваровПоставщикуТовары.Ссылка В (&МассивДокументов)
	|	И ВозвратТоваровПоставщикуТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|СГРУППИРОВАТЬ ПО
	|	ВозвратТоваровПоставщикуТовары.Ссылка,
	|	ВозвратТоваровПоставщикуТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Ссылка,
	|	ЧекККМТовары.Номенклатура,
	|	СУММА(ЧекККМТовары.КоличествоУпаковок)
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|ГДЕ
	|	ЧекККМТовары.Ссылка В (&МассивДокументов)
	|	И ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМТовары.Ссылка,
	|	ЧекККМТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Ссылка,
	|	ЗаказКлиентаТовары.Номенклатура,
	|	СУММА(ЗаказКлиентаТовары.КоличествоУпаковок)
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка В (&МассивДокументов)
	|	И ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|	И ЗаказКлиентаТовары.Отменено = ЛОЖЬ
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаТовары.Ссылка,
	|	ЗаказКлиентаТовары.Номенклатура,
	|	ЗаказКлиентаТовары.Склад
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиентаТовары.Ссылка,
	|	ВозвратТоваровОтКлиентаТовары.Номенклатура,
