			|				ВТЗаказыИКритерии)
			|
			|СГРУППИРОВАТЬ ПО
			|	Заказы.Ссылка";
		
		Запрос.УстановитьПараметр("МассивЗаказов", МассивЗаказов);
		Запрос.УстановитьПараметр("ТипТС", ТипТС);
		
