	 КонецЕсли;
	 
	 ТоварыОбъем.Колонки.Добавить("КоличествоСкруток",Новый ОписаниеТипов("Число"));	 
	 ТоварыОбъем.Колонки.Добавить("МаксКоличествоВСкрутке",Новый ОписаниеТипов("Число"));
	 ТоварыОбъем.Колонки.Добавить("Толщина",Новый ОписаниеТипов("Число"));
	 
	 КоличествоСтрок = ТоварыОбъем.Количество();
	 
	 
	 Для Индекс = 0 По КоличествоСтрок - 1 Цикл
		 Строка = ТоварыОбъем[Индекс];
		 
		 ТолщинаСтрока = Строка.ТолщинаСтрока;
		 ТолщинаЧисло = ?(ТолщинаСтрока = "",0,Число(ТолщинаСтрока)); 
