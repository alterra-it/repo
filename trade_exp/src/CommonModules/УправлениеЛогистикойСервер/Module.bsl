Функция ПолучитьВариантРазгрузкиПоСпособу(Способ,ЛифтГрузовой=Ложь) Экспорт
	
	ВариантРазгрузки = Справочники.ВариантыРазгрузкиКлиента.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВариантыРазгрузкиКлиента.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВариантыРазгрузкиКлиента КАК ВариантыРазгрузкиКлиента
		|ГДЕ
		|	НЕ ВариантыРазгрузкиКлиента.ПометкаУдаления
		|	И ВариантыРазгрузкиКлиента.Способ = &Способ
		|	И ВариантыРазгрузкиКлиента.ЛифтГрузовой = &ЛифтГрузовой
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВариантыРазгрузкиКлиента.Lmax,
		|	ВариантыРазгрузкиКлиента.Smax";
	
	Запрос.УстановитьПараметр("Способ", Способ);
	Запрос.УстановитьПараметр("ЛифтГрузовой", ЛифтГрузовой);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВариантРазгрузки = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Возврат ВариантРазгрузки;
	
КонецФункции

