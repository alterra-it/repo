функция ПолучитьРеализацииПоДоговоруБезОтметкиКассы(Основания,АвторЗаказаНаДоставку)Экспорт  
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Основания.Документ КАК Документ
	|
	|ПОМЕСТИТЬ Основания
	|ИЗ
	|	&Основания КАК Основания; 
	|////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	ВЫБОР
    |		КОГДА ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.РеализацияТоваровУслуг
    |			ТОГДА ВЫРАЗИТЬ(ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ.РеализацияТоваровУслуг).Номер
    |	КОНЕЦ КАК Номер, 
    |	ВЫБОР
    |		КОГДА ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.РеализацияТоваровУслуг
    |			ТОГДА ВЫРАЗИТЬ(ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ.РеализацияТоваровУслуг).Ссылка
    |	КОНЕЦ КАК Реализация,
    |
    |	ВЫБОР
    |		КОГДА ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.РеализацияТоваровУслуг
    |			ТОГДА ВЫРАЗИТЬ(ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ.РеализацияТоваровУслуг).Дата
|	КОНЕЦ КАК Дата
|ПОМЕСТИТЬ Реализации
|ИЗ
|	Основания КАК ЗаказНаДоставкуКлиентуОснования
|ГДЕ
|	ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.РеализацияТоваровУслуг
|	И ЗаказНаДоставкуКлиентуОснования.Документ.ИспользуетсяДоговор = ИСТИНА
|	И ЗаказНаДоставкуКлиентуОснования.Документ.Договор.ВидДоговора В(&МассивВидовДоговора)
|	И ЗаказНаДоставкуКлиентуОснования.Документ.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
|
|ОБЪЕДИНИТЬ ВСЕ
|
|ВЫБРАТЬ
|	РеализацияТоваровУслуг.Номер,
|	РеализацияТоваровУслуг.Дата,
|	РеализацияТоваровУслуг.Ссылка
|ИЗ
|	Основания КАК ЗаказНаДоставкуКлиентуОснования
|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
|		ПО ЗаказНаДоставкуКлиентуОснования.Документ = РеализацияТоваровУслуг.ЗаказКлиента
|ГДЕ
|	ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.ЗаказКлиента
|	И ЗаказНаДоставкуКлиентуОснования.Документ.ИспользуетсяДоговор = ИСТИНА
|	И ЗаказНаДоставкуКлиентуОснования.Документ.Договор.ВидДоговора В(&МассивВидовДоговора)
|	И ЗаказНаДоставкуКлиентуОснования.Документ.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ РАЗЛИЧНЫЕ
|	Реализации.Номер КАК Номер,
|	Реализации.Дата КАК Дата,
|	ЕСТЬNULL(Сотрудники.Отдел.Руководитель.Пользователь, ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)) КАК РуководительОтдела,
|	ЕСТЬNULL(РуководителиНаправления.Пользователь, ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)) КАК РуководительНаправления
|ИЗ
|	Реализации КАК Реализации
|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
|		ПО (&Автор = Сотрудники.Пользователь)
|			И (НЕ Сотрудники.ПометкаУдаления)
|			И (НЕ Сотрудники.Уволен)
|			И (НЕ Сотрудники.Отдел.Руководитель.Пользователь = &Автор)
|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК РуководителиНаправления
|		ПО (Сотрудники.Отдел.Руководитель = РуководителиНаправления.Отдел.Руководитель)
|			И (НЕ РуководителиНаправления.ПометкаУдаления)
|			И (НЕ РуководителиНаправления.Уволен)
|			И (РуководителиНаправления.Должность = &Должность)
|			И (НЕ РуководителиНаправления.Пользователь = &Автор)
|			И (НЕ РуководителиНаправления.Пользователь = Сотрудники.Отдел.Руководитель.Пользователь)
|ИТОГИ ПО
|	Реализация";

	
	Запрос.УстановитьПараметр("Основания",Основания);
	Запрос.УстановитьПараметр("Автор",АвторЗаказаНаДоставку);
	МассивВидовДоговора = Новый Массив();
	МассивВидовДоговора.Добавить(ПредопределенноеЗначение("Перечисление.ВИДДоговора.Отсрочка"));
	МассивВидовДоговора.Добавить(ПредопределенноеЗначение("Перечисление.ВИДДоговора.Предоплата"));
	Запрос.УстановитьПараметр("МассивВидовДоговора",МассивВидовДоговора); 
	Запрос.УстановитьПараметр("Должность",Справочники.Должности.НайтиПоНаименованию("Руководитель направления"));   
	
	Возврат Запрос.Выполнить();
	
КонецФункции

