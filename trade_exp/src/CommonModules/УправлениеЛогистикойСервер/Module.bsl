Функция ПолучитьДоступныеВариантыРазгрузки(МаксимальнаяДлина,МаксимальнаяПлощадь, МаксимальныйВес) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВариантыРазгрузкиКлиента.Ссылка КАК ВариантРазгрузки
		|ИЗ
		|	Справочник.ВариантыРазгрузкиКлиента КАК ВариантыРазгрузкиКлиента
		|ГДЕ
		|	ВЫБОР
		|			КОГДА ВариантыРазгрузкиКлиента.Lmax > 0
		|				ТОГДА ВариантыРазгрузкиКлиента.Lmax >= &Lmax
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И ВЫБОР
		|			КОГДА ВариантыРазгрузкиКлиента.Smax > 0
		|				ТОГДА ВариантыРазгрузкиКлиента.Smax >= &Smax
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ 
		|	И ВЫБОР
		|			КОГДА ВариантыРазгрузкиКлиента.ВесМакс > 0
		|				ТОГДА ВариантыРазгрузкиКлиента.ВесМакс >= &ВесМакс
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|	И НЕ ВариантыРазгрузкиКлиента.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Lmax", МаксимальнаяДлина);
	Запрос.УстановитьПараметр("Smax", МаксимальнаяПлощадь);   
	Запрос.УстановитьПараметр("ВесМакс", МаксимальныйВес);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

Функция ПолучитьСтоимостиРазгрузки(Вес,Этаж,Дата,Зона,Негабарит,СпособРазгрузки) Экспорт
	
	СтруктураСтоимости = Новый Структура("ЦенаДляКлиента,ЦенаДляВодителя,ВремяРазгрузки",0,0,0);
	
	Если Вес=0 Тогда
		Возврат СтруктураСтоимости;
	КонецЕсли;
	
	Если СпособРазгрузки = Перечисления.СпособыРазгрузки.Разгрузка Тогда
		ПодъемНаЭтаж = 1;
	ИначеЕсли СпособРазгрузки = Перечисления.СпособыРазгрузки.Лифт Тогда
		ПодъемНаЭтаж = 2;
	Иначе
		ПодъемНаЭтаж = Этаж;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	СтоимостьРазгрузкиСрезПоследних.ЦенаДляКлиента КАК ЦенаДляКлиента,
		|	СтоимостьРазгрузкиСрезПоследних.ЦенаДляВодителя КАК ЦенаДляВодителя,
		|	СтоимостьРазгрузкиСрезПоследних.ВремяРазгрузки КАК ВремяРазгрузки
		|ИЗ
		|	РегистрСведений.СтоимостьРазгрузки.СрезПоследних(
		|			&Дата,
		|			Зона = &Зона
		|				И Негабарит = &Негабарит
		|				И Вес >= &Вес
		|				И Этаж >= &Этаж) КАК СтоимостьРазгрузкиСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	СтоимостьРазгрузкиСрезПоследних.Вес,
		|	СтоимостьРазгрузкиСрезПоследних.Этаж";
	
	Запрос.УстановитьПараметр("Вес", Вес);		
	Запрос.УстановитьПараметр("Этаж", ПодъемНаЭтаж);
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Зона", Зона);
	Запрос.УстановитьПараметр("Негабарит", Негабарит);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтруктураСтоимости,ВыборкаДетальныеЗаписи);
	КонецЕсли;

	Возврат СтруктураСтоимости;
	
КонецФункции

Функция ПолучитьСтруктуруПараметровРазгрузки() Экспорт
	
	СтруктураПараметров = Новый Структура;
	
	СтруктураПараметров.Вставить("ТЗТоварыКРазгрузке", Неопределено);
	СтруктураПараметров.Вставить("Этаж", 0);
	СтруктураПараметров.Вставить("НомерКвартиры", 0);
	СтруктураПараметров.Вставить("Зона", Перечисления.ЗоныДоставкиКлиента.ПустаяСсылка());
	СтруктураПараметров.Вставить("ВариантРазгрузки", Справочники.ВариантыРазгрузкиКлиента.ПустаяСсылка());
	СтруктураПараметров.Вставить("Дата", ТекущаяДата());
    СтруктураПараметров.Вставить("СНДС", Ложь);
	СтруктураПараметров.Вставить("НаличиеПандуса", Ложь);
	СтруктураПараметров.Вставить("РучнаяКорректировкаВариантовРазгрузки", Ложь);

	Возврат СтруктураПараметров;
	
КонецФункции

Функция ПолучитьГлобальнуюЗону(Зона,Филиал) Экспорт
	
	ГлобальнаяЗона = Перечисления.ЗоныДоставкиКлиента.ПустаяСсылка();	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГлобальныеЗоныПоЗонамДоставкиДоКлиента.ГлобальнаяЗона КАК ГлобальнаяЗона
		|ИЗ
		|	РегистрСведений.ГлобальныеЗоныПоЗонамДоставкиДоКлиента КАК ГлобальныеЗоныПоЗонамДоставкиДоКлиента
		|ГДЕ
		|	ГлобальныеЗоныПоЗонамДоставкиДоКлиента.Подразделение = &Подразделение
		|	И ГлобальныеЗоныПоЗонамДоставкиДоКлиента.Зона = &Зона";
	
	Запрос.УстановитьПараметр("Зона", Зона);
	Запрос.УстановитьПараметр("Подразделение", Филиал);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	    ГлобальнаяЗона =ВыборкаДетальныеЗаписи.ГлобальнаяЗона; 	
	КонецЦикла;
	
	Возврат ГлобальнаяЗона;
	
КонецФункции

