Функция ОбработатьТоварыПоликарбонат(Товары)  Экспорт
	 
	 ПравилаСкрутки = ПолучитьПравилаСкруткиПоликарбоната(); 
	 
	 Если Правиласкрутки = Неопределено Тогда
		 Возврат Новый ТаблицаЗначений;	
	 КонецЕсли;
	 
	 ТаблицаТолщин = ПравилаСкрутки.ТаблицаТолщин; 
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст =
	 "ВЫБРАТЬ
	 |	Товар.Номенклатура КАК Номенклатура,
	 |	Товар.КоличествоУпаковок КАК КоличествоУпаковок
	 |ПОМЕСТИТЬ Товар
	 |ИЗ
	 |	&Товар КАК Товар
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Товар.Номенклатура КАК Номенклатура,
	 |	Товар.КоличествоУпаковок КАК КоличествоУпаковок,
	 |   Выразить( ЕстьNull(НоменклатураДополнительныеРеквизиты.Значение.Наименование,""0"") Как Строка(20) )  КАК ТолщинаСтрока,
	 |   Выбор Когда  Товар.Номенклатура.ВидНоменклатуры = &Поликарбонат И Товар.Номенклатура.Родитель <> &ГруппыИсключения  Тогда 
	 |       Истина
	 |   Иначе 
	 |       Ложь
	 |   Конец Как Крутим,
	 |   0 Как Толщина,
	 |   0 Как МаксКоличествоВСкрутке
	 |
	 |ИЗ  Товар КАК Товар
	 |
	 |	Левое СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	 |		ПО (Товар.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка
	 |	     И НоменклатураДополнительныеРеквизиты.Свойство = &Свойство) 
	 |";
	 Запрос.УстановитьПараметр("Товар", Товары); 
	 Запрос.УстановитьПараметр("Поликарбонат", Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Поликарбонат") );
	 Запрос.УстановитьПараметр("ГруппыИсключения", Справочники.Номенклатура.НайтиПоНаименованию("Поликарбонат монолитный") );
	 Запрос.УстановитьПараметр("Свойство", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Толщина, мм"));
	 
	 Товары = Запрос.Выполнить().Выгрузить();
	 
	 Если Товары.Количество() > 0 Тогда	
		 //Проверка, есть ли вообще здесь Поликарбонат
		 Товары.Сортировать("Крутим Убыв"); 
		 Если НЕ Товары[0].Крутим Тогда
			 Возврат Новый ТаблицаЗначений; 
		 КонецЕсли;
	 КонецЕсли;
	 
	 
	 
	 Для каждого Строка Из Товары Цикл			
		 Если Не Строка.Крутим Тогда //Не Поликарбонат не обрабатываем	
			 Продолжить;
		 КонецЕсли;
		 
		 ТолщинаСтрока = Строка.ТолщинаСтрока;
		 ТолщинаЧисло = ?(ТолщинаСтрока = "",0,Число(ТолщинаСтрока)); 
		 Количество = Строка.КоличествоУпаковок;
		 Строка.Толщина = ТолщинаЧисло;
		 
		 Если ТолщинаЧисло > ПравилаСкрутки.МаксимальнаяТолщинаСкрутки Тогда 
			 Строка.Крутим = Ложь;
			 Строка.Толщина = ПравилаСкрутки.МаксимальнаяТолщинаСкрутки +1; 
		 Иначе  
			 //относим к конкретной толщине
			 Для Каждого Стр Из ТаблицаТолщин Цикл
				 Если ТолщинаЧисло <= Стр.Толщина Тогда 
					 Строка.Толщина = Стр.Толщина; 
					 Строка.МаксКоличествоВСкрутке = Стр.МаксКоличество;
				 КонецЕсли;
			 КонецЦикла;  
		 КонецЕсли;;
	 КонецЦикла;
	 
	 //Если товар с поликарбонатом был, но только с толщиной не подходящей для скрутки
	 Товары.Сортировать("Крутим Убыв"); 	
	 Если НЕ Товары[0].Крутим Тогда
		 Товары.Очистить(); 
	 КонецЕсли;
	 
	 //группироуем по толщине
	 Запрос = Новый Запрос;
	 Запрос.Текст =
	 "ВЫБРАТЬ
	 |	Товары.Номенклатура КАК Номенклатура,
	 |	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	Товары.МаксКоличествоВСкрутке КАК МаксКоличествоВСкрутке,
	 |	Товары.Толщина КАК Толщина,
	 |	Товары.Крутим КАК Крутим
	 |ПОМЕСТИТЬ Товар
	 |ИЗ
	 |	&Товары КАК Товары
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	СУММА(Товар.КоличествоУпаковок) КАК КоличествоУпаковок,
	 |	Товар.Толщина КАК Толщина,
	 |	МАКСИМУМ(Товар.МаксКоличествоВСкрутке) КАК МаксКоличествоВСкрутке,
	 |	МАКСИМУМ(Товар.Крутим) КАК Крутим
	 |ПОМЕСТИТЬ ТоварыДляСкрутки
	 |ИЗ
	 |	Товар КАК Товар
	 |ГДЕ
	 |	Товар.Крутим = ИСТИНА
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	Товар.Толщина
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Товар.Номенклатура КАК Номенклатура,
	 |	Товар.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	Товар.МаксКоличествоВСкрутке КАК МаксКоличествоВСкрутке,
	 |	Товар.Толщина КАК Толщина,
	 |	Товар.Крутим КАК Крутим
	 |ПОМЕСТИТЬ ТоварыНеКрутим
	 |ИЗ
	 |	Товар КАК Товар
	 |ГДЕ
	 |	Товар.Крутим = ЛОЖЬ
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ТоварыНеКрутим.Номенклатура КАК Номенклатура,
	 |	ТоварыНеКрутим.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	ТоварыНеКрутим.МаксКоличествоВСкрутке КАК МаксКоличествоВСкрутке,
	 |	ТоварыНеКрутим.Толщина КАК Толщина,
	 |	ТоварыНеКрутим.Крутим КАК Крутим
	 |ИЗ
	 |	ТоварыНеКрутим КАК ТоварыНеКрутим
	 |
	 |ОБЪЕДИНИТЬ ВСЕ
	 |
	 |ВЫБРАТЬ
	 |	ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка),
	 |	ТоварыДляСкрутки.КоличествоУпаковок,
	 |	ТоварыДляСкрутки.МаксКоличествоВСкрутке,
	 |	ТоварыДляСкрутки.Толщина,
	 |	ТоварыДляСкрутки.Крутим
	 |ИЗ
	 |	ТоварыДляСкрутки КАК ТоварыДляСкрутки";
	 
	 Запрос.УстановитьПараметр("Товары", Товары); 
	 
	 Товары = Запрос.Выполнить().Выгрузить();
	 
	 Товары.Колонки.Добавить("КоличествоСкруток",Новый ОписаниеТипов("Число"));	
	 КоличествоСтрок = Товары.Количество();
	 
	 Для Индекс = 0 По КоличествоСтрок - 1 Цикл
		 
		 Строка = Товары[Индекс]; 
		 
		 Если Не Строка.Крутим Тогда //Не Поликарбонат не обрабатываем	
			 Продолжить;
		 КонецЕсли;
		 
		 Если Строка.МаксКоличествоВСкрутке > Строка.КоличествоУпаковок Тогда
			 Строка.КоличествоСкруток = 1; 
			 
		 Иначе  //нужно разделить на несколько скруток
			 Строка.КоличествоСкруток = Цел(Строка.КоличествоУпаковок/Строка.МаксКоличествоВСкрутке);  
			 
			 Остаток = Строка.КоличествоУпаковок - Строка.КоличествоСкруток * Строка.МаксКоличествоВСкрутке; 
			 
			 Строка.КоличествоУпаковок = Строка.МаксКоличествоВСкрутке;
			 Если Остаток > 0 Тогда					
				 НС = Товары.Добавить(); 
				 НС.Номенклатура = Строка.Номенклатура;
				 НС.Толщина = Строка.Толщина;
				 НС.КоличествоУпаковок = Остаток;
				 НС.КоличествоСкруток = 1;
				 НС.Крутим = Истина;	
			 КонецЕсли;
		 КонецЕсли;
		 
	 КонецЦикла;	
	 
	 Возврат Товары;
	 
 КонецФункции

