//Определение типов ТС
Функция ПолучитьТипыТС(Объект) Экспорт  
	
	МассивКритериев = Новый Массив; 
	
	Если ТипЗнч(Объект) = Тип("ДанныеФормыСтруктура") ИЛИ  ТипЗнч(Объект) = Тип("Структура") Тогда	
		
		Если Объект.Свойство("КритерииCовместимостиСТипамиТС")Тогда 
		   МассивКритериев = ПодборКритериевДляТиповТС(Объект.Основания.Выгрузить().ВыгрузитьКолонку("Документ"));

			//ТаблицаКритериев = Объект.КритерииCовместимостиСТипамиТС.Выгрузить();
			//МассивКритериев = ТаблицаКритериев.ВыгрузитьКолонку("Критерий");
			 
		ИначеЕсли  Объект.Свойство("Товары")Тогда 
			Если Объект.Товары.Количество() > 0 Тогда
					
				Товары = Объект.Товары;  
				Если Объект.Свойство("ТоварыДляДоставки")Тогда 
				    Если Объект.ТоварыДляДоставки.Количество() > 0 Тогда
				    	Товары = Объект.ТоварыДляДоставки;
				    КонецЕсли; 
				КонецЕсли;
		
				Если  ТипЗнч(Товары) = Тип("ТаблицаЗначений")  Тогда 
					МассивКритериев = ПодборКритериевДляТиповТС(Товары); 
				Иначе		
					МассивКритериев = ПодборКритериевДляТиповТС(Товары.Выгрузить()); 
		     	КонецЕсли;	
			КонецЕсли;
		КонецЕсли; 		
	Иначе 
		Если  ЗначениеЗаполнено(Объект.Ссылка) Тогда   
			МассивКритериев = Объект.КритерииCовместимостиСТипамиТС.ВыгрузитьКолонку("Критерий"); 
		Иначе    
			МассивКритериев = ПодборКритериевДляТиповТС(Объект.Основания.ВыгрузитьКолонку("Документ")); // в Помощнике при создании документа
		КонецЕсли;
	КонецЕсли;


	
	//Ограничение Типов ТС по длине, весу, объему	
	Запрос = Новый Запрос;	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТипыТранспортныхСредств.Ссылка КАК ТипТС
	|ИЗ
	|	Справочник.ТипыТранспортныхСредств КАК ТипыТранспортныхСредств
	|ГДЕ
	|	ТипыТранспортныхСредств.ДлинаВМетрах >= &ДлинаВМетрах
	|	И ТипыТранспортныхСредств.ГрузоподъемностьВТоннах >= &ГрузоподъемностьВТоннах
	|	И ТипыТранспортныхСредств.ВместимостьВКубическихМетрах >= &ВместимостьВКубическихМетрах
	|	И НЕ ТипыТранспортныхСредств.ПометкаУдаления";
	
	Если МассивКритериев.Количество() > 0 Тогда 
		
		//Сочетания критериев
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	СочетанияКритериевДляТиповТС.ТипТранспортногоСредства КАК ТипТранспортногоСредства
		|ПОМЕСТИТЬ СочетанияКритериев
		|ИЗ
		|	РегистрСведений.СочетанияКритериевДляТиповТС КАК СочетанияКритериевДляТиповТС
		|ГДЕ
		|	СочетанияКритериевДляТиповТС.КритерийСовместимости В(&МассивКритериев)
		|	И СочетанияКритериевДляТиповТС.КритерийНесовместимости В(&МассивКритериев);
		|/////////////////////////////////////////////////////////////////////////////////
		|"
		+ ТекстЗапроса  + "
		|	И ТипыТранспортныхСредств.Ссылка Не В (Выбрать СочетанияКритериев.ТипТранспортногоСредства Из СочетанияКритериев)";
		
		// Типы ТС и критерии заказа
		ОграничениеПоТипамТСИКритериямЗаказа = ПолучитьОграничениеПоТипамТСИКритериямЗаказа(МассивКритериев);  
		
		Если ОграничениеПоТипамТСИКритериямЗаказа.Количество() > 0 Тогда  
			
			ТекстЗапроса = ТекстЗапроса + "                                                        
			|	И ТипыТранспортныхСредств.Ссылка  В (&ОграничениеПоТипамТСИКритериямЗаказа)" ;
			
			Запрос.УстановитьПараметр("ОграничениеПоТипамТСИКритериямЗаказа",ОграничениеПоТипамТСИКритериямЗаказа); 	                        	
		КонецЕсли;  
		
		Запрос.УстановитьПараметр("МассивКритериев",МассивКритериев);
		
	КонецЕсли; 
	
	Вес = Объект.Вес;
	Объем = Объект.Объем; 
	МаксимальнаяДлина = Объект.МаксимальнаяДлина;
	
	Запрос.УстановитьПараметр("ВместимостьВКубическихМетрах",Объем);
	Запрос.УстановитьПараметр("ГрузоподъемностьВТоннах",Вес/1000);
	Запрос.УстановитьПараметр("ДлинаВМетрах",МаксимальнаяДлина);
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить().Выгрузить();	
	
КонецФункции               

Функция ПолучитьОграничениеПоТипамТСИКритериямЗаказа(МассивКритериев)Экспорт
	
	Запрос = Новый Запрос;	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТипыТранспортныхСредствКритерииЗаказа.Ссылка КАК Ссылка,
	|	ТипыТранспортныхСредствКритерииЗаказа.Критерий КАК Критерий,
	|	1 КАК Количество
	|ПОМЕСТИТЬ КритерииСОграничениямиПоТипу
	|ИЗ
	|	Справочник.ТипыТранспортныхСредств.КритерииЗаказа КАК ТипыТранспортныхСредствКритерииЗаказа
	|ГДЕ
	|	ТипыТранспортныхСредствКритерииЗаказа.Критерий В(&МассивКритериев)
	|	И ТипыТранспортныхСредствКритерииЗаказа.Допланирование = Ложь
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КритерииСОграничениямиПоТипу.Критерий КАК Критерий
	|ПОМЕСТИТЬ РазличныеКритерииСОграничениями
	|ИЗ
	|	КритерииСОграничениямиПоТипу КАК КритерииСОграничениямиПоТипу
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РазличныеКритерииСОграничениями.Критерий) КАК КоличествоРазличных
	|ПОМЕСТИТЬ КоличествоРазличныхКритериевСОграничениямиПоТипу
	|ИЗ
	|	РазличныеКритерииСОграничениями КАК РазличныеКритерииСОграничениями
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КритерииСОграничениямиПоТипу.Ссылка КАК Ссылка,
	|	СУММА(КритерииСОграничениямиПоТипу.Количество) - КоличествоРазличныхКритериевСОграничениямиПоТипу.КоличествоРазличных КАК РазностьКоличеств
	|ПОМЕСТИТЬ Итоговая
	|ИЗ
	|	КритерииСОграничениямиПоТипу КАК КритерииСОграничениямиПоТипу
	|		ЛЕВОЕ СОЕДИНЕНИЕ КоличествоРазличныхКритериевСОграничениямиПоТипу КАК КоличествоРазличныхКритериевСОграничениямиПоТипу
	|		ПО (ИСТИНА)
	|
	|СГРУППИРОВАТЬ ПО
	|	КритерииСОграничениямиПоТипу.Ссылка,
	|	КоличествоРазличныхКритериевСОграничениямиПоТипу.КоличествоРазличных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Итоговая.Ссылка КАК ТипТранспортногоСредства
	|ИЗ
	|	Итоговая КАК Итоговая
	|ГДЕ
	|	Итоговая.РазностьКоличеств = 0" + " ; "; 
	
	Запрос.УстановитьПараметр("МассивКритериев",МассивКритериев); 
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

//Определение Тарифов
Функция ПолучитьТарифы(ТипыТС, Объект, ДляТестирования = Ложь, ДляСайта = Ложь) Экспорт
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	    "ВЫБРАТЬ
	    |	ТипыТС.ТипТС КАК ТипТС
	    |ПОМЕСТИТЬ ВТ_ТипыТС
	    |ИЗ
	    |	&ТипыТС КАК ТипыТС
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	    |	НастройкиТарифов.ТипТС КАК ТипТС,
	    |	НастройкиТарифов.Тариф КАК Тариф
	    |ПОМЕСТИТЬ ВТ_Тарифы
	    |ИЗ
	    |	&НастройкиТарифов КАК НастройкиТарифов 
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	    |	ВТ_Тарифы.Тариф КАК Тариф,
	    |	ВТ_Тарифы.ТипТС КАК ТипТС
	    |ПОМЕСТИТЬ ВТ1_НастройкиТарифов
	    |ИЗ
	    |	ВТ_ТипыТС КАК ВТ_ТипыТС
	    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Тарифы КАК ВТ_Тарифы
	    |		ПО ВТ_ТипыТС.ТипТС = ВТ_Тарифы.ТипТС
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТарифИнтервалы.Ссылка КАК Тариф
		|ПОМЕСТИТЬ ВТ2_ПоИнтервалу
		|ИЗ
		|	Справочник.ТарифыПеревозчиков.Интервалы КАК ТарифИнтервалы
		|ГДЕ
		|	ТарифИнтервалы.Интервал = &Интервал	 
		|;
		|  
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Тарифы.Тариф КАК Тариф,
		|	ВТ1_НастройкиТарифов.ТипТС КАК ТипТС
		|ПОМЕСТИТЬ ВТ3_ПоЗоне
		|ИЗ
		|	ВТ2_ПоИнтервалу КАК Тарифы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ1_НастройкиТарифов КАК ВТ1_НастройкиТарифов
		|		ПО Тарифы.Тариф = ВТ1_НастройкиТарифов.Тариф
		|ГДЕ
	    |	ВЫБОР
	    |			КОГДА &ГлобальнаяЗона = ЗНАЧЕНИЕ(Перечисление.ЗоныДоставкиКлиента.Зона2)
	    |				ТОГДА Тарифы.Тариф.ЗонаДействияТарифа = &ГлобальнаяЗона
	    |						ИЛИ Тарифы.Тариф.ЗонаДействияТарифа = ЗНАЧЕНИЕ(Перечисление.ЗоныДоставкиКлиента.ПустаяСсылка)
		|           Иначе Истина
	    |		КОНЕЦ
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	    |	Тарифы.Тариф КАК Тариф,
	    |	Тарифы.ТипТС КАК ТипТС
	    |ПОМЕСТИТЬ ВТ4_ПоПодразделению
	    |ИЗ
	    |	ВТ3_ПоЗоне КАК Тарифы
	    |ГДЕ
	    |	Тарифы.Тариф.Подразделение = &Подразделение
	    |
	    |ОБЪЕДИНИТЬ ВСЕ
	    |
	    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	    |	Тарифы.Тариф,
	    |	Тарифы.ТипТС
	    |ИЗ
	    |	ВТ3_ПоЗоне КАК Тарифы
	    |ГДЕ
	    |	Тарифы.Тариф.Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	    |;
	    |
	    |////////////////////////////////////////////////////////////////////////////////
	    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	    |	ТарифыПоПодразделению.Тариф КАК Тариф,
		|   УникальныйИдентификатор(ТарифыПоПодразделению.Тариф) КАК УИД_Тарифа,
	    |	СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента КАК СтоимостьДляКлиента,
	    |	ТарифыПоПодразделению.ТипТС КАК ТипТС,
		|	УникальныйИдентификатор(ТарифыПоПодразделению.ТипТС) КАК УИД_ТипаТС,
		|   ТарифыПоПодразделению.ТипТС.Приоритет Как Приоритет
	    |ИЗ
	    |	ВТ4_ПоПодразделению КАК ТарифыПоПодразделению
	    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СтоимостьДоставкиПоЗонам.СрезПоследних(
	    |				&Дата,
	    |				ЗонаДоставки = &ЗонаДоставкиДляКлиента
	    |					И Филиал = &Подразделение) КАК СтоимостьДоставкиПоЗонамСрезПоследних
	    |		ПО ТарифыПоПодразделению.Тариф = СтоимостьДоставкиПоЗонамСрезПоследних.Тариф
	    |
	    |УПОРЯДОЧИТЬ ПО
	    |	СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента,
	    |	ТарифыПоПодразделению.ТипТС.Приоритет"; 
	
	Запрос.УстановитьПараметр("ТипыТС", ТипыТС); 
	Запрос.УстановитьПараметр("НастройкиТарифов", ПолучитьНастройкиАвтоопределения().НастройкиТарифов); 
	Запрос.УстановитьПараметр("Интервал", Объект.Интервал);
	Запрос.УстановитьПараметр("ГлобальнаяЗона", ПолучитьГлобальнуюЗону(Объект.ЗонаДоставкиДляВодителя,Объект.Подразделение));
	Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение); 
	Запрос.УстановитьПараметр("Дата", Объект.ПрибытиеНаОтгрузку);	
	Запрос.УстановитьПараметр("ЗонаДоставкиДляКлиента", Объект.ЗонаДоставкиДляВодителя); 
	                         
	Результат = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
	
	ТарифыНастройкиТарифов = Результат[2].Выбрать();
	ТарифыИнтервалы = Результат[3].Выбрать();
	ТабПредИтоговая = Результат[5].Выбрать();
	ТабИтоговая = Результат[6].Выгрузить(); 
	
	СообщениеОбОшибке = Неопределено;
	
	Если ТарифыНастройкиТарифов.Количество() <1 Тогда 
		СообщениеОбОшибке = "Отсутствует тариф по данному транспортному средству";
	КонецЕсли;
	
   	Если ТарифыИнтервалы.Количество() <1 Тогда 
		СообщениеОбОшибке = "Выбранный интервал не подходит для доставки";
	КонецЕсли;
	
	Если ДляТестирования Тогда 
		Возврат Результат; 
	КонецЕсли;	
		
	Если ТабПредИтоговая.Количество()> 0 И ТабИтоговая.Количество() <1 Тогда 
	   	СообщениеОбОшибке = "Для возможных тарифов нет данных о Стоимости Доставки по Зоне. Обратитесь в отдел Логистики, выберите Тариф вручную";	
	КонецЕсли;
	
	Если СообщениеОбОшибке <> Неопределено Тогда   
		Возврат СообщениеОбОшибке;	
	КонецЕсли;	

	Возврат ТабИтоговая;	
	
КонецФункции

Функция ПолучитьОбъем(Товары) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст =	
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	СУММА(ВТ_Товары.КоличествоУпаковок) КАК КоличествоУпаковок
	|ПОМЕСТИТЬ Товар
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Товары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВЫБОР
	|			КОГДА Товар.КоличествоУпаковок > 0
	|				ТОГДА Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры
	|			ИНАЧЕ -(Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры)
	|		КОНЕЦ) КАК Вес,
	|	СУММА(ВЫБОР
	|			КОГДА Товар.КоличествоУпаковок > 0
	|				ТОГДА Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры
	|			ИНАЧЕ -(Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры)
	|		КОНЕЦ) КАК Объем
	|ИЗ
	|	Товар КАК Товар";
	
	Запрос.УстановитьПараметр("Товары",Товары);   
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура")); 
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Объем = 0;
	Если Выборка.Следующий() Тогда 
		Объем = Выборка.Объем;	
	КонецЕсли;
		
	Возврат Объем;

КонецФункции
 
 #КонецОбласти
 
 #Область АвтоопределениеТарифаДистрибуция
 
 Функция ОпределитьТарифДистрибуция(Объект, Период = Неопределено, Подразделение = неопределено, Зона = Неопределено)Экспорт
	 Период = ?(Период = Неопределено, ТекущаяДата(),Период);
	 Подразделение = ?(Подразделение = Неопределено, Объект.Склад.Подразделение, Подразделение);
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	СтоимостьДоставкиПоЗонамСрезПоследних.Тариф КАК Тариф,
	 |	СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента КАК СтоимостьДляКлиента
	 |ИЗ
	 |	РегистрСведений.СтоимостьДоставкиПоЗонам.СрезПоследних(
	 |			&Период,
	 |			Филиал = &Подразделение
	 |				И ЗонаДоставки = &ЗонаДоставки
	 |				И Тариф.ВидДоставки = &ВидДоставки) КАК СтоимостьДоставкиПоЗонамСрезПоследних";
	 
	 Запрос.УстановитьПараметр("ЗонаДоставки", ?(Зона = Неопределено, Объект.ОбъектДоставки.ЗонаДоставкиДляВодителя,Зона));
	 Запрос.УстановитьПараметр("Период",Период);
	 Запрос.УстановитьПараметр("Подразделение", Подразделение);
	 Запрос.УстановитьПараметр("ВидДоставки", Перечисления.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы);
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 
	 Выборка = РезультатЗапроса.Выбрать();
	 Результат = Новый Структура("Тариф,ТарифЗаКГ", Справочники.ТарифыПеревозчиков.ПустаяСсылка(),0);
	 Пока Выборка.Следующий() Цикл  
		 Результат.Тариф =  Выборка.Тариф;
		 Результат.ТарифЗаКг = Выборка.СтоимостьДляКлиента;
	 КонецЦикла;
	 Возврат Результат;
 Конецфункции
 
 Функция РаспределениеСтоимостиДоставкиДистрибуция(Объект, Товары = Неопределено, ТолькоСтоимостьДоставки = Ложь,
	 Склад = Неопределено, ТарифЗаКг = 0) Экспорт 
	 	 
	 Товар =?(Товары = Неопределено, Объект.Товары.Выгрузить(), Товары);	
	 ТоварыОбъем = ЗаполнитьОбъемСУчетомСкрутокПоликарбонатаПострочно(Товар);
	 
	 Запрос = Новый Запрос;  
	 ТекстЗапроса = 
	 "ВЫБРАТЬ
	 |	Товары.Номенклатура КАК НоменклатураВт,
	 |	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	Товары.Цена КАК Цена,
	 |  Товары.ПроцентРучнойСкидки - Товары.Компенсация КАК ПроцентРучнойСкидкиОстаток,
	 |	Товары.Характеристика КАК Характеристика,
	 |	Товары.НомерСтроки КАК НомерСтроки
	 |ПОМЕСТИТЬ Товар
	 |ИЗ
	 |	&Товары КАК Товары
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ЕСТЬNULL(ТоварыОбъем.Объем, 0) КАК Объем,
	 |	ЕСТЬNULL(ТоварыОбъем.НомерСтроки, 0) КАК НомерСтроки
	 |ПОМЕСТИТЬ ТоварыОбъем
	 |ИЗ
	 |	&ТоварыОбъем КАК ТоварыОбъем
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	Номенклатура.Ссылка КАК Номенклатура,
	 |	Товар.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	&ТекстЗапросаВесНоменклатуры КАК ВесЕдиницыТовара,
	 |	ВЫБОР
	 |		КОГДА ТоварыОбъем.Объем ЕСТЬ NULL
	 |			ТОГДА &ТекстЗапросаОбъемНоменклатуры
	 |		ИНАЧЕ ТоварыОбъем.Объем / Товар.КоличествоУпаковок
	 |	КОНЕЦ КАК ОбъемЕдиницыТовара,
	 |	Товар.Цена КАК Цена,
	 |	Товар.НомерСтроки КАК НомерСтроки,
	 |	Товар.ПроцентРучнойСкидкиОстаток КАК ПроцентРучнойСкидкиОстаток,
	 |	Товар.Характеристика КАК Характеристика
	 |ПОМЕСТИТЬ ВТ_ВесОбъем
	 |ИЗ
	 |	Справочник.Номенклатура КАК Номенклатура
	 |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Товар КАК Товар
	 |		ПО (Товар.НоменклатураВт = Номенклатура.Ссылка)
	 |		ЛЕВОЕ СОЕДИНЕНИЕ ТоварыОбъем КАК ТоварыОбъем
	 |		ПО (Товар.НомерСтроки = ТоварыОбъем.НомерСтроки)
	 |ГДЕ
	 |	Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |   ВЫБРАТЬ РАЗЛИЧНЫЕ
	 |	ВТ_ВесОбъем.Номенклатура КАК Номенклатура,
	 |	ВТ_ВесОбъем.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	ВТ_ВесОбъем.ВесЕдиницыТовара * ВТ_ВесОбъем.КоличествоУпаковок КАК Вес,
	 |	ВТ_ВесОбъем.НомерСтроки КАК НомерСтроки,
	 |	ВТ_ВесОбъем.Цена КАК Цена,
	 |	ВТ_ВесОбъем.ПроцентРучнойСкидкиОстаток КАК ПроцентРучнойСкидкиОстаток,
	 |	ВЫБОР
	 |		КОГДА ВТ_ВесОбъем.ВесЕдиницыТовара = 0
	 |		ИЛИ ВТ_ВесОбъем.ОбъемЕдиницыТовара = 0
	 |			ТОГДА 1
	 |		ИНАЧЕ ВТ_ВесОбъем.ВесЕдиницыТовара / 1000 / ВТ_ВесОбъем.ОбъемЕдиницыТовара
	 |	КОНЕЦ КАК КоэфВесНаОбъем,
	 |	ВТ_ВесОбъем.Цена * ВТ_ВесОбъем.КоличествоУпаковок КАК СуммаРасчетная,
	 |	ВЫБОР
	 |		КОГДА ДопРеквизиты.Значение = &Легкий
	 |			ТОГДА ЛОЖЬ
	 |		ИНАЧЕ ИСТИНА
	 |	КОНЕЦ КАК Тяжелый
	 |ПОМЕСТИТЬ ВТ_ЛегкийТяжелый
	 |ИЗ
	 |	ВТ_ВесОбъем КАК ВТ_ВесОбъем
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК ДопРеквизиты
	 |		ПО ВТ_ВесОбъем.Номенклатура = ДопРеквизиты.Ссылка
	 |		И (ДопРеквизиты.Свойство = &Свойство)
	 |;
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВТ_ЛегкийТяжелый.Номенклатура КАК Номенклатура,
	 |	ВТ_ЛегкийТяжелый.КоличествоУпаковок КАК КоличествоУпаковок,
	 |	ВТ_ЛегкийТяжелый.Вес КАК Вес,
	 |	ВТ_ЛегкийТяжелый.НомерСтроки КАК НомерСтроки,
	 |	ВТ_ЛегкийТяжелый.КоэфВесНаОбъем КАК КоэфВесНаОбъем,
	 |	ВТ_ЛегкийТяжелый.ПроцентРучнойСкидкиОстаток КАК ПроцентРучнойСкидкиОстаток,
	 |	ВЫБОР
	 |		КОГДА ВТ_ЛегкийТяжелый.КоэфВесНаОбъем < 0.1
	 |			ТОГДА &ТарифЗаКг * (&КоэфДляРасчетаВеса / ВТ_ЛегкийТяжелый.КоэфВесНаОбъем)
	 |		ИНАЧЕ &ТарифЗаКг
	 |	КОНЕЦ КАК ТарифЗаКг,
	 |	ВТ_ЛегкийТяжелый.СуммаРасчетная КАК СуммаРасчетная,
	 |	ВТ_ЛегкийТяжелый.Тяжелый КАК Тяжелый,
	 |	ВТ_ЛегкийТяжелый.Цена КАК Цена
	 |ПОМЕСТИТЬ ВТ_Тариф
	 |ИЗ
	 |	ВТ_ЛегкийТяжелый КАК ВТ_ЛегкийТяжелый
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 | ВЫБРАТЬ СУММА(ВТ_Тариф.Вес * ВТ_Тариф.ТарифЗаКг) КАК СтоимостьДоставкиРасчетная,
	 | СУММА(ВЫБОР КОГДА ВТ_Тариф.Тяжелый ТОГДА ВТ_Тариф.Вес * ВТ_Тариф.ТарифЗаКг ИНАЧЕ 0 КОНЕЦ) КАК СтоимостьДоставкиТяжелогоТовара,
	 |	СУММА(ВТ_Тариф.Вес) КАК ВесИтог, 
	 |   СУММА(ВЫБОР
	 |		КОГДА ВТ_Тариф.Тяжелый
	 |			ТОГДА ВТ_Тариф.Вес
	 |		ИНАЧЕ 0
	 |	КОНЕЦ) КАК ВесТяжелогоТовараИтог,
	 |	СУММА(ВТ_Тариф.СуммаРасчетная) КАК СуммаИтог,
	 |	СУММА(ВЫБОР
	 |		КОГДА НЕ ВТ_Тариф.Тяжелый
	 |			ТОГДА ВТ_Тариф.СуммаРасчетная
	 |		ИНАЧЕ 0
	 |	КОНЕЦ) КАК СуммаЛегкогоТовара
	 |ПОМЕСТИТЬ РасчетныеИтоги
	 |ИЗ
	 |	ВТ_Тариф КАК ВТ_Тариф
	 |
	 |;";
	 
	 Если ТолькоСтоимостьДоставки Тогда
		 Запрос.Текст = ТекстЗапроса +
		 "////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ ПЕРВЫЕ 1
		 |	РасчетныеИтоги.СтоимостьДоставкиРасчетная КАК СтоимостьДоставкиРасчетная
		 |ИЗ
		 |	РасчетныеИтоги КАК РасчетныеИтоги
		 |
		 |;";
	 Иначе
		 Запрос.Текст = ТекстЗапроса +
		 "ВЫБРАТЬ
		 |	ВТ_Тариф.Номенклатура КАК Номенклатура,
		 |	ВТ_Тариф.КоличествоУпаковок КАК КоличествоУпаковок,
		 |	ВТ_Тариф.Вес КАК Вес,
		 |	ВТ_Тариф.НомерСтроки КАК НомерСтроки,
		 |	ВТ_Тариф.ТарифЗаКг КАК ТарифЗаКг,
		 |	ВТ_Тариф.СуммаРасчетная КАК СуммаРасчетная,
		 |	ВТ_Тариф.Тяжелый КАК Тяжелый,
		 |	ВТ_Тариф.Вес * ВТ_Тариф.ТарифЗаКг КАК СтоимостьДоставки,
		 |	РасчетныеИтоги.СтоимостьДоставкиРасчетная КАК СтоимостьДоставкиРасчетная,
		 |	РасчетныеИтоги.СтоимостьДоставкиТяжелогоТовара КАК СтоимостьДоставкиТяжелогоТовара,
		 |	РасчетныеИтоги.СуммаИтог КАК СуммаИтог,
		 |	РасчетныеИтоги.СуммаЛегкогоТовара КАК СуммаЛегкогоТовара,
		 |	ВЫБОР
		 |		КОГДА ВТ_Тариф.Тяжелый
		 |			ТОГДА ВТ_Тариф.Вес / РасчетныеИтоги.ВесТяжелогоТовараИтог
		 |		ИНАЧЕ 0
		 |	КОНЕЦ КАК ДоляВесаТяжелогоТовара,
		 |	ВТ_Тариф.ПроцентРучнойСкидкиОстаток КАК ПроцентРучнойСкидкиОстаток,
		 |	ВТ_Тариф.Цена КАК Цена,
		 |	ВТ_Тариф.СуммаРасчетная / РасчетныеИтоги.СуммаИтог КАК ДоляСтоимости
		 |ПОМЕСТИТЬ Расчетная
		 |ИЗ
		 |	ВТ_Тариф КАК ВТ_Тариф
		 |		ЛЕВОЕ СОЕДИНЕНИЕ РасчетныеИтоги КАК РасчетныеИтоги
		 |		ПО (РасчетныеИтоги.СтоимостьДоставкиРасчетная > 0)
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ ПЕРВЫЕ 1
		 |	ВЫБОР
		 |		КОГДА &КоэффКомпенсации * Расчетная.СуммаЛегкогоТовара > Расчетная.СтоимостьДоставкиТяжелогоТовара
		 |			ТОГДА Расчетная.СтоимостьДоставкиТяжелогоТовара
		 |		ИНАЧЕ &КоэффКомпенсации * Расчетная.СуммаЛегкогоТовара
		 |	КОНЕЦ КАК ОбщаяСуммаКомпенсации
		 |ПОМЕСТИТЬ ВТ_Компенсация
		 |ИЗ
		 |	Расчетная КАК Расчетная
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	Расчетная.Номенклатура КАК Номенклатура,
		 |	Расчетная.КоличествоУпаковок КАК КоличествоУпаковок,
		 |	Расчетная.НомерСтроки КАК НомерСтроки,
		 |	Расчетная.СуммаРасчетная КАК СуммаРасчетная,
		 |	Расчетная.СуммаЛегкогоТовара КАК СуммаЛегкогоТовара,
		 |	Расчетная.Тяжелый КАК Тяжелый,
		 |	Расчетная.СтоимостьДоставки КАК СтоимостьДоставки,
		 |	Расчетная.СтоимостьДоставкиРасчетная КАК СтоимостьДоставкиРасчетная,
		 |	Расчетная.СуммаИтог КАК СуммаИтог,
		 |	(Расчетная.СуммаРасчетная + Расчетная.СтоимостьДоставки) / Расчетная.КоличествоУпаковок КАК ЦенаСДоставкой,
		 |	Расчетная.Цена КАК Цена,
		 |	Расчетная.ПроцентРучнойСкидкиОстаток КАК ПроцентРучнойСкидкиОстаток,
		 |	ВТ_Компенсация.ОбщаяСуммаКомпенсации - Расчетная.СуммаЛегкогоТовара * &КоэффНаценкиНаДоставку КАК ОбщаяСуммаКомпенсации,
		 |	ВЫБОР
		 |		КОГДА Расчетная.Тяжелый
		 |			ТОГДА ВТ_Компенсация.ОбщаяСуммаКомпенсации * Расчетная.ДоляСтоимости
		 |		ИНАЧЕ ВТ_Компенсация.ОбщаяСуммаКомпенсации * Расчетная.ДоляСтоимости - Расчетная.СуммаРасчетная * &КоэффНаценкиНаДоставку
		 |	КОНЕЦ КАК Компенсация,
		 |	ВЫБОР
		 |		КОГДА Расчетная.Тяжелый
		 |			ТОГДА ВТ_Компенсация.ОбщаяСуммаКомпенсации * Расчетная.ДоляВесаТяжелогоТовара
		 |		ИНАЧЕ  - Расчетная.СуммаРасчетная * &КоэффНаценкиНаДоставку
		 |	КОНЕЦ КАК КомпенсацияТяжелый,
		 |	ВЫБОР
		 |		КОГДА Расчетная.Тяжелый
		 |			ТОГДА ВТ_Компенсация.ОбщаяСуммаКомпенсации * Расчетная.ДоляСтоимости / Расчетная.СуммаРасчетная * 100
		 |		ИНАЧЕ (ВТ_Компенсация.ОбщаяСуммаКомпенсации * Расчетная.ДоляСтоимости - Расчетная.СуммаРасчетная * &КоэффНаценкиНаДоставку) / Расчетная.СуммаРасчетная * 100
		 |	КОНЕЦ КАК ПроцентКомпенсации
		 |ПОМЕСТИТЬ ВТ_Итог
		 |ИЗ
		 |	Расчетная КАК Расчетная
		 |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Компенсация КАК ВТ_Компенсация
		 |		ПО (ИСТИНА)
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	ВТ_Итог.Номенклатура КАК Номенклатура,
		 |	ВТ_Итог.КоличествоУпаковок КАК КоличествоУпаковок,
		 |	ВТ_Итог.НомерСтроки КАК НомерСтроки,
		 |	ВТ_Итог.СуммаРасчетная КАК СуммаРасчетная,
		 |	ВТ_Итог.Тяжелый КАК Тяжелый,
		 |	ВТ_Итог.СтоимостьДоставки КАК СтоимостьДоставки,
		 |	ВТ_Итог.СтоимостьДоставкиРасчетная КАК СтоимостьДоставкиРасчетная,
		 |	ВТ_Итог.СуммаИтог КАК СуммаИтог,
		 |	ВЫРАЗИТЬ(ВТ_Итог.ПроцентКомпенсации КАК ЧИСЛО(5, 2)) КАК ПроцентКомпенсации,
		 |	ВТ_Итог.ЦенаСДоставкой - ВТ_Итог.КомпенсацияТяжелый / ВТ_Итог.КоличествоУпаковок КАК ЦенаСДоставкойПечать,
		 |	ВТ_Итог.ПроцентРучнойСкидкиОстаток КАК ПроцентРучнойСкидкиОстаток,
		 |	ВТ_Итог.СтоимостьДоставкиРасчетная - ВТ_Итог.ОбщаяСуммаКомпенсации КАК СтоимостьДоставкиДляКлиента,
		 |	ВТ_Итог.Цена КАК Цена,
		 |	ВТ_Итог.СтоимостьДоставки - ВТ_Итог.Компенсация + ВТ_Итог.КомпенсацияТяжелый КАК СуммаРТ,
		 |	ВТ_Итог.Компенсация КАК Компенсация,
		 |	ВТ_Итог.КомпенсацияТяжелый КАК КомпенсацияТяжелый
		 |ПОМЕСТИТЬ СЦенойПечать
		 |ИЗ
		 |	ВТ_Итог КАК ВТ_Итог
		 |;
		 |
		 |////////////////////////////////////////////////////////////////////////////////
		 |ВЫБРАТЬ
		 |	СЦенойПечать.Номенклатура КАК Номенклатура,
		 |	СЦенойПечать.КоличествоУпаковок КАК КоличествоУпаковок,
		 |	СЦенойПечать.НомерСтроки КАК НомерСтроки,
		 |	СЦенойПечать.СтоимостьДоставкиРасчетная КАК СтоимостьДоставкиРасчетная,
		 |	СЦенойПечать.ПроцентРучнойСкидкиОстаток + СЦенойПечать.ПроцентКомпенсации КАК ПроцентРучнойСкидки,
		 |	СЦенойПечать.ПроцентКомпенсации КАК Компенсация,
		 |	ВЫРАЗИТЬ(СЦенойПечать.ЦенаСДоставкойПечать КАК ЧИСЛО(15, 2)) КАК ЦенаСДоставкойПечать,
		 |	СЦенойПечать.СтоимостьДоставкиДляКлиента / (СЦенойПечать.СуммаИтог + СЦенойПечать.СтоимостьДоставкиДляКлиента) КАК ПроцентТранспортныхИтог,
		 |	СЦенойПечать.ЦенаСДоставкойПечать * СЦенойПечать.КоличествоУпаковок - СЦенойПечать.СуммаРасчетная + СЦенойПечать.Компенсация КАК СуммаРТ
		 |ИЗ
		 |	СЦенойПечать КАК СЦенойПечать";
	 КонецЕсли;
	 
	 //Подтягивание вспомогательных параметров
	 УстановитьПривилегированныйРежим(Истина);
	 КоэфДляРасчетаВеса = Константы.КоэффициентДляРасчетаВесаПриРазгрузке.Получить();
	 УстановитьПривилегированныйРежим(Ложь);   
	 СвойствоВидТовараДляДоставки = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ВидТовараДляДоставки");
	 ЗначениеЛегкий = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Легкий",,,СвойствоВидТовараДляДоставки);   
	 НастройкиАвтоопределения = ПолучитьНастройкиАвтоопределения();
	 
	 Запрос.УстановитьПараметр("Товары", Товар);
	 Запрос.УстановитьПараметр("ТоварыОбъем",ТоварыОбъем);
	 Запрос.УстановитьПараметр("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Товар); 
     Запрос.УстановитьПараметр("ТарифЗаКг",?(ТарифЗаКг =0,Объект.ТарифЗаКг,ТарифЗаКг));	
	 Запрос.УстановитьПараметр("КоэфДляРасчетаВеса",КоэфДляРасчетаВеса);
	 Запрос.УстановитьПараметр("Свойство", СвойствоВидТовараДляДоставки);  
	 Запрос.УстановитьПараметр("Легкий",ЗначениеЛегкий);
	 Запрос.УстановитьПараметр("Склад", ?(Склад = Неопределено,Объект.Склад,Склад)); 
	 Запрос.УстановитьПараметр("Период",ТекущаяДата());
	 Запрос.УстановитьПараметр("ПустоеНазначение", Справочники.Назначения.ПустаяСсылка()); 
	 Запрос.УстановитьПараметр("Организация", Объект.Организация); 
	 Запрос.УстановитьПараметр("КоэффКомпенсации",НастройкиАвтоопределения.КоэффМинимальнойКомпенсации);
     Запрос.УстановитьПараметр("КоэффНаценкиНаДоставку",НастройкиАвтоопределения.КоэффНаценкиНаДоставку);
	 
	 Запрос.Текст = СтрЗаменить(
	 Запрос.Текст, 
	 "&ТекстЗапросаВесНоменклатуры",
	 Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	 "Номенклатура.ЕдиницаИзмерения",
	 "Номенклатура")); 
	 
	 Запрос.Текст = СтрЗаменить(
	 Запрос.Текст, 
	 "&ТекстЗапросаОбъемНоменклатуры",
	 Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	 "Номенклатура.ЕдиницаИзмерения",
	 "Номенклатура")); 
	 
	 
	 РезультатЗапроса = Запрос.Выполнить(); 
	 
	 Результат = Новый Структура("СтоимостьДоставки,ТранспортныеИтог",0,0); 
	 
	 Если РезультатЗапроса.Пустой() Тогда 
		 Возврат Результат;	
	 КонецЕсли;
	 
	 Выборка = РезультатЗапроса.Выбрать();
	 
	 Если ТолькоСтоимостьДоставки Тогда
		 Выборка.Следующий();
		 Результат.СтоимостьДоставки = Выборка.СтоимостьДоставкиРасчетная;
		 Возврат Результат;
	 КонецЕсли;
	 
	 СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);	
	 СтруктураДействий = Новый Структура;
	 СтруктураДействий.Вставить("ПересчитатьСумму");
	 СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	 СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	 СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
	 СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
	 СтруктураДействий.Вставить("ОчиститьАвтоматическуюСкидку"); 
	  
	 Отбор = Новый Структура("НомерСтроки",1);
	 Пока Выборка.Следующий() Цикл
		 Отбор.НомерСтроки = Выборка.НомерСтроки;
		 МассивСтрок = Объект.Товары.НайтиСтроки(Отбор);
		 Если МассивСтрок.Количество() > 0 Тогда  
			 ЗаполнитьЗначенияСвойств(МассивСтрок[0],Выборка);
			 МассивСтрок[0].Распределять = Истина;   
			 ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(МассивСтрок[0], СтруктураДействий, Неопределено);
			 
			 МассивСтрок[0].ЦенаСДоставкойПечать =(МассивСтрок[0].Сумма + МассивСтрок[0].СуммаРТ)/МассивСтрок[0].КоличествоУпаковок;
			 МассивСтрок[0].ПроцентТранспортных = (МассивСтрок[0].ЦенаСДоставкойПечать - МассивСтрок[0].Цена) / МассивСтрок[0].ЦенаСДоставкойПечать;
		 КонецЕсли;	
	 КонецЦикла;
	 
	 Результат.СтоимостьДоставки = Выборка.СтоимостьДоставкиРасчетная;
	 Результат.ТранспортныеИтог  = Выборка.ПроцентТранспортныхИтог;
	 
	 Возврат Результат;  
	 
 Конецфункции
 
 #КонецОбласти

#Область ОбъемСкрутокПоликарбоната

Функция ПолучитьОбъемСУчетомСкрутокПоликарбоната(Товары) Экспорт
	
	ОбъемСУчетомСкруток = 0; 
	//Если ТипЗнч(Товары) = Тип("ДанныеФормыКоллекция") Тогда
	//	Товары = Товары.Выгрузить();
	//КонецЕсли;
	//
	Товар = ОбработатьТоварыПоликарбонат(Товары); 
	
	Если Товар.Количество() > 0 Тогда 
		
		ПравилаСкруткиПоликарбоната = ПолучитьПравилаСкруткиПоликарбоната().ПравилаСкрутки; 
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ПравилаСкруткиПоликарбоната.Количество КАК Количество,
		|	ПравилаСкруткиПоликарбоната.Толщина КАК Толщина,
		|	ПравилаСкруткиПоликарбоната.Объем КАК Объем
		|ПОМЕСТИТЬ ПравилаСкрутки
		|ИЗ
		|	&ПравилаСкруткиПоликарбоната КАК ПравилаСкруткиПоликарбоната
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товар.Номенклатура КАК Номенклатура,
		|	Товар.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Товар.Толщина КАК Толщина,
		|	Товар.Крутим КАК Крутим,
		|	Товар.КоличествоСкруток КАК КоличествоСкруток
		|ПОМЕСТИТЬ Товар
		|ИЗ
		|	&Товар КАК Товар
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товар.Номенклатура КАК Номенклатура,
		|	Товар.КоличествоУпаковок КАК Количество,
		|	Товар.Толщина КАК Толщина,
		|	Товар.Крутим КАК Крутим,
		|	Товар.КоличествоСкруток КАК КоличествоСкруток,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(Товар.Крутим, ЛОЖЬ) = ИСТИНА
		|			ТОГДА ПравилаСкрутки.Объем * Товар.КоличествоСкруток
		|		ИНАЧЕ Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры
		|	КОНЕЦ КАК ОбъемСУчетомСкруток
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Товар КАК Товар
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПравилаСкрутки КАК ПравилаСкрутки
		|		ПО Товар.Толщина = ПравилаСкрутки.Толщина
		|			И Товар.КоличествоУпаковок = ПравилаСкрутки.Количество
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТ.ОбъемСУчетомСкруток) КАК ОбъемСУчетомСкруток
		|ИЗ
		|	ВТ КАК ВТ";  
		
		Запрос.УстановитьПараметр("ПравилаСкруткиПоликарбоната", ПравилаСкруткиПоликарбоната); 
		Запрос.УстановитьПараметр("Товар", Товар); 
		Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаОбъемНоменклатуры",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
		"Товар.Номенклатура.ЕдиницаИзмерения",
		"Товар.Номенклатура"));

		Пакеты = Запрос.ВыполнитьПакетСПромежуточнымиДанными();
		Проверка = Пакеты[2].Выгрузить();
		
        Выборка = Пакеты[3].Выгрузить();  
		
		Если  Выборка.Количество()>0 Тогда 
			ОбъемСУчетомСкруток = Выборка[0].ОбъемСУчетомСкруток;
		КонецЕсли;	
		
	КонецЕсли;  
	
	Возврат ОбъемСУчетомСкруток;
	
