			|	И Заказ.ТипТС <> ЗНАЧЕНИЕ(Справочник.ТипыТранспортныхСредств.ПустаяСсылка)
			|
			|УПОРЯДОЧИТЬ ПО
			|	Заказ.ТипТС.Приоритет УБЫВ";
		                                                   
		Запрос.УстановитьПараметр("МассивЗаказов", МассивЗаказов);
		
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() И ЗначениеЗаполнено(Результат.ТипТС) Тогда
			Возврат Результат.ТипТС; 
		КонецЕсли;
	КонецЕсли;
	
	Возврат Справочники.ТипыТранспортныхСредств.ПустаяСсылка(); 
	
