Функция АвтопределениеТарифа_И_ТипаТС(Объект)Экспорт
	
	ТипТС = Справочники.ТипыТранспортныхСредств.ПустаяСсылка();
	Тариф = Справочники.ТарифыПеревозчиков.ПустаяСсылка();
	
	ТипыТС = ПолучитьТипыТС(Объект);
	СообщениеОбОшибке = "";
	Если  ТипыТС.Количество() > 0 Тогда 
		
		ТарифыТипы = ПолучитьТарифы(ТипыТС, Объект);
		
		Если   ТипЗнч(ТарифыТипы) = Тип("Строка")  Тогда   
			СообщениеОбОшибке =  ТарифыТипы;  
	    ИначеЕсли ТарифыТипы.Количество() > 0 Тогда 
			ТипТС = ТарифыТипы[0].ТипТС;
			Тариф = ТарифыТипы[0].Тариф;
		Иначе
			СообщениеОбОшибке = "Не удалось подобрать тарифы для данной доставки";	
		КонецЕсли;	
		
	Иначе
		СообщениеОбОшибке ="В розничной доставке нет подходящего типа транспорта. 
		|Выберите вид доставки: Свыше 3 тонн и дистрибуция. Обратитесь в отдел Логистики!";
	КонецЕсли;
	
	СтруктураТарифТипТС = Новый Структура("ТипТС,Тариф,СообщениеОбОшибке",ТипТС,Тариф,СообщениеОбОшибке);
	Возврат СтруктураТарифТипТС;  
	
КонецФункции 

//Объект - Структура("Интервал, Товары, МаксДлина,ЗонаДоставкиДляВодителя,ПрибытиеНаОтгрузку,Вес")
Функция  ОпределениеТарифаСайт(Объект) Экспорт  
	
	Объект.Вставить("Объем", ПолучитьОбъем(Объект.Товары)) ; 
	Объект.Вставить("Подразделение", Объект.Интервал.Подразделение);
	
	СообщениеОбОшибке = "";
	ТарифыТипы = Неопределено;
	
	ТипыТС = ПолучитьТипыТС(Объект);
	
	Если  ТипыТС.Количество() > 0 Тогда 
		ДляСайта = Истина;  
		ДляТестирования = Ложь;
		ТарифыТипы = ПолучитьТарифы(ТипыТС, Объект, ДляТестирования, ДляСайта);
		Если   ТипЗнч(ТарифыТипы) = Тип("Строка")  Тогда   
			СообщениеОбОшибке =  ТарифыТипы;  
			Иначе Если ТарифыТипы.Количество() = 0 Тогда 
				СообщениеОбОшибке = "Не удалось подобрать тарифы для данной доставки";	
			КонецЕсли;	
		КонецЕсли;
	Иначе
		СообщениеОбОшибке = "Нет подходящего Типа ТС для данной доставки";
	КонецЕсли;
	
	Возврат (Новый Структура("СообщениеОбОшибке,ТарифыТипы", СообщениеОбОшибке, ТарифыТипы));	
