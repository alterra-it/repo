 
#Область РаботаСКритериямиДляТиповТС

Функция ПодборКритериевДляТиповТС(МассивЛибоТЗ) Экспорт
	
	Если ЗначениеЗаполнено(МассивЛибоТЗ) Тогда
		Если ТипЗнч(МассивЛибоТЗ) = Тип("ТаблицаЗначений") Тогда 
			ТекстЗапроса = 
				"ВЫБРАТЬ
				|	ТЗ.Номенклатура КАК Ссылка,
				|	ТЗ.КоличествоУпаковок КАК Количество
				|ПОМЕСТИТЬ ТЗ
				|ИЗ
				|	&ИсточникДанных КАК ТЗ
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ТЗ.Ссылка КАК Ссылка,
				|	СУММА(ТЗ.Количество) КАК Количество
				|ПОМЕСТИТЬ Товары
				|ИЗ
				|	ТЗ КАК ТЗ
				|
				|СГРУППИРОВАТЬ ПО
				|	ТЗ.Ссылка";
			
		ИначеЕсли ТипЗнч(МассивЛибоТЗ) = Тип("Массив") Тогда    
			ТекстЗапроса =             
				"ВЫБРАТЬ
				|	ДокТовары.Номенклатура КАК Номенклатура,
				|	ДокТовары.КоличествоУпаковок КАК КоличествоУпаковок
				|ПОМЕСТИТЬ ДокТовары
				|ИЗ
				|	Документ.ПеремещениеТоваров.Товары КАК ДокТовары
				|ГДЕ
				|	ДокТовары.Ссылка В(&ИсточникДанных)
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ДокТовары.Номенклатура,
				|	ДокТовары.КоличествоУпаковок
				|ИЗ
				|	Документ.РеализацияТоваровУслуг.Товары КАК ДокТовары
				|ГДЕ
				|	ДокТовары.Ссылка В(&ИсточникДанных)
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ДокТовары.Номенклатура,
				|	ДокТовары.КоличествоУпаковок
				|ИЗ
				|	Документ.ЧекККМ.Товары КАК ДокТовары
				|ГДЕ
				|	ДокТовары.Ссылка В(&ИсточникДанных)
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ДокТовары.Номенклатура,
				|	ДокТовары.КоличествоУпаковок
				|ИЗ
				|	Документ.ЗаказКлиента.Товары КАК ДокТовары
				|ГДЕ
				|	ДокТовары.Ссылка В(&ИсточникДанных)
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ДокТовары.Номенклатура,
				|	ДокТовары.КоличествоУпаковок
				|ИЗ
				|	Документ.ВозвратТоваровОтКлиента.Товары КАК ДокТовары
				|ГДЕ
				|	ДокТовары.Ссылка В(&ИсточникДанных)
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	ДокТовары.Номенклатура,
				|	ДокТовары.Количество
				|ИЗ
				|	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ДокТовары
				|ГДЕ
				|	ДокТовары.Ссылка В(&ИсточникДанных)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ДокТовары.Номенклатура КАК Ссылка,
				|	СУММА(ДокТовары.КоличествоУпаковок) КАК Количество
				|ПОМЕСТИТЬ Товары
				|ИЗ
				|	ДокТовары КАК ДокТовары
				|
				|СГРУППИРОВАТЬ ПО
				|	ДокТовары.Номенклатура";
		Иначе
			Возврат Неопределено;
		КонецЕсли;
				
		Запрос = Новый Запрос;
		ТекстЗапроса = ТекстЗапроса + " ; " + 
			"ВЫБРАТЬ
			|	НоменклатураСегмента.Сегмент КАК Сегмент,
			|	СправочникНоменклатура.Ссылка.ВидНоменклатуры КАК ВидНоменклатуры,
			|	СправочникНоменклатура.Ссылка.ВесЕдиницаИзмерения КАК ВесЕдиницаИзмерения,
			|	СправочникНоменклатура.Ссылка.ДлинаЕдиницаИзмерения КАК ДлинаЕдиницаИзмерения,
			|	СправочникНоменклатура.Ссылка.ОбъемЕдиницаИзмерения КАК ОбъемЕдиницаИзмерения,
			|	СправочникНоменклатура.Ссылка.ПлощадьЕдиницаИзмерения КАК ПлощадьЕдиницаИзмерения,
			|	ВЫБОР
			|		КОГДА СправочникНоменклатура.Ссылка.НаборУпаковок = &НаборУпаковок
			|				ИЛИ СправочникНоменклатура.Ссылка.ПоставляетсяВМногооборотнойТаре
			|				ИЛИ СправочникНоменклатура.Ссылка.ВидНоменклатуры.ПоставляетсяВМногооборотнойТаре
			|			ТОГДА ИСТИНА
			|		ИНАЧЕ ЛОЖЬ
			|	КОНЕЦ КАК Поддон,
			|	&ТекстЗапросаВесУпаковки КАК Вес,
			|   ВЫБОР
			|		КОГДА ГабаритыТовара.Длина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ПустаяСсылка)
			|				ИЛИ ГабаритыТовара.Длина = 0
			|				ИЛИ ГабаритыТовара.Длина = НЕОПРЕДЕЛЕНО
			|				ИЛИ ГабаритыТовара.Длина ЕСТЬ NULL
			|			ТОГДА &ТекстЗапросаДлинаУпаковки
			|		КОГДА ГабаритыТовара.Длина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
			|			ТОГДА ВЫРАЗИТЬ(СправочникНоменклатура.Количество КАК ЧИСЛО(15, 7))
			|		ИНАЧЕ ВЫРАЗИТЬ(ГабаритыТовара.Длина КАК ЧИСЛО(15, 7))
			|	КОНЕЦ КАК Длина,
			|	ВЫБОР
			|		КОГДА ГабаритыТовара.Длина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ПустаяСсылка)
			|				ИЛИ ГабаритыТовара.Длина = 0
			|				ИЛИ ГабаритыТовара.Длина = НЕОПРЕДЕЛЕНО
			|				ИЛИ ГабаритыТовара.Длина ЕСТЬ NULL
			|				ИЛИ ГабаритыТовара.Ширина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ПустаяСсылка)
			|				ИЛИ ГабаритыТовара.Ширина = 0
			|				ИЛИ ГабаритыТовара.Ширина = НЕОПРЕДЕЛЕНО
			|				ИЛИ ГабаритыТовара.Ширина ЕСТЬ NULL
			|			ТОГДА &ТекстЗапросаПлощадьУпаковки
			|		КОГДА ГабаритыТовара.Длина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
			|				ИЛИ ГабаритыТовара.Ширина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
			|			ТОГДА ВЫРАЗИТЬ(СправочникНоменклатура.Количество КАК ЧИСЛО(15, 7))
			|		ИНАЧЕ (ВЫРАЗИТЬ(ГабаритыТовара.Длина КАК ЧИСЛО(15, 7))) * (ВЫРАЗИТЬ(ГабаритыТовара.Ширина КАК ЧИСЛО(15, 7)))
			|	КОНЕЦ КАК Площадь,
			|	ВЫБОР
			|		КОГДА ГабаритыТовара.Длина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ПустаяСсылка)
			|				ИЛИ ГабаритыТовара.Длина = 0
			|				ИЛИ ГабаритыТовара.Длина = НЕОПРЕДЕЛЕНО
			|				ИЛИ ГабаритыТовара.Длина ЕСТЬ NULL
			|				ИЛИ ГабаритыТовара.Ширина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ПустаяСсылка)
			|				ИЛИ ГабаритыТовара.Ширина = 0
			|				ИЛИ ГабаритыТовара.Ширина = НЕОПРЕДЕЛЕНО
			|				ИЛИ ГабаритыТовара.Ширина ЕСТЬ NULL
			|				ИЛИ ГабаритыТовара.Высота = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ПустаяСсылка)
			|				ИЛИ ГабаритыТовара.Высота = 0
			|				ИЛИ ГабаритыТовара.Высота = НЕОПРЕДЕЛЕНО
			|				ИЛИ ГабаритыТовара.Высота ЕСТЬ NULL
			|			ТОГДА &ТекстЗапросаОбъемУпаковки
			|		КОГДА ГабаритыТовара.Длина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
			|				ИЛИ ГабаритыТовара.Ширина = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
			|				ИЛИ ГабаритыТовара.Высота = ЗНАЧЕНИЕ(Перечисление.ДействияОпределенияГабаритовТовара.ИспользоватьКоличествоИзДокумента)
			|			ТОГДА ВЫРАЗИТЬ(СправочникНоменклатура.Количество КАК ЧИСЛО(15, 7))
			|		ИНАЧЕ (ВЫРАЗИТЬ(ГабаритыТовара.Длина КАК ЧИСЛО(15, 7))) * (ВЫРАЗИТЬ(ГабаритыТовара.Ширина КАК ЧИСЛО(15, 7))) * (ВЫРАЗИТЬ(ГабаритыТовара.Высота КАК ЧИСЛО(15, 7)))
			|	КОНЕЦ КАК Объем,
			|	ВЫРАЗИТЬ(СправочникНоменклатура.Количество КАК ЧИСЛО(15, 7)) КАК Количество
			|ПОМЕСТИТЬ ВТИтоги
			|ИЗ
			|	Товары КАК СправочникНоменклатура
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
			|		ПО СправочникНоменклатура.Ссылка = НоменклатураСегмента.Номенклатура
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГабаритыТовара КАК ГабаритыТовара
			|		ПО СправочникНоменклатура.Ссылка = ГабаритыТовара.Номенклатура
			|ГДЕ
			|	СправочникНоменклатура.Ссылка.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	Критерии.Ссылка КАК Ссылка
			|ИЗ
			|	ВТИтоги КАК Товары
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КритерииДляТиповТС КАК Критерии
			|		ПО (Критерии.СегментНоменклатуры = Товары.Сегмент
			|				ИЛИ Критерии.СегментНоменклатуры = ЗНАЧЕНИЕ(Справочник.СегментыНоменклатуры.ПустаяСсылка))
			|			И (Критерии.ВидНоменклатуры = Товары.ВидНоменклатуры)
			|			И (Критерии.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Вес)
			|					И Критерии.ЕдиницаИзмерения = Товары.ВесЕдиницаИзмерения
			|					И (Товары.Вес >= Критерии.МинимальноеЗначение
			|						ИЛИ Критерии.МинимальноеЗначение = 0)
			|					И (Товары.Вес <= Критерии.МаксимальноеЗначение
			|						ИЛИ Критерии.МаксимальноеЗначение = 0)
			|				ИЛИ Критерии.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Объем)
			|					И Критерии.ЕдиницаИзмерения = Товары.ОбъемЕдиницаИзмерения
			|					И (Товары.Объем >= Критерии.МинимальноеЗначение
			|						ИЛИ Критерии.МинимальноеЗначение = 0)
			|					И (Товары.Объем <= Критерии.МаксимальноеЗначение
			|						ИЛИ Критерии.МаксимальноеЗначение = 0)
			|				ИЛИ Критерии.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Длина)
			|					И Критерии.ЕдиницаИзмерения = Товары.ДлинаЕдиницаИзмерения
			|					И (Товары.Длина >= Критерии.МинимальноеЗначение
			|						ИЛИ Критерии.МинимальноеЗначение = 0)
			|					И (Товары.Длина <= Критерии.МаксимальноеЗначение
			|						ИЛИ Критерии.МаксимальноеЗначение = 0)
			|				ИЛИ Критерии.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Площадь)
			|					И Критерии.ЕдиницаИзмерения = Товары.ПлощадьЕдиницаИзмерения
			|					И (Товары.Площадь >= Критерии.МинимальноеЗначение
			|						ИЛИ Критерии.МинимальноеЗначение = 0)
			|					И (Товары.Площадь <= Критерии.МаксимальноеЗначение
			|						ИЛИ Критерии.МаксимальноеЗначение = 0))
			|			И (Товары.Количество > Критерии.ОграничениеПоКоличеству
			|				ИЛИ Критерии.ОграничениеПоКоличеству = 0)
			|			И (Критерии.Поддон = Товары.Поддон)
			|ГДЕ
			|	Критерии.Ссылка <> ЗНАЧЕНИЕ(Справочник.КритерииДляТиповТС.ПустаяСсылка)
			|	И НЕ Критерии.ПометкаУдаления
			|
			|СГРУППИРОВАТЬ ПО
			|	Критерии.Ссылка";

		Запрос.УстановитьПараметр("ИсточникДанных", МассивЛибоТЗ);
		Запрос.УстановитьПараметр("НаборУпаковок", Справочники.НаборыУпаковок.НайтиПоНаименованию("поддон"));
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаВесУпаковки", Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки("СправочникНоменклатура.Ссылка.ЕдиницаИзмерения", "СправочникНоменклатура.Ссылка", Ложь));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаОбъемУпаковки", Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки("СправочникНоменклатура.Ссылка.ЕдиницаИзмерения", "СправочникНоменклатура.Ссылка", Ложь));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаДлинаУпаковки", Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаДлинаУпаковки("СправочникНоменклатура.Ссылка.ЕдиницаИзмерения", "СправочникНоменклатура.Ссылка", Ложь));
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаПлощадьУпаковки", Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаПлощадьУпаковки("СправочникНоменклатура.Ссылка.ЕдиницаИзмерения", "СправочникНоменклатура.Ссылка", Ложь));
	
		Запрос.Текст = ТекстЗапроса;
		
		Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	КонецЕсли;
	
	Возврат Неопределено;  
	
КонецФункции

Функция СочетанияКритериевДляТиповТС() Экспорт
		
	Возврат 
		"ВЫБРАТЬ
		|	Сочетания.ТипТранспортногоСредства КАК ТипТранспортногоСредства,
		|	Сочетания.КритерийСовместимости КАК КритерийСовместимости,
		|	Сочетания.КритерийНесовместимости КАК КритерийНесовместимости
		|ПОМЕСТИТЬ ВТСочетанияИтог
		|ИЗ
		|	РегистрСведений.СочетанияКритериевДляТиповТС КАК Сочетания
		|ГДЕ
		|	Сочетания.КритерийСовместимости <> ЗНАЧЕНИЕ(Справочник.КритерииДляТиповТС.ПустаяСсылка)
		|	И Сочетания.КритерийНесовместимости <> ЗНАЧЕНИЕ(Справочник.КритерииДляТиповТС.ПустаяСсылка)
		|	И НЕ (Сочетания.ТипТранспортногоСредства, Сочетания.КритерийНесовместимости, Сочетания.КритерийСовместимости) В
		|				(ВЫБРАТЬ
		|					Сочетания.ТипТранспортногоСредства,
		|					Сочетания.КритерийСовместимости,
		|					Сочетания.КритерийНесовместимости
		|				ИЗ
		|					РегистрСведений.СочетанияКритериевДляТиповТС КАК Сочетания)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сочетания.ТипТранспортногоСредства КАК ТипТранспортногоСредства,
		|	Сочетания.КритерийСовместимости КАК КритерийСовместимости,
		|	Сочетания.КритерийНесовместимости КАК КритерийНесовместимости
		|ПОМЕСТИТЬ ВТ_СочетанияКритериевДляТиповТС
		|ИЗ
		|	РегистрСведений.СочетанияКритериевДляТиповТС КАК Сочетания
		|ГДЕ
		|	НЕ (Сочетания.ТипТранспортногоСредства, Сочетания.КритерийСовместимости, Сочетания.КритерийНесовместимости) В
		|				(ВЫБРАТЬ
		|					ВТСочетанияИтог.ТипТранспортногоСредства,
		|					ВТСочетанияИтог.КритерийСовместимости,
		|					ВТСочетанияИтог.КритерийНесовместимости
		|				ИЗ
		|					ВТСочетанияИтог)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Итог.ТипТранспортногоСредства,
		|	Итог.КритерийСовместимости,
		|	Итог.КритерийНесовместимости
		|ИЗ
		|	ВТСочетанияИтог КАК Итог
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Итог.ТипТранспортногоСредства,
		|	Итог.КритерийНесовместимости,
		|	Итог.КритерийСовместимости
		|ИЗ
		|	ВТСочетанияИтог КАК Итог" + " ; "; 
	
КонецФункции

Функция ОпределениеТипаТСДляЗаказаНаДоставку (МассивКритериев) Экспорт

	Если ЗначениеЗаполнено(МассивКритериев) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			СочетанияКритериевДляТиповТС() +
			"ВЫБРАТЬ
			|	КритерииДляТиповТС.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТМассивКритериев
			|ИЗ
			|	Справочник.КритерииДляТиповТС КАК КритерииДляТиповТС
			|ГДЕ
			|	КритерииДляТиповТС.Ссылка В(&МассивКритериев)
			|	И КритерииДляТиповТС.Ссылка <> ЗНАЧЕНИЕ(Справочник.КритерииДляТиповТС.ПустаяСсылка)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СочетанияКритериев.ТипТранспортногоСредства КАК ТипТранспортногоСредства
			|ПОМЕСТИТЬ ВТНесовместимыеТипыТС
			|ИЗ
			|	ВТ_СочетанияКритериевДляТиповТС КАК СочетанияКритериев
			|ГДЕ
			|	СочетанияКритериев.КритерийСовместимости В
			|			(ВЫБРАТЬ
			|				ВТМассивКритериев.Ссылка
			|			ИЗ
			|				ВТМассивКритериев)
			|	И СочетанияКритериев.КритерийНесовместимости В
			|			(ВЫБРАТЬ
			|				ВТМассивКритериев.Ссылка
			|			ИЗ
			|				ВТМассивКритериев)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СочетанияКритериев.ТипТранспортногоСредства КАК ТипТранспортногоСредства
			|ИЗ
			|	ВТ_СочетанияКритериевДляТиповТС КАК СочетанияКритериев
			|ГДЕ
			|	СочетанияКритериев.КритерийСовместимости В
			|			(ВЫБРАТЬ
			|				ВТМассивКритериев.Ссылка
			|			ИЗ
			|				ВТМассивКритериев)
			|	И НЕ СочетанияКритериев.КритерийНесовместимости В
			|				(ВЫБРАТЬ
			|					ВТМассивКритериев.Ссылка
			|				ИЗ
			|					ВТМассивКритериев)
			|	И НЕ СочетанияКритериев.ТипТранспортногоСредства В
			|				(ВЫБРАТЬ
			|					ВТНесовместимыеТипыТС.ТипТранспортногоСредства
			|				ИЗ
			|					ВТНесовместимыеТипыТС)
			|
			|УПОРЯДОЧИТЬ ПО
			|	СочетанияКритериев.ТипТранспортногоСредства.Приоритет";
		
		Запрос.УстановитьПараметр("МассивКритериев", МассивКритериев);
		
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() И ЗначениеЗаполнено(Результат.ТипТранспортногоСредства) Тогда
			Возврат Результат.ТипТранспортногоСредства;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено; 
	
КонецФункции

Функция СкрытьНесовместимыеЗаказы(ТипТС, ЗаказыВРейс, ПулЗаказов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		СочетанияКритериевДляТиповТС() +
		"ВЫБРАТЬ
		|	Заказ.Критерий КАК Критерий
		|ПОМЕСТИТЬ ВТМассивСтарыхЗаказов
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.КритерииCовместимостиСТипамиТС КАК Заказ
		|ГДЕ
		|	Заказ.Ссылка В(&ЗаказыВРейс)
		|	И Заказ.Критерий <> ЗНАЧЕНИЕ(Справочник.КритерииДляТиповТС.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	Заказ.Критерий
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СочетанияКритериев.КритерийНесовместимости КАК Критерий
		|ПОМЕСТИТЬ ВТКритерииНесовместимости
		|ИЗ
		|	ВТ_СочетанияКритериевДляТиповТС КАК СочетанияКритериев
		|ГДЕ
		|	СочетанияКритериев.ТипТранспортногоСредства = &ТипТС
		|	И СочетанияКритериев.КритерийСовместимости В
		|			(ВЫБРАТЬ
		|				ВТМассивСтарыхЗаказов.Критерий
		|			ИЗ
		|				ВТМассивСтарыхЗаказов)
		|
		|СГРУППИРОВАТЬ ПО
		|	СочетанияКритериев.КритерийНесовместимости
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Заказ.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.КритерииCовместимостиСТипамиТС КАК Заказ
		|ГДЕ
		|	Заказ.Ссылка В(&ПулЗаказов)
		|	И Заказ.Критерий <> ЗНАЧЕНИЕ(Справочник.КритерииДляТиповТС.ПустаяСсылка)
		|	И Заказ.Критерий В
		|			(ВЫБРАТЬ
		|				ВТКритерииНесовместимости.Критерий
		|			ИЗ
		|				ВТКритерииНесовместимости)";
	
	Запрос.УстановитьПараметр("ТипТС", ТипТС);
	Запрос.УстановитьПараметр("ЗаказыВРейс", ЗаказыВРейс);
	Запрос.УстановитьПараметр("ПулЗаказов", ПулЗаказов);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"); 
	
КонецФункции

