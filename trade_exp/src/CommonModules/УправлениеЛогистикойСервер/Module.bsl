		 Иначе  
			 //относим к конкретной толщине
			 Для Каждого Стр Из ТаблицаТолщин Цикл
				 Если ТолщинаЧисло <= Стр.Толщина Тогда 
					 Строка.Толщина = Стр.Толщина; 
					 Строка.МаксКоличествоВСкрутке = Стр.МаксКоличество;
				 КонецЕсли;
			 КонецЦикла;  
			 
			 Если Строка.МаксКоличествоВСкрутке > Строка.КоличествоУпаковок Тогда
				 Строка.КоличествоСкруток = 1; 	
			 Иначе  //нужно разделить на несколько скруток
				 Строка.КоличествоСкруток = Цел(Строка.КоличествоУпаковок/Строка.МаксКоличествоВСкрутке);  
				 
				 Остаток = Строка.КоличествоУпаковок - Строка.КоличествоСкруток * Строка.МаксКоличествоВСкрутке; 
				 
				 Строка.КоличествоУпаковок = Строка.МаксКоличествоВСкрутке;
				 Если Остаток > 0 Тогда					
					 НС = ТоварыОбъем.Добавить(); 
					 НС.Номенклатура = Строка.Номенклатура;
					 НС.Толщина = Строка.Толщина;
					 НС.КоличествоУпаковок = Остаток;
					 НС.КоличествоСкруток = 1;
					 НС.НомерСтроки = Строка.НомерСтроки;
				 КонецЕсли;
			 КонецЕсли;
		 КонецЕсли;;
	 КонецЦикла; 
	 
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст =
	 "ВЫБРАТЬ
	 |	ПравилаСкруткиПоликарбоната.Количество КАК Количество,
