Функция ПолучитьСотрудникаПоВнутреннемуНомеру(ВнутреннийНомер) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Сотрудник
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.ВнутреннийТелефон = &ВнутреннийТелефон
		|	И Сотрудники.ПометкаУдаления = Ложь
		|	И Сотрудники.Уволен = Ложь";
	
	Запрос.УстановитьПараметр("ВнутреннийТелефон", ВнутреннийНомер);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	ПустоеЗначение = Справочники.Сотрудники.ПустаяСсылка();
	
	Если Выборка.Количество() = 0 Тогда
		
		Возврат ПустоеЗначение;
		
	ИначеЕсли Выборка.Следующий() Тогда
		
		Если НЕ ЗначениеЗаполнено(Выборка.Сотрудник) Тогда
			Возврат ПустоеЗначение;
		Иначе
			Возврат Выборка.Сотрудник;
		КонецЕсли;
		
	Иначе
		Возврат ПустоеЗначение;
	КонецЕсли;
	
