Процедура ВходВОчередь() Экспорт
	
	Пользователь = Пользователи.ТекущийПользователь();
	Настройки = НастройкиАстериск();

	РезультатАвторизации = Авторизация(Настройки);	
	
	Если РезультатАвторизации.КодСостояния=200 Тогда
		Cookie=РезультатАвторизации.Заголовки.Получить("Set-Cookie");
	Иначе
		Возврат;
	КонецЕсли; 
	
	ТекстКоманды="/asterisk/rawman?action=QueueAdd&Queue=queue_overall&Interface=SIP/"+ПолучитьВнутреннийНомерПользователя()+"&Paused=no";
	
	РезультатЗапроса = ВыполнитьЗапрос(Настройки,ТекстКоманды,Cookie);	
	
	Если РезультатЗапроса.КодСостояния=200 Тогда
		Сообщить("Вход в очередь выполнен успешно!"); 
	Иначе  
		Попытка
			ЗаписьЖурналаРегистрации("Вход в очередь оператора колл-центра",УровеньЖурналаРегистрации.Ошибка,,,"" + Пользователь + "  " + РезультатЗапроса.ПолучитьТелоКакСтроку(),); 
		Исключение 
			ЗаписьЖурналаРегистрации("Вход в очередь оператора колл-центра",УровеньЖурналаРегистрации.Ошибка,,,"" + Пользователь + "Ошибка при получении тела Результата запроса" ,); 
		Конецпопытки;
	КонецЕсли; 
		
КонецПроцедуры

Процедура ВыходИзОчереди() Экспорт
	
	Пользователь = Пользователи.ТекущийПользователь();
	Настройки = НастройкиАстериск();
   	РезультатАвторизации = Авторизация(Настройки);	
	
	Если РезультатАвторизации.КодСостояния=200 Тогда
		Cookie=РезультатАвторизации.Заголовки.Получить("Set-Cookie");
	Иначе
		Возврат;
	КонецЕсли; 
	
	ТекстКоманды="/asterisk/rawman?action=QueueRemove&Queue=queue_overall&Interface=SIP/"+ПолучитьВнутреннийНомерПользователя();
	
	РезультатЗапроса = ВыполнитьЗапрос(Настройки,ТекстКоманды,Cookie);	
	
	Если РезультатЗапроса.КодСостояния=200 Тогда
		Сообщить("Выход из очереди выполнен успешно!");
	Иначе
		Попытка
			ЗаписьЖурналаРегистрации("Выход из очереди оператора колл-центра",УровеньЖурналаРегистрации.Ошибка,,,"" + Пользователь + "  " + РезультатЗапроса.ПолучитьТелоКакСтроку(),); 
		Исключение 
			ЗаписьЖурналаРегистрации("Выход из очереди оператора колл-центра",УровеньЖурналаРегистрации.Ошибка,,,"" + Пользователь + "Ошибка при получении тела Результата запроса" ,); 
		Конецпопытки;

	КонецЕсли; 
	
КонецПроцедуры

Функция СтатусОчереди() Экспорт
	
    Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ДанныеЗвонков.ИдентификаторЗвонкаВАТС) КАК Количество
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|ГДЕ
		|	ДанныеЗвонков.ДатаСобытия >= &ДатаСобытия
		|	И НЕ ДанныеЗвонков.ВызовЗавершен
		|   И ДанныеЗвонков.НачалоРазговора = ДАТАВРЕМЯ(1, 1, 1)
		|   И ДанныеЗвонков.ВходящееИсходящее = &ТипЗвонка
		|   И ДанныеЗвонков.Сотрудник.Отдел.ИдентификаторАстерикс=1";
	
	Запрос.УстановитьПараметр("ДатаСобытия", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ТипЗвонка", Перечисления.ВходящееИсходящееСобытие.Входящее);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Количество;
	КонецЦикла;
		
	Возврат 0;
	
КонецФункции

// Получить настройки сервера астериска
// Возвращаемое значение:
//   - Настройки - тип "Структура" 
//
Функция НастройкиАстериск() Экспорт
	
	Настройки = Новый Структура();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	_1Servic_РС_НастройкаАстериск.Настройка КАК Настройка,
	|	_1Servic_РС_НастройкаАстериск.Значение КАК Значение
	|ИЗ
	|	РегистрСведений._1Servic_РС_НастройкаАстериск КАК _1Servic_РС_НастройкаАстериск";
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Настройки.Вставить(ВыборкаДетальныеЗаписи.Настройка,ВыборкаДетальныеЗаписи.Значение);	
		
	КонецЦикла;

	Возврат Настройки;
	
КонецФункции

// Отправить запрос на авторизацию
// Возвращаемое значение:
//   - Ответ - тип "HTTPОтвет" 
// 
Функция Авторизация(Настройки)  Экспорт
	
	ТекстКоманды="/asterisk/rawman?action=login&username="+СокрЛП(Настройки.User)+"&secret="+СокрЛП(Настройки.Password);
	
	Запрос= Новый HTTPЗапрос();
	
	Запрос.АдресРесурса=ТекстКоманды;
	
	Соединение=Новый HTTPСоединение(Настройки.IP,Настройки.Port,,,,30,);
	
	Ответ=Соединение.Получить(Запрос);

	Возврат Ответ;
	
КонецФункции

// Отправить произвольный запрос
// Возвращаемое значение:
//   - Ответ - тип "HTTPОтвет" 
//
Функция ВыполнитьЗапрос(Настройки,ТекстКоманды,Cookie) Экспорт
	
	Заголовки=Новый Соответствие;
	Заголовки.Вставить("Cookie",Cookie);
	Заголовки.Вставить("Accept","*/*");

	Запрос= Новый HTTPЗапрос();
	Запрос.АдресРесурса=ТекстКоманды;
	Запрос.Заголовки=Заголовки;

	Соединение=Новый HTTPСоединение(Настройки.IP,Настройки.Port,,,,30,);
	Ответ=Соединение.Получить(Запрос);
	
	Возврат Ответ;
	
КонецФункции

// Получить внутренний номер текущего пользователя
// Возвращаемое значение:
//   - Номер - тип "Строка" 
//
Функция ПолучитьВнутреннийНомерПользователя() Экспорт
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	_1Servic_Стек_Пользователей_Упрощенный.ВнутреннийНомер КАК ВнутреннийНомер
		|ИЗ
		|	РегистрСведений._1Servic_Стек_Пользователей_Упрощенный КАК _1Servic_Стек_Пользователей_Упрощенный
		|ГДЕ
		|	_1Servic_Стек_Пользователей_Упрощенный.Пользователь = &Пользователь";
		
		Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь()); 
		
		УстановитьПривилегированныйРежим(Истина);
		Выборка = Запрос.Выполнить().Выбрать();		
		УстановитьПривилегированныйРежим(Ложь); 
		
		Если Выборка.Следующий() Тогда
			Возврат Выборка.ВнутреннийНомер;
		КонецЕсли;
		
		Возврат Неопределено;
		
КонецФункции

Функция ПолучитьПоследнийЗвонокПоНомеру(НомерТелефона)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДанныеЗвонков.НомерОрганизации КАК НомерОрганизации
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|ГДЕ
		|	ДанныеЗвонков.НомерОтКого = &НомерОтКого
		|   И ДанныеЗвонков.ВходящееИсходящее = &ВходящееИсходящее
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДанныеЗвонков.ДатаСобытия УБЫВ";
	
	Запрос.УстановитьПараметр("НомерОтКого", НомерТелефона);
	Запрос.УстановитьПараметр("ВходящееИсходящее", Перечисления.ВходящееИсходящееСобытие.Входящее);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.НомерОрганизации;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

