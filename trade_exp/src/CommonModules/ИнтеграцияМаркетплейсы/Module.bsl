#Область Отгрузки

Функция ПодтвердитьОтгрузку(Рейс, ВозвратТовара = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыОтгрузки(ВозвратТовара);
	
	Если Не ЗначениеЗаполнено(Рейс) Тогда
		ЗакрытьПараметрыОтгрузки(РезультатВыполнения, "Отсутствует рейс для определения отгрузки");
		Возврат РезультатВыполнения;	
	КонецЕсли;
	
	МаркетплейсЗаказОтгрузки = ПолучитьМаркетплейсЗаказОтгрузки(Рейс);
	ЗаполнитьЗначенияСвойств(РезультатВыполнения, МаркетплейсЗаказОтгрузки, "Маркетплейс, ЗаказНаДоставку");
	Если Не ЗначениеЗаполнено(РезультатВыполнения.МаркетПлейс) Тогда
		ЗакрытьПараметрыОтгрузки(РезультатВыполнения, "Отсутствуют отгрузки маркетплейсам");
		Возврат РезультатВыполнения;	
	КонецЕсли;

	ПолучениеШтрихкода = ПолучитьШтрихкодОтгрузки(Рейс, ВозвратТовара, РезультатВыполнения.МаркетПлейс);

	// Новая отгрузка с результатом выполнения в итоговый результат
	Если Не ЗначениеЗаполнено(ПолучениеШтрихкода) Тогда
		НоваяОтгрузка = СформироватьОтгрузку(РезультатВыполнения.Маркетплейс, Рейс, ВозвратТовара);
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, НоваяОтгрузка);
		
		// Сохранить результат новой отгрузки
		Если НоваяОтгрузка.Результат Тогда
			ЗаписьОтгрузки = ЗаписатьОтгрузку(Рейс, ВозвратТовара, РезультатВыполнения.Маркетплейс, НоваяОтгрузка);
			РезультатВыполнения.Результат = ЗаписьОтгрузки.Результат;
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ЗаписьОтгрузки.Сообщение;
		КонецЕсли;
		
		ЗакрытьПараметрыОтгрузки(РезультатВыполнения, "");	
	
	// Существующая отгрузка сохраненная ранее
	Иначе
		РезультатВыполнения.Результат = Истина;
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, ПолучениеШтрихкода); 
		ЗакрытьПараметрыОтгрузки(РезультатВыполнения, СтрШаблон("Получена сохраненная отрузка %1 штрихкод %2 по %3", 
			РезультатВыполнения.Отгрузка, РезультатВыполнения.Штрихкод, Рейс));	
	КонецЕсли; 
	
	ЗаписатьЛоги(ПолучитьНастройкиИнтеграции(), ПолучитьНазваниеМаркетплейса(РезультатВыполнения.МаркетПлейс, "en"), 
		ВозвратТовара, РезультатВыполнения);
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьМаркетплейсЗаказОтгрузки(Рейс)
	
	РезультатВыполнения = Новый Структура("Маркетплейс, ЗаказНаДоставку", "");

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	Рейс.Ссылка КАК Рейс,    
		|	ЗаказНаДоставку.Ссылка КАК ЗаказНаДоставку,
		|	ЗаказНаДоставку.ОбъектДоставки КАК ОбъектДоставки,
		|	ЗаказНаДоставку.Партнер КАК Партнер
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс КАК Рейс   
		|	СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ОснованияДоставки
		|		ПО Рейс.Ссылка = &Рейс	                       
//		|		И Рейс.Проведен           
		|		И Рейс.Ссылка = ОснованияДоставки.Ссылка
		|	СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставку
		|		ПО ОснованияДоставки.Документ = ЗаказНаДоставку.Ссылка  
		|		И ЗаказНаДоставку.Партнер = &Партнер 
		|		И ЗаказНаДоставку.ОбъектДоставки = &ОбъектДоставки    
		|	СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопСведения
		|		ПО ЗаказНаДоставку.Партнер = ДопСведения.Объект
		|		И ДопСведения.Свойство.Имя = &МаркетПлейс 
		|		И ДопСведения.Значение = &Озон";
	
	Запрос.УстановитьПараметр("Рейс", Рейс);
	Запрос.УстановитьПараметр("Партнер", Справочники.Партнеры.НайтиПоНаименованию("Интернет решения ООО"));
	Запрос.УстановитьПараметр("ОбъектДоставки", Справочники.ОбъектыДоставки.НайтиПоНаименованию("СЦ ОЗОН Дальняя"));
	Запрос.УстановитьПараметр("МаркетПлейс", "Маркетплейс_4c7083f3175d4c5e862c415877c4206c");
	Запрос.УстановитьПараметр("Озон", "Озон"); 
	
	Выборка	= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		РезультатВыполнения.Маркетплейс = "Озон";	
		РезультатВыполнения.ЗаказНаДоставку = Выборка.ЗаказНаДоставку; 
	КонецЕсли;
	
	Возврат РезультатВыполнения;

КонецФункции	

#КонецОбласти

#Область МетодыКонкретныхМаркетПлейсов	

Функция СформироватьОтгрузку(МаркетПлейс, Рейс, ВозвратТовара)
		
	МодульИнтеграции =  ОбщегоНазначения.ОбщийМодуль("Интеграция" + МаркетПлейс);
	РезультатВыполнения = МодульИнтеграции.СформироватьОтгрузку(Рейс, ВозвратТовара);
	
	Возврат РезультатВыполнения; 
	
КонецФункции	

Функция ПолучитьВидМаркетплейса(МаркетПлейс)
		
	МодульИнтеграции =  ОбщегоНазначения.ОбщийМодуль("Интеграция" + МаркетПлейс);
	РезультатВыполнения = МодульИнтеграции.ПолучитьВидМаркетплейса();
	
	Возврат РезультатВыполнения; 
	
КонецФункции

Функция ПолучитьНазваниеМаркетплейса(МаркетПлейс, lang)
		
	МодульИнтеграции =  ОбщегоНазначения.ОбщийМодуль("Интеграция" + МаркетПлейс);
	РезультатВыполнения = МодульИнтеграции.ПолучитьНазваниеМаркетплейса(lang);
	
	Возврат РезультатВыполнения; 
	
КонецФункции

#КонецОбласти

#Область РегистрОтгрузок 

Функция ПолучитьШтрихкодОтгрузки(Рейс, ВозвратТовара, МаркетПлейс);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	Отгрузка, Штрихкод
		|ИЗ
		|	РегистрСведений.ОтгрузкиМаркетплейсов
		|ГДЕ 
		|	Рейс = &Рейс
		|	И ВозвратТовара = &ВозвратТовара
		|	И Маркетплейс = &Маркетплейс";
		
	Запрос.УстановитьПараметр("Рейс", Рейс);
	Запрос.УстановитьПараметр("ВозвратТовара", ВозвратТовара);
	Запрос.УстановитьПараметр("Маркетплейс", ПолучитьВидМаркетплейса(МаркетПлейс));
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка, Неопределено);

Конецфункции

Функция ЗаписатьОтгрузку(Рейс, ВозвратТовара, Маркетплейс, НоваяОтгрузка)
	
	РезультатВыполнения = Новый Структура("Результат, Сообщение", Ложь, "");
	
	Попытка
	
		НаборЗаписей = РегистрыСведений.ОтгрузкиМаркетплейсов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Рейс.Установить(Рейс);	
		НаборЗаписей.Отбор.ВозвратТовара.Установить(ВозвратТовара);
		НаборЗаписей.Отбор.Маркетплейс.Установить(ПолучитьВидМаркетплейса(МаркетПлейс));

		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Дата = ТекущаяДатаСеанса();
		НоваяЗапись.Рейс = Рейс;	
		НоваяЗапись.Маркетплейс = ПолучитьВидМаркетплейса(МаркетПлейс);
		НоваяЗапись.ВозвратТовара = ВозвратТовара;
		НоваяЗапись.Отгрузка = НоваяОтгрузка.Отгрузка;
		НоваяЗапись.Штрихкод = НоваяОтгрузка.Штрихкод;
		
		НаборЗаписей.Записать();
		
		РезультатВыполнения.Результат = Истина;
	Исключение
		РезультатВыполнения.Сообщение = "Отгрузка не записана в регистр:" + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + Символы.ПС;
	КонецПопытки;	
		
	Возврат РезультатВыполнения;	

КонецФункции

#КонецОбласти 

#Область Параметры

Функция ПараметрыОтгрузки(ВозвратТовара = Ложь)  
	
	Дата = ТекущаяДатаСеанса();
		
	Параметры = Новый Структура;
	Параметры.Вставить("Результат", 	Ложь);
	Параметры.Вставить("ДатаНачала", 	Дата);
	Параметры.Вставить("ДатаОкончания",	Дата);
	Параметры.Вставить("ЗаказНаДоставку");
	Параметры.Вставить("Маркетплейс", 	"");
	Параметры.Вставить("ВозвратТовара", ВозвратТовара);
	Параметры.Вставить("Отгрузка", 		"");
	Параметры.Вставить("Штрихкод", 		"");
	Параметры.Вставить("Сообщение", 	"");
	Параметры.Вставить("Лог", 			"");
	Возврат Параметры;
	
КонецФункции

Процедура ЗакрытьПараметрыОтгрузки(Параметры, Сообщение)
	
	Параметры.Сообщение = Параметры.Сообщение + Сообщение;
	Параметры.Лог = Параметры.Лог + Сообщение + ?(ЗначениеЗаполнено(Сообщение), Символы.ПС, "") + 
		?(Параметры.Результат, "Успешное выполнение", "Неуспешное выполнение");
	Параметры.ДатаОкончания = ТекущаяДатаСеанса();

КонецПроцедуры

Функция НастройкиИнтеграции() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("ПапкаЛогов");
	Возврат Параметры;
	
КонецФункции

#КонецОбласти

#Область Логи

Процедура ЗаписатьЛоги(НастройкиИнтеграции, Маркетплейс, ВозвратТовара, ПараметрыВыполнения)
	
	Если ТипЗнч(НастройкиИнтеграции) = Тип("Структура") И Не ЗначениеЗаполнено(НастройкиИнтеграции.ПапкаЛогов) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКаталога = НастройкиИнтеграции.ПапкаЛогов + ?(Прав(НастройкиИнтеграции.ПапкаЛогов, 1) <> "\", "\", "") + Маркетплейс + "\" +
		Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=ггггММдд"); 
	
	Попытка 
		КаталогЛогов = Новый Файл(ИмяКаталога);
		Если Не КаталогЛогов.Существует() Тогда
			СоздатьКаталог(ИмяКаталога);
		КонецЕсли; 
		  
		Заголовок = ?(Не ВозвратТовара, "ship", "return"); 
		
		ИмяЛога = "log" + "_" + Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=ггггММдд") + "_" + Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=ЧЧммсс") + "_" + 
			СтрЗаменить(Заголовок, " ", "_") + ?(Не ПараметрыВыполнения.Результат, "_error", "") + ".txt";   
		
		ФайлЛогов = Новый ЗаписьТекста(ИмяКаталога + "\" + ИмяЛога, КодировкаТекста.UTF8, , Истина);
		ФайлЛогов.ЗаписатьСтроку(Формат(ПараметрыВыполнения.ДатаНачала, "ДФ=дд.ММ.гггг ЧЧ:мм:сс") + Символы.ПС +
			ПараметрыВыполнения.Лог + Символы.ПС +
			Формат(ПараметрыВыполнения.ДатаОкончания, "ДФ=дд.ММ.гггг ЧЧ:мм:сс"));
		ФайлЛогов.Закрыть();

	Исключение
		ФайлЛогов = Неопределено;
	КонецПопытки;    

КонецПроцедуры

Функция ПолучитьНастройкиИнтеграции()
	
	НастройкиИнтеграции = НастройкиИнтеграции();
	
	ДополнительнаяОбработка = ПолучитьОбработку();
	Если Не ДополнительнаяОбработка.Пустая() Тогда

		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда  
			Если НастройкиХранилища.Свойство("НастройкаПапкаЛогов") Тогда
				НастройкиИнтеграции.ПапкаЛогов = НастройкиХранилища.НастройкаПапкаЛогов;
			КонецЕсли;   
		Иначе
			// Сохраненные настройки отсутствуют
		КонецЕсли;    
	Иначе
		// Обработка для определения настроек не найдена
	КонецЕсли;

	Возврат НастройкиИнтеграции;
	
КонецФункции

Функция ПолучитьОбработку()
	
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", "ИнтеграцияМаркетплейсы.epf");			
	Возврат ДополнительнаяОбработка;
	
КонецФункции 	 


#КонецОбласти
