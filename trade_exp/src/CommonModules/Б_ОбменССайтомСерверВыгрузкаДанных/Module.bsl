		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Статуса заказа ИД"	, лСтатусЗаказа);
	КонецЕсли;

	лСлужбаДоставки = "";	

	лНастройкиСлужбДоставкиДокументов = ПланыОбмена.Б_ОбменССайтом.ПолучитьЗначениеКлючаСтруктурыНастроек(ПараметрыОбмена, "НастройкиСлужбДоставкиДокументов");

	Если лНастройкиСлужбДоставкиДокументов <> Неопределено тогда


		Если лНастройкиСлужбДоставкиДокументов.ИсточникСлужбДоставкиЗаказа = "СвойствоЗаказов" тогда

			НайденнаяСлужбаДоставкиЗаказа = ПараметрыОбмена.НастройкиСлужбДоставкиДокументов.СоответствияЗначенийСвойствЗаказа.Найти(Документ.СвойствоСлужбаДоставкиЗаказа);
			Если НайденнаяСлужбаДоставкиЗаказа <> Неопределено тогда
				лСлужбаДоставки = НайденнаяСлужбаДоставкиЗаказа.ИдСлужбы;
			КонецЕсли;

