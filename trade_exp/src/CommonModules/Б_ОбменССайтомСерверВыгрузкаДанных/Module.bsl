
&ИзменениеИКонтроль("СформироватьВременныеТаблицыПоСвойствамПакета")
Функция Док_СформироватьВременныеТаблицыПоСвойствамПакета(ПараметрыОбмена, СписокСвойств)

	Запрос = Новый Запрос;

	Запрос.УстановитьПараметр("Узел"	, ПараметрыОбмена.Ссылка);
	Запрос.УстановитьПараметр("ТекДата"	, ТекущаяДатаСеанса());

	Запрос.УстановитьПараметр("СписокСвойств"	, СписокСвойств);
	Запрос.УстановитьПараметр("НастройкиСвойств", ПараметрыОбмена.НастройкаСвойствТоваровИХарактеристик);

	Если ПараметрыОбмена.Свойство("БренВыгружен") Тогда
		Запрос.УстановитьПараметр("БренВыгружен", Истина);
	Иначе
		Запрос.УстановитьПараметр("БренВыгружен", Ложь);
		ПараметрыОбмена.Вставить("БренВыгружен", Истина);
	КонецЕсли;


	////////////////////////////////////////////////////////////////////////////////////////////////////////
	//	                                                                                                ///
	//             ПАКЕТ ЗАПРОСОВ ДЛЯ ПОЛУЧЕНИЯ НОМЕНКЛАТУРЫ С ХАРАКТЕРИСТИКОЙ                         ///
	//                                                                                                ///
	////////////////////////////////////////////////////////////////////////////////////////////////////


	ТекстЗапроса = "ВЫБРАТЬ
	|	НастройкиСвойств.Свойство КАК Свойство,
	|	НастройкиСвойств.НеВыгружатьВСвойстваПредложений КАК НеВыгружатьВСвойстваПредложений,
	|	НастройкиСвойств.НеВыгружатьВСвойстваТоваров КАК НеВыгружатьВСвойстваТоваров,
	|	НастройкиСвойств.ВлияетНаЦену КАК ВлияетНаЦену,
	|	НастройкиСвойств.ВыгружатьВХИ КАК ВыгружатьВХИ
	|ПОМЕСТИТЬ НастройкиСвойств
	|ИЗ
	|	&НастройкиСвойств КАК НастройкиСвойств
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДополнительныеРеквизитыИСведения.Ссылка КАК СвойствоНоменклатуры,
	|	ВЫБОР
	|		КОГДА ДополнительныеРеквизитыИСведения.Б_Идентификатор = """"
	|			ТОГДА ДополнительныеРеквизитыИСведения.Ссылка
	|		ИНАЧЕ ДополнительныеРеквизитыИСведения.Б_Идентификатор
	|	КОНЕЦ КАК Идентификатор,
	|	ДополнительныеРеквизитыИСведения.ВерсияДанных КАК ВерсияДанных,
	|	ДополнительныеРеквизитыИСведения.ПометкаУдаления КАК ПометкаУдаления,
	|	ВЫБОР
	|		КОГДА ДополнительныеРеквизитыИСведения.Заголовок = """"
	|			ТОГДА ДополнительныеРеквизитыИСведения.Наименование
	|		ИНАЧЕ ДополнительныеРеквизитыИСведения.Заголовок
	|	КОНЕЦ КАК Наименование,
	|	НастройкиСвойств.НеВыгружатьВСвойстваПредложений КАК НеВыгружатьВСвойстваПредложений,
	|	НастройкиСвойств.НеВыгружатьВСвойстваТоваров КАК НеВыгружатьВСвойстваТоваров,
	|	НастройкиСвойств.ВлияетНаЦену КАК ВлияетНаЦену,
	|	НастройкиСвойств.ВыгружатьВХИ КАК ВыгружатьВХИ,
	|	ДополнительныеРеквизитыИСведения.ВладелецДополнительныхЗначений КАК ВладелецДополнительныхЗначений
	#Вставка
	|,
	|Null
	#КонецВставки
	|ПОМЕСТИТЬ ВремСвойства
	|ИЗ
	|	ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	|		ЛЕВОЕ СОЕДИНЕНИЕ НастройкиСвойств КАК НастройкиСвойств
	|		ПО ДополнительныеРеквизитыИСведения.Ссылка = НастройкиСвойств.Свойство
	|ГДЕ
	|	ДополнительныеРеквизитыИСведения.Ссылка В(&СписокСвойств)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""Бренд"",
	|	""Бренд"",
	|	"""",
	|	ЛОЖЬ,
	|	""Бренд"",
	|	ИСТИНА,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	#Удаление
	|	NULL 
	#КонецУдаления
	#Вставка
	|	NULL,
	|	Null
	#КонецВставки
	|ГДЕ
	|	&БренВыгружен = ЛОЖЬ
    #Вставка
	|ОБЪЕДИНИТЬ ВСЕ
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ДополнительныеСведения_Альтерра.ПодразделениеСклад.ФорматПодразделения.Наименование ЕСТЬ NULL
	|			ТОГДА ВЫРАЗИТЬ(ДополнительныеСведения_Альтерра.ПодразделениеСклад.Наименование + ДополнительныеСведения_Альтерра.ПодразделениеСклад.Подразделение.ФорматПодразделения.Наименование + ДополнительныеСведения_Альтерра.ВидСведения.Наименование КАК СТРОКА(200))
	|		ИНАЧЕ ВЫРАЗИТЬ(ДополнительныеСведения_Альтерра.ПодразделениеСклад.Наименование + ДополнительныеСведения_Альтерра.ПодразделениеСклад.ФорматПодразделения.Наименование + ДополнительныеСведения_Альтерра.ВидСведения.Наименование КАК СТРОКА(200))
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ДополнительныеСведения_Альтерра.УникальныйИдентификатор = """"
	|			ТОГДА ВЫБОР
	|				КОГДА ДополнительныеСведения_Альтерра.ПодразделениеСклад.ФорматПодразделения.Наименование ЕСТЬ NULL
	|					ТОГДА ВЫРАЗИТЬ(ДополнительныеСведения_Альтерра.ПодразделениеСклад.Наименование + ДополнительныеСведения_Альтерра.ПодразделениеСклад.Подразделение.ФорматПодразделения.Наименование + ДополнительныеСведения_Альтерра.ВидСведения.Наименование КАК СТРОКА(200))
	|				ИНАЧЕ ВЫРАЗИТЬ(ДополнительныеСведения_Альтерра.ПодразделениеСклад.Наименование + ДополнительныеСведения_Альтерра.ПодразделениеСклад.ФорматПодразделения.Наименование + ДополнительныеСведения_Альтерра.ВидСведения.Наименование КАК СТРОКА(200))
	|			КОНЕЦ
	|		ИНАЧЕ ДополнительныеСведения_Альтерра.УникальныйИдентификатор
	|	КОНЕЦ,
	|	"""",
	|	ЛОЖЬ,
	|	ВЫБОР
	|		КОГДА ДополнительныеСведения_Альтерра.ПодразделениеСклад.ФорматПодразделения.Наименование ЕСТЬ NULL
	|			ТОГДА ВЫРАЗИТЬ(ДополнительныеСведения_Альтерра.ПодразделениеСклад.Наименование + ДополнительныеСведения_Альтерра.ПодразделениеСклад.Подразделение.ФорматПодразделения.Наименование + ДополнительныеСведения_Альтерра.ВидСведения.Наименование КАК СТРОКА(200))
	|		ИНАЧЕ ВЫРАЗИТЬ(ДополнительныеСведения_Альтерра.ПодразделениеСклад.Наименование + ДополнительныеСведения_Альтерра.ПодразделениеСклад.ФорматПодразделения.Наименование + ДополнительныеСведения_Альтерра.ВидСведения.Наименование КАК СТРОКА(200))
	|	КОНЕЦ,
	|	ИСТИНА,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	ЛОЖЬ,
	|	ДополнительныеСведения_Альтерра.ВидСведения,
	|	NULL
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения_Альтерра КАК ДополнительныеСведения_Альтерра
 #КонецВставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВремСвойства.СвойствоНоменклатуры КАК СвойствоНоменклатуры,
	|	ВремСвойства.Идентификатор КАК ИдентификаторСвойства,
	|	ВремСвойства.Наименование КАК НаименованиеСвойства,
	|	ЗначенияСвойствОбъектов.Ссылка КАК ЗначениеСвойства,
	|	ВЫБОР
	|		КОГДА ЗначенияСвойствОбъектов.Б_Идентификатор = """"
	|				ИЛИ ЗначенияСвойствОбъектов.Б_Идентификатор ЕСТЬ NULL
	|			ТОГДА ЗначенияСвойствОбъектов.Ссылка
	|		ИНАЧЕ ЗначенияСвойствОбъектов.Б_Идентификатор
	|	КОНЕЦ КАК ИдентификаторЗначенияСвойства,
	|	ЗначенияСвойствОбъектов.Наименование КАК НаименованиеЗначенияСвойства
	|ПОМЕСТИТЬ ВремЗначенияСвойств
	|ИЗ
	|	Справочник.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВремСвойства КАК ВремСвойства
	|		ПО (ВЫБОР
	|				КОГДА ВремСвойства.ВладелецДополнительныхЗначений = ЗНАЧЕНИЕ(ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения.ПустаяСсылка)
	|					ТОГДА ВремСвойства.СвойствоНоменклатуры = ЗначенияСвойствОбъектов.Владелец
	|				ИНАЧЕ ВремСвойства.ВладелецДополнительныхЗначений = ЗначенияСвойствОбъектов.Владелец
	|			КОНЕЦ)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	""Бренд"",
	|	""Бренд"",
	|	""Бренд"",
	|	Марки.Ссылка,
	|	Марки.Ссылка,
	|	Марки.Наименование
	|ИЗ
	|	Справочник.Марки КАК Марки
	|ГДЕ
	|	&БренВыгружен = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ НастройкиСвойств";

	лМенеджерВременныхТаблиц 		= Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц 	= лМенеджерВременныхТаблиц;
	Запрос.Текст = ТекстЗапроса;
	запрос.Выполнить();

	Возврат лМенеджерВременныхТаблиц;

КонецФункции
            
&ИзменениеИКонтроль("ВыгрузитьЗаказXDTO")
Функция Док_ВыгрузитьЗаказXDTO(ПараметрыОбмена, МенеджерВременныхТаблиц, Документ, КоличествоЗаказов)

	XDTOДокументТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Документ");
	XDTOНалогиТип 		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Налоги"		, Истина, XDTOДокументТип);	
	XDTOНалогТип   		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Налог"			, Истина, XDTOНалогиТип);

	XDTOКонтрагентыТип	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Контрагенты"	, Истина, XDTOДокументТип);  	
	XDTOКонтрагентТип	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Контрагент"	, Истина, XDTOКонтрагентыТип); 

	XDTOТоварыТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Товары", Истина, XDTOДокументТип);

	XDTOСкладыТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Склады"	, Истина, XDTOДокументТип);
	XDTOСкладТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Склад"		, Истина, XDTOСкладыТип);

	XDTOЗначенияРеквизитовТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначенияРеквизитов", Истина, XDTOДокументТип);
	XDTOЗначениеРеквизитаТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначениеРеквизита");

	XDTOДокумент		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOДокументТип);

	XDTOДокумент.Ид 			= XMLСтрока(Документ.ИдентификаторДокумента);
	XDTOДокумент.Номер1С 		= Документ.Номер;
	XDTOДокумент.Дата1С 		= XMLСтрока(Формат(Документ.Дата,"ДФ=yyyy-MM-dd"));

	//Если ЗначениеЗаполнено(Документ.НомерССайта) тогда
	XDTOДокумент.Номер 			= Документ.НомерССайта;
	//КонецЕсли;

	//Если ЗначениеЗаполнено(Документ.ДатаССайта) тогда
	лДатаВремяЭлДокумента  		= ?(ЗначениеЗаполнено(Документ.ДатаССайта), Документ.ДатаССайта, Дата(1,1,1,0,0,1));
	XDTOДокумент.Дата 			= XMLСтрока(Формат(лДатаВремяЭлДокумента,"ДФ=yyyy-MM-dd"));
	XDTOДокумент.Время			= XMLСтрока(Формат(лДатаВремяЭлДокумента,"ДФ=ЧЧ:мм:сс"));	
	//КонецЕсли;

	XDTOДокумент.ПометкаУдаления= XMLСтрока(Документ.ПометкаУдаления);

	XDTOДокумент.НомерВерсии 	= Б_ОбменССайтомСервер.ПолучитьВерсиюОбъекта(ПараметрыОбмена, Документ.ВерсияДанных, "Документов"); 
	XDTOДокумент.Комментарий 	= Документ.Комментарий;

	XDTOДокумент.ХозОперация= "Заказ товара";

	КоличествоЗаказов 		= КоличествоЗаказов + 1;

	XDTOДокумент.Роль 			= "Продавец";
	Если НЕ ЗначениеЗаполнено(Документ.ВалютаКод) тогда
		Б_ОбменССайтомСервер.СообщитьПодробно("У документа: " + Документ.Номер + " не заполнена валюта." , ПараметрыОбмена);
	Иначе	
		XDTOДокумент.Валюта			= Лев(Документ.ВалютаКод, 3);
	КонецЕсли;

	XDTOДокумент.Курс			= Формат(Документ.Курс, "ЧЦ=10; ЧДЦ=4; ЧРД=.");
	XDTOДокумент.Сумма			= Формат(Документ.СуммаДокумента , ПараметрыОбмена.ФорматСуммы); 

	ЗапросПоТоварам = Новый Запрос();
	ЗапросПоТоварам.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

#Удаление
	ЗапросПоТоварам.Текст = "ВЫБРАТЬ *
	|ИЗ
	|	ВремТабТоваров КАК ВремТабТоваров
	|ГДЕ
	|	ВремТабТоваров.Документ =&Документ";
#КонецУдаления
#Вставка
	ЗапросПоТоварам.Текст = "
	|ВЫБРАТЬ
	|	ВремТабТоваровГруппировка.Документ КАК Документ,
	|	ВремТабТоваровГруппировка.Заказ КАК Заказ,
	|	ВремТабТоваровГруппировка.Номенклатура КАК Номенклатура,
	|	ВремТабТоваровГруппировка.ИдентификаторНоменклатуры КАК ИдентификаторНоменклатуры,
	|	ВремТабТоваровГруппировка.Характеристика КАК Характеристика,
	|	ВремТабТоваровГруппировка.ИдентификаторХарактеристики КАК ИдентификаторХарактеристики,
	|	ВремТабТоваровГруппировка.Упаковка КАК Упаковка,
	|	ВремТабТоваровГруппировка.ИдентификаторУпаковки КАК ИдентификаторУпаковки,
	|	СУММА(ВремТабТоваровГруппировка.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ВремТабТоваровГруппировка.Количество) КАК Количество,
	|	СРЕДНЕЕ(ВремТабТоваровГруппировка.Цена) КАК Цена,
	|	СУММА(ВремТабТоваровГруппировка.Сумма) КАК Сумма,
	|	ВремТабТоваровГруппировка.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВремТабТоваровГруппировка.СуммаНДС) КАК СуммаНДС,
	|	СУММА(ВремТабТоваровГруппировка.СуммаСНДС) КАК СуммаСНДС,
	|	СРЕДНЕЕ(ВремТабТоваровГруппировка.ПроцентРучнойСкидки) КАК ПроцентРучнойСкидки,
	|	СУММА(ВремТабТоваровГруппировка.СуммаРучнойСкидки) КАК СуммаРучнойСкидки,
	|	СРЕДНЕЕ(ВремТабТоваровГруппировка.ПроцентАвтоматическойСкидки) КАК ПроцентАвтоматическойСкидки,
	|	СУММА(ВремТабТоваровГруппировка.СуммаАвтоматическойСкидки) КАК СуммаАвтоматическойСкидки,
	|	ВремТабТоваровГруппировка.Склад КАК Склад,
	|	ВремТабТоваровГруппировка.ИдентификаторСклада КАК ИдентификаторСклада,
	|	ВремТабТоваровГруппировка.Содержание КАК Содержание,
	|	ВремТабТоваровГруппировка.УпаковкаЧислитель КАК УпаковкаЧислитель,
	|	ВремТабТоваровГруппировка.НоменклатураЕдиницаИзмерения КАК НоменклатураЕдиницаИзмерения,
	|	ВремТабТоваровГруппировка.Отменено КАК Отменено,
	|	ВремТабТоваровГруппировка.НоменклатураНаименование КАК НоменклатураНаименование,
	|	ВремТабТоваровГруппировка.ХарактеристикаНаименование КАК ХарактеристикаНаименование,
	|	ВремТабТоваровГруппировка.ВидНоменклатуры КАК ВидНоменклатуры,
	|	ВремТабТоваровГруппировка.ТипТовара КАК ТипТовара,
	|	ВремТабТоваровГруппировка.НоменклатураСтавкаНДС КАК НоменклатураСтавкаНДС,
