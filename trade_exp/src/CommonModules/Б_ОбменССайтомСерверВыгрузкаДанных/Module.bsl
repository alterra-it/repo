					лСлужбаДоставки = НайденнаяСлужбаДоставкиЗаказа.ИдСлужбы;
				КонецЕсли;
			Иначе

				НайденныеСтроки = ПараметрыОбмена.НастройкиСлужбДоставкиДокументов.СоответствияСпособовДоставкиЗаказа.НайтиСтроки(Новый Структура("Служба, Перевозчик", Документ.СпособДоставки, Документ.Перевозчик));
				Если НайденныеСтроки.Количество() > 0 тогда
					лСлужбаДоставки = НайденныеСтроки[0].ИдСлужбы;
				КонецЕсли;

			КонецЕсли;
		КонецЕсли;

	КонецЕсли;

	Если ЗначениеЗаполнено(лСлужбаДоставки) тогда
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Метод доставки ИД"	, лСлужбаДоставки);
	КонецЕсли;

	XDTOДокумент.ЗначенияРеквизитов = XDTOЗначенияРеквизитов;

	ЕстьТовары 	= МассивТоваров.Количество() 	> 0;

	Если ЕстьТовары тогда

		XDTOТовары		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOТоварыТип);

		Если ЕстьТовары тогда
			ЗаполнениеТабличнойЧастиДокумента(ПараметрыОбмена, МенеджерВременныхТаблиц, XDTOТовары, XDTOТоварыТип, Документ, МассивТоваров);     			
		КонецЕсли;

		XDTOДокумент.Товары = XDTOТовары;
	КонецЕсли;

	Возврат XDTOДокумент;

КонецФункции

&ИзменениеИКонтроль("ВыгрузитьОплатуXDTO")
Функция Док_ВыгрузитьОплатуXDTO(ПараметрыОбмена, МенеджерВременныхТаблиц, Документ, КоличествоОплат)

	XDTOДокументТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Документ");
	XDTOДокумент		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOДокументТип);

	XDTOНалогиТип 		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Налоги"		, Истина, XDTOДокументТип);	
	XDTOНалогТип   		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Налог"		, Истина, XDTOНалогиТип);

	XDTOКонтрагентыТип	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Контрагенты"	, Истина, XDTOДокументТип);  	
	XDTOКонтрагентТип	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Контрагент"	, Истина, XDTOКонтрагентыТип); 


	XDTOЗначенияРеквизитовТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначенияРеквизитов", Истина, XDTOДокументТип);
	XDTOЗначениеРеквизитаТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначениеРеквизита");


	XDTOДокумент.Ид 			= XMLСтрока(Документ.ИдентификаторДокумента);
	XDTOДокумент.Номер1С 		= Документ.Номер;
	XDTOДокумент.Дата1С 		= XMLСтрока(Формат(Документ.Дата,"ДФ=yyyy-MM-dd"));

	XDTOДокумент.Номер 			= Документ.НомерССайта;

	лДатаВремяЭлДокумента  		= ?(ЗначениеЗаполнено(Документ.ДатаССайта), Документ.ДатаССайта, Дата(1, 1,1, 0,0,1));
	XDTOДокумент.Дата 			= XMLСтрока(Формат(лДатаВремяЭлДокумента,"ДФ=yyyy-MM-dd"));
	XDTOДокумент.Время			= XMLСтрока(Формат(лДатаВремяЭлДокумента,"ДФ=ЧЧ:мм:сс"));	

	XDTOДокумент.ПометкаУдаления= XMLСтрока(Документ.ПометкаУдаления);
	XDTOДокумент.НомерВерсии 	= Б_ОбменССайтомСервер.ПолучитьВерсиюОбъекта(ПараметрыОбмена, Документ.ВерсияДанных, "Документов"); 
	XDTOДокумент.Комментарий 	= Документ.Комментарий;

	КоличествоОплат 			= КоличествоОплат + 1;

	Если Документ.ТипДокумента  = "Оплата безналичными" тогда
		XDTOДокумент.ХозОперация= "Выплата безналичных денег";
	ИначеЕсли Документ.ТипДокумента  = "Оплата наличными" тогда
		XDTOДокумент.ХозОперация= "Выплата наличных денег";	
	ИначеЕсли Документ.ТипДокумента  = "Эквайринг" тогда
		XDTOДокумент.ХозОперация= "Эквайринговая операция";	
	КонецЕсли;

	XDTOДокумент.Основание	= XMLСтрока(Документ.ИдентификаторОснования);

	XDTOДокумент.Роль 			= "Продавец";
	Если НЕ ЗначениеЗаполнено(Документ.ВалютаКод) тогда
		Б_ОбменССайтомСервер.СообщитьПодробно("У документа: " + Документ.Номер + " не заполнена валюта." , ПараметрыОбмена);
	Иначе	
		XDTOДокумент.Валюта			= Лев(Документ.ВалютаКод, 3);
	КонецЕсли;

	XDTOДокумент.Курс			= Формат(Документ.Курс, "ЧЦ=10; ЧДЦ=4; ЧРД=.");
	XDTOДокумент.Сумма			= Формат(Документ.СуммаВзаиморасчетов , ПараметрыОбмена.ФорматСуммы); 


	Если ПараметрыОбмена.ИспользоватьПартнеровИКонтрагентов тогда

		Если Документ.Контрагент <> Null тогда

			XDTOКонтрагенты	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтрагентыТип);
#Удаление
			XDTOКонтрагенты.Контрагент.Добавить(ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Контрагент));
#КонецУдаления
#Вставка
            XDTOКонтрагенты.Контрагент.Добавить(_ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Контрагент, Документ.Партнер));
#КонецВставки
			XDTOДокумент.Контрагенты 	= XDTOКонтрагенты;
		Иначе
			Б_ОбменССайтомСервер.СообщитьПодробно("Не найден контрагент в документе: " + Строка(Документ.Объект), ПараметрыОбмена);
		КонецЕсли;

	Иначе

		Если Документ.Партнер <> Null тогда

			XDTOКонтрагенты	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтрагентыТип);
#Удаление
			XDTOКонтрагенты.Контрагент.Добавить(ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Партнер));
#КонецУдаления
#Вставка
            XDTOКонтрагенты.Контрагент.Добавить(_ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Партнер));
#КонецВставки
			XDTOДокумент.Контрагенты 	= XDTOКонтрагенты;
		Иначе
			Б_ОбменССайтомСервер.СообщитьПодробно("Не найден контрагент в документе: " + Строка(Документ.Объект), ПараметрыОбмена);
		КонецЕсли;

	КонецЕсли;	

	XDTOЗначенияРеквизитов 		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOЗначенияРеквизитовТип); 

	Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Проведен", XMLСтрока(Документ.Проведен));
	Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Отменен"	, Документ.Отменен);
	Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Оплачен"	, Документ.Оплачен);

	Если Документ.Оплачен Тогда   			
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Номер оплаты по 1С", Документ.Номер);
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Дата оплаты по 1С"	, XMLСтрока(Формат(Документ.Дата,"ДФ=yyyy-MM-dd")));
	КонецЕсли;

	лИдПлатежнойСистемы = "";

	Если ПараметрыОбмена.СоответствиеПлатежныхСистемИКасс <> Неопределено И ЗначениеЗаполнено(Документ.КассаТерминал) тогда 

		Если Документ.ТипДокумента  = "Оплата наличными" ИЛИ Документ.ТипДокумента  = "Эквайринг" тогда

			НайденныйСтатус = ПараметрыОбмена.СоответствиеПлатежныхСистемИКасс.Найти(Документ.КассаТерминал);

			Если НайденныйСтатус <> Неопределено тогда
				лИдПлатежнойСистемы =  НайденныйСтатус.ИдПлатежнойСистемы;       
			КонецЕсли;

		КонецЕсли;

	КонецЕсли;

	Если лИдПлатежнойСистемы = "" И ЗначениеЗаполнено(Документ.ИдМетодаОплатыССайта) тогда
		лИдПлатежнойСистемы = Документ.ИдМетодаОплатыССайта;
	КонецЕсли;

	Если ЗначениеЗаполнено(лИдПлатежнойСистемы) тогда
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Метод оплаты ИД"	, лИдПлатежнойСистемы);
	КонецЕсли;

	XDTOДокумент.ЗначенияРеквизитов = XDTOЗначенияРеквизитов;

	Если Документ.ТипДокумента  = "Оплата наличными" ИЛИ Документ.ТипДокумента  = "Эквайринг" 
		И Константы.Б_ИспользоватьМеханизмПечатиЧеков.Получить() И ЗначениеЗаполнено(Документ.НомерССайта) тогда
		ЗаполнитьИнформациюОЧеке(ПараметрыОбмена, МенеджерВременныхТаблиц, XDTOДокумент, Документ, XDTOДокументТип);		
	КонецЕсли;

	Возврат XDTOДокумент;

КонецФункции

&ИзменениеИКонтроль("ВыгрузитьОтгрузкуXDTO")
Функция Док_ВыгрузитьОтгрузкуXDTO(ПараметрыОбмена, МенеджерВременныхТаблиц, Документ, КоличествоОтгрузок)

	XDTOДокументТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Документ");
	XDTOНалогиТип 		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Налоги"		, Истина, XDTOДокументТип);	
	XDTOНалогТип   		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Налог"		, Истина, XDTOНалогиТип);

	XDTOКонтрагентыТип	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Контрагенты"	, Истина, XDTOДокументТип);  	
	XDTOКонтрагентТип	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Контрагент"	, Истина, XDTOКонтрагентыТип); 

	XDTOТоварыТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Товары"		, Истина, XDTOДокументТип);

	XDTOСкладыТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Склады"		, Истина, XDTOДокументТип);
	XDTOСкладТип		= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "Склад"		, Истина, XDTOСкладыТип);

	XDTOЗначенияРеквизитовТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначенияРеквизитов", Истина, XDTOДокументТип);
	XDTOЗначениеРеквизитаТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначениеРеквизита");

	XDTOДокумент		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOДокументТип);

	XDTOДокумент.Ид 			= XMLСтрока(Документ.ИдентификаторДокумента);
	XDTOДокумент.Номер1С 		= Документ.Номер;
	XDTOДокумент.Дата1С 		= XMLСтрока(Формат(Документ.Дата,"ДФ=yyyy-MM-dd"));

	XDTOДокумент.Номер 			= Документ.НомерССайта;

	лДатаВремяЭлДокумента  		= ?(ЗначениеЗаполнено(Документ.ДатаССайта), Документ.ДатаССайта, Дата(1, 1,1, 0,0,1));
	XDTOДокумент.Дата 			= XMLСтрока(Формат(лДатаВремяЭлДокумента,"ДФ=yyyy-MM-dd"));
	XDTOДокумент.Время			= XMLСтрока(Формат(лДатаВремяЭлДокумента,"ДФ=ЧЧ:мм:сс"));	

	XDTOДокумент.ПометкаУдаления= XMLСтрока(Документ.ПометкаУдаления);
	XDTOДокумент.НомерВерсии 	= Б_ОбменССайтомСервер.ПолучитьВерсиюОбъекта(ПараметрыОбмена, Документ.ВерсияДанных, "Документов"); 
	XDTOДокумент.Комментарий 	= Документ.Комментарий;


	XDTOДокумент.ХозОперация= "Отпуск товара";	

	КоличествоОтгрузок 		= КоличествоОтгрузок + 1;

	XDTOДокумент.Основание	= XMLСтрока(Документ.ИдентификаторОснования);

	XDTOДокумент.Роль 			= "Продавец";

	Если НЕ ЗначениеЗаполнено(Документ.ВалютаКод) тогда
		Б_ОбменССайтомСервер.СообщитьПодробно("У документа: " + Документ.Номер + " не заполнена валюта." , ПараметрыОбмена);
	Иначе	
		XDTOДокумент.Валюта		= Лев(Документ.ВалютаКод, 3);
	КонецЕсли;

	XDTOДокумент.Курс			= Формат(Документ.Курс, "ЧЦ=10; ЧДЦ=4; ЧРД=.");
	XDTOДокумент.Сумма			= Формат(Документ.СуммаДокумента , ПараметрыОбмена.ФорматСуммы); 

	ЗапросПоТоварам = Новый Запрос();
	ЗапросПоТоварам.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
#Удаление	
	ЗапросПоТоварам.Текст = "ВЫБРАТЬ *
	|ИЗ
	|	ВремТабТоваров КАК ВремТабТоваров
	|ГДЕ
	|	ВремТабТоваров.Документ =&Документ";
#КонецУдаления
#Вставка
	//Нужно сделать свертку таблицы чтобы не передавались дубли строк
	ЗапросПоТоварам.Текст = "
	|ВЫБРАТЬ
	|	ВремТабТоваровГруппировка.Документ КАК Документ,
	|	ВремТабТоваровГруппировка.Заказ КАК Заказ,
	|	ВремТабТоваровГруппировка.Номенклатура КАК Номенклатура,
	|	ВремТабТоваровГруппировка.ИдентификаторНоменклатуры КАК ИдентификаторНоменклатуры,
	|	ВремТабТоваровГруппировка.Характеристика КАК Характеристика,
	|	ВремТабТоваровГруппировка.ИдентификаторХарактеристики КАК ИдентификаторХарактеристики,
	|	ВремТабТоваровГруппировка.Упаковка КАК Упаковка,
	|	ВремТабТоваровГруппировка.ИдентификаторУпаковки КАК ИдентификаторУпаковки,
	|	СУММА(ВремТабТоваровГруппировка.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	СУММА(ВремТабТоваровГруппировка.Количество) КАК Количество,
	|	СРЕДНЕЕ(ВремТабТоваровГруппировка.Цена) КАК Цена,
	|	СУММА(ВремТабТоваровГруппировка.Сумма) КАК Сумма,
	|	ВремТабТоваровГруппировка.СтавкаНДС КАК СтавкаНДС,
	|	СУММА(ВремТабТоваровГруппировка.СуммаНДС) КАК СуммаНДС,
	|	СУММА(ВремТабТоваровГруппировка.СуммаСНДС) КАК СуммаСНДС,
	|	СРЕДНЕЕ(ВремТабТоваровГруппировка.ПроцентРучнойСкидки) КАК ПроцентРучнойСкидки,
	|	СУММА(ВремТабТоваровГруппировка.СуммаРучнойСкидки) КАК СуммаРучнойСкидки,
	|	СРЕДНЕЕ(ВремТабТоваровГруппировка.ПроцентАвтоматическойСкидки) КАК ПроцентАвтоматическойСкидки,
	|	СУММА(ВремТабТоваровГруппировка.СуммаАвтоматическойСкидки) КАК СуммаАвтоматическойСкидки,
	|	ВремТабТоваровГруппировка.Склад КАК Склад,
	|	ВремТабТоваровГруппировка.ИдентификаторСклада КАК ИдентификаторСклада,
	|	ВремТабТоваровГруппировка.Содержание КАК Содержание,
	|	ВремТабТоваровГруппировка.УпаковкаЧислитель КАК УпаковкаЧислитель,
	|	ВремТабТоваровГруппировка.НоменклатураЕдиницаИзмерения КАК НоменклатураЕдиницаИзмерения,
	|	ВремТабТоваровГруппировка.Отменено КАК Отменено,
	|	ВремТабТоваровГруппировка.НоменклатураНаименование КАК НоменклатураНаименование,
	|	ВремТабТоваровГруппировка.ХарактеристикаНаименование КАК ХарактеристикаНаименование,
	|	ВремТабТоваровГруппировка.ВидНоменклатуры КАК ВидНоменклатуры,
	|	ВремТабТоваровГруппировка.ТипТовара КАК ТипТовара,
	|	ВремТабТоваровГруппировка.НоменклатураСтавкаНДС КАК НоменклатураСтавкаНДС,
	|	ВремТабТоваровГруппировка.ИдентификаторБазовойЕдиницыИзмерения КАК ИдентификаторБазовойЕдиницыИзмерения,
	|	ВремТабТоваровГруппировка.НаименованиеБазовойЕдиницыИзмерения КАК НаименованиеБазовойЕдиницыИзмерения,
	|	ВремТабТоваровГруппировка.НаименованиеПолноеБазовойЕдиницыИзмерения КАК НаименованиеПолноеБазовойЕдиницыИзмерения,
	|	ВремТабТоваровГруппировка.КодБазовойЕдиницыИзмерения КАК КодБазовойЕдиницыИзмерения
	|ИЗ
	|
	|(ВЫБРАТЬ *
	|ИЗ
	|	ВремТабТоваров КАК ВремТабТоваров
	|ГДЕ
	|	ВремТабТоваров.Документ =&Документ
	|) КАК ВремТабТоваровГруппировка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВремТабТоваровГруппировка.Документ,
	|	ВремТабТоваровГруппировка.Заказ,
	|	ВремТабТоваровГруппировка.Номенклатура,
	|	ВремТабТоваровГруппировка.ИдентификаторНоменклатуры,
	|	ВремТабТоваровГруппировка.Характеристика,
	|	ВремТабТоваровГруппировка.ИдентификаторХарактеристики,
	|	ВремТабТоваровГруппировка.Упаковка,
	|	ВремТабТоваровГруппировка.ИдентификаторУпаковки,
	|	ВремТабТоваровГруппировка.СтавкаНДС,
	|	ВремТабТоваровГруппировка.Склад,
	|	ВремТабТоваровГруппировка.ИдентификаторСклада,
	|	ВремТабТоваровГруппировка.Содержание,
	|	ВремТабТоваровГруппировка.УпаковкаЧислитель,
	|	ВремТабТоваровГруппировка.НоменклатураЕдиницаИзмерения,
	|	ВремТабТоваровГруппировка.Отменено,
	|	ВремТабТоваровГруппировка.НоменклатураНаименование,
	|	ВремТабТоваровГруппировка.ХарактеристикаНаименование,
	|	ВремТабТоваровГруппировка.ВидНоменклатуры,
	|	ВремТабТоваровГруппировка.ТипТовара,
	|	ВремТабТоваровГруппировка.НоменклатураСтавкаНДС,
	|	ВремТабТоваровГруппировка.ИдентификаторБазовойЕдиницыИзмерения,
	|	ВремТабТоваровГруппировка.НаименованиеБазовойЕдиницыИзмерения,
	|	ВремТабТоваровГруппировка.НаименованиеПолноеБазовойЕдиницыИзмерения,
	|	ВремТабТоваровГруппировка.КодБазовойЕдиницыИзмерения
	|";
#КонецВставки

	ЗапросПоТоварам.УстановитьПараметр("Документ", Документ.Объект);
	МассивТоваров = ЗапросПоТоварам.Выполнить().Выгрузить();

	Если Документ.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС Тогда

		СуммаНДС = МассивТоваров.Итог("СуммаНДС");

		Если СуммаНДС > 0 Тогда

			XDTOНалоги	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOНалогиТип);
			XDTOНалог	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOНалогТип);
			XDTOНалог.Наименование 	= ПараметрыОбмена.НаименованиеНалога;
			XDTOНалог.УчтеноВСумме 	= XMLСтрока(Документ.ЦенаВключаетНДС);
			XDTOНалог.Сумма        	= Формат(СуммаНДС , ПараметрыОбмена.ФорматСуммы); 		
			XDTOНалоги.Налог.Добавить(XDTOНалог);
			XDTOДокумент.Налоги 	= XDTOНалоги; 

		КонецЕсли;

	КонецЕсли;

	Если ПараметрыОбмена.ИспользоватьПартнеровИКонтрагентов тогда

		Если Документ.Контрагент <> Null тогда

			XDTOКонтрагенты	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтрагентыТип);
#Удаление
			XDTOКонтрагенты.Контрагент.Добавить(ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Контрагент));
#КонецУдаления
#Вставка
            XDTOКонтрагенты.Контрагент.Добавить(_ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Контрагент, Документ.Партнер));
#КонецВставки
			XDTOДокумент.Контрагенты 	= XDTOКонтрагенты;
		Иначе
			Б_ОбменССайтомСервер.СообщитьПодробно("Не найден контрагент в документе: " + Строка(Документ.Объект), ПараметрыОбмена);
		КонецЕсли;

	Иначе

		Если Документ.Партнер <> Null тогда

			XDTOКонтрагенты	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтрагентыТип);
#Удаление
			XDTOКонтрагенты.Контрагент.Добавить(ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Партнер));
#КонецУдаления
#Вставка
            XDTOКонтрагенты.Контрагент.Добавить(_ВыгрузитьКонтрагентаВДокументXDTO(ПараметрыОбмена, XDTOКонтрагентыТип, Документ.Партнер));
#КонецВставки
			XDTOДокумент.Контрагенты 	= XDTOКонтрагенты;
		Иначе
			Б_ОбменССайтомСервер.СообщитьПодробно("Не найден контрагент в документе: " + Строка(Документ.Объект), ПараметрыОбмена);
		КонецЕсли;

	КонецЕсли;	

	Если Документ.ИдентификаторСклада <> Null тогда
		XDTOСклады	= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOСкладыТип);

		XDTOСклад				= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOСкладТип);
		XDTOСклад.Ид 			= XMLСтрока(Документ.ИдентификаторСклада); 
		XDTOСклад.Наименование 	= Документ.НаименованиеСклада; 

		XDTOСклады.Склад.Добавить(XDTOСклад);
		XDTOДокумент.Склады 		= XDTOСклады;	
	КонецЕсли;

	XDTOЗначенияРеквизитов 		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOЗначенияРеквизитовТип); 

	Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Проведен", XMLСтрока(Документ.Проведен));

	Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Отменен"	, Документ.Отменен);
	Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Отгружен", Документ.Отгружен);

	Если ЗначениеЗаполнено(Документ.АдресДоставки) тогда
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Адрес доставки"	, Документ.АдресДоставки);
	КонецЕсли;

	лСлужбаДоставки = "";	

	лНастройкиСлужбДоставкиДокументов = ПланыОбмена.Б_ОбменССайтом.ПолучитьЗначениеКлючаСтруктурыНастроек(ПараметрыОбмена, "НастройкиСлужбДоставкиДокументов");

	Если лНастройкиСлужбДоставкиДокументов <> Неопределено тогда

		НайденнаяСлужбаДоставкиЗаказа = ПараметрыОбмена.НастройкиСлужбДоставкиДокументов.СоответствияЗначенийСвойствОтгрузки.Найти(Документ.СвойствоСлужбаДоставкиОтгрузки);
		Если НайденнаяСлужбаДоставкиЗаказа <> Неопределено тогда
			лСлужбаДоставки = НайденнаяСлужбаДоставкиЗаказа.ИдСлужбы;
		КонецЕсли;

	КонецЕсли;

	Если ЗначениеЗаполнено(лСлужбаДоставки) тогда
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Метод доставки ИД"	, лСлужбаДоставки);
	КонецЕсли;

	Если ЗначениеЗаполнено(Документ.ИдентификаторОтправления) Тогда
		Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Идентификатор отправления"	, XMLСтрока(Документ.ИдентификаторОтправления));
	КонецЕсли;

	XDTOДокумент.ЗначенияРеквизитов = XDTOЗначенияРеквизитов;

	ЕстьТовары 	= МассивТоваров.Количество() 	> 0;

	Если ЕстьТовары И НЕ Документ.Отменен тогда

		XDTOТовары		= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOТоварыТип);

		Если ЕстьТовары тогда

			СоздаватьДоставкуАвтоматически = Истина;

			ЗаполнениеТабличнойЧастиДокумента(ПараметрыОбмена, МенеджерВременныхТаблиц, XDTOТовары, XDTOТоварыТип, Документ, МассивТоваров, СоздаватьДоставкуАвтоматически);

			Если Число(Документ.СуммаДоставки) > 0 И СоздаватьДоставкуАвтоматически тогда
				ДобавитьВТабличнуюЧастьДокументаДоставкуТовара(ПараметрыОбмена, XDTOТовары, XDTOТоварыТип, Документ);
			КонецЕсли;			

		КонецЕсли;

		XDTOДокумент.Товары = XDTOТовары;
	КонецЕсли;

	Возврат XDTOДокумент;

КонецФункции

&ИзменениеИКонтроль("ЗаписьИОтправкаXMLДанныхНаСайт")
Функция Док_ЗаписьИОтправкаXMLДанныхНаСайт(ПараметрыОбмена, XDTOКоммерческаяИнформация, ИмяКаталога, ИмяФайла, ПараметрHTTP, Пакет)

	ИмяКаталога = Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ПараметрыОбмена.ПлатформаWindows, ИмяКаталога); 	
	Успешно = Ложь;

	Если НЕ Б_ОбщиеПроцедурыИФункцииСервер.СуществуетФайл(ИмяКаталога) тогда
		СоздатьКаталог(ИмяКаталога);	
	КонецЕсли;

	ПолноеИмяФайла = Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ПараметрыОбмена.ПлатформаWindows,ИмяКаталога +  "\" + ИмяФайла + "___" + Строка(Новый УникальныйИдентификатор) +  ".xml"); 

	МойXML = Новый ЗаписьXML;
	МойXML.ОткрытьФайл(ПолноеИмяФайла, "UTF-8");
	МойXML.ЗаписатьОбъявлениеXML();


	//XDTOКоммерческаяИнформация.Проверить();

	ПараметрыОбмена.МояФабрикаXDTO.ЗаписатьXML(МойXML, XDTOКоммерческаяИнформация, "КоммерческаяИнформация"); 
	МойXML.Закрыть();

	Если ПараметрыОбмена.ХранитьФайлыОбменаНаСайте И ПараметрыОбмена.ВыгружатьНаСайт И ПараметрыОбмена.ВыгружатьЛогНаСайт Тогда

#Удаление
		КаталогХранения 		= Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ПараметрыОбмена.ПлатформаWindows, ПараметрыОбмена.КаталогЛога + "\reports\" + СокрЛП(ПараметрыОбмена.Ссылка.Код) + "\" + ?(Пакет = 0, "", Строка(Пакет)));
#КонецУдаления
#Вставка
		Если ПараметрыОбмена.Свойство("ВыгрузкаОтдельныхДокументов") Тогда
			КаталогХранения 	= Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ПараметрыОбмена.ПлатформаWindows, ПараметрыОбмена.КаталогЛога + "\reports\" + СокрЛП(ПараметрыОбмена.Ссылка.Код) + " выгрузка отдельных документов" + "\" + ?(Пакет = 0, "", Строка(Пакет)));
		Иначе 
			КаталогХранения 	= Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ПараметрыОбмена.ПлатформаWindows, ПараметрыОбмена.КаталогЛога + "\reports\" + СокрЛП(ПараметрыОбмена.Ссылка.Код) + "\" + ?(Пакет = 0, "", Строка(Пакет)));
		КонецЕсли;
#КонецВставки
		ПолноеИмяФайлаХранения 	= Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ПараметрыОбмена.ПлатформаWindows, КаталогХранения +  "\" + ИмяФайла +  ".xml"); 

		Если НЕ Б_ОбщиеПроцедурыИФункцииСервер.СуществуетФайл(КаталогХранения) тогда
			СоздатьКаталог(КаталогХранения);	
		КонецЕсли;

		КопироватьФайл(ПолноеИмяФайла, ПолноеИмяФайлаХранения);

	КонецЕсли;	

	лПродолжатьПопытки 	= Истина;
	лЧислоПопыток		= 0;

	МассивПодкаталогов = Новый Массив;

	лВыгружатьКартинкиИФайлы = ?(ИмяФайла = "offers" , ПараметрыОбмена.ВыгружатьКартинкиИФайлыПредложений, ПараметрыОбмена.ВыгружатьКартинкиИФайлы);

	Если лВыгружатьКартинкиИФайлы Тогда

		МассивПодкаталогов.Добавить(ПараметрыОбмена.ПодкаталогФайлов);

	КонецЕсли;

	Если ПараметрыОбмена.ВыгружатьНаСайт тогда

		//Отправляем на сервер	

		Если ПараметрHTTP = "catalog" тогда

			МассивПодкаталогов = Новый Массив;

			Если ПараметрыОбмена.ВыгружатьКартинкиИФайлы Тогда

				МассивПодкаталогов.Добавить(ПараметрыОбмена.ПодкаталогФайлов);

			КонецЕсли;
		КонецЕсли;

		Пока лПродолжатьПопытки цикл

			Если лЧислоПопыток > 0 И ПараметрыОбмена.ТаймаутМеждуПовторамиНеудачноОтправленныхПакетах тогда
				Б_ОбменССайтомСервер.Таймаут(ПараметрыОбмена.ТаймаутМеждуПовторамиНеудачноОтправленныхПакетах);
			КонецЕсли;

			Успешно = Б_ОбменССайтомСервер.ВыгрузитьДанныеНаСайт(ПараметрыОбмена, ИмяКаталога, ПолноеИмяФайла, МассивПодкаталогов, Истина, ПараметрHTTP);

			Если Успешно ИЛИ лЧислоПопыток = ПараметрыОбмена.ЧислоПовторовПриНеудачноОтправленныхПакетах тогда
				лПродолжатьПопытки = Ложь;
			КонецЕсли;

			лЧислоПопыток = лЧислоПопыток + 1;

		КонецЦикла;

		Б_ОбщиеПроцедурыИФункцииСервер.КаталогОчищен(ИмяКаталога, ПараметрыОбмена);	

	КонецЕсли;	

	Возврат Успешно;

КонецФункции

&ИзменениеИКонтроль("ПолучениеСоглашенияПоВидуЦены")
Функция Док_ПолучениеСоглашенияПоВидуЦены(ПараметрыОбмена, МенеджерВременныхТаблиц, ВидЦены)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
#Удаление
	Запрос.Текст = "ВЫБРАТЬ *
	|ИЗ
	|	ВремСоглашения КАК ВремСоглашения
	| ГДЕ
	|ВремСоглашения.ВидЦены = &ВидЦены";
#КонецУдаления
#Вставка
	Если НовоеЦенообразование() Тогда
		Запрос.Текст = "ВЫБРАТЬ *
		|ИЗ
		|	ВремСоглашения КАК ВремСоглашения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|		ПО ВремСоглашения.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
		|ГДЕ
		|	ВидыЦен.Ссылка = &ВидЦены";
	Иначе
	Запрос.Текст = "ВЫБРАТЬ *
	|ИЗ
	|	ВремСоглашения КАК ВремСоглашения
	| ГДЕ
	|ВремСоглашения.ВидЦены = &ВидЦены";
	КонецЕсли;
#КонецВставки
	Запрос.УстановитьПараметр("ВидЦены",ВидЦены);
	ВыборкаСоглашений = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаСоглашений.Следующий() Цикл
		Возврат ВыборкаСоглашений.Идентификатор;
	КонецЦикла;
	
	Возврат Справочники.ВидыЦен.ПустаяСсылка();
	
КонецФункции

&ИзменениеИКонтроль("СформироватьВременныеТаблицыПоДокументам")
Функция Док_СформироватьВременныеТаблицыПоДокументам(ПараметрыОбмена, МассивДанных)
	
	ОбщийЗапрос = Новый Запрос;
	
	ОбщийЗапрос.УстановитьПараметр("МассивДанных"			, МассивДанных);
	ОбщийЗапрос.УстановитьПараметр("СвойствоИдМетодаОплаты"	, ПараметрыОбмена.СвойствоИдМетодаОплаты);
	ОбщийЗапрос.УстановитьПараметр("СвойствоИдентификаторОтправления", ПараметрыОбмена.СвойствоИдентификаторОтправления);
	
	лИспользуетсяСтатусЗаказаСостояние 	= Ложь;
	лИспользуетсяСтатусЗаказаСвойство 	= Ложь;
	лСтатусЗаказаСвойство 				= Ложь;
	
	лНастройкиСтатусовЗаказа = ПланыОбмена.Б_ОбменССайтом.ПолучитьЗначениеКлючаСтруктурыНастроек(ПараметрыОбмена, "НастройкиСтатусовЗаказа");
	Если лНастройкиСтатусовЗаказа <> Неопределено тогда
			
		Если лНастройкиСтатусовЗаказа.ИсточникСтатусов1С = "СостоянияЗаказов" тогда
			лИспользуетсяСтатусЗаказаСостояние = Истина;
		ИначеЕсли лНастройкиСтатусовЗаказа.ИсточникСтатусов1С = "СвойствоЗаказов" тогда
			лИспользуетсяСтатусЗаказаСвойство = Истина;
			лСтатусЗаказаСвойство = ПараметрыОбмена.НастройкиСтатусовЗаказа.СвойствоЗаказа;
		КонецЕсли;
		
	КонецЕсли;
			
	ОбщийЗапрос.УстановитьПараметр("ИспользуетсяСтатусЗаказаСостояние"	, лИспользуетсяСтатусЗаказаСостояние);
	ОбщийЗапрос.УстановитьПараметр("ИспользуетсяСтатусЗаказаСвойство"	, лИспользуетсяСтатусЗаказаСвойство);
	ОбщийЗапрос.УстановитьПараметр("СтатусЗаказаСвойство"				, лСтатусЗаказаСвойство);
	
	
	лИспользуетсяСлужбыДоставкиЗаказаСвойство 	= Ложь;
	лИспользуетсяСлужбыДоставкиОтгрузкиСвойство = Ложь;
	лСлужбаДоставкиЗаказСвойство 	= Ложь;
	лСлужбаДоставкиОтгрузкиСвойство = Ложь;
	
	лНастройкиСлужбДоставкиДокументов = ПланыОбмена.Б_ОбменССайтом.ПолучитьЗначениеКлючаСтруктурыНастроек(ПараметрыОбмена, "НастройкиСлужбДоставкиДокументов");
	Если лНастройкиСлужбДоставкиДокументов <> Неопределено тогда
		
		лСлужбаДоставкиЗаказСвойство 	= ПараметрыОбмена.НастройкиСлужбДоставкиДокументов.СвойствоЗаказа;
		лСлужбаДоставкиОтгрузкиСвойство = ПараметрыОбмена.НастройкиСлужбДоставкиДокументов.СвойствоОтгрузки;
		
		Если лНастройкиСлужбДоставкиДокументов.ИсточникСлужбДоставкиЗаказа = "СвойствоЗаказов" И ЗначениеЗаполнено(лСлужбаДоставкиЗаказСвойство) тогда
			лИспользуетсяСлужбыДоставкиЗаказаСвойство = Истина;
		КонецЕсли;
		
		Если ПараметрыОбмена.ВыгрузкаОтгрузок  И ЗначениеЗаполнено(лСлужбаДоставкиОтгрузкиСвойство)  тогда
			лИспользуетсяСлужбыДоставкиОтгрузкиСвойство = Истина;
		КонецЕсли;
		
	КонецЕсли;
			
	ОбщийЗапрос.УстановитьПараметр("ИспользуетсяСлужбыДоставкиЗаказаСвойство"	, лИспользуетсяСлужбыДоставкиЗаказаСвойство);
	ОбщийЗапрос.УстановитьПараметр("ИспользуетсяСлужбыДоставкиОтгрузкиСвойство"	, лИспользуетсяСлужбыДоставкиОтгрузкиСвойство);
	ОбщийЗапрос.УстановитьПараметр("СлужбаДоставкиЗаказСвойство"				, лСлужбаДоставкиЗаказСвойство);
	ОбщийЗапрос.УстановитьПараметр("СлужбаДоставкиОтгрузкиСвойство"				, лСлужбаДоставкиОтгрузкиСвойство);
	
	
	ОбщийЗапрос.УстановитьПараметр("ВыгружаемыеОплатыПоОтборам"		, ПараметрыОбмена.ВыгружаемыеОплатыПоОтборам);
	ОбщийЗапрос.УстановитьПараметр("ВыгружаемыеОтгрузкиПоОтборам"	, ПараметрыОбмена.ВыгружаемыеОтгрузкиПоОтборам);
	
	ОбщийЗапрос.УстановитьПараметр("ИспользоватьОтборПоОплатам"		, ?(ПараметрыОбмена.ВыгружаемыеОплатыПоОтборам = Неопределено, Ложь, Истина));
	ОбщийЗапрос.УстановитьПараметр("ИспользоватьОтборПоОтгрузкам"	, ?(ПараметрыОбмена.ВыгружаемыеОтгрузкиПоОтборам = Неопределено, Ложь, Истина));
	
	МенеджерВременныхТаблицДокументов 	= Новый МенеджерВременныхТаблиц;
	ОбщийЗапрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблицДокументов;
	
	ЗапросПоЗаказам = "ВЫБРАТЬ
	|	МассивДанных.Объект КАК Объект
	|ПОМЕСТИТЬ ВремМассивДанных
	|ИЗ
	|	&МассивДанных КАК МассивДанных
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ЗаказКлиента.Ссылка КАК Документ,
