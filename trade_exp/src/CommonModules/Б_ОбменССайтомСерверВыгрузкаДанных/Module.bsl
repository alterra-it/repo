	|ИЗ
	|	МассивДанныхСПакетами КАК МассивДанныхСПакетамит";

	Выборка = Запрос.Выполнить().Выбрать();

	Пока Выборка.Следующий() Цикл
		//+Доработки  
		XDTOКонтрагент.Роль = "Покупатель";	

		Если Покупатель = Справочники.Контрагенты.НайтиПоНаименованию("ФИЗИЧЕСКОЕ ЛИЦО", Истина) И НЕ Партнер = Неопределено Тогда

			Если Не ПустаяСтрока(Партнер.Б_Идентификатор) Тогда
				XDTOКонтрагент.Ид = Партнер.Б_Идентификатор;
			Иначе
				XDTOКонтрагент.Ид = XMLСтрока(Партнер);
			КонецЕсли;
			XDTOКонтрагент.НомерВерсии = Б_ОбменССайтомСервер.ПолучитьВерсиюОбъекта(ПараметрыОбмена, Партнер.ВерсияДанных, "Партнеров");
			XDTOКонтрагент.ПометкаУдаления 	= XMLСтрока(Партнер.ПометкаУдаления);
			XDTOКонтрагент.Наименование 	= Партнер.Наименование;
			XDTOКонтрагент.ОфициальноеНаименование	= Партнер.НаименованиеПолное;

			//выгрузка контактной информации из партнера
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ                    
			|	ПартнерыКонтактнаяИнформация.Ссылка КАК Покупатель,
			|	ПартнерыКонтактнаяИнформация.Тип КАК Тип,
			|	ПартнерыКонтактнаяИнформация.Вид КАК Вид,
			|	ПартнерыКонтактнаяИнформация.Представление КАК Представление,
			|	ПартнерыКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей,
			|	ПартнерыКонтактнаяИнформация.Страна КАК Страна,
			|	ПартнерыКонтактнаяИнформация.Регион КАК Регион,
			|	ПартнерыКонтактнаяИнформация.Город КАК Город,
			|	ПартнерыКонтактнаяИнформация.АдресЭП КАК АдресЭП,
			|	ПартнерыКонтактнаяИнформация.ДоменноеИмяСервера КАК ДоменноеИмяСервера,
			|	ПартнерыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
			|	ПартнерыКонтактнаяИнформация.НомерТелефонаБезКодов КАК НомерТелефонаБезКодов
			|ИЗ
			|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|ГДЕ
			|	ПартнерыКонтактнаяИнформация.Ссылка = &Партнер";
			Запрос.УстановитьПараметр("Партнер", Партнер);
			Результат = Запрос.Выполнить().Выгрузить();			
			Если Результат.Количество() > 0 Тогда

				XDTOКонтактнаяИнформация = ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтактнаяИнформацияТип);

				Для Каждого ТекКонтИнформация Из Результат Цикл
					Если ТекКонтИнформация.Вид 			= Справочники.ВидыКонтактнойИнформации.АдресПартнера Тогда
						XDTOКонтрагент.АдресРегистрации	= Б_ОбменССайтомСервер.ПолучитьАдресXDTO(ПараметрыОбмена, ТекКонтИнформация);
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.ТелефонПартнера Тогда 
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон рабочий", ТекКонтИнформация.Представление));
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Домашний", Истина) Тогда
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон домашний", ТекКонтИнформация.Представление));
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Мобильный", Истина) Тогда
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон мобильный", ТекКонтИнформация.Представление));
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.EmailПартнера Тогда
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Электронная почта", ТекКонтИнформация.Представление));
					КонецЕсли;
				КонецЦикла;

				Если XDTOКонтактнаяИнформация.Контакт.Количество() > 0 тогда
					XDTOКонтрагент.Контакты = XDTOКонтактнаяИнформация;
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если ТипЗнч(Покупатель) = Тип("СправочникСсылка.Контрагенты") И ЗначениеЗаполнено(Покупатель.Партнер) Тогда
				Если Не ПустаяСтрока(Покупатель.Партнер.Б_Идентификатор) Тогда
					XDTOКонтрагент.Ид 				= Покупатель.Партнер.Б_Идентификатор;
				Иначе
					XDTOКонтрагент.Ид 				= XMLСтрока(Покупатель.Партнер);
				КонецЕсли;
			КонецЕсли;
			//-
			XDTOКонтрагент.НомерВерсии 		= Б_ОбменССайтомСервер.ПолучитьВерсиюОбъекта(ПараметрыОбмена, Выборка.ВерсияДанныхПокупателя, "Контрагентов");
			XDTOКонтрагент.ПометкаУдаления 	= XMLСтрока(Выборка.ПометкаУдаленияПокупателя);
			XDTOКонтрагент.Наименование 	= Выборка.НаименованиеПокупателя;

			Если Выборка.ЮрФизЛицоПокупателя 		= Перечисления.ЮрФизЛицо.ЮрЛицо Тогда
				XDTOКонтрагент.ОфициальноеНаименование	= Выборка.НаименованиеПолноеПокупателя;
			Иначе
				XDTOКонтрагент.ПолноеНаименование		= Выборка.НаименованиеПолноеПокупателя;
			КонецЕсли;

			XDTOКонтрагент.ИНН		= Выборка.ИННПокупателя;
			XDTOКонтрагент.КПП		= Выборка.КПППокупателя;
			XDTOКонтрагент.КодПоОКПО= Выборка.КодПоОКПОПокупателя;		

			//выгрузка банковских счетов
			Запрос = Новый Запрос;
			запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблицКонтрагентов;
			Запрос.Текст = "ВЫБРАТЬ 
			|	*
			|ИЗ
			|	ВремБанковскиеСчета КАК ВремБанковскиеСчета";

			тзнВрем = Запрос.Выполнить().Выгрузить();

			Если тзнВрем.Количество() > 0 тогда

				ВыгрузитьБанковскийСчетXDTO(ПараметрыОбмена, XDTOКонтрагент, XDTOКонтрагентТип, тзнВрем);

			КонецЕсли;

			//выгрузка контактов
			Запрос = Новый Запрос;
			запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблицКонтрагентов;
			Запрос.Текст = "ВЫБРАТЬ 
			|	*
			|ИЗ
			|	ВремКонтактныеЛица КАК ВремКонтактныеЛица";

			тзнВрем = Запрос.Выполнить().Выгрузить();

			Если тзнВрем.Количество() > 0 тогда

				XDTOПредставители = ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOПредставителиТип);

				Для каждого ТекКонтакт из тзнВрем Цикл 

					XDTOПредставитель 				= ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOПредставительТип);
					XDTOПредставитель.Отношение 	= "Контактное лицо";
					XDTOПредставитель.Ид 			= XMLСтрока(ТекКонтакт.ИдентификаторКонтактногоЛица);
					XDTOПредставитель.Наименование 	= ТекКонтакт.НаименованиеКонтактногоЛица;

					XDTOПредставители.Представитель.Добавить(XDTOПредставитель);

				КонецЦикла;

				Если XDTOПредставители.Представитель.количество() > 0 тогда
					XDTOКонтрагент.Представители = XDTOПредставители;
				КонецЕсли;

			КонецЕсли;

			//выгрузка контактной информации из контрагента
			Запрос = Новый Запрос;
			запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблицКонтрагентов;
			Запрос.Текст = "ВЫБРАТЬ 
			|	*
			|ИЗ
			|	ВремКонтактнаяИнформация КАК ВремКонтактнаяИнформация";

			тзнВрем = Запрос.Выполнить().Выгрузить();

			Загрузили = Ложь;
			Если тзнВрем.Количество() > 0 тогда//*Доработки

				XDTOКонтактнаяИнформация = ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтактнаяИнформацияТип);

				Для каждого ТекКонтИнформация из тзнВрем Цикл
					Если ТекКонтИнформация.Вид 			= Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента тогда
						XDTOКонтрагент.АдресРегистрации	= Б_ОбменССайтомСервер.ПолучитьАдресXDTO(ПараметрыОбмена, ТекКонтИнформация);
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента тогда
						XDTOКонтрагент.Адрес			= Б_ОбменССайтомСервер.ПолучитьАдресXDTO(ПараметрыОбмена, ТекКонтИнформация);
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента тогда
						//+Доработки
						Если ПустаяСтрока(ТекКонтИнформация.Представление) Тогда
							ТекКонтИнформация.Представление= АльтерраОбщегоНазначения.ПолучитьТелефонПартнера(Покупатель.Партнер);
						КонецЕсли;
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон мобильный", ТекКонтИнформация.Представление));
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон домашний", ТекКонтИнформация.Представление));
						//-
						XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон рабочий", ТекКонтИнформация.Представление));
					ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.EmailКонтрагента тогда

						Если СокрЛП(ТекКонтИнформация.Представление) <> "@Mail.ru" тогда	
							//+Доработки
							Если ПустаяСтрока(ТекКонтИнформация.Представление) Тогда
								ТекКонтИнформация.Представление= АльтерраОбщегоНазначения.ПолучитьПочтуПартнера(Покупатель.Партнер);
							КонецЕсли;
							//-
							XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Электронная почта", ТекКонтИнформация.Представление));
						КонецЕсли;

					КонецЕсли;

				КонецЦикла;

				Если XDTOКонтактнаяИнформация.Контакт.количество() > 0 тогда
					XDTOКонтрагент.Контакты = XDTOКонтактнаяИнформация;
				КонецЕсли;

				Загрузили= Истина;
			КонецЕсли;

			//+Доработки
			Если Не Загрузили Тогда
				//выгрузка контактной информации из партнера
				Запрос = Новый Запрос;
				запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблицКонтрагентов;
				Запрос.Текст = "ВЫБРАТЬ 
				|	*
				|ИЗ
				|	ВремКонтактнаяИнформацияПартнер КАК ВремКонтактнаяИнформация";

				тзнВрем = Запрос.Выполнить().Выгрузить();

				Если тзнВрем.Количество() > 0 тогда
					XDTOКонтактнаяИнформация = ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOКонтактнаяИнформацияТип);

					Для каждого ТекКонтИнформация из тзнВрем Цикл
						Если ТекКонтИнформация.Вид 			= Справочники.ВидыКонтактнойИнформации.ЮрАдресКонтрагента тогда
							XDTOКонтрагент.АдресРегистрации	= Б_ОбменССайтомСервер.ПолучитьАдресXDTO(ПараметрыОбмена, ТекКонтИнформация);
						ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента тогда
							XDTOКонтрагент.Адрес			= Б_ОбменССайтомСервер.ПолучитьАдресXDTO(ПараметрыОбмена, ТекКонтИнформация);
						ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.ТелефонПартнера тогда
							XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон рабочий", ТекКонтИнформация.Представление));
							XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон мобильный", ТекКонтИнформация.Представление));//+Доработки
							XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Телефон домашний", ТекКонтИнформация.Представление));//+Доработки
						ИначеЕсли ТекКонтИнформация.Вид 	= Справочники.ВидыКонтактнойИнформации.EmailПартнера тогда	
							Если СокрЛП(ТекКонтИнформация.Представление) <> "@Mail.ru" тогда	
								XDTOКонтактнаяИнформация.Контакт.Добавить(Б_ОбменССайтомСервер.ПолучитьКонтактнуюИнформациюXDTO(ПараметрыОбмена, XDTOКонтактТип, "Электронная почта", ТекКонтИнформация.Представление));
							КонецЕсли;
						КонецЕсли;

					КонецЦикла;

					Если XDTOКонтактнаяИнформация.Контакт.количество() > 0 тогда
						XDTOКонтрагент.Контакты = XDTOКонтактнаяИнформация;
					КонецЕсли;		
				КонецЕсли;			
			КонецЕсли;

		КонецЕсли;

	КонецЦикла;

	Возврат XDTOКонтрагент;

КонецФункции

Процедура _ВыгрузитьЕдиницыПересчета(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, Номенклатура)
	мЕдиниц= Новый Массив;
	мЕдиниц.Добавить("Объем");
	мЕдиниц.Добавить("Площадь");
	мЕдиниц.Добавить("Длина");
	мЕдиниц.Добавить("Вес");
	мЕдиниц.Добавить("Штуки");
	
	Для Каждого Единица Из мЕдиниц Цикл
		Если Номенклатура[Единица+"ВыгружатьНаСайт"] Тогда 
			Если Номенклатура[Единица+"Знаменатель"] > 0 Тогда
				Коэф= Номенклатура[Единица+"Числитель"]/Номенклатура[Единица+"Знаменатель"];
			Иначе
				Коэф = 1;
			КонецЕсли;
			
			Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "Единица", Единица);
			Б_ОбменССайтомСервер.ДобавитьЗначениеРеквизитаXDTO(ПараметрыОбмена, XDTOЗначенияРеквизитов, XDTOЗначениеРеквизитаТип, "КоэфПересчета", Коэф);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ПолучитьСортировкуСопутствующихВидовНоменклатуры(СопутствующийВидНоменклатуры)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СортировкаСопутствующихВидовНоменклатуры.СопутствующийВидНоменклатуры КАК СопутствующийВидНоменклатуры,
	|	СортировкаСопутствующихВидовНоменклатуры.Сортировка КАК Сортировка
	|ИЗ
	|	РегистрСведений.СортировкаСопутствующихВидовНоменклатуры КАК СортировкаСопутствующихВидовНоменклатуры
	|ГДЕ
	|	СортировкаСопутствующихВидовНоменклатуры.СопутствующийВидНоменклатуры = &СопутствующийВидНоменклатуры";
	Запрос.УстановитьПараметр("СопутствующийВидНоменклатуры", СопутствующийВидНоменклатуры);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Возврат Выборка.Сортировка;
	
КонецФункции

Процедура ВыгрузитьПодразделенияАкцииНоменклатурыXDTO(ПараметрыОбмена, Владелец, ВладелецТип, ВыборкаНоменклатуры, МенеджерВременныхТаблиц);
	
	XDTOЗначенияСвойствТип 	= Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначенияСвойств", Истина, ВладелецТип);
	XDTOЗначенияСвойстваТип = Б_ОбменССайтомСервер.ПолучениеТипОбъектаXDTO(ПараметрыОбмена,  "ЗначенияСвойства");
	
	СтруктураЗначенийСвойствАкций = Новый Структура("aksia_center,aksia_barnaul,aksia_novoalt,aksia_biysk",Ложь,Ложь,Ложь,Ложь);
	ТекущаяДата = ТекущаяДата();
	
	Запрос = Новый Запрос;
	запрос.Текст =  "ВЫБРАТЬ
	                |	МАКСИМУМ(ВЫБОР
	                |			КОГДА МаркетинговыеМероприятияТоварыАкции.Подразделение.Код = ""0А-000001""
	                |				ТОГДА ИСТИНА
	                |			ИНАЧЕ ЛОЖЬ
	                |		КОНЕЦ) КАК aksia_center,
	                |	МАКСИМУМ(ВЫБОР
	                |			КОГДА МаркетинговыеМероприятияТоварыАкции.Подразделение.Код = ""0А-000002""
	                |				ТОГДА ИСТИНА
	                |			ИНАЧЕ ЛОЖЬ
	                |		КОНЕЦ) КАК aksia_barnaul,
	                |	МАКСИМУМ(ВЫБОР
	                |			КОГДА МаркетинговыеМероприятияТоварыАкции.Подразделение.Код = ""0А-000003""
	                |				ТОГДА ИСТИНА
	                |			ИНАЧЕ ЛОЖЬ
	                |		КОНЕЦ) КАК aksia_novoalt,
	                |	МАКСИМУМ(ВЫБОР
	                |			КОГДА МаркетинговыеМероприятияТоварыАкции.Подразделение.Код = ""0А-000004""
	                |				ТОГДА ИСТИНА
	                |			ИНАЧЕ ЛОЖЬ
	                |		КОНЕЦ) КАК aksia_biysk
	                |ИЗ
	                |	Справочник.МаркетинговыеМероприятия.ТоварыАкции КАК МаркетинговыеМероприятияТоварыАкции
	                |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
	                |		ПО МаркетинговыеМероприятияТоварыАкции.Ссылка = МаркетинговыеМероприятия.Ссылка
	                |ГДЕ
	                |	МаркетинговыеМероприятияТоварыАкции.Номенклатура = &Номенклатура
	                |	И НЕ МаркетинговыеМероприятия.ПометкаУдаления
	                |	И НЕ МаркетинговыеМероприятия.Завершено
	                |	И МаркетинговыеМероприятия.ДатаОкончания >= &ТекущаяДата
	                |	И МаркетинговыеМероприятия.ВидАкции = ЗНАЧЕНИЕ(Перечисление.ВидыАкций.Неликвиды)
	                |	И МаркетинговыеМероприятия.ТипОтбора = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоСписку)";
	
	Запрос.УстановитьПараметр("Номенклатура", ВыборкаНоменклатуры.Номенклатура);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата);

	Выборка = Запрос.Выполнить();
	
	
	ВыборкаДетальныеЗаписи = Выборка.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		заполнитьзначениясвойств(СтруктураЗначенийСвойствАкций,ВыборкаДетальныеЗаписи);
		
	КонецЦикла;
	
	XDTOЗначенияСвойств = ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOЗначенияСвойствТип);
	
	Для каждого СтрокаСтруктуры из СтруктураЗначенийСвойствАкций Цикл
		
		XDTOЗначенияСвойства = ПараметрыОбмена.МояФабрикаXDTO.Создать(XDTOЗначенияСвойстваТип);
		
		XDTOЗначенияСвойства.Ид = XMLСтрока(СтрокаСтруктуры.Ключ);
		
		XDTOЗначенияСвойства.Значение.Добавить(XMLСтрока(СтрокаСтруктуры.Значение));
		
		XDTOЗначенияСвойств.ЗначенияСвойства.Добавить(XDTOЗначенияСвойства);
		
	КонецЦикла;
	
	Владелец.ЗначенияСвойств = XDTOЗначенияСвойств;

	
КонецПроцедуры

