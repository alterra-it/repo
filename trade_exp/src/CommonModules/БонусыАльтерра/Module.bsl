Функция ТоварИсключенИзРасчетаБонусныхБалов(стрТовар) Экспорт
	грТара= Справочники.Номенклатура.НайтиПоКоду("00448      ");
	грПоддоны= Справочники.Номенклатура.НайтиПоКоду("Ц0000474   ");
	
	Если стрТовар.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
		Возврат Истина;
	КонецЕсли;
	Если стрТовар.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.МногооборотнаяТара Тогда
		Возврат Истина;
	КонецЕсли;
	Если стрТовар.Номенклатура.Родитель = грТара ИЛИ  стрТовар.Номенклатура.Родитель = грПоддоны Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

Процедура РаспределитьОплатуБаллами(СуммаОплаты, Товары) Экспорт       	
	
	ТоварыКОплате = ПолучитьТоварыКРасчетуБаллов(Товары,,, Истина); 
	МаксимальнаяСуммаОплатыВБаллах = ТоварыКОплате.Итог("Сумма");  
	СуммаКРаспределению = СуммаОплаты;
	
	// Определение строки с максимальной суммой и номера последней строки
	СтрокаСМаксимальнойСуммой  = Неопределено;
	НомерПоследнейСтроки = 0;
	СуммаБонусныхБалловКСписаниюРасчет = 0; 
	
	Для Каждого стрТовара Из ТоварыКОплате Цикл
		СтрокаТЧ = Товары.Найти(стрТовара.НомерСтроки, "НомерСтроки");
		
		Если СтрокаСМаксимальнойСуммой = Неопределено Тогда
			СтрокаСМаксимальнойСуммой = СтрокаТЧ;
		Иначе 
			СтрокаСМаксимальнойСуммой = ?(СтрокаТЧ.Сумма > СтрокаСМаксимальнойСуммой.Сумма, СтрокаТЧ, СтрокаСМаксимальнойСуммой);
		КонецЕсли;		    
		
		НомерПоследнейСтроки = ?(стрТовара.НомерСтроки > НомерПоследнейСтроки, стрТовара.НомерСтроки, НомерПоследнейСтроки);
	КонецЦикла;
	
	// Распределение баллов
	Для Каждого стрТовара Из ТоварыКОплате Цикл
		СтрокаТЧ = Товары.Найти(стрТовара.НомерСтроки, "НомерСтроки");   
		
		Если МаксимальнаяСуммаОплатыВБаллах <= 0 Тогда
			Прервать;
		КонецЕсли;
		
		Если СтрокаТЧ.НомерСтроки <> НомерПоследнейСтроки Тогда
			СтрокаТЧ.СуммаБонусныхБалловКСписанию = СтрокаТЧ.Сумма * (СуммаКРаспределению / МаксимальнаяСуммаОплатыВБаллах);
		Иначе
			СтрокаТЧ.СуммаБонусныхБалловКСписанию = СуммаКРаспределению;
		КонецЕсли;
		
		Цена = (СтрокаТЧ.Сумма - СтрокаТЧ.СуммаБонусныхБалловКСписанию)/СтрокаТЧ.Количество;
		Если Цена < 0.01 Тогда
			СтрокаТЧ.СуммаБонусныхБалловКСписанию = СтрокаТЧ.Сумма - 0.01 * СтрокаТЧ.Количество;
		КонецЕсли;
		СтрокаТЧ.СуммаБонусныхБалловКСписаниюВВалюте = СтрокаТЧ.СуммаБонусныхБалловКСписанию;
		СуммаБонусныхБалловКСписаниюРасчет = СуммаБонусныхБалловКСписаниюРасчет + СтрокаТЧ.СуммаБонусныхБалловКСписанию;
		
		СуммаКРаспределению = СуммаКРаспределению - СтрокаТЧ.СуммаБонусныхБалловКСписанию;
		МаксимальнаяСуммаОплатыВБаллах = МаксимальнаяСуммаОплатыВБаллах - СтрокаТЧ.Сумма;
	КонецЦикла;
	
	// Корректировка копеек при правке цены с 0 на 0,01
	Если СуммаБонусныхБалловКСписаниюРасчет < СуммаОплаты Тогда
		СтрокаСМаксимальнойСуммой.СуммаБонусныхБалловКСписанию = СтрокаСМаксимальнойСуммой.СуммаБонусныхБалловКСписанию + 
			СуммаОплаты - СуммаБонусныхБалловКСписаниюРасчет;
		СтрокаСМаксимальнойСуммой.СуммаБонусныхБалловКСписаниюВВалюте = СтрокаСМаксимальнойСуммой.СуммаБонусныхБалловКСписанию;	
	КонецЕсли;
	
КонецПроцедуры

Функция ОтфильтроватьТаблицуТоваровКРасчетуБонусныхБаллов(ТабличнаяЧастьТовары) Экспорт
	
	ТабличнаяЧастьТоварыИсходная= ТабличнаяЧастьТовары.Скопировать();
	ТабличнаяЧастьТовары.Очистить();
	
	ТоварыКОплате= ПолучитьТоварыКРасчетуБаллов(ТабличнаяЧастьТоварыИсходная);
	
	Для Каждого стрТовара Из ТоварыКОплате Цикл
		НайденныеСтроки = ТабличнаяЧастьТоварыИсходная.НайтиСтроки(Новый Структура("НомерСтроки", стрТовара.НомерСтроки));
		СтрокаТЧ= НайденныеСтроки[0];
		
		НоваяСтрока= ТабличнаяЧастьТовары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
	КонецЦикла;
КонецФункции

Процедура ДобавитьСтрокувТЧБонусныеБаллы(Объект, СуммаБаллов) Экспорт
	Объект.БонусныеБаллы.Очистить();
	
	БонуснаяПрограммаЛояльности = Объект.КартаЛояльности.Владелец.БонуснаяПрограммаЛояльности;
	Если Не ЗначениеЗаполнено(БонуснаяПрограммаЛояльности) Тогда
		 БонуснаяПрограммаЛояльности= АльтерраОбщегоНазначения.ПолучитьБонуснуюПрограмму();
	КонецЕсли;
	
	ТекДата= ?(Объект.Дата = Дата(1,1,1), ТекущаяДата(), Объект.Дата);
	
	НоваяСтрока = Объект.БонусныеБаллы.Добавить();
	НоваяСтрока.БонуснаяПрограммаЛояльности= БонуснаяПрограммаЛояльности;
	НоваяСтрока.ДатаНачисления= ТекДата+3600*24*3;
	НоваяСтрока.ДатаСписания=  ТекДата+3600*24*3;
	НоваяСтрока.СуммаБонусныхБаллов= СуммаБаллов;
КонецПроцедуры

Процедура ОбновитьСтатусВРегистре(Партнер, Статус, БонуснаяПрограммаЛояльности=Неопределено)  Экспорт
	Если Не ЗначениеЗаполнено(БонуснаяПрограммаЛояльности) Тогда
		БонуснаяПрограммаЛояльности= Справочники.БонусныеПрограммыЛояльности.НайтиПоНаименованию("Бонус от ALTERRA", Истина);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запись = РегистрыСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СоздатьМенеджерЗаписи();
	Запись.Период = ТекущаяДата();
	Запись.БонуснаяПрограммаЛояльности = БонуснаяПрограммаЛояльности;
	Запись.Партнер = Партнер;
	Запись.Статус = Статус;
	Запись.Записать();	

	УстановитьПривилегированныйРежим(Ложь);
	
	Комментарий= "Смена статуса на "+Статус;
	ЗаписьЖурналаРегистрации("ОбновлениеСтатусовПартнеров", УровеньЖурналаРегистрации.Информация, Партнер, , Комментарий);
КонецПроцедуры
#КонецОбласти

#ОБласть Проверки
Процедура ПриЗаписиКартыЛояльностиПередЗаписью(Источник, Отказ) Экспорт//Подписка на событие
	Если РольДоступна("ПолныеПрава") Тогда
		Возврат;
	КонецЕсли;
	Если Источник.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	УПартнераУжеЕстьКарта(Источник.Ссылка, Отказ);
	
	Если ЗначениеЗаполнено(Источник.Владелец.БонуснаяПрограммаЛояльности) И Источник.Статус = Перечисления.СтатусыКартЛояльности.Действует Тогда
		Если Источник.Партнер = Справочники.Партнеры.РозничныйПокупатель Тогда
			Сообщить("Не нужно оформлять бонусную карту на клиента РОЗНИЦА!");
			Отказ= Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Источник.Контрагент) Тогда
			Если Источник.Контрагент.ЮрФизЛицо <> Перечисления.ЮрФизЛицо.ФизЛицо Тогда
				Сообщить("Бонусную карту можно оформить только для физических лиц!");
				Отказ= Истина;
			КонецЕсли;
		Иначе
			Сообщить("Контрагент не заполнен!");
			Отказ= Истина;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Источник.Соглашение) Тогда
			Сообщить("Необходимо задать соглашение!");
			Отказ= Истина;
		Иначе
			ЕстьТЗ= Найти(Источник.Соглашение.Наименование, " ТЗ");
			Если ЕстьТЗ = 0 Тогда
				Сообщить("Необходимо выбрать соглашение с аббривиатурой 'ТЗ'!");
				Отказ= Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Выборка= КартыСТакимШтрихкодом(Источник);
	Пока Выборка.Следующий() Цикл
		Сообщить("С данным штрихкодом  '"+Источник.Штрихкод+"' уже зарегистрирована "+Выборка.ВидКарты+" дисконтная карта на партнера '"+Выборка.Партнер+"'!");
		Отказ= Истина;
	КонецЦикла;
КонецПроцедуры

Функция КартыСТакимШтрихкодом(Источник)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КартыЛояльности.Ссылка КАК Ссылка,
		|	КартыЛояльности.Партнер КАК Партнер,
		|	КартыЛояльности.Владелец КАК ВидКарты,
		|	КартыЛояльности.Штрихкод КАК Штрихкод,
		|	КартыЛояльности.Статус КАК Статус
		|ИЗ
		|	Справочник.КартыЛояльности КАК КартыЛояльности
		|ГДЕ
		|	НЕ КартыЛояльности.ПометкаУдаления
		|	И КартыЛояльности.Штрихкод = &Штрихкод
		|	И КартыЛояльности.Статус = &Статус
		|	И КартыЛояльности.Ссылка <> &Источник
		|	И КартыЛояльности.Владелец = &ВидКарты";
	
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыКартЛояльности.Действует);
	Запрос.УстановитьПараметр("Штрихкод", Источник.Штрихкод);
	Запрос.УстановитьПараметр("Источник", Источник.Ссылка);
	Запрос.УстановитьПараметр("ВидКарты", Источник.Владелец);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Процедура УПартнераУжеЕстьКарта(КартаЛояльности, Отказ)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КартыЛояльности.Ссылка КАК Карта,
		|	КартыЛояльности.Партнер КАК Партнер,
		|	КартыЛояльности.Владелец КАК ВидКарты
		|ПОМЕСТИТЬ ВТ_Партнер
		|ИЗ
		|	Справочник.КартыЛояльности КАК КартыЛояльности
		|ГДЕ
		|	КартыЛояльности.Ссылка = &КартаЛояльности
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КартыЛояльности.Ссылка КАК Карта,
		|	КартыЛояльности.Партнер КАК Партнер,
		|	КартыЛояльности.Владелец КАК ВидКарты
		|ИЗ
		|	ВТ_Партнер КАК ВТ_Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КартыЛояльности КАК КартыЛояльности
		|		ПО ВТ_Партнер.Партнер = КартыЛояльности.Партнер
		|ГДЕ
		|	КартыЛояльности.Владелец = &Владелец
		|	И КартыЛояльности.Статус = &Статус
		|	И КартыЛояльности.Ссылка <> &КартаЛояльности";
	
	Запрос.УстановитьПараметр("КартаЛояльности", КартаЛояльности);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыКартЛояльности.Действует);
	Запрос.УстановитьПараметр("Владелец", Справочники.ВидыКартЛояльности.НайтиПоНаименованию("Бонусная карта"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Сообщить("У партнера уже есть бонусная карта "+ВыборкаДетальныеЗаписи.Карта);
		Отказ= Истина;
	КонецЦикла;
КонецПроцедуры

Процедура ЕстьПартнерСТакимТелефоном(ЭтотПартнер, Отказ)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыКонтактнаяИнформация.Ссылка КАК Партнер,
		|	ПартнерыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
		|ПОМЕСТИТЬ ВТ_Телефон
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Ссылка = &ЭтотПартнер
		|	И ПартнерыКонтактнаяИнформация.Вид = &ВидТелефон
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПартнерыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
		|	ПартнерыКонтактнаяИнформация.Ссылка КАК Партнер
		|ИЗ
		|	ВТ_Телефон КАК ВТ_Телефон
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|		ПО ВТ_Телефон.НомерТелефона = ПартнерыКонтактнаяИнформация.НомерТелефона
		|			И (&ВидТелефон = ПартнерыКонтактнаяИнформация.Вид)
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Ссылка <> &ЭтотПартнер";
	
	Запрос.УстановитьПараметр("ЭтотПартнер", ЭтотПартнер);
	Запрос.УстановитьПараметр("ВидТелефон", Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		АльтерраОбщегоНазначения.СообщитьПользователю(ВыборкаДетальныеЗаписи.Партнер, "У "+ВыборкаДетальныеЗаписи.Партнер+" такой же номер телефона");
		Отказ= Истина;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

