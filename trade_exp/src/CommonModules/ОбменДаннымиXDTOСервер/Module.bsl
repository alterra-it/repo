
Процедура ЗаписатьЛогОбмена(Объект,ВсегоОбъектов,Счетчик)
	если Константы.ВестиЛогОбмена.Получить() тогда
		ВремяЗаписи = ТекущаяДата();
		Время10=прав(Формат(ТекущаяДата(), "ДЛФ=T"),4);           
		//если Время10="0:00" или Время10="0:01" или Время10="0:02"   тогда  
			ПолныйПутьКФайлу = "\\1c-alterra\exchange1c\accounting3\log";
			//ПолныйПутьКФайлу = "\\1c-dev\ит-отдел\Устинов\log";
			Если ПолныйПутьКФайлу <> "" Тогда
				
				СтрокаЗаписи = "[" + Формат(ВремяЗаписи, "ДФ='yyyy/MM/dd HH:mm:ss'") + "]" + Символы.ПС 
				+ "[" + Строка(Объект) + "] "+строка(ВсегоОбъектов)+"/"+строка(счетчик) + Символы.ПС;		
				
				Попытка
					ФайлЛогов = Новый ЗаписьТекста(ПолныйПутьКФайлу, КодировкаТекста.UTF8,,Истина);
					ФайлЛогов.ЗаписатьСтроку(СтрокаЗаписи);
					ФайлЛогов.Закрыть();
				Исключение
					//	ЗаписьЖурналаРегистрации("ЗаписьВЛог", УровеньЖурналаРегистрации.Ошибка, ТекстСобытия,"Ошибка записи в лог", ОписаниеОшибки());
				КонецПопытки;
			КонецЕсли;
			
		//конецесли;
	конецесли;
КонецПроцедуры


&ИзменениеИКонтроль ("ВыполнитьВыгрузкуЗарегистрированныхДанныхБезПакетнойРегистрации")
Процедура ИСПР_ВыполнитьВыгрузкуЗарегистрированныхДанныхБезПакетнойРегистрации(
	КомпонентыОбмена, НомерСообщения, НачальнаяВыгрузкаДанных, УзелДляОбменаОбъект, СписокТипов)
	
	УзелДляОбмена = КомпонентыОбмена.УзелКорреспондента;
	
	Если КомпонентыОбмена.ИспользоватьКвитирование Тогда
		Если КомпонентыОбмена.ФильтрВыборкиИзменений <> Неопределено Тогда
			ФильтрВыборкиСПодходящимТипом = Новый Массив;
			Для Каждого СсылкаДляВыгрузки Из КомпонентыОбмена.ФильтрВыборкиИзменений Цикл
				Если СписокТипов.Найти(Метаданные.НайтиПоТипу(ТипЗнч(СсылкаДляВыгрузки))) <> Неопределено Тогда
					ФильтрВыборкиСПодходящимТипом.Добавить(СсылкаДляВыгрузки);
				КонецЕсли;
			КонецЦикла;
			Если ФильтрВыборкиСПодходящимТипом.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			
			ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(УзелДляОбмена, НомерСообщения, ФильтрВыборкиСПодходящимТипом);
		Иначе
			ВыборкаИзменений = ПланыОбмена.ВыбратьИзменения(УзелДляОбмена, НомерСообщения, СписокТипов);
		КонецЕсли;
			#Вставка     
			Счетчик=0;
			#КонецВставки
		
		Пока ВыборкаИзменений.Следующий() Цикл
		    Объект = ВыборкаИзменений.Получить();
			ВыгрузкаЗарегистрированногоОбъекта(КомпонентыОбмена, НачальнаяВыгрузкаДанных, УзелДляОбменаОбъект, Объект);
			#Вставка     
			Счетчик=Счетчик+1;
			ЗаписатьЛогОбмена(Объект,КомпонентыОбмена.КоличествоОбъектовКВыгрузке,Счетчик);
			#КонецВставки
		КонецЦикла;
	Иначе
		Если КомпонентыОбмена.ФильтрВыборкиИзменений <> Неопределено Тогда
			Для Каждого СсылкаДляВыгрузки Из КомпонентыОбмена.ФильтрВыборкиИзменений Цикл
				Если СписокТипов.Найти(Метаданные.НайтиПоТипу(ТипЗнч(СсылкаДляВыгрузки))) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Если ПланыОбмена.ИзменениеЗарегистрировано(УзелДляОбмена, СсылкаДляВыгрузки) Тогда
					Объект = СсылкаДляВыгрузки.ПолучитьОбъект();
					ВыгрузкаЗарегистрированногоОбъекта(КомпонентыОбмена, НачальнаяВыгрузкаДанных, УзелДляОбменаОбъект, Объект);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
