Функция ЗаполнитьИерархическийСправочникТем(АдресДокJSON, ИмяНабораЗаписей)
    ЧтJSON = Новый ЧтениеJSON;
    ЧтJSON.УстановитьСтроку(ПолучитьИзВременногоХранилища(АдресДокJSON));
    Данные = ПрочитатьJSON(ЧтJSON);
    ЧтJSON.Закрыть();
    
    Для Каждого Стр Из Данные[ИмяНабораЗаписей] Цикл
        СоздатьИерархиюТем(Стр, null);
    КонецЦикла
КонецФункции

Процедура СоздатьИерархиюТем(Стр, parent_id)
    Перем Подчиненные;
    ЕстьПодчиненные = Стр.Свойство("child", Подчиненные);
    Если ( ЕстьПодчиненные ) Тогда
       СоздатьТему(Стр.id, Стр.name + " ("+ Подчиненные.Количество() + ")", Стр.type, parent_id, Истина, ?(Стр.test.Количество() > 0,Истина,Ложь));
	   Если Стр.test.Количество() > 0 Тогда
		   СоздатьТест(Стр.id, Стр.name, Стр.test);
	   КонецЕсли;
       Для Каждого Стр2 Из Подчиненные Цикл
            СоздатьИерархиюТем(Стр2, Стр.id);
       КонецЦикла
    Иначе
       СоздатьТему(Стр.id, Стр.name, Стр.type, parent_id, Ложь, ?(Стр.test.Количество() > 0,Истина,Ложь));
	   Если Стр.test.Количество() > 0 Тогда
		   СоздатьТест(Стр.id, Стр.name, Стр.test);
	   КонецЕсли;
    КонецЕсли    
КонецПроцедуры

Процедура СоздатьТест(id, name, test)
	
	Для каждого Тест Из test Цикл
		НовыйТест = Справочники.ТестыАкадемии.СоздатьЭлемент();
		НовыйТест.Код = id;
		НовыйТест.Наименование = name;
		НовыйТест.ИДТеста = Тест;
		НовыйТест.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьТему(id, name, type, parent_id, category = Ложь, testing = Ложь)
    Перем Родитель;
    
    ТипТемыСсылка = Справочники.ТипыТемАкадемии.НайтиПоНаименованию(type);
    Если ТипТемыСсылка = Справочники.ТипыТемАкадемии.ПустаяСсылка() Тогда
        НовыйТипТемы = Справочники.ТипыТемАкадемии.СоздатьЭлемент();
        НовыйТипТемы.Наименование = type;
        НовыйТипТемы.Записать();
        ТипТемыСсылка = НовыйТипТемы.Ссылка;
    КонецЕсли;
    
    Если (parent_id = null) Тогда
        Родитель = Справочники.ТемыАкадемии.НайтиПоНаименованию(type);
        Если Родитель = Справочники.ТемыАкадемии.ПустаяСсылка() Тогда
            НоваяТема = Справочники.ТемыАкадемии.СоздатьЭлемент();
            НоваяТема.Код = 999000000 + ТипТемыСсылка.Код;
            НоваяТема.Наименование = type;
			НоваяТема.СодержитДопТемы = category;
			НоваяТема.Тестирование = testing;
            НоваяТема.Записать();
            Родитель = НоваяТема.Ссылка;
        КонецЕсли;
    Иначе
        Родитель = Справочники.ТемыАкадемии.НайтиПоКоду(parent_id);
    КонецЕсли;

    НоваяТема = Справочники.ТемыАкадемии.СоздатьЭлемент();
    НоваяТема.Код = id;
    НоваяТема.Наименование = ОбработатьНаименование(name);
    НоваяТема.ТипТемы = ТипТемыСсылка;
    НоваяТема.Родитель = Родитель;
	НоваяТема.СодержитДопТемы = category;
	Если Родитель.Код > 999000000 Тогда
		НоваяТема.Тестирование = Истина;
	Иначе
		НоваяТема.Тестирование = testing;
	КонецЕсли; 
    НоваяТема.Записать();    
КонецПроцедуры  

Функция ОбработатьНаименование(Знач Наименование)  
	ПродолжитьПоиск = Истина;
	Пока ПродолжитьПоиск Цикл
		КонечнаяПозиция = СтрНайти(Наименование,")",НаправлениеПоиска.СКонца);
		НачальнаяПозиция = СтрНайти(Наименование,"(",НаправлениеПоиска.СКонца);
		Если НачальнаяПозиция <> 0 И КонечнаяПозиция <> 0 Тогда
			Наименование = СтрЗаменить(Наименование,Сред(Наименование,НачальнаяПозиция,КонечнаяПозиция - НачальнаяПозиция + 1),"");
			Наименование = СокрЛП(СтрЗаменить(Наименование,"  "," "));
		Иначе
			ПродолжитьПоиск = Ложь;
		КонецЕсли;	
	КонецЦикла;  
	Возврат Наименование;
КонецФункции	

Функция ПрочитатьТзИзФайла(АдресДокJSON, ИмяНабораЗаписей)  
    ЧтJSON = Новый ЧтениеJSON;
    ЧтJSON.УстановитьСтроку(ПолучитьИзВременногоХранилища(АдресДокJSON));
    Данные = ПрочитатьJSON(ЧтJSON);
    ЧтJSON.Закрыть();               
    
    ТЗ = Новый ТаблицаЗначений;
    
    Массив = Новый Массив;
    Массив.Добавить(Тип("Дата"));
    ОписаниеТиповДаты = Новый ОписаниеТипов(Массив, , , , , Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя));
    
    Массив.Очистить();
    Массив.Добавить(Тип("Строка"));
    ОписаниеТиповСтроки = Новый ОписаниеТипов(Массив, , , , Новый КвалификаторыСтроки(150));
    
    Массив.Очистить();
    Массив.Добавить(Тип("Число"));
    ОписаниеТиповЧисла = Новый ОписаниеТипов(Массив, , , Новый КвалификаторыЧисла(10,0));

    Массив.Очистить();
    Массив.Добавить(Тип("Булево"));
    ОписаниеТиповБулево = Новый ОписаниеТипов(Массив);

    Если ИмяНабораЗаписей = "dep_tasks" Тогда
        ТЗ.Колонки.Добавить("proff_code", ОписаниеТиповСтроки);
        ТЗ.Колонки.Добавить("theme_id", ОписаниеТиповЧисла);
		ТЗ.Колонки.Добавить("department_id", ОписаниеТиповЧисла);
		ТЗ.Колонки.Добавить("department_code", ОписаниеТиповСтроки);
    КонецЕсли;
    
    Если ИмяНабораЗаписей = "studied" Тогда
        ТЗ.Колонки.Добавить("client_code", ОписаниеТиповСтроки);
        ТЗ.Колонки.Добавить("theme_id", ОписаниеТиповЧисла);
        ТЗ.Колонки.Добавить("date", ОписаниеТиповДаты);
	КонецЕсли;
	
	Если ИмяНабораЗаписей = "test" Тогда
		ТЗ.Колонки.Добавить("id", ОписаниеТиповЧисла);
        ТЗ.Колонки.Добавить("client_code", ОписаниеТиповСтроки);
        ТЗ.Колонки.Добавить("theme_id", ОписаниеТиповЧисла);
		ТЗ.Колонки.Добавить("test_id", ОписаниеТиповЧисла);
        ТЗ.Колонки.Добавить("date", ОписаниеТиповДаты);
		ТЗ.Колонки.Добавить("score", ОписаниеТиповЧисла);
		ТЗ.Колонки.Добавить("time", ОписаниеТиповСтроки);
		ТЗ.Колонки.Добавить("seconds", ОписаниеТиповЧисла);
		ТЗ.Колонки.Добавить("is_reset", ОписаниеТиповСтроки);
		ТЗ.Колонки.Добавить("is_main_test", ОписаниеТиповСтроки);
		ТЗ.Колонки.Добавить("finished", ОписаниеТиповБулево);
    КонецЕсли;
    
    ЗаполнитьТаблицуИзJSON(Данные[ИмяНабораЗаписей], ТЗ);

    Возврат ТЗ;
КонецФункции

Процедура ЗаполнитьТаблицуИзJSON(мДанные, ТЗ)
    
    Для Каждого ЭлементМассива из мДанные Цикл
        Строка = ТЗ.Добавить();
        
        Для Каждого Запись Из ЭлементМассива Цикл
            Колонка = Запись.Ключ;
            Если Колонка = "date" Тогда
                Зн = Запись.Значение;
                Если Зн="-" Тогда
                    Строка[Колонка] = Null;
                Иначе
                    стр = СтрЗаменить(Зн, "-", "");
                    стр = СтрЗаменить(стр, " ", "");
                    стр = СтрЗаменить(стр, ":", "");
                    стр = СтрЗаменить(стр, "+00", "");
                    Строка[Колонка] = Дата(стр);
                КонецЕсли;
            ИначеЕсли Колонка = "count_tries" Или Колонка = "score" Тогда
                Строка[Колонка] = Число(Запись.Значение);
			ИначеЕсли Колонка = "time" Тогда
			    Зн = Запись.Значение;
			    Зн = СтрЗаменить(Зн, " мин. ", "/");
			    Зн = СтрЗаменить(Зн, " с.", "");
			    м = СтрРазделить(Зн, "/");
			    к = м.Количество();
			    в = 0;
			    Если к = 2 Тогда
			        в = Число(м[0]) * 60 + Число(м[1]);    
			    ИначеЕсли к = 1 Тогда
			        в = Число(м[0]);    
			    КонецЕсли;
			    Строка["seconds"] = в;
				Строка[Колонка] = Запись.Значение;
            ИначеЕсли Колонка = "result" Тогда
                Зн = Запись.Значение;
                Строка["is_test"] = ?(Зн = "Не пройден" Или Зн = "Тест пройден", Истина, Ложь);
                Строка["result"] = ?(Зн = "Не пройден" Или Зн = "Не изучено", Ложь, Истина);
            Иначе
                Зн = Запись.Значение;
                Если Зн = "Да" Тогда
                    Строка[Колонка] = Истина;
                ИначеЕсли Зн = "Нет" Тогда
                    Строка[Колонка] = Ложь;
                Иначе
                    Строка[Колонка] = Запись.Значение;
                КонецЕсли;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
 
КонецПроцедуры

Процедура ЗаполнениеДолжностьТема(ТЗ)
    Запрос = Новый Запрос;
    Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |	ТЗ.proff_code КАК proff_code,
    |	ТЗ.theme_id КАК theme_id,
    |	ТЗ.department_code КАК department_code
    |ПОМЕСТИТЬ TЗ_dep_tasks
    |ИЗ
    |	&_ТЗ КАК ТЗ
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |	Должности.Ссылка КАК Должность,
    |	ТемыАкадемии.Ссылка КАК Тема,
    |	Отделы.Ссылка КАК Отдел
    |ИЗ
    |	TЗ_dep_tasks КАК TЗ_dep_tasks
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Должности КАК Должности
    |		ПО TЗ_dep_tasks.proff_code = Должности.Код
    |			И (НЕ Должности.ПометкаУдаления)
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ТемыАкадемии КАК ТемыАкадемии
    |		ПО TЗ_dep_tasks.theme_id = ТемыАкадемии.Код
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Отделы КАК Отделы
    |		ПО TЗ_dep_tasks.department_code = Отделы.Код
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудник
    |		ПО (Сотрудник.Должность = Должности.Ссылка)
    |			И (Сотрудник.Отдел = Отделы.Ссылка)
    |
    |СГРУППИРОВАТЬ ПО
    |	Должности.Ссылка,
    |	ТемыАкадемии.Ссылка,
    |	Отделы.Ссылка";
    
    Запрос.УстановитьПараметр("_ТЗ", ТЗ);
    Результат = Запрос.Выполнить().Выгрузить();
        
    Набор = РегистрыСведений.АкадемияДолжностьЗакрепленныйМатериал.СоздатьНаборЗаписей();
    Набор.Загрузить(Результат);
    Набор.Записать();

КонецПроцедуры

