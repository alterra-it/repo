
Процедура Импорт() Экспорт
    вн = ТекущаяДата();
    
    ТекДата = ТекущаяДата();
    url = ПолучитьUrl(ТекДата);    
    АдресДокJSON = ИмпортДанных(url);
    Если АдресДокJSON = null Тогда
        Сообщить("Ошибка чтения данных с сервера " + url);
        Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
    
	ВыборкаТема = Справочники.ТемыАкадемии.ВыбратьИерархически();
	Пока ВыборкаТема.Следующий() Цикл
		ОбъектСправочника = ВыборкаТема.ПолучитьОбъект();
		ОбъектСправочника.Удалить();
	КонецЦикла;
	
	ВыборкаТест = Справочники.ТестыАкадемии.Выбрать();
	Пока ВыборкаТест.Следующий() Цикл
		ОбъектСправочника = ВыборкаТест.ПолучитьОбъект();
		ОбъектСправочника.Удалить();
	КонецЦикла; 

    РегистрыСведений.АкадемияИзучение.СоздатьНаборЗаписей().Записать();
    РегистрыСведений.АкадемияТестирование.СоздатьНаборЗаписей().Записать();
    РегистрыСведений.АкадемияДолжностьЗакрепленныйМатериал.СоздатьНаборЗаписей().Записать();

    ЗаполнитьИерархическийСправочникТем(АдресДокJSON, "study_material");
    ЗаполнениеДолжностьТема(ПрочитатьТзИзФайла(АдресДокJSON, "dep_tasks"));
    ЗаполнениеИзучения(ПрочитатьТзИзФайла(АдресДокJSON, "studied"));
	ЗаполнитьТестирования(ПрочитатьТзИзФайла(АдресДокJSON, "test"));
	
	УстановитьПривилегированныйРежим(Ложь);
    
    вв = Число(Формат(УниверсальноеВремя(ТекущаяДата()) - Дата('19700101'), "ЧГ=0") - Формат(УниверсальноеВремя(вн) - Дата('19700101'), "ЧГ=0"));
    мин = Цел(вв/60);
    сек = вв - мин * 60;
    Сообщить("Время выполнения: " + мин + " мин. " + сек + " сек.");
КонецПроцедуры

Функция ИмпортДанных(url)
    метка = СтрНайти(url , "/api/");
    Домен = Прав(Лев(url, метка-1), метка - 1 - СтрДлина("https://"));
    Путь = Прав(url, СтрДлина(url)-метка+1);
    Соединение = Новый HTTPСоединение(Домен, 443 ,,,,, Новый ЗащищенноеСоединениеOpenSSL());  
    Запрос = Новый HTTPЗапрос(Путь);
    Результат = Соединение.Получить(Запрос);
    Если (Результат.КодСостояния <> 200) Тогда
        Возврат null; 
    КонецЕсли;
    ТекстJSON = Результат.ПолучитьТелоКакСтроку();
    АдресДокJSON = ПоместитьВоВременноеХранилище(ТекстJSON, Новый УникальныйИдентификатор());
    Возврат АдресДокJSON;
КонецФункции

