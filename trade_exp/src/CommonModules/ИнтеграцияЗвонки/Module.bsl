#Область Звонки

Функция FlashCall(phone, action, service = "") Экспорт 
	
	УстановитьПривилегированныйРежим(Истина); 
	
	НастройкиЗапроса = ПолучитьНастройкиЗапроса(action, service);
	
	КодПодтверждения = zvonok_FlashCall(phone, НастройкиЗапроса);
	Возврат КодПодтверждения;
	
КонецФункции

#КонецОбласти  

#Область zvonok

Функция zvonok_FlashCall(phone, НастройкиЗапроса)
	
	Если НастройкиЗапроса.Сервис <> "zvonok" Тогда
		Возврат "";
	КонецЕсли; 
	
	КодПодтверждения = "";  
	
	НомерТелефона = phone;
	Если Лев(НомерТелефона, 2) <> "+7" Тогда
		НомерТелефона = "+7" + НомерТелефона;
	КонецЕсли;
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url 		= НастройкиЗапроса.url;
	ПараметрыRest.Метод 	= НастройкиЗапроса.Метод;
	ПараметрыRest.ТипМетода = НастройкиЗапроса.ТипМетода;      
	
	ПараметрыRest.Параметры = Новый Массив;                                                                                                     
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "phone", 		ИнтеграцияREST.ПараметрRest(НомерТелефона)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "public_key", 	ИнтеграцияREST.ПараметрRest(НастройкиЗапроса.apiKey)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "campaign_id",	ИнтеграцияREST.ПараметрRest(НастройкиЗапроса.Операция)));
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest); 
	
	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("status") 
			И RestЗапрос.ОтветСтруктура.status = "ok"
			И RestЗапрос.ОтветСтруктура.Свойство("data") 
			И ТипЗнч(RestЗапрос.ОтветСтруктура.data) = Тип("Структура") 
			И RestЗапрос.ОтветСтруктура.data.Свойство("pincode")  Тогда 
				КодПодтверждения = RestЗапрос.ОтветСтруктура.data.pincode;
		КонецЕсли;
	КонецЕсли;
	
	Возврат КодПодтверждения;	
	
КонецФункции

#КонецОбласти 

#Область Настройки  

Функция ПолучитьНастройкиЗапроса(Действие, Сервис = "", Запрос = "Flash Call") Экспорт

	УстановитьПривилегированныйРежим(Истина); 
	
	НастройкиЗапроса = НастройкиЗапроса();

	ДополнительнаяОбработка = ПолучитьОбработку();
	Если Не ДополнительнаяОбработка.Пустая() Тогда

		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда  
			
			// Определение сервиса
			Если НастройкиХранилища.Свойство("НастройкаЗвонки") Тогда
				
				НастройкаЗвонки = НастройкиХранилища.НастройкаЗвонки;
				
				Если ЗначениеЗаполнено(Сервис) Тогда
					Отбор = Новый Структура("Сервис", Сервис);
				Иначе       
					Отбор = Новый Структура("Активность", Истина);
				КонецЕсли;
				
				НайденныеСервисы = НастройкаЗвонки.НайтиСтроки(Отбор);              
				Если НайденныеСервисы.Количество() > 0 Тогда  
					
					НайденныйСервис = НайденныеСервисы[0];
					ЗаполнитьЗначенияСвойств(НастройкиЗапроса, НайденныйСервис);  
					
					// Запрос
					НастройкаЗапросы = НастройкиХранилища.НастройкаЗапросы;
					НайденныеЗапросы = НастройкаЗапросы.НайтиСтроки(Новый Структура("Сервис, Запрос", НайденныйСервис.Сервис, Запрос));
					
					Если НайденныеЗапросы.Количество() > 0 Тогда
						ЗаполнитьЗначенияСвойств(НастройкиЗапроса, НайденныеЗапросы[0]);
					КонецЕсли;
					
					// Идентификатор действия
					НастройкаОперацииСервисы = НастройкиХранилища.НастройкаОперацииСервисы;
					НастройкаОперацииСервисы = НастройкаОперацииСервисы.НайтиСтроки(Новый Структура("Сервис, Имя", НайденныйСервис.Сервис, Действие));
					
					Если НастройкаОперацииСервисы.Количество() > 0 Тогда
						НастройкиЗапроса.Операция = НастройкаОперацииСервисы[0].Идентификатор;
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли;  
		КонецЕсли;    
	КонецЕсли;
	 
	Возврат НастройкиЗапроса;
	
КонецФункции    

Функция ПолучитьТекстСмс(Действие) Экспорт 
	
	УстановитьПривилегированныйРежим(Истина); 

	ТекстСмс = "";
	
	ДополнительнаяОбработка = ПолучитьОбработку();
	Если Не ДополнительнаяОбработка.Пустая() Тогда

		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда 
			
			НастройкаОперации = НастройкиХранилища.НастройкаОперации;
			НастройкаОперации = НастройкаОперации.НайтиСтроки(Новый Структура("Имя", Действие));
			
			Если НастройкаОперации.Количество() > 0 Тогда
				ТекстСмс = НастройкаОперации[0].ТекстСмс;
			КонецЕсли;
			
		КонецЕсли;    
	КонецЕсли;
	 
	Возврат ТекстСмс;
	
КонецФункции

Функция ПолучитьОбработку()
	
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", "ИнтеграцияЗвонки.epf");			
	Возврат ДополнительнаяОбработка;
	
КонецФункции 

#КонецОбласти 

#Область Параметры

Функция НастройкиЗапроса() 
	
	Параметры = Новый Структура;
	Параметры.Вставить("Сервис", 			"");
	Параметры.Вставить("url", 				"");
	Параметры.Вставить("apiKey", 			"");
	Параметры.Вставить("Запрос", 			"");
	Параметры.Вставить("ТипМетода", 		"");
	Параметры.Вставить("Метод", 			"");
	Параметры.Вставить("Операция", 			"");
	Параметры.Вставить("ОжиданиеПоВремени",  0);
	Параметры.Вставить("ИнтервалОповещения", 0);
	Возврат Параметры;
		
КонецФункции

#КонецОбласти
