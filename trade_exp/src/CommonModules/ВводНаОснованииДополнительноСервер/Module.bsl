
Процедура ЗаполнитьДокументПорчиНаОснованииДокументаПоступления(ПараметрКоманды,ДанныеФормы) экспорт
	ДокументПорчи=ДанныеФормыВЗначение(ДанныеФормы,тип("ДокументОбъект.ПорчаТоваров"));
	ЗаполнитьЗначенияСвойств(Документпорчи,ПараметрКоманды);
	ДокументПорчи.ДокументОснование=ПараметрКоманды;
	ДокументПорчи.ИсточникИнформацииОЦенахДляПечати=Перечисления.ИсточникиИнформацииОЦенахДляПечати.ПоВидуЦен;
	ДокументПорчи.Товары.Загрузить(ПараметрКоманды.Товары.Выгрузить(,"Номенклатура,Характеристика,Количество"));
	ЗначениеВДанныеФормы(ДокументПорчи,данныеФормы);
Конецпроцедуры 

Процедура ЗаполнитьДокументЛистСогласованияНаОснованииДокументаПоступления(ПараметрКоманды,ДанныеФормы) экспорт
	Документы.ЛистСогласования.ЗаполнитьДанныеПоОснованию(ПараметрКоманды, ДанныеФормы);
Конецпроцедуры 

Процедура ЗаполнитьДокументПередачиНаОснованииДокументаПоступления(ПараметрКоманды,ДанныеФормы) экспорт
	
	ДокументОснование= ПараметрКоманды;
	ДанныеФормы.ДокументОснования= ПараметрКоманды;

	// Заполним данные шапки документа.
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	ДанныеДокумента.Организация КАК Организация,
	|	ДанныеДокумента.Склад КАК Склад,
	|	ДанныеДокумента.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	ДанныеДокумента.БанковскийСчетОрганизации КАК БанковскийСчетОрганизации
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка = &Ссылка
	|");
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ДанныеЗаполнения = Новый Структура;
		Для Каждого Колонка Из РезультатЗапроса.Колонки Цикл
			ДанныеЗаполнения.Вставить(Колонка.Имя);
		КонецЦикла;
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(ДанныеЗаполнения, Выборка);
		
		ДанныеФормы.ДатаПлатежа = ТекущаяДатаСеанса();
		ДанныеФормы.Организация = ДанныеЗаполнения.Организация;
		
	КонецЕсли;
	
	// Заполним данные табличной части "Товары" документа.
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	ТаблицаТовары.Номенклатура КАК Номенклатура,
	                      |	ТаблицаТовары.Характеристика КАК Характеристика,
	                      |	ТаблицаТовары.Упаковка КАК Упаковка,
	                      |	ТаблицаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	                      |	ТаблицаТовары.Количество КАК Количество,
	                      |	ТаблицаТовары.Назначение КАК Назначение
	                      |ИЗ
	                      |	Документ.ПриобретениеТоваровУслуг.Товары КАК ТаблицаТовары
	                      |ГДЕ
	                      |	ТаблицаТовары.Ссылка = &Ссылка");
	Запрос.УстановитьПараметр("Ссылка", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		
		ДанныеФормы.Товары.Загрузить(РезультатЗапроса.Выгрузить());
		ЗаполнитьРеквизитыПоУмолчаниюВТабличнойЧасти(ДанныеФормы);
		
	КонецЕсли;
	
Конецпроцедуры 

Процедура ЗаполнитьДокументЗаказНаДоставкуОтПоставщикаНаОснованииДокументаПоступления(ПараметрКоманды,ДанныеФормы) экспорт
	Документы.ЗаказНаДоставкуОтПоставщика.ЗаполнитьДанныеПоОснованию(ПараметрКоманды, ДанныеФормы);
Конецпроцедуры 

Процедура ЗаполнитьДокументВнутреннееПотреблениеТоваровНаОснованииДокументаПоступления(ПараметрКоманды,ДанныеФормы) экспорт
	ДанныеЗаполнения= ПараметрКоманды;
    ДанныеФормы.ДокументОснование= ПараметрКоманды;

	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ПоступлениеТоваровУслуг.Организация,
		|	ПоступлениеТоваровУслуг.Склад,
		|	НЕ ПоступлениеТоваровУслуг.Проведен 			КАК ЕстьОшибкиПроведен,
		|	ПоступлениеТоваровУслуг.НаправлениеДеятельности КАК НаправлениеДеятельности
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг КАК ПоступлениеТоваровУслуг
		|ГДЕ
		|	ПоступлениеТоваровУслуг.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоступлениеТоваровУслугТовары.Номенклатура,
		|	ПоступлениеТоваровУслугТовары.Характеристика,
		|	ПоступлениеТоваровУслугТовары.Упаковка,
		|	ПоступлениеТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ПоступлениеТоваровУслугТовары.Количество КАК Количество,
		|	ПоступлениеТоваровУслугТовары.Склад КАК Склад,
		|	ПоступлениеТоваровУслугТовары.Серия,
		|	СпрНаправленияДеятельности.Назначение КАК Назначение
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
		|
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаправленияДеятельности КАК СпрНаправленияДеятельности
		|		ПО СпрНаправленияДеятельности.Ссылка = ПоступлениеТоваровУслугТовары.Ссылка.НаправлениеДеятельности
		|
		|ГДЕ
		|	ПоступлениеТоваровУслугТовары.Ссылка = &Ссылка
		|	И ПоступлениеТоваровУслугТовары.Номенклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПоступлениеТоваровУслугСерии.Серия,
		|	ПоступлениеТоваровУслугСерии.Количество,
		|	ПоступлениеТоваровУслугСерии.Номенклатура,
		|	ПоступлениеТоваровУслугСерии.Характеристика,
		|	СпрНаправленияДеятельности.Назначение КАК Назначение
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг.Серии КАК ПоступлениеТоваровУслугСерии
		|
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.НаправленияДеятельности КАК СпрНаправленияДеятельности
		|		ПО СпрНаправленияДеятельности.Ссылка = ПоступлениеТоваровУслугСерии.Ссылка.НаправлениеДеятельности
		|
		|ГДЕ
		|	ПоступлениеТоваровУслугСерии.Ссылка = &Ссылка
		|	И ПоступлениеТоваровУслугСерии.Номенклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар))");
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаРеквизиты = РезультатЗапроса[0].Выбрать();
	Если Не ВыборкаРеквизиты.Следующий() Тогда
		Возврат;
	КонецЕсли;

		
	Если РезультатЗапроса[1].Пустой() Тогда
		ТекстОшибки = НСтр("ru='Поступление не содержит товаров. Ввод на основании невозможен.'");
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ДанныеФормы, ВыборкаРеквизиты);
	
	ТаблицаТовары = РезультатЗапроса[1].Выгрузить();
	ДанныеФормы.Товары.Загрузить(ТаблицаТовары);
	ДанныеФормы.Серии.Загрузить(РезультатЗапроса[2].Выгрузить());
	
	МассивСкладов = ОбщегоНазначенияУТ.УдалитьПовторяющиесяЭлементыМассива(ТаблицаТовары.ВыгрузитьКолонку("Склад"));
	Если МассивСкладов.Количество() = 1 Тогда
		ДанныеФормы.Склад = МассивСкладов[0];
	Иначе
		ТекстОшибки = НСтр("ru='Ввод на основании поступления на разные склады не поддерживается.'");
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
Конецпроцедуры 

Процедура ЗаполнитьРеквизитыПоУмолчаниюВТабличнойЧасти(ДанныеФормы)
	
	Если ДанныеФормы.Товары.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ДанныеФормы.УказыватьНомераГТД Тогда
		Для Каждого СтрТабл из ДанныеФормы.Товары Цикл
			СтрТабл.НомерГТД = Неопределено;
		КонецЦикла;
	КонецЕсли;
		
	КэшированныеЗначения = Неопределено;
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", Новый Структура("НалогообложениеНДС, Дата, Организация", ДанныеФормы.НалогообложениеНДС, ДанныеФормы.Дата, ДанныеФормы.Организация));
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(ДанныеФормы.Товары, СтруктураДействий, КэшированныеЗначения);

	Если Не ЗначениеЗаполнено(ДанныеФормы.ВидЦены) Тогда
		ДанныеФормы.ВидЦены = Справочники.ВидыЦен.ВидЦеныПоУмолчанию(ДанныеФормы.ВидЦены, Новый Структура("ИспользоватьПриПередачеМеждуОрганизациями", Истина));
	КонецЕсли;

	Если ЗначениеЗаполнено(ДанныеФормы.ВидЦены) Тогда
		Реквизиты = Справочники.ВидыЦен.ПолучитьРеквизитыВидаЦены(ДанныеФормы.ВидЦены);
		Если ДанныеФормы.Валюта = Справочники.Валюты.ПустаяСсылка() Тогда
			ДанныеФормы.Валюта = Реквизиты.ВалютаЦены;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ДанныеФормы.ВалютаВзаиморасчетов) Тогда
			ДанныеФормы.ВалютаВзаиморасчетов = Реквизиты.ВалютаЦены;
		КонецЕсли;
		
		ДанныеФормы.ЦенаВключаетНДС = Реквизиты.ЦенаВключаетНДС;
		
		ПараметрыЗаполнения = Новый Структура();
		ПараметрыЗаполнения.Вставить("Дата", ДанныеФормы.Дата);
		ПараметрыЗаполнения.Вставить("Валюта", ДанныеФормы.Валюта);
		ПараметрыЗаполнения.Вставить("ВидЦены", ДанныеФормы.ВидЦены);
		ПараметрыЗаполнения.Вставить("ПоляЗаполнения", "Цена, ВидЦены");
		
		СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(ДанныеФормы);
		
		СтруктураДействий = Новый Структура();
		СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковок");
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
		
		ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(ДанныеФормы.Товары, , ПараметрыЗаполнения, СтруктураДействий);
	КонецЕсли;		
КонецПроцедуры

Процедура ЗаполнитьДокументВозвратТоваровМеждуОрганизациямиНаОснованииДокументаПеремещениеТоваров(ПараметрКоманды,ДанныеФормы) экспорт
	ВозвратТоваровМеждуОрганизациями=ДанныеФормыВЗначение(ДанныеФормы,тип("ДокументОбъект.ВозвратТоваровМеждуОрганизациями"));
	ЗаполнитьЗначенияСвойств(ВозвратТоваровМеждуОрганизациями,ПараметрКоманды);
	ВозвратТоваровМеждуОрганизациями.ХозяйственнаяОперация=Перечисления.ХозяйственныеОперации.ВозвратТоваровМеждуОрганизациями;
	ВозвратТоваровМеждуОрганизациями.ЦенаВключаетНДС=истина;
	ВозвратТоваровМеждуОрганизациями.Склад=ПараметрКоманды.СкладОтправитель;
	если ПараметрКоманды.ПеремещениеНаФилиал тогда
		ВозвратТоваровМеждуОрганизациями.СкладПолучатель=ПараметрКоманды.СкладПолучатель;
	иначе
		ВозвратТоваровМеждуОрганизациями.СкладПолучатель="";
	конецесли;
	ВозвратТоваровМеждуОрганизациями.Товары.Загрузить(ПараметрКоманды.Товары.Выгрузить());
	для каждого стр из ВозвратТоваровМеждуОрганизациями.Товары цикл
		стр.Цена=1;
	конеццикла;	
	
	ЗначениеВДанныеФормы(ВозвратТоваровМеждуОрганизациями,данныеФормы);
	КэшированныеЗначения = Неопределено;
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(ДанныеФормы);
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", Новый Структура("НалогообложениеНДС, Дата, Организация", ДанныеФормы.НалогообложениеНДС, ДанныеФормы.Дата, ДанныеФормы.Организация));
		
		СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковок");
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(данныеФормы.Товары, СтруктураДействий, КэшированныеЗначения);
	
Конецпроцедуры 



