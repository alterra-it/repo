//Возвращает полную структуру данных пользователя. Если нужен только ID, то: Результат.result[0].ID
Функция ПолучитьПользователя(Пользователь = Неопределено, HTTPСоединение=Неопределено) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	Если Пользователь = Неопределено Тогда
		Пользователь = ПользователиИнформационнойБазы.ТекущийПользователь();
		ПользовательОСДомен = Пользователь.ПользовательОС;
	иначеесли типзнч(Пользователь)=тип("СправочникСсылка.Сотрудники") тогда
		Пользователь = ПолучитьСправочникПользовательПоСотруднику(Пользователь);  
		СвойстваПользователя = Пользователи.СвойстваПользователяИБ(Пользователь.ИдентификаторПользователяИБ);
		ПользовательОСДомен = СвойстваПользователя.ПользовательОС;
	иначеесли типзнч(Пользователь)=тип("СправочникСсылка.ФизическиеЛица") тогда
		ПользовательПоФизлицу = ПолучитьПользователяПоФизЛицу(Пользователь);
		Если ПользовательПоФизлицу = Неопределено Тогда
			ОбщегоНазначения.СообщитьПользователю("Физическое лицо """+ Пользователь +"""  не связано с пользователем. Проверьте настройки пользователя ИБ!");
		Иначе	
	    	СвойстваПользователя = Пользователи.СвойстваПользователяИБ(ПользовательПоФизлицу.ИдентификаторПользователяИБ);
			ПользовательОСДомен = СвойстваПользователя.ПользовательОС;
		КонецЕсли;
	иначеесли типзнч(Пользователь)=тип("СправочникСсылка.Пользователи") тогда  
		Если НЕ Пользователь = Справочники.Пользователи.ПустаяСсылка() Тогда
			СвойстваПользователя = Пользователи.СвойстваПользователяИБ(Пользователь.ИдентификаторПользователяИБ);
			ПользовательОСДомен = СвойстваПользователя.ПользовательОС;
		Иначе     
			ПользовательОСДомен = Пользователь.Наименование;	
		КонецЕсли;
	иначеесли типзнч(Пользователь)=тип("Строка") или типзнч(Пользователь)=тип("Число")  тогда
		Возврат Строка(Пользователь);
	КонецЕсли;  
	
	ПользовательОС = СтрЗаменить(ПользовательОСДомен, "\\ALTERRA\", ""); 
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("LOGIN",ПользовательОС);
		
	ПользовательБП = ВыполнитьПроизвольныйЗапросБитрикс24("user.get", ПараметрыЗапроса);
	УстановитьПривилегированныйРежим(Ложь);
    Возврат ПользовательБП;
КонецФункции

Функция ПолучитьСправочникПользовательПоСотруднику(Сотрудник)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Пользователи.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
	|		ПО Сотрудники.Пользователь = Пользователи.Ссылка
	|ГДЕ
	|	Сотрудники.Ссылка = &Сотрудник"; 
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Ссылка;		
	КонецЦикла;
	
КонецФункции

Функция ПолучитьПользователяПоФизЛицу(ФизическоеЛицо)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Пользователи.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.ФизическоеЛицо = &ФизическоеЛицо";
	Запрос.УстановитьПараметр("ФизическоеЛицо",ФизическоеЛицо);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Ссылка;		
	КонецЦикла;
КонецФункции

Функция ПолучитьПользователяПоСотруднику(Сотрудник) Экспорт 
	ПользовательОС = Сотрудник.Наименование;
	Возврат ПолучитьПользователя(ПользовательОС);
КонецФункции

Функция ПолучитьИДПользователя(Пользователь=НЕОПРЕДЕЛЕНО) Экспорт

	ИДОтветственного ="";
	Ответственный = ПолучитьПользователя(Пользователь);
	Если Ответственный.Свойство("КодСостояния") Тогда
		ТекстОшибки = "Получение пользователя | " + ПолучитьРезультатСтрокой(Ответственный);
		ЗаписатьВЖурналРегистрации(ТекстОшибки);
		Возврат "";
	ИначеЕсли Ответственный.Свойство("result") Тогда
		РезультатЗапроса = Ответственный.result;
		Если РезультатЗапроса.Количество() > 0 Тогда
			Стр = РезультатЗапроса[0];
			ИДОтветственного = Стр.ID;
		КонецЕсли;
	КонецЕсли;

	Возврат ИДОтветственного;
КонецФункции

