Процедура ЗаписатьВЖурналРегистрации(ТекстОшибки)
	ЗаписьЖурналаРегистрации("Отправка запроса в Б24", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);
КонецПроцедуры

Функция ПолучитьКодПодразделения(Подразделение)
	КодВозврата = "";
	
	Наименование = Подразделение.Наименование;
	
	Если Наименование = "Центральный офис" тогда 
		КодВозврата = "856";
	КонецЕсли;
	
	Если Наименование = "Филиал Барнаул" тогда 
		КодВозврата = "857";
	КонецЕсли;
	
	Если Наименование = "Филиал Бийск" тогда 
		КодВозврата = "859";
	КонецЕсли;
	
	Если Наименование = "Филиал Выбор" тогда 
		КодВозврата = "858";
	КонецЕсли;
		
	Возврат КодВозврата;
КонецФункции

Функция ФорматироватьДату(Дата)
	ФорматированнаяДата = "";
	ФорматированнаяДата = Строка(Дата);
	
    ФорматированнаяДата = СтрЗаменить(ФорматированнаяДата,".","");
	ФорматированнаяДата = СтрЗаменить(ФорматированнаяДата,":","");
	ФорматированнаяДата = СтрЗаменить(ФорматированнаяДата," ","");

	Возврат ФорматированнаяДата;
КонецФункции

