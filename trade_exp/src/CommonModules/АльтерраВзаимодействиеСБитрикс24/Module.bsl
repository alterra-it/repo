Функция ПолучитьIDСделкиIDПартнера(НаименованиеПартнера) Экспорт 	
	Метод = "crm.deal.list";
	АдресСервера = "bitrix.tg-alterra.ru";
	АдресРесурса = "/rest/1/qf9d1uvmxxhzxgw5/" + Метод + ".json";

	select = Новый Массив;
	select.Добавить("ID");          // ID Сделки    
	select.Добавить("COMPANY_ID"); // ID Партнера    
	
	ПараметрыПоля = Новый Структура;		
	ПараметрыПоля.Вставить("order", Новый Структура("DATE_MODIFY", "DESC")); // Направление сортировки: "ASC", "DESC"     
	ПараметрыПоля.Вставить("filter", Новый Структура("COMPANY_ID, CATEGORY_ID, STAGE_SEMANTIC_ID", ПолучитьИдентификаторыПартнера(НаименованиеПартнера), "0", "P")); 
	ПараметрыПоля.Вставить("select", select);

	Ответ = ВыполнитьПроизвольныйЗапрос(Метод, ПараметрыПоля); 
	
	Если Ответ.Свойство("result") И 
		ТипЗнч(Ответ.result) = Тип("Массив") И 
		ЗначениеЗаполнено(Ответ.result) И 
		ЗначениеЗаполнено(Ответ.result[0].ID) И
		ЗначениеЗаполнено(Ответ.result[0].COMPANY_ID) Тогда
		Возврат Ответ.result[0];	
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Функция ПолучитьИдентификаторыПартнера(НаименованиеПартнера)  	
	Метод = "crm.company.list";
	АдресСервера = "bitrix.tg-alterra.ru";
	АдресРесурса = "/rest/1/qf9d1uvmxxhzxgw5/" + Метод + ".json";
	
	Массив = Новый Массив;
	Массив.Добавить("ID");
	
	ПараметрыПоля = Новый Структура;
	ПараметрыПоля.Вставить("filter", Новый Структура("TITLE", НаименованиеПартнера)); 
	ПараметрыПоля.Вставить("select", Массив);

	Массив = ВыполнитьПроизвольныйЗапрос(Метод, ПараметрыПоля);
	
	Если Массив.Свойство("result") И ТипЗнч(Массив.result) = Тип("Массив") И ЗначениеЗаполнено(Массив.result) Тогда  	
		Массив = Массив.result;
		
		Для Инд = 0 По Массив.Количество() - 1 Цикл
			Массив[Инд] = Массив[Инд].ID;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Массив;
КонецФункции

Функция ОтправитьВЧат(НазваниеЧата, ТекстСообщения) Экспорт                                           
	
	СписокЧатов = ПолучитьЧаты(НазваниеЧата);    
	ТекстНеудачногоПоиска = "Чат " + НазваниеЧата + " не найден. Возможно пользователь ""Alterra24"" отсутствует в списке пользователей чата.";
	
	Если Не СписокЧатов.Свойство("result") Или СписокЧатов.result.Количество() = 0 Тогда
		Сообщить(ТекстНеудачногоПоиска);
		Возврат Неопределено;	
	КонецЕсли;    
	
    НайденныйЧат = Неопределено;
	Для Каждого Элемент Из СписокЧатов.result Цикл
		Если Элемент.name = НазваниеЧата Тогда
			НайденныйЧат = Элемент.id;   
			Прервать;
		КонецЕсли;
	КонецЦикла;

	Если НайденныйЧат <> Неопределено Тогда
		IDЧата = "chat" +  Формат(НайденныйЧат, "ЧГ=");
		ПараметрыЗапроса = Новый Структура; 
		ПараметрыЗапроса.Вставить("DIALOG_ID", IDЧата); 
		ПараметрыЗапроса.Вставить("MESSAGE", ТекстСообщения);  
					  
		Результат = ВыполнитьПроизвольныйЗапрос("im.message.add", ПараметрыЗапроса);  
		Возврат Результат;    
	Иначе
		Сообщить(ТекстНеудачногоПоиска); 
		Возврат Неопределено;	
	КонецЕсли;
КонецФункции   

