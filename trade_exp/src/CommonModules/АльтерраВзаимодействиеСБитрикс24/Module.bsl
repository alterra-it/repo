//СтрИД получается в формате: user_345, где 345 - ид пользователя в битриксе, user_ - префикс
Функция ПолучитьПользователяПоИд(СтрИд) Экспорт
	Пользователь = Неопределено;
	Ид = Прав(СтрИд, СтрДлина(СтрИд)-5);

	НазванияПолей = Новый Структура;
	НазванияПолей.Вставить("LAST_NAME");
	НазванияПолей.Вставить("NAME");
	НазванияПолей.Вставить("SECOND_NAME");
	
	ДанныеПользователя = ПолучитьЗначениеПоляСущностиПоID("user", Ид, НазванияПолей);
	ФИОПользователя = ДанныеПользователя["LAST_NAME"] + " " + ДанныеПользователя["NAME"] + " " + ДанныеПользователя["SECOND_NAME"];
	Пользователь = НайтиПользователей1СПоНаименованию(ФИОПользователя);
	Если Пользователь.Количество()>0 Тогда
		Пользователь = Пользователь[0];
	Иначе
		Пользователь = Неопределено;
	КонецЕсли;
	
	Возврат Пользователь;
КонецФункции

Функция НайтиПользователей1СПоНаименованию(ФИОПользователей)  Экспорт
	МассивФИОПользователей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ФИОПользователей, ",",,Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Пользователи.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.ПометкаУдаления = ЛОЖЬ
		|	И Пользователи.ФизическоеЛицо = ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
		|	И Пользователи.Наименование В(&Наименования)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Пользователи.Ссылка
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.ПометкаУдаления = ЛОЖЬ
		|	И Пользователи.ФизическоеЛицо.Наименование В(&Наименования)";
	
	Запрос.УстановитьПараметр("Наименования", МассивФИОПользователей);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	МассивПользователей = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		МассивПользователей.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	Возврат МассивПользователей;
КонецФункции

Процедура ЗаписатьРезультатВФайл(ТекстСтрока,ТекстФайл)
	
	ПутьФайла = "\\TG-Storage01\Alterra - общая\Харина М.А\тест";
	ТекстЗаписиВСтроке = "";
	ТекстЗаписиВФайле = "";
	
	Если Не ПустаяСтрока(ТекстФайл) Тогда
	Попытка
		ФайлПолученный = Новый ЧтениеТекста(ТекстФайл);
		ТекстЗаписиВФайле = ФайлПолученный.Прочитать();
		ФайлПолученный.Закрыть();
	Исключение
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Чтение файла'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки
	КонецЕсли;
	
	Если Не ПустаяСтрока(ТекстСтрока) Тогда
		ТекстЗаписиВСтроке = ТекстСтрока;
	КонецЕсли;
	
	Если (Не ПустаяСтрока(ТекстЗаписиВСтроке) ИЛИ Не ПустаяСтрока(ТекстЗаписиВФайле)) И Не ПустаяСтрока(ПутьФайла) Тогда
		Попытка	
			ЗначениеТекущегоПользователя = ПараметрыСеанса.ТекущийПользователь.Наименование;
			Файл = Новый ЗаписьТекста(ПутьФайла+Строка(Формат(ТекущаяДата(), "ДФ=""дд ММММ гггг 'г.' ЧЧ мм сс"""))+" ("+ЗначениеТекущегоПользователя+")"+".txt");
			Файл.ЗаписатьСтроку("Запрос:");
			Файл.ЗаписатьСтроку(ТекстЗаписиВСтроке);
			Файл.ЗаписатьСтроку("Ответ:");
			Файл.ЗаписатьСтроку(ТекстЗаписиВФайле);
			Файл.Закрыть();
		Исключение
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Запись в Файл (строки или файла)'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки
	КонецЕсли;
КонецПроцедуры
