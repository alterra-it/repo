//	 Тело.Вставить("ТекстДляЖивойЛенты", "Основной текст поста");
//	 Тело.Вставить("ПолучательСообщения", "Группа 'Коммерческие вопросы'");
//	 Тело.Вставить("ВажноеСообщение", Истина);
//	 Тело.Вставить("МассивФайлов", МассивФайлов); 
//	 АльтерраВзаимодействиеСБитрикс24.ВыполнитьЗапросУниверсальный("4008", "log.blogpost.add", "", Тело); - Сообщение в ленту
Функция ВыполнитьЗапросУниверсальный(idПользователя, Метод, Сотрудник = "", ТелоСообщения, IDЗадачи = "") Экспорт
	
	Результат = Новый Структура;
    Результат.Вставить("ОписаниеОшибки", ""); 
	Результат.Вставить("Данные", Неопределено);
    
    Попытка
        ХранилищеСсылка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Настройки хранилища"); 
        Хранилище = ХранилищеСсылка.ХранилищеНастроек.Получить();
        
        Если Хранилище = Неопределено Тогда
            Результат.ОписаниеОшибки = "Хранилище не найдено";
            Возврат Результат;
        КонецЕсли;
		
		Отбор = Новый Структура("idПользователя, Метод");
		Отбор.idПользователя = idПользователя;
		Отбор.Метод = Метод;
		НастройкиВебхука = Хранилище.НастройкиВебхуковБотов.ТаблицаЗначений;
		
		ВебхукХранилище = НастройкиВебхука.НайтиСтроки(Отбор);
		
		Если ВебхукХранилище.Количество() = 0 Тогда
			Результат.ОписаниеОшибки = "Указан неверный idПользователя или метод в хранилище";
			Возврат Результат;
		КонецЕсли;
	
		idПользователя = ВебхукХранилище[0].idПользователя;
        АдресСервера = ВебхукХранилище[0].АдресСервера;
        Вебхук = ВебхукХранилище[0].Вебхук;
        Метод = ВебхукХранилище[0].Метод; 
		
		Если ВРег(Метод) = "IM.MESSAGE.ADD" Тогда
	
			ПолучательСообщения = ПолучитьПользователя(Сотрудник);
	        IDПолучателя = ПолучательСообщения.result[0].ID;
			
			МетодAPI = "im.message.add";
	        ПараметрыЗапроса = Новый Структура;
	        ПараметрыЗапроса.Вставить("DIALOG_ID", IDПолучателя);
	        ПараметрыЗапроса.Вставить("MESSAGE", Строка(ТелоСообщения));
		
		ИначеЕсли ВРег(Метод) = "TASK.COMMENTITEM.ADD" Тогда 
		
	        Если Не ЗначениеЗаполнено(IDЗадачи) Тогда
	            Результат.ОписаниеОшибки = "ID задачи обязателен для метода отправки в задачи";
	            Возврат Результат;
			КонецЕсли;
			
			
	        МетодAPI = "task.commentitem.add";
	        ПараметрыЗапроса = Новый Структура;
	        ПараметрыЗапроса.Вставить("ID", IDЗадачи);
	        
	        ПараметрыКомментария = Новый Структура;
	        ПараметрыКомментария.Вставить("POST_MESSAGE", Строка(ТелоСообщения));
	        ПараметрыЗапроса.Вставить("FIELDS", ПараметрыКомментария); 
			
		ИначеЕсли ВРег(Метод) = "LOG.BLOGPOST.ADD" Тогда
	    
	        Если ТипЗнч(ТелоСообщения) <> Тип("Структура") Тогда
	            Результат.ОписаниеОшибки = "Для метода log.blogpost.add необходимо передать структуру параметров";
	            Возврат Результат;
	        КонецЕсли;
	        
	        Если Не ТелоСообщения.Свойство("ТекстЗаголовок") ИЛи Не ТелоСообщения.Свойство("ТекстДляЖивойЛенты") ИЛи Не ТелоСообщения.Свойство("ПолучательСообщения") Тогда
	            Результат.ОписаниеОшибки = "В структуре должны быть ТекстЗаголовок, ТекстДляЖивойЛенты и ПолучательСообщения";
	            Возврат Результат;
	        КонецЕсли;
	        
	        МетодAPI = "log.blogpost.add";
	        ПараметрыЗапроса = Новый Структура;
	        ПараметрыЗапроса.Вставить("POST_TITLE", ТелоСообщения.ТекстЗаголовок);
	        ПараметрыЗапроса.Вставить("POST_MESSAGE", ТелоСообщения.ТекстДляЖивойЛенты);
	        
	        Если ТелоСообщения.Свойство("МассивФайлов") И ТелоСообщения.МассивФайлов <> Неопределено Тогда
	            ПараметрыЗапроса.Вставить("FILES", ТелоСообщения.МассивФайлов);
	        КонецЕсли;
	        
	        Получатель = ТелоСообщения.ПолучательСообщения;
	        Если Получатель = "Группа 'Коммерческие вопросы'" Тогда
	            ПараметрыЗапроса.Вставить("DEST", Новый Структура("SG", "SG46"));
	        ИначеЕсли Получатель = "Группа 'Руководители подразделений'" Тогда
	            ПараметрыЗапроса.Вставить("DEST", Новый Структура("SG", "SG59"));
	        ИначеЕсли Получатель = "Группа 'Руководители'" Тогда
	            ПараметрыЗапроса.Вставить("DEST", Новый Структура("SG", "SG171"));
	        Иначе
	            Результат.ОписаниеОшибки = "Не найден получатель сообщения: " + Получатель;
	            Возврат Результат;
	        КонецЕсли;
	        
	        Если ТелоСообщения.Свойство("ВажноеСообщение") И ТелоСообщения.ВажноеСообщение Тогда
	            ПараметрыЗапроса.Вставить("IMPORTANT", "Y");
	        КонецЕсли;
			
			ПараметрыЗапроса.Вставить("USER_ID", idПользователя);	 
		Иначе
	        Результат.ОписаниеОшибки = "Неизвестный метод: " + Метод;
	        Возврат Результат;
		КонецЕсли;
		
	    ДанныеРезультата = ВыполнитьЗапросСВебхуком(АдресСервера, idПользователя, Вебхук, МетодAPI, ПараметрыЗапроса);
		
		Если ДанныеРезультата <> Неопределено Тогда
	        Результат.Данные = ДанныеРезультата;
	    Иначе
	        Результат.ОписаниеОшибки = "Запрос выполнен, но результат не получен";
	    КонецЕсли;
		
		Возврат Результат
		
	Исключение
	    Результат.ОписаниеОшибки = Результат.ОписаниеОшибки + ОписаниеОшибки();
	    Возврат Результат;
	КонецПопытки;
	
КонецФункции	

Функция ВыполнитьЗапросСВебхуком(АдресСервера, idПользователя, Вебхук, Метод, ПараметрыМетода) Экспорт
    
    Попытка
        АдресРесурса = "/rest/" + idПользователя + "/" + Вебхук + "/" + Метод + ".json";
        
        HTTPСоединение = Новый HTTPСоединение(АдресСервера, 443, , , ПолучениеФайловИзИнтернетаКлиентСервер.ПолучитьПрокси("http"), , Новый ЗащищенноеСоединениеOpenSSL);
        
        Заголовки = Новый Соответствие;
        Заголовки.Вставить("Accept-Language", "ru");
        Заголовки.Вставить("Accept-Charset", "utf-8");
        Заголовки.Вставить("Content-Language", "ru");
        Заголовки.Вставить("Content-Charset", "utf-8");
        Заголовки.Вставить("Content-type", "application/json");
        
        HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
        ПараметрыJSON = СериализоватьВJSON(ПараметрыМетода);
        HTTPЗапрос.УстановитьТелоИзСтроки(ПараметрыJSON);
        
        HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
        ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
        
        Если Метод = "task.commentitem.add" Тогда
            Ответ = ДесериализоватьИзJSONВСоответсвие(ТелоОтвета);
        Иначе
            Ответ = ДесериализоватьИзJSON(ТелоОтвета);
        КонецЕсли;
        
        Если HTTPОтвет.КодСостояния = 200 Тогда
            Возврат Ответ;
        Иначе
            Ошибка = Новый Структура;
            Ошибка.Вставить("КодСостояния", HTTPОтвет.КодСостояния);
            ЭтоСоответствие = ТипЗнч(Ответ) = Тип("Соответствие");
            НазваниеОшибки = ?(ЭтоСоответствие, Ответ["error"], Ответ.error);
            ОписаниеОшибки = ?(ЭтоСоответствие, Ответ["error_description"], Ответ.error_description);
            Ошибка.Вставить("НазваниеОшибки", НазваниеОшибки);
            Ошибка.Вставить("ОписаниеОшибки", ОписаниеОшибки);
            Возврат Ошибка;
        КонецЕсли;
        
    Исключение
        Сообщить("Ошибка выполнения запроса: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции



#Область ЗагрузкаФайлов

// Загружает несколько файлов в Б24 в указанную папку
//
// Параметры:
//  ИдПапки  - Строка - ИД папки для файлов в Б24 (указывать в справочнике настроек - Альтерра_НастройкиОбменаБитрикс, рек.ИдПапкиСФайлами)
//
//  МассивФайлов  - Массив - массив с файлами
//
//  Пользователь  - СправочникСсылка.Пользователи - автор записи
//  
//  КодЭлементаПроцесса  - Строка - гуид объекта-владельца строкой
//  
// Возвращаемое значение:
//   Массив   - структура с ИД загруженных файлов
//
Функция ЗагрузитьФайлыВБитрикс(ИдПапки, МассивФайлов, Пользователь, КодЭлементаПроцесса) Экспорт

	МассивИДФайлов = Новый Структура();
	НомерФайла = 0;
	Для НомерФайла=0 по МассивФайлов.Количество()-1 Цикл
		ИдФайла = ЗагрузитьФайлНаСервере(ИдПапки, МассивФайлов[НомерФайла], Пользователь, КодЭлементаПроцесса);
		Если ЗначениеЗаполнено(ИдФайла) Тогда
			Ид = СтрЗаменить(Строка(ИдФайла.result.ID),Символы.НПП,"");;
			МассивИдФайлов.Вставить("n"+Строка(НомерФайла+1),"n"+Ид);
		КонецЕсли;
	КонецЦикла;
	Возврат МассивИДФайлов;

КонецФункции

//загрузка одного файла
Функция ЗагрузитьФайлНаСервере(ИдПапки, Файл, Пользователь, КодЭлементаПроцесса) Экспорт
	
	СтруктураФайла = РаботаСФайлами.ДанныеФайла(Файл);
	ЗнФайла = ПолучитьИзВременногоХранилища(СтруктураФайла.СсылкаНаДвоичныеДАнныеФайла);

	Бэйз64Строка = Base64Строка(ЗнФайла);
    Бэйз64Строка = СтрЗаменить(Бэйз64Строка, Символы.ВК, "");
    Бэйз64Строка = СтрЗаменить(Бэйз64Строка, Символы.ПС, "");

	ПараметрыЗапроса = Новый Структура; 
    ПараметрыЗапроса.Вставить("id",ИдПапки);
   	ПараметрыЗапроса.Вставить("data",Новый Структура("NAME,CREATED_BY,UPDATED_BY",Файл.Наименование + "_"+Строка(КодЭлементаПроцесса)+"."+Строка(Файл.Расширение),Пользователь,Пользователь));
    ПараметрыЗапроса.Вставить("fileContent",Бэйз64Строка);
    
    Возврат ВыполнитьПроизвольныйЗапрос("disk.folder.uploadfile", ПараметрыЗапроса);
КонецФункции

