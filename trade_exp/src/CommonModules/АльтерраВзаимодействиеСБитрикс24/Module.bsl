Функция СоздатьБП(ПараметрыМетода) Экспорт
	Сотрудник = ПолучитьИДПользователя(ПараметрыМетода.Пользователь);
	Клиент = ПараметрыМетода.Партнер;
		
    ТекущаяДата = ФорматироватьДату(ТекущаяДата());
	
	КодЭлементаПроцесса = Строка(Клиент.Код)+"_"+ТекущаяДата;

	ДатаНачалаАктивности = Строка(ТекущаяДата());
	
	СтруктураД  = Новый Структура();
	
	СтруктураД.Вставить("NAME", ПараметрыМетода.ТекстЗаголовка);
	
	СтруктураД.Вставить("PROPERTY_354", "863");
	СтруктураД.Вставить("PROPERTY_342", ПолучитьКодПодразделения(ПараметрыМетода.Пользователь.Подразделение));
	СтруктураД.Вставить("PROPERTY_343", "1526");
	СтруктураД.Вставить("PROPERTY_345", Сотрудник);
	СтруктураД.Вставить("PROPERTY_710", "1174");

	СтруктураД.Вставить("DETAIL_TEXT", ПараметрыМетода.Описание);
	СтруктураД.Вставить("DETAIL_TEXT_TYPE", "text");
	СтруктураД.Вставить("ACTIVE_FROM", ДатаНачалаАктивности);
	
	РезультатОтправки = ДобавитьНовыйЭлементСпискаРабочейГруппы(КодЭлементаПроцесса,СтруктураД); 
 КонецФункции

Функция ДобавитьНовыйЭлементСпискаРабочейГруппы(КодЭлементаПроцесса, СтруктураПараметров, ВернутьСтрокойJSON=Ложь) Экспорт  
	
    ПараметрыЗапроса = Новый Структура; 
	ПараметрыЗапроса.Вставить("IBLOCK_TYPE_ID","lists_socnet");
	ПараметрыЗапроса.Вставить("IBLOCK_ID","89");
	ПараметрыЗапроса.Вставить("ELEMENT_CODE",КодЭлементаПроцесса);
	ПараметрыЗапроса.Вставить("FIELDS",СтруктураПараметров);
    
    Возврат ВыполнитьПроизвольныйЗапрос("lists.element.add", ПараметрыЗапроса, ВернутьСтрокойJSON);
    
КонецФункции

Функция ДобавитьНовыйЭлементСписка(ИДТипаБлока, ИДБлока, КодЭлементаПроцесса, СтруктураПараметров, ВернутьСтрокойJSON=Ложь) Экспорт
	
	ПараметрыЗапроса = Новый Структура; 
	ПараметрыЗапроса.Вставить("IBLOCK_TYPE_ID", ИДТипаБлока);
	ПараметрыЗапроса.Вставить("IBLOCK_ID", ИДБлока);
	ПараметрыЗапроса.Вставить("ELEMENT_CODE", КодЭлементаПроцесса);
	ПараметрыЗапроса.Вставить("FIELDS", СтруктураПараметров);
	
	Возврат ВыполнитьПроизвольныйЗапрос("lists.element.add", ПараметрыЗапроса, ВернутьСтрокойJSON);

КонецФункции  

функция ИзменитьЭлементСписка(ИДТипаБлока, ИДБлока, КодЭлементаПроцесса, СтруктураПараметров, ВернутьСтрокойJSON = Ложь)   Экспорт
	
    ПараметрыЗапроса = Новый Структура; 
	ПараметрыЗапроса.Вставить("IBLOCK_TYPE_ID", ИДТипаБлока);
	ПараметрыЗапроса.Вставить("IBLOCK_ID", ИДБлока);
	ПараметрыЗапроса.Вставить("ELEMENT_CODE", КодЭлементаПроцесса);
	ПараметрыЗапроса.Вставить("FIELDS", СтруктураПараметров);
	
	Возврат АльтерраВзаимодействиеСБитрикс24.ВыполнитьПроизвольныйЗапрос("lists.element.update", ПараметрыЗапроса, ВернутьСтрокойJSON);

КонецФункции    

Функция ДобавитьНовоеСобытиеКалендаря (СтруктураПараметров, ВернутьСтрокойJSON=Ложь) Экспорт
	
	ПараметрыЗапроса = Новый Структура; 
	ПараметрыЗапроса.Вставить("type", СтруктураПараметров.ТипКалендаря);
	ПараметрыЗапроса.Вставить("ownerId",СтруктураПараметров.ИДВладельцаКалендаря);                            
	ПараметрыЗапроса.Вставить("from", СтруктураПараметров.ДатаНачала);
	ПараметрыЗапроса.Вставить("to", СтруктураПараметров.ДатаОкончания);
	ПараметрыЗапроса.Вставить("section",СтруктураПараметров.ИДКалендаря );
    ПараметрыЗапроса.Вставить("name",СтруктураПараметров.НазваниеСобытия);
	ПараметрыЗапроса.Вставить("description", СтруктураПараметров.ОписаниеСобытия);
	ПараметрыЗапроса.Вставить("is_meeting",СтруктураПараметров.ПризнакВстречиСУчастниками );
	
	СтруктураНапоминания = Новый Структура("type,count","min",15 );
	ПараметрыЗапроса.Вставить("remind",СтруктураНапоминания);
	
	Если СтруктураПараметров.ПризнакВстречиСУчастниками = "Y" Тогда
			ПараметрыЗапроса.Вставить("attendees",СтруктураПараметров.СписокУчастников);
	КонецЕсли;

	Возврат АльтерраВзаимодействиеСБитрикс24.ВыполнитьПроизвольныйЗапрос("calendar.event.add", ПараметрыЗапроса, ВернутьСтрокойJSON);
	
КонецФункции  

