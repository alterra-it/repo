#Область ЗапросВБ24

//"Стучится" в Б24. 
//
// Параметры:
// НазваниеМетода  - Строка - точные названия методов и их параметров 
//                 можно посмотреть тут: https://dev.1c-bitrix.ru/rest_help/index.php
//  ПараметрыМетода  - Структура - заголовки должны точно соответствовать существующим. 
//                 Их можно получить, также обратившись соответствующим запросом в Б24. 
//					Если одно из значений параметров метода - массив, его следует представить также структурой.
// ВернутьСтрокой - Булево - вернуть результат строкой или структурой
//
// Возвращаемое значение:
//   Структура, строка   - в зависимости от параметра. В случае ошибки возвращает структурой со свойством Error
//
Функция ВыполнитьПроизвольныйЗапрос(НазваниеМетода, ПараметрыМетода, ВернутьСтрокой=Ложь, HTTPСоединение=Неопределено, ВернутьТелоОтвета = Ложь) Экспорт
		
	Попытка
	
		ПараметрыЗапроса = СериализоватьВJSON(ПараметрыМетода);
		РезультатЗапроса = ВыполнитьЗапрос(НазваниеМетода, ПараметрыЗапроса, HTTPСоединение, ВернутьТелоОтвета);
		
		Если ВернутьСтрокой Тогда
			Возврат ПолучитьРезультатСтрокой(РезультатЗапроса);
		Иначе
			Возврат РезультатЗапроса;
		КонецЕсли;
	
	Исключение
		Сообщить("Сообщение в Битрикс24 не отправлено. Сервер системы Битрикс24 не работает!");
		Возврат Неопределено;	
	КонецПопытки;
	
КонецФункции

Функция ВыполнитьПроизвольныйЗапросБитрикс24(Метод, Знач ПараметрыЗапроса) Экспорт
	АдресСервера = "bitrix.tg-alterra.ru";

	token = Константы.ВебХук.Получить();	
	
	АдресРесурса = "/local/api/v1/" + Метод;
	
	ПараметрыЗапроса.Вставить("token", token);
	
	HTTPСоединение = Новый HTTPСоединение(АдресСервера, 443, , , ПолучениеФайловИзИнтернетаКлиентСервер.ПолучитьПрокси("http"), , Новый ЗащищенноеСоединениеOpenSSL);
	
	Если ПараметрыЗапроса.login <> "" Тогда
		Запрос = Новый HTTPЗапрос(АдресРесурса + "?login=" + ПараметрыЗапроса.login + "&token=" + token);
		Ответ = HTTPСоединение.Получить(Запрос); 
		
		Если Ответ.КодСостояния = 200 Тогда
		   	Данные = Ответ.ПолучитьТелоКакСтроку();
			Ответ = ДесериализоватьИзJSON(Данные);
		Иначе
		    Ошибка = Новый Структура;
			Ошибка.Вставить("КодСостояния", Ответ.КодСостояния);
			НазваниеОшибки = Ответ.error;
			ОписаниеОшибки = Ответ.error_description;
			Ошибка.Вставить("НазваниеОшибки", НазваниеОшибки);
			Ошибка.Вставить("ОписаниеОшибки", ОписаниеОшибки);
			Возврат Ошибка;
		КонецЕсли; 
		Возврат Ответ; 
	Иначе
		Ошибка = Новый Структура; 
		Возврат Ошибка;
   	КонецЕсли;
КонецФункции

Функция ВыполнитьЗапрос(Метод, Знач ПараметрыЗапроса, HTTPСоединение=Неопределено, ВернутьТелоОтвета = Ложь) Экспорт
	АдресСервера = "bitrix.tg-alterra.ru";
	
	ВебХук=Константы.ВебХук.Получить();
	
	АдресРесурса = "/rest/1/"+ВебХук+"/" + Метод + ".json";

	Если HTTPСоединение=Неопределено Тогда
		HTTPСоединение = ПолучитьСоединение(Метод);
	КонецЕсли;     
	
	Если ТипЗнч(HTTPСоединение) = Тип("Строка") Тогда
		Сообщить("Ошибка: " + HTTPСоединение);
	    Возврат Неопределено;
	Иначе                              
		Заголовки = Новый Соответствие;
	    Заголовки.Вставить("Accept-Language", "ru");
	    Заголовки.Вставить("Accept-Charset", "utf-8");
	    Заголовки.Вставить("Content-Language", "ru");
	    Заголовки.Вставить("Content-Charset", "utf-8");
	    Заголовки.Вставить("Content-type", "application/json"); 
	    
	    HTTPЗапрос = Новый HTTPЗапрос(АдресРесурса, Заголовки);
		HTTPЗапрос.УстановитьТелоИзСтроки(ПараметрыЗапроса);
	
	    HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	    ТелоОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
		
		Если ВернутьТелоОтвета Тогда
			Ответ = ТелоОтвета;
		ИначеЕсли Не (Метод = "tasks.task.add" ИЛИ Метод = "tasks.task.get"
			ИЛИ Метод = "calendar.section.get" 
			ИЛИ Метод = "bizproc.workflow.instances"
			ИЛИ Метод = "bizproc.task.list") Тогда 
			Ответ = ДесериализоватьИзJSON(ТелоОтвета);
		Иначе
			Ответ = ДесериализоватьИзJSONВСоответсвие(ТелоОтвета);
		КонецЕсли;
				
		Если HTTPОтвет.КодСостояния = 200 Тогда
			Возврат Ответ;
		Иначе
			Ошибка = Новый Структура;
			Ошибка.Вставить("КодСостояния", HTTPОтвет.КодСостояния);
			ЭтоСоответствие = ТипЗнч(Ответ) = Тип("Соответствие");
			НазваниеОшибки = ?(ЭтоСоответствие, Ответ["error"], Ответ.error);
			ОписаниеОшибки = ?(ЭтоСоответствие, Ответ["error_description"], Ответ.error_description);
			Ошибка.Вставить("НазваниеОшибки", НазваниеОшибки);
			Ошибка.Вставить("ОписаниеОшибки", ОписаниеОшибки);
			Возврат Ошибка;
		КонецЕсли;
    КонецЕсли;
КонецФункции

//Установить соединение, если требуется сделать несколько запросов подряд 
//
// Параметры:
// АдресСервера  - Строка -  
// АдресРесурса  - Строка - 
//
// Возвращаемое значение:
//   HTTP соединение   
//
Функция ПолучитьСоединение(Метод, АдресСервера="", АдресРесурса="") Экспорт 
	АдресСервера = ?(АдресСервера="", "bitrix.tg-alterra.ru", АдресСервера);
	АдресРесурса = ?(АдресРесурса="", "/rest/1/qf9d1uvmxxhzxgw5/" + Метод + ".json", АдресРесурса);

	Попытка
		Возврат Новый HTTPСоединение(АдресСервера, 443, , , ПолучениеФайловИзИнтернетаКлиентСервер.ПолучитьПрокси("http"), , Новый ЗащищенноеСоединениеOpenSSL); // соединяемся по https
	Исключение
		Возврат ОписаниеОшибки();
	КонецПопытки;
КонецФункции

Процедура ВыполнитьПрямойЗапрос(Метод,ПараметрыМетода) экспорт
	АдресСервера = "bitrix.tg-alterra.ru";
	Соединение = Новый HTTPСоединение(АдресСервера, 443, , , ПолучениеФайловИзИнтернетаКлиентСервер.ПолучитьПрокси("http"), , Новый ЗащищенноеСоединениеOpenSSL); 		
	
	ВебХук=Константы.ВебХук.Получить();
	
	АдресРесурса = "/rest/1/"+ВебХук+"/" + Метод + ".json?";
	
	ТекстЗапроса=АдресРесурса;
	если типзнч(ПараметрыМетода)=тип("Структура") тогда
		для каждого стр из ПараметрыМетода цикл
			ТекстЗапроса=ТекстЗапроса+стр.ключ+"="+стр.Значение+"&";	
		конеццикла;	
		ТекстЗапроса=лев(ТекстЗапроса,стрдлина(ТекстЗапроса)-1);
	иначе
		ТекстЗапроса=ТекстЗапроса+ПараметрыМетода;
	конецесли;
	Запрос = Новый HTTPЗапрос(ТекстЗапроса);
	Результат = Соединение.Получить(Запрос);
КонецПроцедуры

