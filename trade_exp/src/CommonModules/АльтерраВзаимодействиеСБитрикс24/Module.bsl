//	Значения параметра ПолучательСообщения: 
//		Группа 'Коммерческие вопросы'
//		Группа 'Руководители подразделений'
//		Группа 'Руководители'
Функция СообщениеВЖивуюЛенту(ТекстЗаголовок, ТекстДляЖивойЛенты, МассивФайлов = Неопределено, ПолучательСообщения, ВажноеСообщение = Ложь) Экспорт
	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("POST_TITLE", ТекстЗаголовок);
	ПараметрыМетода.Вставить("POST_MESSAGE", ТекстДляЖивойЛенты);
	
	Если МассивФайлов <> Неопределено Тогда
		ПараметрыМетода.Вставить("FILES", МассивФайлов);
	КонецЕсли;
	
	Если ПолучательСообщения = "Группа 'Коммерческие вопросы'" Тогда
		ПараметрыМетода.Вставить("DEST", Новый Структура("SG", "SG46"));
	ИначеЕсли ПолучательСообщения = "Группа 'Руководители подразделений'" Тогда
		ПараметрыМетода.Вставить("DEST", Новый Структура("SG", "SG59"));
	ИначеЕсли ПолучательСообщения = "Группа 'Руководители'" Тогда
		ПараметрыМетода.Вставить("DEST", Новый Структура("SG", "SG171"));
	Иначе
		Возврат "Не найден получатель сообщения!";
	КонецЕсли;
	//ПараметрыМетода.Вставить("DEST", Новый Структура("U", "U6987"));  // На конкретного пользователя(для тестирования)         
	
	Если ВажноеСообщение Тогда 
		ПараметрыМетода.Вставить("IMPORTANT", "Y");
	КонецЕсли;
	
	ПараметрыМетода.Вставить("USER_ID", ПолучитьИДПользователя());	
	
	АдресСервера = "bitrix.tg-alterra.ru";
	Соединение = Новый HTTPСоединение(АдресСервера, 443, , , ПолучениеФайловИзИнтернетаКлиентСервер.ПолучитьПрокси("http"), , Новый ЗащищенноеСоединениеOpenSSL);
	НазваниеОшибки = "";
	ОписаниеОшибки = "";
				 
	Для КоличествоПопыток = 1 По 3 Цикл
		
		Результат = ВыполнитьПроизвольныйЗапрос("log.blogpost.add", ПараметрыМетода, Ложь, Соединение);
		
		Если Результат.Свойство("result") Тогда
			Возврат "";
		Иначе
			НазваниеОшибки = Результат.НазваниеОшибки;
			ОписаниеОшибки = Результат.ОписаниеОшибки;
		КонецЕсли;
	КонецЦикла; 
	
	Возврат "Не удалось отправить сообщение! НазваниеОшибки: " + НазваниеОшибки + ". ОписаниеОшибки: " + ОписаниеОшибки;
	
КонецФункции

//Если всё хорошо - возвращает ID лида. Если всё плохо - возвращает описание ошибки строкой. Мож
//
// Параметры:
//  ПараметрыМетода  - Структура (или массив структур) - содержит поля: "Партнер", "Потенциал", "АктуальныйУТСК", "ФазаСтроительства"
//
// Возвращаемое значение:
//   Строка   - ID созданного лида (или массив созданных ID). Если ошибка - возвращает пустую строку
//
Функция СоздатьЛид(ПараметрыМетода)  Экспорт
	Метод = "crm.lead.add";
	АдресСервера = "bitrix.tg-alterra.ru";
	АдресРесурса = "/rest/1/qf9d1uvmxxhzxgw5/" + Метод + ".json";
		
	ПараметрыПоля = Новый Структура;
	ПараметрыПоля.Вставить("TITLE", Строка(ПараметрыМетода.Партнер));
	ПараметрыПоля.Вставить("OPPORTUNITY", ПараметрыМетода.Потенциал);
	ПараметрыПоля.Вставить("UF_CRM_1580785917214", "141");
	ПараметрыПоля.Вставить("STATUS_ID", "NEW");
	ИДКлиента = ПолучитьИДКонтакта( ПараметрыМетода.Партнер);
	
	Если ИДКлиента<>"" Тогда 
		  ПараметрыПоля.Вставить("CONTACT_ID", ИДКлиента);
	КонецЕсли;
	
	ПараметрыПоля.Вставить("ASSIGNED_BY_ID", ПолучитьИДПользователя(ПараметрыМетода.АктуальныйУТСК));
	ПараметрыПоля.Вставить("SOURCE_DESCRIPTION", "Появился новый клиент с активной фазой "+ ПараметрыМетода.ФазаСтроительства + ". Назначьте ответственного.");
	
	ПараметрыВывода = Новый Структура;
	ПараметрыВывода.Вставить("REGISTER_SONET_EVENT", "N");
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("fields", ПараметрыПоля);
	ПараметрыЗапроса.Вставить("params", ПараметрыВывода);

	Ответ = ВыполнитьПроизвольныйЗапрос(Метод, ПараметрыЗапроса);
	Результат = "";
	//если вернулась ошибка
	Если Ответ.Свойство("КодСостояния") Тогда
		//запись в журнал регистрации об ошибке
		ТекстОшибки = "Создание лида | " + ПолучитьРезультатСтрокой(Ответ) ;
		ЗаписатьВЖурналРегистрации(ТекстОшибки);
	ИначеЕсли Ответ.Свойство("result") Тогда
		Результат = Ответ.result;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

//Получает массив id задач в Битриксе
//Возвращает структуру с 
//МассивID - Массив id полученных задач 
//МассивДат - Массив с датами создания задач
//МассивСтатусов - Массив статусов по задачам (2 не выполнялась, 5 - завершена)
//МассивКрайнихСроков - Массив дат с крайними сроками  
Функция ПолучитьСтатусыПоЗадачам(МассивID) экспорт 
	МассивДат = Новый массив; 
	МассивСтатусов = Новый массив;
	МассивКрайнихСроков = Новый массив; 
	
	Для каждого ID из МассивID Цикл
		Параметры = Новый Структура; 
		Параметры.Вставить("taskId", ID);
		МассивВозврата = Новый Массив; 
		МассивВозврата.Добавить("STATUS");
		МассивВозврата.Добавить("ID");
		МассивВозврата.Добавить("CREATED_DATE");
		МассивВозврата.Добавить("DEADLINE");
		Параметры.Вставить("select", МассивВозврата);
		Ответ = ВыполнитьПроизвольныйЗапрос("tasks.task.get", Параметры);
		Результат = Ответ["result"];
		Ответ = Результат["task"];
		Статус = Ответ["status"];
		ДатаНачалаСтрокой = Ответ["createdDate"];
		КрайнийСрокСтрокой = Ответ["deadline"];
		СтрокаПромежуточная = Сред(ДатаНачалаСтрокой,0 , 4)+Сред(ДатаНачалаСтрокой, 6, 2)+Сред(ДатаНачалаСтрокой, 9, 2)+Сред(ДатаНачалаСтрокой, 12, 2)+Сред(ДатаНачалаСтрокой, 15, 2)+Сред(ДатаНачалаСтрокой, 18, 2); 
		ДатаНачала = Дата(СтрокаПромежуточная); 
		СтрокаПромежуточная = Сред(КрайнийСрокСтрокой,0 , 4)+Сред(КрайнийСрокСтрокой, 6, 2)+Сред(КрайнийСрокСтрокой, 9, 2)+Сред(КрайнийСрокСтрокой, 12, 2)+Сред(КрайнийСрокСтрокой, 15, 2)+Сред(КрайнийСрокСтрокой, 18, 2);
		КрайнийСрок = Дата(СтрокаПромежуточная); 
		МассивДат.Добавить(ДатаНачала); 
		МассивСтатусов.Добавить(Статус); 
		МассивКрайнихСроков.Добавить(КрайнийСрок);
	КонецЦикла;
	
	Результат = Новый Структура;
	Результат.Вставить("МассивID", МассивID);
	Результат.Вставить("МассивДат", МассивДат);
	Результат.Вставить("МассивСтатусов", МассивСтатусов);
	Результат.Вставить("МассивКрайнихСроков", МассивКрайнихСроков);

	Возврат Результат; 
КонецФункции 

//Функция создает задачу в Битрикс. Получает Струтуру параметров 
//Поставновщик - ссылка на постановщика
//Ответственные - Массив ссылок на отвественных - 1 - отвестственный - далее соисполнители
//Наблюдатели - Массив ссылок на наблюдателей
//Заголовок - Строка заголовка
//Описание = Многострочная строка описания
//КрайнийСрок - дата крайнего срока
//ИДГруппы - ИД группы в которую встает новая задача
//ИДРодительскойЗадачи - ИД задачи, которая становится родительской для новой 
//Возвращает id новой задачи
Функция СоздатьЗадачу(СтруктураПараметров) Экспорт 
	Параметры = Новый Структура; 
	Параметры.Вставить("TITLE", СтруктураПараметров.Заголовок); 
	Параметры.Вставить("DESCRIPTION", СтруктураПараметров.Описание); 
	Параметры.Вставить("DEADLINE", СтруктураПараметров.КрайнийСрок); 
	Параметры.Вставить("GROUP_ID", СтруктураПараметров.ИДГруппы); 
	Параметры.Вставить("PARENT_ID", СтруктураПараметров.ИДРодительскойЗадачи);
		
	//Вытаскиваем все id пользователей 
	ИДПостановщика = ПолучитьИДПользователя(СтруктураПараметров.Постановщик); 
	Ответственные = СтруктураПараметров.Ответственные; 
	ИДСоисполнителей = Новый Массив; 
	ОтвВыбран = Ложь; 
	Для Каждого Ответственный из Ответственные Цикл 
		Если не ОтвВыбран Тогда 
			ИДОтветственного = ПолучитьИДПользователя(Ответственный); 
			ОтвВыбран = Истина; 
		Иначе
			ИДСоисполнителей.Добавить(ПолучитьИДПользователя(Ответственный)); 
		КонецЕсли; 
	КонецЦикла; 
	ИДНаблюдателей = Новый Массив; 
	Наблюдатели = СтруктураПараметров.Наблюдатели; 
	Для Каждого Наблюдатель из Наблюдатели Цикл 
		ИДНаблюдателей.Добавить(ПолучитьИДПользователя(Наблюдатель)); 
	КонецЦикла; 
	
	Параметры.Вставить("CREATED_BY", ИДПостановщика);
	Параметры.Вставить("RESPONSIBLE_ID", ИДОтветственного);
	Параметры.Вставить("ACCOMPLICES", ИДСоисполнителей);
	Параметры.Вставить("AUDITORS",ИДНаблюдателей);
	
	Ответ = ВыполнитьПроизвольныйЗапрос("tasks.task.add", новый структура("fields", Параметры));
	Результат = Ответ["result"];
	Ответ = Результат["task"];
	id = Ответ["id"];
	Если id <> неопределено Тогда 
		Сообщить("Задача № " +id +" создана!");
	Иначе
		Сообщить("Ошибка в создании задачи"); 
	КонецЕсли; 
	Возврат id;
КонецФункции   

