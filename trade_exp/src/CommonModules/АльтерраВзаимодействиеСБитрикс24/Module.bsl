//Работает с командой "get", которая возвращает конкретную сущность, если она существует и ошибку, если она не найдена
//
// Параметры:
// НазваниеСущности  - Строка - может принимать значения lead, deal и user. Для остальных сущностей команды get нет
// ИДСущности - строка - id экземпляра, который мы хотим получить
// НазваниеПоля - строка или структура - параметры, которые хотим получить из экземпляра
//
// Возвращаемое значение:
//   Массив, строка   - в зависимости от параметра. В случае ошибки возвращает структурой со свойством Error
//
Функция ПолучитьЗначениеПоляСущностиПоID(НазваниеСущности, ИДСущности, НазваниеПоля, HTTPСоединение=Неопределено) Экспорт

	Команда = "";
	Если НазваниеСущности="lead" или НазваниеСущности = "deal" Тогда
		Команда = "crm.";
	ИначеЕсли НазваниеСущности = "user" Тогда
	Иначе
	//сущность не имеет метода get	
	КонецЕсли;
	Команда = Команда + НазваниеСущности + ".get";
	СтруктураПараметров = Новый Структура;
	Ид_Ч = Формат(Число(ИДСущности), "ЧГ=0");
	СтруктураПараметров.Вставить("ID", Ид_Ч);                                                        
	РезультатЗапроса = ВыполнитьПроизвольныйЗапрос(Команда, СтруктураПараметров, , HTTPСоединение);
	Результат = Новый Структура;
	Если РезультатЗапроса.Свойство("result") Тогда
		СтруктураРезультат = РезультатЗапроса.result;
		Если ТипЗнч(НазваниеПоля) = Тип("Массив") Тогда
			Если ТипЗнч(СтруктураРезультат)=Тип("Массив") Тогда
				СтруктураРезультат = РезультатЗапроса.result[0];
			КонецЕсли;
			Для каждого Название из НазваниеПоля Цикл
				Если СтруктураРезультат.Свойство(Название) Тогда
					Результат.Вставить(Название, СтруктураРезультат[Название]);
				КонецЕсли;
			КонецЦикла;
		Иначе
			Если ТипЗнч(СтруктураРезультат) = Тип("Массив") Тогда
				СтрРезультат = СтруктураРезультат[0];
				Если ТипЗнч(НазваниеПоля) = Тип("Строка") Тогда
					Результат.Вставить(НазваниеПоля, СтрРезультат[НазваниеПоля]);
				Иначе
					Поля = НазваниеПоля;
					Для каждого Поле из Поля Цикл
						Результат.Вставить(Поле.Ключ, СтрРезультат[Поле.Ключ]);
					КонецЦикла;
				КонецЕсли;
			Иначе
				Если СтруктураРезультат.Свойство(НазваниеПоля) Тогда
					Результат.Вставить(НазваниеПоля, СтруктураРезультат[НазваниеПоля]);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе
		//ошибка
		ЗаписатьВЖурналРегистрации(ПолучитьРезультатСтрокой(РезультатЗапроса)+" | получение "+НазваниеСущности);
	КонецЕсли;
	Возврат Результат;
КонецФункции

//получить ид сущности клиента, если его нет в регистре
Функция ПолучитьИДКонтакта(Клиент, HTTPСоединение=Неопределено) Экспорт
	ФИО = ФизическиеЛицаУТ.ФамилияИмяОтчество(Клиент);
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыКонтакта = Новый Структура; 
	ПараметрыКонтакта.Вставить("NAME",ФИО.Имя);
	ПараметрыКонтакта.Вставить("LAST_NAME",ФИО.Фамилия);
    ПараметрыКонтакта.Вставить("SECOND_NAME",ФИО.Отчество);
	ПараметрыЗапроса.Вставить("filter", ПараметрыКонтакта);
	ПараметрыОтвета = Новый Структура("ID", "");
	ПараметрыЗапроса.Вставить("select", ПараметрыОтвета);
	Ответ = ВыполнитьПроизвольныйЗапрос("crm.contact.list", ПараметрыЗапроса, , HTTPСоединение);
	КонтактИД = "";
	Если Ответ.Свойство("result") Тогда
		Если Ответ.result.Количество() > 0 Тогда
			КонтактИД = Ответ.result[0].ID;
		КонецЕсли;
	Иначе
		//ошибка
		ЗаписатьВЖурналРегистрации(ПолучитьРезультатСтрокой(Ответ)+ "| получение ИД контакта");
	КонецЕсли;
	
    Возврат КонтактИД;
КонецФункции

//"Стучится" в Б24, выхватывает сделку, если она есть 
//
// Параметры:
//  ПараметрыМетода  - Структура - заголовки должны точно соответствовать существующим. 
//                 Партнер 
//					Пользователь - либо строка ID, либо пользователь ИБ 
//                Лид (опционально)
//  HTTPСоединение - если требуется сделать несколько обращений в рамках одного соединения 
//
// Возвращаемое значение:
//   Строка  - возвращает ID сделки. Если сделка не найдена - пустая строка
//
Функция ЕстьСделка(ПараметрыМетода, HTTPСоединение=Неопределено) Экспорт
	//искать по полям:
	//партнер - CONTACT_IDS - РС Б24_Синхр_ИдентификаторыОбъектов.Идентификатор
	//пользователь, которому назначено - ASSIGNED_BY_ID
	//получить ИД пользователя
	Если ТипЗнч(ПараметрыМетода.Партнер)=Тип("Строка") Тогда 
		ИДКлиента = ПараметрыМетода.Партнер;
	Иначе
		ИДКлиента =ПолучитьИДКонтакта(ПараметрыМетода.Партнер);
	КонецЕсли;
	Если ИДКлиента="" Тогда
		Возврат "клиента нет";
	КонецЕсли;
	ПараметрыКоманды = Новый Структура;
	
	Фильтр = Новый Структура;
	
	Фильтр.Вставить("CONTACT_IDS", ИДКлиента);
	Если  ТипЗнч(ПараметрыМетода.Пользователь) <> Тип("Строка") Тогда
		Фильтр.Вставить("ASSIGNED_BY_ID", ПолучитьИДПользователя(ПараметрыМетода.Пользователь));
	Иначе
		Фильтр.Вставить("ASSIGNED_BY_ID", ПараметрыМетода.Пользователь);
	КонецЕсли;
	Если ПараметрыМетода.Свойство("Лид") Тогда
		Фильтр.Вставить("LEAD_ID", ПараметрыМетода.Лид);
	КонецЕсли;
	ВыбранныеПоля = Новый Структура;
	ВыбранныеПоля.Вставить("ID");
	
	ПараметрыКоманды.Вставить("filter", Фильтр);
	ПараметрыКоманды.Вставить("select", ВыбранныеПоля);
	
	Ответ = ВыполнитьПроизвольныйЗапрос("crm.deal.list", ПараметрыКоманды, , HTTPСоединение);
	СделкаНайдена = (Не Ответ.Свойство("НазваниеОшибки") И Ответ.total<>0);
	Если СделкаНайдена Тогда
		Если Ответ.Свойство("result") Тогда
			Возврат Ответ.result[0].ID;
		Иначе
			Возврат "";
		КонецЕсли;
	КонецЕсли;
	Возврат "";
КонецФункции

Функция ОтправитьСообщениеВБитрикс(ТелоСообщения, Сотрудник) Экспорт  

	Попытка 

		ПолучательСообщения = ПолучитьПользователя(Сотрудник);
		Если Не ПолучательСообщения.Свойство("result") Или ПолучательСообщения.result.Количество() = 0 Тогда
			Текст = "Учетная запись сотрудника " + Сотрудник + " не найдена. Проверьте настройки пользователя и повторите попытку";
			Сообщить(Текст);
			Возврат Неопределено;	
		КонецЕсли;
		IDПолучательСообщения = ПолучательСообщения.result[0].ID;
		ТекстСообщения = Строка(ТелоСообщения);
	    ПараметрыЗапроса = Новый Структура; 
		ПараметрыЗапроса.Вставить("DIALOG_ID", IDПолучательСообщения);
		ПараметрыЗапроса.Вставить("MESSAGE",ТекстСообщения);
				  
	    Возврат ВыполнитьПроизвольныйЗапрос("im.message.add", ПараметрыЗапроса);
    
	Исключение
		Сообщить("Сообщение в Битрикс24 не отправлено. Сервер системы Битрикс24 не работает!");
		Возврат Неопределено;	
	КонецПопытки;
    
КонецФункции      

