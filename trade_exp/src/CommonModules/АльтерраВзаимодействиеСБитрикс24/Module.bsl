//Если всё хорошо - возвращает ID сделки. Если всё плохо - возвращает описание ошибки строкой
//
//Параметры:
//ПараметрыМетода  - структура - Заголовок, Партнер, Пользователь, Сумма
//
Функция СоздатьСделку(ПараметрыМетода) Экспорт
	ПараметрыПоля = Новый Структура;
	ПараметрыПоля.Вставить("TITLE", ПараметрыМетода.Заголовок);
	ПараметрыПоля.Вставить("OPENED", "Y");
	ПараметрыПоля.Вставить("ASSIGNED_BY_ID", ПолучитьИДПользователя(ПараметрыМетода.Пользователь));
	ПараметрыПоля.Вставить("CURRENCY_ID", "RUB");
	ПараметрыПоля.Вставить("BEGINDATE", ФорматироватьДату(ТекущаяДата()));
	ПараметрыПоля.Вставить("OPPORTUNITY", ПараметрыМетода.Сумма);
	ПараметрыПоля.Вставить("SOURCE_DESCRIPTION",  "Сделка создана автоматически, т.к. клиент имеет корректно заполненную фазу активного строительства.");
	ИДКлиента = ПолучитьИДКонтакта(ПараметрыМетода.Партнер);
	Если ИДКлиента<>"" Тогда 
		  ПараметрыПоля.Вставить("CONTACT_IDS", ИДКлиента);
	КонецЕсли;
	ПараметрыРегистрацииБ = Новый Структура;
	ПараметрыРегистрацииБ.Вставить("REGISTER_SONET_EVENT", "N");
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("fields", ПараметрыПоля);
	СтруктураПараметров.Вставить("params", ПараметрыРегистрацииБ);
	
	Ответ = ВыполнитьПроизвольныйЗапрос("crm.deal.add", СтруктураПараметров, Истина);
	Результат = "";
	Если Ответ.Свойство("result") Тогда
		  Результат = Ответ.result;
	  Иначе
		  ЗаписатьВЖурналРегистрации("Ошибка при создании сделки в Б24." + ПолучитьРезультатСтрокой(Ответ)) ;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция СоздатьДело(ПараметрыМетода) Экспорт
	Метод = "crm.activity.add";
	АдресСервера = "bitrix.tg-alterra.ru";
	АдресРесурса = "/rest/1/qf9d1uvmxxhzxgw5/" + Метод + ".json";
		
	COMMUNICATIONS = Новый Структура;
	COMMUNICATIONS.Вставить("ENTITY_ID", ПараметрыМетода.IDПартнера);
	COMMUNICATIONS.Вставить("ENTITY_TYPE_ID", 4); // 3 контакт / 4 компания (crm.enum.ownertype) 
	COMMUNICATIONS.Вставить("VALUE", ПараметрыМетода.ТелефонИлиEmailПартнера);

	Массив = Новый Массив;
	Массив.Добавить(COMMUNICATIONS);

	ПараметрыПоля = Новый Структура;
	ПараметрыПоля.Вставить("OWNER_TYPE_ID", 2); // Тип сущности для привязки к делу (crm.enum.ownertype) 2 - тип "сделка"
	ПараметрыПоля.Вставить("OWNER_ID", Число(ПараметрыМетода.IDПоследнейСделкиПоПартнеру)); //id сделки
	ПараметрыПоля.Вставить("RESPONSIBLE_ID",ПараметрыМетода.Ответственный);
	ПараметрыПоля.Вставить("SUBJECT", ПараметрыМетода.Тема); 	
	ПараметрыПоля.Вставить("COMMUNICATIONS", Массив); // (crm_activity_communication)
	ПараметрыПоля.Вставить("DESCRIPTION", ПараметрыМетода.Описание); 
	ПараметрыПоля.Вставить("TYPE_ID", ПараметрыМетода.ВстречаИлиЗвонок); // Тип дела. 1 встреча / 2 звонок (crm_enum_activitytype)
	Если ПараметрыМетода.ВстречаИлиЗвонок = 2 Тогда 
		ПараметрыПоля.Вставить("DIRECTION", 2);  // Направление дела: 1 входящее / 2 исходящее	(crm.enum.activitydirection)
	КонецЕсли;                                  // Используется только для звонков и писем, для встреч не используется
	ПараметрыПоля.Вставить("START_TIME", ПараметрыМетода.ДатаИВремяНачала);
	ПараметрыПоля.Вставить("END_TIME", ПараметрыМетода.ДатаИВремяОкончания);    
	
	Возврат ВыполнитьПроизвольныйЗапрос(Метод, Новый Структура("fields", ПараметрыПоля));
КонецФункции

