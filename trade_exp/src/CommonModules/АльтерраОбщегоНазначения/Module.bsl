Функция ПолучитьСсылкуНаДокументПоQR(СтрокаКода) Экспорт
	
	ПараметрыПоискаПродажи = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.РасшифроватьQRКодЧекаККТ(НРег(СтрокаКода));
	
	Если ПараметрыПоискаПродажи = Новый Структура Тогда
		Возврат Неопределено;
	КонецЕсли;
	Запрос = Новый Запрос;
	 Запрос.Текст = 
		 "ВЫБРАТЬ
		 |	ФискальныеОперации.ДокументОснование КАК ДокументОснование
		 |ИЗ
		 |	РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
		 |ГДЕ
		 |	ФискальныеОперации.ЗаводскойНомерФН = &НомерФискальногоНакопителя
		 |	И ФискальныеОперации.НомерЧекаККМ = &НомерФискальногоДокумента
		 |	И ФискальныеОперации.ТипРасчета = &ПризнакРасчета
		 |	И ФискальныеОперации.Дата = &ДатаВремяРасчета
		 |	И ФискальныеОперации.Сумма = &СуммаРасчета";
	 
	 Запрос.УстановитьПараметр("НомерФискальногоНакопителя", ПараметрыПоискаПродажи.НомерФискальногоНакопителя);
	 Запрос.УстановитьПараметр("НомерФискальногоДокумента", Число(ПараметрыПоискаПродажи.НомерФискальногоДокумента));
	 Запрос.УстановитьПараметр("ПризнакРасчета", ПараметрыПоискаПродажи.ПризнакРасчета);
	 Запрос.УстановитьПараметр("ДатаВремяРасчета", ПараметрыПоискаПродажи.ДатаВремяРасчета);
	 Запрос.УстановитьПараметр("СуммаРасчета", ПараметрыПоискаПродажи.СуммаРасчета);
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 Выборка =  РезультатЗапроса.Выбрать();
	 Если Выборка.Следующий() Тогда
		Возврат Выборка.ДокументОснование; 
	Иначе
		Возврат Неопределено;
	КонецЕсли;
