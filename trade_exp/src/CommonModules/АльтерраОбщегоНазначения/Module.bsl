Функция ТабличнаяЧастьИзменилась(ИсходнаяТЧ,НоваяТЧ) Экспорт
			
	ИсходнаяСтрокаТаблицы = "";
	
	НоваяСтрокаТаблицы = "";
	
	Для каждого Строка из ИсходнаяТЧ Цикл
		ИсходнаяСтрокаТаблицы = ИсходнаяСтрокаТаблицы + Строка(Строка.Номенклатура) + Строка(Строка.Характеристика) + Строка(Строка.Назначение) + Строка(Строка.КоличествоУпаковок);
	КонецЦикла;
	
	Для каждого Строка из НоваяТЧ Цикл
		НоваяСтрокаТаблицы = НоваяСтрокаТаблицы + Строка(Строка.Номенклатура) + Строка(Строка.Характеристика) + Строка(Строка.Назначение) + Строка(Строка.КоличествоУпаковок);
	КонецЦикла;
	
	Если ИсходнаяСтрокаТаблицы = НоваяСтрокаТаблицы Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьКоличествоЗаписейВРегистреСобытияДокументов(Документ,Событие) Экспорт
	
	КоличествоЗаписей = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(СобытияДокументовАльтерра.Период) КАК Количество
		|ИЗ
		|	РегистрСведений.СобытияДокументовАльтерра КАК СобытияДокументовАльтерра
		|ГДЕ
		|	СобытияДокументовАльтерра.Документ = &Документ
		|	И СобытияДокументовАльтерра.Событие = &Событие";
	
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("Событие", Событие);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	    КоличествоЗаписей = ВыборкаДетальныеЗаписи.Количество;	
	КонецЦикла;

	Возврат КоличествоЗаписей;
	
