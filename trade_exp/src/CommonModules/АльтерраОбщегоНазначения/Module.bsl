Процедура ДобавитьУслугуБезНДСНаСервере(Объект) Экспорт
	
	НоваяСтрока = Объект.Товары.Добавить();
	НоваяСтрока.Номенклатура = АльтерраОбщегоНазначения.УслугаДоставкиБезНДС();
	НоваяСтрока.Количество = Константы.СтоимостьУслугиДоставкиБезНДС.Получить(); 
	НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
	если не ДопМодуль.НовоеЦенообразование() тогда
		НоваяСтрока.ВидЦены = Объект.Соглашение.ВидЦен;  
	иначе                                         
		//Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		//	Подразделение=Объект.Склад.Подразделение; 
		//иначе
			Подразделение=Объект.Подразделение; 
		//конецесли;
		НоваяСтрока.ВидЦены = ПодборТоваровВызовСервера.ВернутьВидЦенПоПараметрам(Объект.Соглашение.ГруппаВидовЦен,Подразделение); 
	конецесли;
	НоваяСтрока.СтавкаНДС = НоваяСтрока.Номенклатура.СтавкаНДС;
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		НоваяСтрока.ВариантОбеспечения= Перечисления.ВариантыОбеспечения.Отгрузить;
	КонецЕсли;
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		НоваяСтрока.Продавец = Объект.Менеджер;
	КонецЕсли;

	НоваяСтрока.Склад = Объект.Склад;
	БонусыАльтерра.ЗаполнитьЦенуПродажиИПересчитатьСуммыСУчетомБонусов(Объект, НоваяСтрока); 
	
КонецПроцедуры    

Процедура ДобавитьУслугуВДокумент(Объект, Услуга, Количество, Цена) Экспорт
	
	НоваяСтрока = Объект.Товары.Добавить();
	НоваяСтрока.Номенклатура = Услуга;
	НоваяСтрока.Количество = Количество; 
	НоваяСтрока.Цена = Цена; 
	НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
	НоваяСтрока.ВидЦены = Объект.Соглашение.ВидЦен;
	НоваяСтрока.СтавкаНДС = НоваяСтрока.Номенклатура.СтавкаНДС;
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		НоваяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
	КонецЕсли;
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		НоваяСтрока.Продавец = Объект.Менеджер;
	КонецЕсли;
	НоваяСтрока.Склад = Объект.Склад;
	ПересчитатьСуммыВСтрокеТовара(Объект, НоваяСтрока);
	
КонецПроцедуры

Функция ПолучитьСотрудника(Пользователь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	НЕ Сотрудники.ПометкаУдаления
		|	И НЕ Сотрудники.Уволен
		|	И Сотрудники.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Справочники.Сотрудники.ПустаяСсылка();
	КонецЕсли;  
	
КонецФункции

