Функция ПроверитьОтсрочку(Объект)
	
	Если Не значениезаполнено(Объект.Договор) Тогда
		Возврат Ложь;
	КонецЕсли;	
	Если Объект.Договор.ВидДоговора <> Перечисления.видДоговора.Отсрочка Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	Возврат Истина;
	
КонецФункции

Функция ПроверитьМенеджера(Объект)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Партнеры.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Партнеры КАК Партнеры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО Партнеры.ОсновнойМенеджер = ДополнительныеСведения.Объект
		|			И (ДополнительныеСведения.Свойство.Имя = ""Отделы"")
		|ГДЕ
		|	Партнеры.Ссылка = &Ссылка
		|	И ДополнительныеСведения.Значение = &Значение";
	
	Запрос.УстановитьПараметр("Значение", Справочники.ЗначенияСвойствОбъектов.ПолучитьСсылку(Новый УникальныйИдентификатор("779739e7-ce5f-11e2-a8a7-0025900c6332")));
	Запрос.УстановитьПараметр("Ссылка", Объект.Партнер);
	
	РезультатЗапроса = Запрос.Выполнить();
	Возврат Не РезультатЗапроса.Пустой();

КонецФункции 

Функция ПроверитьДоставку(Объект)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Номенклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Наименование = &Наименование
		|	И Номенклатура.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("Наименование", "Услуги доставки");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() тогда
		ГруппаНоменклатуры = ВыборкаДетальныеЗаписи.ссылка;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВР
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ВР.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВР КАК ВР
		|ГДЕ
		|	ВР.Номенклатура В ИЕРАРХИИ (&Группа)";
	
	Запрос.УстановитьПараметр("Группа", ГруппаНоменклатуры);
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
    Возврат Не результатзапроса.Пустой();
	
КонецФункции 

Функция НайтиСкидку(УправляемыеСкидки, Скидка)
	
	Если УправляемыеСкидки.НайтиПоЗначению(Скидка) <> Неопределено Тогда
		Результат = Истина;
	Иначе
		Результат = Ложь;	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьУдалитьСкидку(УправляемыеСкидки, Скидка, Добавление)
	
	Если Добавление Тогда
		УправляемыеСкидки.Добавить(Скидка);
	Иначе
		Если УправляемыеСкидки.НайтиПоЗначению(Скидка) <> НЕОПРЕДЕЛЕНО Тогда
			УправляемыеСкидки.Удалить(УправляемыеСкидки.НайтиПоЗначению(Скидка));
		КонецЕсли;  
	КонецЕсли; 
	
КонецПроцедуры

Процедура УстановитьУправляемуюСкидкуНаОтсрочку(Объект, УправляемыеСкидки) экспорт
	       
	Скидка = Справочники.СкидкиНаценки.НайтиПоНаименованию("+1% (наценка на отсрочку)");
	Если ПроверитьМенеджера(Объект) И ПроверитьОтсрочку(Объект) Тогда
		Если найтиСкидку(УправляемыеСкидки,скидка) Тогда
			Возврат;
		Иначе
			ДобавитьУдалитьСкидку(УправляемыеСкидки,Скидка, Истина);
		КонецЕсли;  
	Иначе
		ДобавитьУдалитьСкидку(УправляемыеСкидки,Скидка, Ложь);
	КонецЕсли;
	Объект.СкидкиРассчитаны = Ложь;  
	
КонецПроцедуры

Процедура УстановитьУправляемуюСкидкуНаДоставку(Объект, УправляемыеСкидки) экспорт
	
	Скидка = Справочники.СкидкиНаценки.НайтиПоНаименованию("+1% (доставка организацией)");
	Если ПроверитьМенеджера(Объект) И ПроверитьДоставку(Объект) Тогда
		Если найтиСкидку(УправляемыеСкидки, Скидка) Тогда
			Возврат;
		Иначе
			ДобавитьУдалитьСкидку(УправляемыеСкидки, Скидка, Истина);
		КонецЕсли;  
	Иначе
		ДобавитьУдалитьСкидку(УправляемыеСкидки, Скидка, Ложь);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Цены  

Процедура ЗаполнитьЦеныПоСоглашению(Объект, ВидЦены = Неопределено) Экспорт
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
	СтруктураДействий.Вставить("ОчиститьАвтоматическуюСкидку");
	
	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("Дата", Объект.Дата);
	ПараметрыЗаполнения.Вставить("Валюта", Объект.Валюта);
	Если ЗначениеЗаполнено(Объект.Соглашение) Тогда
		ПараметрыЗаполнения.Вставить("Соглашение", Объект.Соглашение);
	КонецЕсли;
	Если ЗначениеЗаполнено(ВидЦены) Тогда
		ПараметрыЗаполнения.Вставить("ВидЦены", ВидЦены);
	КонецЕсли;

	ПараметрыЗаполнения.Вставить("Организация", Объект.Организация);
	ПараметрыЗаполнения.Вставить("РассчитыватьНаборы", Истина);
	ПараметрыЗаполнения.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	ПараметрыЗаполнения.Вставить("ВозвращатьМногооборотнуюТару", Объект.ВернутьМногооборотнуюТару);
	ПараметрыЗаполнения.Вставить("ПоляЗаполнения", "Цена, СтавкаНДС, ВидЦены, СрокПоставки");

	Если ДопМодуль.НовоеЦенообразование() Тогда
		ПараметрыЗаполнения.Вставить("Подразделение",Объект.Подразделение);
	КонецЕсли;
	
	ЦеныРассчитаны = ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(
		Объект.Товары,
		,
		ПараметрыЗаполнения,
		СтруктураДействий);
	
КонецПроцедуры

Функция ЗависимыеРеквизиты()
	
	Возврат Новый Структура(
		"БезВозвратнойТары,ОтмененоБезВозвратнойТары,Отменено",
		"Сумма,СуммаНДС,СуммаСНДС,СуммаРучнойСкидки",
		"Сумма,СуммаНДС,СуммаСНДС,СуммаРучнойСкидки",
		"Сумма,СуммаНДС,СуммаСНДС,СуммаРучнойСкидки");
	
КонецФункции

Процедура ПересчитатьСуммыВСтрокеТовара(Объект, стрТоваров) Экспорт
	
	Если Не ПустаяСтрока(Объект) Тогда
		Если стрТоваров <> Неопределено Тогда
			стрТоваров.Сумма = стрТоваров.Количество*стрТоваров.Цена;
					
			СтруктураЗаполненияЦены = Новый Структура;
			СтруктураЗаполненияЦены.Вставить("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС);
			
			СтруктураДействий = Новый Структура();			
			СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
			СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураЗаполненияЦены);
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураЗаполненияЦены);
			СтруктураДействий.Вставить("ПересчитатьСумму");
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
			СтруктураДействий.Вставить("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС);
			
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда 
				СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
			КонецЕсли;
			СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", Новый Структура("Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки") );
			
			ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(стрТоваров, СтруктураДействий, Неопределено);
			
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
				Объект.СуммаДокумента = Объект.ПолучитьСуммуЗаказанныхСтрок();
				ОбновитьЭтапыОплатыВЗаказе(Объект, Объект.СуммаДокумента);
			КонецЕсли;
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
				Объект.СуммаДокумента = Объект.ПолучитьСуммуДокумента();
			КонецЕсли;
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЧекККМ") ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.ОтчетОРозничныхПродажах") Тогда
				Объект.СуммаДокумента = ЦенообразованиеКлиентСервер.ПолучитьСуммуДокумента(Объект.Товары, Объект.ЦенаВключаетНДС);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПересчитатьЦеныВСтрокеТовара(Объект, стрТоваров) Экспорт
	
	Если Не ПустаяСтрока(Объект) Тогда
		Если стрТоваров <> Неопределено Тогда
			СтруктураПересчетаЦены  = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруПересчетаЦеныСкидкиВПродажахВТЧ(Объект);
			СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
			
			СтруктураДействий = Новый Структура;
			СтруктураДействий.Вставить("ПересчитатьЦенуПоСумме");
			СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
			СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
			
			Если ТипЗнч(Объект) =  Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда 
				СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
			КонецЕсли;
			
			СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", Новый Структура("Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки") );
			
			ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(стрТоваров, СтруктураДействий, Неопределено);
			
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
				Объект.СуммаДокумента = Объект.ПолучитьСуммуЗаказанныхСтрок();
				ОбновитьЭтапыОплатыВЗаказе(Объект, Объект.СуммаДокумента);
			КонецЕсли;
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
				Объект.СуммаДокумента = Объект.ПолучитьСуммуДокумента();
			КонецЕсли;
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЧекККМ") ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.ОтчетОРозничныхПродажах") Тогда
				Объект.СуммаДокумента = ЦенообразованиеКлиентСервер.ПолучитьСуммуДокумента(Объект.Товары, Объект.ЦенаВключаетНДС);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьЭтапыОплатыВЗаказе(Заказ, Сумма)
	
	Заказ.ЭтапыГрафикаОплаты.Очистить();
	
	стрЭтапОплаты = Заказ.ЭтапыГрафикаОплаты.Добавить();
	стрЭтапОплаты.ВариантОплаты = Перечисления.ВариантыКонтроляОплатыКлиентом.КредитПослеОтгрузки;
	стрЭтапОплаты.ДатаПлатежа = Заказ.Дата;
	стрЭтапОплаты.ПроцентПлатежа = 100;
	стрЭтапОплаты.СуммаПлатежа = Сумма;
	
КонецПроцедуры

