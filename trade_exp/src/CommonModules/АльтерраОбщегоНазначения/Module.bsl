Процедура СоздатьСделку(Объект) Экспорт
	
	Если Не ЗначениеЗаполнено(Объект.Сделка) Тогда
		Сделка = Справочники.СделкиСКлиентами.СоздатьЭлемент();
		ЗаполнитьЗначенияСвойств(Сделка, Объект);
		Сделка.ВалютаПервичногоСпроса = Объект.Валюта;
		Сделка.ВидСделки = Справочники.ВидыСделокСКлиентами.НайтиПоНаименованию("Продажа");
		Сделка.ДатаНачала = ТекущаяДата();
		Сделка.ВалютаПервичногоСпроса = Объект.Валюта;
		Сделка.Комментарий = "";
		Сделка.Ответственный =  Объект.Автор;
		Сделка.ПереведенаНаУправлениеВРучную = Истина;
		Сделка.Статус = Перечисления.СтатусыСделок.ВРаботе;
		Сделка.СоглашениеСКлиентом = Объект.Соглашение;
		Сделка.ОбособленныйУчетТоваровПоСделке = Ложь;
		
		Сделка.Товары.Загрузить(Объект.Товары.Выгрузить());
		Сделка.СкидкиНаценки.Загрузить(Объект.СкидкиНаценки.Выгрузить());
		Сделка.БонусныеБаллы.Загрузить(Объект.БонусныеБаллы.Выгрузить());
		Сделка.Нарезка.Загрузить(Объект.Нарезка.Выгрузить());

		Сделка.ПотенциальнаяСуммаПродажи= Объект.СуммаДокумента;
		Сделка.Наименование = Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy")+" на сумму: "+Сделка.ПотенциальнаяСуммаПродажи;

		Сделка.Записать();
		
		Объект.Сделка = Сделка.Ссылка;
	КонецЕсли; 
	
КонецПроцедуры

