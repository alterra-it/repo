		|	""по наименованию""
		|ИЗ
		|	ВТ_Контакты КАК ВТ_Контакты
		|ГДЕ
		|	ВТ_Контакты.Партнер.НаименованиеПолное ПОДОБНО &Фамилия
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_Контакты.Партнер,
		|	ВТ_Контакты.Наименование,
		|	""по наименованию""
		|ИЗ
		|	ВТ_Контакты КАК ВТ_Контакты
		|ГДЕ
		|	ВТ_Контакты.Наименование ПОДОБНО &Фамилия2
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_Контакты.Партнер,
		|	ВТ_Контакты.Наименование,
		|	""по наименованию""
		|ИЗ
		|	ВТ_Контакты КАК ВТ_Контакты
		|ГДЕ
		|	ВТ_Контакты.Партнер.НаименованиеПолное ПОДОБНО &Фамилия2
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТ_Проверка.Партнер КАК Партнер,
		|	ВТ_Проверка.Параметр КАК Параметр,
		|	ВТ_Проверка.Проверка КАК Проверка
		|ИЗ
		|	ВТ_Проверка КАК ВТ_Проверка";
		
		Если ЗначениеЗаполнено(ПараметрыПроверки) Тогда
			Запрос.УстановитьПараметр("Партнер", Справочники.Партнеры.ПустаяСсылка());
			Запрос.УстановитьПараметр("ТипПочта", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
			Запрос.УстановитьПараметр("ТипТелефон", Перечисления.ТипыКонтактнойИнформации.Телефон);
			Запрос.УстановитьПараметр("ТипТелефон", Перечисления.ТипыКонтактнойИнформации.Телефон);
			Запрос.УстановитьПараметр("ТипАдрес", Перечисления.ТипыКонтактнойИнформации.Адрес);
			
			Наименование= ПараметрыПроверки.Наименование;
			НаименованиеПолное = ПараметрыПроверки.НаименованиеПолное;
			
			Почта = ПараметрыПроверки.Почта;
			Телефон = ПараметрыПроверки.Телефон;
			Адрес = ПараметрыПроверки.Адрес;
		Иначе
			Наименование = Партнер.Наименование;
			НаименованиеПолное = Партнер.НаименованиеПолное;
			
			Запрос.УстановитьПараметр("Партнер", Партнер);
			Запрос.УстановитьПараметр("ТипПочта", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
			Запрос.УстановитьПараметр("ТипТелефон", Перечисления.ТипыКонтактнойИнформации.Телефон);
			Запрос.УстановитьПараметр("ТипТелефон", Перечисления.ТипыКонтактнойИнформации.Телефон);
			Запрос.УстановитьПараметр("ТипАдрес", Перечисления.ТипыКонтактнойИнформации.Адрес);
			
			Почта = ПолучитьКонтактнуюИнформацию(Партнер, Справочники.ВидыКонтактнойИнформации.EmailПартнера);
			Телефон = ПолучитьКонтактнуюИнформацию(Партнер, Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
			Адрес = ПолучитьКонтактнуюИнформацию(Партнер, Справочники.ВидыКонтактнойИнформации.АдресПартнера);		
		КонецЕсли;
		
	мФИО = СтрРазделить(Наименование, " ", Ложь);
	Если мФИО.Количество() > 0 Тогда
		Фамилия = мФИО[0];
	Иначе
		Фамилия = "";
	КонецЕсли;
	Если СтрДлина(Фамилия) < 4 Тогда
		Фамилия = "";
	КонецЕсли;
	
	мФИО = СтрРазделить(НаименованиеПолное, " ", Ложь);
	Если мФИО.Количество() > 0 Тогда
		Фамилия2 = мФИО[0];
	Иначе
		Фамилия2 = "";
	КонецЕсли;
	Если СтрДлина(Фамилия2) < 4 Тогда
		Фамилия2 = "";
	КонецЕсли;

	Запрос.УстановитьПараметр("Фамилия", ?(ПустаяСтрока(Фамилия), "*************", "%"+Фамилия+"%" ));
	Запрос.УстановитьПараметр("Фамилия2", ?(ПустаяСтрока(Фамилия2), "*************", "%"+Фамилия2+"%" ));
		
	Запрос.УстановитьПараметр("Почта", ?(ПустаяСтрока(Почта), "*************", Почта ));
	Запрос.УстановитьПараметр("Телефон", ?(ПустаяСтрока(Телефон), "*************", Телефон ));
	Запрос.УстановитьПараметр("Адрес", ?(ПустаяСтрока(Адрес), "*************", Адрес ));

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	мОтветов = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Ответ = Новый Структура("Партнер, Проверка");
		ЗаполнитьЗначенияСвойств(Ответ, ВыборкаДетальныеЗаписи);
		мОтветов.Добавить(Ответ);
	КонецЦикла;
	
	Возврат мОтветов; 
	
КонецФункции

Функция ДействующийПоставщик(Контрагент) Экспорт
	
	Если РольДоступна("ПолныеПрава") Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Партнеры.Ссылка КАК Партнер,
	|	ЕстьNull(КонтрагентыДополнительныеРеквизиты.Значение,Ложь) КАК ВключенВРеестр
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
	|			ПО (Партнеры.Ссылка = ПартнерыДополнительныеРеквизиты.Ссылка)
	|		ПО (Контрагенты.Партнер = Партнеры.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты
	|		ПО (Контрагенты.ГоловнойКонтрагент = КонтрагентыДополнительныеРеквизиты.Ссылка И КонтрагентыДополнительныеРеквизиты.Свойство.Наименование = ""Добавить контрагента в Реестр Поставщиков (Контрагенты)"")
	|ГДЕ
	|	Контрагенты.Ссылка = &Контрагент                               
	|   И ПартнерыДополнительныеРеквизиты.Свойство.Наименование = ""Тип поставщика (Поставщики)""
	|   И ПартнерыДополнительныеРеквизиты.Значение.Наименование = ""Поставщик товаров""";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);  
	
	РезультатЗапроса = Запрос.Выполнить();             	
	Выборка = РезультатЗапроса.Выбрать(); 
	Если Выборка.Следующий() Тогда //Это поставщик товаров
		Если Выборка.ВключенВРеестр ТОгда 
			Возврат Истина; 
		Иначе
			Возврат Ложь; 
		КонецЕсли; 
	Иначе //Это не поставщик товаров
		Возврат Истина;    
	КонецЕсли;

КонецФункции // ДействующийПоставщик()
#КонецОбласти

