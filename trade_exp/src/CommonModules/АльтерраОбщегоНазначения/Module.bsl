Функция ПолучитьОстаткиПоСкладу(Склад) Экспорт
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
		|	НоменклатураСпр.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ЗапасыИПотребностиОстатки.ВНаличииОстаток КАК Количество,
		|	ЗапасыИПотребностиОстатки.ВНаличииОстаток КАК КоличествоУпаковок
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(, Склад = &Склад) КАК ЗапасыИПотребностиОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
		|		ПО ЗапасыИПотребностиОстатки.Номенклатура = НоменклатураСпр.Ссылка
		|ГДЕ
		|	ЗапасыИПотребностиОстатки.ВНаличииОстаток > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	НоменклатураСпр.Наименование");  
	
	Запрос.УстановитьПараметр("Склад", Склад);
