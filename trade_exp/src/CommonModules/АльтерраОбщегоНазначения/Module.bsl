Функция ПолчитьТелефонБезКода(Знач НомерТелефона) Экспорт
	
	ПривестиКФорматуНомерТелефона(НомерТелефона);
	
	Возврат НомерТелефона; 
	
КонецФункции

Процедура ПривестиКФорматуНомерТелефона(НомерТелефона, НомерТелефонаБезКода="", Представление="", КодСтраны="", КодГорода="", Префикс="")   Экспорт
	
	Изменен = Ложь;
	СтарыйНомер = НомерТелефона;
	
	НомерТелефона = СокрЛП(НомерТелефона);
	НомерТелефона = СтрЗаменить(НомерТелефона, "-", "");
	НомерТелефона = СтрЗаменить(НомерТелефона, "_", "");
	НомерТелефона = СтрЗаменить(НомерТелефона, "(", "");
	НомерТелефона = СтрЗаменить(НомерТелефона, ")", "");
	НомерТелефона = СтрЗаменить(НомерТелефона, " ", "");
	НомерТелефона = СокрЛП(НомерТелефона);
	
	Если ПустаяСтрока(НомерТелефона) Тогда
		НомерТелефонаБезКода = "";
		НомерТелефона = "";
		КодСтраны = "";
		Представление = "";
		КодСтраны = "";
		КодГорода = "";
		Возврат;
	КонецЕсли;
	
	ДлиннаТелефона = СтрДлина(НомерТелефона);
	ПервыйСимвол = Лев(НомерТелефона, 1);
	
	Если ДлиннаТелефона = 12 Тогда
		Если Лев(НомерТелефона, 2) = "+7" Тогда
			НомерТелефона = Прав(НомерТелефона, 10);
			Изменен = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ДлиннаТелефона = 11 Тогда
		Если  ПервыйСимвол = "8" ИЛИ ПервыйСимвол = "7"  Тогда
			НомерТелефона = Прав(НомерТелефона, 10);
			Изменен = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ДлиннаТелефона = 10 Тогда
		Если  ПервыйСимвол = "9" Тогда
			НомерТелефона = НомерТелефона;
			Изменен = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если Изменен Тогда
		НомерТелефонаБезКода = НомерТелефона;
		НомерТелефона = Префикс + НомерТелефона;
		Представление = Префикс + НомерТелефона;
		КодСтраны = Префикс;
		КодГорода = "";
	Иначе
		НомерТелефона = СтарыйНомер;
		Представление = СтарыйНомер;
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьФорматированныйТелефон(Знач НомерТелефона) Экспорт
	
	НомерТелефона = ПолчитьТелефонБезКода(НомерТелефона);
	
	Если СтрДлина(НомерТелефона) = 10 Тогда
		мСлов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(НомерТелефона);
		Первые3 = Лев(НомерТелефона, 3);
		Второые3 = Сред(НомерТелефона, 4, 3);
		Первые2 = Сред(НомерТелефона, 7, 2);
		Вторые2 = Прав(НомерТелефона, 2);
		
		Возврат "" + Первые3 + "-" + Второые3 + "-" + Первые2 + "-" + Вторые2;
	Иначе
		Возврат НомерТелефона;
	КонецЕсли;
	
КонецФункции

Процедура ЗаполнитьПочтуИТелефонВКлиентеПоКомментарию(Знач Ссылка)  Экспорт
	
	Комментарий = Ссылка.Комментарий;
	
	Позиция = Найти(Комментарий, "E-Mail:");
	Если Позиция = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	мСтрок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Комментарий, Строка(Символы.ПС), Ложь, Истина);
	
	//Получаем почту и телефон из коментария
	Для Каждого стрКомментария Из мСтрок Цикл
		стрКомментария = СокрЛП(стрКомментария);
		ДлинаСтроки = СтрДлина(стрКомментария);
		Если Найти(стрКомментария, "E-Mail:") > 0 Тогда 
			Позиция = Найти(стрКомментария, ":");
			Почта = СокрЛП(Прав(стрКомментария, ДлинаСтроки-Позиция));
		КонецЕсли;
		
		Если Найти(стрКомментария, "Телефон:") > 0 Тогда 
			Позиция = Найти(стрКомментария, ":");
			Телефон = СокрЛП(Прав(стрКомментария, ДлинаСтроки-Позиция));
		КонецЕсли;
		
		Если Не ПустаяСтрока(Почта) И Не ПустаяСтрока(Телефон) Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	//Записываем в клиента
	Если  Не ПустаяСтрока(Почта) ИЛИ Не ПустаяСтрока(Телефон) Тогда
		ЗаполнитьКонтактыВКлиенте(Ссылка, Почта, Телефон);
	КонецЕсли; 
	
КонецПроцедуры

Процедура ЗаполнитьКонтактыВКлиенте(Ссылка, Почта, Телефон)

	Если ЗначениеЗаполнено(Ссылка.Партнер) И НЕ Ссылка.Партнер.ПометкаУдаления Тогда
		
		Попытка
			Если Не ПустаяСтрока(Почта) Тогда
				
				ЕстьПочта = Ложь;
				ПочтаСовпадает = Ложь;
				УжеЕстьПочтаУПартнера(Ссылка.Партнер, Почта, ЕстьПочта, ПочтаСовпадает);
				
				Если ЕстьПочта = Ложь ИЛИ ПочтаСовпадает Тогда 
					СтруктураКИ = Новый Структура("Представление,АдресЭП", Почта,Почта);
					УправлениеКонтактнойИнформацией.ЗаполнитьКонтактнуюИнформациюОбъекта(Ссылка.Партнер, Справочники.ВидыКонтактнойИнформации.EmailПартнера, СтруктураКИ, "АдресЭП");
					
					Если Не ПустаяСтрока(Телефон) Тогда
						СтруктураКИ = Новый Структура("НомерТелефона",  Телефон);
						УправлениеКонтактнойИнформацией.ЗаполнитьКонтактнуюИнформациюОбъекта(Ссылка.Партнер, Справочники.ВидыКонтактнойИнформации.ТелефонПартнера, СтруктураКИ, "Телефон");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ссылка.Контрагент) И НЕ Ссылка.Контрагент.ПометкаУдаления Тогда
		Попытка
			Если Не ПустаяСтрока(Почта) Тогда			
				Если ЕстьПочта = Ложь ИЛИ ПочтаСовпадает Тогда 
					СтруктураКИ = Новый Структура("Представление", Почта);
					УправлениеКонтактнойИнформацией.ЗаполнитьКонтактнуюИнформациюОбъекта(Ссылка.Контрагент, Справочники.ВидыКонтактнойИнформации.EmailКонтрагента, СтруктураКИ, "АдресЭП");
					Если Не ПустаяСтрока(Телефон) Тогда
						СтруктураКИ = Новый Структура("Представление", Телефон);
						УправлениеКонтактнойИнформацией.ЗаполнитьКонтактнуюИнформациюОбъекта(Ссылка.Контрагент, Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента, СтруктураКИ, "Телефон");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

Функция УжеЕстьТелефон(Партнер)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыКонтактнаяИнформация.Ссылка,
		|	ПартнерыКонтактнаяИнформация.Тип,
		|	ПартнерыКонтактнаяИнформация.НомерТелефона
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Ссылка = &Ссылка
		|	И ПартнерыКонтактнаяИнформация.Тип = &Тип";
	
	Запрос.УстановитьПараметр("Ссылка", Партнер);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Не ПустаяСтрока(ВыборкаДетальныеЗаписи.НомерТелефона) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

