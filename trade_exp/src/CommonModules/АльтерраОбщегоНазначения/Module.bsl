#Область Партнеры  

Функция СоздатьПартнера(ДанныеПартнера) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПартнерОбъект = Справочники.Партнеры.СоздатьЭлемент();
	ЮрФизЛицо =  Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;
	
	//Область Партнер	  
	ПартнерОбъект.Клиент = Истина;
	ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;
	Если ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо тогда
		ПартнерОбъект.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания;
	Иначе
		ПартнерОбъект.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;
	КонецЕсли;
	
	ПартнерОбъект.ДатаРегистрации 	 = ТекущаяДата();
	ПартнерОбъект.Комментарий 		 = ДанныеПартнера.Комментарий;
	ПартнерОбъект.Наименование 		 = ДанныеПартнера.Наименование;
	ПартнерОбъект.НаименованиеПолное = ДанныеПартнера.Наименование;
	ПартнерОбъект.БонуснаяПрограммаАктивна = ДанныеПартнера.БонуснаяПрограммаАктивна;
	Если ДанныеПартнера.БонуснаяПрограммаАктивна = Истина Тогда
		ПартнерОбъект.ДатаАктивацииБонуснойПрограммы = ТекущаяДата();
	КонецЕсли;
	ПартнерОбъект.ДатаРождения = ДанныеПартнера.ДатаРождения;
	
	ЗаполнитьКонтакты(ПартнерОбъект, ДанныеПартнера.Телефон, ДанныеПартнера.Почта);
	
	Попытка
		ПартнерОбъект.Записать();
		Партнер = ПартнерОбъект.Ссылка;
		ЗаписьЖурналаРегистрации("Создание клиентов с сайта", УровеньЖурналаРегистрации.Информация, , , "создан партенр: "+Партнер);		
	Исключение
		Ошибка = "Ошибка создание партнера с сайта";
		Сообщить(Ошибка);
		ЗаписьЖурналаРегистрации("Создание клиентов с сайта", УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		Возврат Ошибка;
	КонецПопытки;
	
	//шруппа партнеров
	Владелец = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров");
	Значение = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Частные лица", Истина, , Владелец);
	АльтерраОбщегоНазначения.УстановитьДополнительныйРеквизит(Партнер, "Группы партнеров", Значение);
	
	//согласее на обработку
	Значение = Истина;
	АльтерраОбщегоНазначения.УстановитьДополнительныйРеквизит(Партнер, "Согласие на получение информационной рассылки", Значение);
	
	//статус
	БонусыАльтерра.ОбновитьСтатусВРегистре(Партнер, Справочники.СтатусыПартнеровВПрограммеЛояльности_Альтерра.Умелец);
	
	//Сегмент
	Сегмент = Справочники.СегментыПартнеров.НайтиПоНаименованию("Бонусные карты", Истина);
	Если ЗначениеЗаполнено(Сегмент) Тогда
		СегментыСервер.ДобавитьПартнераВСегмент(Сегмент, Партнер);
	КонецЕсли;
	
	//Область Контрагент
	КонтрагентОбъект = Справочники.Контрагенты.СоздатьЭлемент();
	
	КонтрагентОбъект.Партнер = Партнер;
	КонтрагентОбъект.Наименование = Партнер.Наименование;
	КонтрагентОбъект.НаименованиеПолное	= Партнер.Наименование;
	
	Если ЮрФизЛицо 	= Перечисления.ЮрФизЛицо.ЮрЛицо тогда
		КонтрагентОбъект.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;	
		КонтрагентОбъект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
	Иначе
		КонтрагентОбъект.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;	
		КонтрагентОбъект.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
	КонецЕсли;
	
	ЗаполнитьКонтакты(КонтрагентОбъект, ДанныеПартнера.Телефон, ДанныеПартнера.Почта);
	
	Попытка
		КонтрагентОбъект.Записать();
		Контрагент = КонтрагентОбъект.Ссылка;
		ЗаписьЖурналаРегистрации("Создание клиентов с сайта", УровеньЖурналаРегистрации.Информация, , , "создан контрагент: "+Контрагент);
	Исключение
		Ошибка = "Ошибка создание контрагента с сайта";
		Сообщить(Ошибка);
		ЗаписьЖурналаРегистрации("Создание клиентов с сайта", УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		Возврат Ошибка;
	КонецПопытки;
	
	//создание записи об источнике первичного интереса
	ЗаписьОбИсточникеПервичногоИнтереса = РегистрыСведений.ИсточникиПервичногоИнтереса.СоздатьМенеджерЗаписи();
	ЗаписьОбИсточникеПервичногоИнтереса.Партнер = Партнер;
	ЗаписьОбИсточникеПервичногоИнтереса.КаналПервичногоИнтереса = ПланыВидовХарактеристик.КаналыРекламныхВоздействий.НайтиПоНаименованию("Интернет-сайт");
	Попытка 
		ЗаписьОбИсточникеПервичногоИнтереса.Записать();
		ЗаписьЖурналаРегистрации("Создание клиентов с сайта", УровеньЖурналаРегистрации.Информация, , , "заполнен канал первичного интереса.");
	Исключение
		Ошибка = "Ошибка заполнения канала первичного интереса у клиента с сайта";
		Сообщить(Ошибка);
		ЗаписьЖурналаРегистрации("Создание клиентов с сайта", УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		Возврат Ошибка;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Партнер;
	
КонецФункции  

Процедура ЗаполнитьКонтакты(Объект, Телефон, Почта) Экспорт	
	
	Представление = "";
	ПривестиКФорматуНомерТелефона(Телефон, , Представление);
	
	Если ТипЗнч(Объект) = Тип("СправочникОбъект.Контрагенты") Тогда
		лПочта      = Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
		лТелефон	= Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
	ИначеЕсли ТипЗнч(Объект) = Тип("СправочникОбъект.Партнеры") Тогда
		лПочта      = Справочники.ВидыКонтактнойИнформации.EmailПартнера;
		лТелефон	= Справочники.ВидыКонтактнойИнформации.ТелефонПартнера;
	ИначеЕсли ТипЗнч(Объект) = Тип("СправочникОбъект.ФизическиеЛица") Тогда
		лПочта      = Справочники.ВидыКонтактнойИнформации.EMailФизическиеЛица;
		лТелефон	= Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица;
	Иначе
		Возврат;
	КонецЕсли;
	
	
	НовКонтакт 					= Объект.КонтактнаяИнформация.Добавить();
	НовКонтакт.Тип 				= Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	НовКонтакт.Вид 				= лПочта;
	НовКонтакт.Представление 	= Почта;
	НовКонтакт.АдресЭП		 	= Почта;
	ОбъектКонтактнойИнформации = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(НовКонтакт.Представление, лПочта);
	НовКонтакт.Значение = УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(ОбъектКонтактнойИнформации);
	НовКонтакт.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияВXML(НовКонтакт.Значение);
	
	НовКонтакт 					= Объект.КонтактнаяИнформация.Добавить();
	НовКонтакт.Тип 				= Перечисления.ТипыКонтактнойИнформации.Телефон;
	НовКонтакт.Вид 				= лТелефон;
	НовКонтакт.Представление 	= Представление;
	НовКонтакт.НомерТелефона 	= Телефон;
	НовКонтакт.НомерТелефонаБезКодов = "";
	ОбъектКонтактнойИнформации = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(НовКонтакт.Представление, лТелефон);
	НовКонтакт.Значение = УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(ОбъектКонтактнойИнформации);
	НовКонтакт.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияВXML(НовКонтакт.Значение);

КонецПроцедуры


Процедура ОбновитьДанныеПартнера(Партнер, ФИО, ДР, Телефон, Почта) Экспорт
	
	Если ЗначениеЗаполнено(ДР) Тогда
		Партнер.ДатаРождения = Дата(ДР); 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ФИО) Тогда
		Партнер.Наименование = ФИО;
		Партнер.НаименованиеПолное = ФИО;
	КонецЕсли;
	
	Коллекция = Партнер.КонтактнаяИнформация;
	ПараметрыОтбора = Новый Структура("Тип, Вид");
	
	Если ЗначениеЗаполнено(Почта) Тогда		
		Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		Вид = Справочники.ВидыКонтактнойИнформации.EmailПартнера;
		
		ПараметрыОтбора.Тип = Тип;
		ПараметрыОтбора.Вид = Вид;
		МассивНайденныхСтроки = Коллекция.НайтиСтроки(ПараметрыОтбора);
		
		Для Каждого Строка Из МассивНайденныхСтроки Цикл
			Коллекция.Удалить(Строка);
		КонецЦикла;
		
		НовКонтакт 				 = Коллекция.Добавить();
		НовКонтакт.Тип 			 = Тип;
		НовКонтакт.Вид 			 = Вид;
		НовКонтакт.Представление = Почта;
		НовКонтакт.АдресЭП		 = Почта;
		НовКонтакт.ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(Почта, Вид);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Телефон) Тогда
		Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
		Вид = Справочники.ВидыКонтактнойИнформации.ТелефонПартнера;
		
		ПараметрыОтбора.Тип = Тип;
		ПараметрыОтбора.Вид = Вид;
		МассивНайденныхСтроки = Коллекция.НайтиСтроки(ПараметрыОтбора);
		
		Для Каждого Строка Из МассивНайденныхСтроки Цикл
			Коллекция.Удалить(Строка);
		КонецЦикла;

		Представление = "";
		ПривестиКФорматуНомерТелефона(Телефон, , Представление);
		
		НовКонтакт 						 = Коллекция.Добавить();
		НовКонтакт.Тип 					 = Тип;
		НовКонтакт.Вид 					 = Вид;
		НовКонтакт.Представление 		 = Представление;
		НовКонтакт.НомерТелефона 		 = Телефон;
		НовКонтакт.НомерТелефонаБезКодов = "";
		НовКонтакт.ЗначенияПолей		 = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(Представление, Вид);
	КонецЕсли; 
	
КонецПроцедуры

Функция АктивироватьПартнера(Партнер) Экспорт
	
	ПартнерОбъект = Партнер.ПолучитьОбъект();
	ПартнерОбъект.БонуснаяПрограммаАктивна= Истина;
	ПартнерОбъект.ДатаАктивацииБонуснойПрограммы= ТекущаяДата();
	
	Попытка
		ПартнерОбъект.Записать();
		ЗаписьЖурналаРегистрации("Создание активация партнера", УровеньЖурналаРегистрации.Информация, , , "успешно");
	Исключение
		Ошибка = "Ошибка создание партнера с сайта";
		Сообщить(Ошибка);
		ЗаписьЖурналаРегистрации("Создание активация партнера", УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
		Возврат Ложь;
	КонецПопытки;

	Возврат Истина; 
	
