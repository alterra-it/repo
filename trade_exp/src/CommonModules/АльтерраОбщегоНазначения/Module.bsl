Функция ПолучитьСоглашениеПоУмолчаниюЧЕКСтарый(Партнер, Подразделение, КартаЛояльности = Неопределено) Экспорт	
	
	Если ЗначениеЗаполнено(Партнер) Тогда		
		Если Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо тогда
			Если Партнер = Справочники.Партнеры.РозничныйПокупатель Тогда
				Возврат ПолучитьСоглашениеЦенаБезКарты(Подразделение);
			Иначе
				
				Если ЗначениеЗаполнено(КартаЛояльности) Тогда
					Если КартаЛояльности.Соглашение.Статус = Перечисления.СтатусыСоглашенийСКлиентами.Действует тогда 
						Возврат КартаЛояльности.Соглашение;
					Иначе
						Возврат Справочники.КартыЛояльности.ПустаяСсылка();
					КонецЕсли;
				Иначе
					Возврат ПолучитьСоглашениеЦенаПоКарте(Подразделение);
				КонецЕсли;
			КонецЕсли;
		Иначе
			Возврат ПолучитьСоглашениеЮрЛицаЧЕК(Партнер);
			
		КонецЕсли;
	Иначе
		Возврат ПолучитьСоглашениеЦенаБезКарты(Подразделение);
	КонецЕсли;
	
