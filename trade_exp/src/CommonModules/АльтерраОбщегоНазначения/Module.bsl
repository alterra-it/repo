#Область Очередь
Функция РассчитатьОчередь(Знач Объект)  Экспорт
	//1. Если частное лицо = Розница
	//2. Не частное лицо
	//2.1 Вычисляем коэф. по весу	
	//2.2 Вычисляем коэф. по кол-ву секций
	//2.3 Вычисляем коэф. по кол-ву позиций
	
	//1
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Если Объект.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо Тогда
			Возврат Перечисления.Очередь.Очередь2;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Если Объект.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
			Возврат Перечисления.Очередь.Очередь2;
		КонецЕсли;
	КонецЕсли;
	
	//2	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ВЫРАЗИТЬ(Товары.Упаковка КАК Справочник.УпаковкиЕдиницыИзмерения) КАК Упаковка,
	|	Товары.КоличествоУпаковок,
	|	ВЫРАЗИТЬ(Товары.Склад КАК Справочник.Склады) КАК Склад
	|ПОМЕСТИТЬ Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	|	Товары.Номенклатура,
	|	Товары.КоличествоУпаковок,
	|	ЕСТЬNULL(ВЫБОР
	|			КОГДА Товары.Номенклатура.ИспользоватьУпаковки = ЛОЖЬ
	|					ИЛИ ЕСТЬNULL(Товары.Упаковка.ЕдиницаИзмерения, ИСТИНА) = ИСТИНА
	|				ТОГДА Товары.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры
	|			ИНАЧЕ Товары.Упаковка.Вес * Товары.КоличествоУпаковок
	|		КОНЕЦ, 0) КАК Вес
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО (ИСТИНА = РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)
	|			И Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|ГДЕ
	|	Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_Товары.Секция) КАК КолСекций,
	|	СУММА(ЕСТЬNULL(ВТ_Товары.Вес, 0)) КАК Вес,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_Товары.Номенклатура) КАК КолПозиций
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары" ;
	
	Товары= Объект.Товары.Выгрузить(,"Номенклатура,Склад,Упаковка,КоличествоУпаковок");
	Запрос.УстановитьПараметр("Товары", Товары);
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товары.Номенклатура.ЕдиницаИзмерения",
	"Товары.Номенклатура"));
	
	ПакетРезультатов= Запрос.ВыполнитьПакет();
	
	Если ПакетРезультатов[1].Выгрузить()[0].Количество = 0 Тогда
		Очередь= Перечисления.Очередь.Очередь2;
	Иначе
		Выборка= ПакетРезультатов[2].Выбрать();
		Выборка.Следующий();
		
		Вес= Выборка.Вес;
		КолСекций= Выборка.КолСекций;
		КолПозиций= Выборка.КолПозиций;
		
		//Расчет
		Если Вес >= 0 И Вес < 300 Тогда
			Коэффициент1= 1;
		ИначеЕсли Вес >= 300 И Вес < 1500 Тогда
			Коэффициент1= 2;
		Иначе
			Коэффициент1= 3;
		КонецЕсли;
		
		Если КолСекций <= 1  Тогда
			Коэффициент2= 1;
		ИначеЕсли КолСекций = 2  Тогда
			Коэффициент2= 2;
		Иначе
			Коэффициент2= 3;
		КонецЕсли;
		
		Если КолПозиций >= 1 И КолПозиций < 3 Тогда
			Коэффициент3= 1;
		ИначеЕсли КолПозиций >= 3 И КолПозиций < 50 Тогда
			Коэффициент3= 2;
		Иначе
			Коэффициент3= 3;
		КонецЕсли;
		
		СуммаКоэффициентов= Коэффициент1+Коэффициент2+Коэффициент3;
		Если СуммаКоэффициентов <= 5 Тогда
			Очередь= Перечисления.Очередь.Очередь2;//Розница
		Иначе
			Очередь= Перечисления.Очередь.Очередь1;//ОПТ
		КонецЕсли;
	КонецЕсли;
	
	Возврат Очередь;  
	
КонецФункции
