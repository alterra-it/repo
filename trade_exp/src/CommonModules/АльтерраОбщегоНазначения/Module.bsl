Функция ПолучитьКорректировкуНазначения(ВозвратИлиКорректировкаИлиПриходныйОрдер, СтатусПроведен, СтатусПометкаУдаления) Экспорт
	
	МассивКорректировокНазначения = Новый Массив;
	
	Если ВозвратИлиКорректировкаИлиПриходныйОрдер <> Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
			|ГДЕ
			|	ПриходныйОрдерНаТовары.Распоряжение = &ВозвратИлиКорректировка
			|	И ПриходныйОрдерНаТовары.Проведен = &СтатусПроведен
			|	И ПриходныйОрдерНаТовары.ПометкаУдаления = &СтатусПометкаУдаления";
		
		Запрос.УстановитьПараметр("ВозвратИлиКорректировка", ВозвратИлиКорректировкаИлиПриходныйОрдер);
		Запрос.УстановитьПараметр("СтатусПроведен", СтатусПроведен);
		Запрос.УстановитьПараметр("СтатусПометкаУдаления", СтатусПометкаУдаления);
		
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			НаличиеКорректировки = ПолучитьКорректировкуНазначения(Выборка.Ссылка, СтатусПроведен, СтатусПометкаУдаления);
			Если ЗначениеЗаполнено(НаличиеКорректировки) Тогда
				МассивКорректировокНазначения.Добавить(НаличиеКорректировки);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВозвратТоваровОтКлиента.Ссылка КАК Ссылка,
		|	ВозвратТоваровОтКлиента.ДокументРеализации.ЗаказКлиента.Организация КАК Организация,
		|	Назначения.Ссылка КАК Назначение
		|ПОМЕСТИТЬ Возврат
		|ИЗ
		|	Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваровОтКлиента
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК Назначения
		|		ПО ВозвратТоваровОтКлиента.ДокументРеализации.ЗаказКлиента = Назначения.Заказ
		|ГДЕ
		|	ВозвратТоваровОтКлиента.ДокументРеализации.ЗаказКлиента <> ЗНАЧЕНИЕ(Документ.ЗаказКлиента.ПустаяСсылка)
		|	И ВозвратТоваровОтКлиента.ДокументРеализации.ЗаказКлиента ССЫЛКА Документ.ЗаказКлиента
		|	И ВозвратТоваровОтКлиента.Ссылка = &ВозвратИлиКорректировкаИлиПриходныйОрдер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КорректировкаРеализации.Ссылка,
		|	КорректировкаРеализации.ДокументОснование.ЗаказКлиента.Организация,
		|	Назначения.Ссылка
		|ИЗ
		|	Документ.КорректировкаРеализации КАК КорректировкаРеализации
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК Назначения
		|		ПО КорректировкаРеализации.ДокументОснование.ЗаказКлиента = Назначения.Заказ
		|ГДЕ
		|	КорректировкаРеализации.ДокументОснование.ЗаказКлиента <> ЗНАЧЕНИЕ(Документ.ЗаказКлиента.ПустаяСсылка)
		|	И КорректировкаРеализации.ДокументОснование.ЗаказКлиента ССЫЛКА Документ.ЗаказКлиента
		|	И КорректировкаРеализации.Ссылка = &ВозвратИлиКорректировкаИлиПриходныйОрдер
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПриходныйОрдерНаТовары.Ссылка,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(ПриходныйОрдерНаТовары.Распоряжение) = ТИП(Документ.КорректировкаРеализации)
		|			ТОГДА ПриходныйОрдерНаТовары.Распоряжение.ДокументОснование.ЗаказКлиента.Организация
		|		КОГДА ТИПЗНАЧЕНИЯ(ПриходныйОрдерНаТовары.Распоряжение) = ТИП(Документ.ВозвратТоваровОтКлиента)
		|			ТОГДА ПриходныйОрдерНаТовары.Распоряжение.ДокументРеализации.ЗаказКлиента.Организация
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|	КОНЕЦ,
		|	Назначения.Ссылка
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК Назначения
		|		ПО (ПриходныйОрдерНаТовары.Распоряжение.ДокументОснование.ЗаказКлиента = Назначения.Заказ
		|				ИЛИ ПриходныйОрдерНаТовары.Распоряжение.ДокументРеализации.ЗаказКлиента = Назначения.Заказ)
		|ГДЕ
		|	((ПриходныйОрдерНаТовары.Распоряжение.ДокументОснование.ЗаказКлиента <> ЗНАЧЕНИЕ(Документ.ЗаказКлиента.ПустаяСсылка)
		|				И ПриходныйОрдерНаТовары.Распоряжение.ДокументОснование.ЗаказКлиента ССЫЛКА Документ.ЗаказКлиента)
		|			ИЛИ (ПриходныйОрдерНаТовары.Распоряжение.ДокументРеализации.ЗаказКлиента <> ЗНАЧЕНИЕ(Документ.ЗаказКлиента.ПустаяСсылка)
		|				И ПриходныйОрдерНаТовары.Распоряжение.ДокументРеализации.ЗаказКлиента ССЫЛКА Документ.ЗаказКлиента))
		|	И ПриходныйОрдерНаТовары.Ссылка = &ВозвратИлиКорректировкаИлиПриходныйОрдер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Возврат.Ссылка КАК Возврат,
		|	Корректировка.Ссылка КАК Корректировка,
		|	Корректировка.Назначение КАК Назначение
		|ПОМЕСТИТЬ Итог
		|ИЗ
		|	Документ.КорректировкаНазначенияТоваров КАК Корректировка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Возврат КАК Возврат
		|		ПО (ИСТИНА)
		|ГДЕ
		|	(Корректировка.Назначение, Корректировка.Организация) В
		|			(ВЫБРАТЬ
		|				Возврат.Назначение,
		|               Возврат.Организация
		|			ИЗ
		|				Возврат)
		|	И Корректировка.Проведен = &СтатусПроведен
		|	И Корректировка.ПометкаУдаления = &СтатусПометкаУдаления
		|   И Корректировка.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийКорректировкиНазначения.СнятьРезерв)
		|   И НЕ Корректировка.Ссылка В (&МассивКорректировокНазначения)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВозвратТовары.Номенклатура КАК Номенклатура,
		|	СУММА(ВЫБОР
		|			КОГДА ВозвратТовары.Количество >= 0
		|				ТОГДА ВозвратТовары.Количество
		|			ИНАЧЕ -ВозвратТовары.Количество
		|		КОНЕЦ) КАК Количество
		|ПОМЕСТИТЬ ВозвратТовары
		|ИЗ
		|	Документ." + ВозвратИлиКорректировкаИлиПриходныйОрдер.Метаданные().Имя +
		?(ТипЗнч(ВозвратИлиКорректировкаИлиПриходныйОрдер) = Тип("ДокументСсылка.КорректировкаРеализации"), ".Расхождения", ".Товары") +
		" КАК ВозвратТовары
		|ГДЕ
		|	(ВозвратТовары.Ссылка, ВозвратТовары.Назначение) В
		|			(ВЫБРАТЬ
		|				Итог.Возврат,
		|				Итог.Назначение
		|			ИЗ
		|				Итог)
		|	И ВозвратТовары.Количество <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ВозвратТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КОЛИЧЕСТВО(ВозвратТовары.Номенклатура) КАК Номенклатура,
		|	СУММА(ВозвратТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ ВозвратИтоги
		|ИЗ
		|	ВозвратТовары КАК ВозвратТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КорректировкаТовары.Ссылка КАК Ссылка,
		|	КорректировкаТовары.Номенклатура КАК Номенклатура,
		|	СУММА(КорректировкаТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ КорректировкаТовары
		|ИЗ
		|	Документ.КорректировкаНазначенияТоваров.Товары КАК КорректировкаТовары
		|ГДЕ
		|	(КорректировкаТовары.Ссылка, КорректировкаТовары.ИсходноеНазначение) В
		|			(ВЫБРАТЬ
		|				Итог.Корректировка,
		|               Итог.Назначение
		|			ИЗ
		|				Итог)
		|	И КорректировкаТовары.Количество <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	КорректировкаТовары.Ссылка,
		|	КорректировкаТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КорректировкаТовары.Ссылка КАК Ссылка,
		|	КОЛИЧЕСТВО(КорректировкаТовары.Номенклатура) КАК Номенклатура,
		|	СУММА(КорректировкаТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ КорректировкаИтоги
		|ИЗ
		|	КорректировкаТовары КАК КорректировкаТовары
		|
		|СГРУППИРОВАТЬ ПО
		|	КорректировкаТовары.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КорректировкаТовары.Ссылка КАК Ссылка,
		|	КОЛИЧЕСТВО(КорректировкаТовары.Номенклатура) КАК Номенклатура,
		|	СУММА(КорректировкаТовары.Количество) КАК Количество,
		|	МИНИМУМ(Возврат.Номенклатура) КАК ВозвратНоменклатура,
		|	МИНИМУМ(Возврат.Количество) КАК ВозвратКоличество,
		|	МИНИМУМ(Корректировка.Номенклатура) КАК КорректировкаНоменклатура,
		|	МИНИМУМ(Корректировка.Количество) КАК КорректировкаКоличество
		|ПОМЕСТИТЬ ПредварительныйИтог
		|ИЗ
		|	КорректировкаТовары КАК КорректировкаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвратИтоги КАК Возврат
		|		ПО (ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ КорректировкаИтоги КАК Корректировка
		|		ПО КорректировкаТовары.Ссылка = Корректировка.Ссылка
		|ГДЕ
		|	(КорректировкаТовары.Номенклатура, КорректировкаТовары.Количество) В
		|			(ВЫБРАТЬ
		|				ВозвратТовары.Номенклатура,
		|				ВозвратТовары.Количество
		|			ИЗ
		|				ВозвратТовары)
		|
		|СГРУППИРОВАТЬ ПО
		|	КорректировкаТовары.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПредварительныйИтог.Ссылка КАК Ссылка
		|ИЗ
		|	ПредварительныйИтог КАК ПредварительныйИтог
		|ГДЕ
		|	ПредварительныйИтог.Номенклатура = ПредварительныйИтог.ВозвратНоменклатура
		|	И ПредварительныйИтог.Номенклатура = ПредварительныйИтог.КорректировкаНоменклатура
		|	И ПредварительныйИтог.Количество = ПредварительныйИтог.ВозвратКоличество
		|	И ПредварительныйИтог.Количество = ПредварительныйИтог.КорректировкаКоличество";
	
	Запрос.УстановитьПараметр("ВозвратИлиКорректировкаИлиПриходныйОрдер", ВозвратИлиКорректировкаИлиПриходныйОрдер);
	Запрос.УстановитьПараметр("СтатусПроведен", СтатусПроведен);
	Запрос.УстановитьПараметр("СтатусПометкаУдаления", СтатусПометкаУдаления);
	Запрос.УстановитьПараметр("МассивКорректировокНазначения", МассивКорректировокНазначения);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Если РезультатЗапроса.Следующий() Тогда
		Возврат РезультатЗапроса.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьНалогообложениеНДС(Организация) Экспорт
	
	ПрименяетсяУСН = УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(Организация, ТекущаяДата());

	Если ПрименяетсяУСН Тогда//МУД
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;
	Иначе
		НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
	КонецЕсли;
	
	Возврат НалогообложениеНДС; 
	
КонецФункции

Функция ПолучитьСтавкуНДСФилиала(Организация) Экспорт
	
	ПрименяетсяУСН = УчетнаяПолитикаПереопределяемый.ПрименяетсяУСН(Организация, ТекущаяДата());
	Если ПрименяетсяУСН Тогда
		Возврат Перечисления.СтавкиНДС.БезНДС;
	Иначе
		Возврат УчетНДСУП.СтавкаНДСПоУмолчанию(Организация);
	КонецЕсли; 
	
КонецФункции

Процедура ПроверитьКассыОрганизаций(Источник, Отказ) Экспорт 
	
	КассаВладелец = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.Касса, "Владелец"); 

	Если Источник.Организация <> КассаВладелец Тогда
		Сообщить("Касса организации не соответствует организации по документу!");
		Отказ = Истина; 
		
	ИначеЕсли ЗначениеЗаполнено(Источник.ДокументОснование) И 
		ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Источник.ДокументОснование, "Организация") <> КассаВладелец Тогда
		
		Сообщить("Касса организации не соответствует организации документу основанию!");
		Отказ = Истина;	 	
	КонецЕсли; 

КонецПроцедуры

Функция ПолучитьСтатусКартыЛояльностиДействует() Экспорт
    Возврат Перечисления.СтатусыКартЛояльности.Действует;
