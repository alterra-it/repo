		Телефон2 = Контакты.НомерТелефона;
		Примечание2 = УправлениеКонтактнойИнформацией.КомментарийКонтактнойИнформации(Контакты.ЗначенияПолей);
	Иначе
		Телефон2 = "";
		Примечание2 = "";
	КонецЕсли;
	
	Вид = Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Телефон 3", Истина, Родитель);
	Контакты = АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформациюИПримечания(Партнер, Вид);
