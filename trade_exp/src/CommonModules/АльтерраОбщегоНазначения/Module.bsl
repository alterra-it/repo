	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыСоглашенийСКлиентами.Действует);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Соглашение;
	КонецЕсли;
	
	Возврат Неопределено; 
	
КонецФункции 

Функция ПолучитьСоглашениеПоУмолчанию(Партнер, Подразделение, КартаЛояльности = Неопределено, ДатаДействия = Неопределено) Экспорт	
	
	УстановитьПривилегированныйРежим(Истина);	      
	
	Если ДатаДействия = Неопределено Тогда 
		ДатаДействия = ТекущаяДата();
	КонецЕсли;	
	Если ЭтоБригадир(Партнер) и не ДопМодуль.НовоеЦенообразование() Тогда
		Возврат Константы.СоглашениеДляБригадиров.Получить();
	КонецЕсли; 	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СоглашенияСКлиентами.Ссылка КАК Соглашение,
			|	СоглашенияСКлиентами.СегментПартнеров КАК СегментПартнеров,
			|	&Партнер КАК Партнер
			|ПОМЕСТИТЬ ВР
			|ИЗ
			|	Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
			|ГДЕ
			|	СоглашенияСКлиентами.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
			|	И (СоглашенияСКлиентами.ДатаОкончанияДействия >= &ДатаДействия
			|			ИЛИ СоглашенияСКлиентами.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
			|	И (СоглашенияСКлиентами.ДатаНачалаДействия <= &ДатаДействия
			|			ИЛИ СоглашенияСКлиентами.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1))
			|	И (СоглашенияСКлиентами.Партнер = &Партнер
			|			ИЛИ СоглашенияСКлиентами.СегментПартнеров В
			|				(ВЫБРАТЬ
			|					ПартнерыСегмента.Сегмент
			|				ИЗ
			|					РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
			|				ГДЕ
			|					ПартнерыСегмента.Партнер = &Партнер))
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	1 КАК Приоритет,
			|	""Розничный покупатель"" КАК Условие,
			|	СтруктураПредприятия.СоглашениеСКлиентомПоУмолчанию КАК Соглашение
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
			|ГДЕ
			|	&Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.РозничныйПокупатель)
			|	И СтруктураПредприятия.Ссылка = &Подразделение
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|                
			|ВЫБРАТЬ 
			|	2,
			|	""Сотрудники"",
			|	СтруктураПредприятия.СоглашениеДляСотрудников
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия,
			|	Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДопРеквизиты
			|ГДЕ           
			|	СтруктураПредприятия.Ссылка = &Подразделение
			|	И ПартнерыДопРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
			|	И ПартнерыДопРеквизиты.Значение.Наименование = ""Сотрудники""  
			|	И ПартнерыДопРеквизиты.Ссылка = &Партнер
			|	И НЕ СтруктураПредприятия.СоглашениеДляСотрудников.Ссылка ЕСТЬ NULL
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	3,
			|	""Партнер (Бригадиры)"",
			|	СтруктураПредприятия.СоглашениеДляБригадиров
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия,
			|	Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДопРеквизиты
			|ГДЕ
			|	СтруктураПредприятия.Ссылка = &Подразделение
			|	И ПартнерыДопРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
			|	И ПартнерыДопРеквизиты.Значение.Наименование = ""Бригадиры""
			|	И ПартнерыДопРеквизиты.Ссылка = &Партнер
			|	И НЕ СтруктураПредприятия.СоглашениеДляБригадиров.Ссылка ЕСТЬ NULL
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	4,
			|	""Партнер (частные лица)"",
			|	СтруктураПредприятия.СоглашениеСКлиентомЦенаПоКарте
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия,
			|	Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДопРеквизиты
			|ГДЕ
			|	СтруктураПредприятия.Ссылка = &Подразделение
			|	И ПартнерыДопРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
			|	И ПартнерыДопРеквизиты.Значение.Наименование = ""Частные лица""
			|	И ПартнерыДопРеквизиты.Ссылка = &Партнер
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	5,
			|	""По соглашениям партнера (компания)"",
			|	ВР.Соглашение
			|ИЗ
			|	ВР КАК ВР
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
			|		ПО ВР.Партнер = Партнеры.Ссылка
			|ГДЕ
			|	Партнеры.Ссылка = &Партнер
			|	И Партнеры.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.КомпанияЧастноеЛицо.Компания)
			|	И ВР.Соглашение.ЧекККМ
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	6,
			|	""По карте лояльности (частное лицо)"",
			|	КартыЛояльности.Соглашение
			|ИЗ
			|	Справочник.КартыЛояльности КАК КартыЛояльности
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
			|		ПО КартыЛояльности.Партнер = Партнеры.Ссылка
			|ГДЕ
			|	КартыЛояльности.Ссылка = &КартаЛояльности
			|	И КартыЛояльности.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКартЛояльности.Действует)
			|	И Партнеры.Ссылка = &Партнер
			|	И Партнеры.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.КомпанияЧастноеЛицо.ЧастноеЛицо)
			|	И КартыЛояльности.Соглашение.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСКлиентами.Действует)
			|	И (КартыЛояльности.Соглашение.ДатаОкончанияДействия >= &ДатаДействия
			|			ИЛИ КартыЛояльности.Соглашение.ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1))
			|	И (КартыЛояльности.Соглашение.ДатаНачалаДействия <= &ДатаДействия
			|			ИЛИ КартыЛояльности.Соглашение.ДатаНачалаДействия = ДАТАВРЕМЯ(1, 1, 1))
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	7,
			|	""По подразделению"",
			|	СтруктураПредприятия.СоглашениеСКлиентомЦенаПоКарте
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
			|ГДЕ
			|	СтруктураПредприятия.Ссылка = &Подразделение
			|
			|УПОРЯДОЧИТЬ ПО
			|	Приоритет"; 
		
		Запрос.УстановитьПараметр("ДатаДействия", ДатаДействия);
		Запрос.УстановитьПараметр("КартаЛояльности", КартаЛояльности);
		Запрос.УстановитьПараметр("Партнер", Партнер);
		Запрос.УстановитьПараметр("Подразделение", Подразделение);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			Возврат ВыборкаДетальныеЗаписи.соглашение;
		Конецесли;
		
		УстановитьПривилегированныйРежим(Ложь);
		
		Возврат Справочники.СоглашенияСКлиентами.ПустаяСсылка();
	
КонецФункции

Функция ПолучитьКонтрагента(ПараметрыОбмена, ДокументXML) Экспорт
	
	Результат 	= Справочники.Контрагенты.ПустаяСсылка();
	Контрагент 	= Неопределено;
	
	ИнформацияОКонтрагенте = ДокументXML.Контрагент;
	
	Если Контрагент = Неопределено тогда
		Запрос = Новый Запрос();
		
		Запрос.УстановитьПараметр("ИНН", ИнформацияОКонтрагенте.ИНН);
		
		Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Контрагенты.Ссылка КАК Контрагент
			|ИЗ
			|	Справочник.Контрагенты КАК Контрагенты
			|ГДЕ
			|	Контрагенты.ИНН = &ИНН
			|	И НЕ Контрагенты.ПометкаУдаления";
		
		тзнКонтрагента 	= Запрос.Выполнить().Выгрузить();
		Если тзнКонтрагента.Количество() > 0 тогда
			Контрагент 	= тзнКонтрагента[0].Контрагент; 	
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Контрагент;
	
КонецФункции

Функция ПолучитьПастпортныеДанные(Физлицо) Экспорт
	
	ПаспортныеДанные = Новый Структура;
	ПаспортныеДанные.Вставить("Серия","");
	ПаспортныеДанные.Вставить("Номер","");
	ПаспортныеДанные.Вставить("ДатаВыдачи","");
	ПаспортныеДанные.Вставить("СрокДействия","");
	ПаспортныеДанные.Вставить("КемВыдан","");
	ПаспортныеДанные.Вставить("СтранаВыдачи","");
	ПаспортныеДанные.Вставить("КодПодразделения","");
	ПаспортныеДанные.Вставить("ФамилияЛатиницей","");
	ПаспортныеДанные.Вставить("ИмяЛатиницей","");
	ПаспортныеДанные.Вставить("Представление","");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДокументыФизическихЛицСрезПоследних.Серия КАК Серия,
		|	ДокументыФизическихЛицСрезПоследних.Номер КАК Номер,
		|	ДокументыФизическихЛицСрезПоследних.ДатаВыдачи КАК ДатаВыдачи,
		|	ДокументыФизическихЛицСрезПоследних.СрокДействия КАК СрокДействия,
		|	ДокументыФизическихЛицСрезПоследних.КемВыдан КАК КемВыдан,
		|	ДокументыФизическихЛицСрезПоследних.КодПодразделения КАК КодПодразделения,
		|	ДокументыФизическихЛицСрезПоследних.Представление КАК Представление,
		|	ДокументыФизическихЛицСрезПоследних.ФамилияЛатиницей КАК ФамилияЛатиницей,
		|	ДокументыФизическихЛицСрезПоследних.ИмяЛатиницей КАК ИмяЛатиницей,
		|	ДокументыФизическихЛицСрезПоследних.СтранаВыдачи КАК СтранаВыдачи
		|ИЗ
		|	РегистрСведений.ДокументыФизическихЛиц.СрезПоследних(
		|			,
		|			ВидДокумента = &ВидДокумента
		|				И Физлицо = &Физлицо) КАК ДокументыФизическихЛицСрезПоследних";
	
	Запрос.УстановитьПараметр("ВидДокумента", Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ);
	Запрос.УстановитьПараметр("Физлицо", Физлицо);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ПаспортныеДанные, ВыборкаДетальныеЗаписи);
	КонецЕсли;
	
	Возврат ПаспортныеДанные; 
	
КонецФункции

Функция ПроверитьПоСегментуЗапретОтгрузки(Партнер, ПараметрыПроверки=Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыСегмента.Партнер КАК Партнер,
		|	ПартнерыСегмента.Партнер.Наименование КАК ПартнерНаименование
		|ПОМЕСТИТЬ ВТ_Партнеры
		|ИЗ
		|	РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
		|ГДЕ
		|	ПартнерыСегмента.Сегмент.ЗапретОтгрузки
		|	И ПартнерыСегмента.Партнер <> &Партнер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Партнеры.Партнер.Ссылка КАК Партнер,
		|	ВТ_Партнеры.Партнер.Наименование КАК Наименование,
		|	ЕСТЬNULL(ВТ_Партнеры.Партнер.Б_Идентификатор, """") КАК Б_Идентификатор,
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформацияПочта.АдресЭП, """") КАК Почта,
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформацияТелефон.НомерТелефона, """") КАК Телефон,
		|	ЕСТЬNULL(КонтактныеЛицаПартнеров.Ссылка, """") КАК КонтактноеЛицо,
		|	ЕСТЬNULL(КонтактныеЛицаПартнеров.Наименование, """") КАК КонтактноеЛицоФИО,
		|	ЕСТЬNULL(КонтактныеЛицаПартнеров.ДолжностьПоВизитке, """") КАК КонтактноеЛицоДолжность,
		|	ЕСТЬNULL(КонтактныеЛицаПартнеровКонтактнаяИнформацияТелефон.НомерТелефона, """") КАК КонтактноеЛицоТелефон,
		|	ЕСТЬNULL(КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица.Наименование, """") КАК КонтактноеЛицоРоль,
		|	ПартнерыКонтактнаяИнформацияАдрес.Представление КАК Фактический
		|ПОМЕСТИТЬ ВТ_Контакты
		|ИЗ
		|	ВТ_Партнеры КАК ВТ_Партнеры
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияПочта
		|		ПО ВТ_Партнеры.Партнер = ПартнерыКонтактнаяИнформацияПочта.Ссылка
		|			И (&ТипПочта = ПартнерыКонтактнаяИнформацияПочта.Тип)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияТелефон
		|		ПО ВТ_Партнеры.Партнер = ПартнерыКонтактнаяИнформацияТелефон.Ссылка
		|			И (&ТипТелефон = ПартнерыКонтактнаяИнформацияТелефон.Тип)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияАдрес
		|		ПО ВТ_Партнеры.Партнер = ПартнерыКонтактнаяИнформацияАдрес.Ссылка
		|			И (&ТипАдрес = ПартнерыКонтактнаяИнформацияАдрес.Тип)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.РолиКонтактногоЛица КАК КонтактныеЛицаПартнеровРолиКонтактногоЛица
		|			ПО КонтактныеЛицаПартнеров.Ссылка = КонтактныеЛицаПартнеровРолиКонтактногоЛица.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.КонтактнаяИнформация КАК КонтактныеЛицаПартнеровКонтактнаяИнформацияТелефон
		|			ПО КонтактныеЛицаПартнеров.Ссылка = КонтактныеЛицаПартнеровКонтактнаяИнформацияТелефон.Ссылка
		|				И (&ТипТелефон = КонтактныеЛицаПартнеровКонтактнаяИнформацияТелефон.Тип)
		|		ПО ВТ_Партнеры.Партнер = КонтактныеЛицаПартнеров.Владелец
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Контакты.Партнер КАК Партнер,
		|	ВТ_Контакты.Наименование КАК Параметр,
		|	""по наименованию"" КАК Проверка
		|ПОМЕСТИТЬ ВТ_Проверка
		|ИЗ
		|	ВТ_Контакты КАК ВТ_Контакты
		|ГДЕ
		|	ВТ_Контакты.Наименование ПОДОБНО &Фамилия
		|
