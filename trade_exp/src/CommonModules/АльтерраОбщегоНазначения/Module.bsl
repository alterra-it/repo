Функция ПолучитьСсылкуИзНавигационной(НС)  Экспорт
	
	ПерваяТочка = Найти(НС, "e1cib/data/");
	ВтораяТочка = Найти(НС, "?ref=");
	
	ПредставлениеТипа   = Сред(НС, ПерваяТочка + 11, ВтораяТочка - ПерваяТочка - 11);
	ШаблонЗначения = ЗначениеВСтрокуВнутр(ПредопределенноеЗначение(ПредставлениеТипа + ".ПустаяСсылка"));
	ЗначениеСсылки = СтрЗаменить(ШаблонЗначения, "00000000000000000000000000000000", Сред(НС, ВтораяТочка + 5));
	Ссылка = ЗначениеИзСтрокиВнутр(ЗначениеСсылки);
	
	Возврат Ссылка;
	
КонецФункции 

//Регламентное задание ПроверкаОбработкиЗаказовССайта
Процедура ПроверкаОбработкиЗаказовССайта() Экспорт
	
	//Центральный
	РольКонтроля = Справочники.РолиИсполнителей.НайтиПоКоду("000000014");
	РольИсполнителя = Справочники.РолиИсполнителей.НайтиПоКоду("000000013");
	ОбработаЗаказовССайта(РольКонтроля, РольИсполнителя);
	//Барнаул
	РольКонтроля = Справочники.РолиИсполнителей.НайтиПоКоду("000000018");
	РольИсполнителя = Справочники.РолиИсполнителей.НайтиПоКоду("000000015");
	ОбработаЗаказовССайта(РольКонтроля, РольИсполнителя);
	//Выбор
	РольКонтроля = Справочники.РолиИсполнителей.НайтиПоКоду("000000019");
	РольИсполнителя = Справочники.РолиИсполнителей.НайтиПоКоду("000000016");
	ОбработаЗаказовССайта(РольКонтроля, РольИсполнителя);
	//Бийск
	РольКонтроля = Справочники.РолиИсполнителей.НайтиПоКоду("000000020");
	РольИсполнителя = Справочники.РолиИсполнителей.НайтиПоКоду("000000017");
	ОбработаЗаказовССайта(РольКонтроля, РольИсполнителя);   
	
КонецПроцедуры  

Процедура ОбработаЗаказовССайта(РольКонтроля, РольИсполнителя) 

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗадачаИсполнителя.Предмет
	|ПОМЕСТИТЬ ВТ_ЗадачиКонтроля
	|ИЗ
	|	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	|ГДЕ
	|	ЗадачаИсполнителя.РольИсполнителя = &РольКонтроля
	|	И НЕ ЗадачаИсполнителя.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗадачаИсполнителя.Ссылка,
	|	ЗадачаИсполнителя.Дата,
	|	ЗадачаИсполнителя.СрокИсполнения,
	|	ЗадачаИсполнителя.РольИсполнителя,
	|	РАЗНОСТЬДАТ(ЗадачаИсполнителя.Дата, &ТекущаяДата, МИНУТА) КАК Просрочка,
	|	ЗадачаИсполнителя.Выполнена
	|ПОМЕСТИТЬ ВТ_ЗадачиПоЗаказам
	|ИЗ
	|	Задача.ЗадачаИсполнителя КАК ЗадачаИсполнителя
	|ГДЕ
	|	ЗадачаИсполнителя.РольИсполнителя = &РольИсполнителя
	|	И НЕ ЗадачаИсполнителя.Выполнена
	|	И ЗадачаИсполнителя.Предмет ССЫЛКА Документ.ЗаказКлиента
	|	И НЕ ЗадачаИсполнителя.Ссылка В
	|				(ВЫБРАТЬ
	|					ВТ_ЗадачиКонтроля.Предмет
	|				ИЗ
	|					ВТ_ЗадачиКонтроля КАК ВТ_ЗадачиКонтроля)
	|	И ЗадачаИсполнителя.Предмет.ССайта
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Задачи.Ссылка,
	|	ВТ_Задачи.Дата,
	|	ВТ_Задачи.СрокИсполнения,
	|	ВТ_Задачи.РольИсполнителя,
	|	ВТ_Задачи.Просрочка,
	|	ВТ_Задачи.Выполнена
	|ИЗ
	|	ВТ_ЗадачиПоЗаказам КАК ВТ_Задачи
	|ГДЕ
	|	ВТ_Задачи.Просрочка > &Просрочка";
	
	Запрос.УстановитьПараметр("РольКонтроля",РольКонтроля);
	Запрос.УстановитьПараметр("РольИсполнителя", РольИсполнителя);
	Запрос.УстановитьПараметр("Просрочка", 30);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НовЗадача 					= Задачи.ЗадачаИсполнителя.СоздатьЗадачу();
		НовЗадача.Дата 				= ТекущаяДата();
		НовЗадача.СрокИсполнения= НовЗадача.Дата+30*60;
		НовЗадача.Наименование  	= "Просрочена задача по заказу "+ВыборкаДетальныеЗаписи.Ссылка.Номер+" от "+ВыборкаДетальныеЗаписи.Ссылка.Дата+ " не отработана";
		НовЗадача.РольИсполнителя 	= РольКонтроля;
		НовЗадача.Предмет			= ВыборкаДетальныеЗаписи.Ссылка;
		НовЗадача.Описание		= "В течении 30 минут не была отработана задача по заказу "+ВыборкаДетальныеЗаписи.Ссылка;
		НовЗадача.Важность      	= Перечисления.ВариантыВажностиЗадачи.Высокая;
		НовЗадача.Записать();
	КонецЦикла;
	
КонецПроцедуры

