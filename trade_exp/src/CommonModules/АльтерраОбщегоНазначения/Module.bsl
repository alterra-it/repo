Функция ПолучитьДобавитьЗначениеСвойства(Свойство, стрЗначение) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗначенияСвойствОбъектов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
		|ГДЕ
		|	НЕ ЗначенияСвойствОбъектов.ПометкаУдаления
		|	И ЗначенияСвойствОбъектов.Владелец = &Свойство
		|	И ЗначенияСвойствОбъектов.Наименование = &стрЗначение";
	
	Запрос.УстановитьПараметр("Свойство", Свойство);
	Запрос.УстановитьПараметр("стрЗначение", стрЗначение);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Спр = Справочники.ЗначенияСвойствОбъектов.СоздатьЭлемент();
		Спр.Наименование = стрЗначение;
		Спр.ПолноеНаименование = стрЗначение;
		Спр.Владелец = Свойство;
		Спр.Записать();
		
		Возврат Спр.Ссылка
	КонецЕсли;
	
