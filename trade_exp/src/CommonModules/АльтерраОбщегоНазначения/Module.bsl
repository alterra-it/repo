Функция ПолучитьIdРассылки(idРассылки, НаименованиеРассылки) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	IdРассылки.id КАК id
		|ИЗ
		|	Справочник.IdРассылки КАК IdРассылки
		|ГДЕ
		|	IdРассылки.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", НаименованиеРассылки);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выгрузить();
	
	idРассылки = ВыборкаДетальныеЗаписи[0].id;
	
    Возврат idРассылки
	
