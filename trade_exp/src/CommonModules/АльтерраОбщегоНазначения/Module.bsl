	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Не ПустаяСтрока(ВыборкаДетальныеЗаписи.АдресЭП) Тогда
			ЕстьПочта = Истина;
			Если  СокрЛП(ВыборкаДетальныеЗаписи.АдресЭП) = СокрЛП(Почта) Тогда
				ПочтаСовпадает = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ВыгрузкаПрайсовСайт 

Процедура ВыгрузкаПрайсовДляИнтернетМагазина() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Примечание, , , "Начало работы");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрайсыКлиентов.Ссылка КАК Прайс
		|ИЗ
		|	Справочник.ПрайсыКлиентов КАК ПрайсыКлиентов
		|ГДЕ
		|	ПрайсыКлиентов.Выгружать
		|	И НЕ ПрайсыКлиентов.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрайсыКлиентов.Наименование";
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	мФайлов = Новый Массив;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ВыгрузитьКлиентовСервер(ВыборкаДетальныеЗаписи.Прайс, мФайлов);
		ВыгрузитьПрайсСервер(ВыборкаДетальныеЗаписи.Прайс, мФайлов);
	КонецЦикла;
	
	ВыгрузитьФайлыНаСайт(мФайлов);
	
	ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Примечание, , , "Окончание работы");
	УстановитьПривилегированныйРежим(Ложь); 
	
КонецПроцедуры

Процедура ВыгрузитьКлиентовСервер(Прайс, мФайлов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрайсыКлиентовКлиенты.Клиент.Код КАК Код,
		|	ПрайсыКлиентовКлиенты.Клиент.Ссылка КАК Ссылка,
		|	ПрайсыКлиентовКлиенты.Клиент.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ПрайсыКлиентов.Клиенты КАК ПрайсыКлиентовКлиенты
		|ГДЕ
		|	НЕ ПрайсыКлиентовКлиенты.Клиент.ПометкаУдаления
		|	И ПрайсыКлиентовКлиенты.Ссылка = &Прайс
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрайсыКлиентовКлиенты.Клиент.Наименование";
	
	Запрос.УстановитьПараметр("Прайс", Прайс);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Текст = Новый ТекстовыйДокумент;
	Разделитель = ";";
	СтрТекста = "";
	Путь = "D:\Bitrix\Прайсы\";
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		СтрТекста = XMLСтрока(ВыборкаДетальныеЗаписи.Ссылка) + Разделитель
		+ XMLСтрока(СокрЛП(ВыборкаДетальныеЗаписи.Код)) + Разделитель
		+ XMLСтрока(СокрЛП(ВыборкаДетальныеЗаписи.Наименование)) + Разделитель;
		
		Текст.ДобавитьСтроку(СтрТекста);
	КонецЦикла;
	ИмяФайла = XMLСтрока(Путь + СокрЛП(Прайс.ИДГруппыПользователей) + "_" + СокрЛП(Прайс.Наименование) + "_Клиенты.txt");
	мФайлов.Добавить(ИмяФайла);
	Текст.Записать(ИмяФайла);
	
КонецПроцедуры 

Процедура ВыгрузитьПрайсСервер(Прайс, мФайлов) 
	
	ДатаПрайса = ТекущаяДата();
	// Загрузка сформированного списка товаров.
	Товары = ПолучитьТаблицуТоваровЧасть(Прайс);
	// Формируем цену
	ВходныеПараметры = Новый Структура;
	УправляемыеСкидки = Новый СписокЗначений;
	ВходныеПараметры.Вставить("ТолькоПредварительныйРасчет", ЛОЖЬ);
	
	ПараметрыРасчета = Новый Структура;
	ПараметрыРасчета.Вставить("СкидкиНаценки", СкидкиНаценкиСервер.ПолучитьТаблицуСкидокНаценокДляОптовойТорговли(ДатаПрайса, Прайс.Соглашение.Склад, Прайс.Соглашение, Справочники.КартыЛояльности.ПустаяСсылка()));
	ПараметрыРасчета.Вставить("Партнер",       Прайс.Соглашение.Партнер);
	ПараметрыРасчета.Вставить("Соглашение",    Прайс.Соглашение);
	ПараметрыРасчета.Вставить("Регистратор",   Документы.РеализацияТоваровУслуг.ПустаяСсылка());
	
	// Для скидки "За форму оплаты".
	ПараметрыРасчета.Вставить("ФормаОплаты", Прайс.Соглашение.ФормаОплаты);
	
	// Для скидки "За время продажи".
	ПараметрыРасчета.Вставить("ДеньНедели",   Перечисления.ДниНедели.Получить(ДеньНедели(ДатаПрайса) - 1));
	ПараметрыРасчета.Вставить("ТекущееВремя", ДатаПрайса);
	
	// Скидка "За соблюдение графика оплаты" не предоставляется.
	ПараметрыРасчета.Вставить("ГрафикОплаты", Неопределено);
	
	// Карты лояльности
	ПараметрыРасчета.Вставить("КартаЛояльности", Справочники.КартыЛояльности.ПустаяСсылка());
	
	ПараметрыРасчета.Вставить("Товары", Товары);
	ПараметрыРасчета.Вставить("ВалютаДокумента", Константы.ВалютаУправленческогоУчета.Получить());
	ПараметрыРасчета.Вставить("ВалютаУправленческогоУчета", Константы.ВалютаУправленческогоУчета.Получить());
	ПараметрыРасчета.Вставить("Пользователь", Пользователи.ТекущийПользователь());
	ПараметрыРасчета.Вставить("ТекущаяДата", ДатаПрайса);
	
	ПараметрыРасчета.Вставить("УправляемыеСкидки", Новый Массив);
	Сообщения = Новый ТаблицаЗначений;
	Сообщения.Колонки.Добавить("СкидкаНаценка", Новый ОписаниеТипов("СправочникСсылка.СкидкиНаценки"));
	Сообщения.Колонки.Добавить("НапомнитьПозже", Новый ОписаниеТипов("Булево"));
	Сообщения.Индексы.Добавить("СкидкаНаценка");
	ПараметрыРасчета.Вставить("Сообщения", Сообщения);
	
	ПримененныеСкидкиНаценки = СкидкиНаценкиСервер.РассчитатьДляПрайса(ПараметрыРасчета, ВходныеПараметры);
	
	Результат = ПолучитьРезультатЗапросаТаблиц(ПараметрыРасчета.Товары,ПримененныеСкидкиНаценки.ТаблицаСкидкиНаценки);
	
	ВыборкаНоменклатура = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
	
	Текст = Новый ТекстовыйДокумент;
	Разделитель = ";";
	СтрТекста = "";
	Путь = "D:\Bitrix\Прайсы\";
	Пока ВыборкаНоменклатура.Следующий() Цикл
		
		СтрТекста = XMLСтрока(ВыборкаНоменклатура.Номенклатура.Ссылка) + Разделитель
		+ XMLСтрока(СокрЛП(ВыборкаНоменклатура.Номенклатура.Код)) + Разделитель
		+ XMLСтрока(СокрЛП(ВыборкаНоменклатура.Номенклатура.Наименование)) + Разделитель
		+ XMLСтрока(ВыборкаНоменклатура.Цена) + Разделитель;
		
		Текст.ДобавитьСтроку(СтрТекста);
	КонецЦикла;
	ИмяФайла = XMLСтрока(Путь + СокрЛП(Прайс.ИДГруппыПользователей) + "_" + СокрЛП(Прайс.Наименование) + "_Цены.txt");
	мФайлов.Добавить(ИмяФайла);
	Текст.Записать(ИмяФайла); 
	
конецПроцедуры

Процедура ВыгрузитьФайлыНаСайт(мФайлов)
	
	ТипСоединения = "catalog";
	ПараметрЗапросаHTTP_ПередачаФайла = "&mode=file&filename=";
	ОтветСервера = "";
	Соединение = Неопределено;
	
	ИмяКаталога =  "D:\Bitrix\Прайсы\";
	КаталогНаСайте = "\Prices\";
	ИмяФайлаАрхива = "Прайсы.zip";
	
	УзелОбмена = ПланыОбмена.Б_ОбменССайтом.НайтиПоКоду("000000002");
	
	//Авторизация и создание соединения
	ПараметрыОбмена = Новый Структура;
	Б_ОбменССайтомСервер.ДобавитьНастройкиУзлаВПараметры(УзелОбмена, ПараметрыОбмена);
	НастройкиПодключения = Новый Структура;
	Б_ОбменССайтомСервер.ПолучитьНастройкиПодключения(НастройкиПодключения, ПараметрыОбмена);
	
	АдресДляРаботы = НастройкиПодключения.АдресСкрипта + "?type=" + ТипСоединения; 
	
	ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Примечание, , , "Отправка запроса на авторизацию на сайте");
	
	Успешно = Б_ОбменССайтомСервер.АвторизацияВыполнена(Соединение, НастройкиПодключения, ОтветСервера, ПараметрыОбмена, ТипСоединения);
	Если Не Успешно Тогда
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Ошибка, , , "Овторизация не удалась");
	КонецЕсли;
	
	КукиИмя	= СтрПолучитьСтроку(ОтветСервера, 2);
	КукиЗначение = СтрПолучитьСтроку(ОтветСервера, 3);
	Попытка
		Токен = "&" + СтрПолучитьСтроку(ОтветСервера, 4);
	Исключение
		Токен = "";
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Ошибка, , , "CSRF токен не поддерживается. Для того, чтобы поддерживался - необходимо обновить БУС");		
	КонецПопытки;
	ЗаголовкиЗапросов = "Cookie: " + КукиИмя + "=" + КукиЗначение;
	
	//Выгрузка
	ПолноеИмяАрхива = ИмяКаталога+ИмяФайлаАрхива;
	ЗаписьАрхива = Новый ЗаписьZipФайла(ПолноеИмяАрхива);
	
	Для Каждого ПолноеИмя Из мФайлов Цикл
		ПолноеИмяФайлаАрхива= ПолноеИмя;
		ЗаписьАрхива.Добавить(ПолноеИмяФайлаАрхива);
	КонецЦикла;
	
	Попытка
		ЗаписьАрхива.Записать();
	Исключение
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось записать zip-архив на диск!");				
	КонецПопытки;
	
	ПредставлениеФайла = КаталогНаСайте+ИмяФайлаАрхива;
	
	ОтветСервера = Б_ОбменССайтомСервер.ПолучитьРезультатОтправкиФайлаНаСервер(ПараметрыОбмена, ПолноеИмяАрхива, Соединение, АдресДляРаботы + ПараметрЗапросаHTTP_ПередачаФайла + ПредставлениеФайла + Токен, ЗаголовкиЗапросов);
	
	Если ОтветСервера = Неопределено Тогда
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить ответ сервера. Файл не отправлен.");				
	КонецЕсли;
	
	Если Найти(ОтветСервера, "success") > 0 Тогда
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Примечание, , , "Файл отправлен на сервер успешно!");					
	Иначе
		ЗаписьЖурналаРегистрации("РегламентноеЗадание.ВыгрузкаПрайсовДляИнтернетМагазина", УровеньЖурналаРегистрации.Ошибка, , , "Не удалось получить ответ сервера. Файл не отправлен.");				
	КонецЕсли;
	
КонецПроцедуры

//Запросы
Функция ПолучитьТаблицуТоваров(Прайс)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Номенклатура.Ссылка КАК Номенклатура,
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры
		|ПОМЕСТИТЬ ИсходныеДанные
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ВыгружаетсяНаСайт
		|
		|СГРУППИРОВАТЬ ПО
		|	Номенклатура.Ссылка,
		|	Номенклатура.ВидНоменклатуры
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура КАК Номенклатура,
		|	1 КАК Количество,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
		|	1 КАК КоличествоУпаковок,
		|	ЕСТЬNULL(Цены.Цена, 0) КАК Цена,
		|	0 КАК КлючСвязи,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.НаименованиеДляПрайса КАК НаименованиеДляПрайса,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.СправочникДляПрайса КАК СправочникДляПрайса,
		|	&ВидЦены КАК ВидЦены
		|ИЗ
		|	ИсходныеДанные КАК ИсходныеДанныеПоследнийЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(КОНЕЦПЕРИОДА(&Датапрайса, ДЕНЬ), ВидЦены = &ВидЦены) КАК Цены
		|		ПО ИсходныеДанныеПоследнийЗапрос.Номенклатура = Цены.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура,
		|	ЕСТЬNULL(Цены.Цена, 0),
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.НаименованиеДляПрайса,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.ЕдиницаИзмерения,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.СправочникДляПрайса
		|
		|УПОРЯДОЧИТЬ ПО
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.Наименование";
	
	Запрос.УстановитьПараметр("ВидЦены", Прайс.Соглашение.ВидЦен);
	Запрос.УстановитьПараметр("ДатаПрайса", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ; 
	
КонецФункции 

Функция ПолучитьТаблицуТоваровЧасть(Прайс)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Номенклатура.Ссылка КАК Номенклатура,
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры
		|ПОМЕСТИТЬ ИсходныеДанные
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В ИЕРАРХИИ(&Группа)
		|	И Номенклатура.ВыгружаетсяНаСайт
		|
		|СГРУППИРОВАТЬ ПО
		|	Номенклатура.Ссылка,
		|	Номенклатура.ВидНоменклатуры
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура КАК Номенклатура,
		|	1 КАК Количество,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) КАК Характеристика,
		|	ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка) КАК Упаковка,
		|	1 КАК КоличествоУпаковок,
		|	ЕСТЬNULL(Цены.Цена, 0) КАК Цена,
		|	0 КАК КлючСвязи,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.НаименованиеДляПрайса КАК НаименованиеДляПрайса,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.СправочникДляПрайса КАК СправочникДляПрайса,
		|	&ВидЦены КАК ВидЦены
		|ИЗ
		|	ИсходныеДанные КАК ИсходныеДанныеПоследнийЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(КОНЕЦПЕРИОДА(&Датапрайса, ДЕНЬ), ВидЦены = &ВидЦены) КАК Цены
		|		ПО ИсходныеДанныеПоследнийЗапрос.Номенклатура = Цены.Номенклатура
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура,
		|	ЕСТЬNULL(Цены.Цена, 0),
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.НаименованиеДляПрайса,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.ЕдиницаИзмерения,
		|	ИсходныеДанныеПоследнийЗапрос.Номенклатура.СправочникДляПрайса";
	
	Запрос.УстановитьПараметр("ВидЦены", Прайс.Соглашение.ВидЦен);
	Запрос.УстановитьПараметр("ДатаПрайса", ТекущаяДата());
	Запрос.УстановитьПараметр("Группа", Справочники.Номенклатура.НайтиПоКоду("А7918"));
		
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ; 
	
КонецФункции 

Функция ПолучитьРезультатЗапросаТаблиц(Товары,СкидкиНаценки)
	
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("Товары",Товары);
	Запрос.УстановитьПараметр("СкидкиНаценки",СкидкиНаценки);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура,
		|	Товары.Характеристика,
		|	Товары.Цена КАК Цена,
		|	Товары.КлючСвязи,
		|	Товары.ЕдиницаИзмерения,
		|	Товары.НаименованиеДляПрайса,
		|	Товары.СправочникДляПрайса
		|ПОМЕСТИТЬ Таблица
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Скидки.КлючСвязи,
		|	Скидки.Сумма
		|ПОМЕСТИТЬ Скидки
		|ИЗ
		|	&СкидкиНаценки КАК Скидки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Таблица.Номенклатура КАК Номенклатура,
		|	Таблица.Характеристика,
		|	Таблица.Цена - ЕСТЬNULL(Скидки.Сумма, 0) КАК Цена,
		|	Таблица.ЕдиницаИзмерения КАК ЕдИзм,
		|	Таблица.НаименованиеДляПрайса КАК НаименованиеДляПрайса,
		|	ГруппаПрайса.Ссылка КАК Группапрайса
		|ИЗ
		|	Таблица КАК Таблица
		|		ЛЕВОЕ СОЕДИНЕНИЕ Скидки КАК Скидки
		|		ПО Таблица.КлючСвязи = Скидки.КлючСвязи
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СправочникДляПрайса КАК ГруппаПрайса
		|		ПО Таблица.СправочникДляПрайса = ГруппаПрайса.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Таблица.Номенклатура,
		|	Таблица.Характеристика,
		|	Таблица.ЕдиницаИзмерения,
		|	Таблица.НаименованиеДляПрайса,
		|	ГруппаПрайса.Ссылка,
		|	Таблица.Цена - ЕСТЬNULL(Скидки.Сумма, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ГруппаПрайса.Код,
		|	НаименованиеДляПрайса";
	
	Запрос.Текст = Запрос.Текст + "
		|ИТОГИ ПО
		|	ГруппаПрайса ИЕРАРХИЯ";
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат; 
	
КонецФункции 

