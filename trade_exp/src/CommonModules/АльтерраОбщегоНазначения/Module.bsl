#Область IDТранзакцииОперацийПоПлатежнойКарте

Процедура ЗаписьIDТранзакцииВРегистр(ДокументСсылка, IDТранзакции, СБП = Ложь) Экспорт
	
	//запись ID в регистр
	НаборЗаписей = РегистрыСведений.ДанныеБезналичныхОплат.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокументОплаты.Установить(ДокументСсылка);
	НаборЗаписей.Очистить();
	ЗаписьВРегистр = НаборЗаписей.Добавить();
	ЗаписьВРегистр.ДокументОплаты = ДокументСсылка;
	ЗаписьВРегистр.IDТранзакции = IDТранзакции;
	ЗаписьВРегистр.СБП = СБП;
	УстановитьПривилегированныйРежим(Истина);
	НаборЗаписей.Записать();
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры 

Функция ПолучитьIDТранзакцииИзРегистра(ДокументСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеБезналичныхОплат.IDТранзакции КАК IDТранзакции
		|ИЗ
		|	РегистрСведений.ДанныеБезналичныхОплат КАК ДанныеБезналичныхОплат
		|ГДЕ
		|	ДанныеБезналичныхОплат.ДокументОплаты = &ДокументОплаты";
	Запрос.УстановитьПараметр("ДокументОплаты", ДокументСсылка);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Выборка = Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.IDТранзакции;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции 

Функция ПолучитьПараметрыДокумента(ДокументСсылка)экспорт
	
	ПараметрыДокумента = Новый Структура();
	ПараметрыДокумента.Вставить("ДатаДокумента",ДокументСсылка.Дата - 300);
	КодАвторизации = "Kod not found";
   
	МассивКодовАвторизации = Новый Массив;
	МассивСуммОплат = Новый Массив; 
	КоличествоОплат = 0; 
	Если типзнч(ДокументСсылка) = Тип("ДокументСсылка.ЧекККМ") Тогда  
		КоличествоОплат = ДокументСсылка.ОплатаПлатежнымиКартами.Количество(); 
		Для Счетчик = 0 по КоличествоОплат - 1 Цикл 
			МассивКодовАвторизации.Добавить(ДокументСсылка.ОплатаПлатежнымиКартами[Счетчик].КодАвторизации); 
			МассивСуммОплат.Добавить(ДокументСсылка.ОплатаПлатежнымиКартами[Счетчик].Сумма); 
		КонецЦикла; 
	ИначеЕсли типзнч(ДокументСсылка) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") Тогда
		КоличествоОплат = 1; 
		МассивКодовАвторизации.Добавить(ДокументСсылка.КодАвторизации); 
		МассивСуммОплат.Добавить(ДокументСсылка.СуммаДокумента);
	КонецЕсли;
	ПараметрыДокумента.Вставить("КодАвторизации",МассивКодовАвторизации);
	ПараметрыДокумента.Вставить("СуммаДокумента",МассивСуммОплат); 
	ПараметрыДокумента.Вставить("КоличествоОплат",КоличествоОплат); 
	
	Возврат ПараметрыДокумента;

КонецФункции 

#КонецОбласти

#Область ОбменСИнтернетМагазином

Функция ПроверкаНаНаличиеЗаписейВРегистре(ЗаказКлиента, ЭквайринговаяОперация, СуммаОплаты, АдресУведомленияКлиента, НомерКарты, ЭквайринговыйТерминал, ИдентификаторОплаты) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОчередьЧековКПробитию.КоличествоПопытокПробития КАК КоличествоПопытокПробития,
		|	ОчередьЧековКПробитию.СтатусОшибки КАК СтатусОшибки,
		|	ОчередьЧековКПробитию.Информация КАК Информация
		|ИЗ
		|	РегистрСведений.ОчередьЧековКПробитию КАК ОчередьЧековКПробитию
		|ГДЕ
		|	ОчередьЧековКПробитию.ЗаказКлиента = &ЗаказКлиента";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();	
	Если РезультатЗапроса.Следующий() Тогда
		Если РезультатЗапроса.СтатусОшибки Тогда 
			Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(
				Истина, 
				"Чек находится в очереди к пробитию!" + Символы.ПС +
				"Количество попыток пробития - " + РезультатЗапроса.КоличествоПопытокПробития + Символы.ПС + 
				"Информация по текущему статусу: " + Символы.ПС + РезультатЗапроса.Информация);
		Иначе
			Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ложь, "Чек пробит!"); 	
		КонецЕсли;
	КонецЕсли;
	
	Ответ = ПробитьДокументОплаты(ЗаказКлиента, ЭквайринговаяОперация, СуммаОплаты, АдресУведомленияКлиента, НомерКарты, ЭквайринговыйТерминал);	
	Если Ответ.Ошибка Тогда
		НоваяЗапись = РегистрыСведений.ОчередьЧековКПробитию.СоздатьМенеджерЗаписи();
		НоваяЗапись.ССайта              		= Истина;
		НоваяЗапись.ДатаПостановки            	= ТекущаяДатаСеанса();
		НоваяЗапись.ЗаказКлиента              	= ЗаказКлиента;
		НоваяЗапись.ЭквайринговаяОперация     	= ЭквайринговаяОперация;
		НоваяЗапись.СуммаОплаты               	= СуммаОплаты;
		НоваяЗапись.АдресУведомленияКлиента   	= АдресУведомленияКлиента;
		НоваяЗапись.НомерКарты                	= НомерКарты;
		НоваяЗапись.ЭквайринговыйТерминал     	= ЭквайринговыйТерминал;
		НоваяЗапись.ДинамическаяСсылка			= ИдентификаторОплаты;	
		НоваяЗапись.КоличествоПопытокПробития 	= 1;
		НоваяЗапись.СтатусОшибки              	= Истина;
		НоваяЗапись.Информация                	= Ответ.ТекстСообщения;
	    НоваяЗапись.Записать(Истина);
	КонецЕсли;
	
	Возврат ОбщийHTTPСервер.ПодготовитьHTTPОтвет(Ответ.Ошибка, Ответ.ТекстСообщения, Ответ.Данные);  
	
КонецФункции

Функция ПробитьДокументОплаты(Заказ, ДокументОплаты, СуммаОплаты, АдресУведомленияКлиента, НомерКарты, ЭквайринговыйТерминал) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Ответ = Новый HTTPСервисОтвет(200);
	Если ЗначениеЗаполнено(ДокументОплаты) Тогда
		Док = ДокументОплаты.ПолучитьОбъект();
	Иначе
		Док = Документы.ОперацияПоПлатежнойКарте.СоздатьДокумент();
		Док.Заполнить(Заказ);
	КонецЕсли;
	Док.ЭквайринговыйТерминал = ЭквайринговыйТерминал;
	Док.Комментарий = Док.Комментарий + " Оплачено через сайт.";
	Док.Дата = ТекущаяДата(); 
	Док.ДоговорЭквайринга = ЭквайринговыйТерминал.Владелец;
	ИмяСобытия = "ОбменСИнтернетМагазиномОплата";
	
	ФинансыКлиентСервер.ПересчитатьСуммыВСтрокеРасшифровкиПлатежа(Док, СуммаОплаты, Ложь);
	Док.СуммаДокумента = Док.РасшифровкаПлатежа.Итог("Сумма");
	КассаИнтернетМагазина = Константы.КассаИнтернетМагазина.Получить();
	
	Попытка
		Если НомерКарты <> "" Тогда
			Док.НомерПлатежнойКарты = НомерКарты;
		ИначеЕсли ДокументОплаты = Неопределено ИЛИ ДокументОплаты.НомерПлатежнойКарты = "" Тогда
			Док.НомерПлатежнойКарты = "0202";
		КонецЕсли;
		Док.Записать(РежимЗаписиДокумента.Проведение);
		АТОЛСревер.ЗаписатьЛогВФайл(КассаИнтернетМагазина, Док, , "Проведение документа эквайринга");
	Исключение
		
		////++Для отслеживания ошибки 
		////При ошибке записи сохраняем все реквизиты в журнал регистрации, чтобы получить больше данных
		СписокРеквизитовСтрокой = "";
		Для Каждого Реквизит Из Док.Метаданные().Реквизиты Цикл
			СписокРеквизитовСтрокой = СписокРеквизитовСтрокой + Реквизит.Имя + " = " + Док[Реквизит.Имя] + Символы.ПС;
		КонецЦикла;
		////реквизиты ТЧ
		СписокРеквизитовТЧСтрокой = "";
		Для Каждого ТЧ из Док.Метаданные().ТабличныеЧасти Цикл
			Для Каждого СтрокаТЧ из Док[ТЧ.Имя] Цикл
				Для Каждого РеквизитТЧ из ТЧ.Реквизиты Цикл
					СписокРеквизитовТЧСтрокой = СписокРеквизитовТЧСтрокой + РеквизитТЧ.Имя + " = " + СтрокаТЧ[РеквизитТЧ.Имя] + Символы.ПС;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		СписокРеквизитовСтрокой = СписокРеквизитовСтрокой + СписокРеквизитовТЧСтрокой;
		////--Для отсеживания ошибки
		
		ОшибкаРасш = "";
		Инфо = ИнформацияОбОшибке();
		ОшибкаРасш = Инфо.Описание + Символы.ПС + Инфо.ИмяМодуля + Символы.ПС + Инфо.НомерСтроки + Символы.ПС + Инфо.ИсходнаяСтрока;
		Если Док.Организация <> Заказ.Организация Тогда
			ОшибкаРасш = "Организации заказа и эквайринговой операции отличаются! " + ОшибкаРасш;
		КонецЕсли;
		Ответ = ПодготовитьHTTPОтвет(Истина, "Ошибка записи эквайринга" + Символы.ПС + ОшибкаРасш);
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , ОшибкаРасш, "Ошибка записи Эквайринга по заказу " + Строка(Заказ) + Символы.ПС + СписокРеквизитовСтрокой);
		// изменение: проверка создания при ошибке
		Док.ОбменДанными.Загрузка = Истина;
		Док.Записать();
		Возврат Ответ;
	КонецПопытки;
	
	ДокументОплаты = Док.Ссылка;
	
	НачатьТранзакцию();
	
	//пробитие чека
	ПараметрыАТОЛ = ПолучитьПараметрыКассы(КассаИнтернетМагазина, Заказ, ДокументОплаты, СуммаОплаты, "ОбменСИнтернетМагазиномОплата");
	Отказ = Ложь;
	Если ПараметрыАТОЛ.Свойство("Ошибка") И ПараметрыАТОЛ.Ошибка Тогда
		Текст = ПараметрыАТОЛ.ТекстСообщения;
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Текст);
		Отказ = Истина;   
		Ответ = ПараметрыАТОЛ;  
		Если ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") Тогда
			Ответ.ТекстСообщения = "Невозможно получить информацию по кассовой смене. Проверьте работу кассы";
		Иначе
			Ответ.ТекстСообщения = "Сервер АТОЛ недоступен";
		КонецЕсли;
		АТОЛСревер.ЗаписатьЛогВФайл(КассаИнтернетМагазина, Заказ, Ответ, "Сервер АТОЛ недоступен");
	КонецЕсли;	
	
	ОтказПробитияЧека = Ложь;
	Если Не Отказ Тогда
		ПараметрыАТОЛ.EmailИлиТелефон = АдресУведомленияКлиента;
		ПараметрыАТОЛ.Вставить("ОтправлятьЧекИзОФД", Истина);
		Если Не Отказ Тогда
			Ответ = ПробитьЧек(ПараметрыАТОЛ, ИмяСобытия, Отказ);
			//log
			АТОЛСревер.ЗаписатьЛогВФайл(КассаИнтернетМагазина,Заказ, Ответ, "Пробитие чека");
		КонецЕсли;
		
		Если Ответ.Ошибка ИЛИ Не Ответ.Данные.Свойство("uuid") Тогда
			Текст = Ответ.ТекстСообщения;
			ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , Текст);
			Отказ = Истина;
		КонецЕсли;
		
		Если Не Отказ Тогда
			УИД = Ответ.Данные.uuid;
		Иначе
			УИД = XMLСтрока(Заказ);
			ОтказПробитияЧека = Истина;
			Текст = "По данному чеку было ранее пробитие с ошибкой. Состояние задания: ";
		КонецЕсли;
		
		Если ОтказПробитияЧека <> Истина Тогда
			КоличествоПопыток = 3;
		Иначе
			КоличествоПопыток = 1;
		КонецЕсли;
		Таймаут = 1;
		Пока КоличествоПопыток > 0 Цикл
			ТекстЗаписиВЛог = "Попытка обращения к АТОЛ: #" + Строка(КоличествоПопыток); 
			АТОЛСревер.ЗаписатьЛогВФайл(КассаИнтернетМагазина, Заказ, Ответ, ТекстЗаписиВЛог);
			Ответ = АТОЛСревер.РезультатПробитияЧека(ПараметрыАТОЛ, УИД);
			Если Ответ.Ошибка Тогда
				КоличествоПопыток = КоличествоПопыток - 1;
				Б_ОбменССайтомСервер.Таймаут(Таймаут);
			Иначе
				Прервать;
			КонецЕсли;	
		КонецЦикла;
		
		//log
		АТОЛСревер.ЗаписатьЛогВФайл(КассаИнтернетМагазина, Заказ, Ответ, "Результат пробития чека на АТОЛ");
	КонецЕсли;
	Если Не Отказ И Не Ответ.Ошибка Тогда
		ДанныеФН= Ответ.Данные;
		//ЗаписатьФискальнуюОперацию
		ПараметрыФискализации = АТОЛСревер.ПодготовитьДанныеФискализацииЧека(ПараметрыАТОЛ, ДанныеФН);
		ОборудованиеЧекопечатающиеУстройстваВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации);
		
		ОтветHTTP = ПодготовитьHTTPОтвет(Ложь, "Чек пробит", АдресУведомленияКлиента);
		
		Если Не Отказ Тогда
			
			ЗафиксироватьТранзакцию();
			
			Попытка
				ОтправитьСМСПоИнтернетЗаказу(Заказ);
				ОтправитьОповещениеБ24ПоИнтернетЗаказу(Заказ);
			Исключение
				ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , , "Не удалось отправить сообщение в Битрикс24");
			КонецПопытки;
			
		КонецЕсли;
		
		Возврат ОтветHTTP;
	Иначе
		Ошибка = Истина;
		Если ОтказПробитияЧека Тогда
			Ошибка = Не СтрНайти(Ответ.ТекстСообщения, "Данные ФН") > 0;
			Если Не Ошибка Тогда
				Текст = "Чек был пробит ранее";
				Ошибка = Ложь;       
				
				Если Не ПолучитьФискальнуюОперацию(ДокументОплаты) Тогда  
					//ЗаписатьФискальнуюОперацию
					ДанныеФН= Ответ.Данные;
					ПараметрыФискализации = АТОЛСревер.ПодготовитьДанныеФискализацииЧека(ПараметрыАТОЛ, ДанныеФН);
					ОборудованиеЧекопечатающиеУстройстваВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации);
				КонецЕсли;
			
			Иначе
				Текст = Текст + Ответ.ТекстСообщения;
			КонецЕсли;
		Иначе
			Текст= Ответ.ТекстСообщения;
		КонецЕсли;
		
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка, , Ответ.ТекстСообщения, Текст);		
		ОтветHTTP = ПодготовитьHTTPОтвет(Ошибка, Текст, "");
		ОтменитьТранзакцию();
		
		Возврат ОтветHTTP;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецФункции      

Функция ПолучитьФискальнуюОперацию(ДокументОснование) Экспорт
	
	Запрос = Новый Запрос;   
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ДокументОснование
		|ИЗ
		|	РегистрСведений.ФискальныеОперации
		|ГДЕ
		|	ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции


