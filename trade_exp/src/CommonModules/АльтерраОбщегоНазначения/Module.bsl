Функция КодироватьВBase64(Строка) Экспорт
	
	ПотокВПамяти = Новый ПотокВПамяти();
	ЗаписьДанных = Новый ЗаписьДанных(ПотокВПамяти);
	ЗаписьДанных.ЗаписатьСтроку(Строка);
	ДД = ПотокВпамяти.ЗакрытьИПолучитьДвоичныеДанные();
	
	СтрокаКодированная = Base64Строка(ДД);
	
	Возврат СтрокаКодированная; 
	
КонецФункции 

Функция РаскодироватьИзBase64(СтрокаКодированная) Экспорт
	
	ДД1 = Base64Значение(СтрокаКодированная);
	ЧтениеДанных = Новый ЧтениеДанных(ДД1);
	СтрокаРаскодированная = ЧтениеДанных.ПрочитатьСтроку();
	ЧтениеДанных.Закрыть();
	
	Возврат СтрокаРаскодированная; 
	
КонецФункции

