		Примечание3 = "";
	КонецЕсли;
	
	СведенияОКлиента = 
	Новый Структура("Наименование, ПолноеНаименование, ФактическийАдрес,ЮридическийАдрес,ТелефонПартнера,Телефон1,Телефон2,Телефон3,Примечание1,Примечание2,Примечание3,ПочтаПартнера",
	Наименование, ПолноеНаименование, ФактическийАдрес, ЮридическийАдрес, ТелефонПартнера, Телефон1, Телефон2, Телефон3, Примечание1, Примечание2, Примечание3, ПочтаПартнера);
	
