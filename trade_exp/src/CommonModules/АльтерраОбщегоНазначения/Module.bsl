Процедура ПроверитьНаличиеПриходныхОрдеров(ПоВозвратуИлиКорректировке, СтатусПроведен, СтатусПометкаУдаления, СообщениеЗаголовок, Отказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПРЕДСТАВЛЕНИЕ(ПриходныйОрдерНаТовары.Ссылка) КАК ПредставлениеСсылки,
		|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Распоряжение = &ВозвратИлиКорректировка
		|	И ПриходныйОрдерНаТовары.Проведен = &СтатусПроведен
		|	И ПриходныйОрдерНаТовары.ПометкаУдаления = &СтатусПометкаУдаления";
	
	Запрос.УстановитьПараметр("ВозвратИлиКорректировка", ПоВозвратуИлиКорректировке);
	Запрос.УстановитьПараметр("СтатусПроведен", СтатусПроведен);
	Запрос.УстановитьПараметр("СтатусПометкаУдаления", СтатусПометкаУдаления);
	
	Выборка = Запрос.Выполнить();
	Если Не Выборка.Пустой() Тогда
		Отказ = Истина;
		Выборка = Выборка.Выбрать();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеЗаголовок);
		Пока Выборка.Следующий() Цикл
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Выборка.ПредставлениеСсылки, Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура НаличиеЗаказаНаДоставкуПриПолномВозврате(Отказ, ТЗТовары, ДокументВозврата, ДокументОснованиеВозврата) Экспорт		
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДокументОснованиеВозврата.Номенклатура КАК Номенклатура,
		|	СУММА(ДокументОснованиеВозврата.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТТоварыИзДокументаОснования
		|ИЗ
		|	Документ." + ДокументОснованиеВозврата.Метаданные().Имя + ".Товары КАК ДокументОснованиеВозврата
		|ГДЕ
		|	ДокументОснованиеВозврата.Ссылка = &ДокументОснованиеВозврата
		|	И ДокументОснованиеВозврата.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|	И ДокументОснованиеВозврата.Количество <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ДокументОснованиеВозврата.Номенклатура
		|;
		|
		|//////////////////////////////////////////////////////////////////////////////// 
		|ВЫБРАТЬ
		|	ТЗ.Номенклатура КАК Номенклатура,
		|	ТЗ.Количество КАК Количество
		|ПОМЕСТИТЬ ТЗСУслугами
		|ИЗ
		|	&ТЗТовары КАК ТЗ
		|;
		|
		|//////////////////////////////////////////////////////////////////////////////// 
		|ВЫБРАТЬ
		|	ТЗ.Номенклатура КАК Номенклатура,
		|	ТЗ.Количество КАК Количество
		|ПОМЕСТИТЬ ТЗБезУслуг
		|ИЗ
		|	ТЗСУслугами КАК ТЗ
		|ГДЕ
		|	ТЗ.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|;" +
		
		?(ТипЗнч(ДокументВозврата) = Тип("ДокументСсылка.КорректировкаРеализации") ИЛИ ТипЗнч(ДокументВозврата) = Тип("ДокументСсылка.ЧекККМКоррекции"),
		"ВЫБРАТЬ
		|	ТоварыИзДокументаОснования.Номенклатура КАК Номенклатура,
		|	ТоварыИзДокументаОснования.Количество - ЕСТЬNULL(ТЗ.Количество, 0) КАК Количество
		|ПОМЕСТИТЬ ТЗ
		|ИЗ
		|	ВТТоварыИзДокументаОснования КАК ТоварыИзДокументаОснования
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТЗБезУслуг КАК ТЗ
		|		ПО ТоварыИзДокументаОснования.Номенклатура = ТЗ.Номенклатура
		|ГДЕ
		|	ТЗ.Номенклатура ЕСТЬ NULL
		|		ИЛИ ТоварыИзДокументаОснования.Количество <> ЕСТЬNULL(ТЗ.Количество, 0)
		|;",
		"ВЫБРАТЬ
		|	ТЗ.Номенклатура КАК Номенклатура,
		|	ТЗ.Количество КАК Количество
		|ПОМЕСТИТЬ ТЗ
		|ИЗ
		|	ТЗБезУслуг КАК ТЗ
		|;") +
		
		"ВЫБРАТЬ
		|	Корректировки.Номенклатура КАК Номенклатура,
		|	СУММА(Корректировки.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТКорректировки
		|ИЗ
		|	(ВЫБРАТЬ
		|		КорректировкаРеализации.Номенклатура КАК Номенклатура,
		|		КорректировкаРеализации.Количество КАК Количество
		|	ИЗ
		|		Документ.КорректировкаРеализации.Товары КАК КорректировкаРеализации
		|	ГДЕ
		|		КорректировкаРеализации.Ссылка <> &ДокументВозврата
		|		И КорректировкаРеализации.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|		И КорректировкаРеализации.Ссылка.ДокументОснование = &ДокументОснованиеВозврата
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЧекККМКоррекции.Номенклатура,
		|		ЧекККМКоррекции.Количество
		|	ИЗ
		|		Документ.ЧекККМКоррекции.Товары КАК ЧекККМКоррекции
		|	ГДЕ
		|		ЧекККМКоррекции.Ссылка <> &ДокументВозврата
		|		И ЧекККМКоррекции.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|		И ЧекККМКоррекции.Ссылка.ЧекККМ = &ДокументОснованиеВозврата) КАК Корректировки
		|ГДЕ
		|	Корректировки.Количество <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Корректировки.Номенклатура
		|;
		|
		|//////////////////////////////////////////////////////////////////////////////// 	
		|ВЫБРАТЬ
		|	ТоварыВозврат.Номенклатура КАК Номенклатура,
		|	СУММА(ТоварыВозврат.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТТоварыВозврат
		|ИЗ
		|	(ВЫБРАТЬ
		|		ТЗ.Номенклатура КАК Номенклатура,
		|		ТЗ.Количество КАК Количество
		|	ИЗ
		|		ТЗ КАК ТЗ
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		ВозвратТоваровОтКлиента.Номенклатура,
		|		ВозвратТоваровОтКлиента.Количество
		|	ИЗ
		|		Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиента
		|	ГДЕ
		|		ВозвратТоваровОтКлиента.Ссылка <> &ДокументВозврата
		|		И ВозвратТоваровОтКлиента.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|		И (ВозвратТоваровОтКлиента.Ссылка.ДокументРеализации = &ДокументОснованиеВозврата
		|				ИЛИ ВозвратТоваровОтКлиента.Ссылка.ЧекККМ = &ДокументОснованиеВозврата)
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		ЧекККМВозврат.Номенклатура,
		|		ЧекККМВозврат.Количество
		|	ИЗ
		|		Документ.ЧекККМВозврат.Товары КАК ЧекККМВозврат
		|	ГДЕ
		|		ЧекККМВозврат.Ссылка <> &ДокументВозврата
		|		И ЧекККМВозврат.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|		И ЧекККМВозврат.Ссылка.ЧекККМ = &ДокументОснованиеВозврата
		|
		|	ОБЪЕДИНИТЬ ВСЕ
		|
		|	ВЫБРАТЬ
		|		ТоварыИзДокументаОснования.Номенклатура,
		|		ТоварыИзДокументаОснования.Количество - ЕСТЬNULL(Корректировки.Количество, 0)
		|	ИЗ
		|		(ВЫБРАТЬ
		|			Корректировки.Ссылка КАК Ссылка,
		|			ТоварыИзДокументаОснования.Номенклатура КАК Номенклатура,
		|			ТоварыИзДокументаОснования.Количество КАК Количество
		|		ИЗ
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				КорректировкаРеализации.Ссылка КАК Ссылка
		|			ИЗ
		|				Документ.КорректировкаРеализации КАК КорректировкаРеализации
		|			ГДЕ
		|				КорректировкаРеализации.Ссылка <> &ДокументВозврата
		|				И КорректировкаРеализации.Ссылка.ДокументОснование = &ДокументОснованиеВозврата
		|		
		|			ОБЪЕДИНИТЬ ВСЕ
		|		
		|			ВЫБРАТЬ ПЕРВЫЕ 1
		|				ЧекККМКоррекции.Ссылка
		|			ИЗ
		|				Документ.ЧекККМКоррекции КАК ЧекККМКоррекции
		|			ГДЕ
		|				ЧекККМКоррекции.Ссылка <> &ДокументВозврата
		|				И ЧекККМКоррекции.Ссылка.ЧекККМ = &ДокументОснованиеВозврата) КАК Корректировки
		|				ЛЕВОЕ СОЕДИНЕНИЕ ВТТоварыИзДокументаОснования КАК ТоварыИзДокументаОснования
		|				ПО (ИСТИНА)) КАК ТоварыИзДокументаОснования
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТКорректировки КАК Корректировки
		|			ПО ТоварыИзДокументаОснования.Номенклатура = Корректировки.Номенклатура
		|	ГДЕ
		|		НЕ ТоварыИзДокументаОснования.Ссылка ЕСТЬ NULL
		|		И (Корректировки.Номенклатура ЕСТЬ NULL
		|			ИЛИ ТоварыИзДокументаОснования.Количество <> ЕСТЬNULL(Корректировки.Количество, 0))) КАК ТоварыВозврат
		|ГДЕ
		|	ТоварыВозврат.Количество <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыВозврат.Номенклатура
		|;
		|
		|//////////////////////////////////////////////////////////////////////////////// 
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТЗаказНаДоставку
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Документ = &ДокументОснованиеВозврата
		|	И НЕ ЗаказНаДоставкуКлиентуОснования.Ссылка.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТоварыИзДокументаОснования.Номенклатура КАК Номенклатура,
		|	ТоварыИзДокументаОснования.Количество - ЕСТЬNULL(ТоварыВозврат.Количество, 0) КАК Количество
		|ИЗ
		|	ВТТоварыИзДокументаОснования КАК ТоварыИзДокументаОснования
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТТоварыВозврат КАК ТоварыВозврат
		|		ПО ТоварыИзДокументаОснования.Номенклатура = ТоварыВозврат.Номенклатура
		|ГДЕ
		|	ТоварыИзДокументаОснования.Количество <> ЕСТЬNULL(ТоварыВозврат.Количество, 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказНаДоставку.Ссылка КАК Ссылка
		|ИЗ
		|	ВТЗаказНаДоставку КАК ЗаказНаДоставку
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсОснования.Ссылка КАК Рейс
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейсОснования.Документ В
		|			(ВЫБРАТЬ
		|				ВТЗаказНаДоставку.Ссылка
		|			ИЗ
		|				ВТЗаказНаДоставку)
		|	И НЕ ЗаданиеНаПеревозкуРейсОснования.Ссылка.ПометкаУдаления
		|	И ЗаданиеНаПеревозкуРейсОснования.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРейсов.ПредварительнаяКомплектация)
		|	И ЗаданиеНаПеревозкуРейсОснования.Ссылка.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРейсов.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ТЗТовары", ТЗТовары);
	Запрос.УстановитьПараметр("ДокументВозврата", ДокументВозврата);
	Запрос.УстановитьПараметр("ДокументОснованиеВозврата", ДокументОснованиеВозврата);
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Если МассивРезультатов[7].Пустой() Тогда
		Результат = МассивРезультатов[8];
		Если Не Результат.Пустой() Тогда
			Результат = Результат.Выбрать();
			Если Результат.Следующий() Тогда
				Результат = Результат.Ссылка; // ЗаказНаДоставку 
				Если МассивРезультатов[9].Пустой() Тогда
					Отказ = Истина;	
					Сообщение = Новый СообщениеПользователю;
					Сообщение.Текст = "По документу продажи '" + ДокументОснованиеВозврата + "' существует заказ на доставку '" + Результат + "', который необходимо удалить.";
					Сообщение.КлючДанных = Результат;
					Сообщение.Сообщить();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура КонтрольОтметкиКассы(Объект, Отказ) Экспорт
	
	Если Не РольДоступна("ПолныеПрава") И Не РольДоступна("ОтметкаКассы")  Тогда

		Если Не Объект.ДополнительныеСвойства.Свойство("ОтключитьКонтроль") Тогда
			Если Объект.Метаданные().Реквизиты.Найти("Кассир") <> Неопределено И Не Объект.Кассир.Пустая() Тогда
				Сообщить("Документ оплачен. Изменение документа запрещено!");
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли Не РольДоступна("ПолныеПрава") И Не РольДоступна("ОтменаПроведенияДокументаРеализации")  Тогда 
		
		Если Не Объект.ДополнительныеСвойства.Свойство("ОтключитьКонтроль") Тогда
			Сообщить("У вас нет прав на отмену проведения документа реализации!");
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ЕстьПроизвольныеЦены(Объект) Экспорт
	
	ЕстьПроизвольныеЦены = Объект.Товары.Выгрузить().Найти(Справочники.ВидыЦен.ПустаяСсылка(), "ВидЦены");
	Если ЕстьПроизвольныеЦены <> Неопределено Тогда
		Возврат Истина;
	КонецЕсли;	
	
	Возврат Ложь; 
	
КонецФункции

Функция ЕстьЗеленение(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура,
		|	Товары.Кладовщик
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Товары.Номенклатура,
		|	ВТ_Товары.Кладовщик
		|ИЗ
		|	ВТ_Товары КАК ВТ_Товары
		|ГДЕ
		|	ВТ_Товары.Кладовщик <> &ПустойКладовщик";
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());		
	Запрос.УстановитьПараметр("ПустойКладовщик", Справочники.Пользователи.ПустаяСсылка());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	сч = 0;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		сч = сч+1;
	КонецЦикла;
	
	Возврат сч;
	
КонецФункции

Функция РасчетыПоДоговорам(Документ) Экспорт
	
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Документ.Соглашение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Документ.Договор) Тогда 
		Возврат Документ.Договор.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Документ.Соглашение.ПорядокРасчетов) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Документ.Соглашение.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов; 
	
КонецФункции

Функция ОпределитьРасчетыПоСоглашению(Соглашение)  Экспорт
	
	//ТЧ -нал, остальное - безнал
	Наименование = СокрЛП(Соглашение.Наименование);	
	ТЧ = Прав(Наименование, 2);
	
	Если ТЧ = "ТЧ" Тогда 
		Возврат "Нал";
	Иначе
		Возврат "БезНал";
	КонецЕсли;
	
КонецФункции

Функция ПолучитьНеЗелененыйТовар(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Номенклатура,
		|	РеализацияТоваровУслугТовары.Характеристика,
		|	РеализацияТоваровУслугТовары.КодСтроки,
		|	РеализацияТоваровУслугТовары.Кладовщик
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И РеализацияТоваровУслугТовары.Кладовщик = ЗНАЧЕНИЕ(Справочник.Пользователи.)";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ; 
	
КонецФункции

Функция ПолучитьРеализацииПоЗаказу(Заказ) Экспорт
	
	мРеализаций = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
		|			И (ЛОЖЬ = РеализацияТоваровУслуг.ПометкаУдаления)
		|ГДЕ
		|	Заказ.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Заказ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		мРеализаций.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Возврат мРеализаций; 
	
КонецФункции

Функция ПолучитьСчФактуруВыданную(ДокументОснование) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СчетФактураВыданныйДокументыОснования.Ссылка КАК Ссылка,
		|	СчетФактураВыданныйДокументыОснования.ДокументОснование КАК ДокументОснование
		|ИЗ
		|	Документ.СчетФактураВыданный.ДокументыОснования КАК СчетФактураВыданныйДокументыОснования
		|ГДЕ
		|	СчетФактураВыданныйДокументыОснования.Ссылка.Проведен
		|	И СчетФактураВыданныйДокументыОснования.ДокументОснование = &ДокументОснование
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СчетФактураВыданныйАванс.Ссылка,
		|	СчетФактураВыданныйАванс.ДокументОснование
		|ИЗ
		|	Документ.СчетФактураВыданныйАванс КАК СчетФактураВыданныйАванс
		|ГДЕ
		|	СчетФактураВыданныйАванс.ДокументОснование = &ДокументОснование
		|	И СчетФактураВыданныйАванс.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СчетФактураКомиссионеру.Ссылка,
		|	СчетФактураКомиссионеру.ДокументОснование
		|ИЗ
		|	Документ.СчетФактураКомиссионеру КАК СчетФактураКомиссионеру
		|ГДЕ
		|	СчетФактураКомиссионеру.Проведен
		|	И СчетФактураКомиссионеру.ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено; 
	
КонецФункции

