Функция ПолучитьСписокЗначениеДопРеквизита(НаименованиеНабораСвойств, НаименованиеСвойства = "") Экспорт
	
	СП = Новый СписокЗначений;
	
	НаборСвойств = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию(НаименованиеНабораСвойств, Истина);
	Если Не ЗначениеЗаполнено(НаборСвойств) Тогда 
		Возврат СП;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗначенияСвойствОбъектов.Ссылка КАК Значение,
	|	ЗначенияСвойствОбъектов.Владелец КАК Владелец,
	|	ЗначенияСвойствОбъектов.Наименование КАК Наименование
	|ИЗ
	|	Справочник.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|ГДЕ
	|	ЗначенияСвойствОбъектов.Владелец = &Владелец
	|	И ЗначенияСвойствОбъектов.Наименование = &Наименование
	|	И ЗначенияСвойствОбъектов.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Владелец", НаборСвойств);
	
	Если ЗначениеЗаполнено(НаименованиеСвойства) Тогда
		Запрос.УстановитьПараметр("Наименование", НаименованиеСвойства);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		Если РезультатЗапроса.Следующий() И ЗначениеЗаполнено(РезультатЗапроса.Значение) Тогда
			Возврат РезультатЗапроса.Значение;
		Иначе
			Возврат Справочники.ЗначенияСвойствОбъектов.ПустаяСсылка();
		КонецЕсли;
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ЗначенияСвойствОбъектов.Наименование = &Наименование", "");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Пока РезультатЗапроса.Следующий() Цикл
		СП.Добавить(РезультатЗапроса.Значение, РезультатЗапроса.Наименование);
	КонецЦикла;
	
	Возврат СП;
	
КонецФункции	

