Функция ПолучитьКороткийАдрес(Адрес) Экспорт
	
	мАдреса = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Адрес, ",", Истина, Истина);
		
	КолСтрок = мАдреса.Количество();
	
	Если КолСтрок > 2 Тогда
		Попытка 
			Индекс = Число(мАдреса[0]);
			мАдреса[0] = "";
		Исключение
		КонецПопытки;
		
		Если мАдреса[0] = "Россия" Тогда
			мАдреса[0] = "";
		КонецЕсли;
		
		Если мАдреса[1] = "Алтайский край" Тогда
			мАдреса[1] = "";
		КонецЕсли;
		
		сч = КолСтрок-1;
		Пока сч >= 0 Цикл
			Если ПустаяСтрока(мАдреса[сч]) Тогда
				мАдреса.Удалить(сч);
			КонецЕсли;
			сч = сч-1;
		КонецЦикла;
		
		КороткийАдрес = СтрСоединить(мАдреса, ", ");
	Иначе
		КороткийАдрес = Адрес;
	КонецЕсли;
	
	Возврат КороткийАдрес;
	
КонецФункции

