Функция ПолучитьВремяЗаездаВыезда(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостояниеОтгрузкиДокумента.Документ КАК Документ,
	|	МИНИМУМ(СостояниеОтгрузкиДокумента.Период) КАК ДатаВремяЗаезда
	|ПОМЕСТИТЬ ВТ_СостояниеОтгрузкиЗаехал
	|ИЗ
	|	РегистрСведений.СостояниеОтгрузкиДокумента КАК СостояниеОтгрузкиДокумента
	|ГДЕ
	|	СостояниеОтгрузкиДокумента.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Заехал)
	|	И СостояниеОтгрузкиДокумента.Документ = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	СостояниеОтгрузкиДокумента.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СостояниеОтгрузкиДокумента.Документ КАК Документ,
	|	МАКСИМУМ(СостояниеОтгрузкиДокумента.Период) КАК ДатаВремяВыезда
	|ПОМЕСТИТЬ ВТ_СостояниеОтгрузкиВыехал
	|ИЗ
	|	РегистрСведений.СостояниеОтгрузкиДокумента КАК СостояниеОтгрузкиДокумента
	|ГДЕ
	|	СостояниеОтгрузкиДокумента.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Выехал)
	|	И СостояниеОтгрузкиДокумента.Документ = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	СостояниеОтгрузкиДокумента.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(РезультатПоВремени.ДатаВремяЗаезда) КАК ВремяЗаезда,
	|	МАКСИМУМ(РезультатПоВремени.ДатаВремяВыезда) КАК ВремяВыезда,
	|	РезультатПоВремени.Документ,
	|	ВЫБОР
	|		КОГДА РезультатПоВремени.ДатаВремяЗаезда = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ РезультатПоВремени.ДатаВремяВыезда = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 0
	|		ИНАЧЕ РАЗНОСТЬДАТ(РезультатПоВремени.ДатаВремяЗаезда, РезультатПоВремени.ДатаВремяВыезда, МИНУТА)
	|	КОНЕЦ КАК ВремяНаОтгрузку
	|ИЗ
	|	(ВЫБРАТЬ
	|		ЕСТЬNULL(ВТ_СостояниеОтгрузкиЗаехал.ДатаВремяЗаезда, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаВремяЗаезда,
	|		ДАТАВРЕМЯ(1, 1, 1) КАК ДатаВремяВыезда,
	|		ВТ_СостояниеОтгрузкиЗаехал.Документ КАК Документ
	|	ИЗ
	|		ВТ_СостояниеОтгрузкиЗаехал КАК ВТ_СостояниеОтгрузкиЗаехал
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ДАТАВРЕМЯ(1, 1, 1),
	|		ЕСТЬNULL(ВТ_СостояниеОтгрузкиВыехал.ДатаВремяВыезда, ДАТАВРЕМЯ(1, 1, 1)),
	|		ВТ_СостояниеОтгрузкиВыехал.Документ
	|	ИЗ
	|		ВТ_СостояниеОтгрузкиВыехал КАК ВТ_СостояниеОтгрузкиВыехал) КАК РезультатПоВремени
	|
	|СГРУППИРОВАТЬ ПО
	|	РезультатПоВремени.Документ,
	|	ВЫБОР
	|		КОГДА РезультатПоВремени.ДатаВремяЗаезда = ДАТАВРЕМЯ(1, 1, 1)
	|				ИЛИ РезультатПоВремени.ДатаВремяВыезда = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 0
	|		ИНАЧЕ РАЗНОСТЬДАТ(РезультатПоВремени.ДатаВремяЗаезда, РезультатПоВремени.ДатаВремяВыезда, МИНУТА)
	|	КОНЕЦ";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Новый  Структура("ВремяЗаезда, ВремяВыезда, ВремяНаОтгрузку",Выборка.ВремяЗаезда, Выборка.ВремяВыезда, Выборка.ВремяНаОтгрузку);
	Иначе
		Возврат Новый  Структура("ВремяЗаезда, ВремяВыезда, ВремяНаОтгрузку",Дата(1,1,1), Дата(1,1,1), 0);
	КонецЕсли; 
	
КонецФункции

Функция КассаККМПоумолчанию(Подразделение)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КассыККМ.Ссылка КАК кассаККМ
		|ИЗ
		|	Справочник.КассыККМ КАК КассыККМ
		|ГДЕ
		|	НЕ КассыККМ.ПометкаУдаления
		|	И КассыККМ.Подразделение = &Подразделение
		|	И КассыККМ.Владелец = КассыККМ.Подразделение.Организация
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	КассыККМ.Ссылка
		|ИЗ
		|	Справочник.КассыККМ КАК КассыККМ
		|ГДЕ
		|	НЕ КассыККМ.ПометкаУдаления
		|	И КассыККМ.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда	
		Возврат ВыборкаДетальныеЗаписи.кассаККМ;
	Иначе
		Возврат Справочники.КассыККМ.ПустаяСсылка();
	КонецЕсли;    
	
КонецФункции 

