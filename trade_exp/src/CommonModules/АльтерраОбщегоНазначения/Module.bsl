Процедура ЗаполнитьТелефонВПартнере(Партнер, Телефон) Экспорт
	
	ТЗКонтактнаяИнформация = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация();
	НоваяСтрока = ТЗКонтактнаяИнформация.Добавить();
	НоваяСтрока.Объект = Партнер;
	НоваяСтрока.Представление = Телефон;
	НоваяСтрока.ЗначенияПолей = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(НоваяСтрока.Представление, НоваяСтрока.Тип);;
	НоваяСтрока.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияВJSON(НоваяСтрока.ЗначенияПолей, НоваяСтрока.Тип);;
	НоваяСтрока.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонПартнера;
	НоваяСтрока.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
	НоваяСтрока.Дата = Неопределено;
	НоваяСтрока.ИдентификаторСтрокиТабличнойЧасти = Неопределено;
	
	УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъектов(ТЗКонтактнаяИнформация, Истина);

