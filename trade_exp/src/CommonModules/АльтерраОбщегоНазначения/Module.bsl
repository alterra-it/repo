Процедура ЗаполнитьМенеджераМагазин(Источник) Экспорт
	
	Если Источник.Метаданные().Реквизиты.Найти("Ответственный") <> Неопределено Тогда
		Если Не ЗначениеЗаполнено(Источник.Ответственный) Тогда
			Источник.Ответственный = Пользователи.ТекущийПользователь();
		КонецЕсли;
	КонецЕсли;
	
	Если Источник.Метаданные().Реквизиты.Найти("Автор") <> Неопределено Тогда
		Если Не ЗначениеЗаполнено(Источник.Автор) Тогда
			Источник.Автор = Пользователи.ТекущийПользователь();
		КонецЕсли;
	КонецЕсли;
	
	Если Источник.Метаданные().Реквизиты.Найти("Менеджер") <> Неопределено Тогда
		Если Не ЗначениеЗаполнено(Источник.Менеджер) Тогда
			Источник.Менеджер = Пользователи.ТекущийПользователь();
		КонецЕсли;
	КонецЕсли;
	
	//Уточнение по документам
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда 	
		Если ЗначениеЗаполнено(Источник.ЗаказКлиента) Тогда
			Источник.Менеджер = Источник.ЗаказКлиента.Менеджер;
		КонецЕсли;
	КонецЕсли;
		
	Если Источник.Метаданные().Реквизиты.Найти("Магазин") <> Неопределено И Источник.Метаданные().Реквизиты.Найти("Менеджер") <> Неопределено И Не ЗначениеЗаполнено(Источник.Магазин) Тогда
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЧекККМВозврат") Тогда
			Источник.Магазин = Источник.КассаККМ.Подразделение;
		ИначеЕсли ТипЗнч(Источник) <> Тип("ДокументОбъект.ЧекККМ") Тогда
			Источник.Магазин = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Источник.Менеджер, Неопределено);
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьРеквизитыПродажи(Объект) Экспорт
	
	Если ЗначениеЗаполнено(Объект.Подразделение) Тогда
		Объект.Партнер = Справочники.Партнеры.РозничныйПокупатель;
		Объект.Контрагент = Справочники.Контрагенты.РозничныйПокупатель;
		Объект.Организация = Объект.Подразделение.Организация;
		Объект.Склад = Объект.Подразделение.СкладПоУмолчанию;
		Объект.Соглашение = Объект.Подразделение.СоглашениеСКлиентомПоУмолчанию;
		Объект.ЦенаВключаетНДС = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПодразделение(Источник) Экспорт
	
	Если Источник.Метаданные().Реквизиты.Найти("Подразделение") <> Неопределено	Тогда
		Если Источник.Метаданные().Реквизиты.Найти("Склад") <> Неопределено Тогда
			Если ЗначениеЗаполнено(Источник.Склад.Подразделение) Тогда
				Источник.Подразделение = Источник.Склад.Подразделение;
			Иначе
				Источник.Подразделение = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Пользователи.ТекущийПользователь(), Неопределено);
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") Тогда
			Подразделение = Источник.Подразделение;
			Если Подразделение = Неопределено Тогда
				Источник.Подразделение = Источник.СкладПолучатель.Подразделение;
			Иначе
				Источник.Организация = Подразделение.Организация;
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.СчетФактураПолученный") Тогда
			Если Источник.ДокументыОснования.Количество() > 0 Тогда
				Источник.Подразделение = Источник.ДокументыОснования[0].ДокументОснование.Подразделение;
			КонецЕсли;
			Источник.Ответственный = Пользователи.ТекущийПользователь();
		КонецЕсли;		
	КонецЕсли;
		
	//Проверка банковского счета
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		Источник.БанковскийСчет = ?(Источник.Организация.ОсновнойБанковскийСчет.Закрыт, "", Источник.Организация.ОсновнойБанковскийСчет);
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		Источник.БанковскийСчетОрганизации = ?(Источник.Организация.ОсновнойБанковскийСчет.Закрыт, "", Источник.Организация.ОсновнойБанковскийСчет);
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

#Область Бригадиры

Процедура СгенерироватьПИНПартнера(Код) Экспорт
	
	ПартнерСсылка = Справочники.Партнеры.НайтиПоКоду(Код);
    ПартнерОбъект = ПартнерСсылка.ПолучитьОбъект();
	ГСЧ = Новый ГенераторСлучайныхЧисел();
    СлучайноеЧисло = ГСЧ.СлучайноеЧисло(0, 9999);  
	СтрокаПина =  Строка(Формат(СлучайноеЧисло,"ЧГ=4"));
	Если СтрДлина(СтрокаПина)<4 Тогда
	   Если СтрДлина(СтрокаПина) = 1 Тогда
	     СтрокаПина = "000"+СтрокаПина;
	   ИначеЕсли СтрДлина(СтрокаПина) = 2 Тогда
	     СтрокаПина = "00"+СтрокаПина;
	   Иначе	
	     СтрокаПина = "0"+СтрокаПина;
	   КонецЕсли; 
	КонецЕсли; 
    ПартнерОбъект.ПИН_Код = СтрокаПина;
    ПартнерОбъект.Записать();
	
КонецПроцедуры 

Функция ЭтоБригадир(Партнер) Экспорт
	
	ГруппаПартнеров = АльтерраОбщегоНазначения.ПолучитьДополнительныйРеквизит(Партнер, "Группы партнеров");
	Если ЗначениеЗаполнено(ГруппаПартнеров) Тогда
		Если ГруппаПартнеров.Наименование = "Бригадиры" Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
