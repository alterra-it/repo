Функция ПолучитьТекущийСтатусВодителя(вхПараметр) Экспорт
	
	Если ТипЗнч(вхПараметр) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Водитель =  вхПараметр;
	ИначеЕсли ТипЗнч(вхПараметр) = Тип("СправочникСсылка.Сотрудники") Тогда
		Водитель =  вхПараметр.ФизическоеЛицо;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыВодителейСрезПоследних.Статус КАК Статус
		|ИЗ
		|	РегистрСведений.СтатусыВодителей КАК СтатусыВодителейСрезПоследних
		|ГДЕ
		|	СтатусыВодителейСрезПоследних.Водитель = &Водитель";
	
	Запрос.УстановитьПараметр("Водитель", Водитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Статус;
	КонецЕсли;
	
	Возврат Перечисления.СтатусыВодителей.НеГотов;
	
КонецФункции

Функция ПолучитьСтруктуруСтатусаВодителя(вхПараметр) Экспорт
	
	Ответ = Новый Структура("Статус,Рейс,Дата", Неопределено, Документы.ЗаданиеНаПеревозкуРейс.ПустаяСсылка(),Дата(1,1,1));
	
	Если ТипЗнч(вхПараметр) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Водитель =  вхПараметр;
	ИначеЕсли ТипЗнч(вхПараметр) = Тип("СправочникСсылка.Сотрудники") Тогда
		Водитель =  вхПараметр.ФизическоеЛицо;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтатусыВодителейСрезПоследних.Статус КАК Статус,
		|	СтатусыВодителейСрезПоследних.Рейс КАК Рейс,
		|	СтатусыВодителейСрезПоследних.Дата КАК Дата
		|ИЗ
		|	РегистрСведений.СтатусыВодителей КАК СтатусыВодителейСрезПоследних
		|ГДЕ
		|	СтатусыВодителейСрезПоследних.Водитель = &Водитель";
	
	Запрос.УстановитьПараметр("Водитель", Водитель);

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Ответ, ВыборкаДетальныеЗаписи);
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Процедура УстановитьСтатусГотовВодителю(Сотрудник, Комментарий = "") Экспорт
	УстановитьСтатусВодителю(Сотрудник,Перечисления.СтатусыВодителей.Готов, Комментарий); 
КонецПроцедуры 

Процедура УстановитьСтатусВодителю(Сотрудник, Статус, Комментарий = "", Дата = '00010101', Рейс = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка	
		Если Не ЗначениеЗаполнено(Сотрудник) Тогда
			Возврат;
		КонецЕсли;
		
		Если ТипЗнч(Сотрудник) <> Тип("СправочникСсылка.ФизическиеЛица") Тогда
			Водитель = Сотрудник.ФизическоеЛицо; 
		Иначе
			Водитель = Сотрудник;
		КонецЕсли;
		ЗаписьСтатусаВодителя = РегистрыСведений.СтатусыВодителей.СоздатьМенеджерЗаписи();
		ЗаписьСтатусаВодителя.Дата = ?(Дата = '00010101', ТекущаяДата(), Дата);
		ЗаписьСтатусаВодителя.Водитель = Водитель;
		ЗаписьСтатусаВодителя.Рейс = Рейс;
		ЗаписьСтатусаВодителя.Статус = Статус;
		ЗаписьСтатусаВодителя.Автор = Пользователи.ТекущийПользователь();
		ЗаписьСтатусаВодителя.Комментарий = Комментарий;
		
		ЗаписьСтатусаВодителя.Записать();
		
		Текст = "Установили статус: " + Статус;
		ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьИнформацию(Сотрудник, Текст);
	Исключение
		Текст = "Ошибка при записи статуса водителя: " + Сотрудник;
		ОбменСМобильнымПриложениемВодителейСервер.ЗарегестрироватьОшибку(Сотрудник, Текст, ИнформацияОбОшибке().Описание);
	КонецПопытки; 
	
	УстановитьПривилегированныйРежим(Ложь);  
	
КонецПроцедуры

Функция ПолучитьВсеВидыАвтомобилей() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВидыТранспортныхСредств.Ссылка КАК Ссылка,
		|	ВидыТранспортныхСредств.Наименование КАК Наименование,
		|	ВидыТранспортныхСредств.Вес КАК Вес,
		|	ВидыТранспортныхСредств.Объем КАК Объем,
		|	ВидыТранспортныхСредств.Длина КАК Длина
		|ИЗ
		|	Справочник.ВидыТранспортныхСредств КАК ВидыТранспортныхСредств
		|ГДЕ
		|	НЕ ВидыТранспортныхСредств.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	МассивДляВозвратаДанных = Новый Массив;
	Пока РезультатЗапроса.Следующий() Цикл
		МассивДляВозвратаДанных.Добавить(Новый Структура("CarTypeID, name, weight, volume, length",
			XMLСтрока(РезультатЗапроса.Ссылка),
			РезультатЗапроса.Наименование,
			РезультатЗапроса.Вес,
			РезультатЗапроса.Объем,
			РезультатЗапроса.Длина));
	КонецЦикла;
	
	Возврат МассивДляВозвратаДанных; 
	
КонецФункции

Функция ПолучитьПодготовленныйРейс(Сотрудник, Статус) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейс.Ссылка КАК Рейс,
		|	ЗаданиеНаПеревозкуРейс.Дата КАК Дата
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеНаПеревозкуРейс
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейс.Проведен
		|	И ЗаданиеНаПеревозкуРейс.Водитель = &Водитель
		|	И ЗаданиеНаПеревозкуРейс.Статус В(&Статус)
		|	И ЗаданиеНаПеревозкуРейс.ВидДоставки <> &ВидДоставки
		|	И ЗаданиеНаПеревозкуРейс.Дата >= &ДатаНачала
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
	
	Запрос.УстановитьПараметр("ВидДоставки", Перечисления.ВидыДоставокДоКлиента.СборнаяОРК);
	Запрос.УстановитьПараметр("Водитель", Сотрудник.ФизическоеЛицо);
	Запрос.УстановитьПараметр("Статус", Статус);
	Запрос.УстановитьПараметр("ДатаНачала", Документы.ЗаданиеНаПеревозкуРейс.ДатаСтартаЦентрализованнойДоставки());
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда 
		Возврат  ВыборкаДетальныеЗаписи.Рейс;
	КонецЕсли;
	
	Возврат Неопределено;   
	
КонецФункции

Функция СотрудникВОфисе(Сотрудник) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УчетРабочегоВремениСотрудниковСрезПоследних.Событие,
		|	УчетРабочегоВремениСотрудниковСрезПоследних.Период КАК Период
		|ИЗ
		|	РегистрСведений.УчетРабочегоВремениСотрудников.СрезПоследних(
		|			,
		|			Сотрудник = &Сотрудник
		|				И Подразделение = &Подразделение
		|				И Пользователь = &Пользователь) КАК УчетРабочегоВремениСотрудниковСрезПоследних
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период";
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Подразделение", Сотрудник.Подразделение);
	Запрос.УстановитьПараметр("Пользователь", Сотрудник.Пользователь);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Если  ВыборкаДетальныеЗаписи.Событие = Перечисления.СостоянияСотрудников.Зашел Тогда
			Состояние = Перечисления.СостоянияСотрудников.Зашел;
			Период = ВыборкаДетальныеЗаписи.Период;
		Иначе
			Состояние = Перечисления.СостоянияСотрудников.Вышел;
			Период = ВыборкаДетальныеЗаписи.Период;
		КонецЕсли;
	Иначе
		Состояние = Перечисления.СостоянияСотрудников.Вышел;
		Период = Дата(0001,01,01);;
	КонецЕсли;
	Рез = Новый Структура("Состояние,Период", Состояние, Период);
	Возврат Рез;
	
КонецФункции

Процедура ОтправитьСМС(Телефон, Текст, СтатусОшибки = Ложь) Экспорт
	// Отправляет SMS через настроенного поставщика услуги, возвращает идентификатор сообщения.
	//
	// Параметры:
	//  НомераПолучателей  - Массив - массив строк номеров получателей в формате +7ХХХХХХХХХХ;
	//  Текст              - Строка - текст сообщения, максимальная длина у операторов может быть разной;
	//  ИмяОтправителя     - Строка - имя отправителя, которое будет отображаться вместо номера у получателей.
	//  ПеревестиВТранслит - Булево - Истина, если требуется переводить текст сообщения в транслит перед отправкой.
	//
	// Возвращаемое значение:
	//  Структура:
	//    * ОтправленныеСообщения - Массив - массив структур:
	//      ** НомерПолучателя - Строка.
	//      ** ИдентификаторСообщения - Строка.
	//    * ОписаниеОшибки - Строка - пользовательское представление ошибки, если пустая строка,
	//                                то ошибки нет.
	
	НомераПолучателей = Новый Массив;
	НомераПолучателей.Добавить(Телефон);
	
	//ИмяОтправителя = "TG_Alterra";
	Попытка
		РезультатОтправки= ОтправкаSMS.ОтправитьSMS(НомераПолучателей, Текст, , Ложь);
		Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда
			СтатусОшибки = Истина;
			ОбщегоНазначения.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки);
		Иначе
			СтатусДоставкиСообщения = ОтправкаSMS.СтатусДоставки(РезультатОтправки.ОтправленныеСообщения[0].ИдентификаторСообщения);
		КонецЕсли;
	Исключение
		СтатусОшибки = Истина;
		ОбщегоНазначения.СообщитьПользователю("Ошибка отправки СМС водителю! Возможно, у Вас нет прав доступа, необходимых для отправки сообщения..");
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтправитьСМСВодителю(Объект) Экспорт
	// Отправляет SMS через настроенного поставщика услуги, возвращает идентификатор сообщения.
	//
	// Параметры:
	//  НомераПолучателей  - Массив - массив строк номеров получателей в формате +7ХХХХХХХХХХ;
	//  Текст              - Строка - текст сообщения, максимальная длина у операторов может быть разной;
	//  ИмяОтправителя     - Строка - имя отправителя, которое будет отображаться вместо номера у получателей.
	//  ПеревестиВТранслит - Булево - Истина, если требуется переводить текст сообщения в транслит перед отправкой.
	//
	// Возвращаемое значение:
	//  Структура:
	//    * ОтправленныеСообщения - Массив - массив структур:
	//      ** НомерПолучателя - Строка.
	//      ** ИдентификаторСообщения - Строка.
	//    * ОписаниеОшибки - Строка - пользовательское представление ошибки, если пустая строка,
	//                                то ошибки нет.
	
	Телефон = ПолучитьТелеофнВодителя(Объект.Водитель);
	НомераПолучателей = Новый Массив;
	НомераПолучателей.Добавить(Телефон);
		
	Текст = "Подойдите за документами на погрузку Рейс №" + Объект.Номер + " от " + Формат(Объект.Дата, "ДФ=dd.MM.yyyy");
	
	РезультатОтправки = ОтправкаSMS.ОтправитьSMS(НомераПолучателей, Текст, , Ложь);
	Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда
		Сообщить(РезультатОтправки.ОписаниеОшибки);
	Иначе
		СтатусДоставкиСообщения = ОтправкаSMS.СтатусДоставки(РезультатОтправки.ОтправленныеСообщения[0].ИдентификаторСообщения);
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьТелеофнВодителя(ФизическоеЛицо) Экспорт
	
	Телефон = "";
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ФизическиеЛицаКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
	|ГДЕ
	|	ФизическиеЛицаКонтактнаяИнформация.Тип = &Тип
	|	И ФизическиеЛицаКонтактнаяИнформация.Вид = &Вид
	|	И ФизическиеЛицаКонтактнаяИнформация.Ссылка = &ФизЛицо";
	
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("ФизЛицо", ФизическоеЛицо);
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Телефон = ВыборкаДетальныеЗаписи.НомерТелефона;
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(Телефон, ,,,, "+7");
	КонецЕсли;
	
	Возврат Телефон; 
	
КонецФункции

Функция ПолучитьФизиЧескоеЛицоПоТелефону(Телефон) Экспорт
	
	ПривестиКФорматуНомерТелефона(Телефон);
	ФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ФизическиеЛицаКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
	|	ФизическиеЛицаКонтактнаяИнформация.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
	|ГДЕ
	|	ФизическиеЛицаКонтактнаяИнформация.Тип = &Тип
	|	И ФизическиеЛицаКонтактнаяИнформация.Вид = &Вид
	|	И ФизическиеЛицаКонтактнаяИнформация.НомерТелефона = &НомерТелефона";
	
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("НомерТелефона", Телефон);
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ФизЛицо = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат ФизЛицо;
	
КонецФункции

Функция ПолучитьВодителяПоТелефону(Телефон) Экспорт
	
	ПривестиКФорматуНомерТелефона(Телефон);
	ФизЛицо = Справочники.ФизическиеЛица.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФизическиеЛицаКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
		|	ФизическиеЛицаКонтактнаяИнформация.Ссылка КАК ФизЛицо,
		|	Сотрудники.Ссылка КАК Сотрудник
		|ИЗ
		|	Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		|		ПО ФизическиеЛицаКонтактнаяИнформация.Ссылка = Сотрудники.ФизическоеЛицо
		|ГДЕ
		|	ФизическиеЛицаКонтактнаяИнформация.Тип = &Тип
		|	И ФизическиеЛицаКонтактнаяИнформация.Вид = &Вид
		|	И ФизическиеЛицаКонтактнаяИнформация.НомерТелефона = &НомерТелефона
		|	И НЕ ФизическиеЛицаКонтактнаяИнформация.Ссылка.ПометкаУдаления
		|	И НЕ Сотрудники.Уволен
		|	И НЕ Сотрудники.ПометкаУдаления
		|	И Сотрудники.Должность = &Видители";
	
	Запрос.УстановитьПараметр("Вид", Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица);
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("НомерТелефона", Телефон);
	Запрос.УстановитьПараметр("Видители", ПолучитьДолжностьВодителя());
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Сотрудник = ВыборкаДетальныеЗаписи.Сотрудник;
	КонецЕсли;
	
	Возврат Сотрудник;  
	
КонецФункции

Функция ПолучитьСотрудникаПоФизЛицу(ФизическоеЛицо) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.ФизическоеЛицо = &ФизическоеЛицо
		|	И Сотрудники.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка; 
	КонецЕсли;
	
	Возврат Справочники.Сотрудники.ПустаяСсылка();  
	
КонецФункции

Функция ЗапретСовмещенияУслугиБезНДС(ДатаДокумента) Экспорт

	Настройки = ДопМодуль.ПолучитьНастройкиХранилища("НастройкаОтдельнойУслугиБезНДС");
	Если Настройки <> Неопределено И ТипЗнч(Настройки) = Тип("Структура") и Настройки.Свойство("ДатаНачала") тогда
			Если Настройки.ДатаНачала <> Дата(1,1,1) И ДатаДокумента >= Настройки.ДатаНачала Тогда
				Возврат Истина
			КонецЕсли;
	КонецЕсли;		
	Возврат Ложь
	
КонецФункции	

Функция ПроверкаУслугБезНДСВместеСТоваром(ДатаДокумента, Товары, Контрагент, Договор) Экспорт   

Если НЕ ЗапретСовмещенияУслугиБезНДС(ДатаДокумента) Тогда
	Возврат Ложь
КонецЕсли;	
Если Контрагент.ЮрФизЛицо <> Перечисления.ЮрФизЛицо.ФизЛицо И ЗначениеЗаполнено(Договор) Тогда
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВР_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВЫБОР
	|			КОГДА ВР_Товары.Номенклатура = &УслугаДоставки
	|					ИЛИ ВР_Товары.Номенклатура = &УслугаРазгрузки
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КоличествоУслугБезНДС,
	|	СУММА(ВЫБОР
	|			КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|					ИЛИ СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара)
	|				ТОГДА 1
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КоличествоТоваров
	|ИЗ
	|	ВР_Товары КАК ВР_Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО ВР_Товары.Номенклатура = СпрНоменклатура.Ссылка";
	
	Запрос.УстановитьПараметр("УслугаРазгрузки", УслугаРазгрузкиБезНДС());
	Запрос.УстановитьПараметр("УслугаДоставки", УслугаДоставкиБезНДС());
	Запрос.УстановитьПараметр("Товары", Товары.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();       
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл          
		Если ВыборкаДетальныеЗаписи.КоличествоУслугБезНДС > 0 И ВыборкаДетальныеЗаписи.КоличествоТоваров > 0 Тогда
		 Сообщение = "Для контрагентов с видом ""Юридическое лицо"" или ""ИП"" услуга без НДС и товары должны быть оформлены отдельными документами.";	
		 ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение);
		 Возврат Истина 
		КонецЕсли; 
	КонецЦикла;	
	Возврат Ложь 
КонецЕсли;
Возврат Ложь;		
	
КонецФункции	


