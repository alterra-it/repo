Функция ПолучитьДанныеКлиентаПоТелефону(Телефон)  Экспорт
	
	ПривестиКФорматуНомерТелефона(Телефон);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыКонтактнаяИнформация.Представление КАК Представление,
		|	ПартнерыКонтактнаяИнформация.Ссылка КАК Ссылка,
		|	ПартнерыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
		|	ПартнерыКонтактнаяИнформация.Ссылка.БонуснаяПрограммаАктивна КАК БонуснаяПрограммаАктивна,
		|	ПартнерыКонтактнаяИнформация.Ссылка.ДатаРождения КАК ДатаРождения,
		|	ПартнерыКонтактнаяИнформация.Ссылка.ДатаРегистрации КАК ДатаРегистрации,
		|	ЕСТЬNULL(ПартнерыДополнительныеРеквизиты.Значение, """") КАК Значение
		|ПОМЕСТИТЬ ВТ_Партнер
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|		ПО ПартнерыКонтактнаяИнформация.Ссылка = ПартнерыДополнительныеРеквизиты.Ссылка
		|			И (&СвойствоГрПарт = ПартнерыДополнительныеРеквизиты.Свойство)
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.НомерТелефона = &НомерТелефона
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Партнер.Ссылка КАК Партнер,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ АнкетированиеОтветы.ШаблонАнкеты) КАК ШаблонАнкеты
		|ПОМЕСТИТЬ ВТ_Анкеты
		|ИЗ
		|	ВТ_Партнер КАК ВТ_Партнер
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АнкетированиеОтветы КАК АнкетированиеОтветы
		|		ПО ВТ_Партнер.Ссылка = АнкетированиеОтветы.Респондент
		|ГДЕ
		|	АнкетированиеОтветы.ШаблонАнкеты = &Анкета50Бонусов
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Партнер.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ЕСТЬNULL(БонусныеБаллы.НачисленоОстаток - Выбор Когда &НовыйПорядокНачисленияБонусов = Истина Тогда БонусныеБаллы.ВРезервеОстаток Иначе 0 Конец, 0) КАК ЧИСЛО(10, 0)) КАК Бонусы,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Статус), """") КАК Статус,
		|	ВТ_Партнер.НомерТелефона КАК Телефон,
		|	ВТ_Партнер.Ссылка КАК Ссылка,
		|	ВТ_Партнер.НомерТелефона КАК НомерТелефона,
		|	ЕСТЬNULL(КартыЛояльности.Штрихкод, """") КАК Штрихкод,
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформацияПочта.АдресЭП, """") КАК АдресЭП,
		|	ВТ_Партнер.БонуснаяПрограммаАктивна КАК БонуснаяПрограммаАктивна,
		|	ВТ_Партнер.ДатаРождения КАК ДатаРождения,
		|	ВТ_Партнер.ДатаРегистрации КАК ДатаРегистрации,
		|	ЕСТЬNULL(ВТ_Анкеты.ШаблонАнкеты, """") КАК Анкета50Бонусов,
		|	ПРЕДСТАВЛЕНИЕ(ВТ_Партнер.Значение) КАК ГруппаПартнеров,
		|	ВЫРАЗИТЬ(ЕСТЬNULL(БонусныеБаллыДоступные.НачисленоОстаток - Выбор Когда &НовыйПорядокНачисленияБонусов = Истина Тогда БонусныеБаллыДоступные.ВРезервеОстаток Иначе 0 Конец, 0) КАК ЧИСЛО(10, 0)) КАК БонусыДоступно,
		|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК REF,
		|	ПРЕДСТАВЛЕНИЕ(ВТ_Партнер.Ссылка) КАК Партнер,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(КартыЛояльности.Владелец), """") КАК ВидКарты,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(КартыЛояльности.Ссылка), """") КАК Карта
		|ИЗ
		|	ВТ_Партнер КАК ВТ_Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.БонусныеБаллы.Остатки КАК БонусныеБаллы
		|		ПО ВТ_Партнер.Ссылка = БонусныеБаллы.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.БонусныеБаллы.Остатки(&Дата, ) КАК БонусныеБаллыДоступные
		|		ПО ВТ_Партнер.Ссылка = БонусныеБаллыДоступные.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СрезПоследних КАК СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних
		|		ПО ВТ_Партнер.Ссылка = СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КартыЛояльности КАК КартыЛояльности
		|		ПО ВТ_Партнер.Ссылка = КартыЛояльности.Партнер
		|			И (&СтатусКарты = КартыЛояльности.Статус)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияПочта
		|		ПО ВТ_Партнер.Ссылка = ПартнерыКонтактнаяИнформацияПочта.Ссылка
		|			И (&ВидПочта = ПартнерыКонтактнаяИнформацияПочта.Вид)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Анкеты КАК ВТ_Анкеты
		|		ПО ВТ_Партнер.Ссылка = ВТ_Анкеты.Партнер";
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Запрос.УстановитьПараметр("НомерТелефона", Телефон);
	Запрос.УстановитьПараметр("ВидПочта", Справочники.ВидыКонтактнойИнформации.EmailПартнера);
	Запрос.УстановитьПараметр("СтатусКарты", Перечисления.СтатусыКартЛояльности.Действует);
	Запрос.УстановитьПараметр("Анкета50Бонусов", Справочники.ШаблоныАнкетАльтерра2.НайтиПоНаименованию("Анкета 50 бонусов", Истина));
	Запрос.УстановитьПараметр("СвойствоГрПарт", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров (Общие)", Истина));
	Запрос.УстановитьПараметр("НовыйПорядокНачисленияБонусов", БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Неопределено));
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Для Каждого стр Из ТЗ Цикл 
		стр.REF = XMLСтрока(стр.Ссылка);
	КонецЦикла;
	ТЗ.Колонки.Удалить("Ссылка");
	
	Возврат ТЗ;
	
КонецФункции 

Функция ПолучитьДанныеПартнера(Партнер) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ АнкетированиеОтветы.ШаблонАнкеты) КАК ШаблонАнкеты
		|ПОМЕСТИТЬ ВТ_Анкеты
		|ИЗ
		|	РегистрСведений.АнкетированиеОтветы КАК АнкетированиеОтветы
		|ГДЕ
		|	АнкетированиеОтветы.ШаблонАнкеты = &Анкета50Бонусов
		|	И АнкетированиеОтветы.Респондент = &Партнер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Партнеры.Ссылка КАК Ссылка,
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформацияПочта.АдресЭП, """") КАК АдресЭП,
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформацияТелефон.НомерТелефона, """") КАК НомерТелефона,
		|	ЕСТЬNULL(ПартнерыКонтактнаяИнформацияТелефон.НомерТелефона, """") КАК Телефон,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(КартыЛояльности.Ссылка), """") КАК Карта,
		|	ВЫРАЗИТЬ(ЕСТЬNULL(БонусныеБаллыОстатки.НачисленоОстаток - Выбор Когда &НовыйПорядокНачисленияБонусов = Истина Тогда БонусныеБаллыОстатки.ВРезервеОстаток Иначе 0 Конец, 0) КАК ЧИСЛО(10, 0)) КАК Бонусы,
		|	ВЫРАЗИТЬ(ЕСТЬNULL(БонусныеБаллыДоступные.НачисленоОстаток - Выбор Когда &НовыйПорядокНачисленияБонусов = Истина Тогда БонусныеБаллыДоступные.ВРезервеОстаток Иначе 0 Конец, 0) КАК ЧИСЛО(10, 0)) КАК БонусыДоступно,
		|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК REF,
		|	ЕСТЬNULL(КартыЛояльности.Штрихкод, """") КАК Штрихкод,
		|	Партнеры.ДатаРегистрации КАК ДатаРегистрации,
		|	Партнеры.БонуснаяПрограммаАктивна КАК БонуснаяПрограммаАктивна,
		|	Партнеры.ДатаРождения КАК ДатаРождения,
		|	Партнеры.Б_Идентификатор КАК Б_Идентификатор,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(ПартнерыДополнительныеРеквизиты.Значение), """") КАК ГруппаПартнеров,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Статус), """") КАК Статус,
		|	ЕСТЬNULL(ВТ_Анкеты.ШаблонАнкеты, """") КАК Анкета50Бонусов,
		|	Партнеры.Представление КАК Партнер,
		|	ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(КартыЛояльности.Владелец), """") КАК ВидКарты
		|ИЗ
		|	Справочник.Партнеры КАК Партнеры
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияТелефон
		|		ПО Партнеры.Ссылка = ПартнерыКонтактнаяИнформацияТелефон.Ссылка
		|			И (&ВидТелефон = ПартнерыКонтактнаяИнформацияТелефон.Вид)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияПочта
		|		ПО Партнеры.Ссылка = ПартнерыКонтактнаяИнформацияПочта.Ссылка
		|			И (&ВидПочта = ПартнерыКонтактнаяИнформацияПочта.Вид)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.БонусныеБаллы.Остатки КАК БонусныеБаллыОстатки
		|		ПО Партнеры.Ссылка = БонусныеБаллыОстатки.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.БонусныеБаллы.Остатки(&Дата, ) КАК БонусныеБаллыДоступные
		|		ПО Партнеры.Ссылка = БонусныеБаллыДоступные.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КартыЛояльности КАК КартыЛояльности
		|		ПО (КартыЛояльности.Партнер = Партнеры.Ссылка)
		|			И (КартыЛояльности.Статус = &СтатусКарты)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|		ПО Партнеры.Ссылка = ПартнерыДополнительныеРеквизиты.Ссылка
		|			И (&СвойствоГрПарт = ПартнерыДополнительныеРеквизиты.Свойство)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СрезПоследних(, Партнер = &Партнер) КАК СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних
		|		ПО Партнеры.Ссылка = СтатусыПартнеровВПрограммеЛояльности_АльтерраСрезПоследних.Партнер
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Анкеты КАК ВТ_Анкеты
		|		ПО (ИСТИНА)
		|ГДЕ
		|	Партнеры.Ссылка = &Партнер";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ВидПочта", Справочники.ВидыКонтактнойИнформации.EmailПартнера);
	Запрос.УстановитьПараметр("ВидТелефон", Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	Запрос.УстановитьПараметр("СтатусКарты", Перечисления.СтатусыКартЛояльности.Действует);
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Запрос.УстановитьПараметр("Анкета50Бонусов", Справочники.ШаблоныАнкетАльтерра2.НайтиПоНаименованию("Анкета 50 бонусов", Истина));
	Запрос.УстановитьПараметр("СвойствоГрПарт", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров (Общие)", Истина));
	Запрос.УстановитьПараметр("НовыйПорядокНачисленияБонусов", БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Неопределено));
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Для Каждого стр Из ТЗ Цикл 
		стр.REF = XMLСтрока(Партнер);
	КонецЦикла;
	ТЗ.Колонки.Удалить("Ссылка");
	
	Возврат ТЗ;
	
