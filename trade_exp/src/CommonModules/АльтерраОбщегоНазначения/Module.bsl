Функция ПолучитьБанковскийСчетПоУмолчанию(Организация, Валюта=Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	БанковскиеСчетаОрганизаций.Ссылка КАК БанковскийСчетОрганизации
		|ИЗ
		|	Справочник.БанковскиеСчетаОрганизаций КАК БанковскиеСчетаОрганизаций
		|ГДЕ
		|	НЕ БанковскиеСчетаОрганизаций.ПометкаУдаления
		|	И НЕ БанковскиеСчетаОрганизаций.Закрыт
		|	И БанковскиеСчетаОрганизаций.Владелец = &Организация
		|	И БанковскиеСчетаОрганизаций.ВалютаДенежныхСредств = &Валюта
		|	И БанковскиеСчетаОрганизаций.Владелец.ОсновнойБанковскийСчет.Ссылка ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Организации.ОсновнойБанковскийСчет
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	НЕ Организации.ОсновнойБанковскийСчет.Ссылка ЕСТЬ NULL
		|	И Организации.Ссылка = &Организация";
	
	Если Не ЗначениеЗаполнено(Валюта) Тогда
		Запрос.УстановитьПараметр("Валюта", Константы.ВалютаРегламентированногоУчета.Получить());	
	Иначе
		Запрос.УстановитьПараметр("Валюта", Валюта);
	КонецЕсли;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.БанковскийСчетОрганизации
	КонецЕсли;
	
	Возврат Справочники.БанковскиеСчетаОрганизаций.ПустаяСсылка(); 
	
КонецФункции

Функция РасчитатьКоличествоПоЕдПоставщика(Номенклатура, НоменклатураПоставщика, КоличествоПоставщика) Экспорт
	
	//Расчет Количества по ед. зм
	РасчетноеКоличество = 0;
	Если Номенклатура.ЕдиницаИзмерения =  НоменклатураПоставщика.ЕдиницаПоставщика Тогда                     
		РасчетноеКоличество = КоличествоПоставщика;
	Иначе
		//Объем
		Если НоменклатураПоставщика.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияОбъема.Получить() И Номенклатура.ОбъемИспользовать Тогда
			РасчетноеКоличество = Номенклатура.ОбъемЧислитель*КоличествоПоставщика/Номенклатура.ОбъемЗнаменатель;
		КонецЕсли;
		//Вес
		Если НоменклатураПоставщика.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияВеса.Получить() И Номенклатура.ВесИспользовать Тогда
			РасчетноеКоличество = Номенклатура.ВесЧислитель*КоличествоПоставщика/Номенклатура.ВесЗнаменатель;
		КонецЕсли;
		//Площадь
		Если НоменклатураПоставщика.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияПлощади.Получить() И Номенклатура.ПлощадьИспользовать Тогда
			РасчетноеКоличество = Номенклатура.ПлощадьЧислитель*КоличествоПоставщика/Номенклатура.ПлощадьЗнаменатель;
		КонецЕсли;
		//Длинна
		Если НоменклатураПоставщика.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияДлины.Получить() И Номенклатура.ДлинаИспользовать Тогда
			РасчетноеКоличество = Номенклатура.ДлинаЧислитель*КоличествоПоставщика/Номенклатура.ДлинаЗнаменатель;
		КонецЕсли;
		//Либо расчетное либо равно КоличествоПоставщика
		РасчетноеКоличество = ?(РасчетноеКоличество=0, КоличествоПоставщика, РасчетноеКоличество);
	КонецЕсли;
	
	Возврат РасчетноеКоличество; 
	
КонецФункции

