Процедура ИзменитьУслугуДоставки(Объект,СтоимостьДоставки,ПричинаОтмены = Неопределено)Экспорт
	
	МассивУслуг = Новый Массив;	

	Услуга = АльтерраОбщегоНазначения.УслугаДоставкиБезНДС();
	МассивУслуг.Добавить(Услуга);
	Услуга =  АльтерраОбщегоНазначения.УслугаДоставкиСНДС();
	МассивУслуг.Добавить(Услуга);
	
	Для Каждого стрУслуга из МассивУслуг Цикл 
		
		Если ПричинаОтмены = Неопределено Тогда 
			СтруктураОтбора = Новый Структура("Номенклатура", стрУслуга);			
		Иначе
			СтруктураОтбора = Новый Структура("Номенклатура, ОтметкаРеализации", стрУслуга,Ложь)  	
		КонецЕсли;    
		
		СтрокиТовара = Объект.Товары.НайтиСтроки(СтруктураОтбора);
	КонецЦикла;
	 
	Если СтрокиТовара.Количество() > 0 Тогда
	 	СтрТовар = СтрокиТовара[0];
	Иначе
		СтрТовар = Объект.Товары.Добавить();
	КонецЕсли;  
		
	    ВидЦены = Справочники.ВидыЦен.ПустаяСсылка();
	    СтрТовар.Номенклатура = Услуга; 
		
		Если ПричинаОтмены <> Неопределено Тогда
			СтоимостьДоставки = СтрТовар.Сумма - СтоимостьДоставки; 
			Если СтоимостьДоставки  < 1 Тогда //Отменяются все неотгруженные товары, нужно отменить и услугу доставки.
				СтрТовар.Отменено = Истина; 
				СтрТовар.ПричинаОтмены = ПричинаОтмены;
				Возврат;
			КонецЕсли;
		КонецЕсли;   
		
	    СтрТовар.Количество = СтоимостьДоставки; 
	    СтрТовар.КоличествоУпаковок = СтрТовар.Количество;
	    СтрТовар.ВидЦены = ?(ЗначениеЗаполнено(Объект.Соглашение), ПодборТоваровСервер.ПолучитьВидЦеныСоглашения(Объект.Соглашение,Объект.Подразделение),ВидЦены);
				
	    СтрТовар.СтавкаНДС = УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата);  
		Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
	       СтрТовар.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить; 
		КонецЕсли;
	    СтрТовар.Упаковка = СтрТовар.Номенклатура.ЕдиницаИзмерения;	
		СтрТовар.Цена = ?(СтрТовар.Цена = 0, 1,СтрТовар.Цена);
		СтрТовар.ЦенаСДоставкойПечать = 1; 
		
		СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);	
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ПересчитатьСумму");
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
		СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
		СтруктураДействий.Вставить("ОчиститьАвтоматическуюСкидку"); 
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрТовар, СтруктураДействий, Неопределено);
	КонецПроцедуры
	
Функция КлиентДистрибуцииИлиКоммерческого(Партнер) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Партнеры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО (Партнеры.ОсновнойМенеджер = ДополнительныеСведения.Объект)
	|ГДЕ
	|	Партнеры.Ссылка = &Партнер
	|	И ДополнительныеСведения.Свойство = &Свойство
	|	И ДополнительныеСведения.Значение в (&МассивЗначений)";
	
	СвойствоОтделы = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Отделы");   
	МассивЗначений = Новый Массив;
	МассивЗначений.Добавить(Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Отдел Дистрибуции",,,СвойствоОтделы));
	МассивЗначений.Добавить(Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Коммерческий отдел",,,СвойствоОтделы));
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("Свойство", СвойствоОтделы);
	Запрос.УстановитьПараметр("МассивЗначений", МассивЗначений);
	
	Возврат НЕ Запрос.Выполнить().Пустой();

КонецФункции

Процедура ПересчитатьЦенуСДоставкойПечать(Товары)  Экспорт
	
	Для Каждого Стр Из Товары Цикл 
		Стр.ЦенаСДоставкойПечать =(Стр.Сумма + Стр.СуммаРТ)/Стр.КоличествоУпаковок; 
		Стр.ПроцентТранспортных = (Стр.ЦенаСДоставкойПечать - Стр.Цена) / Стр.ЦенаСДоставкойПечать;
	КонецЦикла;
	
КонецПроцедуры 

