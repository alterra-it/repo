		Объект.Подразделение = Объект.Склад.Подразделение;
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьВесОбъемТоваров(Товары) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(Товары.Упаковка КАК Справочник.УпаковкиЕдиницыИзмерения) КАК Упаковка,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Товары.Отменено КАК Отменено
		|ПОМЕСТИТЬ Товары
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВЫБОР
		|		КОГДА Товары.Номенклатура.ИспользоватьУпаковки = ЛОЖЬ
		|				ИЛИ ЕСТЬNULL(Товары.Упаковка.ЕдиницаИзмерения, ИСТИНА) = ИСТИНА
		|			ТОГДА ВЫБОР
		|					КОГДА Товары.Номенклатура.ВесЗнаменатель <> 0
		|						ТОГДА Товары.КоличествоУпаковок * Товары.Номенклатура.ВесЧислитель / Товары.Номенклатура.ВесЗнаменатель
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		ИНАЧЕ Товары.Упаковка.Вес * Товары.КоличествоУпаковок
		|	КОНЕЦ КАК Вес,
		|	ВЫБОР
		|		КОГДА Товары.Номенклатура.ИспользоватьУпаковки = ЛОЖЬ
		|				ИЛИ ЕСТЬNULL(Товары.Упаковка.ЕдиницаИзмерения, ИСТИНА) = ИСТИНА
		|			ТОГДА ВЫБОР
		|					КОГДА Товары.Номенклатура.ОбъемЗнаменатель <> 0
		|						ТОГДА Товары.КоличествоУпаковок * Товары.Номенклатура.ОбъемЧислитель / Товары.Номенклатура.ОбъемЗнаменатель
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		ИНАЧЕ Товары.Упаковка.Объем * Товары.КоличествоУпаковок
		|	КОНЕЦ КАК Объем
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	Товары КАК Товары
		|ГДЕ
		|	ИСТИНА
		|	И Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ Товары.Отменено
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ЕСТЬNULL(ВТ_Товары.Вес, 0)) КАК Вес,
		|	СУММА(ЕСТЬNULL(ВТ_Товары.Объем, 0)) КАК Объем
		|ИЗ
		|	ВТ_Товары КАК ВТ_Товары" ;
	
	Запрос.УстановитьПараметр("Товары", Товары);
	
	Рез = Новый Структура("Вес,Объем,СтоимостьТовара",0,0);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, Выборка);
	КонецЕсли;
	
	Возврат Рез; 
	
КонецФункции

Функция ПолучитьВесОбъемТиповой(Номенклатура, Количество=1) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	&Товары КАК ВТ_Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	&Количество * &ТекстЗапросаВесНоменклатуры КАК Вес,
		|	&Количество * &ТекстЗапросаОбъемНоменклатуры КАК Объем
		|ИЗ
		|	ВТ_Товары КАК Товары";
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товары.Номенклатура.ЕдиницаИзмерения",
	"Товары.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товары.Номенклатура.ЕдиницаИзмерения",
	"Товары.Номенклатура"));
	
	
	ТЗ = Новый ТаблицаЗначений;
	Тип = Новый Массив;
	Тип.Добавить(Тип("СправочникСсылка.Номенклатура"));
	ТЗ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов(Тип));
	НоваяСтрока = ТЗ.Добавить();
	НоваяСтрока.Номенклатура = Номенклатура;
	
	Запрос.УстановитьПараметр("Товары", ТЗ);
	Запрос.УстановитьПараметр("Количество", Количество);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Рез = Новый Структура("Вес, Объем", 0,0);
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, ВыборкаДетальныеЗаписи);
		Возврат Рез;
	КонецЕсли;
	
	Возврат Рез; 
	
КонецФункции

Функция ПолучитьСекцииДокумента(Документ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		|	ВЫРАЗИТЬ(Товары.Склад КАК Справочник.Склады) КАК Склад
		|ПОМЕСТИТЬ Товары
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция
		|ИЗ
		|	Товары КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО (ИСТИНА = РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)
		|			И Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|ГДЕ
		|	Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|
		|СГРУППИРОВАТЬ ПО
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток,
		|	Товары.Номенклатура";
	
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
		Запрос.УстановитьПараметр("Товары", Документ.ТоварыДляДовоза);
	Иначе
		Запрос.УстановитьПараметр("Товары", Документ.Товары);
		
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫРАЗИТЬ(Товары.Склад КАК Справочник.Склады)", "&Склад");
			Запрос.УстановитьПараметр("Склад", Документ.Склад);
		ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВЫРАЗИТЬ(Товары.Склад КАК Справочник.Склады)", "&Склад");
			Запрос.УстановитьПараметр("Склад", Документ.СкладПолучатель);
        КонецЕсли;
	КонецЕсли;
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	ТЗ.Свернуть("Секция");
	ТЗ.Сортировать("Секция ВОЗР");
	
	Возврат ТЗ.ВыгрузитьКолонку("Секция"); 
	
КонецФункции

Процедура УстановитьОформлениеЗеленениеСтрокТабличныхЧастей(Форма,ИмяТЧ) Экспорт
	
	УсловноеОформление = Форма.УсловноеОформление;
	ЭлементыФормы = Форма.Элементы;	
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяТЧ);
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект."+ИмяТЧ+".Кладовщик");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", Новый Цвет(0, 128, 0));
	ЖирныйШрифт = Новый Шрифт(,,Истина);
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", ЖирныйШрифт);  
	
КонецПроцедуры

Функция ПолучитьТаруИзНоменклатуры(Номенклатура) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	Номенклатура.ИспользоватьУпаковки КАК ИспользоватьУпаковки,
		|	УпаковкиЕдиницыИзмерения.Ссылка КАК Упаковка,
		|	УпаковкиЕдиницыИзмерения.ПоставляетсяВМногооборотнойТаре КАК ПоставляетсяВМногооборотнойТаре,
		|	УпаковкиЕдиницыИзмерения.НоменклатураМногооборотнаяТара КАК НоменклатураМногооборотнаяТара
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
		|		ПО Номенклатура.НаборУпаковок = УпаковкиЕдиницыИзмерения.Владелец
		|ГДЕ
		|	Номенклатура.Ссылка = &Ссылка
		|	И Номенклатура.ИспользоватьУпаковки
		|	И НЕ УпаковкиЕдиницыИзмерения.ПометкаУдаления
		|	И УпаковкиЕдиницыИзмерения.ПоставляетсяВМногооборотнойТаре
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Номенклатура.Ссылка,
		|	Номенклатура.ЕдиницаИзмерения,
		|	Номенклатура.ИспользоватьУпаковки,
		|	УпаковкиЕдиницыИзмерения.Ссылка,
		|	УпаковкиЕдиницыИзмерения.ПоставляетсяВМногооборотнойТаре,
		|	УпаковкиЕдиницыИзмерения.НоменклатураМногооборотнаяТара
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УпаковкиЕдиницыИзмерения КАК УпаковкиЕдиницыИзмерения
		|		ПО Номенклатура.Ссылка = УпаковкиЕдиницыИзмерения.Владелец
		|ГДЕ
		|	Номенклатура.Ссылка = &Ссылка
		|	И Номенклатура.ИспользоватьУпаковки
		|	И НЕ УпаковкиЕдиницыИзмерения.ПометкаУдаления
		|	И УпаковкиЕдиницыИзмерения.ПоставляетсяВМногооборотнойТаре";
	
	Запрос.УстановитьПараметр("Ссылка", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.НоменклатураМногооборотнаяТара;
	КонецЕсли;
	
	Возврат Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка();
	
КонецФункции

