Функция ПолучитьПараметрыКассы(Касса, ДокументПродажи, ДокументОплаты, СуммаОплаты, ИмяСобытия) Экспорт
	
	Адрес = Касса.IP;
	Порт = Касса.Порт;
	ИДУстройства = Касса.ИДУстройства; 
	Логин = ?(ЗначениеЗаполнено(Касса.ПользовательУстройства), Касса.ПользовательУстройства, Неопределено);
	Пароль = ?(ЗначениеЗаполнено(Касса.ПарольУстройства), Касса.ПарольУстройства, Неопределено);
	
	ПараметрыПодключения = АТОЛСревер.ПолучитьПараметрыСоединения(Адрес, Порт, Логин, Пароль, Ложь, ИДУстройства);
	ПараметрыПодключения.Таймаут = 5;
	
	ПараметрыАТОЛ = АТОЛСревер.ШаблонПараметровАТОЛ();
	ПараметрыАТОЛ.ПараметрыПодключения = ПараметрыПодключения;
	ПараметрыАТОЛ.ИДУстройства = ПараметрыПодключения.ИДУстройства;
	ПараметрыАТОЛ.Кассир = Касса.Кассир;
	ПараметрыАТОЛ.НеПечататьЧек = Касса.НеПечататьЧек;
	ПараметрыАТОЛ.СуммаОплаты = СуммаОплаты;
	
	Ответ = АТОЛСревер.ПроверитьСвязь(ПараметрыАТОЛ);
	Если Ответ.Свойство("Ошибка") И Ответ.Ошибка Тогда
		Возврат Ответ;
	КонецЕсли;
	
	//Информация о кассовой смене
	ИнформацияОКассовойСмене = АТОЛСревер.ИнформацияОКассовойСмене(ПараметрыАТОЛ);
	
	Если ИнформацияОКассовойСмене.Свойство("Ошибка") И ИнформацияОКассовойСмене.Ошибка Тогда
		ИнформацияОКассовойСмене.Вставить("ПолучениеИнформацииОКассовойСмене", Истина);
		Возврат ИнформацияОКассовойСмене;
	ИначеЕсли ИнформацияОКассовойСмене.Свойство("state") И ИнформацияОКассовойСмене.state = "expired" Тогда  
		Ответ = АТОЛСревер.ЗакрытьСмену(ПараметрыАТОЛ);
	КонецЕсли;	
	
	//Информация О ККТ
	ИнформацияККТ = АТОЛСревер.ИнформацияОККТ(ПараметрыАТОЛ);
	ПараметрыАТОЛ.Вставить("ИнформацияККТ", ИнформацияККТ);
	
	ПараметрыАТОЛ.ДокументПродажи = ДокументПродажи;
	ПараметрыАТОЛ.ДокументОплаты = ДокументОплаты;
	
	Возврат ПараметрыАТОЛ;
	
КонецФункции 

