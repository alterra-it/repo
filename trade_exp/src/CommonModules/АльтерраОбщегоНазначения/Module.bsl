		Возврат Координаты;
	ИначеЕсли Филиал.Код ="0А-000004" Тогда
		Координаты = Новый Структура("Широта, Долгота, Адрес", 52.57366, 85.180528, Адрес);
		Возврат Координаты;
	ИначеЕсли Филиал.Код ="01-000002" Тогда
		Координаты = Новый Структура("Широта, Долгота, Адрес", 51.9747, 85.8501, Адрес);
