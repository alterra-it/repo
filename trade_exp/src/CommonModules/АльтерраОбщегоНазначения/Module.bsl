#Область Геокодированием 

Функция ПолучитьАдресаКлиента(Партнер) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	мАдресов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КоординатыОбъектов.Объект,
		|	КоординатыОбъектов.Широта,
		|	КоординатыОбъектов.Долгота,
		|	КоординатыОбъектов.Представление,
		|	КоординатыОбъектов.Адрес
		|ИЗ
		|	РегистрСведений.КоординатыОбъектов КАК КоординатыОбъектов
		|ГДЕ
		|	КоординатыОбъектов.Объект = &Партнер";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		мАдресов.Добавить(ВыборкаДетальныеЗаписи.Представление);
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат мАдресов; 
	
КонецФункции

Процедура ЗаписатьКоординаты(Координаты, Адрес, Партнер, ТелефонКлиентаНаВыгрузке="")  Экспорт
	
	НаборЗаписей = РегистрыСведений.КоординатыОбъектов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Установить(Партнер);
	НаборЗаписей.Отбор.Адрес.Установить(Адрес);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() = 0 Тогда
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Объект = Партнер;
		НоваяЗапись.Адрес = Адрес;
		НоваяЗапись.Широта = Координаты.Широта;
		НоваяЗапись.Долгота = Координаты.Долгота;
		НоваяЗапись.Представление = ПолучитьпредставленияАдреса(Координаты, Адрес);
		НоваяЗапись.ТелефонКлиентаНаВыгрузке = ТелефонКлиентаНаВыгрузке;
	Иначе
		НоваяЗапись = НаборЗаписей[0];
		НоваяЗапись.Широта = Координаты.Широта;
		НоваяЗапись.Долгота = Координаты.Долгота;
		НоваяЗапись.Представление = ПолучитьпредставленияАдреса(Координаты, Адрес);
	КонецЕсли;
	НаборЗаписей.Записать(Истина);  
	
КонецПроцедуры

