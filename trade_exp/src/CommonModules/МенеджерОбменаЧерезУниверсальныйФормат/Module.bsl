	КонецЕсли;
	СтруктураКлючевыеСвойства = Новый Структура("Дата, Номер, Ссылка, Организация");  
	//++ Локализация
	ОснованиеПоСчетуФактуре = Неопределено;
	Если ТипЗнч(ДанныеИБ.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		
