			|					КОГДА ЕСТЬNULL(&Курс, 0) > 0
			|							И ЕСТЬNULL(&Кратность, 0) > 0
			|						ТОГДА ВЫРАЗИТЬ(ВидыЗапасов.СебестоимостьРегл / &Курс / &Кратность КАК ЧИСЛО(31, 2))
