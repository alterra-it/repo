Процедура ПКО_Документ_ПорчаВСписаниеЗапасов_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.10") Тогда
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
										"Документ_ПорчаВСписаниеЗапасов_Отправка", 
										"Товары", 
										"НомерГТД",
										Истина,
										"Справочник_НомераГТД_Отправка");
	КонецЕсли;
	
	Префикс = "S";
	//++ Локализация
	Префикс = "Ч";
	//-- Локализация
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеИБ.Номер, 5) + Префикс + Сред(ДанныеИБ.Номер, 7));
	
	СкладДляВыгрузки = СкладДляВыгрузки(ДанныеИБ.Склад, КомпонентыОбмена.ПараметрыКонвертации);
	ДанныеXDTO.Вставить("Склад", СкладДляВыгрузки);
	
	ВыгрузитьПодразделениеИзРеквизитаДокумента(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, "Склад");
	ВыгрузитьНалогообложениеНДС(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, Ложь, Ложь);
	
	ВыгрузитьДополнительныеРеквизитыИСведения(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO);
	
	ДанныеXDTO.Вставить("Основание", Строка(ДанныеИБ));
	
	#Область Товары
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ВидыЗапасов.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВидыЗапасов.АналитикаУчетаНоменклатуры.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ВидыЗапасов.Количество КАК Количество,
		|	ВидыЗапасов.НомерГТД КАК НомерГТД,
		|	ВидыЗапасов.КоличествоПоРНПТ КАК КоличествоПоРНПТ,
		|	1 КАК Коэффициент,
		|	ВЫБОР
		|		КОГДА ВидыЗапасов.ВидЗапасов.ТипЗапасов = ЗНАЧЕНИЕ(Перечисление.ТипыЗапасов.КомиссионныйТовар)
		|			ТОГДА ВЫРАЗИТЬ(""КомиссионныеТовары"" КАК СТРОКА(20))
		|		ИНАЧЕ ВЫРАЗИТЬ(&СобственныеТовары КАК СТРОКА(20))
		|	КОНЕЦ КАК ТипЗапасов,
		|	ВидыЗапасов.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
		|	ВидыЗапасов.АналитикаУчетаНоменклатуры.Серия КАК Серия
		|ПОМЕСТИТЬ ВидыЗапасов
		|ИЗ
		|	Документ.ПорчаТоваров.ВидыЗапасов КАК ВидыЗапасов
		|ГДЕ
		|	ВидыЗапасов.Ссылка = &Ссылка
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	МАКСИМУМ(Товары.НомерСтроки) КАК НомерСтроки
		|ПОМЕСТИТЬ ПорядокСтрокТаблицыТовары
		|ИЗ
		|	Документ.ПорчаТоваров.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	Товары.Номенклатура
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВидыЗапасов.Номенклатура КАК Номенклатура,
		|	ВидыЗапасов.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ВидыЗапасов.Коэффициент КАК Коэффициент,
		|	ВидыЗапасов.ТипЗапасов КАК ТипЗапасов,
		|	ЕСТЬNULL(ПорядокСтрокТаблицыТовары.НомерСтроки, 0) КАК НомерСтрокиДокумента,
		|	ВидыЗапасов.Количество КАК Количество,
		|	&ТекстЗапросаХарактеристика,
		|	&ТекстЗапросаСерия,
		|	&ТекстЗапросаРНПТ,
		|	&ТекстЗапросаГТД
		|ИЗ
		|	ВидыЗапасов КАК ВидыЗапасов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ПорядокСтрокТаблицыТовары КАК ПорядокСтрокТаблицыТовары
		|		ПО ВидыЗапасов.Номенклатура = ПорядокСтрокТаблицыТовары.Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЕСТЬNULL(ПорядокСтрокТаблицыТовары.НомерСтроки, 0)";
	
	ЗаполнитьСобственныеТоварыВТексте(ТекстЗапроса);
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаХарактеристика",
		ПолучитьТекстЗапросаХарактеристики(КомпонентыОбмена, "ВидыЗапасов"));
		
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаСерия",
		ПолучитьТекстЗапросаСерии(КомпонентыОбмена, "ВидыЗапасов"));
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаРНПТ",
		ПолучитьТекстЗапросаРНПТ(КомпонентыОбмена, "ВидыЗапасов"));
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ТекстЗапросаГТД",
		ПолучитьТекстЗапросаГТД(КомпонентыОбмена, "ВидыЗапасов"));
		
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
	Товары = Запрос.Выполнить().Выгрузить();
	ЗаполнитьХарактеристикуУпаковкуВТЧ(КомпонентыОбмена, Товары, Истина, Ложь);
	
	ДанныеXDTO.Вставить("Товары", Товары);
	
	//++ Локализация
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.16") Тогда
		ИмяТаблицы = "Документ.ПорчаТоваров.ВидыЗапасов"; 
		ИдентификаторыИзВидовЗапасов = Истина;
		ПолучитьСведенияОПрослеживаемости(ИмяТаблицы, ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, ИдентификаторыИзВидовЗапасов);
	КонецЕсли; 
	//-- Локализация
	
	#КонецОбласти
КонецПроцедуры

#КонецОбласти

#Область Документ_ВозвратТоваровМеждуОрганизациями
&После("ПКО_ВозвратМеждуОрганизациями_ОтПокупателя_Отправка_ПриОтправкеДанных")
Процедура Док_ПКО_ВозвратМеждуОрганизациями_ОтПокупателя_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если ДанныеXDTO.Свойство("Склад") И ДанныеXDTO.Свойство("Подразделение") Тогда
		Если ЗначениеЗаполнено(ДанныеИБ.СкладПолучатель) Тогда
			ДанныеXDTO.Склад = ДанныеИБ.СкладПолучатель;	
			Если ТипЗнч(ДанныеXDTO.Подразделение) = Тип("Структура") И ДанныеXDTO.Подразделение.Свойство("Значение") Тогда
				ДанныеXDTO.Подразделение.Значение = ДанныеИБ.СкладПолучатель.Подразделение;
			ИначеЕсли ТипЗнч(ДанныеXDTO.Подразделение) = Тип("СправочникСсылка.СтруктураПредприятия") Тогда
				ДанныеXDTO.Подразделение = ДанныеИБ.СкладПолучатель.Подразделение;	
			КонецЕсли;
		Иначе
			ДанныеXDTO.Склад = ДанныеИБ.Склад;	
			Если ТипЗнч(ДанныеXDTO.Подразделение) = Тип("Структура") И ДанныеXDTO.Подразделение.Свойство("Значение") Тогда
				ДанныеXDTO.Подразделение.Значение = ДанныеИБ.Склад.Подразделение;
			ИначеЕсли ТипЗнч(ДанныеXDTO.Подразделение) = Тип("СправочникСсылка.СтруктураПредприятия") Тогда
				ДанныеXDTO.Подразделение = ДанныеИБ.Склад.Подразделение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область Документ_РКО_Отправка
&ИзменениеИКонтроль ("ПКО_Документ_РКОВыплатаЗарплаты_Отправка_ПриОтправкеДанных")
Процедура ДОК_ПКО_Документ_РКОВыплатаЗарплаты_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	
	ВыгрузитьПодразделениеИзРеквизитаДокумента(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, "Касса");
	ВыгрузитьОтветственноеЛицо(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, "ГлавныйБухгалтер");
	ВыгрузитьОтветственноеЛицо(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, "Руководитель");
	ВыгрузитьДополнительныеРеквизитыИСведения(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO);
	
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.7")
		И ЗначениеЗаполнено(ДанныеИБ.ЗаявкаНаРасходованиеДенежныхСредств) Тогда
		ДанныеXDTO.Вставить("ЗаявкаНаРасходДенежныхСредств", ДанныеИБ.ЗаявкаНаРасходованиеДенежныхСредств);
	КонецЕсли;
	
	ТабРасшифровка = Новый ТаблицаЗначений;
	ТабРасшифровка.Колонки.Добавить("СтатьяДДС");
	ТабРасшифровка.Колонки.Добавить("Сумма");
	ТабРасшифровка.Колонки.Добавить("ДатаВедомостиНаВыплатуЗарплаты");
	ТабРасшифровка.Колонки.Добавить("НомерВедомостиНаВыплатуЗарплаты");
	ТабРасшифровка.Колонки.Добавить("Сотрудник");
	
	НоваяСтрока = ТабРасшифровка.Добавить();
	НоваяСтрока.СтатьяДДС = ДанныеИБ.СтатьяДвиженияДенежныхСредств;
	НоваяСтрока.Сумма = ДанныеИБ.СуммаДокумента;
	
	НоваяСтрока.ДатаВедомостиНаВыплатуЗарплаты = ДанныеИБ.ДатаВедомостиНаВыплатуЗарплаты;
	НоваяСтрока.НомерВедомостиНаВыплатуЗарплаты = ДанныеИБ.НомерВедомостиНаВыплатуЗарплаты;
	Если ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаботнику
		ИЛИ ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыРаздатчиком Тогда
		НоваяСтрока.Сотрудник = ДанныеИБ.ПодотчетноеЛицо;
	КонецЕсли;	
	#Вставка
	КодАльтерра(ДанныеИБ, НоваяСтрока);
	#КонецВставки
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", ТабРасшифровка);
КонецПроцедуры

Процедура КодАльтерра(ДанныеИБ, НоваяСтрока)
	Если ДанныеИБ.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("01-000007") // Депонированная заработная плата (76.04)
		И ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВыплатаЗарплатыЧерезКассу 
		И ЗначениеЗаполнено(ДанныеИБ.Выдать) Тогда 
		Сотрудник = ДопМодуль.НайтиФизЛицоПоНаименованию(ДанныеИБ.Выдать);
		Если ЗначениеЗаполнено(Сотрудник) Тогда    
			НоваяСтрока.Сотрудник = Сотрудник;   
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

// новые правила
&После ("ПОД_Документ_СписаниеБезналичныхДенежныхСредств_ПриОбработке")
Процедура ДОК_ПОД_Документ_СписаниеБезналичныхДенежныхСредств_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	Если ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыНаПлатежнуюКарту Тогда     
		ИспользованиеПКО.Документ_СБДСРасчетыСКонтрагентами_Отправка = Истина;
	КонецЕсли;
конецпроцедуры	

&ИзменениеИКонтроль("ПКО_Документ_СБДСРасчетыСКонтрагентами_Отправка_ПриОтправкеДанных")
Процедура Док_ПКО_Документ_СБДСРасчетыСКонтрагентами_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	ПривестиНомерКФормату11(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO);
	
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.17") Тогда
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
										"Документ_СБДСРасчетыСКонтрагентами_Отправка", 
										"РасшифровкаПлатежа", 
										"СтавкаНДС",
										Истина,
										"СправочникСсылка_СтавкиНДС_Отправка");
	КонецЕсли;
	
	ПодразделениеИБ = ДанныеИБ["Подразделение"];
	Если ЗначениеЗаполнено(ПодразделениеИБ) Тогда
		ВыгрузитьПодразделение(ДанныеИБ, ДанныеXDTO, ПодразделениеИБ, "Подразделение");
	Иначе
		ВыгрузитьПодразделениеИзРеквизитаДокумента(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, "БанковскийСчет");
	КонецЕсли;
	
	ВыгрузитьДополнительныеРеквизитыИСведения(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO);
	
	Если ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ОплатаДенежныхСредствВДругуюОрганизацию
		Или ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствВДругуюОрганизацию Тогда
		
		ДанныеКонтрагента = ПолучитьДанныеКонтрагентаПоБанкСчетуОрганизации(ДанныеИБ.БанковскийСчетПолучатель, КомпонентыОбмена);
		ДанныеXDTO.Вставить("Контрагент",     ДанныеКонтрагента.Контрагент);
		ДанныеXDTO.Вставить("БанковскийСчет", ДанныеКонтрагента.БанковскийСчетКонтрагента);
	
		КонтрагентСсылка = ДанныеКонтрагента.Контрагент;
	ИначеЕсли ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыНаПлатежнуюКарту	Тогда
		КонтрагентСсылка = ?(ЗначениеЗаполнено(ДанныеИБ.Контрагент), ДанныеИБ.Контрагент, Справочники.Контрагенты.ПустаяСсылка());
		ДанныеXDTO.Вставить("Контрагент",      КонтрагентСсылка);
		ДанныеXDTO.Вставить("БанковскийСчет",  ДанныеИБ.БанковскийСчетКонтрагента);
	Иначе
		
		КонтрагентСсылка = ?(ЗначениеЗаполнено(ДанныеИБ.Контрагент), ДанныеИБ.Контрагент, Справочники.Контрагенты.ПустаяСсылка());
		ДанныеXDTO.Вставить("БанковскийСчет", ДанныеИБ.БанковскийСчетКонтрагента);
		ДанныеXDTO.Вставить("Контрагент",     КонтрагентСсылка);
	
	КонецЕсли;
	
	ЗаполнитьДанныеВходящегоДокументаСБДС(ДанныеИБ, ДанныеXDTO);
	
	ДанныеШапки = ДанныеИБ.ДополнительныеСвойства.ДанныеШапки;
	#Удаление
	ДанныеXDTO.Вставить("ВидРасчетов", ДанныеШапки.ВидРасчетов);
#КонецУдаления
	#Вставка
	Если ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыНаПлатежнуюКарту тогда
		ДанныеXDTO.Вставить("ВидРасчетов", "Прочее");
	иначе     
		ДанныеXDTO.Вставить("ВидРасчетов", ДанныеШапки.ВидРасчетов);
	конецесли;
	#КонецВставки
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.7")
		И ЗначениеЗаполнено(ДанныеИБ.ЗаявкаНаРасходованиеДенежныхСредств) Тогда
		ДанныеXDTO.Вставить("ЗаявкаНаРасходДенежныхСредств", ДанныеИБ.ЗаявкаНаРасходованиеДенежныхСредств);
	КонецЕсли;
	
	Если ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыНаПлатежнуюКарту	Тогда 
		РасшифровкаПлатежа = Новый ТаблицаЗначений;
		РасшифровкаПлатежа.Колонки.Добавить("Договор");
		РасшифровкаПлатежа.Колонки.Добавить("ДокументРасчетов");
		РасшифровкаПлатежа.Колонки.Добавить("Сумма");
		РасшифровкаПлатежа.Колонки.Добавить("ВалютаВзаиморасчетов");  
		НоваяСтрока = РасшифровкаПлатежа.Добавить();
		НоваяСтрока.Сумма = ДанныеИБ.СуммаДокумента;
		НоваяСтрока.ВалютаВзаиморасчетов = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ДанныеИБ.Организация); 
		НоваяСтрока.Договор = ДанныеИБ.Договор;
		Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) < ВерсияФорматаЧислом("1.17") Тогда   
			ПереопределитьСтавкуНДСДляСтарыхФорматов(РасшифровкаПлатежа, Ложь);
		КонецЕсли; 
		ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
	Иначе
		ВыгрузитьРасшифровкуКонтрагенты_СписаниеДС(ДанныеИБ, ДанныеXDTO, КонтрагентСсылка, КомпонентыОбмена);
	КонецЕсли;
	#Вставка   
	Если ДанныеИБ.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыНаПлатежнуюКарту тогда
		ТабРасшифровка = Новый ТаблицаЗначений;
		ТабРасшифровка.Колонки.Добавить("СтатьяДДС");
		ТабРасшифровка.Колонки.Добавить("Сумма");
		ТабРасшифровка.Колонки.Добавить("СуммаВзаиморасчетов");
		ТабРасшифровка.Колонки.Добавить("СчетУчетаРасчетовСКонтрагентом");
		ТабРасшифровка.Колонки.Добавить("Договор");    
		ТабРасшифровка.Колонки.Добавить("Заказ");    
		
		ПараметрыПоУмолчанию = Новый Структура(ДоговорФиксированнаяСтруктураКлючей());
		ПараметрыПоУмолчанию.Организация              = ДанныеИБ.Организация;
		ПараметрыПоУмолчанию.Контрагент               = КонтрагентСсылка;
		ПараметрыПоУмолчанию.ВидДоговора              = "Прочее";
		ПараметрыПоУмолчанию.Наименование              =
		ПараметрыПоУмолчанию.ВалютаВзаиморасчетов     = ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ДанныеИБ.Организация);
		ПараметрыПоУмолчанию.РасчетыВУсловныхЕдиницах = Ложь;	
		
		НоваяСтрока = ТабРасшифровка.Добавить();
		НоваяСтрока.СтатьяДДС         = ДанныеИБ.СтатьяДвиженияДенежныхСредств;
		НоваяСтрока.Сумма             = ДанныеИБ.СуммаДокумента;
		НоваяСтрока.СуммаВзаиморасчетов             = ДанныеИБ.СуммаДокумента;
		НоваяСтрока.СчетУчетаРасчетовСКонтрагентом = "57.03";
        ДоговорЭквайринга=ДоговорИнструкцияКонвертацииПоДаннымВзаиморасчетов(ПараметрыПоУмолчанию, КомпонентыОбмена);
		НоваяСтрока.Договор           = ДоговорЭквайринга;	 
	  
		ДанныеXDTO.Вставить("РасшифровкаПлатежа", ТабРасшифровка);		
		
 	иначе     
		ВыгрузитьРасшифровкуКонтрагенты_СписаниеДС(ДанныеИБ, ДанныеXDTO, КонтрагентСсылка, КомпонентыОбмена);
	конецесли;
	#КонецВставки
КонецПроцедуры
&После ("ПКО_Документ_ВЗ_НашаОрганизация_ПриОтправкеДанных")
Процедура Док_ПКО_Документ_ВЗ_НашаОрганизация_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	
	ДанныеXDTO.Вставить("КонтрагентДебитор",  КонтрагентПоРеквизиту(ДанныеИБ.КонтрагентДебитор));
	ДанныеXDTO.Вставить("КонтрагентКредитор", КонтрагентПоРеквизиту(ДанныеИБ.КонтрагентКредитор));
	
КонецПроцедуры

&ИзменениеИКонтроль("ВыгрузитьТаблицуЗадолженности")
Функция Док_ВыгрузитьТаблицуЗадолженности(ИмяТЧ, Ссылка, ТекКонтрагент, ТекОрганизация, ОрганизацияДокумента = Неопределено, КомпонентыОбмена)
	ТекстЗапроса = "ВЫБРАТЬ
		|	Задолженность.ОбъектРасчетов.Объект КАК Заказ,
		|	Задолженность.ТипРасчетов КАК ВидРасчетов,
		|	Задолженность.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
		|	Задолженность.СуммаРегл КАК Сумма,
		|	Задолженность.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
		|	ЕстьNULL(КурсыВалют.КурсЧислитель, 1) КАК КурсВзаиморасчетов,
		|	ЕстьNULL(КурсыВалют.КурсЗнаменатель, 1) КАК КратностьВзаиморасчетов
		|ИЗ &ТаблицаДокумента КАК Задолженность
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(&ДатаДок, БазоваяВалюта = &БазоваяВалюта) КАК КурсыВалют
		|	ПО Задолженность.ВалютаВзаиморасчетов = КурсыВалют.Валюта 
		|ГДЕ
		|	Задолженность.Ссылка = &Ссылка";
	
	Запрос = Новый Запрос;
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.КорректировкаЗадолженности") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Задолженность.СуммаРегл КАК",
			"ВЫРАЗИТЬ(Задолженность.Сумма * ЕСТЬNULL(КурсыВалют.КурсЧислитель, 1) / ЕСТЬNULL(КурсыВалют.КурсЗнаменатель, 1) КАК ЧИСЛО(31, 2)) КАК");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Задолженность.СуммаВзаиморасчетов КАК", "Задолженность.Сумма КАК");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.КорректировкаПриобретения") Или ТипЗнч(Ссылка) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Задолженность.СуммаРегл КАК",
			"ВЫРАЗИТЬ(Задолженность.СуммаКорректировки * ЕСТЬNULL(КурсыВалют.КурсЧислитель, 1) / ЕСТЬNULL(КурсыВалют.КурсЗнаменатель, 1) КАК ЧИСЛО(31, 2)) КАК");
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Задолженность.ВалютаВзаиморасчетов",
			"Задолженность.Ссылка.ВалютаВзаиморасчетов"); 
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.КорректировкаПриобретения") Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Задолженность.ТипРасчетов КАК",
				"ЗНАЧЕНИЕ(Перечисление.ТипыРасчетовСПартнерами.РасчетыСПоставщиком)");
		Иначе
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Задолженность.ТипРасчетов КАК",
				"ЗНАЧЕНИЕ(Перечисление.ТипыРасчетовСПартнерами.РасчетыСКлиентом)");
		КонецЕсли;
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "&ТаблицаДокумента", "Документ." + Ссылка.Метаданные().Имя + "." + ИмяТЧ);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ДатаДок", Ссылка.Дата);
	Запрос.УстановитьПараметр("БазоваяВалюта", ЗначениеНастроекПовтИсп.ВалютаРегламентированногоУчетаОрганизации(ТекОрганизация));
	ДанныеЗадолженность = Запрос.Выполнить().Выгрузить();
	
	ДанныеЗадолженность.Колонки.Добавить("Договор");
	ДанныеЗадолженность.Колонки.Добавить("ДокументРасчетов");
	
	Для Каждого СтрокаТаблицы Из ДанныеЗадолженность Цикл
		
		
		Если ЗначениеЗаполнено(СтрокаТаблицы.Заказ) Тогда
			
			ТипЗаказа = ТипЗнч(СтрокаТаблицы.Заказ);
			
			Если ТипЗаказа = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
				СтрокаТаблицы.Договор = СтрокаТаблицы.Заказ;
				#Вставка
				если ТекКонтрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо тогда
					НазваниеПоУмолчанию = ТекКонтрагент.Партнер.Наименование + " " + Строка(ТекКонтрагент.Партнер.код);
					ПараметрыПоУмолчанию = Новый Структура(ДоговорФиксированнаяСтруктураКлючей());
                    заполнитьЗначенияСвойств(ПараметрыПоУмолчанию,СтрокаТаблицы.Договор);  
					ПараметрыПоУмолчанию.Вставить("Контрагент", КонтрагентПоРеквизиту(ТекКонтрагент)); 
					ПараметрыПоУмолчанию.Вставить("Наименование", НазваниеПоУмолчанию);    
					ПараметрыПоУмолчанию.Вставить("РасчетыВУсловныхЕдиницах", ложь); 
					ПараметрыПоУмолчанию.Вставить("ВидДоговора", "СПокупателем"); 
					
					Договор = Новый Структура("Значение, ИмяПКО", ПараметрыПоУмолчанию, "Справочник_ДоговорыКонтрагентов_ИзСтруктуры");
					СтрокаТаблицы.Договор = Договор;

				конецесли;
				#КонецВставки

			Иначе
				Если СтрокаТаблицы.Заказ.Метаданные().Реквизиты.Найти("Договор") <> Неопределено Тогда
					ТекДоговор = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТаблицы.Заказ, "Договор");
					Если ТипЗнч(ТекДоговор) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
						СтрокаТаблицы.Договор = ТекДоговор;
					КонецЕсли;
				КонецЕсли;
				
				ИмяПКО = ИмяПКОДляОбъектаДанных(КомпонентыОбмена, СтрокаТаблицы.Заказ, ТекКонтрагент);
				
				Если Не ПустаяСтрока(ИмяПКО) Тогда
					СтрокаТаблицы.ДокументРасчетов = Новый Структура("Значение, ИмяПКО", СтрокаТаблицы.Заказ, ИмяПКО);
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СтрокаТаблицы.Договор) Тогда
			Продолжить;
		КонецЕсли;
		
		ИнвертироватьПараметрыДоговора = Ложь;
		РасчетыВУсловныхЕдиницах       = Ложь;
		ВидДоговора                    = "";
		
		Если ЗначениеЗаполнено(ОрганизацияДокумента)
			И ОрганизацияДокумента <> ТекОрганизация Тогда
			ИнвертироватьПараметрыДоговора = Истина;
		КонецЕсли;
		
		ПолучитьПараметрыДоговораПоЗаказу(СтрокаТаблицы.Заказ, СтрокаТаблицы.ВидРасчетов,
			ВидДоговора, РасчетыВУсловныхЕдиницах, ИнвертироватьПараметрыДоговора);
		
		ПараметрыПоУмолчанию = Новый Структура(ДоговорФиксированнаяСтруктураКлючей());
		ПараметрыПоУмолчанию.Организация              = ТекОрганизация;
		ПараметрыПоУмолчанию.ВалютаВзаиморасчетов     = СтрокаТаблицы.ВалютаВзаиморасчетов;
		ПараметрыПоУмолчанию.РасчетыВУсловныхЕдиницах = РасчетыВУсловныхЕдиницах;
		ПараметрыПоУмолчанию.ВидДоговора              = ВидДоговора; 
		ПараметрыПоУмолчанию.Контрагент               = ТекКонтрагент;
		
		СтрокаТаблицы.Договор = ДоговорИнструкцияКонвертацииПоДаннымВзаиморасчетов(ПараметрыПоУмолчанию, КомпонентыОбмена, СтрокаТаблицы.Заказ, Ссылка);
		
	КонецЦикла;
	
	ДанныеЗадолженность.Колонки.Удалить("Заказ");
	
	Возврат ДанныеЗадолженность;
КонецФункции

&ИзменениеИКонтроль("ПКО_Документ_КорректировкаРеализации_Отправка_ПриОтправкеДанных")
Процедура Док_ПКО_Документ_КорректировкаРеализации_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	ПоддерживаетсяКомиссионнаяТорговля = ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.17");
	
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.10") Тогда
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
		"Документ_КорректировкаРеализации_Отправка", 
		"Товары", 
		"НомерГТД",
		Истина,
		"Справочник_НомераГТД_Отправка");
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
		"Документ_КорректировкаРеализации_Отправка", 
		"Товары", 
		"НомерГТДДоИзменения",
		Истина,
		"Справочник_НомераГТД_Отправка");
	КонецЕсли;
	Если ВерсияФорматаЧислом(КомпонентыОбмена.ВерсияФорматаОбмена) >= ВерсияФорматаЧислом("1.17") Тогда
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
		"Документ_КорректировкаРеализации_Отправка", 
		"Товары", 
		"СтавкаНДС",
		Истина,
		"СправочникСсылка_СтавкиНДС_Отправка"); 
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
		"Документ_КорректировкаРеализации_Отправка", 
		"Услуги", 
		"СтавкаНДС",
		Истина,
		"СправочникСсылка_СтавкиНДС_Отправка");
		
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
		"Документ_КорректировкаРеализации_Отправка", 
		"Товары", 
		"СтавкаНДСДоИзменения",
		Истина,
		"СправочникСсылка_СтавкиНДС_Отправка"); 
		УстановитьПравилоДляПКСТабЧасти(КомпонентыОбмена,
		"Документ_КорректировкаРеализации_Отправка", 
		"Услуги", 
		"СтавкаНДСДоИзменения",
		Истина,
		"СправочникСсылка_СтавкиНДС_Отправка");
		
	КонецЕсли;
	ВыгрузитьНалогообложениеНДС(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, Ложь, Ложь);
	
	ВыгрузитьДополнительныеРеквизитыИСведения(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO);
	
	// Данные исходного документа реализации
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Док.ЗаказКлиента КАК ЗаказКлиента,
	|	Док.ВернутьМногооборотнуюТару КАК ВернутьМногооборотнуюТару,
	|	докЗаказКлиента.Дата КАК Дата,
	|	докЗаказКлиента.Ссылка КАК Ссылка,
	|	докЗаказКлиента.Номер КАК Номер,
	|	докЗаказКлиента.Организация КАК Организация
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК докЗаказКлиента
	|		ПО Док.ЗаказКлиента = докЗаказКлиента.Ссылка
	|ГДЕ
	|	Док.Ссылка = &ДокументОснование
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Док.ЗаказКлиента,
	|	ЛОЖЬ,
	|	ДокЗаказКлиента.Дата,
	|	ДокЗаказКлиента.Ссылка,
	|	ДокЗаказКлиента.Номер,
	|	ДокЗаказКлиента.Организация
	|ИЗ
	|	Документ.АктВыполненныхРабот КАК Док
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ДокЗаказКлиента
	|		ПО Док.ЗаказКлиента = ДокЗаказКлиента.Ссылка
	|ГДЕ
	|	Док.Ссылка = &ДокументОснование";
	
	// Ссылка на исправляемый документ
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов() +
	"ВЫБРАТЬ
	|	КорректировкаРеализации.Ссылка КАК Ссылка,
	|	КорректировкаРеализации.МоментВремени КАК МоментВремени,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА &МеждународнаяВерсия
	|				ТОГДА ЛОЖЬ
	//++ Локализация
	|			КОГДА СчетФактураВыданный.Ссылка ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	//-- Локализация
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ) КАК Корректировочный,
	|	ЛОЖЬ КАК ЭтоДокументОснование,
	|	КорректировкаРеализации.ТипКорректировки КАК ТипКорректировки,
	|	КорректировкаРеализации.ВидКорректировки КАК ВидКорректировки
	|ПОМЕСТИТЬ ПараметрыДокументовПоследовательности
	|ИЗ
	|	Документ.КорректировкаРеализации КАК КорректировкаРеализации
	//++ Локализация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактураВыданный
	|		ПО КорректировкаРеализации.Ссылка = СчетФактураВыданный.ДокументОснование
	|			И (СчетФактураВыданный.Корректировочный)
	|			И (НЕ СчетФактураВыданный.ПометкаУдаления)
	//-- Локализация
	|ГДЕ
	|	КорректировкаРеализации.Проведен
	|	И КорректировкаРеализации.МоментВремени <= &МоментВремени
	|	И КорректировкаРеализации.ДокументОснование = &ДокументОснование
	|
	|СГРУППИРОВАТЬ ПО
	|	КорректировкаРеализации.Ссылка,
	|	КорректировкаРеализации.МоментВремени,
	|	КорректировкаРеализации.ТипКорректировки,
	|	КорректировкаРеализации.ВидКорректировки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КорректировкаРеализации.ДокументОснование,
	|	КорректировкаРеализации.ДокументОснование.МоментВремени,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА &МеждународнаяВерсия
	|				ТОГДА ЛОЖЬ
	//++ Локализация
	|			КОГДА СчетФактураВыданный.Ссылка ЕСТЬ NULL
	|				ТОГДА ЛОЖЬ
	//-- Локализация
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ),
	|	ИСТИНА,
	|	КорректировкаРеализации.ТипКорректировки,
	|	КорректировкаРеализации.ВидКорректировки
	|ИЗ
	|	Документ.КорректировкаРеализации КАК КорректировкаРеализации
	//++ Локализация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СчетФактураВыданный КАК СчетФактураВыданный
	|		ПО КорректировкаРеализации.ДокументОснование = СчетФактураВыданный.ДокументОснование
	|			И (НЕ СчетФактураВыданный.ПометкаУдаления)
	|			И (СчетФактураВыданный.Корректировочный)
	//-- Локализация
	|ГДЕ
	|	КорректировкаРеализации.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	КорректировкаРеализации.ДокументОснование,
	|	КорректировкаРеализации.ТипКорректировки,
	|	КорректировкаРеализации.ВидКорректировки,
	|	КорректировкаРеализации.ДокументОснование.МоментВремени
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Параметры1.Ссылка КАК Ссылка,
	|	Параметры1.Корректировочный КАК Корректировочный,
	|	МИНИМУМ(ВЫБОР
	|			КОГДА Параметры1.Корректировочный
	|					И НЕ Параметры2.Корректировочный
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ) КАК ИсходныйКорректировочный
	|ПОМЕСТИТЬ ПараметрыОтбора
	|ИЗ
	|	ПараметрыДокументовПоследовательности КАК Параметры1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПараметрыДокументовПоследовательности КАК Параметры2
	|		ПО (Параметры1.Ссылка = &Ссылка)
	|			И (Параметры2.Ссылка <> &Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	Параметры1.Ссылка,
	|	Параметры1.Корректировочный
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Параметры1.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсправляемыеДокументы.Ссылка КАК Ссылка,
	|	ИсправляемыеДокументы.МоментВремени КАК МоментВремени
	|ПОМЕСТИТЬ ИсправляемыйДокумент
	|ИЗ
	|	ПараметрыДокументовПоследовательности КАК ИсправляемыеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПараметрыОтбора КАК ПараметрыОтбора
	|		ПО (ИсправляемыеДокументы.Корректировочный = ПараметрыОтбора.Корректировочный
	|				ИЛИ ПараметрыОтбора.ИсходныйКорректировочный
	|				ИЛИ ИсправляемыеДокументы.ЭтоДокументОснование)
	|			И ИсправляемыеДокументы.Ссылка <> ПараметрыОтбора.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИсправляемыеДокументы.МоментВремени УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсправляемыеДокументы.Ссылка КАК Ссылка,
	|	ИсправляемыеДокументы.МоментВремени КАК МоментВремени,
	|	ИсправляемыеДокументы.Ссылка.Дата КАК Дата,
	|	ИсправляемыеДокументы.Ссылка.Организация КАК Организация,
	|	ИсправляемыеДокументы.Ссылка.Номер КАК Номер,  
	|	ИсправляемыеДокументы.ВидКорректировки КАК ВидКорректировки,
	|	ПараметрыОтбора.ИсходныйКорректировочный КАК ИсходныйКорректировочный
	|ИЗ
	|	ПараметрыДокументовПоследовательности КАК ИсправляемыеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПараметрыОтбора КАК ПараметрыОтбора
	|		ПО ИсправляемыеДокументы.Ссылка <> ПараметрыОтбора.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИсправляемыеДокументы.МоментВремени УБЫВ";
	
	// Ссылка на основание исправления (корректировки) и документ до корректировки
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов() +
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсправляемыеДокументы.Ссылка КАК Ссылка,
	|	ИсправляемыеДокументы.МоментВремени КАК МоментВремени
	|ПОМЕСТИТЬ ДокументДоКорректировки
	|ИЗ
	|	ПараметрыДокументовПоследовательности КАК ИсправляемыеДокументы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПараметрыОтбора КАК ПараметрыОтбора
	|		ПО (ПараметрыОтбора.Корректировочный)
	|			И (НЕ ПараметрыОтбора.ИсходныйКорректировочный)
	|			И (НЕ ИсправляемыеДокументы.Корректировочный)
	|			И ИсправляемыеДокументы.Ссылка <> ПараметрыОтбора.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИсправляемыеДокументы.ЭтоДокументОснование,
	|	ИсправляемыеДокументы.МоментВремени УБЫВ";
	
	// Товары исходной реализации
	
	ТекстЗапроса = ТекстЗапроса + ОбщегоНазначения.РазделительПакетаЗапросов() +
	"ВЫБРАТЬ
	|	КорректировкаРеализацииТовары.Номенклатура КАК Номенклатура,
	|	КорректировкаРеализацииТовары.Характеристика КАК Характеристика,
	|	КорректировкаРеализацииТовары.Серия КАК Серия,
	|	КорректировкаРеализацииТовары.Упаковка КАК Упаковка,
	|	КорректировкаРеализацииТовары.СтавкаНДС КАК СтавкаНДС,
	|	КорректировкаРеализацииТовары.НомерГТД КАК НомерГТД,
	|	ЕСТЬNULL(КорректировкаРеализацииВидыЗапасовКорректировкаВыручки.ВидЗапасов.ТипЗапасов, ЕСТЬNULL(КорректировкаРеализацииВидыЗапасовОприходование.ВидЗапасов.ТипЗапасов, КорректировкаРеализацииВидыЗапасовСписание.ВидЗапасов.ТипЗапасов)) КАК ТипЗапасов,
	|	КорректировкаРеализацииТовары.Количество КАК Количество,
	|	КорректировкаРеализацииТовары.КоличествоУпаковок - КорректировкаРеализацииРасхождения.КоличествоУпаковок КАК КоличествоУпаковок,
	|	КорректировкаРеализацииТовары.КоличествоПоРНПТ КАК КоличествоПоРНПТ,
	|	КорректировкаРеализацииТовары.СуммаСНДС КАК СуммаСНДС,
	|	КорректировкаРеализацииТовары.СуммаНДС КАК СуммаНДС,
	|	КорректировкаРеализацииТовары.Ссылка.ТипКорректировки КАК ТипКорректировки,
	|	КорректировкаРеализацииРасхождения.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	КорректировкаРеализацииТовары.Ссылка КАК Ссылка,
	|	КорректировкаРеализацииТовары.НомерСтроки КАК НомерСтроки,
	|	КорректировкаРеализацииТовары.Сумма КАК Сумма,
	|	КорректировкаРеализацииРасхождения.ВариантОтражения КАК ВариантОтражения
	|ПОМЕСТИТЬ ТоварыКорректировкиВводаОстатков
	|ИЗ
	|	ПараметрыДокументовПоследовательности КАК ПараметрыДокументовПоследовательности
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации.Товары КАК КорректировкаРеализацииТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации.Расхождения КАК КорректировкаРеализацииРасхождения
	|			ПО КорректировкаРеализацииТовары.Ссылка = КорректировкаРеализацииРасхождения.Ссылка
	|				И КорректировкаРеализацииТовары.Номенклатура = КорректировкаРеализацииРасхождения.Номенклатура
	|				И КорректировкаРеализацииТовары.Характеристика = КорректировкаРеализацииРасхождения.Характеристика
	|				И КорректировкаРеализацииТовары.НомерСтроки = КорректировкаРеализацииРасхождения.НомерСтроки
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации.ВидыЗапасовКорректировкаВыручки КАК КорректировкаРеализацииВидыЗапасовКорректировкаВыручки
	|			ПО КорректировкаРеализацииТовары.Ссылка = КорректировкаРеализацииВидыЗапасовКорректировкаВыручки.Ссылка
	|				И КорректировкаРеализацииТовары.Номенклатура = КорректировкаРеализацииВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Номенклатура
	|				И КорректировкаРеализацииТовары.Характеристика = КорректировкаРеализацииВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Характеристика
	|				И КорректировкаРеализацииТовары.Серия = КорректировкаРеализацииВидыЗапасовКорректировкаВыручки.АналитикаУчетаНоменклатуры.Серия
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации.ВидыЗапасовОприходование КАК КорректировкаРеализацииВидыЗапасовОприходование
	|			ПО КорректировкаРеализацииТовары.Ссылка = КорректировкаРеализацииВидыЗапасовОприходование.Ссылка
	|				И КорректировкаРеализацииТовары.Номенклатура = КорректировкаРеализацииВидыЗапасовОприходование.АналитикаУчетаНоменклатуры.Номенклатура
	|				И КорректировкаРеализацииТовары.Характеристика = КорректировкаРеализацииВидыЗапасовОприходование.АналитикаУчетаНоменклатуры.Характеристика
