	ПравилоОбработки.ИспользуемыеПКО.Добавить("Документ_ОтчетБанкаПоОперациямЭквайринга_Отправка");
	#Вставка
	ПравилоОбработки.ПриОбработке            = "Документ_ОтчетБанкаПоОперациямЭквайринга_Отправка_ПриОбработке";
