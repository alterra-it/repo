			|	КОНЕЦ КАК ТипЗапасов
			|ИЗ
			|	ВидыЗапасов КАК ВидыЗапасов";
			
	Иначе
			
		ТекстЗапроса = 
			"ВЫБРАТЬ
			|	""Товары"" КАК ИмяТабличнойЧасти,
			|	Т.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
