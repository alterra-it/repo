Процедура ПКО_Документ_ПорчаВОприходование_Отправка_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеИБ.Номер, 5) + "Ч" + Сред(ДанныеИБ.Номер, 7));
	
	СкладДляВыгрузки = СкладДляВыгрузки(ДанныеИБ.Склад, КомпонентыОбмена.ПараметрыКонвертации);
	ДанныеXDTO.Вставить("Склад", СкладДляВыгрузки);
	
	ВыгрузитьПодразделениеИзРеквизитаДокумента(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, "Склад");
	
	ВыгрузитьНалогообложениеНДС(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, Ложь, Ложь);
	
	ДанныеXDTO.Вставить("Основание", Строка(ДанныеИБ));
	
	ТаблицаТовары = ДанныеИБ.ДополнительныеСвойства.Товары;
	ТаблицаТовары.Колонки.Добавить("ТипЗапасов");
	ТаблицаТовары.ЗаполнитьЗначения("СобственныеТовары", "ТипЗапасов");
	
	ЗаполнитьВидДеятельностиНДСВТЧ(КомпонентыОбмена, ДанныеИБ, ТаблицаТовары, "ОприходованиеПодДеятельность", "ВидДеятельностиНДС");
	
	ДанныеXDTO.Вставить("Товары", ТаблицаТовары);
	ДанныеXDTO.Вставить("Сумма", ТаблицаТовары.Итог("Сумма"));
	ВыгрузитьДополнительныеРеквизитыИСведения(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO);   
	
	МассивКолонки=ДанныеXDTO.Товары.ВыгрузитьКолонку("Номенклатура");  
	МассивСтр="";
	для каждого стр из МассивКолонки цикл          
		МассивСтр=МассивСтр+стр.УникальныйИдентификатор()+";";
	конеццикла;	
	ДанныеXDTO.Вставить("AdditionalInfo",МассивСтр);

КонецПроцедуры

