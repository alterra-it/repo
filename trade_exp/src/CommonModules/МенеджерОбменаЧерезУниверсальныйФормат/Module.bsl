	КонецЕсли;
	Запрос.УстановитьПараметр("ВернутьМногооборотнуюТару", ВернутьМногооборотнуюТару);
	
	МеждународнаяВерсия = Истина;
	//++ Локализация
	МеждународнаяВерсия = Ложь;
	//-- Локализация
	Запрос.УстановитьПараметр("МеждународнаяВерсия", МеждународнаяВерсия);
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ДокументРеализацииСсылка = Неопределено;
	ВыборкаДанных = РезультатыЗапроса[4].Выбрать(); 
