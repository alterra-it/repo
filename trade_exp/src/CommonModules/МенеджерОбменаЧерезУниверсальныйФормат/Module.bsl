			Если ТипЗнч(ВыборкаДетальныеЗаписи.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 
				ДанныеРеализации = Новый Структура;
				ДанныеРеализации.Вставить("Дата",ВыборкаДетальныеЗаписи.Дата); 
				ДанныеРеализации.Вставить("Номер",ВыборкаДетальныеЗаписи.Номер);
				ДанныеРеализации.Вставить("Организация",ВыборкаДетальныеЗаписи.Организация);
				ОснованиеПоСчетуФактуре = ВыборкаДетальныеЗаписи.ДокументОснование;
			КонецЕсли;
		КонецЦикла;  
	КонецЕсли;
	//-- Локализация
	Если (ДанныеИБ.ВидКорректировки = Перечисления.ХозяйственныеОперации.КорректировкаПоСогласованиюСторон 
		И ВидПервичнойКорректировки = Неопределено) ИЛИ  ВидПервичнойКорректировки = Перечисления.ХозяйственныеОперации.ИсправлениеОшибок Тогда
		ДокументРеализацииСсылка = ДанныеИБ.ДокументОснование;
		Если ЗначениеЗаполнено(ДанныеИБ.ДокументОснование) Тогда
			ДанныеОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеИБ.ДокументОснование, "Дата, Номер, Организация");
			ЗаполнитьЗначенияСвойств(СтруктураКлючевыеСвойства, ДанныеОснования); 
		КонецЕсли;
		СтруктураКлючевыеСвойства.Ссылка = ДокументРеализацииСсылка;
		//++ Локализация
	ИначеЕсли Не ОснованиеПоСчетуФактуре = Неопределено Тогда  
		ДокументРеализацииСсылка = ОснованиеПоСчетуФактуре;  
		ЗаполнитьЗначенияСвойств(СтруктураКлючевыеСвойства, ДанныеРеализации);
		СтруктураКлючевыеСвойства.Ссылка = ОснованиеПоСчетуФактуре;
		//-- Локализация
	ИначеЕсли  ВыборкаДанных.Количество() > 0 Тогда // Вид корректировки ИсправлениеОшибки
		ДокументРеализацииСсылка = ВыборкаДанных.Ссылка;
		ЗаполнитьЗначенияСвойств(СтруктураКлючевыеСвойства, ВыборкаДанных);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДокументРеализацииСсылка) Тогда
		
		ТипСсылки = ТипЗнч(ДокументРеализацииСсылка);
		ИмяПКО = "";
		Если ТипСсылки = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
			ИмяПКО = "Документ_ВозвратТоваровОтКлиента_Отправка";
			//++ Локализация
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
			ИмяПКО = "Документ_СчетФактураВыданный_Отправка";
			//-- Локализация
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
			ИмяПКО = "Документ_ВозвратТоваровПоставщику_Отправка";
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 
			ИмяПКО = "Документ_РеализацияТоваровУслуг_Отправка";
			Если ПоддерживаетсяКомиссионнаяТорговля И РеализацияЧерезКомиссионера(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
				ДокументРеализацииСсылка, "ХозяйственнаяОперация")) Тогда
				ИмяПКО = "Документ_РеализацияТоваровУслугКомиссия_Отправка";
				ДополнительныеДанныеОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументРеализацииСсылка, 
				"Контрагент, ХозяйственнаяОперация");
				СтруктураКлючевыеСвойства.Вставить("Контрагент", ДополнительныеДанныеОснования.Контрагент);
				СтруктураКлючевыеСвойства.Вставить("ХозяйственнаяОперация", ДополнительныеДанныеОснования.ХозяйственнаяОперация);
			КонецЕсли;
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.ОтчетКомиссионера") Тогда
			ИмяПКО = "Документ_ОтчетКомиссионера_Отправка";
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.ОтчетКомитенту") Тогда
			ИмяПКО = "Документ_ОтчетКомитенту_Отправка";
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.КорректировкаРеализации")  Тогда
			ИмяПКО = "Документ_КорректировкаРеализации_Отправка";
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.АктВыполненныхРабот") Тогда
			ИмяПКО = "Документ_АктВыполненныхРабот_Отправка";
		ИначеЕсли ТипСсылки = Тип("ДокументСсылка.РеализацияУслугПрочихАктивов") Тогда
			ИмяПКО = "Документ_РеализацияУслугПрочихАктивов_Отправка"; 
		ИначеЕсли	ТипСсылки = Тип("ДокументСсылка.ПервичныйДокумент")Тогда
			ИмяПКО = "Документ_ПервичныйДокумент_Отправка"; 
