		|ГДЕ
		|	СчетФактураВыданныйТовары.Ссылка.ДокументОснование = &ДокументОснование
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_СФ.ПредыдущийСчетФактура.ДокументОснование КАК ДокументОснование,
		|	ВТ_СФ.ПредыдущийСчетФактура.ДокументОснование.Номер КАК Номер,
		|	ВТ_СФ.ПредыдущийСчетФактура.ДокументОснование.Дата КАК Дата,
		|	ВТ_СФ.ПредыдущийСчетФактура.ДокументОснование.Организация КАК Организация
		|ИЗ
		|	ВТ_СФ КАК ВТ_СФ";
		
		Запрос.УстановитьПараметр("ДокументОснование", ДанныеИБ.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
