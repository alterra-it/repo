&ИзменениеИКонтроль ("ОбщаяСтавкаНДС")
Функция Док_ОбщаяСтавкаНДС(Период) Экспорт
	#Удаление
	Если Период < '20190101' Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС18");
	Иначе
		Возврат ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС20");
	КонецЕсли;
	#КонецУдаления
	#Вставка     
	Если Период < '20190101' Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС18");
	Иначеесли Период < '20260101' тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС20");
	Иначе
		Возврат ПредопределенноеЗначение("Перечисление.СтавкиНДС.НДС22");
	КонецЕсли;
	#КонецВставки
КонецФункции 

