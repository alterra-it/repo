Функция ПолучитьКолбэкОперации(Операция) Экспорт
	
	РезультатВыполнения = ИнтеграцияБанки.ПараметрыВыполнения("Получение статуса операции");
	РезультатВыполнения.Ответ = Новый Структура;
	РезультатВыполнения.Ответ.Вставить("ПолучениеДС", ИнтеграцияБанки.ПараметрыПолученияДинамическиеСсылки());
	РезультатВыполнения.Ответ.Вставить("ИзменениеДС", ИнтеграцияБанки.ПараметрыИзмененияДинамическойСсылки());
	
	Если Операция.Свойство("mdOrder") Тогда
		РезультатВыполнения.Ответ.ПолучениеДС.ИдентификаторСсылки = Операция.mdOrder;
	Иначе 
		РезультатВыполнения.Сообщение = "Не получен идентификатор ссылки";
	КонецЕсли;

	Если Операция.Свойство("orderNumber") Тогда
		РезультатВыполнения.Ответ.ПолучениеДС.Номер = Операция.orderNumber;
	КонецЕсли;
	
	Если Операция.Свойство("operation") И Операция.Свойство("status") Тогда
		РезультатВыполнения.Ответ.ИзменениеДС.Статус = ОпределитьСтатусОперации(Операция);
		
		Если ЗначениеЗаполнено(РезультатВыполнения.Ответ.ИзменениеДС.Статус) Тогда
			
			Если ЗначениеЗаполнено(РезультатВыполнения.Ответ.ПолучениеДС.ИдентификаторСсылки)
				И РезультатВыполнения.Ответ.ИзменениеДС.Статус <> ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.ПустаяСсылка") Тогда
					РезультатВыполнения.Результат = Истина;
					РезультатВыполнения.Сообщение = СтрШаблон("Получен статус %1 операции оплаты %2", 
						Строка(РезультатВыполнения.Ответ.ИзменениеДС.Статус), РезультатВыполнения.Ответ.ПолучениеДС.ИдентификаторСсылки);
			КонецЕсли;                                               
		КонецЕсли;
	Иначе
		РезультатВыполнения.Сообщение = "Не получен статус операции";
	КонецЕсли;
	
	ИнтеграцияБанки.ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ПолучитьСтатусQRКода(СтатусQRКода)
	
	Если СтатусQRКода = "STARTED" Или СтатусQRКода = "CONFIRMED" Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Активация")
		
	ИначеЕсли СтатусQRКода = "ACCEPTED" Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Оплата")
		
	ИначеЕсли СтатусQRКода = "REJECTED" Или СтатусQRКода = "REJECTED_BY_USER" Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Отмена")
	КонецЕсли;
	
	Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.ПустаяСсылка")
	
КонецФункции	

Функция ОпределитьСтатусОперации(Операция)
	
	Если Операция.operation = "deposited" И Операция.status = "1" Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Оплата")
		
	ИначеЕсли Операция.operation = "refunded" И Операция.status = "1" Тогда
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Возврат")
		
	ИначеЕсли Операция.operation = "deposited" И Операция.status = "0" Тогда 
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.Отмена")
		
	ИначеЕсли Операция.operation = "declinedByTimeout" И Операция.status = "1"  Тогда		
		Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.ИстекСрокДействия")
		
	КонецЕсли;
	
	Возврат ПредопределенноеЗначение("Перечисление.СтатусДинамическойСсылки.ПустаяСсылка");

КонецФункции	

Функция ПолучитьСтраницыСтатистики() Экспорт
	
	Страницы = Новый Структура();
	Страницы.Вставить("ПерваяСтраница", 			0);
	Страницы.Вставить("МаксКоличествоНаСтранице", 	200);
	
	Возврат Страницы;
	
КонецФункции

Функция ПолучитьСтатусыДинамическойСсылки() Экспорт
	
	Статусы = Новый Массив;
	Статусы.Добавить("CREATED");
	Статусы.Добавить("APPROVED");
	Статусы.Добавить("DEPOSITED");
	Статусы.Добавить("DECLINED");
	Статусы.Добавить("REVERSED");
	Статусы.Добавить("REFUNDED");
	
	Возврат Статусы;
	
КонецФункции

Функция ПолучитьФорматированнуюДату(Дата) Экспорт
	
	 Возврат Формат (Дата, "ДФ=ггггММддЧЧммсс");
		
КонецФункции

