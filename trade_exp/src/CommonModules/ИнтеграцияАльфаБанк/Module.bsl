Функция ПолучитьСтатистикуЗаПериодДинамическихСсылок(НастройкиДС, ПараметрыСтатистикиДС) Экспорт
	
	РезультатВыполнения = ИнтеграцияБанки.ПараметрыВыполнения("Статистика по периоду динамических ссылок");
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = НастройкиДС.url;
	ПараметрыRest.Метод = "/payment/rest/getLastOrdersForMerchants.do";
	ПараметрыRest.ТипМетода = "POST"; 
	
	ПараметрыRest.Параметры = Новый Массив;
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "userName", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Логин)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "password", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Пароль)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "from", 				ИнтеграцияREST.ПараметрRest(ПолучитьФорматированнуюДату(ПараметрыСтатистикиДС.ДатаНачала))));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "to",				ИнтеграцияREST.ПараметрRest(ПолучитьФорматированнуюДату(ПараметрыСтатистикиДС.ДатаОкончания))));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "page",				ИнтеграцияREST.ПараметрRest(ПараметрыСтатистикиДС.Страница)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "size", 				ИнтеграцияREST.ПараметрRest(ПараметрыСтатистикиДС.КоличествоНаСтранице)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "transactionStates", ИнтеграцияREST.ПараметрRest(ПараметрыСтатистикиДС.Статусы)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "merchants", ""));
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest); 
	РезультатВыполнения.Ответ = Новый Массив;

	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("errorCode") И RestЗапрос.ОтветСтруктура.errorCode = 0 
			И RestЗапрос.ОтветСтруктура.Свойство("orderStatuses") Тогда
				
				Для Каждого ОплатаЗаказа Из RestЗапрос.ОтветСтруктура.orderStatuses Цикл
					
					Заказ = ИнтеграцияБанки.ПараметрыКодовДинамическихСсылок();
					
					Если ОплатаЗаказа.Свойство("orderNumber") Тогда
						Заказ.Номер = ОплатаЗаказа.orderNumber;
					КонецЕсли;
					
					Если ОплатаЗаказа.Свойство("attributes") И ТипЗнч(ОплатаЗаказа.attributes) = Тип("Массив") Тогда 
						
						Для Каждого Аттрибут Из ОплатаЗаказа.attributes Цикл
							
							Если Аттрибут.name = "mdOrder" Тогда
								Заказ.УИД = Аттрибут.value;
								Прервать;
							КонецЕсли;
							
						КонецЦикла;
					КонецЕсли;
					
					РезультатВыполнения.Ответ.Добавить(Заказ);
					
				КонецЦикла;
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = "Не получена статистика за период" + Символы.ПС + 
				?(RestЗапрос.ОтветСтруктура.Свойство("errorCode"), "errorCode" = RestЗапрос.ОтветСтруктура.errorCode, "");				
		КонецЕсли;	
	КонецЕсли;
	
	ИнтеграцияБанки.ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

