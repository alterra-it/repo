#Область REST

Функция ЗарегистрироватьДинамическуюСсылку(НастройкиДС, ПараметрыРегистрацииДС) Экспорт
	
	РезультатВыполнения = ИнтеграцияБанки.ПараметрыВыполнения("Регистрация динамической ссылки");
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = НастройкиДС.url;
	ПараметрыRest.Метод = "/payment/rest/register.do";
	ПараметрыRest.ТипМетода = "POST"; 
	
	СрокДействия = ТекущаяДата() + 86400 * НастройкиДС.СрокЖизни;
	
	ПараметрыRest.Параметры = Новый Массив;
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "userName", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Логин)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "password", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Пароль)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "returnUrl", 		ИнтеграцияREST.ПараметрRest(НастройкиДС.returnUrl)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "dynamicCallbackUrl",ИнтеграцияREST.ПараметрRest(НастройкиДС.callback)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "expirationDate",	ИнтеграцияREST.ПараметрRest(Формат(СрокДействия, "ДФ=гггг-ММ-дд") + "T00:00:00")));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "orderNumber", 		ИнтеграцияREST.ПараметрRest(ПараметрыРегистрацииДС.Номер)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "description", 		ИнтеграцияREST.ПараметрRest(ПараметрыРегистрацииДС.Описание)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "amount", 			ИнтеграцияREST.ПараметрRest(ПараметрыРегистрацииДС.Сумма*100)));
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest); 
	РезультатРегистрации = ИнтеграцияБанки.РезультатРегистрацииДинамическиеСсылки();

	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("orderId") И RestЗапрос.ОтветСтруктура.Свойство("formUrl") Тогда
			РезультатРегистрации.ИдентификаторСсылки = RestЗапрос.ОтветСтруктура.orderId;
			РезультатРегистрации.Дата = ТекущаяДатаСеанса();
			РезультатРегистрации.ДатаОперации = РезультатРегистрации.Дата;
			РезультатРегистрации.СсылкаОплаты = RestЗапрос.ОтветСтруктура.formUrl;
			РезультатРегистрации.СрокДействия = СрокДействия;
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = "Не получен идентификатор ссылки при регистрации" + Символы.ПС + 
				?(RestЗапрос.ОтветСтруктура.Свойство("errorMessage"), RestЗапрос.ОтветСтруктура.errorMessage, "");				
		КонецЕсли;	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(РезультатВыполнения, RestЗапрос);
	РезультатВыполнения.Ответ = РезультатРегистрации;
	ИнтеграцияБанки.ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ПолучитьQRКод(НастройкиДС, ПараметрыПолученияQRКода) Экспорт
	
	РезультатВыполнения = ИнтеграцияБанки.ПараметрыВыполнения("Получение QR-кода");
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = НастройкиДС.url;
	ПараметрыRest.Метод = "/payment/rest/sbp/c2b/qr/dynamic/get.do";
	ПараметрыRest.ТипМетода = "POST"; 
	
	ПараметрыRest.Параметры = Новый Массив;
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "userName", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Логин)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "password", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Пароль)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "redirectUrl", 		ИнтеграцияREST.ПараметрRest(НастройкиДС.returnUrl)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "mdOrder", 			ИнтеграцияREST.ПараметрRest(ПараметрыПолученияQRКода.ИдентификаторСсылки)));
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest); 
	РезультатПолученияQRКода = ИнтеграцияБанки.РезультатПолученияQRКода();
	
	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("qrId") 
			И RestЗапрос.ОтветСтруктура.Свойство("qrStatus") 
			И RestЗапрос.ОтветСтруктура.Свойство("payload") Тогда
				РезультатПолученияQRКода.QRКод = RestЗапрос.ОтветСтруктура.qrId;
				РезультатПолученияQRКода.СсылкаQRКода = RestЗапрос.ОтветСтруктура.payload;
				РезультатПолученияQRКода.Статус = ПолучитьСтатусQRКода(RestЗапрос.ОтветСтруктура.qrStatus);
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = "Не получен QR-код" + Символы.ПС + 
				?(RestЗапрос.ОтветСтруктура.Свойство("errorMessage"), RestЗапрос.ОтветСтруктура.errorMessage, "");				
		КонецЕсли;	
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(РезультатВыполнения, RestЗапрос);
	РезультатВыполнения.Ответ = РезультатПолученияQRКода;
	ИнтеграцияБанки.ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ОтменитьАктивациюДинамическойСсылки(НастройкиДС, ПараметрыОтменыДС) Экспорт
	
	РезультатВыполнения = ИнтеграцияБанки.ПараметрыВыполнения("Отмена динамической ссылки");
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = НастройкиДС.url;
	ПараметрыRest.Метод = "/payment/rest/decline.do";
	ПараметрыRest.ТипМетода = "POST"; 
	
	ПараметрыRest.Параметры = Новый Массив;
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "userName", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Логин)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "password", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Пароль)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "orderId", 			ИнтеграцияREST.ПараметрRest(ПараметрыОтменыДС.ИдентификаторСсылки)));
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest); 
	
	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("errorCode") Тогда
			
			Если RestЗапрос.ОтветСтруктура.errorCode = "0" Тогда
				RestЗапрос.Результат = Истина;
				RestЗапрос.Сообщение = "Динамическая ссылка отменена";				
			Иначе
				RestЗапрос.Результат = Ложь;
				RestЗапрос.Сообщение = "Динамическая ссылка не отменена " + 
					?(RestЗапрос.ОтветСтруктура.Свойство("errorMessage"), RestЗапрос.ОтветСтруктура.errorMessage, "");	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(РезультатВыполнения, RestЗапрос);
	РезультатВыполнения.Ответ = ТекущаяДатаСеанса();
	ИнтеграцияБанки.ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьСостояниеДинамическойСсылки(НастройкиДС, ПараметрыПолученияСостоянияДС) Экспорт
	
	РезультатВыполнения = ИнтеграцияБанки.ПараметрыВыполнения("Состояние динамической ссылки");
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url = НастройкиДС.url;
	ПараметрыRest.Метод = "/payment/rest/getOrderStatusExtended.do";
	ПараметрыRest.ТипМетода = "POST"; 
	
	ПараметрыRest.Параметры = Новый Массив;
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "userName", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Логин)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "password", 			ИнтеграцияREST.ПараметрRest(НастройкиДС.Пароль)));
	ПараметрыRest.Параметры.Добавить(Новый Структура("Ключ, Значение", "orderId", 			ИнтеграцияREST.ПараметрRest(ПараметрыПолученияСостоянияДС.ИдентификаторСсылки)));
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest); 
	
	Если RestЗапрос.Результат Тогда
		Если RestЗапрос.ОтветСтруктура.Свойство("errorCode") Тогда
			
			Если RestЗапрос.ОтветСтруктура.errorCode = "0" Тогда
				
				RestЗапрос.Результат = Истина;
				RestЗапрос.Сообщение = "Состояние динамической ссылки получено";	

				РезультатВыполнения.Ответ = ИнтеграцияБанки.ПараметрыСостоянияДинамическиеСсылки();

				Если RestЗапрос.ОтветСтруктура.Свойство("paymentAmountInfo") 
					И RestЗапрос.ОтветСтруктура.paymentAmountInfo.Свойство("depositedAmount") Тогда
						
					РезультатВыполнения.Ответ.Сумма = RestЗапрос.ОтветСтруктура.paymentAmountInfo.depositedAmount / 100;
				КонецЕсли;	                                                 
					
				РезультатВыполнения.Ответ.СБП = Не RestЗапрос.ОтветСтруктура.Свойство("authRefNum");
				
			Иначе
				RestЗапрос.Результат = Ложь;
				RestЗапрос.Сообщение = "Состояние динамической ссылки не получено " + 
					?(RestЗапрос.ОтветСтруктура.Свойство("errorMessage"), RestЗапрос.ОтветСтруктура.errorMessage, "");	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(РезультатВыполнения, RestЗапрос);
	ИнтеграцияБанки.ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

