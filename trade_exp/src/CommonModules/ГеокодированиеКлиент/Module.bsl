#Область РазборОтветаЯндекс

Функция ПолучитьКоординатыXML(стрОтвета) Экспорт
	Координаты= Новый Структура("Широта, Долгота, Адрес", 0, 0, "");
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(стрОтвета);
	
	ПостроительDOM 			= Новый ПостроительDOM;
	ДокументДОМ 			= ПостроительDOM.Прочитать(ЧтениеXML);
	
	СписокText 				= ДокументДОМ.ПолучитьЭлементыПоИмени("text");
	СписокPos 				= ДокументДОМ.ПолучитьЭлементыПоИмени("pos");
	
	Если (СписокText.Количество() = 0) ИЛИ (СписокPos.Количество() = 0) Тогда
		Возврат Координаты;	
	КонецЕсли;
	Если СписокPos.Количество() > 0 Тогда
		стрКоординаты = СписокPos[0].ТекстовоеСодержимое;
		Разделитель = Найти(стрКоординаты," ");
		Широта = Число(Сред(стрКоординаты, Разделитель + 1));
		Долгота = Число(Лев(стрКоординаты, Разделитель - 1));
		Координаты.Широта= Широта;
		Координаты.Долгота= Долгота;
	КонецЕсли;
	
	Если СписокText.Количество() > 0 Тогда
		стрАдреса = СписокText[0].ТекстовоеСодержимое;
		Координаты.Адрес= СокрЛП(стрАдреса);
	КонецЕсли;
	
	Возврат Координаты;	
КонецФункции

Функция РазобратьОтветОМаршруте(стрИнфоОМаршруте)  Экспорт
	Попытка
		мВремяПуть= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(стрИнфоОМаршруте, "Время");
		мПуть= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мВремяПуть[0], "&#");
		стрРасстояние= СокрЛП(мПуть[0]+" "+СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мПуть[1], ";")[1]);
		мВремя= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мВремяПуть[1], "&#");
		стрВремя= "Время "+СокрЛП(мВремя[0]+" "+СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мВремя[1], ";")[1]);
		Если мВремя.Количество() = 3 Тогда
			стрВремя= стрВремя+" "+СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мВремя[2], ";")[1];
		КонецЕсли;
		Возврат стрРасстояние+"  "+стрВремя+".";	
	Исключение
		Возврат "";
	КонецПопытки;
КонецФункции
	
