Процедура ПостроитьПолигон(ЯндексКарта, Знач ТаблицаТочек) Экспорт
	МассивТочек = "[";
	Для Каждого ТекТочка Из ТаблицаТочек Цикл
		Широта = формат(ТекТочка.Широта, "ЧРД=.");
		Долгота = формат(ТекТочка.Долгота, "ЧРД=.");
		МассивТочек = МассивТочек + "[" + Широта + "," + Долгота + "],"; 
	КонецЦикла;
	МассивТочек = Сред(МассивТочек, 1, СтрДлина(МассивТочек) - 1) + "]";
	
	Цвет16 = "0066ff99";
	
	Название = "Полигон";
	ЯндексКарта.document.getElementById("WebClientOperation").value = "createPolygon(" + МассивТочек + ", '" + Название + "', '" + Цвет16 + "');";
	ЯндексКарта.document.getElementById("WebClient").click();
КонецПроцедуры

Процедура ПостроитьКластера(ЯндексКарта, Знач ТаблицаТочек)  Экспорт
	Кол = ТаблицаТочек.Количество();
	Индекс = 1;
	Для Каждого ТекСтрока Из ТаблицаТочек Цикл
		Широта = формат(ТекСтрока.Широта, "ЧРД=.");
		Долгота = формат(ТекСтрока.Долгота, "ЧРД=.");
		Если Не ПустаяСтрока(Долгота) Тогда
			ЯндексКарта.document.getElementById("WebClientOperation").value = "addToPointArray(" + Широта + "," + Долгота + ", '" + ТекСтрока.Клиент + "', '" + ТекСтрока.АдресДоставки+ "', '" + ТекСтрока.Цвет + "');";
			ЯндексКарта.document.getElementById("WebClient").click();
		Иначе
			Сообщить("Для клиента "+ТекСтрока.Клиент+" с адресом "+ТекСтрока.АдресДоставки+" точка на карте не задана!");
		КонецЕсли;
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
	ЯндексКарта.document.getElementById("WebClientOperation").value = "drawCluster();";
	ЯндексКарта.document.getElementById("WebClient").click();
КонецПроцедуры

