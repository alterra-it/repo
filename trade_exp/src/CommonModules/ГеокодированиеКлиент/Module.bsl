	КартаЯндекс.document.getElementById("WebClient").click();
КонецПроцедуры

Функция  ПолучитьКоординатыТочки(КартаЯндекс) Экспорт
	Координаты= Новый Структура("Широта, Долгота, Адрес", 0, 0, "");
	Попытка
		ЧислоТип = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 12));
		
		КоординатаX = КартаЯндекс.document.getElementById("CoordX").value;
		КоординатаX = ЧислоТип.ПривестиЗначение(КоординатаX);
		
		КоординатаY = КартаЯндекс.document.getElementById("CoordY").value;
		КоординатаY = ЧислоТип.ПривестиЗначение(КоординатаY);
		
		Если КоординатаX > 0 И КоординатаY > 0 Тогда
			Широта = КоординатаX;
			Долгота = КоординатаY;
			Координаты.Широта= Широта;
			Координаты.Долгота= Долгота;
		КонецЕсли;
		
		Координаты.Адрес= КартаЯндекс.document.getElementById("adress").value;
	Исключение
	КонецПопытки;
	
	Возврат Координаты;
КонецФункции

Процедура ОбратнПоискАдреса(КартаЯндекс, Широта, Долгота, Адрес) Экспорт
	КартаЯндекс.document.parentWindow.eval("ReverseSearchAdres(" + Формат(Широта,"ЧРД=.") + "," + Формат(Долгота,"ЧРД=.") + ", """ + Адрес + """);");
