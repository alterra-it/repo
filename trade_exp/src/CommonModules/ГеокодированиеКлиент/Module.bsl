Функция ПолучитьАдресПоКоординатам(Знач Широта, Знач Долгота) Экспорт
	Параметры= "&ll=83.739999,53.34057&spn=0.3,0.3&rspn=1&results=1";
	Широта= XMLСтрока(Широта);
	Долгота= XMLСтрока(Долгота);
