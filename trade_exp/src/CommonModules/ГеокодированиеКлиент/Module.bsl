	ПреобразованныйАдрес = "1.x/?geocode=" + стрКоординат+Параметры;//XML
	Соединение = Новый HTTPСоединение("geocode-maps.yandex.ru",,,,,, Новый ЗащищенноеСоединениеOpenSSL());
	ОтветСервера = Соединение.Получить(Новый HTTPЗапрос(ПреобразованныйАдрес)).ПолучитьТелоКакСтроку();
	Координаты= ПолучитьКоординатыXML(ОтветСервера);
	
