Функция ПолучитьМетку(Доставка)
	Если Доставка.ВремяДоставкиС	>= Дата(1,1,1,8,0,0) И Доставка.ВремяДоставкиПо	<= Дата(1,1,1,12,0,0) Тогда
		Цвет= "twirl#redStretchyIcon";
	ИначеЕсли Доставка.ВремяДоставкиС >= Дата(1,1,1,12,0,0) И Доставка.ВремяДоставкиПо <= Дата(1,1,1,16,0,0) Тогда
		Цвет= "twirl#greenStretchyIcon";
	ИначеЕсли Доставка.ВремяДоставкиС >= Дата(1,1,1,16,0,0) И Доставка.ВремяДоставкиПо <= Дата(1,1,1,20,0,0) Тогда
		Цвет= "twirl#blueStretchyIcon";
	Иначе
		Цвет= "twirl#braunStretchyIcon";
	КонецЕсли;
	
	Возврат Цвет;
КонецФункции

Функция ПолучитьЦвет16(Доставка)
	Если Доставка.ВремяДоставкиС	>= Дата(1,1,1,8,0,0) И Доставка.ВремяДоставкиПо	<= Дата(1,1,1,12,0,0) Тогда
		Цвет= "#ff0000";
	ИначеЕсли Доставка.ВремяДоставкиС >= Дата(1,1,1,12,0,0) И Доставка.ВремяДоставкиПо <= Дата(1,1,1,16,0,0) Тогда
		Цвет= "#00ff00";
	ИначеЕсли Доставка.ВремяДоставкиС >= Дата(1,1,1,16,0,0) И Доставка.ВремяДоставкиПо <= Дата(1,1,1,20,0,0) Тогда
		Цвет= "#0000ff";
	Иначе
		Цвет= "#663300";
	КонецЕсли;
	
	Возврат Цвет;
КонецФункции

