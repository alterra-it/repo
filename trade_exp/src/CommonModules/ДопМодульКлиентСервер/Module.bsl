
&НаСервере
Процедура ЗаписьОшибокПоIDТранзакции(Документ) Экспорт
	Событие = Перечисления.СобытияДокументов.ОшибкаЗаписиIDТранзакции;
	Пользователь = Пользователи.ТекущийПользователь(); 
	РегистрыСведений.СобытияДокументовАльтерра.ЗаписатьСобытие(Документ, Событие, Пользователь); 	
КонецПроцедуры  

&НаСервере	
Процедура ОбновитьДП(Партнер, ФИО, ДР, Телефон, Почта) Экспорт
	
	Если ЗначениеЗаполнено(ДР) Тогда
		Партнер.ДатаРождения = Дата(ДР); 
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ФИО) Тогда
		Партнер.Наименование = ФИО;
		Партнер.НаименованиеПолное = ФИО;
	КонецЕсли;
	
	Коллекция = Партнер.КонтактнаяИнформация;
	ПараметрыОтбора = Новый Структура("Тип, Вид");
	
	Если ЗначениеЗаполнено(Почта) Тогда		
		Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		Вид = Справочники.ВидыКонтактнойИнформации.EmailПартнера;
		
		ПараметрыОтбора.Тип = Тип;
		ПараметрыОтбора.Вид = Вид;
		МассивНайденныхСтроки = Коллекция.НайтиСтроки(ПараметрыОтбора);
		
		Для Каждого Строка Из МассивНайденныхСтроки Цикл
			Коллекция.Удалить(Строка);
		КонецЦикла;
		
		НовКонтакт 				 = Коллекция.Добавить();
		НовКонтакт.Тип 			 = Тип;
		НовКонтакт.Вид 			 = Вид;
		НовКонтакт.Представление = Почта;
		НовКонтакт.АдресЭП		 = Почта;
		НовКонтакт.ЗначенияПолей = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(Почта, Вид);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Телефон) Тогда
		Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
		Вид = Справочники.ВидыКонтактнойИнформации.ТелефонПартнера;
		
		ПараметрыОтбора.Тип = Тип;
		ПараметрыОтбора.Вид = Вид;
		МассивНайденныхСтроки = Коллекция.НайтиСтроки(ПараметрыОтбора);
		
		Для Каждого Строка Из МассивНайденныхСтроки Цикл
			Коллекция.Удалить(Строка);
		КонецЦикла;

		Представление="";
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(Телефон, , Представление);
		
		НовКонтакт 						 = Коллекция.Добавить();
		НовКонтакт.Тип 					 = Тип;
		НовКонтакт.Вид 					 = Вид;
		НовКонтакт.Представление 		 = Представление;
		НовКонтакт.НомерТелефона 		 = Телефон;
		НовКонтакт.НомерТелефонаБезКодов = "";
		НовКонтакт.ЗначенияПолей		 = УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(Представление, Вид);
	КонецЕсли; 
	
	Партнер.Записать(); 
КонецПроцедуры  

&НаСервере
Функция НомерСуществуетВБазе(Партнер, ТелефонПартнера) Экспорт	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПартнерыКонтактнаяИнформация.Ссылка КАК Партнер
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
	|ГДЕ
	|	ПартнерыКонтактнаяИнформация.НомерТелефона = &ТелефонПартнера
	|	И ПартнерыКонтактнаяИнформация.Вид = &ВидТелефон
	|	И ПартнерыКонтактнаяИнформация.Ссылка.ЮрФизЛицо = &ЮрФизЛицо";
	
	Запрос.УстановитьПараметр("ТелефонПартнера", ТелефонПартнера);
	Запрос.УстановитьПараметр("ВидТелефон", Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	Запрос.УстановитьПараметр("ЮрФизЛицо", Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	//Если встречаем другого партнера с тем же номером 
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Если ВыборкаДетальныеЗаписи.Партнер <> Партнер Тогда 
			Возврат Истина; 
		КонецЕсли; 
	КонецЕсли;
		
	Возврат Ложь;	
КонецФункции

Функция ЕстьПарсинг(Реквизит) Экспорт
	Возврат СтрНайти(ИнтеграцияИСКлиентСервер.ЗаменитьНечитаемыеСимволы(ВРег(Реквизит)), "(ПАРСИНГ)") <> 0;
КонецФункции



	                          