КонецПроцедуры

Функция ВсеСклады() экспорт
	ЗапросПоСкладам = Новый Запрос(
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Склады.Ссылка КАК Склад
	|ИЗ
	|	Справочник.Склады КАК Склады
	|ГДЕ
	|	(НЕ Склады.ЭтоГруппа)");
	
	Возврат ЗапросПоСкладам.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");
	
КонецФункции

Функция СкладыСДвижениями(Номенклатура) экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЗапасыИПотребностиОстатки.Склад КАК Склад
	|ИЗ
	|	РегистрНакопления.ЗапасыИПотребности.Остатки(
	|			,
	|			Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|				И Номенклатура = &Номенклатура) КАК ЗапасыИПотребностиОстатки
	|ГДЕ
	|	ЗапасыИПотребностиОстатки.ВНаличииОстаток <> 0";
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Склад");
	
КонецФункции 

Функция КлючиНоменклатуры(Ссылка) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АналитикаУчетаНоменклатуры.КлючАналитики
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры
	|		ПО РеализацияТоваровУслугТовары.Номенклатура = АналитикаУчетаНоменклатуры.Номенклатура
	|			И РеализацияТоваровУслугТовары.Характеристика = АналитикаУчетаНоменклатуры.Характеристика
	|			И РеализацияТоваровУслугТовары.Склад = АналитикаУчетаНоменклатуры.МестоХранения
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("КлючАналитики");
	
	Возврат Результат;	
КонецФункции

Функция ВодительТС(знач ПользовательИБ=НЕОПРЕДЕЛЕНО) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Водители.Ссылка КАК Водитель
	|ИЗ
	|	Справочник.Водители КАК Водители
	|ГДЕ
	|	Водители.ПользовательИБ = &ПользовательИБ";
	
	Запрос.УстановитьПараметр("ПользовательИБ", ПользовательИБ);
	
	Результат = Запрос.Выполнить();
	
	если не Результат.Пустой() тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Возврат Выборка.Водитель;
	иначе
		Возврат Справочники.Водители.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Функция ТранспортноеСредство(Водитель) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 2
	|	ЗакрепленныеТС.ТранспортноеСредство
	|ИЗ
	|	РегистрСведений.ЗакрепленныеТС КАК ЗакрепленныеТС
	|ГДЕ
	|	ЗакрепленныеТС.Водитель = &Водитель";
	
	Запрос.УстановитьПараметр("Водитель", Водитель);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.Количество() = 1 Тогда
		ТранспортноеСредство = Выборка.ТранспортноеСредство;
	Иначе
		ТранспортноеСредство = Справочники.ТранспортныеСредстваСобственные.ПустаяСсылка();
	КонецЕсли;
	
	Возврат ТранспортноеСредство;	
КонецФункции 

Функция ТопливоПоРасходу(ТранспортноеСредство) экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НормыРасходаГСМСрезПоследних.Топливо
	|ИЗ
	|	РегистрСведений.НормыРасходаГСМ.СрезПоследних(, ТранспортноеСредство = &транспортноеСредство) КАК НормыРасходаГСМСрезПоследних";
	
	Запрос.УстановитьПараметр("транспортноеСредство",ТранспортноеСредство);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ДанныеТоплива = Выборка.Топливо;
	Иначе
		ДанныеТоплива = НЕОПРЕДЕЛЕНО;
	КонецЕсли; 
	
	Возврат ДанныеТоплива;
КонецФункции

