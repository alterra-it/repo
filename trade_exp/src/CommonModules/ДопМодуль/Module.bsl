// Процедура формирования движений по регистру "Учет прочих расходов".
//
// Параметры:
//	ДокументОбъект - Текущий документ
//	Отказ - Булево - Признак отказа от проведения документа
//
Процедура ОтразитьДвижениеПоПутевымЛистам(ЭтотОбъект,ДополнительныеСвойства, Движения, Отказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	&Период КАК Период,
	|	ВнутреннееПотреблениеТоваровПутевыеЛисты.ПутевойЛист,
	|	ВнутреннееПотреблениеТоваровПутевыеЛисты.ПутевойЛист.РасходФактический КАК Количество,
	|	ВнутреннееПотреблениеТоваровПутевыеЛисты.ПутевойЛист.Топливо КАК Топливо,
	|	ВнутреннееПотреблениеТоваровПутевыеЛисты.ПутевойЛист.Водитель.СкладТоплива КАК Склад
	|ИЗ
	|	Документ.ВнутреннееПотреблениеТоваров.ПутевыеЛисты КАК ВнутреннееПотреблениеТоваровПутевыеЛисты
	|ГДЕ
	|	ВнутреннееПотреблениеТоваровПутевыеЛисты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Период", ЭтотОбъект.Дата);
	Запрос.УстановитьПараметр("Ссылка", ЭтотОбъект.ссылка);
	
	ТаблицаДвижений = Запрос.Выполнить().Выгрузить();
	
	Если Отказ ИЛИ ТаблицаДвижений.Количество() = 0 Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ДвиженияРасчеты = Движения.ДвижениеТоплива;
	ДвиженияРасчеты.Записывать = Истина;
	ДвиженияРасчеты.Загрузить(ТаблицаДвижений);
	
КонецПроцедуры

