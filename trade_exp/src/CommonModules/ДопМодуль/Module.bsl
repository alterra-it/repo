	Если  Пересчет.ТипПересчета = Справочники.ТипыПересчетов.НайтиПоНаименованию("Товар под остаток") Тогда
		Возврат Истина;
	КонецЕсли;	
	
	Возврат Ложь; 
	
КонецФункции

Процедура КонтрольОбособленногоОстатка(Объект, Отказ) Экспорт
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
		|	ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
		|	ЗапасыИПотребностиОстатки.Склад КАК Склад,
		|	ЗапасыИПотребностиОстатки.Назначение КАК Назначение,
		|	Сумма(ЗапасыИПотребностиОстатки.ВНаличииОстаток + ЗапасыИПотребностиОстатки.ЗаказаноОстаток) как Обеспечивается,
		|	Сумма(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток +
		|		ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток + ЗапасыИПотребностиОстатки.КОбеспечениюОстаток +
		|		ЗапасыИПотребностиОстатки.НеОбеспечиватьОстаток) как НужноОбеспечить
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки КАК ЗапасыИПотребностиОстатки
		|ГДЕ
		|	ЗапасыИПотребностиОстатки.Назначение.Заказ = &Заказ
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыИПотребностиОстатки.Номенклатура,
		|	ЗапасыИПотребностиОстатки.Характеристика,
		|	ЗапасыИПотребностиОстатки.Склад,
		|	ЗапасыИПотребностиОстатки.Назначение
		|Имеющие
		|	Сумма(ЗапасыИПотребностиОстатки.ВНаличииОстаток +
		|		ЗапасыИПотребностиОстатки.ЗаказаноОстаток) > Сумма(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток +
		|		ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток + ЗапасыИПотребностиОстатки.КОбеспечениюОстаток +
		|		ЗапасыИПотребностиОстатки.НеОбеспечиватьОстаток)";
	
	Запрос.УстановитьПараметр("Заказ", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ШаблонСообщения = НСтр("ru = 'Номенклатура: %НоменклатураХарактеристика% Склад: %Склад% Назначение: %Назначение%
			|Заказано для обеспечения больше чем необходимо на %Количество% '");
		
		ТекстСообщения = СтрЗаменить(ШаблонСообщения, "%НоменклатураХарактеристика%",
			НоменклатураКлиентСервер.ПредставлениеНоменклатуры(Выборка.Номенклатура, Выборка.Характеристика));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Назначение%", Строка(Выборка.Назначение));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Количество%", Строка(Выборка.Обеспечивается-Выборка.НужноОбеспечить));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Склад%",      Строка(Выборка.Склад));
		
		Отказ = Истина;
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,Отказ);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

Функция ПолучитьКассуККМ() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Т.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ НастройкаРМК
		|ИЗ
		|	Справочник.НастройкиРМК КАК Т
		|ГДЕ
		|	Т.РабочееМесто = &РабочееМесто
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Кассы.ПодключаемоеОборудование КАК ККТ,
		|	Кассы.КассаККМ КАК Касса
		|ИЗ
		|	Справочник.НастройкиРМК.КассыККМ КАК Кассы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ НастройкаРМК КАК НастройкаРМК
		|		ПО (НастройкаРМК.Ссылка = Кассы.Ссылка)
		|ГДЕ
		|	НЕ Кассы.ПодключаемоеОборудование.ПометкаУдаления
		|	И Кассы.ПодключаемоеОборудование.УстройствоИспользуется";
	
	Запрос.УстановитьПараметр("РабочееМесто", МенеджерОборудованияВызовСервера.ПолучитьРабочееМестоКлиента());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
КонецФункции

#Область ОтправкаСообщенийВБитрикс
Процедура ОтправитьСообщениеОЗаменеКартинки(ТекстСообщения, Номенклатура, Замечание, АвторЗамечания) Экспорт
	 
	Список = ПолучитьНастройкиХранилища("АдресатПолученияЗапросаОЗаменеКартинки");
	Для каждого Получатель Из Список.СписокПолучателей Цикл
		АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения + Номенклатура + " (Код - " + Номенклатура.Код + ")" + Символы.ПС + "Замечание: " + Замечание + Символы.ПС + "Автор замечания: " + АвторЗамечания, Получатель.Значение);
	КонецЦикла;	
	 
	АльтерраОбщегоНазначения.СообщитьПользователю( ,"Спасибо за обращение!", ); 
	
КонецПроцедуры

Процедура ОтправитьСообщениеОЗаменеКомплектующих(ПараметрыСообщения) Экспорт
	 
	Список = ПолучитьНастройкиХранилища("АдресатПолученияЗапросаОЗаменеКомплектующих");
	Для каждого Получатель Из Список.СписокПолучателей Цикл
		Если НЕ Получатель = Справочники.Пользователи.ПустаяСсылка() Тогда
			АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ПараметрыСообщения.ТекстСообщения + ПараметрыСообщения.Номенклатура + " (Код - " + ПараметрыСообщения.Номенклатура.Код + ")" + Символы.ПС
																	+ "Комплектующий товар: " + ПараметрыСообщения.КомплектующийТовар + Символы.ПС
																	+ "Вид запроса: " + ПараметрыСообщения.ВидЗапроса + Символы.ПС
																	+ "Замечание: " + ПараметрыСообщения.Замечание + Символы.ПС
																	+ "Автор замечания: " + ПараметрыСообщения.АвторЗамечания,
																	Получатель.Значение);
		КонецЕсли;		
	КонецЦикла;	
	 
	АльтерраОбщегоНазначения.СообщитьПользователю( ,"Спасибо за обращение!", ); 
	
КонецПроцедуры

Процедура ОтправитьСообщениеОРазблокировкеВБитрикс24 (ПараметрыСообщения) Экспорт
	ТекстСообщения = "";
	Если ПараметрыСообщения.Свойство("НомерБлокировки") Тогда
		ТекстСообщения = "Разблокированны товары из блокировки №" + ПараметрыСообщения.НомерБлокировки + Символы.ПС
	Иначе
		ТекстСообщения = "Разблокированы товары без блокировки-основания" + Символы.ПС
	КонецЕсли;
	ТекстСообщения = ТекстСообщения + "Автор разблокировки: " + ПараметрыСообщения.АвторРазблокировки + Символы.ПС
					+ "Список товаров: " + Символы.ПС + ПараметрыСообщения.СписокТоваров;
	Если ПараметрыСообщения.Свойство("Комментарий") Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС + "Комментарий: " + ПараметрыСообщения.Комментарий;
	КонецЕсли;

	Если ПараметрыСообщения.Свойство("Склад") И ПараметрыСообщения.Склад = Справочники.Склады.НайтиПоНаименованию("Склад (Выбор)") Тогда
			
		ТекстСообщения = ТекстСообщения + Символы.ПС + "РуководительСекции: " + ПараметрыСообщения.РуководительСекции;
		Запрос = Новый Запрос;
		Запрос.Текст = "Выбрать Ссылка из Справочник.Сотрудники Где Наименование = &п1 И Уволен = ЛОЖЬ И ПометкаУдаления = ЛОЖЬ";
		Запрос.УстановитьПараметр("п1", "Краснова Алёна Александровна");
		Результат = Запрос.Выполнить().Выгрузить();
		Получатель = Результат[0].Ссылка;
		АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения, Получатель);
	КонецЕсли;	
		
	АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения, ПараметрыСообщения.РуководительСекции);
	
КонецПроцедуры

