Функция ВозвратДанныхКонтрагента(Документ)
	ДокументИсточник=Документ;
	если ДокументИсточник.Метаданные().имя="ОтчетОРозничныхПродажах" тогда
		СведенияКонтрагента=Новый Структура;
		СведенияКонтрагента.Вставить("Контрагент",Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор("0562ed9b-4ca4-11e1-8e7d-001e101f9843")));
		СведенияКонтрагента.Вставить("Партнер",Справочники.Партнеры.НайтиПоНаименованию("ФИЗИЧЕСКОЕ ЛИЦО"));
		СведенияКонтрагента.Вставить("Договор","С покупателем, руб");
		СведенияКонтрагента.Вставить("Склад",ДокументИсточник.Склад);
		Возврат СведенияКонтрагента;	
	конецесли;
	СведенияКонтрагента=Новый Структура;
	СведенияКонтрагента.Вставить("Контрагент",Документ.Контрагент);
	СведенияКонтрагента.Вставить("Партнер",НЕОПРЕДЕЛЕНО);
	СведенияКонтрагента.Вставить("Договор","");
	СведенияКонтрагента.Вставить("Склад",Справочники.Склады.ПустаяСсылка());
	если ДокументИсточник.Метаданные().имя="РеализацияТоваровУслуг" тогда
		СчетФактура=ПродажиСервер.ПараметрыПредставленияСчетаФактуры(ДокументИсточник,ДокументИсточник.Организация);
		ЗначениеСклада=ВозвратитьСклад(ДокументИсточник);
		СведенияКонтрагента.Склад=ЗначениеСклада;
		Если СчетФактура.ТекстСчетФактура="Оформить счет-фактуру" Тогда
			СведенияКонтрагента.Контрагент=Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор("0562ed9b-4ca4-11e1-8e7d-001e101f9843"));
			СведенияКонтрагента.Партнер=Справочники.Партнеры.НайтиПоНаименованию("ФИЗИЧЕСКОЕ ЛИЦО");
			
			Стрпоиск="С покупателем, руб";
			СведенияКонтрагента.Договор=стрПоиск;
			
		иначе
			СведенияКонтрагента.Контрагент=ДокументИсточник.Контрагент;
			СведенияКонтрагента.Партнер=ДокументИсточник.Партнер;
		конецесли;	
		
	иначе
		если (Метаданные.Документы[ДокументИсточник.Метаданные().имя].Реквизиты.Найти("ДокументРеализации")<>НЕОПРЕДЕЛЕНО) тогда
			если ДокументИсточник.ДокументРеализации<>НЕОПРЕДЕЛЕНО Тогда
				ДокументИсточник=ДокументИсточник.ДокументРеализации;
				СведенияКонтрагента=ВозвратДанныхКонтрагента(ДокументИсточник);
			конецесли;
			
		Конецесли;	
		
		если (Метаданные.Документы[ДокументИсточник.Метаданные().имя].Реквизиты.Найти("ДокументОснование")<>НЕОПРЕДЕЛЕНО) тогда
			если ДокументИсточник.ДокументОснование<>НЕОПРЕДЕЛЕНО Тогда
				ДокументИсточник=ДокументИсточник.ДокументОснование;
				СведенияКонтрагента=ВозвратДанныхКонтрагента(ДокументИсточник);
			конецесли;
		Конецесли;		
	конецесли;	
	Возврат СведенияКонтрагента;
	
	
КонецФункции

Функция ВозвратитьСклад(Документ)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РеализацияТоваровУслугТовары.Склад.СкладДляБухгалтерии КАК Склад
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
	|	И РеализацияТоваровУслугТовары.Ссылка.Склад.ЭтоГруппа
	|	И РеализацияТоваровУслугТовары.Склад.СкладДляБухгалтерии <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	РеализацияТоваровУслуг.Склад.СкладДляБухгалтерии
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &Ссылка
	|	И НЕ РеализацияТоваровУслуг.Ссылка.Склад.ЭтоГруппа
	|	И РеализацияТоваровУслуг.Склад.СкладДляБухгалтерии <> ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	РеализацияТоваровУслугТовары.Склад
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
	|	И РеализацияТоваровУслугТовары.Ссылка.Склад.ЭтоГруппа
	|	И РеализацияТоваровУслугТовары.Склад.СкладДляБухгалтерии = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	РеализацияТоваровУслуг.Склад
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &Ссылка
	|	И НЕ РеализацияТоваровУслуг.Ссылка.Склад.ЭтоГруппа
	|	И РеализацияТоваровУслуг.Склад.СкладДляБухгалтерии = ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Ссылка", Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	если НЕ РезультатЗапроса.Пустой() тогда
		Выборка = РезультатЗапроса.Выбрать();
		
		если Выборка.Следующий() тогда
			Возврат Выборка.Склад;
			
		иначе
			Возврат Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
	иначе
		Возврат Справочники.Склады.ПустаяСсылка()
	КонецЕсли;	
КонецФункции

Функция ПроверитьЗеленение(Товары,Склад) экспорт
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц= Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц=МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Кладовщик,
	|	Товары.Номенклатура
	|ПОМЕСТИТЬ Табл
	|ИЗ
	|	&Товары КАК Товары
	|ГДЕ
	|	Товары.Кладовщик = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Табл.Номенклатура
	|ИЗ
	|	Табл КАК Табл
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО Табл.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|ГДЕ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад";
	
	Запрос.УстановитьПараметр("Товары", Товары);
	Запрос.УстановитьПараметр("Склад", Склад);
	Результат = Запрос.ВыполнитьПакет();
	Количество=Результат[1].Выгрузить().Количество();
	возврат количество>0;
