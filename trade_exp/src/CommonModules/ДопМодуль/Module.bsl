Функция ПодобратьВидЦеныТСК(ВидЦены) экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыЦен.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	ВидыЦен.РегионПрисутствия = &РегионПрисутствия
	|	И ВидыЦен.ФорматПодразделения = &ФорматПодразделения
	|	И ВидыЦен.ГруппаВидовЦен = &ГруппаВидовЦен";
	
	Запрос.УстановитьПараметр("ГруппаВидовЦен", ВидЦены.ГруппаВидовЦен);
	Запрос.УстановитьПараметр("РегионПрисутствия", ВидЦены.РегионПрисутствия);
	Запрос.УстановитьПараметр("ФорматПодразделения", Справочники.ФорматыПодразделений.НайтиПоНаименованию("ТСК"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		возврат ВыборкаДетальныеЗаписи.ссылка;  
	иначе
		Возврат Справочники.ВидыЦен.ПустаяСсылка();
	Конецесли;
	
	
КонецФункции // ПодобратьВидЦены()

Процедура ОбработатьЛистСогласованияПоДокументу(Статус, ДокументСсылка) Экспорт
	Если Статус <> "Подписан" Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистСогласования.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистСогласования КАК ЛистСогласования
	|ГДЕ
	|	ЛистСогласования.Основание = &Основание
	|	И НЕ ЛистСогласования.Аннулирован
	|	И НЕ ЛистСогласования.Исполнен
	|	И ЛистСогласования.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления)";
	
	Запрос.УстановитьПараметр("Основание", ДокументСсылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	ТекДата = ТекущаяДата();  
	Если День(ТекДата) >= 1 И День(ТекДата) < 11 Тогда
		ДатаИсполнения = НачалоМесяца(ТекДата) - 1;
	Иначе 
		ДатаИсполнения = ТекДата;
	КонецЕсли;
	
	Пока РезультатЗапроса.Следующий() Цикл
		ДокОбъект = РезультатЗапроса.Ссылка.ПолучитьОбъект();
		ДокОбъект.ДатаИсполнения = ДатаИсполнения;
		ДокОбъект.Исполнен = Истина;
		ДокОбъект.Исполнитель = Пользователи.ТекущийПользователь();
		ДокОбъект.ДатаРегистрацииИсполнения = ТекДата;
		ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЦикла;
	
КонецПроцедуры

Функция ОприходованиеИзлишковТоваров_ПараметрыОткрытияФормы(Объект) Экспорт
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Организация",   АльтерраОбщегоНазначения.ПолучитьАСКР());
	ПараметрыОткрытияФормы.Вставить("Склад", 		 Объект.Склад);       
	ПараметрыОткрытияФормы.Вставить("Комментарий",   "излишки касса");
	ПараметрыОткрытияФормы.Вставить("СтатьяДоходов", ПланыВидовХарактеристик.СтатьиДоходов.НайтиПоКоду("0А-000003")); // Результаты инвентаризаций (товар)
	ПараметрыОткрытияФормы.Вставить("Товары", 		 ПоместитьВоВременноеХранилище(
		Объект.Товары.Выгрузить( ,"Номенклатура, Характеристика, Цена, Сумма, Серия, СтатусУказанияСерий, Кладовщик"),
		Новый УникальныйИдентификатор));
		
	Возврат ПараметрыОткрытияФормы;
КонецФункции    

#Область ПроверитьВозможностьРучныхСкидкок

Процедура СохранитьПроцентРучнойСкидки(Товары) Экспорт
	Для Каждого Стр Из Товары Цикл
		Стр.ПроцентРучнойСкидки_СтароеЗначение = Стр.ПроцентРучнойСкидки;
		Стр.Номенклатура_СтароеЗначение = Стр.Номенклатура;
	КонецЦикла; 
КонецПроцедуры

Процедура ПроверитьВозможностьРучныхСкидкок(Отказ, Товары, Соглашение)  Экспорт
	
	Если РольДоступна("ПолныеПрава") Тогда //ИЛИ РольДоступна("ОтметкаКассы")  Тогда
		Возврат;
	КонецЕсли;
	
	ОграниченияРучныхСкидок = НастройкиПродажДляПользователейСервер.ОграниченияСкидокНаценок(Соглашение, Пользователи.ТекущийПользователь());
	Если ОграниченияРучныхСкидок.Количество() > 0 Тогда
		стрОграничения =  ОграниченияРучныхСкидок[0]; // Берем любую, т.к. нет деления скидок по ценовым группам
		Если ЗначениеЗаполнено(стрОграничения.МаксимальныйПроцентРучнойСкидки) Тогда
			Для Каждого Стр Из Товары Цикл
				Если ЗначениеЗаполнено(Стр.ПроцентРучнойСкидки) И Стр.ПроцентРучнойСкидки > стрОграничения.МаксимальныйПроцентРучнойСкидки Тогда
					Если Стр.ПроцентРучнойСкидки = Стр.ПроцентРучнойСкидки_СтароеЗначение Тогда
						Если Стр.Номенклатура <> Стр.Номенклатура_СтароеЗначение Тогда
							ОбщегоНазначения.СообщитьПользователю("Для строки #" + Стр.НомерСтроки + " задан процент ручной скидки, превышающий допустимое значение для пользователя! Номенклатура не должна меняться");
							Отказ = Истина;
							Прервать;
						КонецЕсли;
					Иначе
						ОбщегоНазначения.СообщитьПользователю("Для строки #" + Стр.НомерСтроки + " задан процент ручной скидки, превышающий допустимое значение для пользователя! (" + стрОграничения.МаксимальныйПроцентРучнойСкидки + ")");
						Отказ = Истина;
						Прервать;	
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

