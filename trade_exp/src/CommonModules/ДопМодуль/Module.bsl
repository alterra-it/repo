#Область РаспределениеТранспортных

Процедура КонтрольТранспортных(Объект,отказ) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка.РаспределитьТранспортные
	|	И РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.типыНоменклатуры.Услуга)
	|	И РеализацияТоваровУслугТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	если РезультатЗапроса.Пустой() тогда
		ТекстСообщения = "В таблице товаров отсутствуют услуги к распределению!
		|Снимите флажок ""Распределять сумму услуг ...""";
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, ,, Отказ);
	конецесли;
КонецПроцедуры

Процедура РаспределениеТранспортных(Источник) Экспорт
	если Источник.Товары.Итог("Распределять")= 0 и Источник.Товары.Итог("СуммаСНДСРТ")+Источник.Товары.Итог("СуммаНДСРТ")=0 тогда  
		Источник.РаспределитьТранспортные=ложь;
		возврат;
	конецесли;

	СтруктураПараметров = Новый Структура("СуммаТоваров,СуммаУслуг,Коэфф",0,0,0);
	ЗаполнитьПараметрыСтруктуры(СтруктураПараметров,Источник);
	Если Источник.Товары.Итог("Распределять")>0 и СтруктураПараметров.СуммаУслуг=0 тогда 
		ОчиститьТабличныеЧасти(Источник);	
		Источник.РаспределитьТранспортные=ложь;
		возврат;
	конецесли;
	
	Товары=Источник.Товары;
	ИТОГСуммаСНДСРТ=0;
	ИТОГСуммаНДСРТ=0;
	ИТОГСуммаРТ=0;  
		
	Если  Источник.РаспределитьТранспортныеДистрибуция Тогда
		

		Для Каждого Стр Из Товары Цикл 
			
			Коэфф = Стр.СуммаРТ/(Стр.Сумма);
			
			Стр.СуммаСНДСРТ=Стр.СуммаСНДС*Коэфф;
			Стр.СуммаНДСРТ=Стр.СуммаНДС*Коэфф;
			
			Если Стр.Номенклатура.ТипНоменклатуры=перечисления.ТипыНоменклатуры.Услуга тогда
				ОтборУслуг=0;
			Иначе                   
				ОтборУслуг=1;
			КонецЕсли;
			
			ИТОГСуммаСНДСРТ=ИТОГСуммаСНДСРТ+Стр.СуммаСНДСРТ+отборУслуг*Стр.СуммаСНДС;
			ИТОГСуммаНДСРТ=ИТОГСуммаНДСРТ+Стр.СуммаНДСРТ+отборУслуг*Стр.СуммаНДС;
			ИТОГСуммаРТ=ИТОГСуммаРТ+Стр.СуммаРТ+отборУслуг*Стр.Сумма; 
			
			Стр.ЦенаСДоставкойПечать =(Стр.Сумма + Стр.СуммаРТ)/Стр.КоличествоУпаковок; 

		КонецЦикла;		
		
	Иначе
		
		Коэфф = СтруктураПараметров.Коэфф; 
	
		Для каждого стр из Товары цикл 		
			стр.СуммаСНДСРТ=Стр.СуммаСНДС*Коэфф*стр.Распределять;
			стр.СуммаНДСРТ=Стр.СуммаНДС*Коэфф*стр.Распределять;
			стр.СуммаРТ=Стр.Сумма*Коэфф*стр.Распределять; 
			если стр.Номенклатура.ТипНоменклатуры=перечисления.ТипыНоменклатуры.Услуга тогда
				ОтборУслуг=0;
			иначе
				ОтборУслуг=1;
			конецесли;	
			ИТОГСуммаСНДСРТ=ИТОГСуммаСНДСРТ+стр.СуммаСНДСРТ+отборУслуг*стр.СуммаСНДС;
			ИТОГСуммаНДСРТ=ИТОГСуммаНДСРТ+стр.СуммаНДСРТ+отборУслуг*стр.СуммаНДС;
			ИТОГСуммаРТ=ИТОГСуммаРТ+стр.СуммаРТ+отборУслуг*стр.Сумма;
		конеццикла;
	КонецЕсли;	

	
		ТаблДокументаВР=Товары.Выгрузить();
		ТаблДокументаВР.Сортировать("Сумма Убыв");
		для каждого стр из ТаблДокументаВР цикл
			Если стр.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга И стр.Распределять <> 0 Тогда 
				строкаДокумента=Товары.Найти(стр.номерстроки,"НомерСтроки");
				строкаДокумента.СуммаСНДСРТ=стр.СуммаСНДСРТ+Товары.ИТОГ("СуммаСНДС")-ИТОГСуммаСНДСРТ;
				строкаДокумента.СуммаНДСРТ=стр.СуммаНДСРТ+Товары.ИТОГ("СуммаНДС")-ИТОГСуммаНДСРТ;
				строкаДокумента.СуммаРТ=стр.СуммаРТ+Товары.ИТОГ("Сумма")-ИТОГСуммаРТ;
				стр.СуммаСНДСРТ=строкаДокумента.СуммаСНДСРТ;
				стр.СуммаНДСРТ=строкаДокумента.СуммаНДСРТ;
				стр.СуммаРТ=строкаДокумента.СуммаРТ;		
				прервать;
			КонецЕсли;	
		конеццикла;	

	
	Источник.РаспределитьТранспортные= Источник.Товары.Итог("Распределять")>0;
	если ТипЗнч(Источник)=Тип("ДокументОбъект.РеализацияТоваровУслуг") тогда
		ТаблДокументаВР.Свернуть("АналитикаУчетаНоменклатуры,ЗаказКлиента","Количество,СуммаСНДСРТ,СуммаРТ,СуммаНДСРТ");
		для каждого стр из ТаблДокументаВР цикл
			ЗаполнитьСтрокуВидовЗапасов(Стр,Источник);
		конеццикла;	
	конецесли;	
КонецПроцедуры

