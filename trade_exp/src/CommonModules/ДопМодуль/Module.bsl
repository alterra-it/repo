			  
#Область РаботаСДопРеквизитамиНаФорме 

Функция ПолучитьПолеДополнительногоРеквизитаНаФорме(Форма, ИмяРеквизита) Экспорт 
	
	Список = Форма.Свойства_ОписаниеДополнительныхРеквизитов;
	Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоРеквизиту("Имя", ИмяРеквизита);
	
	Если ЗначениеЗаполнено(Свойство) Тогда
	    НайденныеСтроки = Список.НайтиСтроки(Новый Структура("Свойство", Свойство));
		Если НайденныеСтроки.Количество() > 0 Тогда
			Возврат НайденныеСтроки[0];		
		КонецЕсли; 		
	КонецЕсли;
	
КонецФункции

Функция ПолучитьЗначениеДополнительногоРеквизитаНаФорме(Форма, ИмяРеквизита) Экспорт
	
	ПолеДополнительногоРеквизитаНаФорме = ПолучитьПолеДополнительногоРеквизитаНаФорме(Форма, ИмяРеквизита);
	
	Если ПолеДополнительногоРеквизитаНаФорме <> Неопределено Тогда
		Возврат Форма[ПолеДополнительногоРеквизитаНаФорме.ИмяРеквизитаЗначение];
	КонецЕсли;
	
КонецФункции

Процедура УстановитьЗначениеДополнительногоРеквизитаНаФорме(Форма, ИмяРеквизита, ЗначениеРеквизита) Экспорт
	
	ПолеДополнительногоРеквизитаНаФорме = ПолучитьПолеДополнительногоРеквизитаНаФорме(Форма, ИмяРеквизита);
	
	Если ПолеДополнительногоРеквизитаНаФорме <> Неопределено Тогда
		Форма[ПолеДополнительногоРеквизитаНаФорме.ИмяРеквизитаЗначение] = ЗначениеРеквизита;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПереместитьДополнительныйРеквизит(Форма, ИмяРеквизита, ИмяГруппы, Доступность = Истина) Экспорт
	
	Попытка
		Поле = ПолучитьПолеДополнительногоРеквизитаНаФорме(Форма, ИмяРеквизита);
		Группа = Форма.Элементы.Найти(ИмяГруппы); 
		ПолеФормы = Форма.Элементы[Поле.ИмяРеквизитаЗначение];
		Если ПолеФормы <> Неопределено Тогда
			Форма.Элементы.Переместить(ПолеФормы, Группа); 
			ПолеФормы.Доступность = Доступность;
		КонецЕсли; 
	Исключение
		ОбщегоНазначения.СообщитьПользователю("Ошибка при перемещении доп. реквизита '" + ИмяРеквизита + "' в группу '" + ИмяГруппы + "'!");
	КонецПопытки;
	
КонецПроцедуры  

Функция КонтрагентРаботаетВЭДО(Контрагент) экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты
		|ГДЕ
		|	КонтрагентыДополнительныеРеквизиты.Ссылка = &Контрагент
		|	И КонтрагентыДополнительныеРеквизиты.Свойство.Имя = ""УчастникЭДО""
		|	И КонтрагентыДополнительныеРеквизиты.Значение = ИСТИНА";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
возврат не РезультатЗапроса.Пустой();	

КонецФункции // КонтрагентРаботаетВЭДО()

#КонецОбласти

Функция СуммаПеремещения(Объект) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Ссылка.ВидЦены,
	|	ЦеныНоменклатурыСрезПоследних.Цена,
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.Количество,
	|	СУММА(ПеремещениеТоваровТовары.Количество * ЦеныНоменклатурыСрезПоследних.Цена) КАК Сумма
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаДокумента, ) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ПеремещениеТоваровТовары.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И ПеремещениеТоваровТовары.Ссылка.ВидЦены = ЦеныНоменклатурыСрезПоследних.ВидЦены
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка = &Объект
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Ссылка.ВидЦены,
	|	ЦеныНоменклатурыСрезПоследних.Цена,
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.Количество
	|ИТОГИ
	|	СУММА(Сумма)
	|ПО
	|	ОБЩИЕ";
	
	Запрос.УстановитьПараметр("ДатаДокумента", объект.Дата);
	Запрос.УстановитьПараметр("Объект", Объект.Ссылка);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаОбщийИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ВыборкаОбщийИтог.Следующий();		
	
	ВыборкаДетальныеЗаписи = ВыборкаОбщийИтог.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	КонецЦикла;
	
	Возврат ВыборкаОбщийИтог.Сумма;
КонецФункции

Функция ПолучитьПользователя() Экспорт
	возврат параметрыСеанса.ТекущийПользователь;
конецфункции	

Процедура УстановкаОтметкиКассы(ОбъектСпис) экспорт
	
	объект=объектСпис.Получитьобъект();
	
	если Объект.Кассир.Пустая() тогда
		Объект.Кассир=ПолучитьПользователя();
		
	иначе		
		Объект.Кассир="";
	конецесли;
	
	объект.Записать();
	
КонецПроцедуры

Функция ПолучитьКассуПоУмолчанию(Организация, Валюта = Неопределено) Экспорт
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 2
	|	Кассы.Ссылка КАК Касса
	|ИЗ
	|	Справочник.Кассы КАК Кассы
	|ГДЕ
	|	Не Кассы.ПометкаУдаления
	|	И (Кассы.Владелец = &Организация
	|		ИЛИ &Организация = Неопределено)
	|	И (Кассы.ВалютаДенежныхСредств = &Валюта
	|		ИЛИ &Валюта = Неопределено)
	|");
	
	Запрос.УстановитьПараметр("Организация", ?(ЗначениеЗаполнено(Организация), Организация, Неопределено));
	Запрос.УстановитьПараметр("Валюта", ?(ЗначениеЗаполнено(Валюта), Валюта, Неопределено));
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Количество() > 0 тогда
		Выборка.Следующий();
		Касса = Выборка.Касса;
	Иначе
		Касса = Справочники.Кассы.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Касса;
	
КонецФункции

Процедура ПроверкаНаОтклонениеОтЦеновыхУсловий(Объект, Отказ) Экспорт	
	МассивСообщений = Новый Массив;
	Соглашение = Объект.Соглашение;
	СоглашениеЗаполнено = ЗначениеЗаполнено(Соглашение);	
	
	Запрос = Новый Запрос;
	если НовоеЦенообразование() тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧТовары.НомерСтроки КАК НомерСтроки,
		|	ТЧТовары.Номенклатура КАК Номенклатура,
		|	ТЧТовары.Характеристика КАК Характеристика,
		|	ТЧТовары.ВидЦены КАК ВидЦены,
		|	ТЧТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки, 
		|	&ПолеОбособленно КАК Обособленно,
		|	ТЧТовары.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ТЧТовары
		|ГДЕ
		|	НЕ &ПолеОбособленно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧТовары.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	ВТТовары КАК ТЧТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашенияСКлиентамиТовары
		|		ПО (СоглашенияСКлиентамиТовары.Ссылка = &Соглашение)
		|			И ТЧТовары.Номенклатура = СоглашенияСКлиентамиТовары.Номенклатура
		|			И ТЧТовары.Характеристика = СоглашенияСКлиентамиТовары.Характеристика
		|			И (СоглашенияСКлиентамиТовары.Цена > 0)
		|ГДЕ
		|	ТЧТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|	И СоглашенияСКлиентамиТовары.Номенклатура.Ссылка ЕСТЬ NULL
		|;
		|" + ?(СоглашениеЗаполнено, "
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧТовары.Номенклатура КАК Номенклатура,
		|	ТЧТовары.Характеристика КАК Характеристика,
		|	ТЧТовары.НомерСтроки КАК НомерСтроки,
		|	ТЧТовары.ВидЦены КАК РеализацияВидЦены,
		|	ТЧТовары.Обособленно КАК Обособленно,  
		|	ВидыЦен.Ссылка КАК СоглашенияВидЦеныОбщая,
		|	МАКСИМУМ(ВидыЦенТовары.Ссылка) КАК СоглашенияТоварыВидЦены,
		|	МАКСИМУМ(ВидыЦенЦеновыеГруппы.Ссылка) КАК СоглашенияЦеновыеГруппыВидЦены,
		|	ТЧТовары.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки,
		|	ТЧТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки
		|ИЗ
		|	ВТТовары КАК ТЧТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК Соглашения
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|			ПО Соглашения.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
		|				И (ВидыЦен.ФорматПодразделения = &ФорматПодразделения)
		|				И (ВидыЦен.РегионПрисутствия = &Регионприсутствия)
		|		ПО (Соглашения.Ссылка = &Соглашение)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашенияТовары
		|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|				ВидыЦен.Ссылка КАК Ссылка,
		|				ВидыЦен.ГруппаВидовЦен КАК ГруппаВидовЦен
		|			ИЗ
		|				Справочник.ВидыЦен КАК ВидыЦен
		|			ГДЕ
		|				ВидыЦен.ФорматПодразделения = &ФорматПодразделения
		|				И ВидыЦен.РегионПрисутствия = &РегионПрисутствия) КАК ВидыЦенТовары
		|			ПО СоглашенияТовары.ГруппаВидовЦен = ВидыЦенТовары.ГруппаВидовЦен
		|		ПО (СоглашенияТовары.Ссылка = &Соглашение)
		|			И ТЧТовары.Номенклатура = СоглашенияТовары.Номенклатура
		|			И ТЧТовары.Характеристика = СоглашенияТовары.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглашенияЦеновыеГруппы
		|			ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|				ВидыЦен.Ссылка КАК Ссылка,
		|				ВидыЦен.ГруппаВидовЦен КАК ГруппаВидовЦен
		|			ИЗ
		|				Справочник.ВидыЦен КАК ВидыЦен
		|			ГДЕ
		|				ВидыЦен.ФорматПодразделения = &ФорматПодразделения
		|				И ВидыЦен.РегионПрисутствия = &РегионПрисутствия) КАК ВидыЦенЦеновыеГруппы
		|			ПО СоглашенияЦеновыеГруппы.ГруппаВидовЦен = ВидыЦенЦеновыеГруппы.ГруппаВидовЦен
		|		ПО (СоглашенияЦеновыеГруппы.Ссылка = &Соглашение)
		|			И ТЧТовары.Номенклатура.ЦеноваяГруппа = СоглашенияЦеновыеГруппы.ЦеноваяГруппа
		|ГДЕ
		|	ТЧТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ТЧТовары.Номенклатура,
		|	ТЧТовары.Характеристика,
		|	ТЧТовары.НомерСтроки,
		|   ТЧТовары.Обособленно,
		|	ТЧТовары.ВидЦены,
		|	ВидыЦен.Ссылка,
		|	ТЧТовары.ПроцентРучнойСкидки,
		|	ТЧТовары.СуммаРучнойСкидки","");
		Запрос.УстановитьПараметр("ФорматПодразделения", Объект.Подразделение.ФорматПодразделения);
		Запрос.УстановитьПараметр("Регионприсутствия", Объект.Подразделение.Регионприсутствия);
	иначе         
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЧТовары.НомерСтроки КАК НомерСтроки,
		|	ТЧТовары.Номенклатура КАК Номенклатура,
		|	ТЧТовары.Характеристика КАК Характеристика,
		|	ТЧТовары.ВидЦены КАК ВидЦены,
		|	&ПолеОбособленно КАК Обособленно,
		|	ТЧТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	ТЧТовары.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ТЧТовары
		|ГДЕ
		|	НЕ &ПолеОбособленно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧТовары.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	ВТТовары КАК ТЧТовары
		|ГДЕ
		|	ТЧТовары.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|;
		|" + ?(СоглашениеЗаполнено, "
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЧТовары.Номенклатура КАК Номенклатура,
		|	ТЧТовары.Характеристика КАК Характеристика,
		|	ТЧТовары.НомерСтроки КАК НомерСтроки,
		|	ТЧТовары.ВидЦены КАК РеализацияВидЦены,
		|	Соглашения.ВидЦен КАК СоглашенияВидЦеныОбщая,
		|	МАКСИМУМ(СоглашенияТовары.ВидЦены) КАК СоглашенияТоварыВидЦены,
		|	МАКСИМУМ(СоглашенияЦеновыеГруппы.ВидЦен) КАК СоглашенияЦеновыеГруппыВидЦены,
		|	ТЧТовары.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки,
		|	ТЧТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки
		|ИЗ
		|	ВТТовары КАК ТЧТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК Соглашения
		|		ПО (Соглашения.Ссылка = &Соглашение)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашенияТовары
		|		ПО (СоглашенияТовары.Ссылка = &Соглашение)
		|			И ТЧТовары.Номенклатура = СоглашенияТовары.Номенклатура
		|			И ТЧТовары.Характеристика = СоглашенияТовары.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглашенияЦеновыеГруппы
		|		ПО (СоглашенияЦеновыеГруппы.Ссылка = &Соглашение)
		|			И ТЧТовары.Номенклатура.ЦеноваяГруппа = СоглашенияЦеновыеГруппы.ЦеноваяГруппа
		|ГДЕ
		|	ТЧТовары.ВидЦены <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ТЧТовары.Номенклатура,
		|	ТЧТовары.Характеристика,
		|	ТЧТовары.НомерСтроки,
		|	ТЧТовары.ВидЦены,
		|	Соглашения.ВидЦен,
		|	ТЧТовары.ПроцентРучнойСкидки,
		|	ТЧТовары.СуммаРучнойСкидки", "");
		
	Конецесли;                              
	если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") тогда
		Запрос.Текст=стрзаменить(Запрос.Текст,"&ПолеОбособленно","ТЧТовары.Обособленно"); 
	иначеесли ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") тогда
		Запрос.Текст=стрзаменить(Запрос.Текст,"&ПолеОбособленно","ТЧТовары.Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)");
	иначе
		Запрос.Текст=стрзаменить(Запрос.Текст,"&ПолеОбособленно","ложь"); 
	конецесли;	
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("Соглашение", Соглашение);
	
	СписокПакетов = Запрос.ВыполнитьПакет();
	Если Не СписокПакетов[1].Пустой() Тогда
		РезультатЗапроса = СписокПакетов[1].Выбрать();
		Пока РезультатЗапроса.Следующий() Цикл
			МассивСообщений.Добавить("Существует отклонение от ценовых условий! Необходимо заполнить реквизит 'Причина отклонения от ценовых условий'! (По строке №" + РезультатЗапроса.НомерСтроки + " не заполнен 'Вид цены')");
		КонецЦикла;
	КонецЕсли;  
	
	Если СоглашениеЗаполнено Тогда
		РезультатЗапроса = СписокПакетов[2].Выбрать();
		Пока РезультатЗапроса.Следующий() Цикл
			Если ЗначениеЗаполнено(РезультатЗапроса.СоглашенияТоварыВидЦены) Тогда 
				//Если РезультатЗапроса.РеализацияВидЦены <> ?(РезультатЗапроса.Обособленно,ПодобратьВидЦеныТСК(РезультатЗапроса.СоглашенияТоварыВидЦены),РезультатЗапроса.СоглашенияТоварыВидЦены)  Тогда 
				Если РезультатЗапроса.РеализацияВидЦены <>РезультатЗапроса.СоглашенияТоварыВидЦены тогда
					МассивСообщений.Добавить("Существует отклонение от ценовых условий! Необходимо заполнить реквизит 'Причина отклонения от ценовых условий'! (По строке №" + РезультатЗапроса.НомерСтроки + " 'Вид цены' отличается от данных по документу Соглашения (Уточнение цен по товарам), " + РезультатЗапроса.РеализацияВидЦены + " <> " + РезультатЗапроса.СоглашенияТоварыВидЦены + ")"); 
				КонецЕсли; 
			ИначеЕсли ЗначениеЗаполнено(РезультатЗапроса.СоглашенияЦеновыеГруппыВидЦены) Тогда 
				Если РезультатЗапроса.РеализацияВидЦены <> РезультатЗапроса.СоглашенияЦеновыеГруппыВидЦены Тогда
					МассивСообщений.Добавить("Существует отклонение от ценовых условий! Необходимо заполнить реквизит 'Причина отклонения от ценовых условий'! (По строке №" + РезультатЗапроса.НомерСтроки + " 'Вид цены' отличается от данных по документу Соглашения (Уточнение цен по ценовым группам), " + РезультатЗапроса.РеализацияВидЦены + " <> " + РезультатЗапроса.СоглашенияЦеновыеГруппыВидЦены + ", Ценовая группа: '" + РезультатЗапроса.Номенклатура.ЦеноваяГруппа + "')"); 
				КонецЕсли;
			ИначеЕсли ЗначениеЗаполнено(РезультатЗапроса.СоглашенияВидЦеныОбщая) Тогда 
				Если РезультатЗапроса.РеализацияВидЦены <> РезультатЗапроса.СоглашенияВидЦеныОбщая Тогда
					МассивСообщений.Добавить("Существует отклонение от ценовых условий! Необходимо заполнить реквизит 'Причина отклонения от ценовых условий'! (По строке №" + РезультатЗапроса.НомерСтроки + " 'Вид цены' отличается от данных по документу Соглашения, " + РезультатЗапроса.РеализацияВидЦены + " <> " + РезультатЗапроса.СоглашенияВидЦеныОбщая + ")"); 	
				КонецЕсли; 
			Иначе
				МассивСообщений.Добавить("Для выбранного в документе Соглашения не заполнен реквизит 'Вид цены'! (Ошибка по строке №" + РезультатЗапроса.НомерСтроки + ")");
			КонецЕсли; 
			
			Если ЗначениеЗаполнено(РезультатЗапроса.ПроцентРучнойСкидки) ИЛИ ЗначениеЗаполнено(РезультатЗапроса.СуммаРучнойСкидки) Тогда
				Если Объект.РаспределитьТранспортныеДистрибуция Тогда                                             
					Если Объект.ПричинаОтклоненияОтЦеновыхУсловий = "" Тогда 
						Объект.ПричинаОтклоненияОтЦеновыхУсловий = "Ручная скидка при распределении транспортных дистрибуция";
					КонецЕсли;
				ИначеЕсли РезультатЗапроса.ПроцентРучнойСкидки <> 0 ИЛИ РезультатЗапроса.СуммаРучнойСкидки <>0 Тогда 
					Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
						МассивСообщений.Добавить("Была поставлена ручная скидка или наценка! Существует отклонение от ценовых условий! Необходимо заполнить реквизит 'Причина отклонения от ценовых условий'!"); 
					Иначе	
						МассивСообщений.Добавить("Существует отклонение от ценовых условий! Необходимо заполнить реквизит 'Причина отклонения от ценовых условий'! (По строке №" + РезультатЗапроса.НомерСтроки + " 'Вид цены' отличается от данных по документу Соглашения, " + РезультатЗапроса.РеализацияВидЦены + " <> " + РезультатЗапроса.СоглашенияВидЦеныОбщая + ")");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(МассивСообщений) Тогда		
		Если ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") И 
			ЗначениеЗаполнено(Объект.ЗаказКлиента) И
			ЗначениеЗаполнено(Объект.ЗаказКлиента.ПричинаОтклоненияОтЦеновыхУсловий) Тогда
			Объект.ПричинаОтклоненияОтЦеновыхУсловий = Объект.ЗаказКлиента.ПричинаОтклоненияОтЦеновыхУсловий;
		Иначе
			Для Каждого Сообщение Из МассивСообщений Цикл
				ОбщегоНазначения.СообщитьПользователю(Сообщение);
			КонецЦикла;
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// корректировка
Процедура КорректировкаСкладаДляКорректировкиНазначенияТоваров(Ссылка, Проведен, ПометкаУдаления, НовыйСклад) Экспорт
	Если ЗначениеЗаполнено(Ссылка) И ЗначениеЗаполнено(НовыйСклад) Тогда
		СтарыйСклад = Ссылка.Склад;
		Если ЗначениеЗаполнено(СтарыйСклад) И СтарыйСклад <> НовыйСклад Тогда
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
			|ГДЕ
			|	ПриходныйОрдерНаТовары.Распоряжение = &Ссылка
			|	И ПриходныйОрдерНаТовары.Проведен = &Проведен
			|	И ПриходныйОрдерНаТовары.ПометкаУдаления = &ПометкаУдаления";
			
			Запрос.УстановитьПараметр("Ссылка", Ссылка);
			Запрос.УстановитьПараметр("Проведен", Проведен);
			Запрос.УстановитьПараметр("ПометкаУдаления", ПометкаУдаления);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				ДокОбъект = АльтерраОбщегоНазначения.ПолучитьКорректировкуНазначения(Выборка.Ссылка, Проведен, ПометкаУдаления); 
				Если ЗначениеЗаполнено(ДокОбъект) Тогда
					Попытка
						ДокОбъект.ПолучитьОбъект().УстановитьПометкуУдаления(Истина);
					Исключение
						ВызватьИсключение;
					КонецПопытки;
				КонецЕсли;
			КонецЦикла;
			
			ДокОбъект = АльтерраОбщегоНазначения.ПолучитьКорректировкуНазначения(Ссылка, Проведен, ПометкаУдаления); 	
			Если ЗначениеЗаполнено(ДокОбъект) Тогда			
				Попытка
					ДокОбъект.ПолучитьОбъект().УстановитьПометкуУдаления(Истина);
				Исключение
					ВызватьИсключение;
				КонецПопытки;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ЗаполнитьОбъектКорректировки(ДокКорр,ДокР,СтрПост,ВидЗадолженности,ВидКорр)	 
	если СтрПост.Количество()=0 тогда
		Сообщить("Не найдено сопоставление регистра!");
	конецесли;	
	если ДокКорр.Пустая() тогда
		Док=Документы.КорректировкаЗадолженности.СоздатьДокумент();
	иначе
		Док=ДокКорр.ПолучитьОбъект();
	конецесли;	
	
	Док.Дата=ДокР.дата;
	
	если ((ВидЗадолженности="Расход") и (ВидКорр="Клиент")) или ((ВидЗадолженности="Приход") и (ВидКорр="Поставщик")) тогда
		Док.ТипЗадолженности=Перечисления.ТипыЗадолженности.Кредиторская;
		Док.организация=СтрПост.ОрганизацияРеализация;
		Док.Контрагент=СтрПост.КонтрагентРеализация;
		Док.Подразделение=СтрПост.ПодразделениеРеализация;
	иначе
		Док.ТипЗадолженности=Перечисления.ТипыЗадолженности.Дебиторская;
		Док.организация=СтрПост.ОрганизацияПоступление;
		Док.Контрагент=СтрПост.КонтрагентПоступление;
		Док.Подразделение=СтрПост.ПодразделениеПоступление;
	конецесли;
	Док.СтатьяРасходов=СтрПост.СтатьяРасходов;
	Док.Задолженность.Очистить();
	для каждого стрР из ДокР.РасшифровкаПлатежа цикл
		стр=Док.Задолженность.Добавить();
		стр.ВалютаВзаиморасчетов=стрР.ВалютаВзаиморасчетов;
		Стр.Партнер=СтрПост.ПартнерРеализация;
		если ВидКорр="Клиент" тогда
			Стр.ТипРасчетов=Перечисления.ТипыРасчетовСПартнерами.РасчетыСКлиентом;	
		иначе
			Стр.ТипРасчетов=Перечисления.ТипыРасчетовСПартнерами.РасчетыСПоставщиком;
		конецесли;
		Стр.Сумма=СтрР.Сумма;
	конеццикла;
	Док.Комментарий="Взаимозачет "+СОКРЛП(ДокР.Ссылка)+" "+СОКРЛП(ДокР.Контрагент)+" на сумму "+ДокР.СуммаДокумента;
	Док.Записать(РежимЗаписиДокумента.Проведение);
	если ВидКорр="Клиент" тогда
		ДокР.Корректировка1=Док.ссылка;
	иначе
		ДокР.Корректировка2=Док.ссылка;
	конецесли;
КонецФункции

Функция ДокументПоступления(ДокументОснования) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПоступлениеТоваровУслуг.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг КАК ПоступлениеТоваровУслуг
	|ГДЕ
	|	ПоступлениеТоваровУслуг.ДокументОснования.Ссылка = &ДокументОснования
	|	И ПоступлениеТоваровУслуг.ПометкаУдаления = ЛОЖЬ
	|	И ПоступлениеТоваровУслуг.РеализацияВПоступление = ИСТИНА";
	
	Запрос.УстановитьПараметр("ДокументОснования", ДокументОснования.Ссылка);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		ДокументПоступления=ВыборкаДетальныеЗаписи.Ссылка
	иначе
		ДокументПоступления=НЕОПРЕДЕЛЕНО;
	КонецЕсли;
	
	возврат ДокументПоступления;
конецФункции	

Процедура ДвижениеВзаиморасчетовПодразделенияПеремещение(Объект,ТаблицаДвижений,ВидОперации,Подразделение,ПодразделениеКорреспондент) экспорт
	
	Объект.Движения.ВзаиморасчетыСПодразделениями.Записывать=Истина;
	для каждого стр из ТаблицаДвижений цикл
		Движение=Объект.Движения.ВзаиморасчетыСПодразделениями.Добавить();
		Движение.ВидДвижения=Стр.ВидДвижения;
		если Стр.ВидДвижения=ВидДвиженияНакопления.Расход тогда
			Движение.Подразделение=Подразделение;
			Движение.ПодразделениеПолучатель=ПодразделениеКорреспондент;
		иначе
			Движение.Подразделение=ПодразделениеКорреспондент;
			Движение.ПодразделениеПолучатель=Подразделение;
		конецесли;
		Движение.ВидОперации=ВидОперации;
		Движение.Период=Объект.Дата;
		Движение.Сумма=	Стр.Стоимость+Стр.СуммаДопРасходов;
	Конеццикла;
	Объект.Движения.Записать();
	
конецПроцедуры

Процедура ДвижениеВзаиморасчетовПодразделения(Объект,ВидДвижения,ВидОперации,Подразделение,ПодразделениеКорреспондент) экспорт
	Объект.Движения.ВзаиморасчетыСПодразделениями.Записывать=Истина;
	Движение=Объект.Движения.ВзаиморасчетыСПодразделениями.Добавить();
	если ВидДвижения="Расход" тогда
		Движение.ВидДвижения=ВидДвиженияНакопления.Расход;
	иначе
		Движение.ВидДвижения=ВидДвиженияНакопления.Приход;
	конецесли;
	Движение.Подразделение=Подразделение;
	Движение.ПодразделениеПолучатель=ПодразделениеКорреспондент;
	Движение.ВидОперации=ВидОперации;
	
	Движение.Период=Объект.Дата;
	если ВидДвижения="Расход" тогда
		если типзнч(Объект.ссылка)=тип("ДокументСсылка.ВозвратТоваровМеждуОрганизациями") тогда
			Движение.Период=Объект.ДатаПринятия;
		конецесли;	
	конецесли;	
	если ВидДвижения="Приход" тогда
		если типзнч(Объект.ссылка)=тип("ДокументСсылка.ПередачаТоваровМеждуОрганизациями") тогда
			Движение.Период=Объект.ДатаПринятия;
		конецесли;	
	конецесли;	
	
	если типзнч(Объект.Ссылка)=тип("ДокументСсылка.КорректировкаЗадолженности") тогда
		Движение.Сумма=	Объект.Задолженность.Итог("Сумма");
	иначе
		Движение.Сумма=Объект.СуммаДокумента;
	конецесли;
	Объект.Движения.Записать();
	
конецПроцедуры

Процедура КонтрольОстатков(Объект,Отказ) экспорт
	Возврат;	
КонецПроцедуры	

Процедура КонтрольОстатковПоСебестоимости(Объект, Отказ) Экспорт
	
	Если Отказ ИЛИ Не Константы.КонтролироватьОстаткиТоваровПоСебестоимости.Получить() Тогда
		Возврат;
	КонецЕсли;	
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Себестоимость.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	Себестоимость.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
		|	Себестоимость.АналитикаУчетаНоменклатуры.Назначение КАК Назначение,
		|	Себестоимость.АналитикаУчетаНоменклатуры.СкладскаяТерритория КАК Склад,
		|	Себестоимость.АналитикаУчетаНоменклатуры.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	Себестоимость.КоличествоКонечныйОстаток КАК Количество
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров.ОстаткиИОбороты(, , Регистратор, , АналитикаУчетаНоменклатуры В (&МассивАналитики)) КАК Себестоимость
		|ГДЕ
		|	Себестоимость.КоличествоКонечныйОстаток < 0
		|	И Себестоимость.Регистратор = &Регистратор";
	
	Запрос.УстановитьПараметр("Регистратор", Объект.Ссылка);
	
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.КорректировкаПриобретения") Тогда
		Запрос.УстановитьПараметр("МассивАналитики", Объект.Расхождения.ВыгрузитьКолонку("Номенклатура"));
	Иначе
		Запрос.УстановитьПараметр("МассивАналитики", Объект.ВидыЗапасов.ВыгрузитьКолонку("АналитикаУчетаНоменклатуры"));
	КонецЕсли;	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ШаблонСообщения = НСтр("ru = 'Номенклатура %НоменклатураХарактеристика% 
		|Недостаточно на складе %Склад% на %Количество% %Единица% на дату %ДатаДокумента% по себестоимости'");
		
		ТекстСообщения = СтрЗаменить(ШаблонСообщения, "%НоменклатураХарактеристика%",
		НоменклатураКлиентСервер.ПредставлениеНоменклатуры(Выборка.Номенклатура, Выборка.Характеристика));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Количество%", Строка(-Выборка.Количество));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Склад%",      Строка(Выборка.Склад));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Единица%",    Строка(Выборка.ЕдиницаИзмерения));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ДатаДокумента%",    Строка(Объект.Дата));
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, Отказ);
		
		ДополнительнаяИнформация(Выборка.Номенклатура, Выборка.Характеристика, Выборка.Назначение, Выборка.Склад, Объект.Дата);
	КонецЦикла;
	
КонецПроцедуры

Процедура ДополнительнаяИнформация(Номенклатура, Характеристика, Назначение, Склад, ДатаДокумента)	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказыПоставщикам.ЗаказПоставщику КАК ЗаказПоставщику,
		|	ЗаказыПоставщикам.Номенклатура КАК Номенклатура,
		|	ЗаказыПоставщикам.Характеристика КАК Характеристика,
		|	ЗаказыПоставщикам.Склад КАК Склад,
		|	ЗаказыПоставщикам.КОформлениюРасход КАК КОформлениюРасход
		|ПОМЕСТИТЬ ВТЗаказыПоставщикам
		|ИЗ
		|	РегистрНакопления.ЗаказыПоставщикам.ОстаткиИОбороты(, &ДатаДокумента, , , ) КАК ЗаказыПоставщикам
		|ГДЕ
		|	ЗаказыПоставщикам.КОформлениюПриход <> 0
		|	И ЗаказыПоставщикам.Номенклатура = &Номенклатура
		|	И ЗаказыПоставщикам.Характеристика = &Характеристика
		|	И ЗаказыПоставщикам.Склад = &Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКПоступлению.ДокументПоступления КАК ДокументПоступления,
		|	ТоварыКПоступлению.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлению.Характеристика КАК Характеристика,
		|	ТоварыКПоступлению.Назначение КАК Назначение,
		|	ЗаказыПоставщикам.КОформлениюРасход КАК КОформлениюРасход
		|ПОМЕСТИТЬ ВТИтог
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.ОстаткиИОбороты(, &ДатаДокумента, , , ) КАК ТоварыКПоступлению
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЗаказыПоставщикам КАК ЗаказыПоставщикам
		|		ПО (ЗаказыПоставщикам.ЗаказПоставщику = ТоварыКПоступлению.ДокументПоступления)
		|			И (ЗаказыПоставщикам.Номенклатура = ТоварыКПоступлению.Номенклатура)
		|			И (ЗаказыПоставщикам.Характеристика = ТоварыКПоступлению.Характеристика)
		|			И (ЗаказыПоставщикам.Склад = ТоварыКПоступлению.Склад)
		|ГДЕ
		|	ТоварыКПоступлению.КОформлениюПоступленийПоРаспоряжениюРасход + ТоварыКПоступлению.КОформлениюОрдеровРасход <> 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТоварыКПоступлению.ДокументПоступления КАК ЗаказПоставщику
		|ИЗ
		|	ВТИтог КАК ТоварыКПоступлению
		|ГДЕ
		|	ТоварыКПоступлению.Назначение = &Назначение
		|	И ТоварыКПоступлению.КОформлениюРасход = 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТоварыКПоступлению.ДокументПоступления.Дата УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТоварыКПоступлению.ДокументПоступления КАК ЗаказПоставщику,
		|	ВЫБОР
		|		КОГДА ПриходныйОрдер.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|			ТОГДА Приобретение.Ссылка
		|		ИНАЧЕ ПриходныйОрдер.Ссылка
		|	КОНЕЦ КАК НазначениеЗаполнено,
		|	ВЫБОР
		|		КОГДА ПриходныйОрдер.Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|			ТОГДА Приобретение.Ссылка
		|		ИНАЧЕ ПриходныйОрдер.Ссылка
		|	КОНЕЦ КАК НазначениеНеЗаполнено
		|ИЗ
		|	ВТИтог КАК ТоварыКПоступлению
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдер
		|		ПО (ВЫРАЗИТЬ(ПриходныйОрдер.Ссылка.Распоряжение КАК Документ.ЗаказПоставщику).Ссылка = ТоварыКПоступлению.ДокументПоступления)
		|			И (ПриходныйОрдер.Номенклатура = ТоварыКПоступлению.Номенклатура)
		|			И (ПриходныйОрдер.Характеристика = ТоварыКПоступлению.Характеристика)
		|			И (ПриходныйОрдер.Ссылка.ПометкаУдаления = ЛОЖЬ)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг.Товары КАК Приобретение
		|		ПО (Приобретение.Ссылка.ЗаказПоставщику = ТоварыКПоступлению.ДокументПоступления)
		|			И (Приобретение.Номенклатура = ТоварыКПоступлению.Номенклатура)
		|			И (Приобретение.Характеристика = ТоварыКПоступлению.Характеристика)
		|			И (Приобретение.Ссылка.ПометкаУдаления = ЛОЖЬ)
		|ГДЕ
		|	ПриходныйОрдер.КоличествоУпаковок = Приобретение.КоличествоУпаковок
		|	И ПриходныйОрдер.Назначение <> Приобретение.Назначение
		|	И ТоварыКПоступлению.КОформлениюРасход <> 0
		|	И (ТоварыКПоступлению.Назначение = &Назначение
		|		ИЛИ ПриходныйОрдер.Назначение = &Назначение
		|		ИЛИ Приобретение.Назначение = &Назначение)
		|	И (ПриходныйОрдер.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|		ИЛИ Приобретение.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка))
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТоварыКПоступлению.ДокументПоступления.Дата УБЫВ";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Запрос.УстановитьПараметр("Назначение", Назначение);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
	
	СписокПакетов = Запрос.ВыполнитьПакет();
	
	Результат = СписокПакетов[2].Выбрать();
	Если Результат.Следующий() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По заказу поставщику '" + Результат.ЗаказПоставщику + "' отсутствует приобретение на дату реализации: " + ДатаДокумента, Результат.ЗаказПоставщику);
	КонецЕсли;
	
	Результат = СписокПакетов[3].Выбрать();
	Если Результат.Следующий() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю( 
			"По заказу поставщику '" + Результат.ЗаказПоставщику + "' в '" + 
			Результат.НазначениеЗаполнено + "' назначение указано, а в '" +
			Результат.НазначениеНеЗаполнено + "' назначение отсутствует!", Результат.ЗаказПоставщику);
	КонецЕсли;

КонецПроцедуры

Процедура КонтрольОтгрузки(Объект,Отказ) экспорт
	Если Объект.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыКОтгрузкеОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыКОтгрузкеОстатки.Характеристика КАК Характеристика,
	|	ТоварыКОтгрузкеОстатки.Склад КАК Склад,
	|	ТоварыКОтгрузкеОстатки.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СУММА(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток) КАК Количество
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки КАК ТоварыКОтгрузкеОстатки
	|ГДЕ
	|	ТоварыКОтгрузкеОстатки.ДокументОтгрузки = &ДокументОтгрузки
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыКОтгрузкеОстатки.Номенклатура,
	|	ТоварыКОтгрузкеОстатки.Характеристика,
	|	ТоварыКОтгрузкеОстатки.Склад
	|
	|ИМЕЮЩИЕ
	|	СУММА(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток) < 0";
	
	Запрос.УстановитьПараметр("ДокументОтгрузки", Объект.ссылка);	
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ШаблонСообщения = НСтр("ru = 'Номенклатура %НоменклатураХарактеристика% 
		|Реализовано больше, чем заказано на складе %Склад% на %Количество% %Единица%'");
		
		ТекстСообщения = СтрЗаменить(ШаблонСообщения, "%НоменклатураХарактеристика%",
		НоменклатураКлиентСервер.ПредставлениеНоменклатуры(Выборка.Номенклатура, Выборка.Характеристика));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Количество%", Строка(-Выборка.Количество));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Склад%",      Строка(Выборка.Склад));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Единица%",    Строка(Выборка.ЕдиницаИзмерения));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%датадокумента%",    Строка(Объект.Дата));
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, ,, Отказ);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);	
	
КонецПроцедуры

