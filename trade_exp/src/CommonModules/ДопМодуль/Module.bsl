// Возвращает структуру из настроек хранилища дополнительной обработки.
//
// Параметры:
//	ИмяФайла - поиск элемента справочника по имени файла 
//  ИмяСтруктуры - название структуры в структуре хранилища значений
// Возвращаемое значение:
//	Структура со значениями сохраненных настроек.
//
Функция ПолучитьНастройкиХранилища(ИмяСтруктуры,ИмяФайла="НастройкиХранилища.epf") экспорт
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", имяФайла);		
	СтруктураХранилища=ДополнительнаяОбработка.ХранилищеНастроек.Получить();
	если типзнч(СтруктураХранилища)=тип("Структура") и СтруктураХранилища.Свойство(ИмяСтруктуры) тогда
		Возврат СтруктураХранилища[ИмяСтруктуры] ;
	конецесли;
	возврат неопределено;
КонецФункции

Процедура УстановитьДоступностьПоОтметкеКассыОбщий(Форма) Экспорт 
	
	Если Не ЗначениеЗаполнено(Форма.Объект.Дата) Тогда
		Форма.Объект.Дата = ТекущаяДата();
	КонецЕсли;
	
	Если Форма.Объект.Кассир.Пустая() Тогда
		Форма.Элементы.ОтметкаКассы.Заголовок = "Установить отм.кассы";
		Если РольДоступна("Кассир") И НачалоДня(Форма.Объект.Дата) <> НачалоДня(ТекущаяДата()) 
			И ТипЗнч(Форма.Объект.Ссылка) <> Тип("ДокументСсылка.ЗаказКлиента") Тогда 
			ДопМодуль.УстановитьДоступностьФормыПоОтметкеКассы(Форма);
		КонецЕсли;
	Иначе
		Форма.Элементы.ОтметкаКассы.Заголовок = "Снять отм.кассы";
		ДопМодуль.УстановитьДоступностьФормыПоОтметкеКассы(Форма);
	Конецесли;
	
	Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда	
		Форма.Элементы.ОтмКассы.Видимость = ЗначениеЗаполнено(Форма.Объект.Кассир);
	КонецЕсли;
	Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		//Задача № 212178 скроем и посмотрим будет на нее запрос или нет,
		Форма.Элементы.ОтметкаКассы.Видимость = РольДоступна("ПолныеПрава");
	Иначе	
		Форма.Элементы.ОтметкаКассы.Видимость = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ОтметкаКассы");
	КонецЕсли	
	
КонецПроцедуры

Процедура УстановитьДоступностьФормыПоОтметкеКассы(Форма) Экспорт
	
	// Составим список элементов, доступность которых менять не требуется
	СписокИсключенияЭлементов = Новый СписокЗначений;
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ОтметкаКассы);    
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ФормаЗаписать);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ФормаПровестиИЗакрыть);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ПодменюЗаполнить);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ПодменюОтчеты);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ПодменюЭДО);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ПодменюСоздатьНаОсновании);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ПодменюПечать);
	СписокИсключенияЭлементов.Добавить(Форма.Элементы.ФормаОбщаяКомандаИсторияИзменений);
	
	ЭлементыФормы = Новый Массив;
	Если ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда	
		ЭлементыФормы.Добавить("Форма_ВводНаОснованииЗаявкаВЕГАИСЛес");
		ЭлементыФормы.Добавить("Форма_ВодНаОсновании_ЛистСогласования");
		ЭлементыФормы.Добавить("УправлениеПрисоединеннымиФайламиОткрытьСписок0");
		ЭлементыФормы.Добавить("ТоварыКонтекстноеМенюКопироватьВБуферОбмена");
		ЭлементыФормы.Добавить("КонтекстноеМенюТоварыОткрытьИнформациюОСкидках");
	ИначеЕсли ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда	 
		ЭлементыФормы.Добавить("Форма_ВВодНаОсновании_ЛистСогласования");
		ЭлементыФормы.Добавить("Форма_ВводНаОснованииЗаказНаДоставкуНДСБезНДС");
	ИначеЕсли ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ЭлементыФормы.Добавить("Форма_ВводНаОснованииЗаказНаДоставкуОтПоставщика");
		ЭлементыФормы.Добавить("Форма_ВводНаОснованииУстановкаЦенНоменклатуры");
	ИначеЕсли ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.КорректировкаРеализации") ИЛИ ТипЗнч(Форма.Объект.Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		ЭлементыФормы.Добавить("ФормаДокументЛистСогласованияСоздатьНаОсновании");
	КонецЕсли;
	Для Каждого Элемент Из ЭлементыФормы Цикл
		Если Форма.Элементы.Найти(Элемент) <> Неопределено Тогда
			СписокИсключенияЭлементов.Добавить(Форма.Элементы.Найти(Элемент));
		КонецЕсли; 
	КонецЦикла;
	
	// Составим список типов элементов, доступность которых менять не требуется
	СписокИсключенияТипов = Новый СписокЗначений;
	СписокИсключенияТипов.Добавить(Тип("ДекорацияФормы"));
	СписокИсключенияТипов.Добавить(Тип("ГруппаФормы"));
	
	// Для всех элементов формы установим их доступность
	Для Каждого ТекЭлемент Из Форма.Элементы Цикл  
		
		// Определим элемент и его тип
		ТипЭлемента = ТипЗнч(ТекЭлемент);
		
		// Уберем доступность всех элементов формы, кроме списка исключений
		Если СписокИсключенияТипов.НайтиПоЗначению(ТипЭлемента) = Неопределено Тогда
			Если СписокИсключенияЭлементов.НайтиПоЗначению(ТекЭлемент) = Неопределено Тогда
				Попытка
					ТекЭлемент.ТолькоПросмотр = Истина;
				Исключение
					ТекЭлемент.Доступность = Ложь;
				КонецПопытки;    
			КонецЕсли;     
		КонецЕсли;
		
	КонецЦикла;
	
	Форма.Элементы.ОтметкаКассы.Видимость = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ОтметкаКассы") ИЛИ РольДоступна("Кассир");
	
КонецПроцедуры

Процедура ЗаполнитьВидЦеныПоСоглашению(Объект) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.НомерСтроки КАК НомерСтроки,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.ВидЦены КАК ВидЦены
		|ПОМЕСТИТЬ ВР_Док
		|ИЗ
		|	&Товары КАК Товары	
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Док.НомерСтроки КАК НомерСтроки,
		|	Док.Номенклатура КАК Номенклатура,
		|	Док.Номенклатура.ЦеноваяГруппа КАК Номенклатура_ЦеноваяГруппа,
		|	Док.Характеристика КАК Характеристика,
		|	Док.ВидЦены = ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка) КАК ПроизвольныйВидЦен,
		|	Док.ВидЦены.Родитель.Наименование = ""Архив"" КАК СтарыйВидЦен
		|ПОМЕСТИТЬ ВТСтроки
		|ИЗ
		|	ВР_Док КАК Док
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВЫБОР
		|			КОГДА НЕ Строки.ПроизвольныйВидЦен
		|					И Строки.СтарыйВидЦен
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК КоличествоСтарыеВидыЦен,
		|	СУММА(ВЫБОР
		|			КОГДА НЕ Строки.ПроизвольныйВидЦен
		|					И НЕ Строки.СтарыйВидЦен
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК КоличествоНовыеВидыЦен
		|ПОМЕСТИТЬ ВТКоличествоСтрокПоВидамЦен
		|ИЗ
		|	ВТСтроки КАК Строки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатуры.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатуры.Характеристика КАК Характеристика,
		|	ЦеныНоменклатуры.ВидЦены КАК ВидЦены,
		|	ЦеныНоменклатуры.Цена КАК Цена
		|ПОМЕСТИТЬ ВТЦеныНоменклатуры
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			&Дата,
		|			(Номенклатура, Характеристика) В
		|				(ВЫБРАТЬ
		|					ВТСтроки.Номенклатура,
		|					ВТСтроки.Характеристика
		|				ИЗ
		|					ВТСтроки)) КАК ЦеныНоменклатуры
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Строки.НомерСтроки КАК НомерСтроки,
		|	Строки.Номенклатура КАК Номенклатура,
		|	Строки.Характеристика КАК Характеристика,
		|	Строки.ПроизвольныйВидЦен КАК ПроизвольныйВидЦен,
		|	Строки.СтарыйВидЦен КАК СтарыйВидЦен,
		|	ЕСТЬNULL(УточнениеЦеновыеГруппы.ВидЦен, &ВидЦен) КАК ВидЦеныПоСоглашению,
		|	ЕСТЬNULL(УточнениеЦеновыеГруппы.ГруппаВидовЦен, &ГруппаВидовЦен) КАК ГруппаВидовЦенПоСоглашению,
		|	ВЫБОР
		|		КОГДА НЕ УточнениеЦеновыеГруппы.ВидЦен ЕСТЬ NULL
		|			ТОГДА ""По ценовым группам""
		|	КОНЕЦ КАК ВидУточнения_ВидЦен,
		|	ВЫБОР
		|		КОГДА НЕ УточнениеЦеновыеГруппы.ГруппаВидовЦен ЕСТЬ NULL
		|			ТОГДА ""По ценовым группам""
		|	КОНЕЦ КАК ВидУточнения_ГруппаВидовЦен
		|ПОМЕСТИТЬ ВР_ЦеновыеГруппы
		|ИЗ
		|	ВТСтроки КАК Строки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК УточнениеЦеновыеГруппы
		|		ПО (&Соглашение = УточнениеЦеновыеГруппы.Ссылка)
		|			И Строки.Номенклатура.ЦеноваяГруппа = УточнениеЦеновыеГруппы.ЦеноваяГруппа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_ЦеновыеГруппы.НомерСтроки КАК НомерСтроки,
		|	ВР_ЦеновыеГруппы.Номенклатура КАК Номенклатура,
		|	ВР_ЦеновыеГруппы.Характеристика КАК Характеристика,
		|	ВР_ЦеновыеГруппы.ПроизвольныйВидЦен КАК ПроизвольныйВидЦен,
		|	ВР_ЦеновыеГруппы.СтарыйВидЦен КАК СтарыйВидЦен,
		|	ЕСТЬNULL(УточнениеТовары.ВидЦены, ВР_ЦеновыеГруппы.ВидЦеныПоСоглашению) КАК ВидЦеныПоСоглашению,
		|	ЕСТЬNULL(УточнениеТовары.ГруппаВидовЦен, ВР_ЦеновыеГруппы.ГруппаВидовЦенПоСоглашению) КАК ГруппаВидовЦенПоСоглашению,
		|	ВЫБОР
		|		КОГДА НЕ УточнениеТовары.ВидЦены ЕСТЬ NULL
		|			ТОГДА ""Уточнение по товарам""
		|		ИНАЧЕ ВР_ЦеновыеГруппы.ВидУточнения_ВидЦен
		|	КОНЕЦ КАК ВидУточнения_ВидЦен,
		|	ВЫБОР
		|		КОГДА НЕ УточнениеТовары.ГруппаВидовЦен ЕСТЬ NULL
		|			ТОГДА ""Уточнение по товарам""
		|		ИНАЧЕ ВР_ЦеновыеГруппы.ВидУточнения_ГруппаВидовЦен
		|	КОНЕЦ КАК ВидУточнения_ГруппаВидовЦен
		|ПОМЕСТИТЬ ВР_Уточнения
		|ИЗ
		|	ВР_ЦеновыеГруппы КАК ВР_ЦеновыеГруппы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК УточнениеТовары
		|		ПО ВР_ЦеновыеГруппы.Номенклатура = УточнениеТовары.Номенклатура
		|			И ВР_ЦеновыеГруппы.Характеристика = УточнениеТовары.Характеристика
		|			И (&Соглашение = УточнениеТовары.Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Уточнения.НомерСтроки КАК НомерСтроки,
		|	Уточнения.Номенклатура КАК Номенклатура,
		|	Уточнения.Характеристика КАК Характеристика,
		|	Уточнения.ВидЦеныПоСоглашению КАК ВидЦеныПоСоглашению,
		|	Уточнения.ГруппаВидовЦенПоСоглашению КАК ГруппаВидовЦенПоСоглашению,
		|	Уточнения.ВидУточнения_ВидЦен КАК ВидУточнения_ВидЦен,
		|	Уточнения.ВидУточнения_ГруппаВидовЦен КАК ВидУточнения_ГруппаВидовЦен,
		|	Уточнения.ПроизвольныйВидЦен КАК ПроизвольныйВидЦен,
		|	Уточнения.СтарыйВидЦен КАК СтарыйВидЦен,
		|	КоличествоСтрокПоВидамЦен.КоличествоНовыеВидыЦен = 0 КАК ИспользуютсяТолькоСтарыеЦены,
		|	КоличествоСтрокПоВидамЦен.КоличествоНовыеВидыЦен = 0
		|		ИЛИ КоличествоСтрокПоВидамЦен.КоличествоСтарыеВидыЦен = 0 КАК ИспользуетсяТолькоОдинВидЦен,
		|	КоличествоСтрокПоВидамЦен.КоличествоНовыеВидыЦен = 0
		|		И КоличествоСтрокПоВидамЦен.КоличествоСтарыеВидыЦен = 0 КАК ИспользуютсяТолькоПроизвольныеВидыЦен
		|ПОМЕСТИТЬ ВР_УточненияИтог
		|ИЗ
		|	ВР_Уточнения КАК Уточнения
		|		ПОЛНОЕ СОЕДИНЕНИЕ ВТКоличествоСтрокПоВидамЦен КАК КоличествоСтрокПоВидамЦен
		|		ПО (ИСТИНА)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Уточнения.НомерСтроки КАК НомерСтроки,
		|	Уточнения.Номенклатура КАК Номенклатура,
		|	Уточнения.Характеристика КАК Характеристика,
		|	Уточнения.ВидЦеныПоСоглашению КАК ВидЦеныПоСоглашению_ВидЦен,
		|	ВидыЦен.Ссылка КАК ВидЦеныПоСоглашению_ГруппаВидовЦен,
		|	Уточнения.ВидУточнения_ВидЦен КАК ВидУточнения_ВидЦен,
		|	Уточнения.ВидУточнения_ГруппаВидовЦен КАК ВидУточнения_ГруппаВидовЦен,
		|	ВЫБОР
		|		КОГДА Уточнения.ИспользуютсяТолькоПроизвольныеВидыЦен
		|				ИЛИ НЕ Уточнения.ИспользуетсяТолькоОдинВидЦен
		|			ТОГДА ВЫБОР
		|					КОГДА Уточнения.ПроизвольныйВидЦен
		|						ТОГДА ВЫБОР
		|								КОГДА &ДатаДокументаМеньше_28_03_2023
		|									ТОГДА ИСТИНА
		|								ИНАЧЕ ЛОЖЬ
		|							КОНЕЦ
		|					ИНАЧЕ ВЫБОР
		|							КОГДА Уточнения.СтарыйВидЦен
		|								ТОГДА ИСТИНА
		|							ИНАЧЕ ЛОЖЬ
		|						КОНЕЦ
		|				КОНЕЦ
		|		ИНАЧЕ ВЫБОР
		|				КОГДА Уточнения.ИспользуютсяТолькоСтарыеЦены
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ
		|	КОНЕЦ КАК ИспользоватьСтарыйВидЦен
		|ПОМЕСТИТЬ ВТСтрокиИтог
		|ИЗ
		|	ВР_УточненияИтог КАК Уточнения
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|		ПО (ВидыЦен.РегионПрисутствия = &РегионПрисутствия)
		|			И (ВидыЦен.ФорматПодразделения = &ФорматПодразделения)
		|			И (ВидыЦен.ГруппаВидовЦен = Уточнения.ГруппаВидовЦенПоСоглашению)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Строки.НомерСтроки КАК НомерСтроки,
		|	Строки.Номенклатура КАК Номенклатура,
		|	Строки.Характеристика КАК Характеристика,
		|	ВЫБОР
		|		КОГДА Строки.ИспользоватьСтарыйВидЦен
		|			ТОГДА Строки.ВидЦеныПоСоглашению_ВидЦен
		|		ИНАЧЕ Строки.ВидЦеныПоСоглашению_ГруппаВидовЦен
		|	КОНЕЦ КАК ВидЦеныПоСоглашению,
		|	ВЫБОР
		|		КОГДА Строки.ИспользоватьСтарыйВидЦен
		|			ТОГДА Строки.ВидУточнения_ВидЦен
		|		ИНАЧЕ Строки.ВидУточнения_ГруппаВидовЦен
		|	КОНЕЦ КАК ВидУточнения,
		|	ВЫБОР
		|		КОГДА Строки.ИспользоватьСтарыйВидЦен
		|			ТОГДА ЦенаПоСоглашению_ВидЦен.Цена
		|		ИНАЧЕ ЦенаПоСоглашению_ГруппаВидовЦен.Цена
		|	КОНЕЦ КАК ЦенаПоСоглашению
		|ИЗ
		|	ВТСтрокиИтог КАК Строки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦеныНоменклатуры КАК ЦенаПоСоглашению_ВидЦен
		|		ПО (Строки.Номенклатура = ЦенаПоСоглашению_ВидЦен.Номенклатура)
		|			И (Строки.Характеристика = ЦенаПоСоглашению_ВидЦен.Характеристика)
		|			И (Строки.ВидЦеныПоСоглашению_ВидЦен = ЦенаПоСоглашению_ВидЦен.ВидЦены)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦеныНоменклатуры КАК ЦенаПоСоглашению_ГруппаВидовЦен
		|		ПО (Строки.Номенклатура = ЦенаПоСоглашению_ГруппаВидовЦен.Номенклатура)
		|			И (Строки.Характеристика = ЦенаПоСоглашению_ГруппаВидовЦен.Характеристика)
		|			И (Строки.ВидЦеныПоСоглашению_ГруппаВидовЦен = ЦенаПоСоглашению_ГруппаВидовЦен.ВидЦены)
		|
		|СГРУППИРОВАТЬ ПО
		|	Строки.НомерСтроки,
		|	Строки.Номенклатура,
		|	Строки.Характеристика,
		|	ВЫБОР
		|		КОГДА Строки.ИспользоватьСтарыйВидЦен
		|			ТОГДА Строки.ВидЦеныПоСоглашению_ВидЦен
		|		ИНАЧЕ Строки.ВидЦеныПоСоглашению_ГруппаВидовЦен
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА Строки.ИспользоватьСтарыйВидЦен
		|			ТОГДА Строки.ВидУточнения_ВидЦен
		|		ИНАЧЕ Строки.ВидУточнения_ГруппаВидовЦен
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА Строки.ИспользоватьСтарыйВидЦен
		|			ТОГДА ЦенаПоСоглашению_ВидЦен.Цена
		|		ИНАЧЕ ЦенаПоСоглашению_ГруппаВидовЦен.Цена
		|	КОНЕЦ";               
	
	Дата = ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДата());
		                                  
	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("ДатаДокументаМеньше_28_03_2023", Дата < Дата(2023, 3, 28));
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить( , "НомерСтроки, Номенклатура, Характеристика, ВидЦены"));
	
	Запрос.УстановитьПараметр("Соглашение", Объект.Соглашение);    	
	Запрос.УстановитьПараметр("ВидЦен", Объект.Соглашение.ВидЦен);
	Запрос.УстановитьПараметр("ГруппаВидовЦен", Объект.Соглашение.ГруппаВидовЦен);  
	
	Запрос.УстановитьПараметр("РегионПрисутствия", Объект.Склад.Подразделение.РегионПрисутствия);
	Запрос.УстановитьПараметр("ФорматПодразделения", Объект.Склад.Подразделение.ФорматПодразделения);
	
	ТаблицаСоглашения = Запрос.Выполнить().Выгрузить();
	Для Каждого стр Из Объект.Товары Цикл
		Строки = ТаблицаСоглашения.НайтиСтроки(
			Новый Структура("НомерСтроки, Номенклатура, Характеристика", стр.НомерСтроки, стр.Номенклатура, стр.Характеристика));
			
		Если ЗначениеЗаполнено(Строки) тогда
			ЗаполнитьЗначенияСвойств(стр, Строки[0], "ВидЦеныПоСоглашению, ВидУточнения, ЦенаПоСоглашению");	
		КонецЕсли
	КонецЦикла;	
	
КонецПроцедуры

Процедура ЗаписатьЛог(ТекстСобытия,Примечание) Экспорт
	
	ПользовательДляПроверки = ПолучитьНастройкиХранилища("ВключитьДопПроверкиПоКассовымСменам").КассирДляЛогирования;
	
	Если ПользовательДляПроверки.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не (Пользователи.ТекущийПользователь() = ПользовательДляПроверки) Тогда
		Возврат;
	КонецЕсли;
	
	ПолныйПутьКФайлу = "\\TG-Storage01\Alterra - общая\Харина М.А\лог\log";
	Если ПолныйПутьКФайлу <> "" Тогда
		ВремяЗаписи = ТекущаяДата();
		
		СтрокаЗаписи = "[" + Формат(ВремяЗаписи, "ДФ='yyyy/MM/dd HH:mm:ss'") + "]" + Символы.ПС 
		+ "[" + Строка(ТекстСобытия) + "]" + "[Прим: " + Строка(Примечание) + "]"+ Символы.ПС;		
		
		Попытка
			ФайлЛогов = Новый ЗаписьТекста(ПолныйПутьКФайлу, КодировкаТекста.UTF8,,Истина);
			ФайлЛогов.ЗаписатьСтроку(СтрокаЗаписи);
			ФайлЛогов.Закрыть();
		Исключение
			ЗаписьЖурналаРегистрации("ЗаписьВЛог", УровеньЖурналаРегистрации.Ошибка, ТекстСобытия,"Ошибка записи в лог", ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

Процедура ИнформированиеВБитриксОПоступленииНаСкладМОЛТМЦ(Ссылка, Товары, Склад, АвторДокумента) Экспорт
	
	Если АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "УведомлятьВБитриксОПоступлениях") Тогда
		
		ТекущийОтветственный = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "Подотчетник");
		Если Не ЗначениеЗаполнено(ТекущийОтветственный) Тогда
			ТекущийОтветственный = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Склад, "ТекущийОтветственный");			
		КонецЕсли;	
		Если ЗначениеЗаполнено(ТекущийОтветственный) Тогда
			
			ТекстСообщения = "На склад '" + Склад + "' поступили ТМЦ по документу '" + Ссылка + "'. Автор документа: " + АвторДокумента + Символы.ПС;
			Для Каждого Строка Из Товары Цикл 
				ТекстСообщения = ТекстСообщения + Символы.ПС + "№" + Строка.НомерСтроки + " '" + Строка.Номенклатура + "'  Количество: " + Строка.КоличествоУпаковок + " " + Строка.Упаковка;
			КонецЦикла;                                          
			
			Результат = АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения, ТекущийОтветственный);
			Если Результат <> Неопределено Тогда 
				ЗаписьЖурналаРегистрации("Информирование в Битрикс о поступлении на склад МОЛ ТМЦ", УровеньЖурналаРегистрации.Информация,,, ТекстСообщения);
			Иначе
				ОбщегоНазначения.СообщитьПользователю("Не получилось отправить данные в Битрикс!");
			КонецЕсли;
		Иначе
			ОбщегоНазначения.СообщитьПользователю("Не получилось отправить данные в Битрикс! Для склада '" + Склад + "' не указан ответственный!");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры                                     

Функция ЕстьСвойствоОбъекта(Объект, ИмяСвойстваОбъекта) Экспорт

   ЕстьСвойство = Ложь;
   СтруктураОбъекта = Новый Структура(ИмяСвойстваОбъекта, Неопределено);
   ЗаполнитьЗначенияСвойств(СтруктураОбъекта, Объект);

   Если СтруктураОбъекта[ИмяСвойстваОбъекта] = Неопределено Тогда
       СтруктураОбъекта[ИмяСвойстваОбъекта] = Ложь;
       ЗаполнитьЗначенияСвойств(СтруктураОбъекта, Объект);
       Если СтруктураОбъекта[ИмяСвойстваОбъекта] <> Ложь Тогда
           ЕстьСвойство = Истина;
       КонецЕсли;
   Иначе
       ЕстьСвойство = Истина;
   КонецЕсли;

   Возврат ЕстьСвойство;// Булево

КонецФункции

#Область ЛогированиеОтчетов
Процедура ЗаписатьЛогиДляОтчета(Отчет, КомпоновщикНастроек) Экспорт	
	
	Комментарий = "";
	ТекДата = ТекущаяДата();     
	ИзвлечьПараметры(КомпоновщикНастроек.ПользовательскиеНастройки.Элементы, КомпоновщикНастроек.Настройки.Отбор.Элементы, Комментарий);                    
	
	Комментарий =                           
	Символы.ПС + "Отчет: " + Отчет +
	Символы.ПС + "Дата: " + ТекДата +
	Символы.ПС + "Пользователь: " + ПользователиКлиентСервер.ТекущийПользователь() +
	Символы.ПС + "Параметры: " + ?(ЗначениеЗаполнено(Комментарий), Комментарий, "(Параметры не заданы)"); 
	
	ЗаписатьЛоги("\\1C-alterra\C$\Bitrix\Log\" + Формат(НачалоНедели(ТекДата), "DF=dd-MM-yyyy") + "_Параметры_отчетов.txt", Ложь, Комментарий);  
КонецПроцедуры

Процедура ИзвлечьПараметры(Параметры, ПараметрыОтбора, Комментарий)	
	Если ЗначениеЗаполнено(Параметры) Тогда
		Для Каждого Параметр Из Параметры Цикл
			Если ТипЗнч(Параметр) = Тип("ЗначениеПараметраНастроекКомпоновкиДанных") Тогда 
				Если Параметр.Использование Тогда
					Комментарий = Комментарий + Символы.ПС + Параметр.Параметр + ": " + ОбработкаЗначений(Параметр.Значение);
				КонецЕсли;
			ИначеЕсли ТипЗнч(Параметр) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Если Параметр.Использование Тогда                                              
					Попытка
						Комментарий = Комментарий + Символы.ПС + Параметр.ЛевоеЗначение + " " + Параметр.ВидСравнения + " " + ОбработкаЗначений(Параметр.ПравоеЗначение);
					Исключение     
						Если ЗначениеЗаполнено(ПараметрыОтбора) Тогда
							Для Каждого ПараметрОтбора Из ПараметрыОтбора Цикл
								Если ПараметрОтбора.ИдентификаторПользовательскойНастройки = Параметр.ИдентификаторПользовательскойНастройки Тогда  
									Комментарий = Комментарий + Символы.ПС + ПараметрОтбора.ЛевоеЗначение + " " + Параметр.ВидСравнения + " " + ОбработкаЗначений(Параметр.ПравоеЗначение);
								КонецЕсли;	
							КонецЦикла;
						КонецЕсли;
					КонецПопытки; 
				КонецЕсли;    
			ИначеЕсли ТипЗнч(Параметр) = Тип("ОтборКомпоновкиДанных") Тогда
				ИзвлечьПараметры(Параметр.Элементы, ПараметрыОтбора, Комментарий);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;                    
КонецПроцедуры

Функция ОбработкаЗначений(Значение)	
	Комментарий = "";
	
	Если ТипЗнч(Значение) = Тип("СписокЗначений") Тогда
		Для Каждого ЭлементСпискаЗначений Из Значение Цикл
			Если ЗначениеЗаполнено(Комментарий) Тогда      
				Комментарий = Комментарий + ", '" + ЭлементСпискаЗначений.Значение + "'";
			Иначе                                                                        
				Комментарий = "'" + ЭлементСпискаЗначений.Значение + "'";
			КонецЕсли; 
		КонецЦикла;
	Иначе
		Комментарий = Комментарий + "'" + Значение + "'";
	КонецЕсли;           
	
	Возврат Комментарий;
КонецФункции

Процедура ЗаписатьЛоги(ПолныйПутьКФайлу, СтираемСтарыеЛоги, Сообщение) Экспорт	
	Попытка                 		   
		ФайлЛогов = Новый ЗаписьТекста(ПолныйПутьКФайлу, КодировкаТекста.UTF8, , Не СтираемСтарыеЛоги);
		ФайлЛогов.ЗаписатьСтроку(Сообщение);
		ФайлЛогов.Закрыть();
	Исключение
		ЗаписьЖурналаРегистрации("ЗаписатьЛоги", УровеньЖурналаРегистрации.Ошибка, ,"Ошибка записи в лог", ОписаниеОшибки());
	КонецПопытки;
КонецПроцедуры 

