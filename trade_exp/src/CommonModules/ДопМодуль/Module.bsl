Функция ПолучитьНормуРасхода(Объект) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НормыРасходаГСМСрезПоследних.БазоваяНорма
	|ИЗ
	|	РегистрСведений.НормыРасходаГСМ.СрезПоследних(
	|			&Период,
	|			Топливо = &Топливо
	|				И транспортноеСредство = &ТранспортноеСредство) КАК НормыРасходаГСМСрезПоследних";
	
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("Топливо", Объект.Топливо);
	Запрос.УстановитьПараметр("ТранспортноеСредство", Объект.ТранспортноеСредство);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.Количество() = 1 Тогда
		Норма = Выборка.БазоваяНорма;
	Иначе
		Норма = 0;
	КонецЕсли;
	Норма=Норма*?(Объект.ТранспортноеСредство.СпидометрСчетчик=1,КоэффициентЗимы(Объект.Дата),1);
	
	Возврат Норма;
КонецФункции

Функция КоэффициентЗимы(ДатаЛиста)
	коэффициент=1;
	ТекДата=?(ЗначениеЗаполнено(ДатаЛиста),ДатаЛиста,ТекущаяДата());
	если не значениеЗаполнено(Константы.ЗимнийПериодНачало.Получить()) и не значениеЗаполнено(Константы.ЗимнийПериодОкончание.Получить()) тогда
		возврат коэффициент;
	конецесли;
	ДатаН=Константы.ЗимнийПериодНачало.Получить();
	ДатаНачала=Дата(СТРЗАМЕНИТЬ(ГОД(ТекДата),Символы.НПП,"")+ПРАВ(ДатаН,2)+ЛЕВ(ДатаН,2));
	ДатаН=Константы.ЗимнийПериодОкончание.Получить();
	ДатаОкончания=Дата(СТРЗАМЕНИТЬ(ГОД(ТекДата),Символы.НПП,"")+ПРАВ(ДатаН,2)+ЛЕВ(ДатаН,2));
	если ТекДата<ДатаНачала и ТекДата>=ДатаОкончания тогда
		возврат коэффициент;
	иначе
		возврат коэффициент+Константы.ПредельнаяВеличинаЗимнихНадбавок.Получить()/100;
	конецесли;
КонецФункции

