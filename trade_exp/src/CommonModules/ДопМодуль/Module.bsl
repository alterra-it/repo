//Начисление и списание ББ   

Функция СуммаПревышаетДопустимую(Объект,Сумма = Неопределено, ВходящиеДанные = Неопределено)Экспорт
	
	Сообщение = "";	
	Если Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание  Тогда
		Возврат Сообщение;
    КонецЕсли;
	
	Если Сумма = Неопределено Тогда
		Если Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление Тогда 
			Сумма = Объект.Начисление.Итог("Баллы"); 
		КонецЕсли;
	КонецЕсли;
	
	ДопустимаяСуммаУтвержденияББ = ПолучитьКонстанту_ДопустимаяСуммаУтвержденияББ();
	ДопустимаяСуммаУтвержденияББОбменВТЗ = ПолучитьКонстанту_ДопустимаяСуммаУтвержденияББОбменВТЗ(); 

	Если Объект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Обмен в ТЗ (по БП)") И Сумма > ДопустимаяСуммаУтвержденияББОбменВТЗ Тогда   
		
		Сообщение = "Для начислений по причине ""Обмен в ТЗ (по БП)"" сумма не должна превышать " + ДопустимаяСуммаУтвержденияББОбменВТЗ + " бб. ";       
		
	ИначеЕсли  Сумма >= ДопустимаяСуммаУтвержденияББ Тогда  
		
		Если ВходящиеДанные = Неопределено Тогда
			МассивУтверждающих = Новый Массив(); 
			МассивУтверждающих.Добавить(Объект.Утверждающий1);
			МассивУтверждающих.Добавить(Объект.Утверждающий2);
		Иначе
			МассивУтверждающих = ПолучитьМассивУтверждающихПоВходящимДанным(ВходящиеДанные);			
		КонецЕсли; 
		
		Если НЕ ЕстьДопУтверждающий(МассивУтверждающих)  Тогда
			Сообщение = "При сумме " + ДопустимаяСуммаУтвержденияББ +  " бб. и более нужно выбрать Утверждающего с правом доп. согласования ББ ";   
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Сообщение;
	
КонецФункции

Функция ПолучитьМассивУтверждающих(ДопУтверждение) Экспорт 
	
	Запрос = Новый Запрос;
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сотрудники.Ссылка КАК Сотрудник
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|   Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.Уволен = ЛОЖЬ
	|   И Условие";
	
	Если ДопУтверждение Тогда 
		Условие = "Сотрудники.ДопУтверждениеББ = ИСТИНА";
	Иначе
		Условие = "Сотрудники.Должность.УтверждениеББ = ИСТИНА";
	КонецЕсли;  
	
	Запрос.Текст = СтрЗаменить(ТекстЗапроса,"Условие",Условие);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	МассивУтверждающих = Новый Массив;
	
	Пока Выборка.Следующий() Цикл	
		МассивУтверждающих.Добавить(Выборка.Сотрудник);	
	КонецЦикла;
	
	Возврат  МассивУтверждающих;
	
КонецФункции

Функция ЕстьДопУтверждающий(МассивУтверждающих) Экспорт
	
	ДопУтверждение = Истина;
	МассивДопУтверждающих = ПолучитьМассивУтверждающих(ДопУтверждение); 
	
	Для Каждого Утв из МассивУтверждающих Цикл
		Если МассивДопУтверждающих.Найти(Утв) <> Неопределено  Тогда   
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;  
	
КонецФункции

Функция ПолучитьМассивУтверждающихПоВходящимДанным(ВходящиеДанные)
	
	МассивУтверждающих = Новый Массив;
	
	Для Ин = 1 По 2 Цикл 
		
		ИмяРеквизита = "Утверждающий" + Ин;
		
		Если ЗначениеЗаполнено(ВходящиеДанные[ИмяРеквизита]) Тогда   
			
			Пользователь = АльтерраВзаимодействиеСБитрикс24.ПолучитьПользователяПоИд(ВходящиеДанные[ИмяРеквизита]);  
			
			Если ЗначениеЗаполнено(Пользователь) Тогда    
				
				УтверждающийСотрудник = АльтерраОбщегоНазначения.ПолучитьСотрудника(Пользователь);
				
				Если ЗначениеЗаполнено(УтверждающийСотрудник) Тогда
					МассивУтверждающих.Добавить(УтверждающийСотрудник); 
				КонецЕсли; 
				
			КонецЕсли;     
			
		КонецЕсли;
		
	КонецЦикла; 
	Возврат  МассивУтверждающих;    
	
КонецФункции

Функция ПолучитьКонстанту_ДопустимаяСуммаУтвержденияББ()Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);
	Константа = Константы.ДопустимаяСуммаУтвержденияББ.Получить();
	УстановитьПривилегированныйРежим(Ложь); 
	
	Возврат Константа;
	
КонецФункции

Функция ПолучитьКонстанту_ДопустимаяСуммаУтвержденияББОбменВТЗ() Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);
	Константа = Константы.ДопустимаяСуммаУтвержденияББОбменВТЗ.Получить(); 
	УстановитьПривилегированныйРежим(Ложь); 
	
	Возврат Константа;
	
КонецФункции 

Функция НужноСогласованиеАналитиков(Причина) Экспорт
	
	Если Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Доначисление (по бп)") 
		ИЛИ Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Неверный ценник (по бп)") 
		ИЛИ Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Прочее (по бп)") Тогда
		Возврат  Истина;
	Иначе
		Возврат Ложь;     
	КонецЕсли; 
	
КонецФункции

Функция ЕстьМаркируемыеТовары(Товары) Экспорт 
	
	МассивИсключений = Новый Массив; 
	ОсобенностиУчетаПеречисление = Перечисления.ОсобенностиУчетаНоменклатуры;
	МассивИсключений.Добавить(ОсобенностиУчетаПеречисление.ПустаяСсылка());
	МассивИсключений.Добавить(ОсобенностиУчетаПеречисление.БезОсобенностейУчета);
    МассивИсключений.Добавить(ОсобенностиУчетаПеречисление.Партнером); 
	МассивИсключений.Добавить(ОсобенностиУчетаПеречисление.ОрганизациейПоАгентскойСхеме); 
    МассивИсключений.Добавить(ОсобенностиУчетаПеречисление.ОрганизациейПродавцом); 

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ Товары1
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары1.Номенклатура КАК Номенклатура
	|ИЗ
	|	Товары1 КАК Товары1
	|ГДЕ
	|  НЕ Товары1.Номенклатура.ОсобенностьУчета В(&ОсобенностиУчетаИсключение)";
	
	Запрос.УстановитьПараметр("Товары", Товары.Выгрузить());
	Запрос.УстановитьПараметр("ОсобенностиУчетаИсключение", МассивИсключений);
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	Возврат Ложь;
	
КонецФункции

Функция ОпределитьСклад(Документ) экспорт
	МетаданныеДокумента=Документ.Метаданные();
	если ОбщегоНазначения.ЕстьРеквизитОбъекта("Склад",МетаданныеДокумента) тогда
		возврат Документ.Склад;
	конецесли;	
	возврат НЕОПРЕДЕЛЕНО;
КонецФункции	

