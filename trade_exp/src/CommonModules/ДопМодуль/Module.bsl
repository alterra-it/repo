Функция ВозвратитьТаблицу(Значениепараметра,Контекст) экспорт
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	если типзнч(ЗначениеПараметра)=тип("ДокументТабличнаяЧасть.РеализацияТоваровУслуг.Товары") тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Реализация.Ссылка КАК Ссылка,
		|	Реализация.НомерСтроки КАК НомерСтроки,
		|	Реализация.Номенклатура КАК Номенклатура,
		|	Реализация.Характеристика КАК Характеристика,
		|	Реализация.Назначение КАК Назначение,
		|	Реализация.Упаковка КАК Упаковка,
		|	Реализация.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Реализация.Количество КАК Количество,
		|	Реализация.ВидЦены КАК ВидЦены,
		|	ВЫРАЗИТЬ(ВЫБОР
		|			КОГДА Реализация.Количество <> 0
		|					И Реализация.Ссылка.РаспределитьТранспортные
		|				ТОГДА (Реализация.Сумма + Реализация.СуммаРТ) / Реализация.Количество
		|			ИНАЧЕ Реализация.Цена
		|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК Цена,
		|	Реализация.Сумма + Реализация.СуммаРТ КАК Сумма,
		|	Реализация.СтавкаНДС КАК СтавкаНДС,
		|	Реализация.СуммаНДС + Реализация.СуммаНДСРТ КАК СуммаНДС,
		|	Реализация.СуммаСНДС + Реализация.СуммаСНДСРТ КАК СуммаСНДС,
		|	Реализация.КодСтроки КАК КодСтроки,
		|	Реализация.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	Реализация.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
		|	Реализация.ПроцентРучнойСкидки КАК ПроцентРучнойСкидки,
		|	Реализация.ПроцентАвтоматическойСкидки КАК ПроцентАвтоматическойСкидки,
		|	Реализация.КлючСвязи КАК КлючСвязи,
		|	Реализация.Склад КАК Склад,
		|	Реализация.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	Реализация.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
		|	Реализация.ЗаказКлиента КАК ЗаказКлиента,
		|	Реализация.СрокПоставки КАК СрокПоставки,
		|	Реализация.Распределять КАК Распределять,
		|	Реализация.Кладовщик КАК Кладовщик,
		|	Реализация.ВодительПогрузчика КАК ВодительПогрузчика,
		|	Реализация.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	Реализация.Серия КАК Серия,
		|	Реализация.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	Реализация.НоменклатураНабора КАК НоменклатураНабора,
		|	Реализация.ХарактеристикаНабора КАК ХарактеристикаНабора,
		|	Реализация.АналитикаУчетаНаборов КАК АналитикаУчетаНаборов,
		|	Реализация.СуммаНачисленныхБонусныхБалловВВалюте КАК СуммаНачисленныхБонусныхБалловВВалюте,
		|	Реализация.СуммаБонусныхБалловКСписаниюВВалюте КАК СуммаБонусныхБалловКСписаниюВВалюте,
		|	Реализация.СуммаБонусныхБалловКСписанию КАК СуммаБонусныхБалловКСписанию,
		|	Реализация.СуммаНДСРТ КАК СуммаНДСРТ,
		|	Реализация.СуммаРТ КАК СуммаРТ,
		|	Реализация.СуммаСНДСРТ КАК СуммаСНДСРТ,
		|	Реализация.КодТНВЭД КАК КодТНВЭД,
		|	Реализация.ВидЦеныПоСоглашению КАК ВидЦеныПоСоглашению,
		|	Реализация.ВидУточнения КАК ВидУточнения,
		|	Реализация.ЦенаПоСоглашению КАК ЦенаПоСоглашению
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК Реализация
		|ГДЕ
		|	Реализация.Ссылка = &Ссылка
		|	И ВЫБОР
		|			КОГДА Реализация.Ссылка.РаспределитьТранспортные
		|				ТОГДА Реализация.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
		
			Запрос.УстановитьПараметр("Ссылка", Контекст.Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();

	иначеесли типзнч(ЗначениеПараметра)=тип("ДокументТабличнаяЧасть.РеализацияТоваровУслуг.ВидыЗапасов") тогда
         
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугВидыЗапасов.Ссылка КАК Ссылка,
		|	РеализацияТоваровУслугВидыЗапасов.НомерСтроки КАК НомерСтроки,
		|	РеализацияТоваровУслугВидыЗапасов.Упаковка КАК Упаковка,
		|	РеализацияТоваровУслугВидыЗапасов.КоличествоУпаковок КАК КоличествоУпаковок,
		|	РеализацияТоваровУслугВидыЗапасов.Количество КАК Количество,
		|	РеализацияТоваровУслугВидыЗапасов.СтавкаНДС КАК СтавкаНДС,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаНДС + РеализацияТоваровУслугВидыЗапасов.СуммаНДСРТ КАК СуммаНДС,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаСНДС + РеализацияТоваровУслугВидыЗапасов.СуммаСНДСРТ КАК СуммаСНДС,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
		|	РеализацияТоваровУслугВидыЗапасов.ЗаказКлиента КАК ЗаказКлиента,
		|	РеализацияТоваровУслугВидыЗапасов.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	РеализацияТоваровУслугВидыЗапасов.АналитикаУчетаНоменклатуры КАК АналитикаУчетаНоменклатуры,
		|	РеализацияТоваровУслугВидыЗапасов.АналитикаУчетаНаборов КАК АналитикаУчетаНаборов,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаНДСРТ КАК СуммаНДСРТ,
		|	РеализацияТоваровУслугВидыЗапасов.СуммаСНДСРТ КАК СуммаСНДСРТ,
		|	РеализацияТоваровУслугВидыЗапасов.КодТНВЭД КАК КодТНВЭД,
		|	ВЫРАЗИТЬ(ВЫБОР
		|			КОГДА РеализацияТоваровУслугВидыЗапасов.Количество <> 0
		|					И РеализацияТоваровУслугВидыЗапасов.Ссылка.РаспределитьТранспортные
		|				ТОГДА (РеализацияТоваровУслугВидыЗапасов.СуммаСНДС + РеализацияТоваровУслугВидыЗапасов.СуммаСНДСРТ) / РеализацияТоваровУслугВидыЗапасов.Количество
		|			ИНАЧЕ РеализацияТоваровУслугВидыЗапасов.Цена
		|		КОНЕЦ КАК ЧИСЛО(15, 2)) КАК Цена
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.ВидыЗапасов КАК РеализацияТоваровУслугВидыЗапасов
		|ГДЕ
		|	РеализацияТоваровУслугВидыЗапасов.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Контекст.Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
иначе
	возврат Значениепараметра; 
	конецесли;

КонецФункции //

Процедура УстановитьСтатусыНаДокументы(СписокДокументов) экспорт

		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	СчетФактураВыданный.ссылка КАК ДокСФ
		|ИЗ
		|	Документ.СчетФактураВыданный КАК СчетФактураВыданный
		|ГДЕ
		|	СчетФактураВыданный.Ссылка В(&СписокДокументов)";
		
		Запрос.УстановитьПараметр("СписокДокументов", СписокДокументов);
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
			УстановитьСтатусНаДокумент(ВыборкаДетальныеЗаписи.ДокСФ);
	    конеццикла;

КонецПроцедуры

Процедура УстановитьСтатусНаДокумент(ДокСФ) экспорт
	
	если типзнч(ДокСФ)<>тип("ДокументСсылка.СчетФактураВыданный")  тогда
		возврат;
	конецесли;	                                                  
	если не значениезаполнено(ДокСФ.ДокументОснование) тогда
		возврат;
	конецесли;	
	
	Статус="Выгружен";
	попытка
		ДокументОбъект=ДокСФ.ДокументОснование.ПолучитьОбъект();
		МетаданныеОбъекта=ДокументОбъект.Метаданные();
		если Общегоназначения.ЕстьРеквизитОбъекта("СтатусДокументаВЭДО",МетаданныеОбъекта) и ДокументОбъект.СтатусДокументаВЭДО<>перечисления.СтатусыДокументаЭДО[Статус]  тогда
			ДокументОбъект.СтатусДокументаВЭДО=перечисления.СтатусыДокументаЭДО[Статус];
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
		конецесли;
	исключение 	
	конецпопытки;
	
КонецПроцедуры
 
#КонецОбласти 

//Отладка временных таблиц
Функция ПроверитьВрТаб(МенеджерВремТаб,ИмяВремтаб ="",Порядок = "") Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВремТаб;
	Запрос.Текст =
	"ВЫБРАТЬ
	| *
	|ИЗ
	| ВремТаб КАК ВремТаб
	|
	|УПОРЯДОЧИТЬ ПО Порядок";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВремТаб",ИмяВремтаб);
	Если Порядок = "" тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"УПОРЯДОЧИТЬ ПО Порядок","");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"Порядок",Порядок);
	КонецЕсли;
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	Возврат ТЗ;
	
КонецФункции

функция ДатаИзмененияВерсииОбъекта(Ссылка) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВерсииОбъектов.ДатаВерсии КАК ДатаВерсии
	|ИЗ
	|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
	|ГДЕ
	|	ВерсииОбъектов.Объект = &Объект
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаВерсии УБЫВ";
	
	Запрос.УстановитьПараметр("Объект", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		ДатаИзменения=ВыборкаДетальныеЗаписи.ДатаВерсии;
		если ДатаИзменения<ТекущаяДата()-60*60*24*90 тогда
			подсветкадаты=истина;
		иначе
			подсветкадаты=ложь;
		конецесли;
		СтруктураДаты=новый Структура("ДатаИзменения",ВыборкаДетальныеЗаписи.ДатаВерсии);
		СтруктураДаты.Вставить("Подсветка",подсветкаДаты);
	иначе
		СтруктураДаты=новый Структура("ДатаИзменения",дата('00010101'));
		СтруктураДаты.Вставить("Подсветка",истина);
	Конецесли;
	возврат СтруктураДаты;	
конецфункции	

Функция ПодстановкаГрузоотправителя(Организация,Подразделение) экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка
	|ИЗ
	|	РегистрСведений.РегистрацииВНалоговомОргане КАК РегистрацииВНалоговомОргане
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО РегистрацииВНалоговомОргане.РегистрацияВНалоговомОргане.КПП = Контрагенты.КПП
	|			И РегистрацииВНалоговомОргане.Организация.ИНН = Контрагенты.ИНН
	|ГДЕ
	|	РегистрацииВНалоговомОргане.Подразделение = &Подразделение
	|	И РегистрацииВНалоговомОргане.Организация = &Организация";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		Возврат  ВыборкаДетальныеЗаписи.Ссылка;
	иначе
		возврат "";
		
	Конецесли;
КонецФункции

Процедура ОбработкаЗаполнения(Источник, ДанныеЗаполнения, СтандартнаяОбработка) Экспорт
	
	АльтерраОбщегоНазначения.ЗаполнитьПодразделение(Источник);
	АльтерраОбщегоНазначения.ЗаполнитьМенеджераМагазин(Источник);
	
КонецПроцедуры

Процедура ПриКопированииОбъекта(Источник, ОбъектКопирования) Экспорт
	
	АльтерраОбщегоНазначения.ЗаполнитьПодразделение(Источник);
	АльтерраОбщегоНазначения.ЗаполнитьМенеджераМагазин(Источник);
	
КонецПроцедуры

// Вспомогательные
Функция ВводНаОснованииПересчета(ДокументОснования,ПараметрДвижения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПересортицаТоваровТовары.Номенклатура КАК Номенклатура,
	|	ПересортицаТоваровТовары.Характеристика КАК Характеристика,
	|	ПересортицаТоваровТовары.Назначение КАК Назначение,
	|	СУММА(ЕСТЬNULL(ПересортицаТоваровТовары.Количество, 0)) КАК КоличествоРасход,
	|	СУММА(0) КАК КоличествоПриход
	|ПОМЕСТИТЬ ВР_Таб
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПересортицаТоваров.Товары КАК ПересортицаТоваровТовары
	|		ПО (ПересчетТоваров.Ссылка = ПересортицаТоваровТовары.Ссылка.ПересчетТоваров)
	|ГДЕ
	|	ПересчетТоваров.Ссылка = &Ссылка
	|	И ПересортицаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПересортицаТоваровТовары.Номенклатура,
	|	ПересортицаТоваровТовары.Характеристика,
	|	ПересортицаТоваровТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СписаниеНедостачТоваровТовары.Номенклатура,
	|	СписаниеНедостачТоваровТовары.Характеристика,
	|	СписаниеНедостачТоваровТовары.Назначение,
	|	СУММА(ЕСТЬNULL(СписаниеНедостачТоваровТовары.Количество, 0)),
	|	СУММА(0)
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.СписаниеНедостачТоваров.Товары КАК СписаниеНедостачТоваровТовары
	|		ПО (ПересчетТоваров.Ссылка = СписаниеНедостачТоваровТовары.Ссылка.ПересчетТоваров)
	|ГДЕ
	|	ПересчетТоваров.Ссылка = &Ссылка
	|	И СписаниеНедостачТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	СписаниеНедостачТоваровТовары.Номенклатура,
	|	СписаниеНедостачТоваровТовары.Характеристика,
	|	СписаниеНедостачТоваровТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПересортицаТоваровТовары.НоменклатураОприходование,
	|	ПересортицаТоваровТовары.ХарактеристикаОприходование,
	|	ПересортицаТоваровТовары.Назначение,
	|	СУММА(0),
	|	СУММА(ЕСТЬNULL(ПересортицаТоваровТовары.Количество, 0))
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПересортицаТоваров.Товары КАК ПересортицаТоваровТовары
	|		ПО ПересчетТоваров.Ссылка = ПересортицаТоваровТовары.Ссылка.ПересчетТоваров
	|ГДЕ
	|	ПересчетТоваров.Ссылка = &Ссылка
	|	И ПересортицаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПересортицаТоваровТовары.НоменклатураОприходование,
	|	ПересортицаТоваровТовары.ХарактеристикаОприходование,
	|	ПересортицаТоваровТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОприходованиеИзлишковТоваровТовары.Номенклатура,
	|	ОприходованиеИзлишковТоваровТовары.Характеристика,
	|	ОприходованиеИзлишковТоваровТовары.Назначение,
	|	СУММА(0),
	|	СУММА(ЕСТЬNULL(ОприходованиеИзлишковТоваровТовары.Количество, 0))
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОприходованиеИзлишковТоваров.Товары КАК ОприходованиеИзлишковТоваровТовары
	|		ПО ПересчетТоваров.Ссылка = ОприходованиеИзлишковТоваровТовары.Ссылка.ПересчетТоваров
	|ГДЕ
	|	ПересчетТоваров.Ссылка = &Ссылка
	|	И ОприходованиеИзлишковТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ОприходованиеИзлишковТоваровТовары.Номенклатура,
	|	ОприходованиеИзлишковТоваровТовары.Характеристика,
	|	ОприходованиеИзлишковТоваровТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПорчаТоваровТовары.Номенклатура,
	|	ПорчаТоваровТовары.Характеристика,
	|	ПорчаТоваровТовары.Назначение,
	|	СУММА(ЕСТЬNULL(ПорчаТоваровТовары.Количество, 0)),
	|	СУММА(0)
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПорчаТоваров.Товары КАК ПорчаТоваровТовары
	|		ПО ПересчетТоваров.Ссылка = ПорчаТоваровТовары.Ссылка.ПересчетТоваров
	|ГДЕ
	|	ПересчетТоваров.Ссылка = &Ссылка
	|	И ПорчаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПорчаТоваровТовары.Номенклатура,
	|	ПорчаТоваровТовары.Характеристика,
	|	ПорчаТоваровТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПорчаТоваровТовары.НоменклатураОприходование,
	|	ПорчаТоваровТовары.ХарактеристикаОприходование,
	|	ПорчаТоваровТовары.Назначение,
	|	СУММА(0),
	|	СУММА(ЕСТЬNULL(ПорчаТоваровТовары.Количество, 0))
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПорчаТоваров.Товары КАК ПорчаТоваровТовары
	|		ПО (ПересчетТоваров.Ссылка = ПорчаТоваровТовары.Ссылка.ПересчетТоваров)
	|ГДЕ
	|	ПересчетТоваров.Ссылка = &Ссылка
	|	И ПорчаТоваровТовары.Ссылка.Проведен 
	|
	|СГРУППИРОВАТЬ ПО
	|	ПорчаТоваровТовары.НоменклатураОприходование,
	|	ПорчаТоваровТовары.ХарактеристикаОприходование,
	|	ПорчаТоваровТовары.Назначение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПересчетТоваровТовары.Номенклатура КАК Номенклатура,
	|	ПересчетТоваровТовары.Характеристика КАК Характеристика,
	|	ПересчетТоваровТовары.Назначение КАК Назначение,
	|	-&НовыйРасчетОтклонения - СУММА(ЕСТЬNULL(ВР_Таб.КоличествоРасход, 0)) КАК Количество
	|ИЗ
	|	Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВР_Таб КАК ВР_Таб
	|		ПО ПересчетТоваровТовары.Номенклатура = ВР_Таб.Номенклатура
	|			И ПересчетТоваровТовары.Характеристика = ВР_Таб.Характеристика
	|			И ПересчетТоваровТовары.Назначение = ВР_Таб.Назначение
	|ГДЕ
	|	ПересчетТоваровТовары.Ссылка = &Ссылка
	|	И -&НовыйРасчетОтклонения - ЕСТЬNULL(ВР_Таб.КоличествоРасход, 0) > 0
	|	И &Приемник = 1
	|
	|СГРУППИРОВАТЬ ПО
	|	ПересчетТоваровТовары.Ссылка.НовыйРасчетОтклонения,
	|	ПересчетТоваровТовары.Номенклатура,
	|	ПересчетТоваровТовары.Упаковка,
	|	ПересчетТоваровТовары.Характеристика,
	|	ПересчетТоваровТовары.Количество,
	|	ПересчетТоваровТовары.КоличествоФакт,
	|	ПересчетТоваровТовары.КоличествоПоУчетуВЗонеХранения,
	|	ПересчетТоваровТовары.Назначение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПересчетТоваровТовары.Номенклатура,
	|	ПересчетТоваровТовары.Характеристика,
	|	ПересчетТоваровТовары.Назначение,
	|	&НовыйРасчетОтклонения - СУММА(ЕСТЬNULL(ВР_Таб.КоличествоПриход, 0))
	|ИЗ
	|	Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВР_Таб КАК ВР_Таб
	|		ПО ПересчетТоваровТовары.Номенклатура = ВР_Таб.Номенклатура
	|			И ПересчетТоваровТовары.Характеристика = ВР_Таб.Характеристика
	|			И ПересчетТоваровТовары.Назначение = ВР_Таб.Назначение
	|ГДЕ
	|	ПересчетТоваровТовары.Ссылка = &Ссылка
	|	И &Приемник = 2
	|
	|СГРУППИРОВАТЬ ПО
	|	ПересчетТоваровТовары.Ссылка.НовыйРасчетОтклонения,
	|	ПересчетТоваровТовары.Номенклатура,
	|	ПересчетТоваровТовары.Упаковка,
	|	ПересчетТоваровТовары.Характеристика,
	|	ПересчетТоваровТовары.КоличествоФакт,
	|	ПересчетТоваровТовары.Количество,
	|	ПересчетТоваровТовары.КоличествоПоУчетуВЗонеХранения,
	|	ПересчетТоваровТовары.Назначение
	|
	|ИМЕЮЩИЕ
	|	&НовыйРасчетОтклонения - СУММА(ЕСТЬNULL(ВР_Таб.КоличествоПриход, 0)) > 0";
	
	Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&НовыйРасчетОтклонения", 
		Документы.ПересчетТоваров.НовыйРасчетОтклонения_ПараметрЗапросаБезУпаковок("ПересчетТоваровТовары"));
		
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
		"&ТекстЗапросаКоэффициентУпаковки",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
		"ПересчетТоваровТовары.Упаковка",
		"ПересчетТоваровТовары.Номенклатура"));
	
	Запрос.УстановитьПараметр("Приемник", ПараметрДвижения);
	Запрос.УстановитьПараметр("Ссылка", ДокументОснования);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ПроверитьРасхождениеЗаказаИРеализаций(Источник,отказ) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.ЗаказКлиента
	|ПОМЕСТИТЬ ВТ_Заказ
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Контрагент,
	|	РеализацияТоваровУслуг.Партнер,
	|	РеализацияТоваровУслуг.Склад,
	|	РеализацияТоваровУслуг.Соглашение,
	|	РеализацияТоваровУслуг.Договор КАК Договор
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	ВТ_Заказ КАК ВТ_Заказ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_Заказ.ЗаказКлиента = РеализацияТоваровУслуг.ЗаказКлиента
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка <> &Ссылка
	|	И РеализацияТоваровУслуг.ПометкаУдаления = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_Заказ.ЗаказКлиента.Организация,
	|	ВТ_Заказ.ЗаказКлиента.Контрагент,
	|	ВТ_Заказ.ЗаказКлиента.Партнер,
	|	ВТ_Заказ.ЗаказКлиента.Склад,
	|	ВТ_Заказ.ЗаказКлиента.Соглашение,
	|	ВТ_Заказ.ЗаказКлиента.Договор
	|ИЗ
	|	ВТ_Заказ КАК ВТ_Заказ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Организация,
	|	ВТ.Контрагент,
	|	ВТ.Партнер,
	|	ВТ.Склад,
	|	ВТ.Соглашение,
	|	ВТ.Договор
	|ИЗ
	|	ВТ КАК ВТ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ.Организация,
	|	ВТ.Контрагент,
	|	ВТ.Договор,
	|	ВТ.Склад,
	|	ВТ.Соглашение,
	|	ВТ.Партнер";
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ= РезультатЗапроса.Выгрузить();
	
	НоваяСтрока= ТЗ.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, Источник); 
	
	ТЗ.Свернуть("Организация,Контрагент,Договор,Склад,Соглашение,Партнер");
	Если ТЗ.Количество()>1 Тогда
		Сообщить("Есть расхождения между заказом или несколькими реализациями по реквизитам шапки!");
		отказ= Истина;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьПараметрыСтруктуры(СтруктураПараметров,Источник)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Сумма,
	|	Товары.Номенклатура,
	|	Товары.Распределять
	|ПОМЕСТИТЬ ВР
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВР.Сумма * ВР.Распределять) КАК СуммаТоваров,
	|	СУММА(ВЫБОР
	|			КОГДА СПР_Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|				ТОГДА ВР.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаУслуг,
	|	ВЫБОР
	|		КОГДА СУММА(ВР.Сумма * ВР.Распределять) <> 0
	|			ТОГДА СУММА(ВЫБОР
	|						КОГДА СПР_Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|							ТОГДА ВР.Сумма
	|						ИНАЧЕ 0
	|					КОНЕЦ) / СУММА(ВР.Сумма * ВР.Распределять)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Коэфф
	|ИЗ
	|	ВР КАК ВР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СПР_Номенклатура
	|		ПО ВР.Номенклатура = СПР_Номенклатура.Ссылка";
	
	Запрос.УстановитьПараметр("Товары", Источник.Товары);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	если  Выборка.Следующий() тогда
		Заполнитьзначениясвойств(Структурапараметров,Выборка);
	конецесли;
	
КонецПроцедуры

Процедура ОчиститьТабличныеЧасти(Источник)
	Для каждого стр из Источник.Товары цикл
		стр.СуммаСНДСРТ=0;
		стр.СуммаНДСРТ=0;
		стр.СуммаРТ=0;
		стр.Распределять=0;
	конеццикла;
	
	если ТипЗнч(Источник)=Тип("ДокументОбъект.РеализацияТоваровУслуг") тогда
		Для каждого стр из Источник.ВидыЗапасов цикл
			стр.СуммаСНДСРТ=0;
			стр.СуммаНДСРТ=0;
		конеццикла;
	конецесли;	
КонецПроцедуры

Процедура ЗаполнитьСтрокуВидовЗапасов(стр,Источник)
	СтруктураПоиска=Новый Структура;
	СтруктураПоиска.Вставить("АналитикаУчетаНоменклатуры",стр.АналитикаУчетаНоменклатуры);
	СтруктураПоиска.Вставить("ЗаказКлиента",стр.ЗаказКлиента);
	КоличествоСтек=стр.Количество;
	СтекСуммаСНДСРТ=стр.СуммаСНДСРТ;
	СтекСуммаНДСРТ=стр.СуммаНДСРТ;
	Для Каждого СтрокаЗапасов Из Источник.ВидыЗапасов.НайтиСтроки(СтруктураПоиска) Цикл
		Если СтрокаЗапасов.Количество = 0 Тогда
			Продолжить;
		КонецЕсли;
		КоличествоСтек=КоличествоСтек-СтрокаЗапасов.Количество;
		если КоличествоСтек<>0 тогда
			СтрокаЗапасов.СуммаНДСРТ=стр.СуммаНДСРТ/стр.Количество*СтрокаЗапасов.Количество;
			СтрокаЗапасов.СуммаСНДСРТ=стр.СуммаСНДСРТ/стр.Количество*СтрокаЗапасов.Количество;
			СтекСуммаСНДСРТ=СтекСуммаСНДСРТ-СтрокаЗапасов.СуммаСНДСРТ;
			СтекСуммаНДСРТ=СтекСуммаНДСРТ-СтрокаЗапасов.СуммаНДСРТ;
		иначе
			СтрокаЗапасов.СуммаНДСРТ=СтекСуммаНДСРТ;
			СтрокаЗапасов.СуммаСНДСРТ=СтекСуммаСНДСРТ;
		конецесли;
	Конеццикла;	
КонецПроцедуры

Процедура ПодставитьКонтрагентаФизическоеЛицо(Объект) Экспорт   
	
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.Дата >= Дата(2017,05,16) Тогда
		Если Не ДопМодуль.ПроверитьРасчетыПоДоговору(Объект) Тогда
			Если Объект.Контрагент.ЮрФизЛицо <> Перечисления.ЮрФизЛицо.ФизЛицо Тогда
				Объект.Контрагент= Справочники.Контрагенты.НайтиПоНаименованию("ФИЗИЧЕСКОЕ ЛИЦО");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Функция ПроверитьРасчетыПоДоговору(Объект) Экспорт
	Если Не ЗначениеЗаполнено(Объект.Соглашение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Договор) Тогда 
		Возврат Объект.Договор.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Соглашение.ПорядокРасчетов) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Объект.Соглашение.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;
КонецФункции

Функция ИдентифицироватьКлиентаПоСМС(Объект,ТекстСМС="") экспорт
	Настройки=ПолучитьНастройкиХранилища("Форма1","НастройкиХранилища.epf");
	если Настройки<>Неопределено и типзнч(Настройки)=тип("Структура") тогда
		если Настройки.свойство("ТекстПроверки") тогда
			если Настройки.ТекстПроверки="" тогда
				ТекстСМС="Ваш код для проверки  - %КодПроверки%";
			иначе
				ТекстСМС=Настройки.ТекстПроверки;
			конецесли;	
		конецесли;
		если Настройки.свойство("ПорогПроверкиИдентификации") тогда
			Возврат Объект.Товары.Итог("Сумма")>=Настройки.ПорогПроверкиИдентификации;
		конецесли;
	конецесли;
	возврат ложь; 
КонецФункции

Процедура ИнформироватьКлиентаПоСМС(Объект,ШаблонСМС="") экспорт
	Настройки=ПолучитьНастройкиХранилища("Форма1","НастройкиХранилища.epf");
	если Настройки<>Неопределено и типзнч(Настройки)=тип("Структура") тогда
		если Настройки.свойство("ПорогОтправкиУведомления") тогда
			если Объект.Товары.Итог("Сумма")>=Настройки.ПорогОтправкиУведомления тогда
				УстановитьПривилегированныйРежим(Истина);
				НомерТелефона = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Объект.Партнер,Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
				АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);
				НомераТелефонов = Новый Массив;
				НомераТелефонов.Добавить("+7"+НомерТелефона);
				
				ТекстСообщения=?(Объект.РеализацияПоЗаказам,"По заказу №"+Объект.ЗаказКлиента.Номер+" от "+формат(Объект.ЗаказКлиента.Дата,"ДЛФ=Д"),
				"По накладной №"+Объект.Номер+" от "+формат(Объект.Дата,"ДЛФ=Д"));
				ТекстСообщения=ТекстСообщения+" произведена отгрузка на сумму "+Объект.Товары.Итог("Сумма")+"р.";
				РезультатОтправки = ОтправкаSMS.ОтправитьSMS(НомераТелефонов,ТекстСообщения,,);
				УстановитьПривилегированныйРежим(Ложь);
			конецесли;
		конецесли;
	конецесли;
КонецПроцедуры

// Возвращает email партнера в независимости от вида контактной информации
Функция ПолучитьПочтуПартнера(Партнер)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Партнеры.Ссылка КАК Партнер,
	|	ПартнерыКонтактнаяИнформацияТелефон.АдресЭП КАК АдресЭП
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|		СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияТелефон
	|		ПО Партнеры.Ссылка = ПартнерыКонтактнаяИнформацияТелефон.Ссылка
	|			И ПартнерыКонтактнаяИнформацияТелефон.АдресЭП <> """"
	|ГДЕ
	|	Партнеры.Ссылка = &Партнер";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка= РезультатЗапроса.Выбрать();
	
	АдресЭП	= "";
	Если Выборка.Следующий() Тогда
		АдресЭП = Выборка.АдресЭП;
	КонецЕсли;
	
	Возврат АдресЭП;
КонецФункции   

// Возвращает телефон партнера в независимости от вида контактной информации
// в отличие от АльтерраОбщегоНазначения.ПолучитьТелефонПартнера(Партнер), возвращающей теоефон
// только по виду контактной информации Справочники.ВидыКонтактнойИнформации.ТелефонПартнера
Функция ПолучитьТелефонПартнера(Партнер)  Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Партнеры.Ссылка КАК Партнер,
	|	ПартнерыКонтактнаяИнформацияТелефон.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|		СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияТелефон
	|		ПО Партнеры.Ссылка = ПартнерыКонтактнаяИнформацияТелефон.Ссылка
	|			И ПартнерыКонтактнаяИнформацияТелефон.НомерТелефона <> """"
	|ГДЕ
	|	Партнеры.Ссылка = &Партнер";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка= РезультатЗапроса.Выбрать();
	
	НомерТелефона = "";
	Если Выборка.Следующий() Тогда
		НомерТелефона = Выборка.НомерТелефона;
	КонецЕсли;
	
	Возврат НомерТелефона;
КонецФункции

// Возвращает партнера по телефону в независимости от вида контактной информации
Функция ПолучитьПартнераПоТелефону(Телефон) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПартнерыКонтактнаяИнформация.Ссылка КАК Ссылка,
	|	ПартнерыКонтактнаяИнформация.Представление КАК Представление
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
	|ГДЕ
	|	ПартнерыКонтактнаяИнформация.Тип = &Тип
	|	И НЕ ПартнерыКонтактнаяИнформация.Ссылка.ПометкаУдаления
	|	И ПартнерыКонтактнаяИнформация.НомерТелефона = &НомерТелефона";
	
	Запрос.УстановитьПараметр("Тип", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("НомерТелефона", Телефон);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Партнер = ПредопределенноеЗначение("Справочник.Партнеры.ПустаяСсылка");
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Партнер = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;    
	
	Возврат Партнер;
КонецФункции

