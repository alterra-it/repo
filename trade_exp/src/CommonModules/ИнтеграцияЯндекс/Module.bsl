Функция ОбновитьКурьерыМониторинг(КурьерыКОтправке, НастройкиАвторизации, ЗапросыДляЛогов)     
	
	РезультатВыполнения = ПараметрыВыполнения("Обновление курьеров в мониторинге");
	
	Попытка     
		// Получение списка курьеров
		КурьерыМониторинг = ВыполнитьЗапросПолучениеКурьеры(НастройкиАвторизации); 
		РезультатВыполнения.Результат = КурьерыМониторинг.Результат;
		РезультатВыполнения.Сообщение = КурьерыМониторинг.Сообщение + Символы.ПС;
		
		ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "СписокКурьеровЗапрос", КурьерыМониторинг.Метод);		
		ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "СписокКурьеровОтвет", КурьерыМониторинг.JsonОтвет, ,, Не КурьерыМониторинг.Результат);
	
		Если КурьерыМониторинг.Результат Тогда  
		
			Сч = КурьерыКОтправке.Количество() - 1;
			Пока Сч >= 0 Цикл          
				Для Каждого КурьерМониторинг Из КурьерыМониторинг.ОтветСтруктура Цикл
					Если КурьерыКОтправке[Сч].number = КурьерМониторинг.number Тогда
						КурьерыКОтправке.Удалить(Сч);
						Прервать;
					КонецЕсли;
				КонецЦикла;
			  Сч = Сч - 1;
			КонецЦикла;		
			
			// Обновить курьеров, которых нет в мониторинге
			Если КурьерыКОтправке.Количество() > 0 Тогда		
				ОбновлениеКурьеры = ВыполнитьЗапросОбновлениеКурьеры(КурьерыКОтправке, НастройкиАвторизации);    
				
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеКурьеровЗапрос", ОбновлениеКурьеры.Метод + Символы.ПС + "Тело:" + ОбновлениеКурьеры.Тело);		
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеКурьеровОтвет", ОбновлениеКурьеры.JsonОтвет,,, Не ОбновлениеКурьеры.Результат);
				
				РезультатВыполнения.Результат = ОбновлениеКурьеры.Результат;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ОбновлениеКурьеры.Сообщение + Символы.ПС;
			КонецЕсли;       
		
		Иначе
			РезультатВыполнения.Сообщение = КурьерыМониторинг.Сообщение;
		КонецЕсли;
		
	Исключение
		РезультатВыполнения.Сообщение = "Ошибка при обновлении курьеров мониторинга: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;      
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

