#Область МаршрутыМониторинга

Функция МаршрутыМониторинга()
	
	ЗаказыТЗ = Новый ТаблицаЗначений;
	КвалификаторСтроки = Новый КвалификаторыСтроки(50);	
	ЗаказыТЗ.Колонки.Добавить("ИдентификаторМаршрута", Новый ОписаниеТипов("Строка", КвалификаторСтроки));
	ЗаказыТЗ.Колонки.Добавить("ИдентификаторЗаказа", Новый ОписаниеТипов("Строка", КвалификаторСтроки));
	ЗаказыТЗ.Колонки.Добавить("НомерЗаказа", Новый ОписаниеТипов("Строка", КвалификаторСтроки));
	Возврат ЗаказыТЗ;
	
КонецФункции

Процедура ДобавитьМаршрутыМониторинга(МаршрутыМониторинга, ЗаказыЯндекс)
	
	Для Каждого Маршрут Из ЗаказыЯндекс Цикл
		Для Каждого Заказ Из Маршрут.nodes Цикл
			
			Если Заказ.type = "order" Тогда
				СтрокаЗаказа = МаршрутыМониторинга.Добавить();
				СтрокаЗаказа.ИдентификаторМаршрута = Маршрут.meta.id;
				СтрокаЗаказа.ИдентификаторЗаказа = Заказ.value.id;	
				
				ИндексПробел = СтрНайти(Заказ.value.number, " ");
				Если ИндексПробел = 0 Тогда
					СтрокаЗаказа.НомерЗаказа = Заказ.value.number;
				Иначе
					СтрокаЗаказа.НомерЗаказа = Лев(Заказ.value.number, ИндексПробел - 1);
				КонецЕсли;
			КонецЕсли;  
			
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ЗаказыМониторинга

Функция ПолучитьМаршрутыЗаказыДляОтслеживания(МаршрутыМониторинга);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	ЗаказыЯндекс.ИдентификаторМаршрута,
		|	ЗаказыЯндекс.ИдентификаторЗаказа,
		|	ЗаказыЯндекс.НомерЗаказа   
		|ПОМЕСТИТЬ
		|	втЗаказыЯндекс	
		|ИЗ
		|	&ЗаказыЯндекс КАК ЗаказыЯндекс
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ                       
		|	ЗаказыНаДоставку.Ссылка КАК ЗаказНаДоставку,
		|	втЗаказыЯндекс.НомерЗаказа,
		|	втЗаказыЯндекс.ИдентификаторЗаказа,
		|	втЗаказыЯндекс.ИдентификаторМаршрута,
		|	ДоставкаЯндекс.ЗаказНаДоставку КАК ВыполненныйЗаказ     
		|ПОМЕСТИТЬ 
		|	втМаршрутыЗаказы	
		|ИЗ
		|	втЗаказыЯндекс
		|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказыНаДоставку
		|		ПО втЗаказыЯндекс.НомерЗаказа = ЗаказыНаДоставку.Номер
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ДоставкаЯндекс
		|		ПО ЗаказыНаДоставку.Ссылка = ДоставкаЯндекс.ЗаказНаДоставку
		|		И СтатусДоставки В (
		|			ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказДоставлен),
		|			ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ЗаказОтменен))
		|;
		|// Несопоставленные заказы с номерами заказов Яндекс
		|ВЫБРАТЬ	
		|	НомерЗаказа
		|ИЗ 
		|	втМаршрутыЗаказы	                            
		|ГДЕ
		|	ЗаказНаДоставку ЕСТь NULL
		|;                                                   
		|// Маршруты для получения данных Яндекс
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИдентификаторМаршрута
		|ИЗ
		|	втМаршрутыЗаказы 	 
		|ГДЕ
		|	ЗаказНаДоставку ЕСТь НЕ NULL
//		|	И ВыполненныйЗаказ ЕСТЬ NULL   
		|;
		|// Заказы для получения данных Яндекс	(найденные в 1с и недоставленные в Яндексе)
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИдентификаторМаршрута,     
		|	ИдентификаторЗаказа,
		|	ЗаказНаДоставку,
		|	ВЫРАЗИТЬ(&ПустаяСтрока КАК Строка(200)) КАК Трекинг,
		|	ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) КАК ПлановоеВремяДоставки
		|ИЗ
		|	втМаршрутыЗаказы 	 
		|ГДЕ
		|	ЗаказНаДоставку ЕСТь НЕ NULL
		|	И ВыполненныйЗаказ ЕСТЬ NULL
		|;  
		|// Заказы для получения трекингов (все найденные в 1с, трекинги могут меняться вручную )
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИдентификаторМаршрута,     
		|	ИдентификаторЗаказа,
		|	ЗаказНаДоставку,
		|	ВЫРАЗИТЬ(&ПустаяСтрока КАК Строка(200)) КАК Трекинг,
		|	ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) КАК ПлановоеВремяДоставки
		|ИЗ
		|	втМаршрутыЗаказы
		|ГДЕ
		|	ЗаказНаДоставку ЕСТь НЕ NULL";  
	
	Запрос.УстановитьПараметр("ЗаказыЯндекс", МаршрутыМониторинга);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	ПакетЗапросов = Запрос.ВыполнитьПакет();
	
	НенайденныеЗаказы = ПакетЗапросов[2].Выгрузить();
	СписокНенайденныхЗаказов = "";
	Если НенайденныеЗаказы.Количество() > 0 Тогда
		Для Каждого Заказ Из НенайденныеЗаказы Цикл
			СписокНенайденныхЗаказов = СписокНенайденныхЗаказов + ?(СписокНенайденныхЗаказов <> "", ", ", "") + Заказ.НомерЗаказа; 	
		КонецЦикла;
		СписокНенайденныхЗаказов = СтрШаблон("Не определены по номерам заказы в количестве %1: ", НенайденныеЗаказы.Количество()) + СписокНенайденныхЗаказов;
	КонецЕсли; 	
	
	Возврат Новый Структура("Маршруты, Заказы, НенайденныеЗаказы, Трекинги", ПакетЗапросов[3].Выгрузить(), ПакетЗапросов[4].Выгрузить(), СписокНенайденныхЗаказов, ПакетЗапросов[5].Выгрузить());		

КонецФункции

