Функция ОбновитьМаршрутыМониторинг(МаршрутыКОтправке, ИдентификаторыРейсов, НастройкиАвторизации, ЗапросыДляЛогов)     
	
	РезультатВыполнения = ПараметрыВыполнения("Обновление маршрутов в мониторинге");
	
	Попытка     
		// Обновить маршруты
		Если МаршрутыКОтправке.Количество() > 0 Тогда		
			ОбновлениеМаршруты = ВыполнитьЗапросОбновлениеМаршруты(МаршрутыКОтправке, НастройкиАвторизации);    
			
			ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеМаршрутовЗапрос", ОбновлениеМаршруты.Метод + Символы.ПС + "Тело:" + ОбновлениеМаршруты.Тело);		
			ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеМаршрутовОтвет", ОбновлениеМаршруты.JsonОтвет,,, Не ОбновлениеМаршруты.Результат);
			
			РезультатВыполнения.Результат = ОбновлениеМаршруты.Результат;
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ОбновлениеМаршруты.Сообщение + Символы.ПС;
		КонецЕсли;  
		     
		// Получить идентификаторы маршрутов
		Если РезультатВыполнения.Результат Тогда
			Для Каждого Рейс Из ИдентификаторыРейсов Цикл
				ПолучениеИдентификатораМаршрута = ВыполнитьЗапросПолучитьМаршрут(Рейс.НомерРейса, НастройкиАвторизации);
				
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ПолучениеИдентификатораМаршрута" + Рейс.НомерРейса + "Запрос", ПолучениеИдентификатораМаршрута.Метод);		
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ПолучениеИдентификатораМаршрута" + Рейс.НомерРейса + "Ответ", ПолучениеИдентификатораМаршрута.JsonОтвет,,, Не ПолучениеИдентификатораМаршрута.Результат);
				
				РезультатВыполнения.Результат = ПолучениеИдентификатораМаршрута.Результат;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ПолучениеИдентификатораМаршрута.Сообщение + Символы.ПС;
				
				Если ПолучениеИдентификатораМаршрута.Результат Тогда
					Рейс.ИдРейса = ПолучениеИдентификатораМаршрута.ОтветСтруктура[0].id;
				Иначе
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли; 

	Исключение
		РезультатВыполнения.Сообщение = "Ошибка при обновлении маршрутов мониторинга: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;      
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
