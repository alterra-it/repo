Функция ЗапросыДляЛогов() Экспорт
	
	ЗапросыДляЛогов = Новый ТаблицаЗначений();
	
	ЗапросыДляЛогов.Колонки.Добавить("Дата", 			Новый ОписаниеТипов("Дата", , , 	Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	ЗапросыДляЛогов.Колонки.Добавить("Заголовок",		Новый ОписаниеТипов("Строка", , , 	Новый КвалификаторыСтроки(200))); 
	ЗапросыДляЛогов.Колонки.Добавить("ТекстЛогов",		Новый ОписаниеТипов("Строка")); 	
	ЗапросыДляЛогов.Колонки.Добавить("Филиал",			Новый ОписаниеТипов("Строка", , , 	Новый КвалификаторыСтроки(100)));
	ЗапросыДляЛогов.Колонки.Добавить("Идентификатор",	Новый ОписаниеТипов("Строка", , , 	Новый КвалификаторыСтроки(36)));
	ЗапросыДляЛогов.Колонки.Добавить("Ошибка",			Новый ОписаниеТипов("Булево"));
	
	Возврат ЗапросыДляЛогов;
	
КонецФункции

Функция ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, Заголовок, ТекстЛогов, Филиал = "", Идентификатор = "", Ошибка = Ложь) Экспорт
	
	СтрокаЗапроса = ЗапросыДляЛогов.Добавить(); 
	
	СтрокаЗапроса.Дата 			= ТекущаяДатаСеанса();
	СтрокаЗапроса.Заголовок 	= Заголовок;
	СтрокаЗапроса.ТекстЛогов 	= ТекстЛогов;
	СтрокаЗапроса.Филиал 		= Филиал;
	СтрокаЗапроса.Идентификатор = Идентификатор;
	СтрокаЗапроса.Ошибка 		= Ошибка;
	
КонецФункции	

Процедура ЗаписатьЛогЗапросов(ПапкаЛогов, ЗапросыДляЛогов) Экспорт
	
	Если ЗапросыДляЛогов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Филиал = "";
	Идентификатор = ""; 
	Для Каждого Запрос Из ЗапросыДляЛогов  Цикл
		Филиал = ?(Запрос.Филиал <> "" И Филиал = "", Запрос.Филиал, Филиал);
		Идентификатор = ?(Запрос.Идентификатор <> "" И Идентификатор = "", Запрос.Идентификатор, Идентификатор);
	КонецЦикла;   
	Филиал = ?(Филиал <> "", Филиал, "Филиал не определен");
	Филиал = СтрЗаменить(Филиал, "/", "");
	Идентификатор = ?(Идентификатор <> "", Идентификатор, "Идентификатор не определен"); 
	
	ИмяПользователя = СтрЗаменить(Строка(Пользователи.ТекущийПользователь()), " ", "");
	ПерваяДатаЗапроса = ЗапросыДляЛогов[0].Дата;
	
	ИмяПапкиЗаписиПоДате = ПапкаЛогов + ?(Прав(ПапкаЛогов, 1) <> "\", "\", "")  + "yandex\" + Филиал + "\" + Формат(ТекущаяДата(), "ДФ=ггггММдд"); 
	
	Попытка   
		КаталогЛоговПоДате = Новый Файл(ИмяПапкиЗаписиПоДате);
		Если Не КаталогЛоговПоДате.Существует() Тогда    
			Попытка
				СоздатьКаталог(ИмяПапкиЗаписиПоДате);
			Исключение
			КонецПопытки;
		КонецЕсли; 	
		
	    НайденныйКаталогПоИдентификатору = НайтиФайлы(ИмяПапкиЗаписиПоДате + "\", "*" + Идентификатор + "*", Ложь);  		
		Если НайденныйКаталогПоИдентификатору.Количество() > 0 Тогда
        	ИмяПапкиЗаписи = НайденныйКаталогПоИдентификатору[0].Имя;
			
		Иначе                                       
			ИмяПапкиЗаписи = Формат(ПерваяДатаЗапроса, "ДФ=ггггММдд") + "_" + Формат(ПерваяДатаЗапроса, "ДФ=ЧЧммсс") + "_" + Идентификатор + "_" + ИмяПользователя; 
			КаталогЛогов = Новый Файл(ИмяПапкиЗаписи);
			Если Не КаталогЛогов.Существует() Тогда
				СоздатьКаталог(ИмяПапкиЗаписиПоДате + "\" + ИмяПапкиЗаписи);
			КонецЕсли;     
		КонецЕсли;
		
		Для Каждого Запрос Из ЗапросыДляЛогов  Цикл
		
			ИмяЛога = "log_" + Формат(Запрос.Дата, "ДФ=ггггММдд") + "_" + Формат(Запрос.Дата, "ДФ=ЧЧммсс") + "_" + СтрЗаменить(Запрос.Заголовок, " ", "") + 
					   Строка(?(Запрос.Ошибка, "_Ошибка", "")) + "_" + ИмяПользователя + ".txt";      
			
			ФайлЛогов = Новый ЗаписьТекста(ИмяПапкиЗаписиПоДате + "\" + ИмяПапкиЗаписи + "\" + ИмяЛога, КодировкаТекста.UTF8, , Истина);
			ФайлЛогов.ЗаписатьСтроку(Запрос.ТекстЛогов);
			ФайлЛогов.Закрыть();  
		
		КонецЦикла;

	Исключение        
		Сообщить("Ошибка при записи логов: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;    
	
	ЗапросыДляЛогов.Очистить();
	
КонецПроцедуры		

