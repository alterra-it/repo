Функция ВыполнитьRestЗапрос(НастройкиАвторизации, Метод, ТипЗапроса = "GET", Тело = Неопределено)
	
	РезультатВыполнения = РезультатВыполненияRest();
	РезультатВыполнения.Метод = Метод; 

	Попытка 
		Соединение = Новый HTTPСоединение("courier.yandex.ru", , , , Новый ИнтернетПрокси(Истина), , Новый ЗащищенноеСоединениеOpenSSL);	   
				
		Запрос = Новый HTTPЗапрос(Метод);
		Запрос.Заголовки.Вставить("Content-Type", "application/json");
		Запрос.Заголовки.Вставить("Accept", "application/json");       
		Если ЗначениеЗаполнено(НастройкиАвторизации.НастройкиТокенЯндексМониторинг) Тогда 
			Запрос.Заголовки.Вставить("Authorization",	"Auth " + НастройкиАвторизации.НастройкиТокенЯндексМониторинг)
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Тело) Тогда
			Запрос.УстановитьТелоИзСтроки(Тело);
		КонецЕсли;
		
		Если ТипЗапроса = "GET" Тогда
			Ответ = Соединение.Получить(Запрос);	
		ИначеЕсли ТипЗапроса = "POST" Тогда
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);	
		КонецЕсли;     
		
		РезультатВыполнения.КодСостояния = Ответ.КодСостояния;

		Если Не ТипЗнч(Ответ) = Тип("HTTPОтвет") Тогда         
			РезультатВыполнения.Сообщение = "Ошибка формирования запроса. Код ошибки: " + Строка(Ответ.КодСостояния);
		Иначе		
			ОтветСтрока = Ответ.ПолучитьТелоКакСтроку();
			РезультатВыполнения.JsonОтвет = ФорматироватьJsonТекст(ОтветСтрока);
			РезультатВыполнения.Сообщение = РезультатВыполнения.JsonОтвет;       
			Попытка
				РезультатВыполнения.ОтветСтруктура = АльтерраОбщегоНазначения.ДесериализоватьИзJSON(ОтветСтрока);
			Исключение
			КонецПопытки;         
			
			Если ТипЗнч(РезультатВыполнения.ОтветСтруктура) = Тип("Структура") 
				Или ТипЗнч(РезультатВыполнения.ОтветСтруктура) = Тип("Массив") Тогда
					РезультатВыполнения.Результат = Истина;
					РезультатВыполнения.Сообщение = "Запрос успешно получен"; 
			Иначе                                
				РезультатВыполнения.Сообщение = "Ошибка при получении ответа";	
			КонецЕсли; 
		КонецЕсли;     

	Исключение         
		РезультатВыполнения.Сообщение = "Не удалось получить результаты запроса: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;                                                                                                                            

	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьНастройкиАвторизации() 

	ПараметрыАвторизации = ПараметрыАвторизации();
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", "ПланированиеРейсовЯндексМаршрутизация.epf");	
	
	Если Не ДополнительнаяОбработка.Пустая() Тогда
		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда  
			ЗаполнитьЗначенияСвойств(ПараметрыАвторизации, НастройкиХранилища);
			Возврат ПараметрыАвторизации;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПараметрыАвторизации;
	
КонецФункции	

Функция ПараметрыАвторизации()
	
	ПараметрыАвторизации = Новый Структура;
	ПараметрыАвторизации.Вставить("НастройкиIdКомпании", 					"");
	ПараметрыАвторизации.Вставить("НастройкиКлючAPIЯндексМаршрутизация", 	"");
	ПараметрыАвторизации.Вставить("НастройкиТокенЯндексМониторинг", 		""); 
	ПараметрыАвторизации.Вставить("НастройкиПапкаЛогов", 					"");
	Возврат ПараметрыАвторизации;
	
КонецФункции	

Функция РезультатВыполненияRest()
	
	РезультатВыполнения = Новый Структура;
	РезультатВыполнения.Вставить("Метод", 			"");
	РезультатВыполнения.Вставить("Результат", 		Ложь); 
	РезультатВыполнения.Вставить("КодСостояния", 	500); 
	РезультатВыполнения.Вставить("JsonОтвет", 		""); 
	РезультатВыполнения.Вставить("ОтветСтруктура", 	Неопределено); 
	РезультатВыполнения.Вставить("Сообщение", 		"");
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ФорматироватьJsonТекст(JsonТекст)            
	
	JsonТекстСер = ?(ТипЗнч(JsonТекст) <> Тип("Структура") И ТипЗнч(JsonТекст) <> Тип("Массив"), 
		АльтерраОбщегоНазначения.ДесериализоватьИзJSON(JsonТекст), JsonТекст);  
		
	ЗаписьJSON = Новый ЗаписьJSON;  
	ЗаписьJSON.ПроверятьСтруктуру = Ложь;
	ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( , Символы.Таб);
	ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);
	ЗаписатьJSON(ЗаписьJSON, JsonТекстСер);
	ТекстЗапроса = СтрЗаменить(ЗаписьJSON.Закрыть(),"\\","\");
	
	Возврат ТекстЗапроса;
	
КонецФункции 

#КонецОбласти

