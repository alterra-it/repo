Функция ВыполнитьЗапросПолучениеМаршруты(НастройкиАвторизации, Дата, НаСтранице = 200) Экспорт
	
	Метод = СтрШаблон("/api/v1/companies/%1/route-info?date=%2&per_page=%3", 
		НастройкиАвторизации.НастройкиIdКомпании, Формат(Дата, "ДФ=гггг-ММ-дд"), Формат(НаСтранице, "ЧГ=")); 
	
	РезультатВыполнения = ВыполнитьRestЗапрос(НастройкиАвторизации, Метод); 
	
	Попытка
		Если РезультатВыполнения.Результат Тогда 
			Если ТипЗнч(РезультатВыполнения.ОтветСтруктура) = Тип("Массив") Тогда 
				РезультатВыполнения.Сообщение = СтрШаблон("Маршруты в количестве %1 на %2 получены", 
					РезультатВыполнения.ОтветСтруктура.Количество(), Формат(Дата, "ДФ=дд.ММ.гггг")); 
			Иначе
				РезультатВыполнения.Результат = Ложь;  
				РезультатВыполнения.Сообщение = "Ошибка при получении маршрутов " + 
					?(РезультатВыполнения.ОтветСтруктура.Свойство("message"), РезультатВыполнения.ОтветСтруктура.message, "");
			КонецЕсли;
		КонецЕсли
	Исключение
	КонецПопытки;
	
	Возврат РезультатВыполнения;
	
КонецФункции      

