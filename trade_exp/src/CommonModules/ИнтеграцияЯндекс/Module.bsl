#Область СобытияДоставки

Функция ПолучитьСобытияДоставки(ДатаНачала, ДатаОкончания, Логирование = Истина) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = Новый Структура("Результат, ДатаНачала, ДатаОкончания, Сообщение", Истина, ТекущаяДатаСеанса(), Дата(1, 1, 1), "");
	РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + Строка(РезультатВыполнения.ДатаНачала) + Символы.ПС;
	
	ДатаНачала = НачалоДня(ДатаНачала);
	ДатаОкончания = НачалоДня(ДатаОкончания); 
	КоличествоДней = (ДатаОкончания - ДатаНачала) / (60 * 60 * 24);
		
	Попытка
		НастройкиАвторизации = ПолучитьНастройкиАвторизации();
		
		// Получить маршруты и заказы из мониторинга за период
		МаршрутыМониторинга = МаршрутыМониторинга();
		Для Счетчик = 0 По КоличествоДней Цикл
			
			ПолучениеМаршрутов = ВыполнитьЗапросПолучениеМаршруты(НастройкиАвторизации, ДатаНачала + Счетчик * 60 * 60 * 24);
			Если Не ПолучениеМаршрутов.Результат Или ПолучениеМаршрутов.ОтветСтруктура.Количество() = 0 Тогда
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ПолучениеМаршрутов.Сообщение + Символы.ПС;
				Продолжить;
			КонецЕсли;
			
			ДобавитьМаршрутыМониторинга(МаршрутыМониторинга, ПолучениеМаршрутов.ОтветСтруктура)
		КонецЦикла;

		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + 
			СтрШаблон("Заказы мониторинга Яндекса за период с %1 по %2 в количестве %3 получены", 
			Формат(ДатаНачала, "ДФ=дд.ММ.гггг"), Формат(ДатаОкончания, "ДФ=дд.ММ.гггг"), МаршрутыМониторинга.Количество()) + Символы.ПС;
		
		// Определить заказы на доставку по номеру заказа
		МаршрутыЗаказыДляОтслеживания = ПолучитьМаршрутыЗаказыДляОтслеживания(МаршрутыМониторинга);

		Если ЗначениеЗаполнено(МаршрутыЗаказыДляОтслеживания.НенайденныеЗаказы) Тогда
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + МаршрутыЗаказыДляОтслеживания.НенайденныеЗаказы + Символы.ПС;
		КонецЕсли; 
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + 
			СтрШаблон("Определены текущие заказы для отслеживания в количестве %1", МаршрутыМониторинга.Количество()) + Символы.ПС;
		
		// Получить события заказов
		СобытияЗаказов = СобытияЗаказов();
		Для Каждого Маршрут Из МаршрутыЗаказыДляОтслеживания.Маршруты Цикл
			
			ПолучениеЗаказыМаршрута = ВыполнитьЗапросПолучениеЗаказыМаршрута(НастройкиАвторизации, Маршрут.ИдентификаторМаршрута);
			Если Не ПолучениеЗаказыМаршрута.Результат Тогда
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ПолучениеЗаказыМаршрута.Сообщение;
				Продолжить;
			КонецЕсли;
			
			ДобавитьСобытияЗаказов(СобытияЗаказов, ПолучениеЗаказыМаршрута.ОтветСтруктура, МаршрутыЗаказыДляОтслеживания.Заказы);
		КонецЦикла;
		
		ЗаписьСобытийДоставки = ЗаписатьСобытияДоставки(СобытияЗаказов);
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + 
			СтрШаблон("Добавлено %1 событий, не добавлено %2 событий", ЗаписьСобытийДоставки.КоличествоДобавлено, ЗаписьСобытийДоставки.КоличествоНедобавлено) + Символы.ПС;
		Если Не ЗаписьСобытийДоставки.Результат Тогда
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ЗаписьСобытийДоставки.Сообщение;
		КонецЕсли;
		
		// Получить трекинг заказов
		Для Каждого Заказ Из МаршрутыЗаказыДляОтслеживания.Трекинги Цикл 
			ПолучениеТрекинг = ВыполнитьЗапросПолучениеТрекинг(НастройкиАвторизации, Заказ.ИдентификаторЗаказа);	
			Если Не ПолучениеТрекинг.Результат Тогда
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ПолучениеТрекинг.Сообщение;
				Продолжить;
			КонецЕсли;	
			ДобавитьТрекинги(Заказ, ПолучениеТрекинг.ОтветСтруктура);
		КонецЦикла;
		
		ЗаписьТрекингов = ЗаписатьТрекинги(МаршрутыЗаказыДляОтслеживания.Трекинги);
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + 
			СтрШаблон("Добавлено %1 трекингов, не добавлено %2 трекингов", ЗаписьТрекингов.КоличествоДобавлено, ЗаписьТрекингов.КоличествоНедобавлено) + Символы.ПС;
		Если Не ЗаписьТрекингов.Результат Тогда
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ЗаписьТрекингов.Сообщение;
		КонецЕсли;		
		
	Исключение
		РезультатВыполнения.Результат = Ложь;
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + "Не удалось получить события доставки: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + Символы.ПС;
	КонецПопытки;	
	
	РезультатВыполнения.ДатаОкончания = ТекущаяДатаСеанса();
	РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + Строка(РезультатВыполнения.ДатаОкончания) + Символы.ПС;
	
	Если Логирование Тогда
		ЗаписатьЛог(НастройкиАвторизации.НастройкиПапкаЛогов, РезультатВыполнения);
	КонецЕсли;	
	
	Возврат РезультатВыполнения;
	
КонецФункции

