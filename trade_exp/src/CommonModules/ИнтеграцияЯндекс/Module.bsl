Функция ОбновитьТоварыМониторинг(ТоварыКОтправке, ИдентификаторыЗаказов, НастройкиАвторизации, ЗапросыДляЛогов)     
	
	РезультатВыполнения = ПараметрыВыполнения("Обновление товаров в мониторинге");
	
	Попытка     
		Для Каждого Заказ Из ИдентификаторыЗаказов Цикл
	
			// Получить товарный состав заказа
			ПолучениеТоварногоСостава = ВыполнитьЗапросПолученияТоварногоСостава(Заказ.ИдЗаказа, НастройкиАвторизации);
			
			ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ПолучениеТоварногоСоставаЗаказа" + Заказ.НомерЗаказа + "Запрос", ПолучениеТоварногоСостава.Метод);		
			ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ПолучениеТоварногоСоставаЗаказа" + Заказ.НомерЗаказа + "Ответ", ПолучениеТоварногоСостава.JsonОтвет,,, Не ПолучениеТоварногоСостава.Результат);
			
			РезультатВыполнения.Результат = ПолучениеТоварногоСостава.Результат;
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ПолучениеТоварногоСостава.Сообщение + Символы.ПС;
			
			Если Не РезультатВыполнения.Результат Тогда
				Прервать;
			КонецЕсли;
			
			// Удалить товарный состав заказа
			Если ПолучениеТоварногоСостава.ОтветСтруктура.results.Количество() > 0 Тогда
				
				УдалениеТоварногоСостава = ВыполнитьЗапросУдаленияТоварногоСостава(Заказ.ИдЗаказа, НастройкиАвторизации);
				
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "УдалениеТоварногоСоставаЗаказа" + Заказ.НомерЗаказа + "Запрос", УдалениеТоварногоСостава.Метод);		
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "УдалениеТоварногоСоставаЗаказа" + Заказ.НомерЗаказа + "Ответ", УдалениеТоварногоСостава.JsonОтвет,,, Не УдалениеТоварногоСостава.Результат);
				
				РезультатВыполнения.Результат = УдалениеТоварногоСостава.Результат;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + УдалениеТоварногоСостава.Сообщение + Символы.ПС;
				
				Если Не РезультатВыполнения.Результат Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли;
		
			// Добавить товарный состав заказа
			ТоварныйСостав = Новый Массив();
			Для Каждого Товар Из ТоварыКотправке Цикл
				
				Если Товар.НомерЗаказа <> Заказ.НомерЗаказа Тогда
					Продолжить;
				КонецЕсли;
				
				ДанныеТовара = ПараметрыТоваров();
				ЗаполнитьЗначенияСвойств(ДанныеТовара, Товар);
				ТоварныйСостав.Добавить(ДанныеТовара);
			КонецЦикла;
			
			Если ТоварныйСостав.Количество() > 0 Тогда
				
				ОбновлениеТоварногоСостава = ВыполнитьЗапросОбновлениеТоварногоСостава(ТоварныйСостав, Заказ.ИдЗаказа, НастройкиАвторизации);
				
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеТоварногоСоставаЗаказа" + Заказ.НомерЗаказа + "Запрос", ОбновлениеТоварногоСостава.Метод + Символы.ПС + "Тело:" + ОбновлениеТоварногоСостава.Тело);		
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеТоварногоСоставаЗаказа" + Заказ.НомерЗаказа + "Ответ", ОбновлениеТоварногоСостава.JsonОтвет,,, Не ОбновлениеТоварногоСостава.Результат);
				
				РезультатВыполнения.Результат = ОбновлениеТоварногоСостава.Результат;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ОбновлениеТоварногоСостава.Сообщение + Символы.ПС;
				
				Если Не РезультатВыполнения.Результат Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли;

		КонецЦикла;		

	Исключение
		РезультатВыполнения.Сообщение = "Ошибка при обновлении заказов мониторинга: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;      
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ВыполнитьЗапросПолученияТоварногоСостава(ИдЗаказа, НастройкиАвторизации) Экспорт
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url		= НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод		= "/api/v1/companies/"  + НастройкиАвторизации.IdКомпании + "/orders/" + Формат(ИдЗаказа, "ЧГ=") + "/items";
	ПараметрыRest.Заголовки	= ПолучитьЗаголовкиТокен(НастройкиАвторизации);
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	
	Если RestЗапрос.Результат Тогда
		Если ТипЗнч(RestЗапрос.ОтветСтруктура) = Тип("Структура")
			И RestЗапрос.ОтветСтруктура.Свойство("results") 
			И ТипЗнч(RestЗапрос.ОтветСтруктура.results) = Тип("Массив") Тогда
  
			RestЗапрос.Результат = Истина;
			RestЗапрос.Сообщение = СтрШаблон("Получен товарный состав по идентификатору заказа %1", Формат(ИдЗаказа, "ЧГ=")); 
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСтруктура);
		КонецЕсли;
	КонецЕсли;
	
	Возврат RestЗапрос;	
	
КонецФункции	

Функция ВыполнитьЗапросУдаленияТоварногоСостава(ИдЗаказа, НастройкиАвторизации) Экспорт
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url		= НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод		= "/api/v1/companies/"  + НастройкиАвторизации.IdКомпании + "/orders/" + Формат(ИдЗаказа, "ЧГ=") + "/items";
	ПараметрыRest.ТипМетода = "DELETE";
	ПараметрыRest.Заголовки	= ПолучитьЗаголовкиТокен(НастройкиАвторизации);
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	
	Если Не RestЗапрос.Результат 
		И ТипЗнч(RestЗапрос.JsonОтвет) = Тип("Строка")
		И Лев(RestЗапрос.JsonОтвет, 4) = "null" Тогда
  
			RestЗапрос.Результат = Истина;
			RestЗапрос.Сообщение = СтрШаблон("Удален товарный состав по идентификатору заказа %1", Формат(ИдЗаказа, "ЧГ=")); 
	Иначе
		RestЗапрос.Результат = Ложь;
		RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСтруктура);
	КонецЕсли;
	
	Возврат RestЗапрос;	
	
КонецФункции

Функция ВыполнитьЗапросОбновлениеТоварногоСостава(ТоварКОтправке, ИдЗаказа, НастройкиАвторизации) Экспорт
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url		= НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод		= "/api/v1/companies/"  + НастройкиАвторизации.IdКомпании + "/orders/" + Формат(ИдЗаказа, "ЧГ=") + "/items";
	ПараметрыRest.ТипМетода = "POST";
	ПараметрыRest.Заголовки	= ПолучитьЗаголовкиТокен(НастройкиАвторизации);
	ПараметрыRest.Тело		= ТоварКОтправке;
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	
	Если RestЗапрос.Результат Тогда
		Если ТипЗнч(RestЗапрос.ОтветСтруктура) = Тип("Массив")
			И RestЗапрос.ОтветСтруктура.Количество() > 0 Тогда   

			RestЗапрос.Результат = Истина;
			RestЗапрос.Сообщение = СтрШаблон("Товары по идентификтору %1 добавлены в количестве %2", 
			Формат(ИдЗаказа, "ЧГ="), RestЗапрос.ОтветСтруктура.Количество()); 
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСтруктура);
		КонецЕсли;
	КонецЕсли;
	
	Возврат RestЗапрос;	
	
