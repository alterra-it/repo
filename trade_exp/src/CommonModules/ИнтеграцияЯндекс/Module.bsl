#Область Авторизация

Функция ПолучитьАвторизацию()
	
	НастройкиАвторизации = НастройкиАвторизации();
	
	ДополнительнаяОбработка = ПолучитьОбработку();
	Если Не ДополнительнаяОбработка.Пустая() Тогда

		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();					
		Если НастройкиХранилища	<> Неопределено Тогда  
			
			Если НастройкиХранилища.Свойство("IdКомпании") Тогда
				НастройкиАвторизации.IdКомпании = НастройкиХранилища.IdКомпании;
			КонецЕсли;
				 
			Если НастройкиХранилища.Свойство("НастройкиКлючAPIЯндексМаршрутизация") Тогда
				НастройкиАвторизации.ApiКлюч = НастройкиХранилища.НастройкиКлючAPIЯндексМаршрутизация;
			КонецЕсли;

			Если НастройкиХранилища.Свойство("НастройкиТокенЯндексМониторинг") Тогда
				НастройкиАвторизации.Токен = НастройкиХранилища.НастройкиТокенЯндексМониторинг;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	 
	Возврат НастройкиАвторизации;	
	
КонецФункции	

