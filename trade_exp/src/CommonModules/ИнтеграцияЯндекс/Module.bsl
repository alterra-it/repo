#Область Склады

Функция ОбновитьСкладыМониторинг(СкладыКОтправке, НастройкиАвторизации, ЗапросыДляЛогов)     
	
	РезультатВыполнения = ПараметрыВыполнения("Обновление складов в мониторинге");
	
	Попытка     
		// Получение списка складов
		СкладыМониторинг = ВыполнитьЗапросПолучениеСклады(НастройкиАвторизации);
		РезультатВыполнения.Результат = СкладыМониторинг.Результат; 
		РезультатВыполнения.Сообщение = СкладыМониторинг.Сообщение + Символы.ПС;
		
		ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "СписокСкладовЗапрос", СкладыМониторинг.Метод);		
		ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "СписокСкладовОтвет", СкладыМониторинг.JsonОтвет, ,, Не СкладыМониторинг.Результат);
	
		Если СкладыМониторинг.Результат Тогда  
		
			Сч = СкладыКОтправке.Количество() - 1;
			Пока Сч >= 0 Цикл          
				Для Каждого СкладМониторинг Из СкладыМониторинг.ОтветСтруктура Цикл
					Если СкладыКОтправке[Сч].number = СкладМониторинг.number Тогда
						СкладыКОтправке.Удалить(Сч);
						Прервать;
					КонецЕсли;
				КонецЦикла;
			  Сч = Сч - 1;
			КонецЦикла;		
			
			// Обновить склады, которых нет в мониторинге
			Если СкладыКОтправке.Количество() > 0 Тогда		
				ОбновлениеСклады = ВыполнитьЗапросОбновлениеСклады(СкладыКОтправке, НастройкиАвторизации);    
				
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеСкладовЗапрос", ОбновлениеСклады.Метод + Символы.ПС + "Тело:" + ОбновлениеСклады.Тело);		
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеСкладовОтвет", ОбновлениеСклады.JsonОтвет,,, Не ОбновлениеСклады.Результат);
				
				РезультатВыполнения.Результат = ОбновлениеСклады.Результат;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ОбновлениеСклады.Сообщение + Символы.ПС;
			КонецЕсли;       
		
		Иначе
			РезультатВыполнения.Сообщение = СкладыМониторинг.Сообщение;
		КонецЕсли;
		
	Исключение
		РезультатВыполнения.Сообщение = "Ошибка при обновлении складов мониторинга: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;      
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ВыполнитьЗапросПолучениеСклады(НастройкиАвторизации) Экспорт
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url		= НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод		= "/api/v1/companies/"  + НастройкиАвторизации.IdКомпании + "/depots";
	ПараметрыRest.Заголовки	= ПолучитьЗаголовкиТокен(НастройкиАвторизации);
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	
	Если RestЗапрос.Результат Тогда
		// В ответе должен быть массив складов
		Если ТипЗнч(RestЗапрос.ОтветСтруктура) = Тип("Массив") Тогда
			RestЗапрос.Результат = Истина;
			RestЗапрос.Сообщение = "Получен список складов";				
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСтруктура);
		КонецЕсли;

	КонецЕсли;
	
	Возврат RestЗапрос;		
	
КонецФункции

Функция ВыполнитьЗапросОбновлениеСклады(СкладыКотправке, НастройкиАвторизации) Экспорт
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url		= НастройкиАвторизации.АдресСервера;
	ПараметрыRest.Метод		= "/api/v1/companies/"  + НастройкиАвторизации.IdКомпании + "/depots-batch";
	ПараметрыRest.ТипМетода = "POST";
	ПараметрыRest.Заголовки	= ПолучитьЗаголовкиТокен(НастройкиАвторизации);
	ПараметрыRest.Тело		= СкладыКОтправке;
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	
	Если RestЗапрос.Результат Тогда
		Если ТипЗнч(RestЗапрос.ОтветСтруктура) = Тип("Структура") 
			И RestЗапрос.ОтветСтруктура.Свойство("inserted") И RestЗапрос.ОтветСтруктура.Свойство("updated") Тогда   

			RestЗапрос.Результат = Истина;
			RestЗапрос.Сообщение = СтрШаблон("Склады обновлены: добавлено %1, редактировано %2", 
			RestЗапрос.ОтветСтруктура.inserted, RestЗапрос.ОтветСтруктура.updated); 
		Иначе
			RestЗапрос.Результат = Ложь;
			RestЗапрос.Сообщение = ПолучитьТекстОшибки(RestЗапрос.ОтветСтруктура);
		КонецЕсли;
	КонецЕсли;
	
	Возврат RestЗапрос;	
	
КонецФункции

