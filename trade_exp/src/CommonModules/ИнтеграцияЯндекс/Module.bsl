#Область Пропуска                   

Функция ПолучитьПропускНаСклад(Рейс)
	
	QrТип 			= "QRCODE";
	QrКод 			= ГенерацияШтрихкода.СформироватьQRкод(Рейс);  
	QrОписание 		= "Пропуск на склад";
	
	Возврат ПолучитьСсылкуQrШтрихкод(QrТип, QrКод, QrОписание);
	
КонецФункции

Функция ПолучитьОтгрузкуМаркетплейса(Рейс, ВозвратТовара = Ложь)
	
	ОтгрузкаМаркетПлейс = ИнтеграцияМаркетплейсы.ПодтвердитьОтгрузку(Рейс, ВозвратТовара);		   
	
	ШкТип 			= "CODE128";
	ШкКод 			= ОтгрузкаМаркетПлейс.Штрихкод;  
	ШкОписание 		= ?(Не ВозвратТовара, "Отгрузка ", "Возврат ") + ВРег(ОтгрузкаМаркетПлейс.Маркетплейс);

	Если ЗначениеЗаполнено(ШкКод) Тогда
		СсылкаОтгрузки = ПолучитьСсылкуQrШтрихкод(ШкТип, ШкКод, ШкОписание);
	Иначе
		СсылкаОтгрузки = "";	
	КонецЕсли;
	
	Возврат Новый Структура ("ЗаказНаДоставку, СсылкаОтгрузки, ОписаниеОтгрузки", ОтгрузкаМаркетПлейс.ЗаказНаДоставку, СсылкаОтгрузки, ШкОписание);
	
КонецФункции

Функция ПолучитьСсылкуQrШтрихкод(QrШкТип, QrКод, QrОписание)
	
	СсылкаНаПропуск = "";
	
	ПараметрыRest = ИнтеграцияREST.ПараметрыВыполненияRest();
	
	ПараметрыRest.url		= "tg-alterra.ru";
	ПараметрыRest.Метод		= "/api/v1/barcode.create";
	ПараметрыRest.ТипМетода = "POST";

	ПараметрыRest.Тело = Новый Структура;
	ПараметрыRest.Тело.Вставить("codeType", 	QrШкТип);
	ПараметрыRest.Тело.Вставить("content", 		QrКод);   
	ПараметрыRest.Тело.Вставить("description", 	QrОписание);   
	
	RestЗапрос = ИнтеграцияREST.ВыполнитьRestЗапрос(ПараметрыRest);
	
	Если RestЗапрос.Результат Тогда
		Если ТипЗнч(RestЗапрос.ОтветСтруктура) = Тип("Структура")
			И RestЗапрос.ОтветСтруктура.Свойство("error")  
			И ТипЗнч(RestЗапрос.ОтветСтруктура.error) = Тип("Булево")
			И Не RestЗапрос.ОтветСтруктура.error 
			И RestЗапрос.ОтветСтруктура.Свойство("data")
			И ТипЗнч(RestЗапрос.ОтветСтруктура.data) = Тип("Структура") 
			И RestЗапрос.ОтветСтруктура.data.Свойство("link") Тогда  
			
			СсылкаНаПропуск = RestЗапрос.ОтветСтруктура.data.link;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СсылкаНаПропуск;	   
	
КонецФункции	

