Функция ОбновитьЗаказыМониторинг(ЗаказыКОтправке, ИдентификаторыРейсов, ИдентификаторыЗаказов, НастройкиАвторизации, ЗапросыДляЛогов)     
	
	РезультатВыполнения = ПараметрыВыполнения("Обновление заказов в мониторинге");
	
	Попытка     
		// Обновить маршруты
		Если ЗаказыКОтправке.Количество() > 0 Тогда		
			ОбновлениеЗаказы = ВыполнитьЗапросОбновлениеЗаказы(ЗаказыКОтправке, НастройкиАвторизации);    
			
			ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеЗаказыЗапрос", ОбновлениеЗаказы.Метод + Символы.ПС + "Тело:" + ОбновлениеЗаказы.Тело);		
			ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеЗаказыОтвет", ОбновлениеЗаказы.JsonОтвет,,, Не ОбновлениеЗаказы.Результат);
			
			РезультатВыполнения.Результат = ОбновлениеЗаказы.Результат;
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ОбновлениеЗаказы.Сообщение + Символы.ПС;
		КонецЕсли;   
		    
		// Получить идентификаторы заказов
		Если РезультатВыполнения.Результат Тогда
			
			Для Каждого Рейс Из ИдентификаторыРейсов Цикл
				
				ПолучениеЗаказов = ВыполнитьЗапросПолученияЗаказов(Рейс.ИдРейса, НастройкиАвторизации);
				
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ПолучениеЗаказовМаршрута" + Рейс.НомерРейса + "Запрос", ПолучениеЗаказов.Метод);		
				ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ПолучениеЗаказовМаршрута" + Рейс.НомерРейса + "Ответ", ПолучениеЗаказов.JsonОтвет,,, Не ПолучениеЗаказов.Результат);
				
				РезультатВыполнения.Результат = ПолучениеЗаказов.Результат;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + ПолучениеЗаказов.Сообщение + Символы.ПС;
				
				Если Не ПолучениеЗаказов.Результат Тогда
					Прервать;
				КонецЕсли;	
				
				Для Каждого Заказ Из ИдентификаторыЗаказов Цикл
					
					Если Рейс.НомерРейса <> Заказ.НомерРейса Тогда
						Продолжить;
					КонецЕсли;
				
					Для Каждого ЗаказМаршрута Из ПолучениеЗаказов.ОтветСтруктура Цикл
						
						Если Заказ.НомерЗаказа <> ЗаказМаршрута.number Тогда
							Продолжить;
						КонецЕсли; 
						
						Заказ.ИдЗаказа = ЗаказМаршрута.id;
						Прервать;

					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли; 		    

	Исключение
		РезультатВыполнения.Сообщение = "Ошибка при получении заказов маршрута: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;      
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции

