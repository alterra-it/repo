#Область Мониторинг

#Область ОтправкаПолучение

Функция ОтправитьВМониторинг(Рейсы, НастройкиОбслуживанияЗаказов, НастройкиАвторизации = Неопределено) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатВыполнения = ПараметрыВыполнения("Отправка в мониторинг", Истина);
	ЗапросыДляЛогов = ЗапросыДляЛогов();
	Идентификатор = "";
	Филиал = Строка(НастройкиОбслуживанияЗаказов.Филиал);
	
	Если Рейсы.Количество() > 0 Тогда
		
		Попытка
			
			Если Не ЗначениеЗаполнено(НастройкиАвторизации) Тогда
				НастройкиАвторизации = ПолучитьАвторизацию();
			КонецЕсли;
			
			Если ТипЗнч(НастройкиАвторизации) = Тип("Структура")  
				И НастройкиАвторизации.Свойство("IdКомпании") И ЗначениеЗаполнено(НастройкиАвторизации.IdКомпании) 
				И НастройкиАвторизации.Свойство("Токен") И ЗначениеЗаполнено(НастройкиАвторизации.Токен) Тогда
			
				МаршрутыОтправки = ПолучитьМаршрутыОтправки(Рейсы, НастройкиОбслуживанияЗаказов);
				Идентификатор = ПолучитьРейсы(МаршрутыОтправки.МассивРейсов, Истина);
				Филиал = ?(Не ЗначениеЗаполнено(Филиал), ПолучитьФилиал(МаршрутыОтправки.МассивСкладов), Филиал);
				РезультатВыполнения.Лог = РезультатВыполнения.Лог + ПолучитьРейсы(МаршрутыОтправки.МассивРейсов) + Символы.ПС; 
			
				Если МаршрутыОтправки.МассивРейсов.Количество() > 0 Или МаршрутыОтправки.МассивЗаказов.Количество() > 0 Тогда
					
					// Обновление складов
					ОбновлениеСкладыМониторинг = ОбновитьСкладыМониторинг(МаршрутыОтправки.МассивСкладов, НастройкиАвторизации, ЗапросыДляЛогов);
					РезультатВыполнения.Сообщение = ОбновлениеСкладыМониторинг.Сообщение;
					РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
					
					Если ОбновлениеСкладыМониторинг.Результат Тогда
					
						// Обновление пользователей  
						ОбновлениеПользователиМобильноеПриложение = ОбновитьПользователиМобильноеПриложение(МаршрутыОтправки.МассивКурьеров, НастройкиАвторизации, ЗапросыДляЛогов);   
						РезультатВыполнения.Сообщение = ОбновлениеПользователиМобильноеПриложение.Сообщение;
						РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
						
						Если ОбновлениеПользователиМобильноеПриложение.Результат Тогда 
	
							// Обновление курьеров
							ОбновлениеКурьерыМониторинг = ОбновитьКурьерыМониторинг(МаршрутыОтправки.МассивКурьеров, НастройкиАвторизации, ЗапросыДляЛогов);   
							РезультатВыполнения.Сообщение = ОбновлениеКурьерыМониторинг.Сообщение;
							РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
							 		
							 // Обновление маршрутов
							 Если ОбновлениеКурьерыМониторинг.Результат Тогда
								
								ОбновлениеМаршрутыМониторинг = ОбновитьМаршрутыМониторинг(МаршрутыОтправки.МассивРейсов, МаршрутыОтправки.ИдентификаторыРейсов, НастройкиАвторизации, ЗапросыДляЛогов); 
								РезультатВыполнения.Сообщение = ОбновлениеМаршрутыМониторинг.Сообщение;
								РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
								
								// Наполнение маршрутов заказами (если созданы маршруты)
								Если ОбновлениеМаршрутыМониторинг.Результат Тогда
									
									ОбновлениеЗаказыМониторинг = ОбновитьЗаказыМониторинг(МаршрутыОтправки.МассивЗаказов, 
										МаршрутыОтправки.ИдентификаторыРейсов, МаршрутыОтправки.ИдентификаторыЗаказов, НастройкиАвторизации, ЗапросыДляЛогов);
									РезультатВыполнения.Сообщение = ОбновлениеЗаказыМониторинг.Сообщение;
									РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
									
									// Задать последовательность точек - склад, заказы
									Если ОбновлениеЗаказыМониторинг.Результат Тогда
										ОбновлениеТочекМониторинг = ОбновитьТочкиМониторинг(МаршрутыОтправки.ИдентификаторыРейсов, МаршрутыОтправки.МассивТочек, 
											НастройкиАвторизации, ЗапросыДляЛогов);
										РезультатВыполнения.Сообщение = ОбновлениеТочекМониторинг.Сообщение;
										РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
									КонецЕсли;
									
									// Добавить товарные составы к заказам
									Если ОбновлениеЗаказыМониторинг.Результат И ОбновлениеТочекМониторинг.Результат Тогда
										
										ОбновлениеТоварыМониторинг = ОбновитьТоварыМониторинг(МаршрутыОтправки.МассивТоваров, МаршрутыОтправки.ИдентификаторыЗаказов, НастройкиАвторизации, ЗапросыДляЛогов);
										РезультатВыполнения.Сообщение = ОбновлениеТоварыМониторинг.Сообщение;
										РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение;
										
										РезультатВыполнения.Результат = ОбновлениеТоварыМониторинг.Результат;
									КонецЕсли;
								КонецЕсли;
							 КонецЕсли;
						 
						 КонецЕсли;
					КонецЕсли;		
					
				Иначе
					РезультатВыполнения.Сообщение = "Отсутствуют данные для отправки в мониторинг";
					РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение + Символы.ПС;
				КонецЕсли;		
		
			Иначе
				РезультатВыполнения.Сообщение = "Не заданы параметры авторизации";
				РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение + Символы.ПС;
			КонецЕсли;
		
		Исключение
			РезультатВыполнения.Сообщение = "Ошибка отправки в мониторинг: "+ КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение + Символы.ПС;
		КонецПопытки;
		
	Иначе
		РезультатВыполнения.Сообщение = "Не выбраны рейсы для отправки в мониторинг";
		РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение + Символы.ПС;		
	КонецЕсли;
	
	РезультатВыполнения.Сообщение = "Рейсы в мониторинг " + ?(РезультатВыполнения.Результат, "отправлены", "не отправлены" + Символы.ПС + РезультатВыполнения.Сообщение);
	РезультатВыполнения.Лог = РезультатВыполнения.Лог + РезультатВыполнения.Сообщение + Символы.ПС;
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	
	ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ВыполнениеОтправкаМониторинг", РезультатВыполнения.Лог, 
		Филиал, Идентификатор, Не РезультатВыполнения.Результат);
	ЗаписатьЛогЗапросов(НастройкиОбслуживанияЗаказов.ПапкаЛогов, ЗапросыДляЛогов);
	
	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПолучитьМаршрутыОтправки(Рейсы, НастройкиОбслуживанияЗаказов)

	Данные = ПараметрыМаршрутов();
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ 
		|	Рейс.Ссылка КАК Рейс,
		|	Рейс.Номер КАК НомерРейса,
		|	Рейс.ВремяВыезда КАК ДатаМаршрута,
		|	СтруктураПредприятия.Ссылка КАК Подразделение,
		|	СтруктураПредприятия.Код КАК ПодразделениеКод,
		|	СтруктураПредприятия.Наименование КАК ПодразделениеНаименование,
		|	СтруктураПредприятия.Адрес КАК ПодразделениеАдрес,
		|	СтруктураПредприятия.Широта КАК ПодразделениеШирота,
		|	СтруктураПредприятия.Долгота КАК ПодразделениеДолгота,
		|	Рейс.Водитель КАК Водитель,
		|	Рейс.Автомобиль КАК Автомобиль,
		|	Рейс.Автомобиль.Наименование КАК АвтомобильНаименование,
		|	Рейс.Автомобиль.ГрузоподъемностьВТоннах КАК АвтомобильГрузоподъемностьВТоннах,
		|	КонтактнаяИнформацияФЛ.НомерТелефона КАК НомерТелефонаВодителя	
		|ПОМЕСТИТЬ втРейсы	
		|ИЗ      
		|	Документ.ЗаданиеНаПеревозкуРейс КАК Рейс   
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ПО Рейс.Подразделение = СтруктураПредприятия.Ссылка
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязьВодителейТСПартнеров КАК СвязьВодителейТСПартнеров
		|		ПО Рейс.Водитель = СвязьВодителейТСПартнеров.Водитель
		|		И Рейс.Автомобиль = СвязьВодителейТСПартнеров.Автомобиль
		|		И Рейс.ПеревозчикПартнер = СвязьВодителейТСПартнеров.ПеревозчикПартнер
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.КонтактнаяИнформация КАК КонтактнаяИнформацияФЛ
		|		ПО Рейс.Водитель = КонтактнаяИнформацияФЛ.Ссылка
		|		И КонтактнаяИнформацияФЛ.НомерТелефона <> &ПустаяСтрока
		|		И КонтактнаяИнформацияФЛ.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица)
		|ГДЕ
		|	Рейс.Ссылка В (&Рейсы)		
		|;             
		|////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Подразделение КАК Подразделение,
		|	ПодразделениеКод КАК Номер,
		|	ПодразделениеНаименование КАК Наименование,
		|	ПодразделениеАдрес КАК Адрес,
		|	ПодразделениеШирота КАК Широта,
		|	ПодразделениеДолгота КАК Долгота
		|ИЗ
		|	втРейсы
		|;
		|////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Водитель,
		|	Автомобиль,
		|	АвтомобильНаименование,
		|	АвтомобильГрузоподъемностьВТоннах,
		|	НомерТелефонаВодителя	
		|ИЗ 
		|	втРейсы
		|;     
		|////////////////////////////////////////////////////////////  
		|ВЫБРАТЬ 
		|	Рейс,
		|	НомерРейса,
		|	ДатаМаршрута,        
		|	ПодразделениеКод КАК НомерСклада,
		|	АвтомобильГрузоподъемностьВТоннах,
		|	НомерТелефонаВодителя	
		|ИЗ 
		|	втРейсы
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втРейсы.Рейс,
		|	втРейсы.НомерРейса,
		|	ЗаказНаДоставку.Ссылка КАК ЗаказНаДоставку, 
		|	ЗаказНаДоставку.Номер КАК НомерЗаказа,
		|	ЗаказНаДоставку.ВремяДоставкиС КАК ВремяДоставкиС,
		|	ЗаказНаДоставку.ВремяДоставкиПо КАК ВремяДоставкиПо,
		|	ЗаказНаДоставку.ТелефонКлиентаНаВыгрузке КАК ТелефонКлиента,
		|	ЗаказНаДоставку.Широта,
		|	ЗаказНаДоставку.Долгота,
		|	ЗаказНаДоставку.АдресДоставки КАК АдресПолучателя,
		|	ЗаказНаДоставку.Партнер.Наименование КАК НаименованиеПолучателя,
		|	ЗаказНаДоставку.Объем,
		|	ЗаказНаДоставку.Вес,      
		|	ЗаказНаДоставку.ВидДоставки,
		|	РейсОснования.НомерСтроки,
		|	ЗаказНаДоставку.Комментарий,
		|	ЗаказНаДоставку.НужнаИнкассация,
		|	ЗаказНаДоставку.Инкассация КАК СуммаИнкассации,
		|	ЗаказНаДоставку.Сдача,
		|	ЗаказНаДоставку.ОплатаБанковскойКартой 
		|ПОМЕСТИТЬ втЗаказыНаДоставку	
		|ИЗ	
		|	втРейсы
		|	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.Основания КАК РейсОснования
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставку
		|			ПО РейсОснования.Документ = ЗаказНаДоставку.Ссылка
		|    	ПО втРейсы.Рейс = РейсОснования.Ссылка
		|;     
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ *
		|ИЗ втЗаказыНаДоставку   
		|УПОРЯДОЧИТЬ ПО
		|	НомерРейса, НомерСтроки
		|;                   
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втЗаказыНаДоставку.Рейс, 
		|	втЗаказыНаДоставку.НомерРейса, 
		|	втЗаказыНаДоставку.ЗаказНаДоставку,
		|	втЗаказыНаДоставку.НомерЗаказа,
		|	ДокументПродажи.Ссылка КАК ДокументПродажи, 
		|	ДокументПродажи.РаспределитьТранспортные,     
		|	ДокументПродажиТовары.НомерСтроки,
		|	ДокументПродажиТовары.Номенклатура,
		|	ДокументПродажиТовары.Цена,
		|	ДокументПродажиТовары.КоличествоУпаковок КАК Количество,
		|	ДокументПродажиТовары.Сумма,
		|	ДокументПродажиТовары.СуммаРТ
		|ПОМЕСТИТЬ втТовары
		|ИЗ             
		|	втЗаказыНаДоставку  
		|		СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
		|			СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ДокументПродажи
		|				ПО ЗаказНаДоставкуОснования.Документ = ДокументПродажи.Ссылка	
		|			СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ДокументПродажиТовары
		|				ПО ДокументПродажи.Ссылка = ДокументПродажиТовары.Ссылка
		|				И НЕ ДокументПродажиТовары.Отменено	
		|			ПО втЗаказыНаДоставку.ЗаказНаДоставку = ЗаказНаДоставкуОснования.Ссылка
		|		
		|ОБЪЕДИНИТЬ ВСЕ
		|     
		|ВЫБРАТЬ
		|	втЗаказыНаДоставку.Рейс, 
		|	втЗаказыНаДоставку.НомерРейса, 
		|	втЗаказыНаДоставку.ЗаказНаДоставку,
		|	втЗаказыНаДоставку.НомерЗаказа,
		|	ДокументПродажи.Ссылка КАК ДокументПродажи, 
		|	ДокументПродажи.РаспределитьТранспортные,     
		|	ДокументПродажиТовары.НомерСтроки,
		|	ДокументПродажиТовары.Номенклатура,
		|	ДокументПродажиТовары.Цена,
		|	ДокументПродажиТовары.КоличествоУпаковок КАК Количество,
		|	ДокументПродажиТовары.Сумма,
		|	ДокументПродажиТовары.СуммаРТ
		|ИЗ             
		|	втЗаказыНаДоставку  
		|		СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
		|			СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК ДокументПродажи
		|				ПО ЗаказНаДоставкуОснования.Документ = ДокументПродажи.Ссылка	
		|			СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК ДокументПродажиТовары
		|				ПО ДокументПродажи.Ссылка = ДокументПродажиТовары.Ссылка	
		|			ПО втЗаказыНаДоставку.ЗаказНаДоставку = ЗаказНаДоставкуОснования.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ   
		|
		| ВЫБРАТЬ
		|	втЗаказыНаДоставку.Рейс, 
		|	втЗаказыНаДоставку.НомерРейса, 
		|	втЗаказыНаДоставку.ЗаказНаДоставку,
		|	втЗаказыНаДоставку.НомерЗаказа,
		|	ДокументПродажи.Ссылка КАК ДокументПродажи, 
		|	ЛОЖЬ КАК РаспределитьТранспортные,     
		|	ДокументПродажиТовары.НомерСтроки,
		|	ДокументПродажиТовары.Номенклатура,
		|	ДокументПродажиТовары.Цена,
		|	ДокументПродажиТовары.КоличествоУпаковок КАК Количество,
		|	ДокументПродажиТовары.Сумма,
		|	0 КАК СуммаРТ
		|ИЗ             
		|	втЗаказыНаДоставку  
		|		СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
		|			СОЕДИНЕНИЕ Документ.ЧекККМ КАК ДокументПродажи
		|				ПО ЗаказНаДоставкуОснования.Документ = ДокументПродажи.Ссылка	
		|			СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ДокументПродажиТовары
		|				ПО ДокументПродажи.Ссылка = ДокументПродажиТовары.Ссылка	
		|			ПО втЗаказыНаДоставку.ЗаказНаДоставку = ЗаказНаДоставкуОснования.Ссылка
		|			
		|ОБЪЕДИНИТЬ ВСЕ   
		|
		| ВЫБРАТЬ
		|	втЗаказыНаДоставку.Рейс, 
		|	втЗаказыНаДоставку.НомерРейса, 
		|	втЗаказыНаДоставку.ЗаказНаДоставку,
		|	втЗаказыНаДоставку.НомерЗаказа,
		|	ДокументПродажи.Ссылка КАК ДокументПродажи, 
		|	ЛОЖЬ КАК РаспределитьТранспортные,     
		|	ДокументПродажиТовары.НомерСтроки,
		|	ДокументПродажиТовары.Номенклатура,
		|	0 КАК Цена,
		|	ДокументПродажиТовары.КоличествоУпаковок КАК Количество,
		|	0 КАК Сумма,
		|	0 КАК СуммаРТ
		|ИЗ             
		|	втЗаказыНаДоставку  
		|		СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
		|			СОЕДИНЕНИЕ Документ.ПеремещениеТоваров КАК ДокументПродажи
		|				ПО ЗаказНаДоставкуОснования.Документ = ДокументПродажи.Ссылка	
		|			СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК ДокументПродажиТовары
		|				ПО ДокументПродажи.Ссылка = ДокументПродажиТовары.Ссылка	
		|			ПО втЗаказыНаДоставку.ЗаказНаДоставку = ЗаказНаДоставкуОснования.Ссылка
		|; 
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ	
		|	ПЕРВЫЕ 1000000
		|	АВТОНОМЕРЗАПИСИ() КАК НомерПоПорядку,
		|	втТовары.Рейс, 
		|	втТовары.НомерРейса, 
		|	втТовары.ЗаказНаДоставку,
		|	втТовары.НомерЗаказа,
		|	втТовары.ДокументПродажи,   
		|	втТовары.Номенклатура,                                     
		|	СпрНоменклатура.НаименованиеПолное КАК Наименование, 
		|	ВЫБОР     
		|		КОГДА втТовары.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР       
		|				КОГДА Сумма = 0 
		|				ТОГДА 0
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 0
		|				ИНАЧЕ ВЫРАЗИТЬ((втТовары.Сумма + втТовары.СуммаРТ) / втТовары.Количество КАК ЧИСЛО(15, 2))
		|			КОНЕЦ
		|		ИНАЧЕ ВЫРАЗИТЬ(втТовары.Сумма / втТовары.Количество КАК ЧИСЛО(15, 2))
		|	КОНЕЦ КАК Цена,
		|	ВЫБОР     
		|		КОГДА втТовары.РаспределитьТранспортные 
		|		ТОГДА   
		|			ВЫБОР 
		|				КОГДА СпрНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|				ТОГДА 1
		|				ИНАЧЕ втТовары.Количество
		|			КОНЕЦ
		|		ИНАЧЕ втТовары.Количество
		|	КОНЕЦ КАК Количество,
		|	ВЫБОР
		|		КОГДА 
		|			СпрНоменклатура.ВесЗнаменатель <> 0
		|		ТОГДА
		|			втТовары.Количество*СпрНоменклатура.ВесЧислитель/СпрНоменклатура.ВесЗнаменатель
		|		ИНАЧЕ           
		|			втТовары.Количество*СпрНоменклатура.ВесЧислитель
		|	КОНЕЦ КАК Вес, 
		|	СпрНоменклатура.ВесЕдиницаИзмерения, 
		|	ВЫБОР
		|		КОГДА 
		|			втТовары.Количество*СпрНоменклатура.ОбъемЗнаменатель <> 0
		|		ТОГДА
		|			втТовары.Количество*СпрНоменклатура.ОбъемЧислитель/СпрНоменклатура.ОбъемЗнаменатель
		|		ИНАЧЕ           
		|			ОбъемЧислитель
		|	КОНЕЦ КАК Объем, 
		|	СпрНоменклатура.ОбъемЕдиницаИзмерения 	
		|ПОМЕСТИТЬ
		|	втТоварныйСостав	
		|ИЗ
		|	втТовары
		|	СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО втТовары.Номенклатура = СпрНоменклатура.Ссылка 
		|ГДЕ 
		|	СпрНоменклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|УПОРЯДОЧИТЬ ПО
		|	втТовары.ЗаказНаДоставку,
		|	втТовары.ДокументПродажи,   
		|	втТовары.НомерСтроки
		|;       
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ	
		|	втТоварныйСостав.ЗаказНаДоставку, 
		|	КОЛИЧЕСТВО(втТоварыПорядок.НомерПоПорядку) КАК НомерСтроки,  
		|	втТоварныйСостав.Рейс, 
		|	втТоварныйСостав.НомерРейса, 
		|	втТоварныйСостав.НомерЗаказа,
		|	втТоварныйСостав.ДокументПродажи,   
		|	втТоварныйСостав.Номенклатура,                                     
		|	втТоварныйСостав.Наименование, 
		|	втТоварныйСостав.Цена,
		|	втТоварныйСостав.Количество,
		|	втТоварныйСостав.Вес,    
		|	втТоварныйСостав.ВесЕдиницаИзмерения,
		|	втТоварныйСостав.Объем,    
		|	втТоварныйСостав.ОбъемЕдиницаИзмерения
		|ИЗ
		|	втТоварныйСостав 
		|	СОЕДИНЕНИЕ втТоварныйСостав КАК втТоварыПорядок
		|		ПО втТоварныйСостав.ЗаказНаДоставку = втТоварыПорядок.ЗаказНаДоставку
		|		И  втТоварныйСостав.НомерПоПорядку >= втТоварыПорядок.НомерПоПорядку  
		|СГРУППИРОВАТЬ ПО
		|	втТоварныйСостав.Рейс, 
		|	втТоварныйСостав.НомерРейса, 
		|	втТоварныйСостав.ЗаказНаДоставку,
		|	втТоварныйСостав.НомерЗаказа,
		|	втТоварныйСостав.ДокументПродажи,   
		|	втТоварныйСостав.НомерПоПорядку, 
		|	втТоварныйСостав.Номенклатура,                                     
		|	втТоварныйСостав.Наименование, 
		|	втТоварныйСостав.Цена,
		|	втТоварныйСостав.Количество,
		|	втТоварныйСостав.Вес,    
		|	втТоварныйСостав.ВесЕдиницаИзмерения,
		|	втТоварныйСостав.Объем,    
		|	втТоварныйСостав.ОбъемЕдиницаИзмерения
		|УПОРЯДОЧИТЬ ПО 1, 2"; 
	
	Запрос.УстановитьПараметр("Рейсы", Рейсы);	
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	ПакетЗапросов = Запрос.ВыполнитьПакет();	
	
	ВыборкаПодразделение = ПакетЗапросов[1].Выбрать();
	Пока ВыборкаПодразделение.Следующий() Цикл  

		ДанныеСклада = ПараметрыСклада();
		ДанныеСклада.number 	= ВыборкаПодразделение.Номер;  
		ДанныеСклада.name 		= ВыборкаПодразделение.Наименование;
	   	ДанныеСклада.address 	= ВыборкаПодразделение.Адрес; 
		ДанныеСклада.lat 		= ВыборкаПодразделение.Широта;
		ДанныеСклада.lon 		= ВыборкаПодразделение.Долгота; 
		Данные.МассивСкладов.Добавить(ДанныеСклада);
	КонецЦикла;
	
	ВыборкаКурьеры = ПакетЗапросов[2].Выбрать();
	Пока ВыборкаКурьеры.Следующий() Цикл  
		
		ИдентификаторКурьера = "+" + ПривестиКФорматуНомерТелефона(ВыборкаКурьеры.НомерТелефонаВодителя);
		Имя = Строка(ВыборкаКурьеры.Водитель) + ", " + ВыборкаКурьеры.АвтомобильНаименование + ", " + ВыборкаКурьеры.АвтомобильГрузоподъемностьВТоннах + "т.";

		ДанныеКурьера = ПараметрыКурьера();
		ДанныеКурьера.number 	= ИдентификаторКурьера;
	   	ДанныеКурьера.phone 	= ИдентификаторКурьера; 
		ДанныеКурьера.name		= Имя;
		Данные.МассивКурьеров.Добавить(ДанныеКурьера); 
    КонецЦикла;	
	
	ВыборкаРейсы = ПакетЗапросов[3].Выбрать();
	Пока ВыборкаРейсы.Следующий() Цикл
		
		ИдентификаторКурьера = "+" + ПривестиКФорматуНомерТелефона(ВыборкаРейсы.НомерТелефонаВодителя);
		
		ДанныеРейса = ПараметрыМаршрута();  
		ДанныеРейса.number			= ВыборкаРейсы.НомерРейса;
		ДанныеРейса.courier_number	= ИдентификаторКурьера; 
		ДанныеРейса.depot_number 	= ВыборкаРейсы.НомерСклада;
		ДанныеРейса.date			= Строка(Формат(ВыборкаРейсы.ДатаМаршрута, "ДФ=yyyy-MM-dd"));
		ДанныеРейса.routing_mode 	= ?(ВыборкаРейсы.АвтомобильГрузоподъемностьВТоннах >= 2.5, "truck", "driving");
		Данные.МассивРейсов.Добавить(ДанныеРейса);

		ДанныеТочкиСклад = ПараметрыТочкиСклад();
		ДанныеТочкиСклад.value.number = ВыборкаРейсы.НомерСклада;
		ТочкиМаршрута = Новый Массив;
		ТочкиМаршрута.Добавить(ДанныеТочкиСклад);
		Данные.МассивТочек.Добавить(ТочкиМаршрута);
		
		ИдентификаторРейса = ИдентификаторыРейсов();   
		
		ИдентификаторРейса.НомерРейса = ВыборкаРейсы.НомерРейса; 
		ИдентификаторРейса.Ссылка = ВыборкаРейсы.Рейс;                   
		
		// Пропуска
		ИдентификаторРейса.ПропускНаСклад = ПолучитьПропускНаСклад(ВыборкаРейсы.Рейс);      
		
		ОтгрузкаМаркетплейс = ПолучитьОтгрузкуМаркетплейса(ВыборкаРейсы.Рейс);
		ИдентификаторРейса.ЗаказОтгрузка	= ОтгрузкаМаркетПлейс.ЗаказНаДоставку; 
		ИдентификаторРейса.СсылкаОтгрузка	= ОтгрузкаМаркетПлейс.СсылкаОтгрузки;  
		ИдентификаторРейса.ОписаниеОтгрузка	= ОтгрузкаМаркетПлейс.ОписаниеОтгрузки; 
		
		ВозвратМаркетплейс = ПолучитьОтгрузкуМаркетплейса(ВыборкаРейсы.Рейс, Истина);
		ИдентификаторРейса.ЗаказВозврат 	= ВозвратМаркетплейс.ЗаказНаДоставку; 
		ИдентификаторРейса.СсылкаВозврат	= ВозвратМаркетплейс.СсылкаОтгрузки; 
		ИдентификаторРейса.ОписаниеВозврат	= ВозвратМаркетплейс.ОписаниеОтгрузки; 
		
		Данные.ИдентификаторыРейсов.Добавить(ИдентификаторРейса);
	КонецЦикла;		
			
	ВыборкаЗаказы = ПакетЗапросов[5].Выбрать();
	ВыгрузкаТовары = ПакетЗапросов[8].Выгрузить();
	
	Пока ВыборкаЗаказы.Следующий() Цикл 
		
		ТелефонКлиента = "+" + ПривестиКФорматуНомерТелефона(ВыборкаЗаказы.ТелефонКлиента);
		
		ДанныеЗаказа = ПараметрыЗаказа(); 
	   	ДанныеЗаказа.route_number 		= ВыборкаЗаказы.НомерРейса;      
		ДанныеЗаказа.time_interval		= ПолучитьВременноеОкно(ВыборкаЗаказы.ВремяДоставкиС, ВыборкаЗаказы.ВремяДоставкиПо, Ложь, 0);
		ДанныеЗаказа.number 			= ВыборкаЗаказы.НомерЗаказа;
		ДанныеЗаказа.phone				= ТелефонКлиента; 
		ДанныеЗаказа.lat				= ВыборкаЗаказы.Широта;
		ДанныеЗаказа.lon				= ВыборкаЗаказы.Долгота;
		ДанныеЗаказа.address			= ВыборкаЗаказы.АдресПолучателя;     
		ДанныеЗаказа.customer_name		= ВыборкаЗаказы.НаименованиеПолучателя;
		ДанныеЗаказа.volume				= ВыборкаЗаказы.Объем;
		ДанныеЗаказа.weight				= ВыборкаЗаказы.Вес; 
		ДанныеЗаказа.status				= НастройкиОбслуживанияЗаказов.СтатусЗаказов; 
		
		Если ВыборкаЗаказы.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
			ДанныеЗаказа.shared_service_duration_s	= НастройкиОбслуживанияЗаказов.ВремяОбслуживанияАдресОРК;   
			ДанныеЗаказа.service_duration_s			= НастройкиОбслуживанияЗаказов.ВремяОбслуживанияЗаказОРК;	
		Иначе	
			ДанныеЗаказа.shared_service_duration_s	= НастройкиОбслуживанияЗаказов.ВремяОбслуживанияАдрес;   
			ДанныеЗаказа.service_duration_s			= НастройкиОбслуживанияЗаказов.ВремяОбслуживанияЗаказ;
		КонецЕсли;    
		
		// Ссылки на пропуска на склад и маркетплейс
		ПропускНаСклад 	= "";  
		СсылкаОтгрузка	= "";
		ОписаниеОтгрузка= "";
		СсылкаВозврат 	= "";
		ОписаниеВозврат = "";  
		
		Для Каждого ИдентификаторРейса Из Данные.ИдентификаторыРейсов Цикл
			
			Если ВыборкаЗаказы.Рейс = ИдентификаторРейса.Ссылка Тогда  
				ПропускНаСклад = ИдентификаторРейса.ПропускНаСклад;                                   
				
				Если ВыборкаЗаказы.ЗаказНадоставку = ИдентификаторРейса.ЗаказОтгрузка Тогда  
					СсылкаОтгрузка 	= ИдентификаторРейса.СсылкаОтгрузка;
					ОписаниеОтгрузка= ИдентификаторРейса.ОписаниеОтгрузка;
				КонецЕсли; 
				
				Если ВыборкаЗаказы.ЗаказНадоставку = ИдентификаторРейса.ЗаказВозврат Тогда  
					СсылкаВозврат 	= ИдентификаторРейса.СсылкаВозврат;
					ОписаниеВозврат = ИдентификаторРейса.ОписаниеВозврат;
				КонецЕсли;
				
				Прервать;
			КонецЕсли;
		КонецЦикла;

		Комментарий = 
			?(ВыборкаЗаказы.Комментарий <> "", ВыборкаЗаказы.Комментарий + Символы.ПС, "") +
			?(ВыборкаЗаказы.НужнаИнкассация, "Инкассация: " + Формат(ВыборкаЗаказы.СуммаИнкассации, "ЧДЦ=2") + " ₽" + Символы.ПС, "") +
			?(ВыборкаЗаказы.Сдача > 0, "Нужна сдача: " + Формат(ВыборкаЗаказы.Сдача, "ЧДЦ=2") + " ₽" + Символы.ПС, "") +
			?(ВыборкаЗаказы.ОплатаБанковскойКартой, "Оплата банковской картой" + Символы.ПС, "") +
			?(ЗначениеЗаполнено(ПропускНаСклад), Символы.ПС + "Пропуск на склад: " + ПропускНаСклад + Символы.ПС, "") +
			?(ЗначениеЗаполнено(СсылкаОтгрузка), Символы.ПС + ОписаниеОтгрузка + ": " + СсылкаОтгрузка + Символы.ПС, "") +
			?(ЗначениеЗаполнено(СсылкаВозврат), Символы.ПС + ОписаниеВозврат + ": " + СсылкаВозврат + Символы.ПС, "");
			
		ДанныеЗаказа.comments = Комментарий; 
		Данные.МассивЗаказов.Добавить(ДанныеЗаказа);
		
		// Последовательность точек маршрута
		Для Сч = 0 По Данные.МассивРейсов.Количество() - 1 Цикл
			Если ДанныеЗаказа.route_number = Данные.МассивРейсов[Сч].number Тогда
				
				ДанныеТочкиЗаказ = ПараметрыТочкиЗаказ();
				ДанныеТочкиЗаказ.value.number 			= ДанныеЗаказа.number;
				ДанныеТочкиЗаказ.value.address 			= ДанныеЗаказа.address;
				ДанныеТочкиЗаказ.value.lat 				= ДанныеЗаказа.lat;
				ДанныеТочкиЗаказ.value.lon 				= ДанныеЗаказа.lon;
				ДанныеТочкиЗаказ.value.time_interval 	= ДанныеЗаказа.time_interval;
				Данные.МассивТочек[Сч].Добавить(ДанныеТочкиЗаказ);
			
				Прервать;	
			КонецЕсли;	
		КонецЦикла;
		
		ИдентификаторЗаказа = ИдентификаторыЗаказов();
		ИдентификаторЗаказа.НомерРейса = ВыборкаЗаказы.НомерРейса; 
		ИдентификаторЗаказа.НомерЗаказа = ВыборкаЗаказы.НомерЗаказа;
		Данные.ИдентификаторыЗаказов.Добавить(ИдентификаторЗаказа);
		
		// Товарный состав заказа
		ТоварыЗаказа = ВыгрузкаТовары.НайтиСтроки(Новый Структура("НомерЗаказа", ВыборкаЗаказы.НомерЗаказа));
		//Ограничение товарного состава 'maxItems': 100
		Если ТоварыЗаказа.Количество() <= 100 Тогда
			Для Каждого СтрокаТовар Из ТоварыЗаказа Цикл
				
			ДанныеТовара = ПараметрыТоваров();  
			ДанныеТовара.Вставить("НомерЗаказа", СтрокаТовар.НомерЗаказа);
			ДанныеТовара.number			= Формат(СтрокаТовар.НомерСтроки, "ЧГ=0");
			ДанныеТовара.description	= СтрокаТовар.Наименование; 
			ДанныеТовара.price 			= Формат(СтрокаТовар.Цена, "ЧГ=0; ЧДЦ=2; ЧРД=.; ЧН=0");
			ДанныеТовара.total_count	= СтрокаТовар.Количество;
			
			Вес = Формат(СтрокаТовар.Вес, "ЧГ=0; ЧДЦ=3; ЧРД=.; ЧН=0.000");
			ВесОбъем = ?(Вес <> "0.000", Вес + " " + СтрокаТовар.ВесЕдиницаИзмерения, "");
			
			Объем = Формат(СтрокаТовар.Объем, "ЧГ=0; ЧДЦ=3; ЧРД=.; ЧН=0.000");
			ВесОбъем = ВесОбъем + ?(Объем <> "0.000", ?(ВесОбъем <> "", ", ", "") + Объем + " " + СтрокаТовар.ОбъемЕдиницаИзмерения, "");
			ДанныеТовара.code			= ВесОбъем;
			
			Данные.МассивТоваров.Добавить(ДанныеТовара);				
				
			КонецЦикла; 
		КонецЕсли;
		
	КонецЦикла;        
		
	Возврат Данные;
 
КонецФункции

