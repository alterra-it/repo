Функция ОбновитьПользователиМобильноеПриложение(КурьерыКОтправке, НастройкиАвторизации, ЗапросыДляЛогов)
	
	РезультатВыполнения = ПараметрыВыполнения("Обновление курьеров в мобильном приложении");
	
	Попытка     
		// Получение списка складов
		ПользователиМониторинг = ВыполнитьЗапросПолучениеПользователи(НастройкиАвторизации);
		РезультатВыполнения.Результат = ПользователиМониторинг.Результат;
		РезультатВыполнения.Сообщение = ПользователиМониторинг.Сообщение + Символы.ПС;
		
		ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "СписокПользователейЗапрос", ПользователиМониторинг.Метод);		
		ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "СписокПользователейОтвет", ПользователиМониторинг.JsonОтвет, ,, Не ПользователиМониторинг.Результат);
	
		Если ПользователиМониторинг.Результат Тогда  
		
			Для Каждого Курьер Из КурьерыКОтправке Цикл      

				ПользовательЕсть = Ложь;
				Для Каждого ПользовательМониторинг Из ПользователиМониторинг.ОтветСтруктура Цикл
					Если ПользовательМониторинг.role = "app" И Курьер.phone = ПользовательМониторинг.login Тогда                                 
						ПользовательЕсть = Истина;
						Прервать;
					КонецЕсли;
				КонецЦикла;  
	
				Если Не ПользовательЕсть Тогда         
					Логин = Новый Структура("login", Курьер.phone);
					ОбновлениеПользователь = ВыполнитьЗапросОбновлениеПользователи(Логин, НастройкиАвторизации);    
					
					ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеПользователя" + Сред(Курьер.phone, 2) + "_Запрос", ОбновлениеПользователь.Метод + Символы.ПС + "Тело:" + ОбновлениеПользователь.Тело);		
					ДобавитьЗапросыДляЛогов(ЗапросыДляЛогов, "ОбновлениеПользователя" + Сред(Курьер.phone, 2) + "_Ответ", ОбновлениеПользователь.JsonОтвет,,, Не ОбновлениеПользователь.Результат);
					
					Если Не ОбновлениеПользователь.Результат Тогда
						РезультатВыполнения.Результат = ОбновлениеПользователь.Результат;
					КонецЕсли;
						
					РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + СтрШаблон("Пользователь %1 %2добавлен в мобильное приложение", Курьер.phone, ?(ОбновлениеПользователь.Результат, "", "не ")) + Символы.ПС;
				КонецЕсли;
			КонецЦикла;
		
		Иначе
			РезультатВыполнения.Сообщение = ПользователиМониторинг.Сообщение;
		КонецЕсли;
		
	Исключение
		РезультатВыполнения.Сообщение = "Ошибка при обновлении пользователей в мобильном приложении: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;      
	
	ЗакрытьПараметрыВыполнения(РезультатВыполнения);
	Возврат РезультатВыполнения;	
	
КонецФункции	

