#Область СобытияЗаказовМониторинга

Функция СобытияЗаказов()
	
	СобытияТЗ = Новый ТаблицаЗначений;
	СобытияТЗ.Колонки.Добавить("ЗаказНаДоставку", Новый ОписаниеТипов("ДокументСсылка.ЗаказНаДоставкуКлиенту"));
	СобытияТЗ.Колонки.Добавить("ВремяСобытия", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.ДатаВремя)));
	СобытияТЗ.Колонки.Добавить("СтатусДоставки", Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыДоставкиЯндекс"));
	Возврат СобытияТЗ;
	
КонецФункции	

Процедура ДобавитьСобытияЗаказов(СобытияЗаказов, ЗаказыМаршрутаЯндекс, ЗаказыДляОтслеживания)
	
	Для Каждого ЗаказМаршрута Из ЗаказыМаршрутаЯндекс Цикл
		
		ОтслеживаемыйЗаказ = ЗаказыДляОтслеживания.НайтиСтроки(Новый Структура("ИдентификаторЗаказа", Формат(ЗаказМаршрута.id, "ЧГ=")));
		Если ОтслеживаемыйЗаказ.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СобытиеИстории Из ЗаказМаршрута.history Цикл
		
			СтатусДоставки = ПолучитьСтатусДоставки(СобытиеИстории.event, ?(СобытиеИстории.Свойство("status"), СобытиеИстории.status, ""));
			
			Если ЗначениеЗаполнено(СтатусДоставки) Тогда
				
				ВремяЯндекса = СобытиеИстории.time; 
				ВремяСобытия = Дата(Лев(ВремяЯндекса, 4), Сред(ВремяЯндекса, 6, 2), Сред(ВремяЯндекса, 9, 2),
					Сред(ВремяЯндекса, 12, 2), Сред(ВремяЯндекса, 15, 2), Сред(ВремяЯндекса, 18, 2));
				
				СтрокаСобытия = СобытияЗаказов.Добавить();
				СтрокаСобытия.ЗаказНаДоставку = ОтслеживаемыйЗаказ[0].ЗаказНаДоставку;	
				СтрокаСобытия.ВремяСобытия = ВремяСобытия;
				СтрокаСобытия.СтатусДоставки = СтатусДоставки;
				
			КонецЕсли;
		КонецЦикла;
		
	КонецЦикла
			
КонецПроцедуры	

Функция ПолучитьСтатусДоставки(СобытиеИстории, Статус)
	
	Если СобытиеИстории = "ORDER_CREATED" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ПереданоВДоставку;
	ИначеЕсли СобытиеИстории = "START" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказОтправленСоСклада;
	ИначеЕсли СобытиеИстории = "ORDER_BECAME_NEXT" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ПредыдущийЗаказДоставлен;
	ИначеЕсли СобытиеИстории = "ARRIVAL" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказПодъезжает;
	ИначеЕсли СобытиеИстории = "ORDER_VISIT" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказПриехал;
	ИначеЕсли СобытиеИстории = "STATUS_UPDATE" И Статус = "finished" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказДоставлен;
	ИначеЕсли СобытиеИстории = "STATUS_UPDATE" И Статус = "partially_finished" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказДоставленЧастично;
	ИначеЕсли СобытиеИстории = "STATUS_UPDATE" И Статус = "cancelled" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказОтменен;
	ИначеЕсли СобытиеИстории = "STATUS_UPDATE" И Статус = "postponed" Тогда 
		СтатусДоставки = Перечисления.СтатусыДоставкиЯндекс.ЗаказОтложен;
	Иначе		
		СтатусДоставки = Неопределено;
	КонецЕсли;
	
	Возврат СтатусДоставки;
	
КонецФункции	

Функция ЗаписатьСобытияДоставки(СобытияЗаказов)
	
	РезультатВыполнения = Новый Структура("Результат, Сообщение, КоличествоДобавлено, КоличествоНедобавлено", Истина, "", 0, 0);
	
	Попытка
	
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ
			|	СобытияЗаказов.ЗаказНаДоставку,
			|	СобытияЗаказов.ВремяСобытия,
			|	СобытияЗаказов.СтатусДоставки
			|ПОМЕСТИТЬ
			|	втСобытияЗаказов	
			|ИЗ
			|	&СобытияЗаказов КАК СобытияЗаказов
			|;
			|ВЫБРАТЬ
			|	втСобытияЗаказов.ЗаказНаДоставку,
			|	втСобытияЗаказов.ВремяСобытия,
			|	втСобытияЗаказов.СтатусДоставки
			|ИЗ
			|	втСобытияЗаказов
			|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ДоставкаЯндекс
			|		ПО втСобытияЗаказов.ЗаказНаДоставку = ДоставкаЯндекс.ЗаказНаДоставку 
			|		И втСобытияЗаказов.ВремяСобытия = ДоставкаЯндекс.ВремяСобытия 
			|		И втСобытияЗаказов.СтатусДоставки = ДоставкаЯндекс.СтатусДоставки
			|ГДЕ
			|	ДоставкаЯндекс.ЗаказНаДоставку ЕСТЬ NULL";
		
		Запрос.УстановитьПараметр("СобытияЗаказов", СобытияЗаказов);
					
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Попытка
				НаборЗаписей = РегистрыСведений.ДоставкаЯндекс.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ЗаказНаДоставку.Установить(Выборка.ЗаказНаДоставку);	
				НаборЗаписей.Отбор.ВремяСобытия.Установить(Выборка.ВремяСобытия);
				НаборЗаписей.Отбор.СтатусДоставки.Установить(Выборка.СтатусДоставки);
				
				НоваяЗапись = НаборЗаписей.Добавить();
				НоваяЗапись.ЗаказНаДоставку = Выборка.ЗаказНаДоставку;				
				НоваяЗапись.ВремяСобытия = Выборка.ВремяСобытия;
				НоваяЗапись.СтатусДоставки = Выборка.СтатусДоставки;
				НаборЗаписей.Записать();
				РезультатВыполнения.КоличествоДобавлено = РезультатВыполнения.КоличествоДобавлено + 1;
			Исключение
				РезультатВыполнения.КоличествоНедобавлено = РезультатВыполнения.КоличествоНедобавлено + 1;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + СтрШаблон("Не удалось записать %1 %2 %3: %4",
					Выборка.ЗаказНаДоставку, Выборка.ВремяСобытия, Выборка.СтатусДоставки, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;			
		КонецЦикла; 		

	Исключение
		РезультатВыполнения.Результат = Ложь;
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + "Не удалось записать события доставки: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатВыполнения;
	
КонецФункции

#КонецОбласти	

#Область Трекинги

Процедура ДобавитьТрекинги(Заказ, ТрекингЯндекс)
	
	Попытка
		Заказ.Трекинг = ТрекингЯндекс.tracking_url;								
		
		Если ТрекингЯндекс.Свойство("estimated_delivery_time") И ТрекингЯндекс.estimated_delivery_time.Свойство("text") Тогда
			ПлановоеВремяДоставки = ТрекингЯндекс.estimated_delivery_time.text;
			ПлановоеВремяДоставки = Дата(Лев(ПлановоеВремяДоставки, 4), Сред(ПлановоеВремяДоставки, 6, 2), Сред(ПлановоеВремяДоставки, 9, 2),
				Сред(ПлановоеВремяДоставки, 12, 2), Сред(ПлановоеВремяДоставки, 15, 2), Сред(ПлановоеВремяДоставки, 18, 2));
			Заказ.ПлановоеВремяДоставки = ПлановоеВремяДоставки;
		КонецЕсли;
	Исключение
	КонецПопытки;		
			
КонецПроцедуры	

Функция ЗаписатьТрекинги(Заказы)
	
	РезультатВыполнения = Новый Структура("Результат, Сообщение, КоличествоДобавлено, КоличествоНедобавлено", Истина, "", 0, 0);
	
	Попытка
	
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ 
			|	Заказы.ЗаказНаДоставку,
			|	Заказы.Трекинг,
			|	Заказы.ПлановоеВремяДоставки
			|ПОМЕСТИТЬ
			|	втЗаказы	
			|ИЗ
			|	&Заказы КАК Заказы
			|;
			|ВЫБРАТЬ  
			|	втЗаказы.ЗаказНаДоставку,
			|	ПереданоВДоставку.ВремяСобытия,
			|	ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг) КАК СтатусДоставки,
			|	втЗаказы.Трекинг,
			|	втЗаказы.ПлановоеВремяДоставки
			|ИЗ
			|	втЗаказы
			|	СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ПереданоВДоставку
			|		ПО втЗаказы.ЗаказНаДоставку = ПереданоВДоставку.ЗаказНаДоставку
			|		И ПереданоВДоставку.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПереданоВДоставку)
			|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ПолученТрекинг
			|		ПО втЗаказы.ЗаказНаДоставку = ПолученТрекинг.ЗаказНаДоставку                                      
			|		И ПолученТрекинг.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)
			|    	И втЗаказы.Трекинг = ПолученТрекинг.Трекинг
			|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоставкаЯндекс КАК ПолученоПлановоеВремя
			|		ПО втЗаказы.ЗаказНаДоставку = ПолученоПлановоеВремя.ЗаказНаДоставку                                      
			|		И ПолученоПлановоеВремя.СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)
			|   	И (втЗаказы.ПлановоеВремяДоставки = ПолученоПлановоеВремя.ПлановоеВремяДоставки
			|    		ИЛИ втЗаказы.ПлановоеВремяДоставки = ДатаВремя(1, 1, 1)
			|    			И ПолученоПлановоеВремя.ПлановоеВремяДоставки <> ДатаВремя(1, 1, 1))
			|ГДЕ 
			|	ПолученТрекинг.ЗаказНаДоставку ЕСТЬ NULL
			|	ИЛИ ПолученоПлановоеВремя.ЗаказНаДоставку ЕСТЬ NULL";
		
		Запрос.УстановитьПараметр("Заказы", Заказы);
					
		Выборка = Запрос.Выполнить().Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Попытка
				НаборЗаписей = РегистрыСведений.ДоставкаЯндекс.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.ЗаказНаДоставку.Установить(Выборка.ЗаказНаДоставку);	
				НаборЗаписей.Отбор.ВремяСобытия.Установить(Выборка.ВремяСобытия);
				НаборЗаписей.Отбор.СтатусДоставки.Установить(Выборка.СтатусДоставки);
				
				НоваяЗапись = НаборЗаписей.Добавить();
				НоваяЗапись.ЗаказНаДоставку = Выборка.ЗаказНаДоставку;				
				НоваяЗапись.ВремяСобытия = Выборка.ВремяСобытия;
				НоваяЗапись.СтатусДоставки = Выборка.СтатусДоставки;
				НоваяЗапись.Трекинг = Выборка.Трекинг;
				Если (Не ЗначениеЗаполнено(НоваяЗапись.ПлановоеВремяДоставки) И ЗначениеЗаполнено(Выборка.ПлановоеВремяДоставки))  
					Или (ЗначениеЗаполнено(НоваяЗапись.ПлановоеВремяДоставки) И ЗначениеЗаполнено(Выборка.ПлановоеВремяДоставки)
						И НоваяЗапись.ПлановоеВремяДоставки <> Выборка.ПлановоеВремяДоставки) Тогда
					НоваяЗапись.ПлановоеВремяДоставки = Выборка.ПлановоеВремяДоставки;
				КонецЕсли;
				НаборЗаписей.Записать();
				РезультатВыполнения.КоличествоДобавлено = РезультатВыполнения.КоличествоДобавлено + 1;
			Исключение
				РезультатВыполнения.КоличествоНедобавлено = РезультатВыполнения.КоличествоНедобавлено + 1;
				РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + СтрШаблон("Не удалось записать %1 %2 %3: %4",
					Выборка.ЗаказНаДоставку, Выборка.ВремяСобытия, Выборка.СтатусДоставки, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;			
		КонецЦикла; 		

	Исключение
		РезультатВыполнения.Результат = Ложь;
		РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + "Не удалось записать трекинги: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатВыполнения;
	
КонецФункции

#КонецОбласти		

#КонецОбласти

#Область Логи

Процедура ЗаписатьЛог(НастройкиПапкаЛогов, РезультатВыполнения)
	
	Попытка             
		ИмяПапкиЛогов = ПутьПапки(НастройкиПапкаЛогов) + "yandex\МониторингДоставки\" + Формат(РезультатВыполнения.ДатаНачала, "ДФ=ггггММдд") + "\" ; 
		ПапкаЛогов = Новый Файл(ИмяПапкиЛогов);       
		
		Если Не ПапкаЛогов.Существует() Тогда
			СоздатьКаталог(ИмяПапкиЛогов);
		КонецЕсли;                          
		
		ИмяЛога = "log_" + ПреобразоватьДатуВСтроку(РезультатВыполнения.ДатаНачала) + ".txt";
		ТекстЛогов = ПолучитьТекстЛогов(РезультатВыполнения);
		
		ФайлЛогов = Новый ЗаписьТекста(ИмяПапкиЛогов + "\" + ИмяЛога, КодировкаТекста.UTF8, , Истина);  
		ФайлЛогов.ЗаписатьСтроку(ТекстЛогов);
		ФайлЛогов.Закрыть();
	Исключение
	КонецПопытки;  
	
КонецПроцедуры          

Функция ПолучитьТекстЛогов(РезультатВыполнения)     
	
	Возврат		?(РезультатВыполнения.Результат, "УСПЕШНОЕ ВЫПОЛНЕНИЕ", "НЕ УСПЕШНОЕ ВЫПОЛНЕНИЕ") + Символы.ПС + 
//				Формат(РезультатВыполнения.ДатаНачала, "ДЛФ=ДВ") + Символы.ПС + Символы.ПС +
				РезультатВыполнения.Сообщение + Символы.ПС;
//				Формат(РезультатВыполнения.ДатаОкончания, "ДЛФ=ДВ");
	
КонецФункции 

Функция ПреобразоватьДатуВСтроку(Дата)           
	
	Возврат Формат(Дата, "ДФ=ггггММдд") + "_" + Формат(Дата, "ДФ=ЧЧммсс");
	  
КонецФункции

Функция ПутьПапки(Папки)

	Возврат Папки + ?(Прав(Папки, 1) <> "\", "\", ""); 
	
КонецФункции 

#КонецОбласти

#КонецОбласти

#Область Служебные

Функция ПривестиКФорматуНомерТелефона(Телефон)
	
	НовыйТелефон = Телефон;
	                     
	Если НовыйТелефон <> "" Тогда
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НовыйТелефон);
				
		Если СтрДлина(НовыйТелефон) = 10 Тогда
			НовыйТелефон = "7" + НовыйТелефон;
		КонецЕсли;
	КонецЕсли;
	
	Возврат НовыйТелефон;
	
КонецФункции

Функция ПолучитьВременноеОкно(ВремяНачало, ВремяОкончание, ИнтервалНесколькоДней, День) Экспорт        
	
	Если Не (ИнтервалНесколькоДней И День > 0)
		И ВремяНачало > ВремяОкончание Тогда
			ВремяОкончание = КонецДня(ВремяОкончание);
	КонецЕсли;
	
	ОкноНачало = СтрЗаменить(Прав(ВремяНачало, 8), " ", 0);
	ОкноОкончание = СтрЗаменить(Прав(ВремяОкончание, 8), " ", 0);
	
	Если ИнтервалНесколькоДней И День > 0 Тогда
		Возврат "0." + ОкноНачало + "-" + День + "." + ОкноОкончание;
	Иначе      
		Возврат "" + День + "."+ ОкноНачало + "-" + День + "." + ОкноОкончание;
	КонецЕсли;
	
КонецФункции

Функция ПолучитьРейсы(МассивРейсов, ТолькоНомера = Ложь)
	
	СпикокРейсоов = "";
	
	Для Каждого Рейс Из МассивРейсов Цикл
		СпикокРейсоов = СпикокРейсоов + ?(ЗначениеЗаполнено(СпикокРейсоов), ?(ТолькоНомера, "_", Символы.ПС), "") + 
			?(ТолькоНомера, Рейс.number, Рейс.number + " " + Рейс.date);
	КонецЦикла;
	
	Возврат СпикокРейсоов;
	
КонецФункции	

Функция ПолучитьФилиал(МассивСкладов)
	
	Филиал = "";
	
	Если МассивСкладов.Количество() > 0 Тогда
		Филиал = МассивСкладов[0].name;	
	КонецЕсли;
	
	Возврат Филиал; 
	
КонецФункции	

Функция ПолучитьТекстОшибки(Ответ)
	
	Сообщение = "";
	Если ТипЗнч(Ответ) = Тип("Структура") И Ответ.Свойство("message") Тогда
		Сообщение = Ответ.message;		
	КонецЕсли;	
	
	Возврат Сообщение;
	
КонецФункции	

