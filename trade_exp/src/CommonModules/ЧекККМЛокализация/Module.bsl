#Область Проведение
&После("ДополнитьТекстыЗапросовПроведения")
Процедура Док_ДополнитьТекстыЗапросовПроведения(Запрос, ТекстыЗапроса, Регистры)
	Если БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Запрос.Параметры.Ссылка) Тогда 
		к=0;
		пока к< ТекстыЗапроса.Количество() Цикл
			Стр=ТекстыЗапроса[к];
			Если стр.представление = "БонусныеБаллы"  или стр.представление = "ВтБонусныеБаллы" Тогда
				ТекстыЗапроса.Удалить(стр);
			иначе
				к=к+1;
			КонецЕсли;    
		КонецЦикла;
		Документы.ЧекККМ.ТекстЗапросаБонусныеБаллыСРаспределением(Запрос, ТекстыЗапроса, Регистры);
	КонецЕсли;
	Документы.ЧекККМ.ТекстЗапросаТаблицаКОтгрузке(Запрос, ТекстыЗапроса, Регистры);
	Документы.ЧекККМ.ТекстЗапросаТаблицаКОтгрузкеПоНакладным(Запрос, ТекстыЗапроса, Регистры, Запрос.Параметры.Ссылка);
	Документы.ЧекККМ.ТекстЗапросаТаблицаДвижениеМаркированногоТовара(Запрос, ТекстыЗапроса, Регистры );
КонецПроцедуры   

#КонецОбласти
