Функция ПолучитьПараметрыСоединения(АдресСервера = "sbp.gazprombank.ru" , Порт=9443, Логин=Неопределено, Пароль=Неопределено, ИспользоватьSSL=Истина, ИДУстройства="") Экспорт
	//СтруктураНастроек = ПолучитьСтруктуруХранилищаНастроек();
	//Если СтруктураНастроек.Свойство("АдресСервера") Тогда
	//	АдресСервера = СтруктураНастроек.АдресСервера;
	//КонецЕсли;
	
	ПараметрыПодключения = Новый Структура;
	
	ПараметрыПодключения.Вставить("Логин", Логин);	
	ПараметрыПодключения.Вставить("Пароль",	Пароль);	
	ПараметрыПодключения.Вставить("АдресСервера", АдресСервера);	 
	ПараметрыПодключения.Вставить("Порт", Порт);	
	ПараметрыПодключения.Вставить("ИспользоватьSSL", ИспользоватьSSL);	
	ПараметрыПодключения.Вставить("ИДУстройства", ИДУстройства);
	ПараметрыПодключения.Вставить("Таймаут", 0);
	
	Возврат ПараметрыПодключения;
КонецФункции

Функция ПолучитьHTTPСоединение(ПараметрыПодключения) Экспорт
	
	ssl = ?(ПараметрыПодключения.ИспользоватьSSL,Новый ЗащищенноеСоединениеOpenSSL,НЕОПРЕДЕЛЕНО);
	
	Соединение = Новый HTTPСоединение(
	ПараметрыПодключения.АдресСервера, 
	ПараметрыПодключения.Порт, 
	ПараметрыПодключения.Логин, 
	ПараметрыПодключения.Пароль, 
	ПолучениеФайловИзИнтернета.ПолучитьПрокси("https"), 
	ПараметрыПодключения.Таймаут, 
	ssl  
	);
	
	Возврат Соединение;
КонецФункции

Функция ПослатьHTTPЗапрос(АдресЗапроса, HTTPСоединение, ТипЗапроса="GET", Заголовки=Неопределено, Данные=Неопределено) Экспорт
	ЕстьОшибка= Ложь;
	Если НЕ АльтерраОбщегоНазначения.ЭтоРабочаяБаза() Тогда
		Возврат "Попытка работы с СБП Газпромбанка в тестовой базе";
	КонецЕсли;	
	
	Попытка
		HTTPЗапрос= Новый HTTPЗапрос(АдресЗапроса); 
		Если ТипЗнч(Заголовки) = Тип("Соответствие") Тогда
			Для каждого Заголовок из Заголовки Цикл
				HTTPЗапрос.Заголовки.Вставить(Заголовок.Ключ, Заголовок.Значение);
			КонецЦикла;
		КонецЕсли;
		
		HTTPЗапрос.УстановитьТелоИзСтроки(Данные);
		
		Если ТипЗапроса="GET" Тогда
			Ответ = HTTPСоединение.Получить(HTTPЗапрос);
		ИначеЕсли ТипЗапроса="POST" Тогда
			Ответ = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
		ИначеЕсли ТипЗапроса="PUT" Тогда
			Ответ = HTTPСоединение.Записать(HTTPЗапрос);
		ИначеЕсли ТипЗапроса="DELETE" Тогда
			Ответ = HTTPСоединение.Удалить(HTTPЗапрос);
		КонецЕсли;
				
		ОтветТело= Ответ.ПолучитьТелоКакСтроку();
		
		ДанныеОтвета= ДесериализоватьИзJSON(ОтветТело);  
		
		Текст= СтрШаблон("Выполнен %1 запрос %2 с данными %3. Ответ %4", ТипЗапроса, АдресЗапроса, Данные, ОтветТело);
		ЗаписьЖурналаРегистрации("СБП Газпромбанк", УровеньЖурналаРегистрации.Информация,,,Текст);

	Исключение
		Инфо = ИнформацияОбОшибке();
		Текст= СтрШаблон("Ошибка выполнения %1 запроса: %2. %3", ТипЗапроса, АдресЗапроса, Инфо.Описание);
		Возврат Текст;

	КонецПопытки;
	
	Возврат ДанныеОтвета;
КонецФункции 

Функция СериализоватьВJSON(Данные) Экспорт   
	Попытка
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, ,Истина));
		ЗаписатьJSON(ЗаписьJSON, Данные);
		ПараметрыJSON = ЗаписьJSON.Закрыть();
		Возврат ПараметрыJSON;
	Исключение
		Сообщить("Ошибка JSON");
		Возврат "{}";
	КонецПопытки;
КонецФункции

Функция ДесериализоватьИзJSON(СтрокаJSON) Экспорт  
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);   
	Результат = Неопределено;
	Результат = ПрочитатьJSON(ЧтениеJSON,, "dateTime, dateTimeSbpMsg", ФорматДатыJSON.ISO);	
	ЧтениеJSON.Закрыть();
	
    Возврат Результат;
КонецФункции

Функция ПолучитьОбработку() Экспорт
	
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяОбъекта", "СБПГазпромбанк");		
		
	Возврат ДополнительнаяОбработка;
	
КонецФункции

Функция ПолучитьСтруктуруХранилищаНастроек(ДополнительнаяОбработка=Неопределено) Экспорт
	
	ОписаниеОшибки = "";	
	Если ДополнительнаяОбработка=Неопределено Тогда
		ДополнительнаяОбработка = ПолучитьОбработку();
	Конецесли;
	Если НЕ ДополнительнаяОбработка.Пустая() Тогда
		
		НастройкиХранилища = ДополнительнаяОбработка.ХранилищеНастроек.Получить();		
		
		Если НастройкиХранилища <> Неопределено Тогда
			Возврат НастройкиХранилища;
		Иначе	
			ОписаниеОшибки = "Настройки выполнения не заданы";
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ОписаниеОшибки;
	
КонецФункции



