Функция ПодготовкаВозврата(ДанныеЗаполнения)  Экспорт
	СтруктураНастроек = ПолучитьСтруктуруХранилищаНастроек();
	Если ТипЗнч(СтруктураНастроек) = ТИП("Структура") Тогда
		Если СтруктураНастроек.Свойство("Пароль")и СтруктураНастроек.Свойство("Логин") Тогда
			Данные = Новый Структура;
			Данные.Вставить("transactionId", ДанныеЗаполнения.transactionId); //транзакция, по которой будет проведен возврат
			Данные.Вставить("amount", ДанныеЗаполнения.amount); 
			Данные.Вставить("currency", "RUB"); 
			Если ДанныеЗаполнения.Свойство("comment") Тогда
				Данные.Вставить("comment", ДанныеЗаполнения.comment);
			КонецЕсли;
			Если ДанныеЗаполнения.Свойство("recipientBankId") Тогда
				Данные.Вставить("recipientBankId", ДанныеЗаполнения.recipientBankId);
			КонецЕсли;
			//Данные.Вставить("callbackMerchantNotifications", "");
			//Данные.Вставить("sign",""); 
			
			ДанныеJSON = СериализоватьВJSON(Данные);
			
			ПараметрыПодключения = ПолучитьПараметрыСоединения();
			HTTPСоединение = ПолучитьHTTPСоединение(ПараметрыПодключения); 
			
			Заголовки = Новый Соответствие;
			Заголовки.Вставить("Content-type", "application/json");
			
			Пароль = АльтерраОбщегоНазначения.РаскодироватьИзBase64(СтруктураНастроек.Пароль);
		    Basic = СтруктураНастроек.Логин + ":" + Пароль;
			Basic = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(Basic));   
			
			Заголовки.Вставить("Authorization", "Basic " + Basic);  //Логин и пароль закодированные согласно Basic auth
			Заголовки.Вставить("login", СтруктураНастроек.Логин);           
			Заголовки.Вставить("password", Пароль);

			АдресЗапроса = "/merchant/transfer/return/prepare";
			Ответ = ПослатьHTTPЗапрос(АдресЗапроса, HTTPСоединение, "POST", Заголовки, ДанныеJSON);
		Иначе
			Ответ = "Не заполнены Логин и Пароль в настройках";
		КонецЕсли;
		
		Возврат Ответ;
		
	Иначе
	    Возврат СтруктураНастроек;
	КонецЕсли;
	
КонецФункции

Функция ПодтверждениеВозврата(prepareTransactionId)  Экспорт
	СтруктураНастроек = ПолучитьСтруктуруХранилищаНастроек();
	Если ТипЗнч(СтруктураНастроек) = ТИП("Структура") Тогда
		Если СтруктураНастроек.Свойство("Пароль")и СтруктураНастроек.Свойство("Логин") Тогда
	
			Данные = Новый Структура;
			Данные.Вставить("transactionId", prepareTransactionId); //транзакция подготовки возврата
			//Данные.Вставить("sign",""); 
			
			ДанныеJSON = СериализоватьВJSON(Данные);
			
			ПараметрыПодключения = ПолучитьПараметрыСоединения();
			HTTPСоединение = ПолучитьHTTPСоединение(ПараметрыПодключения); 
			
			Заголовки = Новый Соответствие;
			Заголовки.Вставить("Content-type", "application/json");
			
			Пароль = АльтерраОбщегоНазначения.РаскодироватьИзBase64(СтруктураНастроек.Пароль);
		    Basic = СтруктураНастроек.Логин + ":" + Пароль;
			Basic = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(Basic));   
			
			Заголовки.Вставить("Authorization", "Basic " + Basic);  //Логин и пароль закодированные согласно Basic auth
			Заголовки.Вставить("login", СтруктураНастроек.Логин);           
			Заголовки.Вставить("password", Пароль); 
			
			АдресЗапроса = "/merchant/transfer/return/confirm";
			Ответ = ПослатьHTTPЗапрос(АдресЗапроса, HTTPСоединение, "POST", Заголовки, ДанныеJSON);
		Иначе
			Ответ = "Не заполнены Логин и Пароль в настройках";
		КонецЕсли;
		
		Возврат Ответ;
		
	Иначе
	    Возврат СтруктураНастроек;
	КонецЕсли;

	
КонецФункции

