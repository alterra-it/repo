Процедура ЗаписьIDТранзакцииВРегистрСБП(ДокументСсылка, IDТранзакции, СБП = Ложь) Экспорт
	
	//запись ID в регистр
	НаборЗаписей = РегистрыСведений.ДанныеБезналичныхОплат.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокументОплаты.Установить(ДокументСсылка);
	НаборЗаписей.Очистить();
	ЗаписьВРегистр = НаборЗаписей.Добавить();
	ЗаписьВРегистр.ДокументОплаты = ДокументСсылка;
	ЗаписьВРегистр.IDТранзакции = IDТранзакции;
	ЗаписьВРегистр.СБП = СБП;
	УстановитьПривилегированныйРежим(Истина);
	НаборЗаписей.Записать();
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры 

Функция ПолучитьДанныеТранзакции(ДокументСсылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеБезналичныхОплат.IDТранзакции КАК IDТранзакции,
		|	ДанныеБезналичныхОплат.СБП КАК СБП
		|ИЗ
		|	РегистрСведений.ДанныеБезналичныхОплат КАК ДанныеБезналичныхОплат
		|ГДЕ
		|	ДанныеБезналичныхОплат.ДокументОплаты = &ДокументОплаты";
	Запрос.УстановитьПараметр("ДокументОплаты", ДокументСсылка);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Выборка = Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		СтруктураДанных = Новый Структура;
		СтруктураДанных.Вставить("IDТранзакции", Выборка.IDТранзакции);
		СтруктураДанных.Вставить("СБП", Выборка.СБП);
		Возврат СтруктураДанных;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции 

