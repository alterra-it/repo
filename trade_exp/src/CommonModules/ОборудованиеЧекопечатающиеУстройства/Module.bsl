							#Вставка
							ИспользуемДругойТег = Ложь;
							ИспользоватьДопПроверку = ДопМодуль.ПолучитьНастройкиХранилища("ВключенияИзмененияВыводаТега2108ВЧеках").ВключитьВыводТега;
							
							Если ИспользоватьДопПроверку Тогда
								
								КассирДляПроверки = ДопМодуль.ПолучитьНастройкиХранилища("ВключенияИзмененияВыводаТега2108ВЧеках").КассирДляПроверки;
								
								Если ЗначениеЗаполнено(КассирДляПроверки) Тогда
									Если ОбщиеПараметры.Кассир = Строка(КассирДляПроверки) Тогда
										ИспользуемДругойТег =Истина;
									Иначе
										ИспользуемДругойТег=Ложь;
									КонецЕсли; 
								Иначе
									ИспользуемДругойТег =Истина;
								КонецЕсли;
							КонецЕсли;
							
							Если ИспользуемДругойТег Тогда
								МераКоличестваПредметаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.МераКоличестваПредметаРасчетаПоКодуЕдиницыИзмерения(ТекущаяПозиция.КодЕдиницыИзмерения);
								МераКоличестваПредметаРасчета = ОборудованиеЧекопечатающиеУстройстваКлиентСервер.КодМерыКоличестваПредметаРасчетаККТ(МераКоличестваПредметаРасчета);
								ЗаписьXML.ЗаписатьАтрибут("MeasureOfQuantity", XMLСтрока(МераКоличестваПредметаРасчета));
							Иначе
							#КонецВставки
							ЗаписьXML.ЗаписатьАтрибут("MeasurementUnit", XMLСтрока(Лев(ТекущаяПозиция.ЕдиницаИзмерения, 16)));
							#Вставка 
