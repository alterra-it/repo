// Работа с напоминаниями
Процедура ПодключитьПроизвольноеНапоминаниеПользователям(Предмет = Неопределено) Экспорт
	ПараметрыНапоминания = Новый Структура;
	ПараметрыНапоминания.Вставить("Описание", "Новая поставка на склад!");
	ПараметрыНапоминания.Вставить("ВремяСобытия", ТекущаяДата());
	ПараметрыНапоминания.Вставить("Источник", Предмет);
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СекцииКладовщиков.Пользователь КАК Пользователь
		|ИЗ
		|	РегистрСведений.СекцииКладовщиков КАК СекцииКладовщиков
		|ГДЕ
		|	СекцииКладовщиков.Склад = &Склад
		|	И СекцииКладовщиков.Ячейка = &Ячейка";
	
	Запрос.УстановитьПараметр("Склад", Предмет.Склад);
	Запрос.УстановитьПараметр("Ячейка", Предмет.РабочийУчасток);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ПараметрыНапоминания.Вставить("Пользователь", ВыборкаДетальныеЗаписи.Пользователь);
        Напоминание = СоздатьНапоминание(ПараметрыНапоминания);
	    НапоминанияПользователяСлужебный.ПодключитьНапоминание(Напоминание);
		ПараметрыНапоминания.Удалить("Пользователь");
	КонецЦикла;
	
КонецПроцедуры

Функция СоздатьНапоминание(ПараметрыНапоминания)
	
	Напоминание = НапоминанияПользователяКлиентСервер.ОписаниеНапоминания(ПараметрыНапоминания, Истина);
	Напоминание.СпособУстановкиВремениНапоминания = Перечисления.СпособыУстановкиВремениНапоминания.ВУказанноеВремя;
		
	Напоминание.СрокНапоминания = Напоминание.ВремяСобытия;
		
	Если Не ЗначениеЗаполнено(Напоминание.СрокНапоминания) Тогда
		Напоминание.СрокНапоминания = Напоминание.ВремяСобытия;
	КонецЕсли;
	
	Возврат Напоминание;
	
КонецФункции

//СистемаВзаимодействия
Процедура СоздатьСообщение(Параметры) Экспорт
	установитьпривилегированныйрежим(Истина);
	
	Если СистемаВзаимодействия.ИнформационнаяБазаЗарегистрирована() Тогда
		ОтветственныйПользовательИБ = Параметры.Ответственный;
		ИдентификаторПользователяСВ = СистемаВзаимодействия.ПолучитьИдентификаторПользователя(ОтветственныйПользовательИБ.ИдентификаторПользователяИБ);
		
		Отбор = Новый ОтборОбсужденийСистемыВзаимодействия();
		Отбор.КонтекстноеОбсуждение = Истина;
		Отбор.КонтекстОбсуждения = Новый КонтекстОбсужденияСистемыВзаимодействия(Параметры.НавигационнаяСсылка);
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждения(Отбор);

		Если Обсуждение.Количество()=1 Тогда
			Для каждого СтрокаОбсуждение из Обсуждение Цикл
				НовоеСообщение = СистемаВзаимодействия.СоздатьСообщение(СтрокаОбсуждение.Идентификатор);
				НовоеСообщение.Данные = Параметры.Ссылка;
				НовоеСообщение.Получатели.Добавить(ИдентификаторПользователяСВ);
				НовоеСообщение.Дата = ТекущаяДата();
				НовоеСообщение.Текст = "Клиент на месте!  Укажите время до конца сборки!";
				НовоеСообщение.Записать();
			КонецЦИкла;
		КонецЕсли;
	КонецЕсли; 
	
	установитьпривилегированныйрежим(Ложь);	
КонецПроцедуры

//Количество текущих заданий 
Функция ОбновитьДанныеНаСервере(Секция,Склад) Экспорт
	
	СтруктураДанныхВозврата = Новый Структура;
	СтруктураДанныхВозврата.Вставить("КоличествоДокПриемка",);
	СтруктураДанныхВозврата.Вставить("КоличествоДокОтгрузка",);
	СтруктураДанныхВозврата.Вставить("КоличествоДокПересчет",);
		
	Запрос = Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ТоварыКПоступлениюОстатки.ДокументПоступления) КАК КоличествоДокПриемка,
	               |	0 КАК КоличествоДокОтгрузка,
	               |	0 КАК КоличествоДокПересчет
	               |ПОМЕСТИТЬ ВТ_Временная
	               |ИЗ
	               |	РегистрНакопления.ТоварыКПоступлению.Остатки(&КонецДня, Склад = &Склад) КАК ТоварыКПоступлениюОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	               |		ПО ТоварыКПоступлениюОстатки.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	               |			И ТоварыКПоступлениюОстатки.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	               |			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	               |ГДЕ
	               |	ТоварыКПоступлениюОстатки.КОформлениюОрдеровОстаток > 0
	               |	И ВЫБОР
	               |			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	               |				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В (&Секция)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	0,
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВЫБОР
	               |			КОГДА ТоварыКОтгрузке.ДокументОтгрузки ССЫЛКА Документ.ЗаказНаПеремещение
	               |				ТОГДА ПеремещениеТоваров.Ссылка
	               |			ИНАЧЕ ВЫБОР
	               |					КОГДА ТоварыКОтгрузке.ДокументОтгрузки ССЫЛКА Документ.ЗаказКлиента
	               |						ТОГДА РеализацияТоваровУслуг.Ссылка
	               |					ИНАЧЕ ТоварыКОтгрузке.ДокументОтгрузки
	               |				КОНЕЦ
	               |		КОНЕЦ),
	               |	0
	               |ИЗ
	               |	РегистрНакопления.ТоварыКОтгрузке.Остатки(&КонецДня, Склад = &Склад) КАК ТоварыКОтгрузке
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	               |		ПО ТоварыКОтгрузке.ДокументОтгрузки = ПеремещениеТоваров.ЗаказНаПеремещение
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	               |		ПО ТоварыКОтгрузке.ДокументОтгрузки = РеализацияТоваровУслуг.ЗаказКлиента
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	               |		ПО ТоварыКОтгрузке.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	               |			И ТоварыКОтгрузке.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	               |			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	               |ГДЕ
	               |	ВЫБОР
	               |			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	               |				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В (&Секция)
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И ТоварыКОтгрузке.КОтгрузкеОстаток > 0
	               |	И ТоварыКОтгрузке.ДокументОтгрузки.Дата >= &ДатаНачалаОрдерной
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	0,
	               |	0,
	               |	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПересчетТоваров.Ссылка)
	               |ИЗ
	               |	Документ.ПересчетТоваров КАК ПересчетТоваров
	               |ГДЕ
	               |	ПересчетТоваров.Склад = &Склад
	               |	И ПересчетТоваров.Проведен = ИСТИНА
	               |	И ПересчетТоваров.Дата МЕЖДУ &НачалоДня И &КонецДня
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СУММА(ВТ_Временная.КоличествоДокПриемка) КАК КоличествоДокПриемка,
	               |	СУММА(ВТ_Временная.КоличествоДокПересчет) КАК КоличествоДокПересчет,
	               |	СУММА(ВТ_Временная.КоличествоДокОтгрузка) КАК КоличествоДокОтгрузка
	               |ИЗ
	               |	ВТ_Временная КАК ВТ_Временная";
	
	Запрос.УстановитьПараметр("Секция", Секция);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("ДатаНачалаОрдерной", Склад.ДатаНачалаОрдернойСхемыПриОтгрузке);
	
	Запрос.УстановитьПараметр("НачалоДня", Началодня(ТекущаяДата()));	
    Запрос.УстановитьПараметр("КонецДня", КонецДня(ТекущаяДата()));	

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		 ЗаполнитьЗначенияСвойств(СтруктураДанныхВозврата,ВыборкаДетальныеЗаписи);
	КонецЦикла;
	 
	Возврат СтруктураДанныхВозврата;
КонецФункции

//Сохранение фотографий в папку
Функция СохранениеФотоВПапку(Сотрудник,ИмяФайла,Файл) Экспорт
	
	Если ЗначениеЗаполнено(Сотрудник.ПутьДляФотоСТСД) Тогда
		ИмяФайла = Сотрудник.ПутьДляФотоСТСД + "\" + ИмяФайла+ ".png";
	Иначе
		ИмяФайла = "\\TG-Storage01\Alterra - общая\Харина М.А\" + ИмяФайла+ ".png";
	КонецЕсли;

	Если Файл <> Неопределено Тогда
            Попытка 
                Файл.Записать(ИмяФайла);
                Сообщить("Файл успешно записан!");
				Возврат ИмяФайла;
            Исключение
                Сообщить(ИмяФайла + "  - Ошибка записи: "+ОписаниеОшибки());
				Возврат "Ошибка записи файла";
            КонецПопытки;
	КонецЕсли;
	
КонецФункции

//Поставка
Функция СкладПересорта(Подразделение, Брак=Ложь)	
	
	Если Брак Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Склады.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Подразделение = &Подразделение
		|   И НЕ Склады.ЭтоГруппа
		|	И Склады.Наименование ПОДОБНО ""%БРАК%""";
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Склады.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Подразделение = &Подразделение
		|   И НЕ Склады.ЭтоГруппа
		|	И Склады.Наименование ПОДОБНО ""%Недостачи%""";
	КонецЕсли;
	 
	Запрос.УстановитьПараметр("Подразделение", Подразделение); 
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		возврат ВыборкаДетальныеЗаписи.ссылка;
	иначе 
		возврат неопределено;
	конецесли;;
	
КонецФункции 

Функция СоздатьПеремещение(Основание, ТоварыТаблица, СоздатьБрак, СоздатьНедостачи) Экспорт
	
	СтруктураВозврата = Новый Структура;
	
	Недостачи = Ложь;
	Брак = Ложь;
	СтрокаЗадачи = ""; 
	
	ТипОснования = ТипЗнч(Основание);
		
	Если ТипОснования = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		СкладОтправительНедостачи = Основание.СкладПолучатель;
		СкладПолучательНедостачи =  Основание.СкладОтправитель;
		КомментарийНедостачи = "АКТ по перемещению № " + Строка(Основание.Номер);
		СкладОтправительБрак = Основание.СкладПолучатель;
		СкладПолучательБрак =  СкладПересорта(СкладОтправительБрак.Подразделение, Истина);
		КомментарийБрак = "АКТ по перемещению № " + Строка(Основание.Номер); 
		Статус = Перечисления.СтатусыПеремещенийТоваров.Отгружено;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		СкладОтправительНедостачи = Основание.Склад;
		СкладПолучательНедостачи =  СкладПересорта(СкладОтправительНедостачи.Подразделение, Ложь);
		КомментарийНедостачи = "АКТ по поступлению № " + Строка(Основание.Номер);
		СкладОтправительБрак = Основание.Склад;
		СкладПолучательБрак =  СкладПересорта(СкладОтправительБрак.Подразделение, Истина);
		КомментарийБрак = "АКТ по поступлению № " + Строка(Основание.Номер);
		Статус = Перечисления.СтатусыПеремещенийТоваров.Принято;
	КонецЕсли;
	
	Если СоздатьНедостачи Тогда 
		
		Док1 = Документы.ПеремещениеТоваров.СоздатьДокумент();
		СсылкаНового = Документы.ПеремещениеТоваров.ПолучитьСсылку();
		Док1.УстановитьСсылкуНового(СсылкаНового);
		СсылкаНовогоДок1 = Док1.ПолучитьСсылкуНового();
		Док1.ОрганизацияПолучатель = СкладПолучательНедостачи.Подразделение.Организация; 
		Док1.Организация = СкладОтправительНедостачи.Подразделение.Организация;
		Док1.Дата= ТекущаяДата();
		Док1.СкладОтправитель = СкладОтправительНедостачи;
		Док1.СкладПолучатель =  СкладПолучательНедостачи;
		Док1.Статус= Статус;
		Док1.Ответственный= Пользователи.ТекущийПользователь();
		Док1.Комментарий = КомментарийНедостачи;
		Док1.СпособДоставки=Перечисления.СпособыДоставки.Самовывоз;
		Док1.ХозяйственнаяОперация=Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		Док1.ФиктивноеПеремещение=Истина;
		
		Для Каждого Товар Из ТоварыТаблица Цикл
			Если Товар.Описание = "Недостачи" Тогда
				Если ТипЗнч(Товар.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
					НоваяСтрока= Док1.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Товар);
					НоваяСтрока.Количество= Товар.КоличествоУпаковок;
				Иначе
					Док1.Комментарий = Док1.Комментарий + Символы.ПС + "Обнаружен неизвестный товар: " + Товар.Номенклатура;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Док1.Записать(РежимЗаписиДокумента.Проведение);
		СтрокаЗадачи = Док1.Комментарий + Символы.ПС;
		
		СтруктураВозврата.Вставить("Недостачи",СсылкаНовогоДок1);
		
	Иначе
		
		СтруктураВозврата.Вставить("Недостачи",Неопределено);
		
	КонецЕсли;
	
	Если СоздатьБрак Тогда
		
		Док2 = Документы.ПеремещениеТоваров.СоздатьДокумент();
		СсылкаНового = Документы.ПеремещениеТоваров.ПолучитьСсылку();
		Док2.УстановитьСсылкуНового(СсылкаНового);
		СсылкаНовогоДок2 = Док2.ПолучитьСсылкуНового();
		Док2.ОрганизацияПолучатель = СкладПолучательБрак.Подразделение.Организация; 
		Док2.Организация = СкладОтправительБрак.Подразделение.Организация;
		Док2.Дата= ТекущаяДата();
		Док2.СкладОтправитель = СкладОтправительБрак;
		Док2.СкладПолучатель =  СкладПолучательБрак;
		Док2.Статус= Статус;
		Док2.Ответственный= Пользователи.ТекущийПользователь();
		Док2.Комментарий = КомментарийБрак;
		Док2.СпособДоставки=Перечисления.СпособыДоставки.Самовывоз;
		Док2.ХозяйственнаяОперация=Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;

		Для Каждого Товар Из ТоварыТаблица Цикл
			Если Товар.Описание = "Брак" Тогда
				Если ТипЗнч(Товар.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
					НоваяСтрока= Док2.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Товар);
					НоваяСтрока.Количество= Товар.КоличествоУпаковок;
				Иначе
					Док2.Комментарий = Док2.Комментарий + Символы.ПС + "Обнаружен неизвестный товар: " + Товар.Номенклатура;
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;
		
		Док2.Записать(РежимЗаписиДокумента.Проведение);
		СтрокаЗадачи = СтрокаЗадачи + Док2.Комментарий + Символы.ПС;
		
		СтруктураВозврата.Вставить("Брак",СсылкаНовогоДок2);
		
	Иначе
		
		СтруктураВозврата.Вставить("Брак",Неопределено);
		
	КонецЕсли;
	
	Возврат СтруктураВозврата;	
КонецФункции

Функция ВнестиИзмененияВЗаказ(ДокументЗаказПоставщику, ТоварыТаблица) Экспорт
	
	ПриобретениеОбъект = Документы.ПриобретениеТоваровУслуг.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(ПриобретениеОбъект,ДокументЗаказПоставщику,,"Номер");
	
	СсылкаНового = Документы.ПриобретениеТоваровУслуг.ПолучитьСсылку();
	ПриобретениеОбъект.УстановитьСсылкуНового(СсылкаНового);
	СсылкаНовогоДок1 = ПриобретениеОбъект.ПолучитьСсылкуНового();
	ПриобретениеОбъект.ДокументОснования = ДокументЗаказПоставщику; 
	ПриобретениеОбъект.Дата= ТекущаяДата()-1;
	ПриобретениеОбъект.ЗаказПоставщику = ДокументЗаказПоставщику;
	ПриобретениеОбъект.ПоступлениеПоЗаказам=Истина;
	ПриобретениеОбъект.Валюта = Справочники.Валюты.НайтиПоКоду("643");
	ПриобретениеОбъект.ВалютаВзаиморасчетов = Справочники.Валюты.НайтиПоКоду("643");
	
	Для каждого Строка из ТоварыТаблица Цикл
		КоличествоФакт = Строка.КоличествоФакт;
		Если КоличествоФакт > Строка.КоличествоУпаковок  Тогда
			Если ТипЗнч(Строка.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
				НоваяСтрока = ПриобретениеОбъект.Товары.Добавить();
				ПараметрыОтбора = Новый Структура("КодСтроки",Строка.КодСтроки);
				НайденныеСтроки = ДокументЗаказПоставщику.Товары.НайтиСтроки(ПараметрыОтбора);
				Если НайденныеСтроки.Количество()>0 Тогда
					Для каждого НайденнаяСтрока из НайденныеСтроки Цикл
						НоваяСтрока2 = ПриобретениеОбъект.Товары.Добавить();
                        ЗаполнитьЗначенияСвойств(НоваяСтрока2,НайденнаяСтрока);
						ЗаполнитьЗначенияСвойств(НоваяСтрока,НайденнаяСтрока);
					КонецЦикла;
				Иначе
					ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
					НоваяСтрока.Склад = ПриобретениеОбъект.Склад;
				КонецЕсли;
				НоваяСтрока.КодСтроки = 0;
				НоваяСтрока.Количество = КоличествоФакт-Строка.КоличествоУпаковок;
				НоваяСтрока.КоличествоУпаковок = КоличествоФакт-Строка.КоличествоУпаковок;
				Иначе
				ПриобретениеОбъект.Комментарий = ПриобретениеОбъект.Комментарий + Символы.ПС + "Обнаружен неизвестный товар: " + Строка.Номенклатура;
			КонецЕсли;
		Иначе   
			   НоваяСтрока = ПриобретениеОбъект.Товары.Добавить();
				ПараметрыОтбора = Новый Структура("КодСтроки",Строка.КодСтроки);
				НайденныеСтроки = ДокументЗаказПоставщику.Товары.НайтиСтроки(ПараметрыОтбора);
				Если НайденныеСтроки.Количество()>0 Тогда
					Для каждого НайденнаяСтрока из НайденныеСтроки Цикл
						ЗаполнитьЗначенияСвойств(НоваяСтрока,НайденнаяСтрока);
					КонецЦикла;
				КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	ПриобретениеОбъект.Записать(РежимЗаписиДокумента.Проведение);

    ПоступлениеДокумент = СсылкаНовогоДок1;

    Возврат ПоступлениеДокумент;

