Функция СоздатьПриобретениеТоваровУслуг(ДокументЗаказПоставщику, ТоварыТаблица) Экспорт
	
	ПриобретениеОбъект = Документы.ПриобретениеТоваровУслуг.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(ПриобретениеОбъект,ДокументЗаказПоставщику,,"Номер");
	
	СсылкаНового = Документы.ПриобретениеТоваровУслуг.ПолучитьСсылку();
	ПриобретениеОбъект.УстановитьСсылкуНового(СсылкаНового);
	СсылкаНовогоДок1 = ПриобретениеОбъект.ПолучитьСсылкуНового();
	ПриобретениеОбъект.ДокументОснования = ДокументЗаказПоставщику; 
	ПриобретениеОбъект.Дата= ТекущаяДата()-1;
	ПриобретениеОбъект.ЗаказПоставщику = ДокументЗаказПоставщику;
	ПриобретениеОбъект.ПоступлениеПоЗаказам=Истина;
	ПриобретениеОбъект.Валюта = Справочники.Валюты.НайтиПоКоду("643");
