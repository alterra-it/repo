// Функция - Есть ли не заблокированные товары
//
// Параметры:
//  Распоряжение	 - 	 - 
//  ПриходныйОрдер	 - 	 - 
// 
// Возвращаемое значение:
//   - 
//
Функция ЕстьЛиНеЗаблокированныеТовары(Распоряжение,ПриходныйОрдер) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыКПоступлениюОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлениюОстатки.Характеристика КАК Характеристика,
		|	СУММА(-1 * ТоварыКПоступлениюОстатки.КОформлениюОрдеровОстаток) КАК КоличествоУпаковок
		|ПОМЕСТИТЬ ИзлишкиПоПоступлению
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Остатки(
		|			,
		|			(Номенклатура, Характеристика) В
		|				(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|					ПриходныйОрдерНаТоварыТовары.Номенклатура КАК Номенклатура,
		|					ПриходныйОрдерНаТоварыТовары.Характеристика КАК Характеристика
		|				ИЗ
		|					Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
		|				ГДЕ
		|					ПриходныйОрдерНаТоварыТовары.Ссылка = &ПриходныйОрдер)) КАК ТоварыКПоступлениюОстатки
		|ГДЕ
		|	ТоварыКПоступлениюОстатки.ДокументПоступления = &ДокументПоступления
		|	И ТоварыКПоступлениюОстатки.КОформлениюОрдеровОстаток < 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКПоступлениюОстатки.Номенклатура,
		|	ТоварыКПоступлениюОстатки.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	БлокировкаДвиженияТоваровТовары.Номенклатура КАК Номенклатура,
		|	БлокировкаДвиженияТоваровТовары.Характеристика КАК Характеристика,
		|	СУММА(БлокировкаДвиженияТоваровТовары.КоличествоУпаковок) КАК КоличествоУпаковок
		|ПОМЕСТИТЬ ЗаблокированныеТовары
		|ИЗ
		|	Документ.БлокировкаДвиженияТоваров.Товары КАК БлокировкаДвиженияТоваровТовары
		|ГДЕ
		|	БлокировкаДвиженияТоваровТовары.Ссылка.Статус = &Статус
		|	И БлокировкаДвиженияТоваровТовары.Ссылка.ДокументОснование = &ПриходныйОрдер
		|	И БлокировкаДвиженияТоваровТовары.Ссылка.Проведен = ИСТИНА
		|
		|СГРУППИРОВАТЬ ПО
		|	БлокировкаДвиженияТоваровТовары.Номенклатура,
		|	БлокировкаДвиженияТоваровТовары.Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА КАК Результат
		|ПОМЕСТИТЬ ВТЕстьРасхождения
		|ИЗ
		|	ИзлишкиПоПоступлению КАК ИзлишкиПоПоступлению
		|		ПОЛНОЕ СОЕДИНЕНИЕ ЗаблокированныеТовары КАК ЗаблокированныеТовары
		|		ПО (ЗаблокированныеТовары.Номенклатура = ИзлишкиПоПоступлению.Номенклатура)
		|			И (ЗаблокированныеТовары.Характеристика = ИзлишкиПоПоступлению.Характеристика)
		|ГДЕ
		|	ЕСТЬNULL(ИзлишкиПоПоступлению.КоличествоУпаковок, 0) - ЕСТЬNULL(ЗаблокированныеТовары.КоличествоУпаковок, 0) <> 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Излишки.Номенклатура КАК Номенклатура,
		|	Излишки.Характеристика КАК Характеристика,
		|	Излишки.КоличествоУпаковок КАК КоличествоУпаковок
		|ИЗ
		|	ИзлишкиПоПоступлению КАК Излишки
		|ГДЕ
		|	ИСТИНА В
		|			(ВЫБРАТЬ
		|				ВТЕстьРасхождения.Результат
		|			ИЗ
		|				ВТЕстьРасхождения)";

	Запрос.УстановитьПараметр("ДокументПоступления", Распоряжение);
	Запрос.УстановитьПараметр("ПриходныйОрдер", ПриходныйОрдер);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано);
				
	Возврат Запрос.Выполнить();
		
КонецФункции

