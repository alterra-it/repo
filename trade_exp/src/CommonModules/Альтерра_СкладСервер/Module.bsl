				        НоваяСтрока2.КоличествоУпаковок = Строка.Количество - НайденнаяСтрока.Количество;
					КонецЕсли;
				Иначе
					 Если Строка.Количество <> 0 Тогда
					 НоваяСтрока1 = ПриобретениеОбъект.Товары.Добавить();
					 ЗаполнитьЗначенияСвойств(НоваяСтрока1,НайденнаяСтрока);
					 НоваяСтрока1.Количество = Строка.Количество;
				     НоваяСтрока1.КоличествоУпаковок = Строка.Количество;
					 КонецЕсли;
				КонецЕсли;
					КонецЦикла;
				Иначе
					Если Строка.Количество <> 0 Тогда
					НоваяСтрока = ПриобретениеОбъект.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
					НоваяСтрока.КодСтроки = 0;
				    НоваяСтрока.Количество = Строка.Количество;
				    НоваяСтрока.КоличествоУпаковок = Строка.Количество;
					НоваяСтрока.Склад = ПриобретениеОбъект.Склад;
					КонецЕсли;
				КонецЕсли;
				Иначе
				ПриобретениеОбъект.Комментарий = ПриобретениеОбъект.Комментарий + Символы.ПС + "Обнаружен неизвестный товар: " + Строка.Номенклатура;
		КонецЕсли;
	КонецЦикла;
	
	ПриобретениеОбъект.Записать(РежимЗаписиДокумента.Проведение);

    ПоступлениеДокумент = СсылкаНовогоДок1;

    Возврат ПоступлениеДокумент;

