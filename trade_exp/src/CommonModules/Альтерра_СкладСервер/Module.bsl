		Если ТипЗнч(Строка.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
				ПараметрыОтбора = Новый Структура("КодСтроки",Строка.КодСтроки);
				НайденныеСтроки = ДокументЗаказПоставщику.Товары.НайтиСтроки(ПараметрыОтбора);
				Если НайденныеСтроки.Количество()<>0 Тогда
					Для каждого НайденнаяСтрока из НайденныеСтроки Цикл
						Если НайденнаяСтрока.Количество <= Строка.Количество Тогда
						НоваяСтрока1 = ПриобретениеОбъект.Товары.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока1,НайденнаяСтрока);
						Если НайденнаяСтрока.Количество < Строка.Количество Тогда
						НоваяСтрока2 = ПриобретениеОбъект.Товары.Добавить();
   						ЗаполнитьЗначенияСвойств(НоваяСтрока2,НайденнаяСтрока);
						НоваяСтрока2.КодСтроки = 0;
