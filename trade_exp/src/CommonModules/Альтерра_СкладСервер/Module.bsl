Функция СоздатьПеремещениеНедостачиБрак(Основание, ТоварыТаблица, СоздатьБрак, СоздатьНедостачи) Экспорт
	
	СтруктураВозврата = Новый Структура;
	
	Недостачи = Ложь;
	Брак = Ложь;
	СтрокаЗадачи = ""; 
	
	ТипОснования = ТипЗнч(Основание);
		
	Если ТипОснования = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		СкладОтправительНедостачи = Основание.СкладПолучатель;
		СкладПолучательНедостачи =  Основание.СкладОтправитель;
		КомментарийНедостачи = "АКТ по перемещению № " + Строка(Основание.Номер);
		СкладОтправительБрак = Основание.СкладПолучатель;
		СкладПолучательБрак =  СкладПересорта(СкладОтправительБрак.Подразделение, Истина);
		КомментарийБрак = "АКТ по перемещению № " + Строка(Основание.Номер); 
		Статус = Перечисления.СтатусыПеремещенийТоваров.Отгружено;
	ИначеЕсли ТипОснования = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		СкладОтправительНедостачи = Основание.Склад;
		СкладПолучательНедостачи =  СкладПересорта(СкладОтправительНедостачи.Подразделение, Ложь);
		КомментарийНедостачи = "АКТ по поступлению № " + Строка(Основание.Номер);
		СкладОтправительБрак = Основание.Склад;
		СкладПолучательБрак =  СкладПересорта(СкладОтправительБрак.Подразделение, Истина);
		КомментарийБрак = "АКТ по поступлению № " + Строка(Основание.Номер);
		Статус = Перечисления.СтатусыПеремещенийТоваров.Принято;
	КонецЕсли;
	
	Если СоздатьНедостачи Тогда 
		
		Док1 = Документы.ПеремещениеТоваров.СоздатьДокумент();
		СсылкаНового = Документы.ПеремещениеТоваров.ПолучитьСсылку();
		Док1.УстановитьСсылкуНового(СсылкаНового);
		СсылкаНовогоДок1 = Док1.ПолучитьСсылкуНового();
		Док1.ОрганизацияПолучатель = СкладПолучательНедостачи.Подразделение.Организация; 
		Док1.Организация = СкладОтправительНедостачи.Подразделение.Организация;
		Док1.Дата= ТекущаяДата();
		Док1.СкладОтправитель = СкладОтправительНедостачи;
		Док1.СкладПолучатель =  СкладПолучательНедостачи;
		Док1.Статус= Статус;
		Док1.Ответственный= Пользователи.ТекущийПользователь();
		Док1.Комментарий = КомментарийНедостачи;
		Док1.СпособДоставки=Перечисления.СпособыДоставки.Самовывоз;
		Док1.ХозяйственнаяОперация=Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		Док1.ФиктивноеПеремещение=Истина;
		
		Для Каждого Товар Из ТоварыТаблица Цикл
				Если ТипЗнч(Товар.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
					НоваяСтрока= Док1.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Товар,,"КодСтроки");
					НоваяСтрока.КоличествоУпаковок = Товар.Количество;
				Иначе
					Док1.Комментарий = Док1.Комментарий + Символы.ПС + "Обнаружен неизвестный товар: " + Товар.Номенклатура;
				КонецЕсли;
		КонецЦикла;
		
		Док1.Записать(РежимЗаписиДокумента.Проведение);
		СтрокаЗадачи = Док1.Комментарий + Символы.ПС;
		
		СтруктураВозврата.Вставить("Недостачи",СсылкаНовогоДок1);
		
	Иначе
		
		СтруктураВозврата.Вставить("Недостачи",Неопределено);
		
	КонецЕсли;
	
	Если СоздатьБрак Тогда
		
		Док2 = Документы.ПеремещениеТоваров.СоздатьДокумент();
		СсылкаНового = Документы.ПеремещениеТоваров.ПолучитьСсылку();
		Док2.УстановитьСсылкуНового(СсылкаНового);
		СсылкаНовогоДок2 = Док2.ПолучитьСсылкуНового();
		Док2.ОрганизацияПолучатель = СкладПолучательБрак.Подразделение.Организация; 
		Док2.Организация = СкладОтправительБрак.Подразделение.Организация;
		Док2.Дата= ТекущаяДата();
		Док2.СкладОтправитель = СкладОтправительБрак;
		Док2.СкладПолучатель =  СкладПолучательБрак;
		Док2.Статус= Статус;
		Док2.Ответственный= Пользователи.ТекущийПользователь();
		Док2.Комментарий = КомментарийБрак;
		Док2.СпособДоставки=Перечисления.СпособыДоставки.Самовывоз;
		Док2.ХозяйственнаяОперация=Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		Док2.ФиктивноеПеремещение=Истина;

		Для Каждого Товар Из ТоварыТаблица Цикл
				Если ТипЗнч(Товар.Номенклатура) = Тип("СправочникСсылка.Номенклатура") Тогда
					НоваяСтрока= Док2.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, Товар,,"КодСтроки");
					НоваяСтрока.КоличествоУпаковок= Товар.Количество;
				Иначе
					Док2.Комментарий = Док2.Комментарий + Символы.ПС + "Обнаружен неизвестный товар: " + Товар.Номенклатура;
				КонецЕсли;	
		КонецЦикла;
		
		Док2.Записать(РежимЗаписиДокумента.Проведение);
		СтрокаЗадачи = СтрокаЗадачи + Док2.Комментарий + Символы.ПС;
		
		СтруктураВозврата.Вставить("Брак",СсылкаНовогоДок2);
		
	Иначе
		
		СтруктураВозврата.Вставить("Брак",Неопределено);
		
	КонецЕсли;
	
	Если Не ПустаяСтрока(СтрокаЗадачи) Тогда
		НоваяЗадача=Задачи.ЗадачаИсполнителя.СоздатьЗадачу();
		НоваяЗадача.Дата = ТекущаяДата();
		НоваяЗадача.Автор = Пользователи.ТекущийПользователь();
		НоваяЗадача.РольИсполнителя = Справочники.РолиИсполнителей.НайтиПоНаименованию("Отдел качества");
		НоваяЗадача.Наименование = "Созданы акты расхождений";
		НоваяЗадача.Важность = Перечисления.ВариантыВажностиЗадачи.Высокая;
		НоваяЗадача.Предмет = Основание; 
		НоваяЗадача.Описание = СтрокаЗадачи; 
		НоваяЗадача.Записать();
	КонецЕсли;

	Возврат СтруктураВозврата;
		
	
КонецФункции

Функция ИспользуетсяНоваяСхемаРаботыСклада(Дата) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	НоваяСхемаУчета = Дата >= Константы.ДатаНачалаДействияНовогоУчетаПоСкладу.Получить() 
		         И Константы.ИспользуетсяНоваяСхемаУчетаПоСкладу.Получить()=Истина;

	УстановитьПривилегированныйРежим(Ложь);
		
	Возврат НоваяСхемаУчета;	
			 
КонецФункции
		 
Функция РабочийУчастокСоздаватьПоставкиНаСклад(РабочийУчасток) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	РабочийУчастокВключен = ?(ЗначениеЗаполнено(РабочийУчасток),?(РабочийУчасток.ИспользуетсяВПриемкеСТСД = Истина,Истина,Ложь),Ложь);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат РабочийУчастокВключен;
	
КонецФункции

Функция РабочийУчастокСоздаватьОтгрузкиСоСклада(РабочийУчасток) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	РабочийУчастокВключен = ?(ЗначениеЗаполнено(РабочийУчасток),?(РабочийУчасток.ИспользуетсяВОтгрузкеСТСД = Истина,Истина,Ложь),Ложь);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат РабочийУчастокВключен;
	
КонецФункции

Функция ДокументОснованиеПрошелКПП(Документ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостояниеОтгрузкиДокументаСрезПоследних.Документ КАК Документ
		|ИЗ
		|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних КАК СостояниеОтгрузкиДокументаСрезПоследних
		|ГДЕ
		|	СостояниеОтгрузкиДокументаСрезПоследних.Документ = &Документ
		|	И СостояниеОтгрузкиДокументаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Заехал)";
	
	Запрос.УстановитьПараметр("Документ", Документ);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
		
КонецФункции

Функция ПолучитьТаблицуДвиженийРазмещениеАльтерра(Ссылка) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
		|	ЗаказПоставщикуТовары.Характеристика КАК Характеристика,
		|	ЗаказПоставщикуТовары.Ссылка КАК Документ,
		|	ЗаказПоставщикуТовары.КоличествоУпаковок КАК КРазмещению,
		|	ЗаказПоставщикуТовары.Склад КАК Склад,
		|	ЗаказПоставщикуТовары.ДатаПоступления КАК Период
		|ПОМЕСТИТЬ ВТ_Объединение
		|ИЗ
		|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
		|ГДЕ
		|	ЗаказПоставщикуТовары.Ссылка = &Ссылка
		|	И ЗаказПоставщикуТовары.Отменено = ЛОЖЬ
		|	И ЗаказПоставщикуТовары.ДатаПоступления <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.Номенклатура,
		|	ПеремещениеТоваровТовары.Характеристика,
		|	ПеремещениеТоваровТовары.Ссылка,
		|	ПеремещениеТоваровТовары.КоличествоУпаковок,
		|	ПеремещениеТоваровТовары.Ссылка.СкладПолучатель,
		|	ПеремещениеТоваровТовары.Ссылка.ДатаПоставкиНаСклад
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка = &Ссылка
		|	И ПеремещениеТоваровТовары.Ссылка.ДатаПоставкиНаСклад <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Объединение.Период КАК Период,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ВТ_Объединение.Документ КАК Документ,
		|	ВТ_Объединение.Номенклатура КАК Номенклатура,
		|	ВТ_Объединение.Характеристика КАК Характеристика,
		|	ВТ_Объединение.Склад КАК Склад,
		|	ВТ_Объединение.КРазмещению КАК КРазмещению
		|ИЗ
		|	ВТ_Объединение КАК ВТ_Объединение
		|ГДЕ
		|	ВТ_Объединение.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТЗ;
	
КонецФункции

Функция ПолучитьТаблицуДвиженийРазмещениеПоРейсам(Ссылка) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	ДатаНачала = Константы.ДатаНачалаЗаписиДвиженийПоПоставкам.Получить();
	
	Если ДатаНачала = Дата(1,1,1) Тогда
		Возврат Новый ТаблицаЗначений;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК ДокументПродажи,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.Дата КАК ДатаПрибытияНаСклад,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_Основания
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка = &Документ
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	РейсОтПоставщикаРасчетДоставки.ДокументОснование,
		|	РейсОтПоставщикаРасчетДоставки.Ссылка.ДатаПрибытияНаСклад,
		|	РейсОтПоставщикаРасчетДоставки.Ссылка
		|ИЗ
		|	Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		|ГДЕ
		|	РейсОтПоставщикаРасчетДоставки.Ссылка = &Документ
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	РейсСиламиПоставщикаОснования.Документ,
		|	РейсСиламиПоставщикаОснования.Ссылка.Дата,
		|	РейсСиламиПоставщикаОснования.Ссылка
		|ИЗ
		|	Документ.РейсСиламиПоставщика.Основания КАК РейсСиламиПоставщикаОснования
		|ГДЕ
		|	РейсСиламиПоставщикаОснования.Ссылка = &Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Основания.Ссылка КАК Ссылка,
		|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
		|	ЗаказПоставщикуТовары.Характеристика КАК Характеристика,
		|	ЗаказПоставщикуТовары.Ссылка КАК Документ,
		|	ЗаказПоставщикуТовары.КоличествоУпаковок КАК КРазмещению,
		|	ЗаказПоставщикуТовары.Склад КАК Склад,
		|	ВТ_Основания.ДатаПрибытияНаСклад КАК ДатаПоРейсу,
		|	ЗаказПоставщикуТовары.ДатаПоступления КАК ДатаПоДокументу
		|ПОМЕСТИТЬ ВТ_Объединение
		|ИЗ
		|	ВТ_Основания КАК ВТ_Основания
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
		|		ПО ВТ_Основания.ДокументПродажи = ЗаказПоставщикуТовары.Ссылка
		|ГДЕ
		|	ЗаказПоставщикуТовары.Отменено = ЛОЖЬ
		|	И ЗаказПоставщикуТовары.ДатаПоступления <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|	И ЗаказПоставщикуТовары.Ссылка.Дата >= &Дата
		|	И ВТ_Основания.ДатаПрибытияНаСклад <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_Основания.Ссылка,
		|	ПеремещениеТоваровТовары.Номенклатура,
		|	ПеремещениеТоваровТовары.Характеристика,
		|	ПеремещениеТоваровТовары.Ссылка,
		|	ПеремещениеТоваровТовары.КоличествоУпаковок,
		|	ПеремещениеТоваровТовары.Ссылка.СкладПолучатель,
		|	ВТ_Основания.ДатаПрибытияНаСклад,
		|	ПеремещениеТоваровТовары.Ссылка.ДатаПоставкиНаСклад
		|ИЗ
		|	ВТ_Основания КАК ВТ_Основания
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|		ПО ВТ_Основания.ДокументПродажи = ПеремещениеТоваровТовары.Ссылка
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка.Дата >= &Дата
		|	И ПеремещениеТоваровТовары.Ссылка.ДатаПоставкиНаСклад <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|	И ВТ_Основания.ДатаПрибытияНаСклад <> ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Объединение.Документ КАК Документ,
		|	ВТ_Объединение.Номенклатура КАК Номенклатура,
		|	ВТ_Объединение.Характеристика КАК Характеристика,
		|	ВТ_Объединение.Склад КАК Склад,
		|	СУММА(ВТ_Объединение.КРазмещению) КАК КРазмещению,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	ВТ_Объединение.ДатаПоРейсу КАК Период,
		|	ВТ_Объединение.Ссылка КАК Рейс
		|ИЗ
		|	ВТ_Объединение КАК ВТ_Объединение
		|ГДЕ
		|	ВТ_Объединение.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Объединение.Документ,
		|	ВТ_Объединение.Номенклатура,
		|	ВТ_Объединение.Характеристика,
		|	ВТ_Объединение.Склад,
		|	ВТ_Объединение.ДатаПоРейсу,
		|	ВТ_Объединение.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТ_Объединение.Документ,
		|	ВТ_Объединение.Номенклатура,
		|	ВТ_Объединение.Характеристика,
		|	ВТ_Объединение.Склад,
		|	СУММА(ВТ_Объединение.КРазмещению),
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход),
		|	ВТ_Объединение.ДатаПоДокументу,
		|	NULL
		|ИЗ
		|	ВТ_Объединение КАК ВТ_Объединение
		|ГДЕ
		|	ВТ_Объединение.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Объединение.Документ,
		|	ВТ_Объединение.Номенклатура,
		|	ВТ_Объединение.Характеристика,
		|	ВТ_Объединение.Склад,
		|	ВТ_Объединение.ДатаПоДокументу";
	
	Запрос.УстановитьПараметр("Документ", Ссылка);
	Запрос.УстановитьПараметр("Дата", ДатаНачала);

	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТЗ;
	
КонецФункции
	
Функция ИспользуетсяНоваяСхемаРаботыСПоставками(Дата) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	ДатаНачала = Константы.ДатаНачалаЗаписиДвиженийПоПоставкам.Получить();

	НоваяСхемаРаботыПоставок = Дата >= ДатаНачала И НЕ ДатаНачала = Дата(1,1,1);

	УстановитьПривилегированныйРежим(Ложь);
		
	Возврат НоваяСхемаРаботыПоставок;	
			 
КонецФункции

Функция ПроверитьОстаткиНаОфорлениеОрдеров(ДокументОснование) Экспорт
	
	СтруктураОтвета = Новый Структура();
	СтруктураОтвета.Вставить("ЕстьРасхожденияСОрдерами");
	СтруктураОтвета.Вставить("ТекстРасхождений");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Номенклатура КАК Номенклатура,
		|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Характеристика КАК Характеристика,
		|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Склад КАК Склад,
		|	СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовПриход) КАК КОформлениюАктовПриход,
		|	СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовРасход) КАК КОформлениюАктовРасход,
		|	-1 * (СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовПриход) - СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовРасход)) КАК КОформлениюОрдеров
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
		|	РегистрНакопления.ТоварыКОформлениюИзлишковНедостач.ОстаткиИОбороты(, , Авто, , ) КАК ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты
		|ГДЕ
		|	(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор = &Регистратор
		|			ИЛИ ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор.Основание = &Регистратор)
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Номенклатура,
		|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Характеристика,
		|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Склад
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.Номенклатура КАК Номенклатура,
		|	ВременнаяТаблица.Характеристика КАК Характеристика,
		|	ВременнаяТаблица.КОформлениюОрдеров КАК КОформлениюОрдеров
		|ИЗ
		|	ВременнаяТаблица КАК ВременнаяТаблица
		|ГДЕ
		|	ВременнаяТаблица.КОформлениюОрдеров <> 0";
	
	Запрос.УстановитьПараметр("Регистратор", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Количество()=0 Тогда
		СтруктураОтвета.ЕстьРасхожденияСОрдерами = Ложь;
	Иначе
		СтруктураОтвета.ЕстьРасхожденияСОрдерами = Истина;
		ТекстОтвета = "";
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ТекстОтвета = ТекстОтвета + ВыборкаДетальныеЗаписи.Номенклатура + " к оформлению ордеров " + ВыборкаДетальныеЗаписи.КОформлениюОрдеров + Символы.ПС; 	
		КонецЦикла;
		СтруктураОтвета.ТекстРасхождений = ТекстОтвета;
	КонецЕсли;
	
	Возврат СтруктураОтвета;
	
КонецФункции

Процедура СоздатьОрдераПоАктам(ДокументРаспоряжение) Экспорт
	
	НачатьТранзакцию();
	Попытка
		    СоздатьОрдера(ДокументРаспоряжение);
			ЗафиксироватьТранзакцию();
	Исключение
        ОтменитьТранзакцию();
		Сообщить("Не удалось создать ордера!");
		Сообщить(ИнформацияОбОшибке().Описание);
	КонецПопытки;
	
КонецПроцедуры

Процедура СоздатьОрдерДляКорректировкаПриобретения(ДокументРаспоряжение, ВидОрдера) Экспорт 
	
	НачатьТранзакцию(); 
	Попытка 
		ОрдерДляКорректировкиПриобретения(ДокументРаспоряжение, ВидОрдера);
		ЗафиксироватьТранзакцию();
	Исключение 
		ОтменитьТранзакцию();
		Сообщить("Не удалось создать ордер!"); 
		Сообщить(ИнформацияОбОшибке().Описание);
	КонецПопытки; 
	
КонецПроцедуры

Процедура ОрдерДляКорректировкиПриобретения(ДокументРаспоряжение, ВидОрдера)
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КорректировкаПриобретенияРасхождения.Номенклатура КАК Номенклатура,
	|	КорректировкаПриобретенияРасхождения.Характеристика КАК Характеристика,
	|	КорректировкаПриобретенияРасхождения.Назначение КАК Назначение,
	|	КорректировкаПриобретенияРасхождения.Количество КАК Количество,
	|	КорректировкаПриобретенияРасхождения.Количество КАК КоличествоУпаковок,
	|	КорректировкаПриобретенияРасхождения.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	КорректировкаПриобретения.Ссылка КАК Основание,
	|	КорректировкаПриобретения.Организация КАК Организация,
	|	КорректировкаПриобретения.Склад КАК Склад,
	|	КорректировкаПриобретенияРасхождения.Серия КАК Серия,
	|	КорректировкаПриобретенияРасхождения.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция
	|ИЗ
	|	Документ.КорректировкаПриобретения.Расхождения КАК КорректировкаПриобретенияРасхождения
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаПриобретения КАК КорректировкаПриобретения
	|		ПО (КорректировкаПриобретенияРасхождения.Ссылка = КорректировкаПриобретения.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|				ПО КорректировкаПриобретенияРасхождения.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|					И КорректировкаПриобретения.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|					И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|
	|ГДЕ
	|	КорректировкаПриобретения.Ссылка = &Ссылка
	|ИТОГИ ПО
	|	Секция"; 
	
	Запрос.УстановитьПараметр("Ссылка", ДокументРаспоряжение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСекция = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСекция.Следующий() Цикл
		
		Ордер = ОрдерДляКорректировкиПриобретенияПоРаспоряжениюИСекции(ДокументРаспоряжение,ВыборкаСекция.Секция, ВидОрдера);
		
		Если Ордер = Неопределено Тогда
			
			Если ВидОрдера = "Отражение излишков" Тогда
				 Ордер = Документы.ОрдерНаОтражениеИзлишковТоваров.СоздатьДокумент();
			КонецЕсли;
			
			Если ВидОрдера = "Отражение недостач" Тогда
				 Ордер = Документы.ОрдерНаОтражениеНедостачТоваров.СоздатьДокумент();
			КонецЕсли;
			
			Ордер.Дата = ТекущаяДата();
			Ордер.Основание = ДокументРаспоряжение;
		    Ордер.Склад =  ДокументРаспоряжение.Склад;
		    Ордер.РабочийУчасток = ВыборкаСекция.Секция;
			Ордер.Комментарий = ДокументРаспоряжение.Комментарий;
			
		Иначе
			Ордер = Ордер.Ссылка.ПолучитьОбъект();
			
			Если Ордер.ПометкаУдаления = Истина Тогда
				 АльтерраОбщегоНазначения.СообщитьПользователю(Ордер.Ссылка,"Есть созданный ордер, который помечен на удаление! Снимите пометку на удаление и попробуйте создать ордера заново! - " + Строка(Ордер.Ссылка));
				 Возврат;
			КонецЕсли;
			 
		КонецЕсли;		
		
		Если Не ЗначениеЗаполнено(Ордер.Ответственный) Тогда
			Ордер.Ответственный = Пользователи.ТекущийПользователь();
		КонецЕсли;
		
		Ордер.Товары.Очистить();
		
		ВыборкаДетальныеЗаписи = ВыборкаСекция.Выбрать();
	
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Если ВидОрдера = "Отражение излишков" И ВыборкаДетальныеЗаписи.Количество > 0 Тогда
				НоваяСтрока = Ордер.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
			КонецЕсли;
			Если ВидОрдера = "Отражение недостач" И ВыборкаДетальныеЗаписи.Количество < 0 Тогда	
				НоваяСтрока = Ордер.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,ВыборкаДетальныеЗаписи);
				НоваяСтрока.Количество = ВыборкаДетальныеЗаписи.Количество * (-1);
				НоваяСтрока.КоличествоУпаковок = ВыборкаДетальныеЗаписи.КоличествоУпаковок * (-1);

			КонецЕсли; 
		КонецЦикла;
		
		Ордер.Записать(РежимЗаписиДокумента.Проведение);
		АльтерраОбщегоНазначения.СообщитьПользователю(Ордер.Ссылка,"Создан/обновлен документ " + Строка(Ордер.Ссылка));
	КонецЦикла;

КонецПроцедуры

Функция ОрдерДляКорректировкиПриобретенияПоРаспоряжениюИСекции(Распоряжение,Секция, ВидОрдера)
	
	СсылкаНаДокумент = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОрдерНаОтражениеИзлишковТоваров.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ОрдерНаОтражениеИзлишковТоваров КАК ОрдерНаОтражениеИзлишковТоваров
		|ГДЕ
		|	ОрдерНаОтражениеИзлишковТоваров.Основание = &Основание
		|	И ОрдерНаОтражениеИзлишковТоваров.РабочийУчасток = &РабочийУчасток
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ОрдерНаОтражениеНедостачТоваров.Ссылка
		|ИЗ
		|	Документ.ОрдерНаОтражениеНедостачТоваров КАК ОрдерНаОтражениеНедостачТоваров
		|ГДЕ
		|	ОрдерНаОтражениеНедостачТоваров.Основание = &Основание
		|	И ОрдерНаОтражениеНедостачТоваров.РабочийУчасток = &РабочийУчасток";
	
	Запрос.УстановитьПараметр("Основание", Распоряжение);
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если (ТипЗнч(ВыборкаДетальныеЗаписи.Ссылка) = Тип("ДокументСсылка.ОприходованиеИзлишковТоваров") И ВидОрдера = "Отражение излишков") ИЛИ  (ТипЗнч(ВыборкаДетальныеЗаписи.Ссылка) = Тип("ДокументСсылка.СписаниеНедостачТоваров") И ВидОрдера = "Отражение недостач") Тогда 
	     СсылкаНаДокумент = ВыборкаДетальныеЗаписи.Ссылка;
	 КонецЕсли; 
	КонецЦикла;
	
	Возврат СсылкаНаДокумент;

КонецФункции

