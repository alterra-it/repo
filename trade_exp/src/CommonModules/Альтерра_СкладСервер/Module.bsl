Процедура СоздатьИзменитьБлокировкуДвиженияТоваров(ДокументБлокировкиДвижения,ПараметрыЗаполнения, ТоварыВТЗ = Ложь) Экспорт
	
	ДокументБлокировкиДвижения.Дата = ПараметрыЗаполнения.Дата;
	ДокументБлокировкиДвижения.Склад = ПараметрыЗаполнения.Склад;
	ДокументБлокировкиДвижения.ДокументОснование =  ПараметрыЗаполнения.ДокументОснование;
	ДокументБлокировкиДвижения.Статус = ПараметрыЗаполнения.Статус;
	ДокументБлокировкиДвижения.ПричинаБлокировки = ПараметрыЗаполнения.ПричинаБлокировки;
    ДокументБлокировкиДвижения.Ответственный = Пользователи.ТекущийПользователь();
    ДокументБлокировкиДвижения.Комментарий = ПараметрыЗаполнения.Комментарий;
    
    ДопСвойство = Новый Структура();
    ПараметрыЗаполнения.Свойство("ДополнительныеСвойства", ДопСвойство);
    Если ДопСвойство <> Неопределено тогда
	    Для Каждого ТекущийПараметр из ДопСвойство Цикл
	     ДокументБлокировкиДвижения.ДополнительныеСвойства.Вставить(ТекущийПараметр.Ключ, ТекущийПараметр.Значение);
	    КонецЦикла;
    Конецесли;
    
    
	Если ТоварыВТЗ Тогда
		ДокументБлокировкиДвижения.Товары.Загрузить(ПараметрыЗаполнения.Товары);
	Иначе
    	ДокументБлокировкиДвижения.Товары.Загрузить(ПараметрыЗаполнения.Товары.Выгрузить());
	КонецЕсли;
	Попытка
        ДокументБлокировкиДвижения.Записать(РежимЗаписиДокумента.Проведение);
		АльтерраОбщегоНазначения.СообщитьПользователю(ДокументБлокировкиДвижения.Ссылка, "Создан/обновлен документ: "+ДокументБлокировкиДвижения.Ссылка + ". Основание - " + ПараметрыЗаполнения.ДокументОснование);
    Исключение
        Сообщить("Не удалось создать/обновить документ " + ДокументБлокировкиДвижения);	
	КонецПопытки;
    
КонецПроцедуры

Функция ПолучитьБлокировкиПоОснования(Основание) Экспорт
	  		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаДвиженияТоваров.Ссылка КАК Ссылка,
		|	ВЫБОР
		|		КОГДА БлокировкаДвиженияТоваров.ПричинаБлокировки = &ПричинаРасхождениеКМ
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ПричинаРасхождениеКМ
		|ИЗ
		|	Документ.БлокировкаДвиженияТоваров КАК БлокировкаДвиженияТоваров
		|ГДЕ
		|	БлокировкаДвиженияТоваров.ДокументОснование = &ДокументОснование
		|	И БлокировкаДвиженияТоваров.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("ДокументОснование", Основание);
	Запрос.УстановитьПараметр("ПричинаРасхождениеКМ",Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Расхождения при поступлении (нет кода маркировки)"));

	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;
	
КонецФункции

Функция ПолучитьПриходныеОрдерыНаТоварыГдеЕстьБлокировкиПоЗаказуПоставщику(ЗаказПоставщику) Экспорт
	  		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
        |   ПриходныйОрдерНаТовары.Ссылка КАК ПриходныйОрдерНаТовары
        |ИЗ
        |   Документ.БлокировкаДвиженияТоваров КАК БлокировкаДвиженияТоваров
        |       ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
        |           ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
        |           ПО ПриходныйОрдерНаТовары.Распоряжение = ЗаказПоставщику.Ссылка
        |       ПО БлокировкаДвиженияТоваров.ДокументОснование = ПриходныйОрдерНаТовары.Ссылка
        |ГДЕ
        |   БлокировкаДвиженияТоваров.Проведен = ИСТИНА
        |   И ПриходныйОрдерНаТовары.Распоряжение = &Распоряжение";
	
	Запрос.УстановитьПараметр("Распоряжение", ЗаказПоставщику);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
    
	Возврат РезультатЗапроса;
	
КонецФункции

Функция СоздатьПриходныйОрдерНаТовары(СтруктураПараметровСоздания) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	ДокументОрдер = Документы.ПриходныйОрдерНаТовары.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(ДокументОрдер,СтруктураПараметровСоздания);
		
		Если ДокументОрдер.СкладскаяОперация <> Перечисления.СкладскиеОперации.ВозвратНепринятыхТоваров
			И ЗначениеЗаполнено(ДокументОрдер.Распоряжение) Тогда
			СкладскаяОперация = СкладыКлиентСервер.СкладскаяОперацияПриемкиПоХозяйственнойОперации(ДокументОрдер.ХозяйственнаяОперация);
			Если СкладскаяОперация = Перечисления.СкладскиеОперации.ПриемкаПоПеремещению
				Или СкладскаяОперация = Перечисления.СкладскиеОперации.ПриемкаПродукцииИзПроизводства Тогда
				ДокументОрдер.ЗаполнитьТоварыПоТоварамКПоступлению("НоменклатураКоличество", СтруктураПараметровСоздания.ДатаПоступления);
			Иначе
				ДокументОрдер.ЗаполнитьТоварыПоТоварамКПоступлению("Номенклатура", СтруктураПараметровСоздания.ДатаПоступления);
			КонецЕсли;
			
			Документы.ПриходныйОрдерНаТовары.ЗаполнитьСерииПоРаспоряжению(ДокументОрдер, Ложь);
		КонецЕсли;
		
	ДокументОрдер.Ответственный = Пользователи.ТекущийПользователь();
	ДокументОрдер.Статус        = Перечисления.СтатусыПриходныхОрдеров.Принят;

    ДокументОрдер.Записать(РежимЗаписиДокумента.Проведение);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ДокументОрдер.Ссылка; 
КонецФункции

Процедура КонтрольОстатковПоТоварамНаСкладах(Объект,Отказ) Экспорт
	
	Если Отказ тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не Константы.КонтролироватьОстаткиТоваровНаСкладах.Получить() тогда
		
		Возврат;
		
	КонецЕсли;	
	
	УстановитьПривилегированныйРежим(Истина);	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Характеристика КАК Характеристика,
	|	ЗаказКлиентаТовары.Склад КАК Склад,
	|	ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - ЗаказКлиентаТовары.Количество, 0)) КАК Количество
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Период, ) КАК ТоварыНаСкладахОстатки
	|		ПО ЗаказКлиентаТовары.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|			И ЗаказКлиентаТовары.Характеристика = ТоварыНаСкладахОстатки.Характеристика
	|			И (ВЫБОР
	|				КОГДА ЗаказКлиентаТовары.ВариантОбеспечения = ЗНАЧЕНИЕ(Перечисление.ВариантыОбеспечения.УдалитьОтгрузитьОбособленно)
	|					ТОГДА ЗаказКлиентаТовары.Ссылка.Назначение = ТоварыНаСкладахОстатки.Назначение
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ)
	|			И ЗаказКлиентаТовары.Склад = ТоварыНаСкладахОстатки.Склад
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка = &Ссылка
	|	И (ЗаказКлиентаТовары.ВариантОбеспечения = ЗНАЧЕНИЕ(Перечисление.ВариантыОбеспечения.УдалитьОтгрузитьОбособленно)
	|			ИЛИ ЗаказКлиентаТовары.ВариантОбеспечения = ЗНАЧЕНИЕ(Перечисление.ВариантыОбеспечения.Отгрузить))
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказКлиентаТовары.Номенклатура,
	|	ЗаказКлиентаТовары.Характеристика,
	|	ЗаказКлиентаТовары.Склад,
	|	ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - ЗаказКлиентаТовары.Количество, 0)) < 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура,
	|	РеализацияТоваровУслугТовары.Характеристика,
	|	РеализацияТоваровУслугТовары.Склад,
	|	РеализацияТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения,
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - РеализацияТоваровУслугТовары.Количество, 0))
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Период, ) КАК ТоварыНаСкладахОстатки
	|		ПО РеализацияТоваровУслугТовары.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|			И РеализацияТоваровУслугТовары.Характеристика = ТоварыНаСкладахОстатки.Характеристика
	|			И РеализацияТоваровУслугТовары.Назначение = ТоварыНаСкладахОстатки.Назначение
	|			И РеализацияТоваровУслугТовары.Склад = ТоварыНаСкладахОстатки.Склад
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
	|	И РеализацияТоваровУслугТовары.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке = ИСТИНА
	|	И РеализацияТоваровУслугТовары.Ссылка.Дата >= РеализацияТоваровУслугТовары.Склад.ДатаНачалаОрдернойСхемыПриОтгрузке
	|
	|СГРУППИРОВАТЬ ПО
	|	РеализацияТоваровУслугТовары.Номенклатура,
	|	РеализацияТоваровУслугТовары.Характеристика,
	|	РеализацияТоваровУслугТовары.Склад,
	|	РеализацияТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - РеализацияТоваровУслугТовары.Количество, 0)) < 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Номенклатура,
	|	ЧекККМТовары.Характеристика,
	|	ЧекККМТовары.Ссылка.Склад,
	|	ЧекККМТовары.Номенклатура.ЕдиницаИзмерения,
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - ЧекККМТовары.Количество, 0))
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Период, ) КАК ТоварыНаСкладахОстатки
	|		ПО ЧекККМТовары.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|			И ЧекККМТовары.Характеристика = ТоварыНаСкладахОстатки.Характеристика
	|			И ЧекККМТовары.Ссылка.Склад = ТоварыНаСкладахОстатки.Склад
	|ГДЕ
	|	ЧекККМТовары.Ссылка = &Ссылка
	|	И ЧекККМТовары.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке = ИСТИНА
	|	И ЧекККМТовары.Ссылка.Дата >= ЧекККМТовары.Склад.ДатаНачалаОрдернойСхемыПриОтгрузке
	|
	|СГРУППИРОВАТЬ ПО
	|	ЧекККМТовары.Номенклатура,
	|	ЧекККМТовары.Характеристика,
	|	ЧекККМТовары.Ссылка.Склад,
	|	ЧекККМТовары.Номенклатура.ЕдиницаИзмерения
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - ЧекККМТовары.Количество, 0)) < 0
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.Характеристика,
	|	ПеремещениеТоваровТовары.Ссылка.СкладОтправитель,
	|	ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения,
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - ПеремещениеТоваровТовары.Количество, 0))
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Период, ) КАК ТоварыНаСкладахОстатки
	|		ПО ПеремещениеТоваровТовары.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|			И ПеремещениеТоваровТовары.Характеристика = ТоварыНаСкладахОстатки.Характеристика
	|			И ПеремещениеТоваровТовары.Ссылка.СкладОтправитель = ТоварыНаСкладахОстатки.Склад
	|			И ПеремещениеТоваровТовары.НазначениеОтправителя = ТоварыНаСкладахОстатки.Назначение
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка = &Ссылка
	|	И ПеремещениеТоваровТовары.Ссылка.СкладОтправитель.ИспользоватьОрдернуюСхемуПриОтгрузке = ИСТИНА
	|	И ПеремещениеТоваровТовары.Ссылка.Дата >= ПеремещениеТоваровТовары.Ссылка.СкладОтправитель.ДатаНачалаОрдернойСхемыПриОтгрузке
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.Характеристика,
	|	ПеремещениеТоваровТовары.Ссылка.СкладОтправитель,
	|	ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток - ТоварыНаСкладахОстатки.КОтгрузкеОстаток - ПеремещениеТоваровТовары.Количество, 0)) < 0";
	
	Запрос.УстановитьПараметр("Период", Объект.Дата+1);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);	
		
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ТекстСообщения = "Превышен складской остаток номенклатуре " + Строка(Выборка.Номенклатура) + " (" + Строка(Выборка.Характеристика)+ ") на количество " +Строка(Выборка.Количество) + " " + Строка(Выборка.ЕдиницаИзмерения) + " на складе " + Строка(Выборка.Склад) + " на дату документа (дополнительный контроль).";
			
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, ,, Отказ);
		ТекстСообщения = НСтр("ru = 'Проведение не выполнено '");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения + Строка(Объект));
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

Функция ПоДокументуЕстьАктПоРасхождениям(ДокументОснование) Экспорт
	 		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АктОРасхожденияхПослеПеремещенияТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.АктОРасхожденияхПослеПеремещения.Товары КАК АктОРасхожденияхПослеПеремещенияТовары
		|ГДЕ
		|	АктОРасхожденияхПослеПеремещенияТовары.ДокументОснование = &ДокументОснование
		|	И АктОРасхожденияхПослеПеремещенияТовары.Ссылка.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

Процедура ЗаписьВРегистрЖурналРаботыТСД(Событие,Комментарий="",Документ=Неопределено,Сотрудник=Неопределено,ИдентификаторКлиента=Неопределено) Экспорт
	
	РегистрыСведений.ЖурналРаботыТСД.ЗаписатьСобытие(Событие,Комментарий,Документ,Сотрудник,ИдентификаторКлиента);
	
КонецПроцедуры

Функция ПолучитьИдентификаторКлиента() Экспорт
	
	 УстановитьПривилегированныйРежим(Истина);

	 СистемнаяИнформация = Новый СистемнаяИнформация;
	 
	 Возврат СистемнаяИнформация.ИдентификаторКлиента; 
	 
КонецФункции

Функция ТекущийСотрудник() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Попытка
		Возврат ?(ЗначениеЗаполнено(ПараметрыСеанса.ТекущийСотрудник), ПараметрыСеанса.ТекущийСотрудник, Справочники.Сотрудники.ПустаяСсылка());
	Исключение
		Возврат Справочники.Сотрудники.ПустаяСсылка();
	КонецПопытки;
	
КонецФункции
		  
Функция ПолучитьОстатки(Номенклатура, ХарактеристикаНоменклатуры, Склад, БезРезервов = Ложь) Экспорт

	Запрос = Новый Запрос;
	
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗапасыИПотребность.ВНаличииОстаток "+?(безрезервов,"- ЗапасыИПотребность.РезервироватьНаСкладеОстаток","")+" КАК ВНаличииОстаток
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(
		|			,
		|			Номенклатура = &Номенклатура
		|				И Характеристика = &Характеристика
		|				И Склад = &Склад и Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)) КАК ЗапасыИПотребность";  
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", ХарактеристикаНоменклатуры);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Остаток = 0;
	
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		Остаток = Выборка.ВНаличииОстаток;
	КонецЕсли;
	
	Возврат Остаток;
	
КонецФункции
