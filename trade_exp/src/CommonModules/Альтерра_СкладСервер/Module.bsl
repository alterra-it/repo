Функция ТоварПоРаспоряжениюПринят(Распоряжение) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыКПоступлениюОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлениюОстатки.Характеристика КАК Характеристика,
		|	СУММА(ТоварыКПоступлениюОстатки.КОформлениюОрдеровОстаток) КАК КоличествоУпаковок,
		|	СУММА(ТоварыКПоступлениюОстатки.ПринимаетсяОстаток) КАК ПринимаетсяОстаток
		|ИЗ
		|	РегистрНакопления.ТоварыКПоступлению.Остатки(, ) КАК ТоварыКПоступлениюОстатки
		|ГДЕ
		|	ТоварыКПоступлениюОстатки.ДокументПоступления = &ДокументПоступления
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКПоступлениюОстатки.Номенклатура,
		|	ТоварыКПоступлениюОстатки.Характеристика
		|
		|ИМЕЮЩИЕ
		|	(СУММА(ТоварыКПоступлениюОстатки.КОформлениюОрдеровОстаток) > 0
		|		ИЛИ СУММА(ТоварыКПоступлениюОстатки.ПринимаетсяОстаток) > 0)";

	Запрос.УстановитьПараметр("ДокументПоступления", Распоряжение);
								
	РезультатЗапроса = Запрос.Выполнить();

	Возврат ?(РезультатЗапроса.Пустой(),Истина,Ложь);		
