&ИзменениеИКонтроль("ЗаполнитьСуммуКомиссии")
Процедура Док_ЗаполнитьСуммуКомиссии(СтрокаДокумента, ДокументОбъект, РеквизитыДоговора) Экспорт
 						
	//++ Локализация
	Если ДокументОбъект.ОтражатьКомиссию Тогда
		
		#Вставка
		СтрокаНазначение = ДокументОбъект.НазначениеПлатежа; 
		НайденнаяСуммаКомиссии = Обработки.КлиентБанк.МожноПолучитьКомиссиюИзНазаченияПлатежа(ВРег(СтрокаНазначение));
		Если НайденнаяСуммаКомиссии > 0 Тогда
			КлиентБанкСервер.УстановитьСвойство(ДокументОбъект, "СуммаКомиссии", НайденнаяСуммаКомиссии);
		Иначе	
		#КонецВставки
		СуммаКомиссии = 0;
		// После слова "комиссия" или "сумма комиссии" или "ком." или "ком" или "к." или "удержано" и т.д. будет (с этого момента начинается вырезка текста):
		// пробел, который может отсутствовать или их несколько, 
		// затем число от 0 до 9, которое может повторяться,
		// затем один пробел и число от 0 до 9, которое может повторяться, причем пробел и числа могут повторяться несколько раз, а могут отсутствовать,
		// затем группа, которая может отсутстовать: последовательность из пробела, который может отсутствовать, слово "руб", знак".", который может отсутствовать, еще пробела, который может отсутствовать или один из  знаков "." или "," или ":" или "-" или "=", и после последовательности со словом "руб" или одного из знака есть числовые символы от 0 до 9, которых может быть несколько
		// в конце вырезаемого текста будет знак "." или "," или пробел или конец строки или "руб" или "коп", которые не брать
		ВыражениеСуммы = "(?<=комисси[яи]|[\W]ком.|[\W]ком|[\W]к.|^к.|^ком.|^ком|удержано|комисси[яи]:|удержано:|комиссия по операциям|комиссия за осущ. расч.|[\W]ком.:|^ком.:|комиссия банка|[\W]ком банка|^ком банка|[\W]комис.|^комис.)([ ]+)?([0-9]+)(([ ][0-9]+)+)?(([ ]?руб[\.]?[ ]?|[\.\,\:\-\=])([0-9]+))?(?=\.|\,|[ ]|руб|коп|$)";
				
		РезультатыПоиска = СтрНайтиВсеПоРегулярномуВыражению(НРег(ДокументОбъект.НазначениеПлатежа), ВыражениеСуммы, Истина, Истина);
				
		Для Каждого Результат Из РезультатыПоиска Цикл
			
			НайденнаяСумма = СокрЛП(Результат.Значение);
			НайденнаяСумма = СтрЗаменить(НайденнаяСумма, "руб.", ",");
			НайденнаяСумма = СтрЗаменить(НайденнаяСумма, "руб", ",");
			НайденнаяСумма = СтрЗаменить(НайденнаяСумма, " ", "");
			
			Если ПустаяСтрока(НайденнаяСумма) Тогда
				Продолжить;
			КонецЕсли;
			
			// Только целая часть
			Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(НайденнаяСумма, , Ложь) Тогда
				СуммаКомиссии = СуммаКомиссии + Число(НайденнаяСумма);
				
			// Есть дробная часть
			Иначе
				
				Для Каждого ТекущийСимвол Из СимволыВСумме() Цикл
					НайденнаяСумма = СтрЗаменить(НайденнаяСумма, ТекущийСимвол, ",");
				КонецЦикла;
				
				Если СтрНайти(НайденнаяСумма, ",") > 0 Тогда
					
					Попытка
						
						ТекущаяСумма = Число(НайденнаяСумма);
						СуммаКомиссии = СуммаКомиссии + ТекущаяСумма;
						
					Исключение
						
						ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
						ТекстОшибки = НСтр("ru = 'Некорректная вырезка суммы комиссии %1 из назначения платежа по причине:
											|%2'");
						
						Комментарий = СтрШаблон(ТекстОшибки, Результат.Значение, ОписаниеОшибки);
						Событие = НСтр("ru = 'Данные'", ОбщегоНазначения.КодОсновногоЯзыка())
							+ "." + НСтр("ru = 'Изменение'", ОбщегоНазначения.КодОсновногоЯзыка());
						ЗаписьЖурналаРегистрации(Событие, УровеньЖурналаРегистрации.Ошибка, ДокументОбъект.Метаданные(), ДокументОбъект.Ссылка, Комментарий);
						СтрокаДокумента.ОшибкиЗагрузки = ?(ПустаяСтрока(СтрокаДокумента.ОшибкиЗагрузки), "", Символы.ПС) + Комментарий;
						Продолжить;
						
					КонецПопытки;
					
				КонецЕсли;
				
			КонецЕсли;
		
		КонецЦикла;
		
		Если СуммаКомиссии = 0
			И РеквизитыДоговора.ФиксированнаяСтавкаКомиссии Тогда
			
			СуммаКомиссии = Окр(ДенежныеСредстваКлиентСервер.РассчитатьСуммуКомиссии(
				ДокументОбъект.СуммаДокумента, РеквизитыДоговора.СтавкаКомиссии, Истина), 2);
				
			Если ЕстьСуммаКомиссииВНазначении(ДокументОбъект.НазначениеПлатежа, СуммаКомиссии) Тогда
				КлиентБанкСервер.УстановитьСвойство(ДокументОбъект, "СуммаКомиссии", СуммаКомиссии);
			КонецЕсли;
			
		ИначеЕсли СуммаКомиссии <> 0 Тогда
			КлиентБанкСервер.УстановитьСвойство(ДокументОбъект, "СуммаКомиссии", СуммаКомиссии);
		КонецЕсли;
	#Вставка 
		КонецЕсли;
	#КонецВставки 	
		
	КонецЕсли;
	//-- Локализация
	
	Возврат;

КонецПроцедуры
