Процедура ЗаписатьШтрихкодыПоСекциямДокумента(Ссылка, Отказ) Экспорт
		
	Выборка = ПолучитьШтрихкодыПоСекциямДокумента(Ссылка);
	
	Если Выборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДатаФормирования = ТекущаяДата();
	РСНЗШтрихкодыПоСекциям = РегистрыСведений.ШтрихкодыПоСекциямДокумента.СоздатьНаборЗаписей();
	РСНЗШтрихкодыПоСекциям.Отбор.Документ.Установить(Ссылка);
	Пока Выборка.Следующий() Цикл
		Запись = РСНЗШтрихкодыПоСекциям.Добавить();
		
		Запись.Документ = Ссылка;
		Если Выборка.ЭтоУслуга Тогда
			Запись.Штрихкод = РСОбщийМодульВызовСервера.ПреобразоватьИзШестнадцатиричнойСистемыСчисленияВДесятичноеЧисло(СокрЛП(СтрЗаменить(Строка(Ссылка.УникальныйИдентификатор()),"-","")));
		Иначе
			Запись.Штрихкод	= РСОбщийМодульВызовСервера.ПреобразоватьИзШестнадцатиричнойСистемыСчисленияВДесятичноеЧисло(СокрЛП(СтрЗаменить(Строка(Новый УникальныйИдентификатор),"-","")));
		КонецЕсли;
		Запись.QRкод = ГенерацияШтрихкода.СформироватьQRКод(Ссылка); 
		Запись.ДатаФормирования	= ДатаФормирования;
		Запись.Проверен	= Ложь;
		Запись.Сумма = Выборка.Сумма;
		Запись.Секция = ?(ЗначениеЗаполнено(Выборка.Секция), Выборка.Секция, "");
		Запись.Назначение = Выборка.Назначение;
	КонецЦикла;
	
	Попытка
		РСНЗШтрихкодыПоСекциям.Записать(Истина);
	Исключение
		ЗаписьЖурналаРегистрации("ЗаписатьШтрихкодыПоСекциямДокумента", УровеньЖурналаРегистрации.Ошибка, , , ОписаниеОшибки());
		СообщениеОбОшибке = Новый СообщениеПользователю;
		СообщениеОбОшибке.Текст = "Ошибка формирования штрихкода по секциям документа!";
		СообщениеОбОшибке.Сообщить();
		Отказ = Истина;
	КонецПопытки;
		
КонецПроцедуры 

Функция ПолучитьШтрихкодыПоСекциямДокумента(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	|	СУММА(РеализацияТоваровУслугТовары.Сумма) КАК Сумма,
	|	ВЫБОР
