#Область СлужебныйПрограммныйИнтерфейс

&После ("ДополнитьУчетныеМеханизмыКонфигурации")
Процедура Док_ДополнитьУчетныеМеханизмыКонфигурации(МеханизмыКонфигурации) Экспорт
	МеханизмыКонфигурации.Вставить("ТоварыРасхожденияПоОбращениям", "РегистрыНакопления.ТоварыРасхожденияПоОбращениям");
	МеханизмыКонфигурации.Вставить("РасходыПоОбъектам", "РегистрыНакопления.РасходыПоОбъектам");  
	МеханизмыКонфигурации.Вставить("БлокировкаДвиженияТоваров", "РегистрыНакопления.БлокировкаДвиженияТоваров");  
	МеханизмыКонфигурации.Вставить("ОтгрузкаПоНакладным", "РегистрыНакопления.ТоварыКОтгрузкеПоНакладным");  
	МеханизмыКонфигурации.Вставить("ДвижениеМаркированногоТовара", "РегистрыНакопления.ДвижениеМаркированногоТовара");  
КонецПроцедуры

&После ("СформироватьЗаданияНаОтложенныеДвижения")
Процедура Док_СформироватьЗаданияНаОтложенныеДвижения(Документ, МенеджерВременныхТаблиц) Экспорт
	если типзнч(Документ)=тип("ДокументОбъект.ОперацияПоПлатежнойКарте") или типзнч(Документ)=тип("ДокументОбъект.ПриходныйКассовыйОрдер") тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛистСогласования.Ссылка КАК ЛистСогласования,
		|	РасшифровкаПлатежа.ОснованиеПлатежа КАК ОбъектРасчета
		|ПОМЕСТИТЬ ВР_Лист_Объект
		|ИЗ
		|	Документ."+Документ.Метаданные().Имя+".РасшифровкаПлатежа КАК РасшифровкаПлатежа
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистСогласования КАК ЛистСогласования
		|		ПО РасшифровкаПлатежа.ОснованиеПлатежа = ЛистСогласования.Основание
		|			И (НЕ ЛистСогласования.Исполнен)
		|			И (ЛистСогласования.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности))
		|ГДЕ
		|	РасшифровкаПлатежа.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЛистСогласования.Ссылка,
		|	РасшифровкаПлатежа.ОснованиеПлатежа
		|ИЗ
		|	Документ."+Документ.Метаданные().Имя+".РасшифровкаПлатежа КАК РасшифровкаПлатежа
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЛистСогласования КАК ЛистСогласования
		|		ПО РасшифровкаПлатежа.ОснованиеПлатежа = ЛистСогласования.Основание.ЗаказКлиента
		|			И (НЕ ЛистСогласования.Исполнен)
		|			И (ЛистСогласования.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности))
		|ГДЕ
		|	РасшифровкаПлатежа.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_Лист_Объект.ЛистСогласования КАК ЛистСогласования,
		|	РасчетыСКлиентамиПоСрокамОстатки.РасчетныйДокумент ЕСТЬ NULL КАК исполнять,
		|	ВР_Лист_Объект.ОбъектРасчета КАК ОбъектРасчета
		|ПОМЕСТИТЬ ВР_ЛистИсполнен
		|ИЗ
		|	ВР_Лист_Объект КАК ВР_Лист_Объект
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСКлиентамиПоСрокам.Остатки(, ) КАК РасчетыСКлиентамиПоСрокамОстатки
		|		ПО ВР_Лист_Объект.ОбъектРасчета = РасчетыСКлиентамиПоСрокамОстатки.РасчетныйДокумент
		|ГДЕ
		|РасчетыСКлиентамиПоСрокамОстатки.РасчетныйДокумент ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_ЛистИсполнен.ЛистСогласования КАК ЛистСогласования,
		|	ВР_ЛистИсполнен.исполнять КАК исполнять,
		|	РасчетыСКлиентамиПоСрокам.Долг КАК СуммаОплаты
		|ИЗ
		|	ВР_ЛистИсполнен КАК ВР_ЛистИсполнен
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РасчетыСКлиентамиПоСрокам КАК РасчетыСКлиентамиПоСрокам
		|		ПО ВР_ЛистИсполнен.ОбъектРасчета = РасчетыСКлиентамиПоСрокам.РасчетныйДокумент
		|			И (РасчетыСКлиентамиПоСрокам.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПогашениеЗадолженностиКлиента))
		|
		|СГРУППИРОВАТЬ ПО
		|	ВР_ЛистИсполнен.ЛистСогласования,
		|	ВР_ЛистИсполнен.исполнять,
		|	РасчетыСКлиентамиПоСрокам.Долг";
		Запрос.УстановитьПараметр("Ссылка", Документ.ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Пока Выборка.Следующий() Цикл                        
			попытка 
			Лист=Выборка.ЛистСогласования.ПолучитьОбъект(); 
			если Выборка.Исполнять тогда
				Лист.Исполнен=истина;
				Лист.ДатаИсполнения=ТекущаяДатаСеанса();
				Лист.ДатаРегистрацииИсполнения=ТекущаяДатаСеанса();
				Лист.Исполнитель=Пользователи.ТекущийПользователь();
			конецесли;
			Лист.СуммаОплаты=Выборка.СуммаОплаты;
			Лист.ОбменДанными.Загрузка=истина;
			Лист.Записать(); 
		исключение  
			ИнформацияОбОшибке = ИнформацияОбОшибке();
			ТекстСообщения = НСтр("ru = 'Не удалось изменить документ лист согласования по причине: %1'");
			ТекстСообщения = СтрШаблон(ТекстСообщения, КраткоеПредставлениеОшибки(ИнформацияОбОшибке));
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			конецПопытки;
		КонецЦикла;                   
		
	конецесли;	
	
КонецПроцедуры

#КонецОбласти

