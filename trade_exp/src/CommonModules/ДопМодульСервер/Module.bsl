Функция ПолучитьТипыПокупателей() Экспорт
	
	ТипыКлиентов = ПолучитьТипыКлиентов(); 
	
	ТЗ = Новый ТаблицаЗначений; 
	ТипСтрока =  Новый ОписаниеТипов("Строка",,,, Новый КвалификаторыСтроки(30));
    ТЗ.Колонки.Добавить("Тип", ТипСтрока);
    ТЗ.Колонки.Добавить("Код", ТипСтрока);   
	
	Для Каждого Элемент Из ТипыКлиентов Цикл
		Если Элемент.Значение.Компания И Элемент.Значение.ТипПокупателя <> "" Тогда
			Строка = ТЗ.Добавить();
			Строка.Тип = Элемент.Значение.ТипПокупателя;
			Строка.Код = Элемент.Значение.Код;
		КонецЕсли;
	КонецЦикла; 	

	Возврат ТЗ;
	
