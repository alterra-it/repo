#Область КСО     

#Область ЧекПпропуск

Функция ПробитьПропуск(ПараметрыАТОЛ, ДанныеПропуска) Экспорт      
	
	Попытка       
		ДанныеПропуска.Вставить("ПикселиQrКода", ПолучитьQrКод(ПараметрыАТОЛ.КаталогЛогов, ДанныеПропуска.QRКод));		
		
		ПорядковыйНомер = 1;  
		НазваниеДокумента = Строка(ДанныеПропуска.Номер) + " от " + Формат(ДанныеПропуска.Дата, "ДЛФ=ДД");
		Если ДанныеПропуска.Секции <> Неопределено Тогда 
			Для Каждого ДанныеСекции Из ДанныеПропуска.Секции Цикл        
				
				ПробитиеСекции = ПробитьСекцию(ПараметрыАТОЛ, ДанныеПропуска.УИД, ПорядковыйНомер, ДанныеСекции, ДанныеПропуска.ПикселиQrКода, НазваниеДокумента);   
				Если Не ПробитиеСекции.Результат Тогда
					Возврат ПробитиеСекции;
				КонецЕсли;
				
				ПорядковыйНомер = ПорядковыйНомер + 1; 
			
			КонецЦикла;
		Иначе  
			ПробитиеСекции = ПробитьСекцию(ПараметрыАТОЛ, ДанныеПропуска.УИД, 0, ДанныеСекции, ДанныеПропуска.ПикселиQrКода, НазваниеДокумента);   
			Если Не ПробитиеСекции.Результат Тогда
				Возврат ПробитиеСекции;
			КонецЕсли;
		КонецЕсли;
		
		Возврат ПробитиеСекции;  
		
	Исключение	         
		ОшибкаПробития = "Не пробит пропуск: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());     
		Возврат Новый Структура("Результат, Сообщение", Ложь, ОшибкаПробития);
	КонецПопытки; 	

КонецФункции       

Функция ПробитьСекцию(ПараметрыАТОЛ, УИД, ПорядковыйНомер, ДанныеСекции, ПикселиQrКода, НазваниеДокумента)   

	ДанныеЗадания = ЗаданиеНаСекции(УИД + "_" + Строка(ПорядковыйНомер), ДанныеСекции, ПикселиQrКода, НазваниеДокумента);  
	
	Отказ = Ложь; 
	ОшибкаПробития = "";
	Попытка                    
		Ответ = АТОЛСревер.ПослатьЗаданиеАТОЛ(ПараметрыАТОЛ, ДанныеЗадания); 
		
		Если Ответ.Ошибка Тогда 
			Отказ = Истина;
			ОшибкаПробития = Ответ.ТекстСообщения;
		КонецЕсли;      
		
		Возврат Новый Структура("Результат, Сообщение", Не Отказ, ОшибкаПробития);  
	Исключение
        Отказ = Истина;
		ОшибкаПробития = "Ошибка пробития пропуска: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());      
		Возврат Новый Структура("Результат, Сообщение", Ложь, ОшибкаПробития);
	КонецПопытки;  
	
КонецФункции	

Функция ЗаданиеНаСекции(УИД, ДанныеСекции, ПикселиQrКода, Документ) Экспорт    
	
	Данные = Новый Структура;
	Данные.Вставить("uuid", УИД);
	
	Задание = Новый Структура;
	Задание.Вставить("type", "nonFiscal");
	
	МассивЭлементов = Новый Массив;  
	МассивЭлементов.Добавить(Новый Структура("type, text", "text", " "));
	
	МассивЭлементов.Добавить(Новый Структура("type, text, alignment, wrap, font, doubleWidth, doubleHeight", "text", ?( ДанныеСекции <> Неопределено, "Получение на складе", "Получение в торговом зале"), "center", "words", 5, Истина, Истина));  
	МассивЭлементов.Добавить(Новый Структура("type, text", "text", " "));	
	
	Если ДанныеСекции <> Неопределено Тогда
		МассивЭлементов.Добавить(Новый Структура("type, text, alignment, wrap, font, doubleWidth, doubleHeight", "text", 
			?(ЗначениеЗаполнено(ДанныеСекции.Секция), Строка(ДанныеСекции.Секция), "Без секции"), "center", "words", 7, Истина, Истина));  
		МассивЭлементов.Добавить(Новый Структура("type, text", "text", " "));	
	КонецЕсли;

	МассивЭлементов.Добавить(Новый Структура("type, pixels, width, scale, alignment", "pixels", ПикселиQrКода, 428, 95, "center"));     
	МассивЭлементов.Добавить(Новый Структура("type, text, font, doubleHeight", "text", " ", 6, Истина));	      
	
	МассивЭлементов.Добавить(Новый Структура("type, text, alignment, wrap, font, doubleWidth, doubleHeight", "text", Документ, "center", "words", 1, Истина, Истина));	
	МассивЭлементов.Добавить(Новый Структура("type, text, font, doubleHeight", "text", " ", 6, Истина));	      
	
	Если ДанныеСекции <> Неопределено Тогда
		МассивЭлементов.Добавить(Новый Структура("type, barcode, barcodeType, scale, alignment", "barcode", ДанныеСекции.Штрихкод, "CODE128", 1, "center"));     
		МассивЭлементов.Добавить(Новый Структура("type, text, font, doubleHeight", "text", " ", 6, Истина));	      
	 	
		МассивЭлементов.Добавить(Новый Структура("type, text, alignment, font", "text", "ОТПУСТИЛ:", "left", 6));	
		МассивЭлементов.Добавить(Новый Структура("type, text", "text", " "));	    
		
		МассивЭлементов.Добавить(Новый Структура("type, text, alignment, font", "text", "ПОЛУЧИЛ:", "left", 6));	
		МассивЭлементов.Добавить(Новый Структура("type, text, alignment, font", "text", "", "center", 6));	 
	КонецЕсли;

	Задание.Вставить("items", МассивЭлементов);
	МассивЗаданий = Новый Массив;
	МассивЗаданий.Добавить(Задание);

	Данные.Вставить("request", МассивЗаданий);  
	Возврат Данные;
	
КонецФункции

Функция ПолучитьСтрокуQrКода(QrКод)  
	
	Попытка
		ДвоичныеДанные = ГенерацияШтрихкода.ДанныеQRКода(QRКод, 1, 420);                
		
	  	Картинка = Новый Картинка(ДвоичныеДанные);
	    Картинка = Картинка.Преобразовать(ФорматКартинки.PNG);
	    КартинкаБМП = Картинка.Преобразовать(ФорматКартинки.BMP);
	    ДанныеКартинки = КартинкаБМП.ПолучитьДвоичныеДанные(); 
		
		Поток = ДанныеКартинки.ОткрытьПотокДляЧтения();
		Чтение = Новый ЧтениеДанных(ДанныеКартинки);
		bfType = Чтение.ПрочитатьЦелое16(); 		//ПорядокБайтов.BigEndian
		bfSize = Чтение.ПрочитатьЦелое32();
		bfReserved1 = Чтение.ПрочитатьЦелое16();
		bfReserved2 = Чтение.ПрочитатьЦелое16();
		bfOffBits = Чтение.ПрочитатьЦелое32();
		// BITMAPINFOHEADER версия 3
		biSize = Чтение.ПрочитатьЦелое32();
		biWidth = Чтение.ПрочитатьЦелое32(); 		// Ширина изображения в пикселах
		biHeight = Чтение.ПрочитатьЦелое32(); 		// Высота изображения в пикселах
		biPlanes = Чтение.ПрочитатьЦелое16(); 		// Содержит единицу
		biBitCount = Чтение.ПрочитатьЦелое16();		// Количество бит на пиксел
		biCompression = Чтение.ПрочитатьЦелое32();	// Тип сжатия
		biSizeImage = Чтение.ПрочитатьЦелое32(); 	// Размер изображения в байтах
		biXPelsPerMeter = Чтение.ПрочитатьЦелое32();// Горизонтальное разрешение в пикселах на метр
		biYPelsPerMeter = Чтение.ПрочитатьЦелое32();// Вертикальное разрешение в пикселах на метр
		biClrUsed = Чтение.ПрочитатьЦелое32(); 		// Количество используемых цветовых индексов в палитре
		biClrImportant = Чтение.ПрочитатьЦелое32(); // Количество индексов
		
		Строка3Байта = "";
		СтрокаBase64 = "";
	
		Для а1 = 0 По biHeight-1 Цикл
			Если а1 = 9999 Тогда 
				Прервать; 
			КонецЕсли; 
			
		    Для а2 = 0 По biWidth - 1 Цикл
				Если а2 = 9999 Тогда 
					Прервать; 
				КонецЕсли;    
				
		        Блю = Чтение.ПрочитатьБайт();
		        Грин = Чтение.ПрочитатьБайт();
		        Ред = Чтение.ПрочитатьБайт();
		   
				Строка3Байта = Строка3Байта + ?(Блю = 0 И Грин = 0 И Ред = 0, "1", "0");
				
				Если СтрДлина(Строка3Байта) = 3 Тогда
					
					Если Строка3Байта = "000" Тогда
						СтрокаBase64 = СтрокаBase64 + "AAAA";   
						
					ИначеЕсли Строка3Байта = "001" Тогда
						СтрокаBase64 = СтрокаBase64 + "AAAB";
						
					ИначеЕсли Строка3Байта = "010" Тогда 
						СтрокаBase64 = СтрокаBase64 + "AAEA";
						
					ИначеЕсли Строка3Байта = "011" Тогда
						СтрокаBase64 = СтрокаBase64 + "AAEB";

					ИначеЕсли Строка3Байта = "100" Тогда 
						СтрокаBase64 = СтрокаBase64 + "AQAA";

					ИначеЕсли Строка3Байта = "101" Тогда 
						СтрокаBase64 = СтрокаBase64 + "AQAB";

					ИначеЕсли Строка3Байта = "110" Тогда 
						СтрокаBase64 = СтрокаBase64 + "AQEA";

					Иначе /// "111"
						СтрокаBase64 = СтрокаBase64 + "AQEB";
					КонецЕсли;
					
					Строка3Байта = "";
				КонецЕсли;
		   		
		    КонецЦикла;
		КонецЦикла;  
	
		Если СтрДлина(Строка3Байта) <> 3 Тогда   
			
			Если Строка3Байта = "0" Тогда
				СтрокаBase64 = СтрокаBase64 + "AA==";  

			ИначеЕсли Строка3Байта = "1" Тогда
				СтрокаBase64 = СтрокаBase64 + "AQ==";  
				
			ИначеЕсли Строка3Байта = "00" Тогда
				СтрокаBase64 = СтрокаBase64 + "AAA=";  
				
			ИначеЕсли Строка3Байта = "01" Тогда  
				СтрокаBase64 = СтрокаBase64 + "AAE=";  
				
			ИначеЕсли Строка3Байта = "10" Тогда  
				СтрокаBase64 = СтрокаBase64 + "AQA=";  

			Иначе // "11"
				СтрокаBase64 = СтрокаBase64 + "AQE=";  
			КонецЕсли;
			
		КонецЕсли;

		Поток.Закрыть();	
	
	Исключение   
		Попытка
			Поток.Закрыть();	
		Исключение
		КонецПопытки;
	КонецПопытки;  

	Возврат СтрокаBase64;    

КонецФункции

Процедура ЗаписатьQrКод(КаталогЛогов, ИДУстройства, ДокументСсылка, QRКод) Экспорт
	
	Попытка 
	
		ИмяКаталога = КаталогЛогов + "selfService\QRcodes";  

		МассивНайденныхФайлов = НайтиФайлы(
		    ИмяКаталога + "\",
		    "*" + QRКод + "*.txt", 
		    Ложь);   
			
		// Если QR код уже сформирован, то ничего не делать		
		Если МассивНайденныхФайлов.Количество() = 0 Тогда
		
			КаталогЛогов = Новый Файл(ИмяКаталога);
			Если Не КаталогЛогов.Существует() Тогда
				СоздатьКаталог(ИмяКаталога);
			КонецЕсли; 
			
			ДатаДокумента = ТекущаяДата();
			ИмяДокумента= ?(ТипЗнч(ДокументСсылка) = Тип("ДокументСсылка.ЧекККМ"), "ЧекККМ", "Реализация") + "_"  + ДокументСсылка.Номер;
			ИмяФайла = "QR" + "_" + Формат(ДатаДокумента, "ДФ=ггггММдд") + "_" + Формат(ДатаДокумента, "ДФ=ЧЧммсс") + "_" + ИДУстройства +  "_" + QRКод + "_" + ИмяДокумента + ".txt";
			
			QRПикселиКартинки = ПолучитьСтрокуQrКода(QRКод);
			
			QRФайл = Новый ЗаписьТекста(ИмяКаталога + "\" + ИмяФайла, КодировкаТекста.UTF8, , Истина);
			QRФайл.ЗаписатьСтроку(QRПикселиКартинки);
			QRФайл.Закрыть();
			
		КонецЕсли;

	Исключение
	КонецПопытки;	
	
КонецПроцедуры	

Функция ПолучитьQrКод(КаталогЛогов, QRКод)    

	Попытка
	
		ИмяКаталога = КаталогЛогов + "selfService\QRcodes";  
		
		МассивНайденныхФайлов = НайтиФайлы(
		    ИмяКаталога + "\",
		    "*" + QRКод + "*.txt", 
		    Ложь); 	 
			
		Если МассивНайденныхФайлов.Количество() > 0 Тогда	
				
			ИмяФайла = МассивНайденныхФайлов[0].Имя;	
			
			Текст = Новый ЧтениеТекста(ИмяКаталога + "\" + ИмяФайла, КодировкаТекста.ANSI);
			QRПикселиКартинки = Текст.ПрочитатьСтроку();     
			Текст.Закрыть();		
			
		Иначе
			QRПикселиКартинки = ПолучитьСтрокуQrКода(QRКод);
		КонецЕсли;	
		
		Возврат QRПикселиКартинки;
		
	Исключение 
		Возврат "";
	КонецПопытки;
	
КонецФункции	

#КонецОбласти      

#Область АТОЛ

Функция ПробитьЧек(ПараметрыАТОЛ, УИД) Экспорт 
	
	РезультатВыполнения = Новый Структура("Результат, Сообщение, JSONПробитие", Ложь, "", "");    
	
	Попытка
		Попытка
			РезультатВыполнения.JSONПробитие = АТОЛСревер.ПробитьЧек(ПараметрыАТОЛ, УИД, , Истина);  
			
			Если РезультатВыполнения.JSONПробитие.Ошибка Или Не РезультатВыполнения.JSONПробитие.Данные.Свойство("uuid") Тогда
				РезультатВыполнения.Сообщение = РезультатВыполнения.JSONПробитие.ТекстСообщения;
			Иначе
				РезультатВыполнения.Результат = Истина;
			КонецЕсли;   
			
		Исключение
			РезультатВыполнения.Сообщение = "Ошибка пробития чека. " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки;  
		
	Исключение	         
		РезультатВыполнения.Сообщение = "Не пробит чек текущей покупки: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки; 	
	
	Возврат РезультатВыполнения;
	
КонецФункции  

Функция ПолучитьРезультатПробития(ПараметрыАТОЛ, УИД)    
	
	РезультатПробития = ПараметрыРезультатПробития();
	
	Попытка
		Ответ = АТОЛСревер.РезультатПробитияЧека(ПараметрыАТОЛ, УИД); 	   
	
		Если Не Ответ.Ошибка Тогда   

			РезультатПробития.Результат = Истина;
			РезультатПробития.ДанныеФН = ?(ТипЗнч(Ответ) = Тип("Структура") И Ответ.Свойство("Данные"), Ответ.Данные, Неопределено); 
			РезультатПробития.ОтветТело = ?(ТипЗнч(Ответ) = Тип("Структура") И Ответ.Свойство("ОтветТело"), Ответ.ОтветТело, "");
			Возврат РезультатПробития;	 
			
		Иначе  
			// Определение статуса задания, если он есть в ответе
			Если Ответ.Свойство("Данные") И ТипЗнч(Ответ.Данные) = Тип("Структура") 
				И Ответ.Данные.Свойство("results") И ТипЗнч(Ответ.Данные.results) = Тип("Массив") И Ответ.Данные.results.Количество() > 0   
				И  ТипЗнч(Ответ.Данные.results[0]) = Тип("Структура") И Ответ.Данные.results[0].Свойство("status") Тогда
			
				Статус = Ответ.Данные.results[0].status;     
				
				ОшибкаМаркировки = Ответ.Данные.results[0].Свойство("result") 
					И ТипЗнч(Ответ.Данные.results[0].result) = Тип("Структура") 
					И Ответ.Данные.results[0].result.Свойство("validateMarks");  
				
				// Задание не выполнится, нужно новое с новым УИД
				Если Статус = "error" Или Статус = "canceled" Или Статус = "interrupted" 
					Или Статус = "ready" И ОшибкаМаркировки Тогда
					
					РезультатПробития.ОтправитьЗадание = Истина;
					РезультатПробития.НовыйУИДЗадания = Истина;
					РезультатПробития.Сообщение = Ответ.ТекстСообщения;
					Возврат РезультатПробития;	
					
				Иначе // Для статусов  wait, inProgress, blocked подождать выполнения следующего регламентного задания   
					РезультатПробития.Сообщение = Ответ.ТекстСообщения;
					Возврат РезультатПробития;	 
				КонецЕсли;
				
			// Нет информации по заданию, отправить задание с таким же УИД
			Иначе
				РезультатПробития.ОтправитьЗадание = Истина;
				РезультатПробития.Сообщение = Ответ.ТекстСообщения;
				Возврат РезультатПробития;	 	
			КонецЕсли;
				
		КонецЕсли;
		
	Исключение   
		РезультатПробития.Сообщение = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат РезультатПробития;	
	КонецПопытки		
	
КонецФункции 

Функция ПроверитьАктуальностьСменыАТОЛ(КассаОрганизации) Экспорт
	
	ДействияСКассовойСменой = Новый Структура("Результат, СменаУжеОткрыта, ДатаЗакрытияСмены, Сообщение", Ложь, Ложь, Дата(1, 1, 1), "");	 
	НеобходимоЗакрытьСмену = Ложь;
	НеобходимоОткрытьСмену = Ложь;

	ПараметрыАТОЛ = Неопределено;
	Попытка
		// Получение кассовой смены АТОЛ
		ПараметрыАТОЛ = ПолучитьСменуАТОЛ(КассаОрганизации);
		Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("Ошибка") И ПараметрыАТОЛ.Ошибка Тогда

			ТекстСообщения = "Невозможно получить информацию по кассовой смене. Проверьте работу кассы. ";
			Если ПараметрыАТОЛ.Свойство("ИнформацияОКассовойСмене")    
				И ТипЗнч(ПараметрыАТОЛ.ИнформацияОКассовойСмене) = Тип("Структура") 
				И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("ТекстСообщения") Тогда
					ТекстСообщения = ТекстСообщения + ПараметрыАТОЛ.ИнформацияОКассовойСмене.ТекстСообщения;
			КонецЕсли;
			
			ДействияСКассовойСменой.Сообщение = ТекстСообщения;    
			Возврат ДействияСКассовойСменой;
		КонецЕсли;  
		
		Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") И ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене 
		И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") Тогда   
			Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.state = "expired" Тогда // Смена истекла
				НеобходимоЗакрытьСмену = Истина;
				НеобходимоОткрытьСмену = Истина;    
				
			ИначеЕсли ПараметрыАТОЛ.ИнформацияОКассовойСмене.state = "closed" Тогда // Смена закрыта                                                       
				НеобходимоОткрытьСмену = Истина;
				
			Иначе	// Смена открыта
				Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("expiredAt") Тогда // Дата окончания смены
					ДатаЗакрытияСмены = Дата(1, 1, 1);
					Попытка
						ДатаЗакрытияСмены = ПрочитатьДатуJSON(ПараметрыАТОЛ.ИнформацияОКассовойСмене.expiredAt, ФорматДатыJSON.ISO);
					Исключение
					КонецПопытки;
					
					// Если смена закрывается уже сегодняшним днем, то переоткрыть
					Если Не ЗначениеЗаполнено(ДатаЗакрытияСмены) Или ДатаЗакрытияСмены <= КонецДня(ТекущаяДата()) Тогда 
						НеобходимоЗакрытьСмену = Истина;
						НеобходимоОткрытьСмену = Истина;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;  
		Иначе	               
			ДействияСКассовойСменой.Сообщение = "Не получено состояние смены АТОЛ."; 
			Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("ИнформацияОКассовойСмене")    
				И ТипЗнч(ПараметрыАТОЛ.ИнформацияОКассовойСмене) = Тип("Структура") И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("ТекстСообщения") Тогда
					ДействияСКассовойСменой.Сообщение = ДействияСКассовойСменой.Сообщение + " " + ПараметрыАТОЛ.ИнформацияОКассовойСмене.ТекстСообщения;   
				Возврат ДействияСКассовойСменой;
			КонецЕсли;
		КонецЕсли;  
		
		// Ничего делать не надо - смена уже открыта сегодняшним днем
		Если Не НеобходимоОткрытьСмену Тогда
			ДействияСКассовойСменой.Результат = Истина; 
			ДействияСКассовойСменой.СменаУжеОткрыта = Истина; 
			Попытка
				ДействияСКассовойСменой.ДатаЗакрытияСмены = ПрочитатьДатуJSON(ПараметрыАТОЛ.ИнформацияОКассовойСмене.expiredAt, ФорматДатыJSON.ISO);
			Исключение
			КонецПопытки;
			Возврат ДействияСКассовойСменой;
		КонецЕсли;
		
		Таймаут = 2;        
		Если НеобходимоЗакрытьСмену Тогда
			Ответ = АТОЛСревер.ЗакрытьСмену(ПараметрыАТОЛ);
			Б_ОбменССайтомСервер.Таймаут(Таймаут);
		КонецЕсли;    
		
		Если НеобходимоОткрытьСмену Тогда
			Ответ = АТОЛСревер.ОткрытьСмену(ПараметрыАТОЛ); 
			Б_ОбменССайтомСервер.Таймаут(Таймаут);
		КонецЕсли;  
		
		// Получение состояния смены (требует времени)
		КоличествоПопыток = 3;
		ТекущаяПопытка = 1;
		Пока ТекущаяПопытка <= КоличествоПопыток Цикл   
			ПараметрыАТОЛ = ПолучитьСменуАТОЛ(КассаОрганизации);
			Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") И ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене
				И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") И ПараметрыАТОЛ.ИнформацияОКассовойСмене.state = "opened" Тогда 
				Прервать;
			Иначе
				Если ТекущаяПопытка <= КоличествоПопыток Тогда
					ТекущаяПопытка = ТекущаяПопытка + 1;
					Б_ОбменССайтомСервер.Таймаут(Таймаут);       
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;
		
		Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") И ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене
			И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") Тогда  
		
		        // Смена не открылась
				Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.state <> "opened" Тогда 
					ДействияСКассовойСменой.Сообщение = "Смена АТОЛ не открыта";		 
					Возврат ДействияСКассовойСменой;
					
				// Смена открылась					
				Иначе
					Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("expiredAt") Тогда // Дата окончания смены
						Попытка
							ДействияСКассовойСменой.ДатаЗакрытияСмены = ПрочитатьДатуJSON(ПараметрыАТОЛ.ИнформацияОКассовойСмене.expiredAt, ФорматДатыJSON.ISO);
						Исключение
						КонецПопытки; 
						ДействияСКассовойСменой.Результат = Истина;
						Возврат ДействияСКассовойСменой;
					КонецЕсли;    
				КонецЕсли;
		Иначе
			ДействияСКассовойСменой.Сообщение = "Не получено состояние смены АТОЛ";     
			Возврат ДействияСКассовойСменой;
		КонецЕсли; 

	Исключение  
		ДействияСКассовойСменой.Сообщение = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
        Возврат ДействияСКассовойСменой;
	КонецПопытки;
	
	Возврат ДействияСКассовойСменой;
КонецФункции      

Функция ЗакрытьСменуАТОЛ(КассаОрганизации) Экспорт
	Попытка
		// Получение кассовой смены АТОЛ
		ПараметрыАТОЛ = ПолучитьСменуАТОЛ(КассаОрганизации);
		Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("Ошибка") И ПараметрыАТОЛ.Ошибка Тогда   
			
			ТекстСообщения = "Невозможно получить информацию по кассовой смене. Проверьте работу кассы. ";
			Если ПараметрыАТОЛ.Свойство("ИнформацияОКассовойСмене") 
				И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("ТекстСообщения") Тогда
					ТекстСообщения = ТекстСообщения + ПараметрыАТОЛ.ИнформацияОКассовойСмене.ТекстСообщения;
			КонецЕсли;
			
			Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Ложь, Ложь, ТекстСообщения);
		КонецЕсли;  
		
		// Получение текущей смены
		Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") И ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене 
			И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") Тогда       
			
				// Текущая смена не закрыта
				Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.state <> "closed" Тогда 
				
					Ответ = АТОЛСревер.ЗакрытьСмену(ПараметрыАТОЛ);   
					Таймаут = 2;
					Б_ОбменССайтомСервер.Таймаут(Таймаут);
					
					// Получение нового состояния смены (требует времени)
					КоличествоПопыток = 3;
					ТекущаяПопытка = 1;
					Пока ТекущаяПопытка <= КоличествоПопыток Цикл   
						
						ПараметрыАТОЛ = ПолучитьСменуАТОЛ(КассаОрганизации);
						Если ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") И ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене 
							И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") И ПараметрыАТОЛ.ИнформацияОКассовойСмене.state = "closed" Тогда 
							Прервать;
						Иначе           
							Если ТекущаяПопытка <= КоличествоПопыток Тогда
								ТекущаяПопытка = ТекущаяПопытка + 1;
								Б_ОбменССайтомСервер.Таймаут(Таймаут);       
							КонецЕсли;
						КонецЕсли;	
					КонецЦикла; 
					
					// После попытки закрытия смены - получение текущей смены
					Если ПараметрыАТОЛ.Свойство("ПолучениеИнформацииОКассовойСмене") И ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене
						И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") Тогда
						
						// По итогам попыток закрытия смена не закрыта
						Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.state <> "closed" Тогда  
							Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Ложь, Ложь, "Смена АТОЛ не закрыта")
						
						Иначе // По итогам попыток закрытия смена закрыта	
							Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Истина, Ложь, "")	
						КонецЕсли
						
					Иначе // Текущая смена не получена
						Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Ложь, Ложь, "Не получено состояние смены АТОЛ. Количество попыток: " + Строка(ТекущаяПопытка));
					КонецЕсли  
					
				// Смена уже закрыта, не надо ничего делать
				Иначе
					Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Истина, Истина, "")	
				КонецЕсли;
				
		// Текущая смена не получена
		Иначе   
			ТекстОшибки = "Не получено состояние смены АТОЛ";
			Если ТипЗнч(ПараметрыАТОЛ) = Тип("Структура") И ПараметрыАТОЛ.Свойство("ИнформацияОКассовойСмене")    
				И ТипЗнч(ПараметрыАТОЛ.ИнформацияОКассовойСмене) = Тип("Структура") И ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("ТекстСообщения") Тогда
					ТекстОшибки = ТекстОшибки + " " + ПараметрыАТОЛ.ИнформацияОКассовойСмене.ТекстСообщения;
			КонецЕсли;   
				
			Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Ложь, Ложь, ТекстОшибки);
		КонецЕсли; 		
		
	Исключение         
		Возврат Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Ложь, Ложь, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;         
	
КонецФункции

Функция ПолучитьСтатусККТ(ПараметрыВходногоЗапроса) Экспорт      
	
	Попытка
		ПараметрыАТОЛ = ЗаполнитьПараметрыАТОЛОсновные(ПараметрыВходногоЗапроса.КассаСамообслуживания);  
		
		Отказ = Ложь; 
		ОшибкаПробития = "";
		Попытка
			Ответ = АТОЛСревер.СтатусККТ(ПараметрыАТОЛ);
			
			Если Ответ.Ошибка Тогда
				Отказ = Истина;
				ОшибкаПробития = Ответ.ТекстСообщения;
			КонецЕсли;   
			
		Исключение
            Отказ = Истина;
			ОшибкаПробития = "Ошибка получения статуса ККТ. " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		КонецПопытки; 
		
		Статус = ?(Ответ.Свойство("Данные") И Ответ.Данные.Свойство("deviceStatus"), Ответ.Данные.deviceStatus, Неопределено);	
		
		Возврат Новый Структура("Результат, СтатусККТ, Сообщение", Не Отказ, Статус, ОшибкаПробития);
	Исключение	         
		ОшибкаПробития = "Не получен статус ККТ: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());     
		Возврат Новый Структура("Результат, Сообщение", Ложь,  ОшибкаПробития) ;
	КонецПопытки; 	
	
КонецФункции

Функция ЗаполнитьПараметрыАТОЛ(Чек) Экспорт 
	
	ПараметрыАТОЛ = АТОЛСревер.ШаблонПараметровАТОЛ();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	IP,
		|	Порт,
		|	ИДУстройства,
		|	ПользовательУстройства,
		|	ПарольУстройства,
		|	Кассир,
		|	НеПечататьЧек,
		|	АдресХраненияЛогов,
		|	Наименование ПОДОБНО &КСО КАК ЭтоКСО
		|ИЗ 
		|	Справочник.Кассы
		|ГДЕ 
		|	Ссылка = &Касса";    
	
	Запрос.УстановитьПараметр("Касса", Чек.Касса);
	Запрос.УстановитьПараметр("КСО", "%КСО%");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ПараметрыАТОЛ;
	КонецЕсли;
	
	ВыборкаКасса = РезультатЗапроса.Выбрать();
	ВыборкаКасса.Следующий();
	
	Адрес 			= ВыборкаКасса.IP;
	Порт 			= ВыборкаКасса.Порт;
	ИДУстройства	= ВыборкаКасса.ИДУстройства; 
	Логин = 		?(ЗначениеЗаполнено(ВыборкаКасса.ПользовательУстройства), ВыборкаКасса.ПользовательУстройства, Неопределено);
	Пароль = 		?(ЗначениеЗаполнено(ВыборкаКасса.ПарольУстройства), ВыборкаКасса.ПарольУстройства, Неопределено);      
	
	ПараметрыПодключения = АТОЛСревер.ПолучитьПараметрыСоединения(Адрес, Порт, Логин, Пароль, Ложь, ИДУстройства);
	ПараметрыПодключения.Таймаут = 10;
	
	ПараметрыАТОЛ.ПараметрыПодключения 	= ПараметрыПодключения;
	ПараметрыАТОЛ.ИДУстройства 			= ПараметрыПодключения.ИДУстройства;
	ПараметрыАТОЛ.Кассир 				= ВыборкаКасса.Кассир;
	ПараметрыАТОЛ.НеПечататьЧек 		= ВыборкаКасса.НеПечататьЧек;
	ПараметрыАТОЛ.СуммаОплаты 			= Чек.СуммаОплаты; 
	ПараметрыАТОЛ.ДокументПродажи 		= Чек.Ссылка;
	ПараметрыАТОЛ.ДокументОплаты 		= Чек.Ссылка; 
	
	ПараметрыАТОЛ.EmailИлиТелефон = ?(Чек.АдресЭП <> "" И Лев(Чек.АдресЭП, 5) <> "buyer", Чек.АдресЭП, 
		?(Чек.НомерТелефона <> "", "+7" + Чек.НомерТелефона, ""));     
		
	ПараметрыАТОЛ.Вставить("КассирВЧеке", 			?(ВыборкаКасса.ЭтоКСО, "Самообслуживание", Чек.КассирВЧеке));
	ПараметрыАТОЛ.Вставить("ПечататьБумажныйЧек", 	Чек.ПечататьБумажныйЧек);	
	ПараметрыАТОЛ.Вставить("МестоРасчетов", 		Чек.МестоРасчетов);     
	ПараметрыАТОЛ.Вставить("АдресРасчетов", 		Чек.АдресРасчетов);    
	ПараметрыАТОЛ.Вставить("ОтправлятьЧекИзОФД", 	Истина);    
	
	ПараметрыАТОЛ.Вставить("КаталогЛогов", Лев(Чек.Касса.АдресХраненияЛогов, 
		СтрНайти(Чек.Касса.АдресХраненияЛогов, "\", НаправлениеПоиска.СКонца)));
	
	//Информация О ККТ
	ИнформацияККТ = АТОЛСревер.ИнформацияОККТ(ПараметрыАТОЛ);
	ПараметрыАТОЛ.Вставить("ИнформацияККТ", ИнформацияККТ);       
	
	Возврат ПараметрыАТОЛ;
	
КонецФункции  

Функция ЗаполнитьПараметрыАТОЛОсновные(Касса) Экспорт 
	
	Адрес = Касса.IP;
	Порт = Касса.Порт;
	ИДУстройства = Касса.ИДУстройства; 
	Логин = ?(ЗначениеЗаполнено(Касса.ПользовательУстройства), Касса.ПользовательУстройства, Неопределено);
	Пароль = ?(ЗначениеЗаполнено(Касса.ПарольУстройства), Касса.ПарольУстройства, Неопределено);
	
	ПараметрыПодключения = АТОЛСревер.ПолучитьПараметрыСоединения(Адрес, Порт, Логин, Пароль, Ложь, ИДУстройства);
	ПараметрыПодключения.Таймаут = 10;
	
	ПараметрыАТОЛ = АТОЛСревер.ШаблонПараметровАТОЛ();
	ПараметрыАТОЛ.ПараметрыПодключения = ПараметрыПодключения;
	ПараметрыАТОЛ.ИДУстройства = ПараметрыПодключения.ИДУстройства;
	
	ПараметрыАТОЛ.Вставить("КаталогЛогов", Лев(Касса.АдресХраненияЛогов, СтрНайти(Касса.АдресХраненияЛогов, "\",  НаправлениеПоиска.СКонца)));
	
	Возврат ПараметрыАТОЛ;
	
КонецФункции

Функция ПолучитьСменуАТОЛ(Касса) 
	Адрес = Касса.IP;
	Порт = Касса.Порт;
	ИДУстройства = Касса.ИДУстройства;    
	Логин = ?(ЗначениеЗаполнено(Касса.ПользовательУстройства), Касса.ПользовательУстройства, Неопределено);
	Пароль = ?(ЗначениеЗаполнено(Касса.ПарольУстройства), Касса.ПарольУстройства, Неопределено);
	
	ПараметрыАТОЛ = АТОЛСревер.ШаблонПараметровАТОЛ();  
	ПараметрыАТОЛ.Кассир = Касса.Кассир;
	ПараметрыАТОЛ.НеПечататьЧек = Касса.НеПечататьЧек;  
	ПараметрыАТОЛ.Вставить("ИнформацияОКассовойСмене");
	ПараметрыАТОЛ.Вставить("ПолучениеИнформацииОКассовойСмене", Ложь);
	ПараметрыАТОЛ.Вставить("Ошибка", Ложь);   
	ПараметрыАТОЛ.Вставить("ИнформацияККТ");
	
	ПараметрыПодключения = АТОЛСревер.ПолучитьПараметрыСоединения(Адрес, Порт, Логин, Пароль, Ложь, ИДУстройства);
	ПараметрыПодключения.Таймаут = 10; //5
	ПараметрыАТОЛ.ПараметрыПодключения = ПараметрыПодключения;   
	ПараметрыАТОЛ.ИДУстройства = ПараметрыПодключения.ИДУстройства;
	
	// Проверка связи
	Попытка
		Ответ = АТОЛСревер.ПроверитьСвязь(ПараметрыАТОЛ);
		Если Ответ.Свойство("Ошибка") И Ответ.Ошибка Тогда                                    
			ПараметрыАТОЛ.Ошибка = Истина;
		КонецЕсли; 
	Исключение 
		ПараметрыАТОЛ.Ошибка = Истина;
	КонецПопытки;
		
	//Информация о кассовой смене   
	Попытка
		ИнформацияОКассовойСмене = АТОЛСревер.ИнформацияОКассовойСмене(ПараметрыАТОЛ);  
		ПараметрыАТОЛ.ИнформацияОКассовойСмене = ИнформацияОКассовойСмене; 
		Если ПараметрыАТОЛ.ИнформацияОКассовойСмене.Свойство("state") Тогда
			ПараметрыАТОЛ.ПолучениеИнформацииОКассовойСмене = Истина;
		КонецЕсли;
	Исключение
		ПараметрыАТОЛ.Ошибка = Истина;
	КонецПопытки; 
	
	//Информация О ККТ
	Попытка
		ИнформацияККТ = АТОЛСревер.ИнформацияОККТ(ПараметрыАТОЛ);
		ПараметрыАТОЛ.ИнформацияККТ = ИнформацияККТ;
	Исключение
		ПараметрыАТОЛ.Ошибка = Истина;
	КонецПопытки; 
	
	Возврат ПараметрыАТОЛ; 
КонецФункции   

#КонецОбласти     

#Область КассаККМ    

Функция ПроверитьАктуальностьСменыККМ(РабочееМесто, КассаККМ, СменаУжеОткрыта, ДатаЗакрытияСмены) Экспорт
	
	РезультатВыполнения = Новый Структура("Результат, СменаУжеОткрыта, Сообщение", Истина, Истина, "");    
	
	ОшибкаПриСнятииZОтчета = Ложь;       
	ОписаниеОшибки = "";        
	ОписаниеОшибкиZОтчета = "";
		
	СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто); 
	ДатаОткрытияСменыАТОЛ = ДатаЗакрытияСмены - 24 * 60 * 60; 
	
	Если Не СменаУжеОткрыта                              
		Или СтруктураСостояниеКассовойСмены.ДатаИзмененияСтатуса = Неопределено       
		// Смена ККМ закрыта
		Или (ЗначениеЗаполнено(СтруктураСостояниеКассовойСмены.КассоваяСмена) И  СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта) 
		// Смена ККМ открыта, но дата начала смены меньше начала смены АТОЛ
		Или (ЗначениеЗаполнено(СтруктураСостояниеКассовойСмены.КассоваяСмена) И  СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта
			И (СтруктураСостояниеКассовойСмены.КассоваяСмена.НачалоКассовойСмены < ДатаОткрытияСменыАТОЛ)) Тогда
		
		// Закрыть кассовую смену, если она открыта
		Если СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта
			Или (СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта
		  		И  СтруктураСостояниеКассовойСмены.СтатусРегламентныхОпераций = Перечисления.СтатусыРегламентныхОперацийКассовойСмены.ПустаяСсылка()) Тогда
		
			ВыполнитьОперациюЗакрытияКассовойСмены(КассаККМ, РабочееМесто, СтруктураСостояниеКассовойСмены, ДатаОткрытияСменыАТОЛ - 1, Ложь, ОшибкаПриСнятииZОтчета, ОписаниеОшибки, ОписаниеОшибкиZОтчета);
			СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто);	
		КонецЕсли; 
		
		// Открыть кассовую смену, если она закрыта или не существует
		Если СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Неопределено
			Или СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта Тогда
				ОткрытьКассовуюСмену(КассаККМ, РабочееМесто, ДатаОткрытияСменыАТОЛ, ОписаниеОшибки);	
				СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто);	
			КонецЕсли;       
			
			РезультатВыполнения.СменаУжеОткрыта = Ложь;
	КонецЕсли;
	
	Если СтруктураСостояниеКассовойСмены.СтатусКассовойСмены <> Перечисления.СтатусыКассовойСмены.Открыта Тогда
		РезультатВыполнения.Результат = Ложь;
		РезультатВыполнения.Сообщение = "Кассовая смена ККМ не открыта. " + ОписаниеОшибки;
	КонецЕсли;
		
	Возврат РезультатВыполнения;
КонецФункции  

Функция ЗакрытьСменуККМ(РабочееМесто, КассаККМ) Экспорт
	
	РезультатВыполнения = Новый Структура("Результат, СменаУжеЗакрыта, Сообщение", Истина, Истина, "");    
			
	СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто); 
	ОшибкаПриСнятииZОтчета = Ложь;       
	ОписаниеОшибки = "";             
	ОписаниеОшибкиZОтчета = "";
	
	// Закрыть кассовую смену, если она открыта
	Если СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта
		Или (СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта
	  		И  СтруктураСостояниеКассовойСмены.СтатусРегламентныхОпераций = Перечисления.СтатусыРегламентныхОперацийКассовойСмены.ПустаяСсылка()) Тогда

		ВыполнитьОперациюЗакрытияКассовойСмены(КассаККМ, РабочееМесто, СтруктураСостояниеКассовойСмены, ТекущаяДата(), Истина, ОшибкаПриСнятииZОтчета, ОписаниеОшибки, ОписаниеОшибкиZОтчета);
		СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто);
		
		РезультатВыполнения.СменаУжеЗакрыта = Ложь;
	КонецЕсли;  
		
	Если Не (СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Неопределено // Для новых касс без смен
		Или СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта) Тогда 
		
		РезультатВыполнения.Результат = Ложь;
		РезультатВыполнения.Сообщение = "Кассовая смена ККМ не закрыта. " + ОписаниеОшибки; 
	КонецЕсли;
	
	Возврат РезультатВыполнения;
КонецФункции

Функция ПолучитьСостояниеКассовойСмены(Объект, РабочееМесто) 
	
	УстановитьПривилегированныйРежим(Истина);
	
	КассаККМФискальноеУстройство = КассаККМФискальноеУстройство(Объект, РабочееМесто);
	ФискальноеУстройство = КассаККМФискальноеУстройство.ФискальноеУстройство;
	КассаККМ             = КассаККМФискальноеУстройство.КассаККМ;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КассоваяСмена.Номер                      КАК НомерКассовойСмены,
	|	КассоваяСмена.Ссылка                     КАК КассоваяСмена,
	|	КассоваяСмена.Статус                     КАК СтатусКассовойСмены,
	|	КассоваяСмена.СтатусРегламентныхОпераций КАК СтатусРегламентныхОпераций,
	|	
	|	КассоваяСмена.Организация          КАК Организация,
	|	КассоваяСмена.КассаККМ             КАК КассаККМ,
	|	КассоваяСмена.ФискальноеУстройство КАК ФискальноеУстройство,
	|	
	|	ВЫБОР
	|		КОГДА КассоваяСмена.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК СменаОткрыта,
	|	
	|	ВЫБОР
	|		КОГДА КассоваяСмена.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта)
	|			ТОГДА КассоваяСмена.НачалоКассовойСмены
	|		ИНАЧЕ КассоваяСмена.ОкончаниеКассовойСмены
	|	КОНЕЦ КАК ДатаИзмененияСтатуса
	|ИЗ
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ГДЕ
	|	КассоваяСмена.Проведен                                                                                                      
	|	И ((КассоваяСмена.КассаККМ = &КассаККМ И &КассаККМ <> Неопределено)
	|	ИЛИ (КассоваяСмена.ФискальноеУстройство = &ФискальноеУстройство И &ФискальноеУстройство <> Неопределено))
	|
	|УПОРЯДОЧИТЬ ПО
	|	КассоваяСмена.Дата УБЫВ,
	|	КассоваяСмена УБЫВ";
	
	Запрос.УстановитьПараметр("КассаККМ",             КассаККМ);
	Запрос.УстановитьПараметр("ФискальноеУстройство", ФискальноеУстройство);
	
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	ОписаниеКассовойСмены = ОписаниеКассовойСмены();
	
	Если Выборка.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(ОписаниеКассовойСмены, Выборка);
		
		Если (ТекущаяДатаСеанса() - ОписаниеКассовойСмены.ДатаИзмененияСтатуса >= 86400)
			И Выборка.СменаОткрыта Тогда
			ОписаниеКассовойСмены.Ошибка24Часа = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КассаККМ) Тогда
		ЗаполнитьОписаниеКассовойСменыПоКассеККМ(ОписаниеКассовойСмены, КассаККМ);
	КонецЕсли;
	
	Возврат ОписаниеКассовойСмены;
	
КонецФункции

Функция КассаККМФискальноеУстройство(Объект, РабочееМесто) 
	
	УстановитьПривилегированныйРежим(Истина);
	
	ФискальноеУстройство = Неопределено;
	КассаККМ             = Неопределено;
	
	Если ТипЗнч(Объект) = Тип("СправочникСсылка.КассыККМ") Тогда
		
		КассаККМ = Объект;
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КассыККМ.ПодключаемоеОборудование КАК ФискальноеУстройство
		|ИЗ
		|	Справочник.НастройкиРМК.КассыККМ КАК КассыККМ
		|ГДЕ
		|	КассыККМ.КассаККМ = &КассаККМ
		|	И НЕ КассыККМ.ИспользоватьБезПодключенияОборудования
		|	И КассыККМ.Ссылка.РабочееМесто = &РабочееМесто
		|");
		
		Запрос.УстановитьПараметр("КассаККМ",     КассаККМ);
		Запрос.УстановитьПараметр("РабочееМесто", РабочееМесто);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		
		ФискальноеУстройство = Выборка.ФискальноеУстройство;
		
	Иначе
		
		ФискальноеУстройство = Объект;
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КассыККМ.КассаККМ КАК КассаККМ
		|ИЗ
		|	Справочник.НастройкиРМК.КассыККМ КАК КассыККМ
		|ГДЕ
		|	КассыККМ.ПодключаемоеОборудование = &ФискальноеУстройство
		|	И КассыККМ.Ссылка.РабочееМесто = &РабочееМесто
		|");
		
		Запрос.УстановитьПараметр("ФискальноеУстройство", ФискальноеУстройство);
		Запрос.УстановитьПараметр("РабочееМесто",         РабочееМесто);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Выборка.Следующий();
		
		КассаККМ = Выборка.КассаККМ;
		
	КонецЕсли;
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("ФискальноеУстройство", ФискальноеУстройство);
	ВозвращаемоеЗначение.Вставить("КассаККМ",             КассаККМ);
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции  

Процедура ВыполнитьОперациюЗакрытияКассовойСмены(КассаККМ, РабочееМесто, СтруктураСостояниеКассовойСмены, ОкончаниеСмены, 
	ОтчетОРозничныхПродажахНаТекущуюДату = Истина, ОшибкаПриСнятииZОтчета = Ложь, ОписаниеОшибки = "", ОписаниеОшибкиZОтчета = "") 
	
	// Опрделение даты отчета о розничных продажах
	ДатаОтчетаОРозничныхПродажах = ОкончаниеСмены;
	
	// Закрытие кассовой смены
	НачатьТранзакцию();
	Попытка
		КассоваяСмена = ЗакрытьКассовуюСмену(КассаККМ, РабочееМесто, ДатаОтчетаОРозничныхПродажах, ОписаниеОшибки);
		Если КассоваяСмена = Неопределено Тогда
			ОтменитьТранзакцию();
			ОписаниеОшибки = "Не удалось закрыть смену ККМ: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			Возврат;     
		КонецЕсли;
		
		Если ЗначениеЗаполнено(КассаККМ) Тогда
			ИнкассацияВыполнена = ВыполнитьАвтоматическуюИнкассациюДС(КассаККМ, РабочееМесто, ОшибкаПриСнятииZОтчета, ОписаниеОшибки);
			Если Не ИнкассацияВыполнена Тогда
				ОтменитьТранзакцию();
				ОписаниеОшибки = "Не удалось выполнить автоматическую инкассацию ДС " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
				Возврат;  
			КонецЕсли;
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();     
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Розничные продажи'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));          
			
		ОписаниеОшибки = "Не удалось закрыть смену ККМ: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
			
		Возврат;
	КонецПопытки;     
	
	// Получить обновленное состояние закрытой смены
	СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто); 
	                                                                                              
	// Удаление отложенных и чеков, по которым был зарезервирован товар.
	УдалитьОтложенныеЧеки(КассоваяСмена, ОписаниеОшибки);     
	
	// Заполнение отчета о розничных продажах         
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;		
	ТипыНалогообложенияНДСПоКассовойСмене = РозничныеПродажи.ПодготовитьДанныеПоЧекамКассовойСмены(СтруктураСостояниеКассовойСмены, МенеджерВременныхТаблиц);
	
	Для Каждого ТипНалогообложенияНДС Из ТипыНалогообложенияНДСПоКассовойСмене Цикл
		
		Попытка
			ОтчетОРозничныхВозвратах = РозничныеПродажи.ЗаполнитьОтчетОРозничныхВозвратахПоКассовойСмене(СтруктураСостояниеКассовойСмены, ТипНалогообложенияНДС.НалогообложениеНДС, МенеджерВременныхТаблиц, ОписаниеОшибкиZОтчета);
		Исключение
			ОписаниеОшибкиZОтчета = "Ошибка отчета о розничных возвратах: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + " ";
		КонецПопытки;
		
		Попытка
			ОтчетОРозничныхПродажах = РозничныеПродажи.ЗаполнитьОтчетОРозничныхПродажахПоКассовойСмене(СтруктураСостояниеКассовойСмены, ТипНалогообложенияНДС.НалогообложениеНДС, МенеджерВременныхТаблиц, ОписаниеОшибкиZОтчета);
		Исключение   
			ОписаниеОшибкиZОтчета = ОписаниеОшибкиZОтчета + " Ошибка отчета о розничных продажах: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + " ";
		КонецПопытки;
		
		// ОРП датой последней продажи
		ДатаПродажи = ПолучитьПоследнююПродажу(КассоваяСмена);
		ДатаПродажи = ?(Не ЗначениеЗаполнено(ДатаПродажи), 
			?(ЗначениеЗаполнено(КассоваяСмена.ОкончаниеКассовойСмены), КассоваяСмена.ОкончаниеКассовойСмены, КассоваяСмена.Дата), ДатаПродажи);
		
		УстановитьДатуОРП(ОтчетОРозничныхПродажах, ДатаПродажи);
		УстановитьДатуОРП(ОтчетОРозничныхВозвратах, ДатаПродажи);
			
	КонецЦикла;

	// Архивация чеков ККМ
	Если Константы.ОперацияПриЗакрытииКассовойСмены.Получить() = Перечисления.ОперацииПриЗакрытииКассовойСмены.АрхивацияЧековККМ Тогда
		ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("КассоваяСмена", КассоваяСмена);
		ПараметрыЗадания.Вставить("ОбработкаВыполнена", Ложь);
		РозничныеПродажи.ВыполнитьАрхивациюЧековККМ(ПараметрыЗадания);
	КонецЕсли;
	
	// Удаление чеков ККМ
	Если Константы.ОперацияПриЗакрытииКассовойСмены.Получить() = Перечисления.ОперацииПриЗакрытииКассовойСмены.УдалениеЧековККМ Тогда
		ПараметрыЗадания = Новый Структура;
		ПараметрыЗадания.Вставить("КассоваяСмена", КассоваяСмена);
		ПараметрыЗадания.Вставить("ОбработкаВыполнена", Ложь);
		РозничныеПродажи.ВыполнитьУдалениеЧековККМ(ПараметрыЗадания);
	КонецЕсли;
	
	РозничныеПродажи.ВыполнитьПроведениеВозвратов(СтруктураСостояниеКассовойСмены.КассоваяСмена);
	
КонецПроцедуры

Функция ЗакрытьКассовуюСмену(Объект, РабочееМесто, ОкончаниеСмены, ОписаниеОшибки = "") 
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = Истина;
	
	СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(Объект, РабочееМесто);
	
	Если СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта
		Или (СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Закрыта
		  И  СтруктураСостояниеКассовойСмены.СтатусРегламентныхОпераций = Перечисления.СтатусыРегламентныхОперацийКассовойСмены.ПустаяСсылка()) Тогда
		
		Если СтруктураСостояниеКассовойСмены.ДатаИзмененияСтатуса <= ТекущаяДатаСеанса() Тогда
		
			КассоваяСменаОбъект = СтруктураСостояниеКассовойСмены.КассоваяСмена.ПолучитьОбъект();
			КассоваяСменаОбъект.Статус                     = Перечисления.СтатусыКассовойСмены.Закрыта;
			КассоваяСменаОбъект.СтатусРегламентныхОпераций = Перечисления.СтатусыРегламентныхОперацийКассовойСмены.СозданОтчет;    
			КассоваяСменаОбъект.ОкончаниеКассовойСмены 	= ?(КассоваяСменаОбъект.НачалоКассовойСмены <= ОкончаниеСмены, ОкончаниеСмены, ТекущаяДата());

			Попытка
				КассоваяСменаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				Результат = Ложь;
				ОписаниеОшибки = НСтр("ru = 'При закрытии кассовой смены произошла ошибка.
				                            |Дополнительное описание:
				                            |%ДополнительноеОписание%'");
				ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%ДополнительноеОписание%", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;
		Иначе
			Результат = Ложь;
			ОписаниеОшибки = НСтр("ru = 'При закрытии кассовой смены произошла ошибка.
			                            |Дополнительное описание:
			                            |Дата закрытия кассовой смены меньше даты последнего изменения статуса кассовой смены.'");
		КонецЕсли;
	Иначе
		// Смена не открыта.
	КонецЕсли;
	
	Возврат ?(Результат, СтруктураСостояниеКассовойСмены.КассоваяСмена, Неопределено);
	
КонецФункции

Функция ВыполнитьАвтоматическуюИнкассациюДС(КассаККМ, РабочееМесто, ОшибкаПриСнятииZОтчета, ОписаниеОшибки = "")
	
	Результат = Истина;
	
	Если Не ОшибкаПриСнятииZОтчета Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		                                            
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиРМККассыККМ.КассаККМ.Владелец                      КАК Организация,
		|	НастройкиРМККассыККМ.КассаККМ.ВалютаДенежныхСредств         КАК Валюта,
		|	НастройкиРМККассыККМ.КассаККМ                               КАК КассаККМ,
		|	ЕСТЬNULL(ДенежныеСредстваВКассахККМОстатки.СуммаОстаток, 0) КАК СуммаДокумента,
		|	НастройкиРМККассыККМ.АвтоматическаяИнкассация               КАК АвтоматическаяИнкассация
		|ИЗ
		|	Справочник.НастройкиРМК.КассыККМ КАК НастройкиРМККассыККМ
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредстваВКассахККМ.Остатки(, КассаККМ = &КассаККМ) КАК ДенежныеСредстваВКассахККМОстатки
		|		ПО ДенежныеСредстваВКассахККМОстатки.КассаККМ = НастройкиРМККассыККМ.КассаККМ
		|ГДЕ
		|	НастройкиРМККассыККМ.КассаККМ = &КассаККМ
		|	И НастройкиРМККассыККМ.Ссылка.РабочееМесто = &РабочееМесто
		|";
		
		Запрос.УстановитьПараметр("КассаККМ", КассаККМ);
		Запрос.УстановитьПараметр("РабочееМесто", РабочееМесто);
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() И Выборка.АвтоматическаяИнкассация И Выборка.СуммаДокумента > 0 Тогда
			РозничныеПродажи.СоздатьДокументВыемкаДенежныхСредствИзКассыККМ(Выборка);
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОткрытьКассовуюСмену(КассаККМ, РабочееМесто, ДатаОткрытияКассовойСмены, ОписаниеОшибки = "") 
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Попытка
		Результат = Истина;
		
		СтруктураСостояниеКассовойСмены = ПолучитьСостояниеКассовойСмены(КассаККМ, РабочееМесто);
		
		Если СтруктураСостояниеКассовойСмены.СтатусКассовойСмены = Перечисления.СтатусыКассовойСмены.Открыта Тогда
			
			// Если смена открыта, то с момента открытия должно пройти не больше чем 24 часа.
			Если СтруктураСостояниеКассовойСмены.Ошибка24Часа Тогда
				Результат = Ложь;
				// Вероятно, что смена была не закрыта.
				ОписаниеОшибки = РозничныеПродажи.ОписаниеОшибки24Часа();
			КонецЕсли;
		Иначе
			// Смена закрыта. Откроем новую кассовую смену.
			
			НоваяКассоваяСмена = Документы.КассоваяСмена.СоздатьДокумент();
			НоваяКассоваяСмена.Заполнить(Новый Структура("КассаККМ", КассаККМ));
			
			НоваяКассоваяСмена.Организация            = СтруктураСостояниеКассовойСмены.Организация;
			НоваяКассоваяСмена.КассаККМ               = КассаККМ;
			НоваяКассоваяСмена.Дата                   = ТекущаяДатаСеанса();
			НоваяКассоваяСмена.Статус                 = Перечисления.СтатусыКассовойСмены.Открыта;
			НоваяКассоваяСмена.НачалоКассовойСмены    = ДатаОткрытияКассовойСмены;
			НоваяКассоваяСмена.ОкончаниеКассовойСмены = '00010101';
			
			Если НоваяКассоваяСмена.ПроверитьЗаполнение() Тогда
				НоваяКассоваяСмена.Записать(РежимЗаписиДокумента.Проведение);
			Иначе
				Результат = Ложь;
				ОписаниеОшибки = ПолучитьТекстОшибкиЗаполненияОтчета();
			КонецЕсли;
		КонецЕсли;   
	Исключение
		ОписаниеОшибки = ОписаниеОшибки + " " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат Результат;
КонецФункции

Функция УдалитьОтложенныеЧеки(КассоваяСмена, ОписаниеОшибки)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Результат = Истина;
	
	НачатьТранзакцию();
	Попытка
		
		ВыборкаЧековККМ = ВыбратьОтложенныеЧекиККМДляУдаления(КассоваяСмена);
		
		Пока ВыборкаЧековККМ.Следующий() Цикл
			ЧекККМОбъект = ВыборкаЧековККМ.Ссылка.ПолучитьОбъект();
			ЧекККМОбъект.Удалить();
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		
		ОтменитьТранзакцию();
		
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Розничные продажи'", ОбщегоНазначенияКлиентСервер.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		Результат = Ложь;
		
		ОписаниеОшибки = НСтр("ru = 'При удалении отложенных чеков произошла ошибка.
		                            |Дополнительное описание:
		                            |%ДополнительноеОписание%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%ДополнительноеОписание%", ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ВыбратьОтложенныеЧекиККМДляУдаления(КассоваяСмена = Неопределено)
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Документ.Ссылка КАК Ссылка,
	|	Документ.Дата КАК Дата,
	|	Документ.ОтложенДо КАК ОтложенДо,
	|	Документ.КассоваяСмена КАК КассоваяСмена
	|ПОМЕСТИТЬ ЧекиККМ
	|ИЗ
	|	Документ.ЧекККМ КАК Документ
	|ГДЕ
	|	Документ.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И (Документ.КассоваяСмена = &КассоваяСмена
	|			ИЛИ &КассоваяСмена = НЕОПРЕДЕЛЕНО)
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Документ.Ссылка,
	|	Документ.Дата,
	|	Документ.КассоваяСмена.ОкончаниеКассовойСмены,
	|	Документ.КассоваяСмена
	|ИЗ
	|	Документ.ЧекККМВозврат КАК Документ
	|ГДЕ
	|	Документ.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И (Документ.КассоваяСмена = &КассоваяСмена
	|			ИЛИ &КассоваяСмена = НЕОПРЕДЕЛЕНО)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка
	|ИЗ
	|	ЧекиККМ КАК ЧекККМ
	|ГДЕ
	|	ЧекККМ.ОтложенДо <> ДАТАВРЕМЯ(1, 1, 1)
	|	И ЧекККМ.ОтложенДо < &ТекущееВремя
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка
	|ИЗ
	|	ЧекиККМ КАК ЧекККМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.КоличествоДнейХраненияОтложенныхЧеков КАК КоличествоДнейХраненияОтложенныхЧеков
	|		ПО (ИСТИНА)
	|ГДЕ
	|	КоличествоДнейХраненияОтложенныхЧеков.Значение > 0
	|	И ДОБАВИТЬКДАТЕ(ЧекККМ.Дата, ДЕНЬ, КоличествоДнейХраненияОтложенныхЧеков.Значение) < &ТекущееВремя
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка
	|ИЗ
	|	ЧекиККМ КАК ЧекККМ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Константа.КоличествоДнейХраненияОтложенныхЧеков КАК КоличествоДнейХраненияОтложенныхЧеков
	|		ПО (ИСТИНА)
	|ГДЕ
	|	КоличествоДнейХраненияОтложенныхЧеков.Значение = 0
	|	И ЧекККМ.КассоваяСмена.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыКассовойСмены.Открыта)");
	
	Запрос.УстановитьПараметр("КассоваяСмена", КассоваяСмена);
	Запрос.УстановитьПараметр("ТекущееВремя",  ТекущаяДатаСеанса());
	
	Результат = Запрос.Выполнить();
	Возврат Результат.Выбрать();
	
КонецФункции

