#Область ПробитиеЧековИзОчереди   
                                                                                                              
Функция ЗаписатьВОчередьКПробитию(ПараметрыЗаписиВОчередь) Экспорт
	
	РезультатВыполнения = ПараметрыВыполнения();
	
	Попытка 
		Если Не ЗначениеЗаполнено(ПараметрыЗаписиВОчередь.ЭквайринговаяОперация) Тогда
			
			Если Не ПараметрыЗаписиВОчередь.Возврат Тогда
				ПараметрыЗаписиВОчередь.ЭквайринговаяОперация = Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(ПараметрыЗаписиВОчередь.ЗаказКлиента, ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал);
			Иначе	
				ПараметрыЗаписиВОчередь.ЭквайринговаяОперация = ПолучитьСуществующуюЭОВозврата(ПараметрыЗаписиВОчередь.ЗаказКлиента, ПараметрыЗаписиВОчередь.ЭквайринговыйТерминал).ЭквайринговаяОперация;
			КонецЕсли;
			
		КонецЕсли;

		// Найденная по заказу клиента ЭО уже пробита
		Если ЗначениеЗаполнено(ПараметрыЗаписиВОчередь.ЭквайринговаяОперация) И ПолучитьФискальнуюОперацию(ПараметрыЗаписиВОчередь.ЭквайринговаяОперация) Тогда
			РезультатВыполнения.Сообщение = СтрШаблон("%1 уже пробита", Строка(ПараметрыЗаписиВОчередь.ЭквайринговаяОперация)) + Символы.ПС;

		Иначе
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	Информация
				|ИЗ
				|	РегистрСведений.ОчередьЧековКПробитию 
				|ГДЕ
				|	ЗаказКлиента = &ЗаказКлиента
				|	И ДинамическаяСсылка = &ДинамическаяСсылка
				|	И &Возврат
				|	И ДатаПостановки = &ДатаПостановки";
						
			Запрос.УстановитьПараметр("ЗаказКлиента", ПараметрыЗаписиВОчередь.ЗаказКлиента);
			Запрос.УстановитьПараметр("ДинамическаяСсылка", ПараметрыЗаписиВОчередь.ДинамическаяСсылка);
			Запрос.УстановитьПараметр("ДатаПостановки", ПараметрыЗаписиВОчередь.ДатаПостановки);
			Запрос.УстановитьПараметр("Возврат", ПараметрыЗаписиВОчередь.Возврат);
			
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				РезультатВыполнения.Сообщение = СтрШаблон("%1 уже находится в очереди: %2", Строка(ПараметрыЗаписиВОчередь.ЗаказКлиента)) + Символы.ПС;	
			Иначе
			
				НоваяЗапись = РегистрыСведений.ОчередьЧековКПробитию.СоздатьМенеджерЗаписи();
				ЗаполнитьЗначенияСвойств(НоваяЗапись, ПараметрыЗаписиВОчередь);
				НоваяЗапись.АдресУведомленияКлиента 	= ?(Не ЗначениеЗаполнено(НоваяЗапись.АдресУведомленияКлиента), 
														ПолучениеУведомленияЧекаККТ(ПараметрыЗаписиВОчередь.ЗаказКлиента), НоваяЗапись.АдресУведомленияКлиента);
				НоваяЗапись.КоличествоПопытокПробития	= 0;
				НоваяЗапись.СтатусОшибки              	= Истина;
				НоваяЗапись.Информация                	= "Чек помещен в очередь!";
			    НоваяЗапись.Записать(Истина);	
			    
			    РезультатВыполнения.Результат = Истина;
			    РезультатВыполнения.Сообщение = "Динамическая ссылка поставлена в очередь к пробитию:";
		    КонецЕсли
	    КонецЕсли;
		
	Исключение
		РезультатВыполнения.Сообщение = СтрШаблон("Динамическая ссылка %1 по %2 не поставлена в очередь к пробитию: %3", 
			ПараметрыЗаписиВОчередь.ИдентификаторСсылки, ПараметрыЗаписиВОчередь.ДокументОперации, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;	

	Возврат РезультатВыполнения;
	
КонецФункции

Функция ПробитьЧекиИзОчереди(ПараметрыПробития) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
		
	НастройкиДС = ИнтеграцияБанки.ПолучитьНастройкиДинамическиеСсылки().Ответ;
	НастройкиДС = ?(ТипЗнч(НастройкиДС) = Тип("Соответствие"), НастройкиДС, Новый Соответствие);
	ЛогОчереди = "";

	ЧекиОчереди = ПолучитьЧекиОчереди(ПараметрыПробития);
	Пока ЧекиОчереди.Следующий() Цикл 
		
		РезультатВыполнения = Новый Структура("Результат, Сообщение, ДатаНачала", Ложь, "", ТекущаяДатаСеанса());  
		ЛогированиеЧека = НастройкиДС.Получить(ЧекиОчереди.ТипСсылки);
		
		НачатьТранзакцию();

		Попытка
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировки = БлокировкаДанных.Добавить("РегистрСведений.ОчередьЧековКПробитию");
			ЭлементБлокировки.УстановитьЗначение("ДатаПостановки", ЧекиОчереди.ДатаПостановки);
			ЭлементБлокировки.УстановитьЗначение("ЗаказКлиента", ЧекиОчереди.ЗаказКлиента);
			ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;   
			
			// Несколько процессов конкурируют за пробитие
			Попытка
				БлокировкаДанных.Заблокировать();                                 
			Исключение           
				ОтменитьТранзакцию();
				Продолжить;
			КонецПопытки;
			
			НаборЗаписей = ПолучитьДанныеОчереди(ЧекиОчереди.ДатаПостановки, ЧекиОчереди.ЗаказКлиента);
			ЗаписьОчереди = НаборЗаписей[0];
			
			// Запись очереди изменена в другом процессе
			Если ЗаписьОчереди.Обработано Тогда
				ОтменитьТранзакцию();
				Продолжить;
			КонецЕсли;	
			
			Если Не ЗначениеЗаполнено(ЗаписьОчереди.УИД) Тогда
				ЗаписьОчереди.УИД = XMLСтрока(Новый УникальныйИдентификатор()); 
				НаборЗаписей.Записать();
			КонецЕсли;  
			
			ПолучениеДокументаОплаты = ПолучитьДокументОплаты(ЗаписьОчереди);
			РезультатВыполнения.Сообщение = ПолучениеДокументаОплаты.Сообщение; 
			
			Если ПолучениеДокументаОплаты.Результат Тогда

				ЗаписьОчереди.ЭквайринговаяОперация = ПолучениеДокументаОплаты.ЭквайринговаяОперация;
				НаборЗаписей.Записать();
				
				ПараметрыАТОЛ = ПараметрыАтолПробитияИзОчереди(ЗаписьОчереди, ЗаписьОчереди.Касса);
					
				// Проверить открыта ли смена ККТ
				АктуальностьСменыККТ = ПроверитьАктуальностьСменыАТОЛ(ЗаписьОчереди.Касса);    
				Если Не АктуальностьСменыККТ.Результат Тогда
					РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + АктуальностьСменыККТ.Сообщение + Символы.ПС;
				
				Иначе             
					// Проверить, что задание еще не отправлялось (стандартно не должно быть отправлено)
					РезультатПробития = ПолучитьРезультатПробития(ПараметрыАТОЛ, ЗаписьОчереди.УИД);
						
					Если Не РезультатПробития.Результат Тогда

						Если РезультатПробития.ОтправитьЗадание Тогда
		
							Если РезультатПробития.НовыйУИДЗадания Тогда   
								ЗаписьОчереди.УИД = XMLСтрока(Новый УникальныйИдентификатор());  
								НаборЗаписей.Записать();
							КонецЕсли;
						
							// Отправить задание на пробитие чека
							ПробитиеЧека = ПробитьЧек(ПараметрыАТОЛ, ЗаписьОчереди.УИД);  
							РезультатВыполнения.Сообщение = ПробитиеЧека.Сообщение;
							
							// Проверить задание по пробитию чека
							Если ПробитиеЧека.Результат Тогда
								РезультатПробития = ПолучитьРезультатПробития(ПараметрыАТОЛ, ЗаписьОчереди.УИД);
								РезультатВыполнения.Сообщение = РезультатПробития.Сообщение;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
					
					// Записать фискальную операцию
					Если РезультатПробития.Результат И Не АльтерраОбщегоНазначения.ПолучитьФискальнуюОперацию(ЗаписьОчереди.ЭквайринговаяОперация) Тогда      
						
						Попытка			
							ПараметрыФискализации = АТОЛСревер.ПодготовитьДанныеФискализацииЧека(ПараметрыАТОЛ, РезультатПробития.ДанныеФН);
							ОборудованиеЧекопечатающиеУстройстваВызовСервера.ЗаписатьФискальнуюОперацию(ПараметрыФискализации);
							
							РезультатВыполнения.Результат = Истина;
						Исключение
							РезультатВыполнения.Сообщение = "Оплата не зафиксирована: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + Символы.ПС;
						КонецПопытки;  
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;

			// Записать результат обработки в регистр очереди   
			ЗаписьОчереди.Обработано = РезультатВыполнения.Результат;
			ЗаписьОчереди.СтатусОшибки = Не РезультатВыполнения.Результат;
			ЗаписьОчереди.КоличествоПопытокПробития = ЗаписьОчереди.КоличествоПопытокПробития + 1;
			ЗаписьОчереди.Информация = ?(РезультатВыполнения.Результат, "Чек пробит", РезультатВыполнения.Сообщение);
			НаборЗаписей.Записать();
		
			ЗафиксироватьТранзакцию();
			
		Исключение
			ОтменитьТранзакцию();
			РезультатВыполнения.Результат = Ложь;
			РезультатВыполнения.Сообщение = "Чек не пробит: " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + Символы.ПС;
			
			// Записать результат ошибки пробития чека         
			Попытка
				НаборЗаписей = ПолучитьДанныеОчереди(ЧекиОчереди.ДатаПостановки, ЧекиОчереди.ЗаказКлиента);
				ЗаписьОчереди = НаборЗаписей[0];
				ЗаписьОчереди.Обработано = Ложь;
				ЗаписьОчереди.СтатусОшибки = Истина;
				ЗаписьОчереди.КоличествоПопытокПробития = ЗаписьОчереди.КоличествоПопытокПробития + 1;
				ЗаписьОчереди.Информация = РезультатВыполнения.Сообщение;
				НаборЗаписей.Записать();
			Исключение
			КонецПопытки
			
		КонецПопытки;                                               
		
		ПараметрыЗаписиОчереди = ПараметрыПробитияЧековОчереди();
		ЗаполнитьЗначенияСвойств(ПараметрыЗаписиОчереди, ПараметрыПробития);
		ПараметрыЗаписиОчереди.ТипПробития = "Текущий";
		ЗаполнитьЗначенияСвойств(ПараметрыЗаписиОчереди, ЧекиОчереди, "ДатаПостановки, ЗаказКлиента");
		
		// Отправка в чаты    
		Попытка
			Если РезультатВыполнения.Результат И ЗначениеЗаполнено(ЛогированиеЧека) И ЗначениеЗаполнено(ЛогированиеЧека.ЧатПробития) Тогда
				ОтправитьРезультатПробитияВЧат(ЛогированиеЧека.ЧатПробития, ЧекиОчереди, ЗаписьОчереди.ЭквайринговаяОперация, 
					РезультатВыполнения.Результат, "");
			КонецЕсли; 								
			Если Не РезультатВыполнения.Результат И ЗначениеЗаполнено(ЛогированиеЧека) И ЗначениеЗаполнено(ЛогированиеЧека.ЧатОшибок) Тогда
				ОтправитьРезультатПробитияВЧат(ЛогированиеЧека.ЧатОшибок, ЧекиОчереди, ЗаписьОчереди.ЭквайринговаяОперация, 
				РезультатВыполнения.Результат, РезультатВыполнения.Сообщение)
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		// Логирование пробития
		Попытка
			Если ЗначениеЗаполнено(ЛогированиеЧека) И ЗначениеЗаполнено(ЛогированиеЧека.ПапкаЛогов) Тогда
				РезультатВыполнения.Вставить("ПапкаЛогов",	ЛогированиеЧека.ПапкаЛогов);
				РезультатВыполнения.Вставить("Описание",	СформироватьОписаниеЗаписиОчереди(ЧекиОчереди, ЗаписьОчереди.ЭквайринговаяОперация, 
															РезультатВыполнения.Результат, Ложь) + Символы.ПС + РезультатВыполнения.Сообщение);
				РезультатВыполнения.Вставить("Номер", 		ЧекиОчереди.ЗаказКлиентаНомер);
				РезультатВыполнения.Вставить("СуммаОплаты", ЧекиОчереди.СуммаОплаты);
				ЗаписатьЛогЧековПробития(РезультатВыполнения);
			КонецЕсли;			
		Исключение
		КонецПопытки;
			
		ЛогОчереди = ЛогОчереди + РезультатВыполнения.Сообщение;
		
		ПолучитьЧекиОчереди(ПараметрыЗаписиОчереди).Следующий();
	КонецЦикла;
	
	Возврат ЛогОчереди;
	
КонецФункции       

Функция ПолучитьДанныеОчереди(ДатаПостановки, ДокументПродажи)
	
	НаборЗаписей = РегистрыСведений.ОчередьЧековКПробитию.СоздатьНаборЗаписеЙ();
	НаборЗаписей.Отбор.ДатаПостановки.Установить(ДатаПостановки);
	НаборЗаписей.Отбор.ЗаказКлиента.Установить(ДокументПродажи);
	НаборЗаписей.Прочитать();   
	
	Возврат НаборЗаписей;
	
КонецФункции

Процедура ОтправитьРезультатПробитияВЧат(Чат, ЗаписьОчереди, ЭквайринговаяОперация, Результат, Сообщение) Экспорт
	
	АльтерраВзаимодействиеСБитрикс24.ОтправитьВЧат(Чат, 
		СформироватьОписаниеЗаписиОчереди(ЗаписьОчереди, ЭквайринговаяОперация, Результат) + Сообщение);
			 								
КонецПроцедуры

Функция ПолучитьЧекиОчереди(ПараметрыПробития, Обработано = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	Очередь.ТипСсылки,		
		|	Очередь.Касса,				
		|	Очередь.ДатаПостановки,
		|	Очередь.ЗаказКлиента,
		|	ЗаказКлиента.Номер,	
		|	ВЫБОР 
		|		КОГДА ЗаказКлиента ССЫЛКА Документ.ЗаказКлиента
		|		ТОГДА ЗаказКлиента.НомерНаСайте
		|		ИНАЧЕ &ПустаяСтрока
		|	КОНЕЦ КАК НомерНаСайте,
		|	ЗаказКлиента.Партнер,
		|	ЗаказКлиента.Партнер.НаименованиеПолное КАК ПартнерНаименование,
		|	Очередь.ЭквайринговаяОперация,
		|	Очередь.СуммаОплаты,
		|	Очередь.АдресУведомленияКлиента,
		|	Очередь.НомерКарты,
		|	Очередь.ЭквайринговыйТерминал,
		|	Очередь.ДинамическаяСсылка,
		|	Очередь.Возврат,
		|	Очередь.Обработано,	
		|	Очередь.КоличествоПопытокПробития,
		|	Очередь.СтатусОшибки,
		|	Очередь.Информация,
		|	Очередь.УИД
		|ИЗ
		|	РегистрСведений.ОчередьЧековКПробитию КАК Очередь
		|ГДЕ
		|	Очередь.Обработано = &Обработано
		|	%Условие";                           
	
	Если ПараметрыПробития.ТипПробития = "Все" Тогда
		Условие = "";			
		
	ИначеЕсли ПараметрыПробития.ТипПробития = "ЗаПериод" Тогда
		Условие = "И Очередь.ДатаПостановки МЕЖДУ &ДатаНачала И &ДатаОкончания";
		Запрос.УстановитьПараметр("ДатаНачала", ПараметрыПробития.ДатаНачала);
		Запрос.УстановитьПараметр("ДатаОкончания", ПараметрыПробития.ДатаОкончания);
		
	ИначеЕсли ПараметрыПробития.ТипПробития = "Текущий" Тогда
		Условие = 
		"И Очередь.ДатаПостановки = &ДатаПостановки 
		|И Очередь.ЗаказКлиента = &ЗаказКлиента";
		Запрос.УстановитьПараметр("ДатаПостановки", ПараметрыПробития.ДатаПостановки);
		Запрос.УстановитьПараметр("ЗаказКлиента", ПараметрыПробития.ЗаказКлиента);
	КонецЕсли;                       
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Условие", Условие);
	Запрос.УстановитьПараметр("Обработано", Обработано);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Функция ПолучитьДокументОплаты(ЗаписьОчереди) Экспорт         
	
	// Отметить оплату в реализации
	Если ТипЗнч(ЗаписьОчереди.ЗаказКлиента) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		УстановитьОтметкуКассыВРеализации(ЗаписьОчереди.ЗаказКлиента);
	КонецЕсли;
			
	// Эквайринговая операция 
	Если ТипЗнч(ЗаписьОчереди.ЗаказКлиента) = Тип("ДокументСсылка.ЗаказКлиента")              
		Или ТипЗнч(ЗаписьОчереди.ЗаказКлиента) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
		Или ТипЗнч(ЗаписьОчереди.ЗаказКлиента) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		
			Возврат ПолучитьЭкваринговуюОперацию(ЗаписьОчереди);  
			
		Иначе
			Возврат  Новый Структура("Результат, Сообщение, ЭквайринговаяОперация", Ложь, "Не определен документ оплаты для этого типа документа продажи", 
				ЗаписьОчереди.ЭквайринговаяОперация);
	КонецЕсли;
	
КонецФункции	  

Функция УстановитьОтметкуКассыВРеализации(Ссылка) Экспорт
	
	Реализация = Ссылка.ПолучитьОбъект();
	
	Реализация.ДатаОтметкиКасса = ТекущаяДата();      
	// TODO: Кто кассир? Может в настройки
	Реализация.Кассир = Справочники.Пользователи.НайтиПоНаименованию("web", Истина);
	Реализация.СуммаВзаиморасчетов = Реализация.СуммаДокумента;
	
	// TODO: Новое место - динамические ссылки и сайт?
	//Реализация.МестоОплаты = ПредопределенноеЗначение("Перечисление.МестоОплаты.КСО");   
		
	Реализация.Записать(РежимЗаписиДокумента.Проведение)
	
КонецФункции	

Функция ПолучитьЭкваринговуюОперацию(ЗаписьОчереди) Экспорт
	
	РезультатВыполнения = Новый Структура("Результат, Сообщение, ЭквайринговаяОперация", Истина, "", ЗаписьОчереди.ЭквайринговаяОперация);
	
	Попытка
		ЭквайринговаяОперация = ЗаписьОчереди.ЭквайринговаяОперация;
		
		Если Не ЗначениеЗаполнено(ЭквайринговаяОперация) Тогда
			
			Если Не ЗаписьОчереди.Возврат Тогда
				ЭквайринговаяОперация = Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(ЗаписьОчереди.ЗаказКлиента, 
					ЗаписьОчереди.ЭквайринговыйТерминал);
			Иначе	
				ЭквайринговаяОперация = ПолучитьСуществующуюЭОВозврата(ЗаписьОчереди.ЗаказКлиента, ЗаписьОчереди.ЭквайринговыйТерминал).ЭквайринговаяОперация;
			КонецЕсли;
		КонецЕсли;
	
		Если ЗначениеЗаполнено(ЭквайринговаяОперация) Тогда
			ДокументОплаты = ЭквайринговаяОперация.ПолучитьОбъект();
		Иначе
			
			ДокументОплаты = Документы.ОперацияПоПлатежнойКарте.СоздатьДокумент();
			
			Если ЗаписьОчереди.Возврат Тогда
				ДокументОплаты.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту");				
			КонецЕсли;
			
			ДокументОплаты.Заполнить(ЗаписьОчереди.ЗаказКлиента);

		КонецЕсли;
		
		// Корректировка заполнения для возврата
		Если ЗаписьОчереди.Возврат Тогда
			
			СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоНаименованию("ВОЗВРАТ ФИЗИЧЕСКОМУ ЛИЦУ", Истина); 
			Для Каждого Расшифоровка Из ДокументОплаты.РасшифровкаПлатежа Цикл
				Расшифоровка.СтатьяДвиженияДенежныхСредств = СтатьяДвиженияДенежныхСредств;
			КонецЦикла;

		КонецЕсли;
		
		ДокументОплаты.Подразделение = ПредопределенноеЗначение("Справочник.СтруктураПредприятия.ПустаяСсылка");
		
		Если Не ЗаписьОчереди.Возврат Тогда  
			Комментарий = ?(ЗаписьОчереди.ТипСсылки = ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт"), "Оплачено на сайте.", "Оплачено по ссылке.");
		Иначе
			Комментарий = ?(ЗаписьОчереди.ТипСсылки = ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт"), "Возврат с сайта.", "Возврат по ссылке.");
		КонецЕсли;
		
		Если ДокументОплаты.Проведен И СтрНайти(ДокументОплаты.Комментарий, Комментарий) > 0  Тогда
			РезультатВыполнения.Сообщение = Строка(ДокументОплаты.Ссылка) + " уже проведена ранее"  + Символы.ПС;
			Возврат РезультатВыполнения;
		КонецЕсли;
		
		Если ДокументОплаты.ПометкаУдаления Тогда
			РезультатВыполнения.Результат = Ложь;
			РезультатВыполнения.Сообщение = Строка(ДокументОплаты.Ссылка) + " помечена на удаление"  + Символы.ПС;
			Возврат РезультатВыполнения;
		КонецЕсли;
		
		ДокументОплаты.Дата = ТекущаяДатаСеанса();
		ДокументОплаты.ДоговорЭквайринга = ЗаписьОчереди.ЭквайринговыйТерминал.Владелец;
		ДокументОплаты.ЭквайринговыйТерминал = ЗаписьОчереди.ЭквайринговыйТерминал;
		ДокументОплаты.Комментарий = ДокументОплаты.Комментарий + 
			?(ЗначениеЗаполнено(ДокументОплаты.Комментарий) И Прав(ДокументОплаты.Комментарий, 1) <> ".", ".", "") + " " + Комментарий;
		 
		Если ЗначениеЗаполнено(ЗаписьОчереди.НомерКарты) Тогда
			ДокументОплаты.НомерПлатежнойКарты = ЗаписьОчереди.НомерКарты;
		ИначеЕсли Не ЗначениеЗаполнено(ДокументОплаты.НомерПлатежнойКарты) И ЗаписьОчереди.ТипСсылки = ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.Сайт") Тогда
			ДокументОплаты.НомерПлатежнойКарты = "0202";
		КонецЕсли;	
		
		ФинансыКлиентСервер.ПересчитатьСуммыВСтрокеРасшифровкиПлатежа(ДокументОплаты, ЗаписьОчереди.СуммаОплаты, Ложь);
		ДокументОплаты.СуммаДокумента = ДокументОплаты.РасшифровкаПлатежа.Итог("Сумма");
	
		ДокументОплаты.Записать(РежимЗаписиДокумента.Проведение);
		РезультатВыполнения.Сообщение = Строка(ДокументОплаты.Ссылка) + " проведена"  + Символы.ПС;
		РезультатВыполнения.ЭквайринговаяОперация = ДокументОплаты.Ссылка;
		
	Исключение
		РезультатВыполнения.Результат = Ложь;
		РезультатВыполнения.Сообщение = "Ошибка проведения эквайринга по заказу " + Строка(ЗаписьОчереди.ЗаказКлиента) + Символы.ПС;
		
		СписокРеквизитов = СписокРеквизитов(ДокументОплаты) + Символы.ПС;
		Инфо = ИнформацияОбОшибке();
		ОшибкаОписание = Инфо.Описание + Символы.ПС + Инфо.ИмяМодуля + Символы.ПС + Инфо.НомерСтроки + Символы.ПС + Инфо.ИсходнаяСтрока + Символы.ПС;

		Если ДокументОплаты.Организация <> ЗаписьОчереди.ЗаказКлиента.Организация Тогда
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + "Организации заказа и эквайринговой операции отличаются" + Символы.ПС;
		КонецЕсли;
		
		// Попытка хотя бы не проведения, но записи эквайринга
		Попытка
			ДокументОплаты.ОбменДанными.Загрузка = Истина;
			ДокументОплаты.Записать();
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + "Экваринговая операция записана" + Символы.ПС;
		Исключение
			РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + "Экваринговая операция не записана" + Символы.ПС;	
		КонецПопытки;
		
		 РезультатВыполнения.Сообщение = РезультатВыполнения.Сообщение + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + Символы.ПС;

	КонецПопытки;
	
	Возврат РезультатВыполнения;

КонецФункции	

Функция ПолучитьСуществующуюЭОВозврата(Документ, ЭквайринговыйТерминал = Неопределено) Экспорт
	
	РезультатВыполнения = Новый Структура("ЭквайринговаяОперация, СуммаДокумента");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ 
		|	ЭО.Ссылка КАК ЭквайринговаяОперация,
		|	ЭО.СуммаДокумента
		|ИЗ  
		|	Документ.ОперацияПоПлатежнойКарте КАК ЭО
		|	СОЕДИНЕНИЕ Документ.ОперацияПоПлатежнойКарте.РасшифровкаПлатежа КАК Расшифровка
		|		ПО ЭО.Ссылка = Расшифровка.Ссылка    
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФискальныеОперации КАК ФискальныеОперации
		|		ПО ЭО.Ссылка = ФискальныеОперации.ДокументОснование  
		|ГДЕ   
		|	ЭО.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту)
		|	И ВЫБОР 
		|		КОГДА &ФильтрЭТ 
		|		ТОГДА ЭО.ЭквайринговыйТерминал = &ЭквайринговыйТерминал
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ
		|	И НЕ ЭО.ПометкаУдаления
		|	И Расшифровка.ОснованиеПлатежа = &Документ
		|	И ФискальныеОперации.ДокументОснование ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Документ", Документ);  
	Запрос.УстановитьПараметр("ФильтрЭТ", ЗначениеЗаполнено(ЭквайринговыйТерминал));  
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", ЭквайринговыйТерминал);
		
	Выборка = Запрос.Выполнить().Выбрать();   
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(РезультатВыполнения, Выборка);
	КонецЕсли;		
	
	Возврат РезультатВыполнения;
	 
КонецФункции

Функция ПараметрыАтолПробитияИзОчереди(ЗаписьОчереди, ККТ) Экспорт
	
	ПараметрыПодключения = АТОЛСревер.ПолучитьПараметрыСоединения(ККТ.IP, ККТ.Порт, 
		ККТ.ПользовательУстройства, ККТ.ПарольУстройства, Ложь, ККТ.ИДУстройства);
	ПараметрыПодключения.Таймаут = 10;
	
	ПараметрыАТОЛ = АТОЛСревер.ШаблонПараметровАТОЛ();
	ПараметрыАТОЛ.ПараметрыПодключения = ПараметрыПодключения;       
	
	ПараметрыАТОЛ.ИДУстройства 			= ПараметрыПодключения.ИДУстройства;
	ПараметрыАТОЛ.НеПечататьЧек 		= ККТ.НеПечататьЧек;
	ПараметрыАТОЛ.СуммаОплаты 			= ЗаписьОчереди.СуммаОплаты; 
	
	Если Не ЗаписьОчереди.Возврат Тогда
		ПараметрыАТОЛ.ДокументПродажи 	= ЗаписьОчереди.ЗаказКлиента;
	Иначе
		ПараметрыАТОЛ.ДокументПродажи 	= ЗаписьОчереди.ЭквайринговаяОперация;
	КонецЕсли;
	
	ПараметрыАТОЛ.ДокументОплаты 		= ЗаписьОчереди.ЭквайринговаяОперация;     
	
	// Интернет-эквайринг
	ПараметрыАТОЛ.Вставить("ИнтернетЭквайринг", Истина);
	ПараметрыАТОЛ.Вставить("МестоРасчетов", "tg-alterra.ru");
	ПараметрыАТОЛ.EmailИлиТелефон = ЗаписьОчереди.АдресУведомленияКлиента;         
	
	ПараметрыАТОЛ.Вставить("КассирВЧеке", "Интернет-магазин tg-alterra.ru");
	
	ПараметрыАТОЛ.Вставить("ОтправлятьЧекИзОФД", Истина);    
	
	Если ЗаписьОчереди.Возврат Тогда
		ПараметрыАТОЛ.Вставить("ТипОперации", "sellReturn");
	КонецЕсли;

	ИнформацияККТ = АТОЛСревер.ИнформацияОККТ(ПараметрыАТОЛ);
	ПараметрыАТОЛ.Вставить("ИнформацияККТ", ИнформацияККТ);       
	
	Возврат ПараметрыАТОЛ;
	
КонецФункции  

Процедура ВыполнитьПробитиеЧека(ДатаПостановки, ЗаказКлиента) Экспорт
	
	ПараметрыПробития = ПараметрыПробитияЧековОчереди();
	ПараметрыПробития.ТипПробития 				= "Текущий";
	ПараметрыПробития.ДатаПостановки 			= ДатаПостановки;
	ПараметрыПробития.ЗаказКлиента 				= ЗаказКлиента;
	
	Попытка
		МассивПараметров = Новый Массив;         
		МассивПараметров.Добавить(ПараметрыПробития);

		ФоновыеЗадания.Выполнить("ДопМодульСервер.ПробитьЧекиИзОчереди", МассивПараметров);
	Исключение
	КонецПопытки;	

КонецПроцедуры	

#Область ЛогированиеОтправкаВЧаты     

Функция ПолучениеУведомленияЧекаККТ(Документ)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(ПартнерыТелефон.НомерТелефона, &ПустаяСтрока) КАК НомерТелефона,
		|	ЕСТЬNULL(ПартнерыАдресЭП.АдресЭП, &ПустаяСтрока) КАК АдресЭП
		|ИЗ 
		|	%ТипДокумента КАК ДокументОчереди
		|	СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		|		ПО ДокументОчереди.Партнер = Партнеры.Ссылка 
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыТелефон 
		|	   	ПО Партнеры.Ссылка = ПартнерыТелефон.Ссылка
		|		И ПартнерыТелефон.НомерТелефона <> &ПустаяСтрока    
		|		И ПартнерыТелефон.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера)
		|	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыАдресЭП
		|		ПО Партнеры.Ссылка = ПартнерыАдресЭП.Ссылка
		|		И ПартнерыАдресЭП.АдресЭП <> &ПустаяСтрока   
		|		И ПартнерыАдресЭП.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailПартнера) 
		|ГДЕ
		|	ДокументОчереди.Ссылка = &Документ";          
	
	ТипДокумента = Метаданные.НайтиПоТипу(ТипЗнч(Документ)).ПолноеИмя();
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%ТипДокумента", ТипДокумента);
	
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	
	// TODO: Вынести почту по умолчанию в настройки
	УведомлениеЧека = "tg-alterra@mail.ru";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		Если ЗначениеЗаполнено(Выборка.НомерТелефона) Тогда
			УведомлениеЧека = "+7" + Выборка.НомерТелефона;	
		
		ИначеЕсли ЗначениеЗаполнено(Выборка.АдресЭП) Тогда
			УведомлениеЧека = Выборка.АдресЭП;	
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат УведомлениеЧека;
		
КонецФункции

Функция СформироватьОписаниеЗаписиОчереди(ЗаписьОчереди, ЭквайринговаяОперация, Результат, ВЧат = Истина)

	Попытка
		НомерНаСайте = Число(ЗаписьОчереди.НомерНаСайте);
	Исключение
		НомерНаСайте = ЗаписьОчереди.НомерНаСайте;
	КонецПопытки;
	
	УведомлениеКлиента = ЗаписьОчереди.АдресУведомленияКлиента;
	ЭтоУведомлениеАдрес = СтрНайти(ЗаписьОчереди.АдресУведомленияКлиента, "@") > 0;
	Если ЗначениеЗаполнено(УведомлениеКлиента) И Не ЭтоУведомлениеАдрес Тогда
		Если Лев(УведомлениеКлиента, 2) = "+7" Тогда
			УведомлениеКлиента = ФорматированныйНомерТелефона(Сред(УведомлениеКлиента, 3));
		Иначе		
			УведомлениеКлиента = ФорматированныйНомерТелефона(УведомлениеКлиента);
		КонецЕсли;
	КонецЕсли;
	
	НЖ = ?(ВЧат, "[B]", "");
	КЖ = ?(ВЧат, "[/B]", "");
	НЦ = ?(ВЧат, "[COLOR=#900020]", "");
	КЦ = ?(ВЧат, "[/COLOR]", "");
	
	Описание = 
		?(ЗаписьОчереди.Возврат, НЖ + НЦ + "Возврат оплаты" + КЦ + КЖ + Символы.ПС, "") +
		СтрШаблон(НЖ + "%1" + КЖ, Строка(ЗаписьОчереди.ЗаказКлиента)) + Символы.ПС +
		?(ЗначениеЗаполнено(НомерНаСайте), СтрШаблон("№ на сайте: " + НЖ + "%1" + КЖ, НомерНаСайте) + Символы.ПС, "") + 
		?(ЗначениеЗаполнено(ЭквайринговаяОперация), СтрШаблон("%1", Строка(ЭквайринговаяОперация)) + Символы.ПС, "") +
		СтрШаблон(?(Результат, ?(ЗаписьОчереди.Возврат, "Возврат на: ", "Пробит чек на: "), "Сумма: ") + 
			?(ЗаписьОчереди.Возврат, НЦ, "") + НЖ + "%1 ₽" + КЖ + ?(ЗаписьОчереди.Возврат, КЦ, "") , Формат(ЗаписьОчереди.СуммаОплаты, "ЧДЦ=2")) + Символы.ПС + 
		?(ЗначениеЗаполнено(ЗаписьОчереди.ПартнерНаименование), СтрШаблон("%1", Строка(ЗаписьОчереди.ПартнерНаименование)) + Символы.ПС, "") + 
		?(ЗначениеЗаполнено(УведомлениеКлиента), СтрШаблон(?(ЭтоУведомлениеАдрес, "email: ", "тел: ") + НЖ + "%1" + КЖ, УведомлениеКлиента) + Символы.ПС, "") +
		?(Не Результат, НЖ + НЦ + "Ошибка" + КЦ + КЖ + Символы.ПС, "");

	Возврат Описание;
		
КонецФункции	

Процедура ЗаписатьЛогЧековПробития(РезультатВыполнения) 
	
	ТекДата = ТекущаяДатаСеанса();
 
	ИмяКаталога = РезультатВыполнения.ПапкаЛогов + ?(Прав(РезультатВыполнения.ПапкаЛогов, 1) <> "\", "\", "") +  Формат(ТекДата, "ДФ=ггггММдд"); 
	
	Попытка 
		КаталогЛогов = Новый Файл(ИмяКаталога);
		Если Не КаталогЛогов.Существует() Тогда
			СоздатьКаталог(ИмяКаталога);
		КонецЕсли;   
		
		ИмяЛога = "log" + "_" + Формат(ТекДата, "ДФ=ггггММдд") + "_" + Формат(ТекДата, "ДФ=ЧЧммсс") + "_" + 
			РезультатВыполнения.Номер + "_" +
			Формат(РезультатВыполнения.СуммаОплаты, "ЧГ=; ЧДЦ=2; ЧРД=,") + "руб" +
			?(Не РезультатВыполнения.Результат, "_error", "") + ".txt";   
		
		ФайлЛогов = Новый ЗаписьТекста(ИмяКаталога + "\" + ИмяЛога, КодировкаТекста.UTF8, , Истина);
		
		ТекстЛогов = Формат(РезультатВыполнения.ДатаНачала,  "ДФ=дд.ММ.гггг ЧЧ:мм:сс")  + Символы.ПС + 
			РезультатВыполнения.Описание + 
			?(ЗначениеЗаполнено(РезультатВыполнения.Сообщение), РезультатВыполнения.Сообщение, "") +
			Формат(ТекДата, "ДФ=дд.ММ.гггг ЧЧ:мм:сс") + Символы.ПС;
		
		ФайлЛогов.ЗаписатьСтроку(ТекстЛогов);
		ФайлЛогов.Закрыть();

	Исключение
		ФайлЛогов = Неопределено;
	КонецПопытки;    

КонецПроцедуры

