Процедура ЗаписатьЛогЛК(ПараметрыВходногоЗапроса, СтрокаJSON = "", Ошибка = Ложь) Экспорт
	
	ТекДата = ТекущаяДатаСеанса();
	ВремяВыполненияМс = ТекущаяУниверсальнаяДатаВМиллисекундах() - ПараметрыВходногоЗапроса.ДатаМс;
	
	ПапкаЛогов = ПолучитьПапкуЛоговЛК();
	ИмяКаталога = ПапкаЛогов + "personalprofile\" + Формат(ТекДата, "ДФ=ггггММдд"); 
	
	Попытка 
		КаталогЛогов = Новый Файл(ИмяКаталога);
		Если Не КаталогЛогов.Существует() Тогда
			СоздатьКаталог(ИмяКаталога);
		КонецЕсли;   
		
		ИмяЛога = "log" + "_" + Формат(ТекДата, "ДФ=ггггММдд") + "_" + Формат(ТекДата, "ДФ=ЧЧммсс") + "_" + 
			ПараметрыВходногоЗапроса.ТипЗапроса + "_" +
			Формат(ВремяВыполненияМс, "ЧГ=") + "mc" +
			?(Ошибка, "_error", "") + ".txt";   
		
		ФайлЛогов = Новый ЗаписьТекста(ИмяКаталога + "\" + ИмяЛога, КодировкаТекста.UTF8, , Истина);
		
		ТекстЛогов = ПараметрыВходногоЗапроса.ДатаЗапроса + Символы.ПС + 
			ПараметрыВходногоЗапроса.Запрос + Символы.ПС + 
			?(ЗначениеЗаполнено(ПараметрыВходногоЗапроса.Тело), "Тело:" + Символы.ПС + ПараметрыВходногоЗапроса.Тело + Символы.ПС, "") +
			Формат(ТекущаяДатаСеанса(), "ДФ=дд.ММ.гггг ЧЧ:мм:сс") + Символы.ПС +
			СтрокаJSON + Символы.ПС;
		
		ФайлЛогов.ЗаписатьСтроку(ТекстЛогов);
		ФайлЛогов.Закрыть();

	Исключение
		ФайлЛогов = Неопределено;
	КонецПопытки;    

КонецПроцедуры

Функция ПолучитьПараметрыHTTPЗапроса(Запрос) Экспорт          

	Параметры = Новый Структура;
	Параметры.Вставить("ТипЗапроса", Сред(Запрос.ОтносительныйURL, 2)); 
	Параметры.Вставить("БазовыйURL", Запрос.БазовыйURL); 
	Параметры.Вставить("Запрос", ПолучитьHTTPЗапрос(Запрос.БазовыйURL, Запрос.ОтносительныйURL, Запрос.ПараметрыЗапроса)); 
	Параметры.Вставить("Тело", Запрос.ПолучитьТелоКакСтроку());
	Параметры.Вставить("ДатаЗапроса", Формат(ТекущаяДатаСеанса(), "ДФ=дд.ММ.гггг ЧЧ:мм:сс"));
	Параметры.Вставить("ДатаМс", ТекущаяУниверсальнаяДатаВМиллисекундах());
	Возврат Параметры;
	
КонецФункции  

Функция ПолучитьHTTPЗапрос(БазовыйURL, ОтносительныйURL, ПараметрыЗапроса)
	
	Запрос = БазовыйURL + ОтносительныйURL;
	
	СписокПараметров = "";
	Для Каждого ПараметрЗапроса Из ПараметрыЗапроса Цикл
		Если СписокПараметров = "" Тогда 
			СписокПараметров = "?"
		Иначе                   
			СписокПараметров = СписокПараметров + "&";
		КонецЕсли;
		
		СписокПараметров = СписокПараметров + ПараметрЗапроса.Ключ + "=" + СтрЗаменить(ПараметрЗапроса.Значение, " ", "%20");
	КонецЦикла;

	Запрос = Запрос + СписокПараметров;
	Возврат Запрос   
	
