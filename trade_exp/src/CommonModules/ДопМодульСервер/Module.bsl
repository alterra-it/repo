Процедура СамообслуживаниеЗаписьПередЗаписью(Источник, Отказ, РежимЗаписи, РежимПроведения) Экспорт
	
	ПроверитьЗавершениеПродажи(Источник, Отказ, "Изменение");

КонецПроцедуры

Процедура СамообслуживаниеУдалениеПередУдалением(Источник, Отказ) Экспорт
	
	ПроверитьЗавершениеПродажи(Источник, Отказ, "Удаление");	
	
КонецПроцедуры    

Процедура ПроверитьЗавершениеПродажи(Источник, Отказ, Действие)
	
	Если Источник.ОбменДанными.Загрузка Или Не ЗначениеЗаполнено(Источник.Ссылка) 
		Или Источник.ДополнительныеСвойства.Свойство("ЗавершениеПродажи") Тогда
			Возврат;
	КонецЕсли;   
	
	Если ЗапретДействийДоЗавершенияПродажи(Источник.Ссылка) Тогда     
		Сообщить(Действие + " невозможно, не завершена продажа на КСО");
		Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры	

Функция ЗапретДействийДоЗавершенияПродажи(ДокументПродажи)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	&Ссылка	
		|ИЗ
		|	Документ.ЧекСамообслуживания       
		|ГДЕ 
		|	Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
		|	И %Документ
		|	И ТипПродажи В (11, 21, 31)
		|	И ОшибкаЗаписиДокумента <> &ПустаяСтрока";     
	
	ПроверяемыйДокумент = "Ложь";	
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекККМ") Тогда
		ПроверяемыйДокумент = "ЧекККМ = &Ссылка";
	ИначеЕсли ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ПроверяемыйДокумент = "Реализация = &Ссылка";               
	ИначеЕсли ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		ПроверяемыйДокумент = "ЗаказКлиента = &Ссылка И Не ЗаказСРеализацией";               
	КонецЕсли;
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%Документ", ПроверяемыйДокумент);
	Запрос.УстановитьПараметр("Ссылка", ДокументПродажи);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");   
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции	

