#Область Товары

Процедура КонтрольОстатковПоПересчетам(Ссылка, Отказ) Экспорт 
	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ
|	ПересортицаТоваровТовары.Номенклатура КАК Номенклатура,
|	ПересортицаТоваровТовары.Характеристика КАК Характеристика,
|	ПересортицаТоваровТовары.Номенклатура.ЕдиницаИзмерения КАК НоменклатураЕдиницаИзмерения,
|	ПересортицаТоваровТовары.Ссылка.Склад КАК Склад
|ПОМЕСТИТЬ ВТ_Номенклатура
|ИЗ
|	Документ.ПересортицаТоваров.Товары КАК ПересортицаТоваровТовары
|ГДЕ
|	ПересортицаТоваровТовары.Ссылка = &Ссылка
|
|ОБЪЕДИНИТЬ ВСЕ
|
|ВЫБРАТЬ
|	ПорчаТоваровТовары.Номенклатура,
|	ПорчаТоваровТовары.Характеристика,
|	ПорчаТоваровТовары.Номенклатура.ЕдиницаИзмерения,
|	ПорчаТоваровТовары.Ссылка.Склад
|ИЗ
|	Документ.ПорчаТоваров.Товары КАК ПорчаТоваровТовары
|ГДЕ
|	ПорчаТоваровТовары.Ссылка = &Ссылка
|
|ОБЪЕДИНИТЬ ВСЕ
|
|ВЫБРАТЬ
|	СписаниеНедостачТоваровТовары.Номенклатура,
|	СписаниеНедостачТоваровТовары.Характеристика,
|	СписаниеНедостачТоваровТовары.Номенклатура.ЕдиницаИзмерения,
|	СписаниеНедостачТоваровТовары.Ссылка.Склад
|ИЗ
|	Документ.СписаниеНедостачТоваров.Товары КАК СписаниеНедостачТоваровТовары
|ГДЕ
|	СписаниеНедостачТоваровТовары.Ссылка = &Ссылка
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ
|	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
|	ВТ_Номенклатура.Характеристика КАК Характеристика, 
|	ВТ_Номенклатура.НоменклатураЕдиницаИзмерения КАК НоменклатураЕдиницаИзмерения, 
|	ВТ_Номенклатура.Склад КАК Склад,
|	Сумма(ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток) КАК ВНаличииОстаток
|ПОМЕСТИТЬ ВТ_Остатки
|ИЗ
|	ВТ_Номенклатура КАК ВТ_Номенклатура
|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыИПотребности.Остатки(&Дата) КАК ЗапасыИПотребностиОстатки
|		ПО ВТ_Номенклатура.Номенклатура = ЗапасыИПотребностиОстатки.Номенклатура
|			И ВТ_Номенклатура.Характеристика = ЗапасыИПотребностиОстатки.Характеристика
|			И ВТ_Номенклатура.Склад = ЗапасыИПотребностиОстатки.Склад
|
|СГРУППИРОВАТЬ ПО
|	ВТ_Номенклатура.Номенклатура,
|	ВТ_Номенклатура.Характеристика, 
|	ВТ_Номенклатура.НоменклатураЕдиницаИзмерения,
|	ВТ_Номенклатура.Склад
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ
|	ВТ_Остатки.Номенклатура КАК Номенклатура,
|	ВТ_Остатки.Характеристика КАК Характеристика, 
|	ВТ_Остатки.НоменклатураЕдиницаИзмерения КАК ЕдиницаИзмерения,
|	ВТ_Остатки.Склад КАК Склад, 
|	ВТ_Остатки.ВНаличииОстаток КАК Количество
|ИЗ
|	ВТ_Остатки КАК ВТ_Остатки
|ГДЕ
|	ВТ_Остатки.ВНаличииОстаток < 0"; 
		
	Запрос.УстановитьПараметр("Дата", Ссылка.Дата+1);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
		
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ШаблонСообщения = НСтр("ru = 'Номенклатура %НоменклатураХарактеристика% 
		|Превышен остаток товара на складе %Склад% на %Количество% %Единица%'");
		
		ТекстСообщения = СтрЗаменить(ШаблонСообщения, "%НоменклатураХарактеристика%",
		НоменклатураКлиентСервер.ПредставлениеНоменклатуры(Выборка.Номенклатура, Выборка.Характеристика));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Количество%", Строка(-Выборка.Количество));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Склад%",      Строка(Выборка.Склад));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Единица%",    Строка(Выборка.ЕдиницаИзмерения));
		                                                               	
	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,, ,, Отказ);
		ТекстСообщения = НСтр("ru = 'Проведение не выполнено '");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения + Строка(Ссылка));
	КонецЦикла;
КонецПроцедуры

Процедура ПроверитьНаличиеРасходногоОрдераНаТовары(ДокСсылка, Отказ) Экспорт   

	Если Не Отказ Тогда
		Ордер = ПолучитьРасходныйОрдерНаТоварыПоОснованию(ДокСсылка);
		Если ЗначениеЗаполнено(Ордер) Тогда 
			ОбщегоНазначения.СообщитьПользователю("Документ '" + ДокСсылка + "' является основанием для '" + Ордер + "'! Удаление невозможно!", Ордер);
			Отказ = Истина;
		КонецЕсли;	
	КонецЕсли;   
	
КонецПроцедуры

Функция ПолучитьРасходныйОрдерНаТоварыПоОснованию(ДокСсылка) Экспорт   

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
		|ГДЕ
		|	РасходныйОрдерНаТовары.Накладная В
		|			(ВЫБРАТЬ
		|				Док.Ссылка КАК Ссылка
		|			ИЗ
		|				Документ." + ДокСсылка.Метаданные().Имя + " КАК Док
		|			ГДЕ
		|				Док.Ссылка = &Ссылка)";
	
	Запрос.УстановитьПараметр("Ссылка", ДокСсылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда 
		Возврат РезультатЗапроса.Ссылка;
	КонецЕсли;	                        
	
	Возврат Неопределено;
	
КонецФункции
	
Процедура УдалитьИзДокументаКомиссионныйТовар(Объект,ТаблицаКомиссии,СтруктураДействий)экспорт
	УстановитьПривилегированныйРежим(Истина);

	СтруктураДействийИзмененныеСтроки = Новый Структура;
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруПересчетаСуммыНДСВСтрокеТЧ(Объект);
	СтруктураДействийИзмененныеСтроки.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	СтруктураДействийИзмененныеСтроки.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьКоличествоУпаковок");
	СтруктураДействийИзмененныеСтроки.Вставить("ЗаполнитьСтавкуНДС", Объект.НалогообложениеНДС);
	СтруктураДействийИзмененныеСтроки.Вставить("ЗаполнитьСтавкуНДСВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействийИзмененныеСтроки.Вставить("ЗаполнитьПризнакБезВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьСумму");
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Истина));
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
	СтруктураДействийИзмененныеСтроки.Вставить("ОчиститьСуммуВзаиморасчетов");
	СтруктураДействийИзмененныеСтроки.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", Новый Структура(
	"БезВозвратнойТары",
	"Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки")
);
	СтруктураДействийИзмененныеСтроки.Вставить("ПересчитатьСуммуСверхЗаказа", Новый Структура("РеализацияПоступлениеПоЗаказу, ТребуетсяЗалогЗаТару",
	Объект.РеализацияПоЗаказам, Объект.ТребуетсяЗалогЗаТару));
	ИменаКолонок="Номенклатура,Характеристика,Склад";
	МассивКолонок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИменаКолонок, ",");
	МассивУдаляемыхСтрок = Новый Массив();

	Для Каждого СтрокаТоваров Из ТаблицаКомиссии Цикл
		СтруктураПоиска = Новый Структура(ИменаКолонок);
		СтруктураПоиска[МассивКолонок[0]] = СтрокаТоваров.Номенклатура;
		СтруктураПоиска[МассивКолонок[1]] = СтрокаТоваров.Характеристика;
		СтруктураПоиска[МассивКолонок[2]] = СтрокаТоваров.Склад;
		ИспользованиеХарактеристик = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТоваров.Номенклатура, "ИспользованиеХарактеристик");
		ХарактеристикаНеУказана    = ИспользованиеХарактеристик <> Перечисления.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать
			И НЕ ЗначениеЗаполнено(СтрокаТоваров.Характеристика);
			
		Если ХарактеристикаНеУказана Тогда
			
			СтруктураПоиска.Удалить(МассивКолонок[1]);
			
		КонецЕсли;
		МассивСтрокТЧТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		
		Если МассивСтрокТЧТовары.Количество() > 0 Тогда
			
			СтрокаТЧТовары = МассивСтрокТЧТовары[0];
			
			Если СтрокаТЧТовары.Количество > СтрокаТоваров.Количество Тогда
				
				СтрокаТЧТовары.Количество=СтрокаТЧТовары.Количество-СтрокаТоваров.Количество;	
				СтрокаТЧТовары[МассивКолонок[2]] = СтрокаТоваров.Склад;
					
				КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
				ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТЧТовары, СтруктураДействийИзмененныеСтроки, КэшированныеЗначения);
			иначеесли СтрокаТЧТовары.Количество = СтрокаТоваров.Количество тогда
			МассивУдаляемыхСтрок.Добавить(СтрокаТЧТовары);
	
			КонецЕсли;
		КонецЕсли;
	
	 конеццикла;
	Для Каждого ТекЭлемент Из МассивУдаляемыхСтрок Цикл
		Объект.Товары.Удалить(ТекЭлемент);
	КонецЦикла;
	СтруктураДействий=СтруктураДействийИзмененныеСтроки;
УстановитьПривилегированныйРежим(ложь);

КонецПроцедуры

Функция СоздатьДокументКомиссионногоТовара(ДокКомиссииФорма,Объект,ТаблицаКомиссии,СтруктураДействийИзмененныеСтроки,СкладГруппа)экспорт

	ДокКомиссии = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
	заполнитьЗначенияСвойств(ДокКомиссии, Объект, , "Номер, Дата");
	ДокКомиссии.Дата = ТекущаяДата();
	ДокКомиссии.ДатаПлатежа = ТекущаяДата();

	ДокКомиссии.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС;

	ДокКомиссии.СкидкиРассчитаны = Ложь;

	ЗначениеВДанныеФормы(ДокКомиссии,ДокКомиссииФорма);

	СтруктураДействийДобавленныеСтроки =  ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(СтруктураДействийИзмененныеСтроки);;
	СтруктураДействийДобавленныеСтроки.Вставить("ПроверитьЗаполнитьСклад", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСкладаВСтрокеТЧ(Объект, СкладГруппа));
	Если ЗначениеЗаполнено(Объект.Соглашение) Тогда
		СтруктураДействийДобавленныеСтроки.Вставить("ЗаполнитьУсловияПродаж", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияУсловийПродажВСтрокеТЧ(Объект));
	Иначе
		СтруктураДействийДобавленныеСтроки.Вставить("ЗаполнитьЦенуПродажи", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияЦеныВСтрокеТЧ(Объект));
	КонецЕсли;
	СтруктураДействийДобавленныеСтроки.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));

	Для Каждого СтрокаТоваров Из ТаблицаКомиссии Цикл
		
		СтрокаТЧТовары = ДокКомиссииФорма.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧТовары, СтрокаТоваров);
		КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТЧТовары, СтруктураДействийДобавленныеСтроки, КэшированныеЗначения);
	конеццикла;
	
	возврат ДокКомиссииФорма; 
	
КонецФункции

Процедура ОбновитьКоличествоДнейПросрочки(Договор,Дата,Текст, ВидимостьТекста, ЦветТекста) экспорт
	УстановитьПривилегированныйРежим(Истина);
	
	если не значениезаполнено(Договор) тогда
		возврат;
	конецесли;	

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	РасчетыСКлиентамиПоДокументамОстатки.ДолгОстаток КАК Долг,
	|	МАКСИМУМ(РасчетыСКлиентамиПоДокументамОстатки.РасчетныйДокумент.Дата) КАК РасчетныйДокументДата
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентамиПоСрокам.Остатки(&Дата, АналитикаУчетаПоПартнерам.Договор = &Договор) КАК РасчетыСКлиентамиПоДокументамОстатки
	|ГДЕ
	|	РасчетыСКлиентамиПоДокументамОстатки.ДолгОстаток > 0
	|//#УсловиеНаДокумент
	|
	|СГРУППИРОВАТЬ ПО
	|	РасчетыСКлиентамиПоДокументамОстатки.ДолгОстаток,
	|	РасчетыСКлиентамиПоДокументамОстатки.ПредоплатаОстаток
	|
	|УПОРЯДОЧИТЬ ПО
	|	РасчетныйДокументДата";	
	
	Запрос.УстановитьПараметр("Дата",Дата);
	Запрос.УстановитьПараметр("Договор",Договор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		ДатаЗадолженности= ВыборкаДетальныеЗаписи.РасчетныйДокументДата;
	иначе
		возврат;
	Конецесли;
	ДнейЗадолженности=окр((дата-ДатаЗадолженности)/60/60/24);
	если ДнейЗадолженности>0 тогда
		ДнейНаФорму=ДнейЗадолженности-Договор.КоличествоДнейПросрочки;
		Текст = НСтр("ru='Просроченная задолженность'");
		Текст=Текст+" "+ДнейНаФорму+" дн.";
		ВидимостьТекста = Истина;
		если Договор.КоличествоДнейПросрочки<= ДнейЗадолженности тогда
			ЦветТекста = WebЦвета.Кирпичный;
		иначе
			ЦветТекста = ЦветаСтиля.ЦветГиперссылки;
		конецесли;	
	конецесли;

	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

Процедура ЗапретИзмененияДокументовАльтерраПередЗаписью(Источник, Отказ) Экспорт
	
	//Список исключений из блокировки  
	Если РольДоступна("Кассир") Тогда
		НачалоДняТекДата = НачалоДня(ТекущаяДатаСеанса());
		Если ТипЗнч(Источник) = Тип("ДокументОбъект.ОтчетБанкаПоОперациямЭквайринга") Тогда
			Если НачалоДня(Источник.Дата) < НачалоДняТекДата-24*60*60 Тогда 
				Сообщить("Запрещено изменять документ с датой отличной от текущей более чем на один день!");
				Отказ = Истина;	
			КонецЕсли;	
		ИначеЕсли ТипЗнч(Источник) <> Тип("ДокументОбъект.РеализацияТоваровУслуг") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ВозвратТоваровОтКлиента")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ЛистКассовойКниги")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ЛистСогласования")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ЗаказКлиента") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.КорректировкаРеализации") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ПеремещениеТоваров") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ЧекККМ") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.КассоваяСмена")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураВыданный")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураВыданныйАванс")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураКомиссионеру")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураКомитента")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураНалоговыйАгент")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураНаНеподтвержденнуюРеализацию0")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураПолученный")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураПолученныйАванс")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.СчетФактураПолученныйНалоговыйАгент")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ЗаявкаВЕГАИСЛес") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ОперацияПоПлатежнойКарте")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ОперацияПоПлатежнойКарте") 
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ТабельУчетаРабочегоВремени")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.КорзинаСамообслуживания")
			И ТипЗнч(Источник) <> Тип("ДокументОбъект.ЧекСамообслуживания")
			И (НачалоДня(Источник.Дата) <> НачалоДняТекДата 
			Или НачалоДня(Источник.Ссылка.Дата) <> НачалоДняТекДата) 
			Тогда 
				Если Источник.ЭтоНовый() И НачалоДня(Источник.Дата) = НачалоДняТекДата 
					Или ОРПнаКСО(Источник) Тогда
						Возврат
				Иначе			
					Сообщить("Запрещено изменять документ датой отличной от текущей!");
					Отказ = Истина;	
				КонецЕсли;	
			
		ИначеЕсли (ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") 
			ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.ВозвратТоваровОтКлиента")
			ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.ЛистСогласования")
			ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказКлиента") 
			ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.КорректировкаРеализации") 
			ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.ПеремещениеТоваров") 
			ИЛИ ТипЗнч(Источник) = Тип("ДокументОбъект.ЧекККМ"))
		Тогда
			Если Источник.ЭтоНовый() И НачалоДня(Источник.Дата) <> НачалоДняТекДата Тогда
				Сообщить("Запрещено изменять документ датой отличной от текущей!");
				Отказ = Истина;
			ИначеЕсли НачалоДня(Источник.Дата) <> НачалоДняТекДата И НачалоДня(Источник.Ссылка.Дата) = НачалоДняТекДата Тогда
				Сообщить("Запрещено изменять документ датой отличной от текущей!");
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры     

Функция ОРПнаКСО(Источник)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ТипЗнч(Источник) <> Тип("ДокументОбъект.ОтчетОРозничныхПродажах") 					
		И ТипЗнч(Источник) <> Тип("ДокументОбъект.ОтчетОРозничныхВозвратах") Тогда
			Возврат Ложь;
	КонецЕсли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ИСТИНА КАК ОРПнаКСО
		|ИЗ           
		|	Документ.ОтчетОРозничныхПродажах ОРП
		|	СОЕДИНЕНИЕ Справочник.КассыККМ Кассы
		|		ПО ОРП.КассаККМ = Кассы.Ссылка 
		|ГДЕ 
		|	ОРП.Ссылка = &Ссылка 
		|	И Кассы.Наименование ПОДОБНО &КСО 
		|	
		|ОБЪЕДИНИТЬ ВСЕ   
		|
		|ВЫБРАТЬ
		|	ИСТИНА КАК ОРПнаКСО
		|ИЗ           
		|	Документ.ОтчетОРозничныхВозвратах ОРП
		|	СОЕДИНЕНИЕ Справочник.КассыККМ Кассы
		|		ПО ОРП.КассаККМ = Кассы.Ссылка 
		|ГДЕ 
		|	ОРП.Ссылка = &Ссылка 
		|	И Кассы.Наименование ПОДОБНО &КСО";
	
	Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);
	Запрос.УстановитьПараметр("КСО", "%КСО%");
	Выборка = Запрос.Выполнить().Выбрать();
	
	ОРПнаКСО = Ложь;
	Если Выборка.Следующий() И Выборка.ОРПнаКСО Тогда
		ОРПнаКСО = Истина;	
	КонецЕсли;
	
	Возврат ОРПнаКСО;
	
КонецФункции	                     

Процедура ПроверитьНумерациюТренажера() экспорт
	если не Константы.ЭтоБазаТренажер.Получить() и найти(СтрокаСоединенияИнформационнойБазы(),"training_trade")>0 тогда
		ОбновитьНумерациюОбъектов();
		Константы.ЭтоБазаТренажер.Установить(истина);
	конецесли;	
КонецПроцедуры

Функция ЭтоКассовыйДокументПоЛистуСогласования(Ссылка)Экспорт
	
	ТипДокумента = ТипЗнч(Ссылка);
	
	Если ТипДокумента = Тип("ДокументСсылка.ВозвратТоваровОтКлиента")ИЛИ	
		 ТипДокумента =  Тип("ДокументСсылка.ЗаказКлиента")ИЛИ
		 ТипДокумента =  Тип("ДокументСсылка.КорректировкаРеализации")ИЛИ
		 ТипДокумента =  Тип("ДокументСсылка.РеализацияТоваровУслуг")Тогда 
	   Возврат Истина;
   Иначе
	   Возврат Ложь;
   Конецесли; 
КонецФункции

#КонецОбласти     

#Область ВыгрузкаОтдельныхЗаказовНаСайт 

Функция ВыгрузитьЗаказыНаСайт(УзелОбмена, ТаблицаЗаказов) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если НЕ ЗначениеЗаполнено(УзелОбмена) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЭквайринговыйТерминал = Документы.ОперацияПоПлатежнойКарте.ПолучитьТерминалССайтаПоУмолчанию();
	Для Каждого Стр Из ТаблицаЗаказов Цикл 
		ЭквайринговаяОперация = Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(Стр.Объект, ЭквайринговыйТерминал);
		Если ЭквайринговаяОперация <> Неопределено Тогда
			ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, ЭквайринговаяОперация);
		КонецЕсли;
		ПланыОбмена.УдалитьРегистрациюИзменений(УзелОбмена, Стр.Объект);  
	КонецЦикла;
	
	ОсновныеПараметры = Новый Структура; 
	ОсновныеПараметры.Вставить("ВыгрузкаОтдельныхДокументов", Истина);	
	
	НастройкиУспешноДобавлены = Б_ОбменССайтомСервер.ДобавитьОсновныеНастройкиВПараметры(УзелОбмена, ОсновныеПараметры);			
	Если НастройкиУспешноДобавлены <> Истина Тогда
		Возврат Ложь;
	КонецЕсли;  
	
	Б_ОбменССайтомСервер.СообщитьПодробно("______________________________________________________________________", ОсновныеПараметры, Истина);
	Б_ОбменССайтомСервер.СообщитьПодробно("Начало выгрузки документов (" + Строка(УзелОбмена) + ")", ОсновныеПараметры, Истина);	
	
	НастройкиУспешноДобавлены = ДобавитьНастройкиВПараметры(УзелОбмена, ОсновныеПараметры);	
	Если НЕ НастройкиУспешноДобавлены Тогда
		Возврат Ложь;
	КонецЕсли;
		
	КаталогВыгрузки = "";
	
	Если НЕ ОсновныеПараметры.ВыгружатьНаСайт Тогда
		КаталогВыгрузки = ОсновныеПараметры.КаталогВыгрузки;
	КонецЕсли;
	
	Если ПустаяСтрока(КаталогВыгрузки) Тогда	
		КаталогВыгрузки = КаталогВременныхФайлов() + Строка(Новый УникальныйИдентификатор) + "\";
	Иначе
		КаталогВыгрузки = ОсновныеПараметры.КаталогВыгрузки;
		ПоследнийСимвол = Прав(КаталогВыгрузки, 1);
		Если НЕ ПоследнийСимвол = "\" Тогда
			КаталогВыгрузки = КаталогВыгрузки + "\";
		КонецЕсли;
	КонецЕсли;
	
	ПодкаталогБезопасностиКаталогаВыгрузки = "webdata\";
	КаталогНаДиске = КаталогВыгрузки + ПодкаталогБезопасностиКаталогаВыгрузки + СокрЛП(ОсновныеПараметры.Ссылка.Код);
	КаталогНаДиске = Б_ОбщиеПроцедурыИФункцииСервер.ПолучитьПутьДляПлатформы(ОсновныеПараметры.ПлатформаWindows, КаталогНаДиске);
	
	Попытка
		СоздатьКаталог(КаталогНаДиске);
	Исключение 
		Б_ОбменССайтомСервер.СообщитьПодробно(ОписаниеОшибки(), ОсновныеПараметры, Истина);
		Возврат Ложь;
	КонецПопытки;
	
	Если НЕ Б_ОбщиеПроцедурыИФункцииСервер.КаталогОчищен(КаталогНаДиске, ОсновныеПараметры) Тогда 
		Б_ОбменССайтомСервер.СообщитьПодробно("Не удалось очистить каталог: " + КаталогНаДиске + ". Продолжение выгрузки невозможно.", ОсновныеПараметры, Истина);
		Возврат Ложь;
	КонецЕсли;
	
	ОсновныеПараметры.Вставить("КаталогНаДиске"	, КаталогНаДиске);
	
	Б_ОбменССайтомСерверВыгрузкаДанных._ВыгрузитьДокументы(ОсновныеПараметры, ТаблицаЗаказов);
				
	УдалитьФайлы(ОсновныеПараметры.ФайлСхемы);	
	
	Б_ОбменССайтомСервер.СообщитьПодробно("Завершение выгрузки (" + Строка(УзелОбмена) + ")", ОсновныеПараметры, Истина);	
	Б_ОбменССайтомСервер.СообщитьПодробно("______________________________________________________________________
										 | ", ОсновныеПараметры, Истина);	
		
	Если ОсновныеПараметры.ОбменВыполненБезОшибок Тогда 
		Возврат Истина; 
	Иначе
		Возврат Ложь;	
	КонецЕсли; 
	
КонецФункции

Функция ДобавитьНастройкиВПараметры(НастройкаУзлаОбмена, ОсновныеПараметры) Экспорт 	
		
	ОсновныеПараметры.Вставить("ВыгрузкаОтгрузок", Истина);
	ОсновныеПараметры.Вставить("ВыгрузкаОплат", Истина);
	ОсновныеПараметры.Вставить("ВыгружаемыеОплатыПоОтборам", Неопределено);
	ОсновныеПараметры.Вставить("ВыгружаемыеОтгрузкиПоОтборам", Неопределено);
	ОсновныеПараметры.Вставить("НаименованиеНалога", "НДС");
	ОсновныеПараметры.Вставить("ВыгружатьКартинкиИФайлы", Ложь);

	СтрСохраненныхНастроек = ОсновныеПараметры.СохраненныеНастройки.Получить();		
	Если СтрСохраненныхНастроек = Неопределено Тогда
		Б_ОбменССайтомСервер.СообщитьПодробно("Ошибка в данных настройки. Пересоздайте настройку обмена.", ОсновныеПараметры, Истина);
		Возврат Ложь;
	КонецЕсли;
	
	Попытка		
	    Б_ОбменССайтомСервер._ДобавитьСтруктурыНастроекВПараметры(ОсновныеПараметры, СтрСохраненныхНастроек.Заказы);
	Исключение
		Б_ОбменССайтомСервер.СообщитьПодробно("Ошибка в данных настройки. Пересоздайте настройку обмена.", ОсновныеПараметры, Истина);
		Возврат Ложь;
	КонецПопытки;
	
	//соответствия касс конвертируем в одну таблицу.
	Массив = Новый Массив;
	Массив.Добавить(Тип("Строка"));
	ОписаниеТиповС = Новый ОписаниеТипов(Массив);

	Массив = Новый Массив;
	Массив.Добавить(Тип("СправочникСсылка.ЭквайринговыеТерминалы"));
	ОписаниеТиповЭТ = Новый ОписаниеТипов(Массив);

	Массив = Новый Массив;
	Массив.Добавить(Тип("СправочникСсылка.Кассы"));
	ОписаниеТиповК = Новый ОписаниеТипов(Массив);

	СоответствиеПлатежныхСистемИКасс = Новый ТаблицаЗначений;
	СоответствиеПлатежныхСистемИКасс.Колонки.Добавить("ИдПлатежнойСистемы"		, ОписаниеТиповС);
	СоответствиеПлатежныхСистемИКасс.Колонки.Добавить("НазваниеПлатежнойСистемы", ОписаниеТиповС);
	СоответствиеПлатежныхСистемИКасс.Колонки.Добавить("Касса"					, ОписаниеТиповК);
	СоответствиеПлатежныхСистемИКасс.Колонки.Добавить("Терминал"				, ОписаниеТиповЭТ);
	
	Если ЗначениеЗаполнено(ОсновныеПараметры.СоответствиеПлатежныхСистемИКасс) Тогда 
		Для Каждого ТекЭлемент из ОсновныеПараметры.СоответствиеПлатежныхСистемИКасс Цикл	
			Для Каждого ТекПлатежнаяСистема из ТекЭлемент.ПлатежнаяСистема Цикл 
				НоваяСтрока = СоответствиеПлатежныхСистемИКасс.Добавить();
				НоваяСтрока.Касса 						= ТекЭлемент.Касса;
				НоваяСтрока.Терминал 					= ТекЭлемент.Терминал;
				НоваяСтрока.ИдПлатежнойСистемы 			= ТекПлатежнаяСистема.Значение;
				НоваяСтрока.НазваниеПлатежнойСистемы 	= ТекПлатежнаяСистема.Представление;	
			КонецЦикла;			
		КонецЦикла;	
	КонецЕсли;   
	
	ОсновныеПараметры.СоответствиеПлатежныхСистемИКасс = СоответствиеПлатежныхСистемИКасс;
	
	Если ОсновныеПараметры.ВыгружатьНаСайт Тогда	
		НастройкиПодключения = Новый Структура;
		
		Если НЕ Б_ОбменССайтомСервер.ПолучитьНастройкиПодключения(НастройкиПодключения, ОсновныеПараметры) Тогда
			Б_ОбменССайтомСервер.СообщитьПодробно("Не удалось получить настройки подключения к сайту", ОсновныеПараметры, Истина);
			Возврат Ложь;
		КонецЕсли;	
		
		Б_ОбменССайтомСервер._ДобавитьПараметрыПротоколаОбменаВСтруктуру(НастройкиПодключения);  	
		ОсновныеПараметры.Вставить("НастройкиПодключения", НастройкиПодключения);	
	КонецЕсли;	

	Возврат Истина;
	
КонецФункции

