Функция СоздатьКлиентаИзОчереди(Идентификатор) Экспорт   
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ДатаИзменения = ТекущаяДата(); 
	
	ТипыИдентификаторов = ПолучитьТипыИдентификаторов(); 
	ТипыДействий = ПолучитьТипыДействий();
	ТипыКлиентов = ПолучитьТипыКлиентов();  
	СтатусыДействий = ПолучитьСтатусыДействий();
		
	ИдентификаторПартнеры = ТипыИдентификаторов["client"].Код;
	ДействияДобавление = ТипыДействий["create"].Код;    
	СтатусВыполнено = СтатусыДействий["ok"].Код;
	СтатусОшибка = СтатусыДействий["error"].Код;
	
	НачатьТранзакцию();
	
	Попытка        
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ОчередьЛичныйКабинет");
		ЭлементБлокировкиДанных.УстановитьЗначение("ТипИдентификатора", ИдентификаторПартнеры);
		ЭлементБлокировкиДанных.УстановитьЗначение("ТипДействия", ДействияДобавление);
		ЭлементБлокировкиДанных.УстановитьЗначение("Идентификатор", Идентификатор);
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Разделяемый;
		БлокировкаДанных.Заблокировать();	
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ   
			|	Статус, ТипКлиента, ДатаЗавершения, Наименование, ДатаРождения, АдресЭП, НомерТелефона, ИНН, БизнесРегион, АктивироватьБонуснуюПрограмму
			|ИЗ
			|	РегистрСведений.ОчередьЛичныйКабинет 
	    	|ГДЕ      
			|   ТипИдентификатора = &ТипИдентификатора
			|	И ТипДействия = &ТипДействия
	    	|	И Идентификатор = &Идентификатор";
		
		Запрос.УстановитьПараметр("ТипИдентификатора", ИдентификаторПартнеры);
		Запрос.УстановитьПараметр("ТипДействия", ДействияДобавление);
		Запрос.УстановитьПараметр("Идентификатор", Идентификатор);
		РезультатЗапроса = Запрос.Выполнить();
		
		Если РезультатЗапроса.Пустой() Тогда     
			ЗафиксироватьТранзакцию();
			Возврат Новый Структура	("Результат, Сообщение", Ложь, "Не удалось найти клиента для добавления по идентификатору " + Идентификатор);
		КонецЕсли;       
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();     
		
		Если Выборка.Статус = СтатусВыполнено Тогда     
			ЗафиксироватьТранзакцию();
			Возврат Новый Структура	("Результат, Сообщение", Ложь, "Клиент " + Выборка.Наименование + " уже добавлен " + Формат(Выборка.ДатаЗавершения, "ДФ=дд.ММ.гггг ЧЧ:мм:сс"));
		КонецЕсли;
		
		// Создание партнера по заданному идентификатору
		Партнер = Справочники.Партнеры.СоздатьЭлемент();  
		СсылкаПартнера = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(Идентификатор));
		Партнер.УстановитьСсылкуНового(СсылкаПартнера);
		
		Партнер.Наименование = Выборка.Наименование;
		Партнер.НаименованиеПолное = Выборка.Наименование; 
		ТипКлиента = ТипыКлиентов[Выборка.ТипКлиента];
		
		Если ТипКлиента.ЧастноеЛицо Или ТипКлиента.Бригадир Тогда
			Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо;	
		ИначеЕсли ТипКлиента.Компания Тогда
			Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания;	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Выборка.ДатаРождения) Тогда 
			Партнер.ДатаРождения = Выборка.ДатаРождения;
		КонецЕсли;
		
		Партнер.Комментарий = "Покупатель добавлен с сайта";
		Партнер.Клиент = Истина;
		Партнер.ДатаРегистрации = ТекущаяДата();  
		
		Если Выборка.АктивироватьБонуснуюПрограмму  Тогда
			Партнер.БонуснаяПрограммаАктивна = Истина;   
			Партнер.ДатаАктивацииБонуснойПрограммы = ТекущаяДата();
			
			Если ТипКлиента.ЧастноеЛицо Тогда
				БонусыАльтерра.ОбновитьСтатусВРегистре(СсылкаПартнера, Справочники.СтатусыПартнеровВПрограммеЛояльности_Альтерра.Умелец);
			ИначеЕсли ТипКлиента.Бригадир Тогда                                                                                
				БонусыАльтерра.ОбновитьСтатусВРегистре(СсылкаПартнера, Справочники.СтатусыПартнеровВПрограммеЛояльности_Альтерра.Бригадир);
			КонецЕсли;            
			
			СегментБонусныеКарты = Справочники.СегментыПартнеров.НайтиПоНаименованию("Бонусные карты"); 
			Если ЗначениеЗаполнено(СегментБонусныеКарты) Тогда
				МенеджерЗаписи = РегистрыСведений.ПартнерыСегмента.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Сегмент = СегментБонусныеКарты;
				МенеджерЗаписи.Партнер = СсылкаПартнера;
				МенеджерЗаписи.Записать();		
			КонецЕсли; 
		КонецЕсли;      
		
		//Партнер.ВариантОтправкиЭлектронногоЧека = ПредопределенноеЗначение("Перечисление.ВариантыОтправкиЭлектронногоЧекаПокупателю.ОтправитьEmail");
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(
			Партнер, Выборка.НомерТелефона, Справочники.ВидыКонтактнойИнформации.ТелефонПартнера,, Истина);
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(
			Партнер, Выборка.АдресЭП, Справочники.ВидыКонтактнойИнформации.EmailПартнера,, Истина);		
		
		ГруппаДоступа = Партнер.ДополнительныеРеквизиты.Добавить();
		ГруппаДоступа.Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров");     
		Если ТипКлиента.ЧастноеЛицо Тогда
			ГруппаДоступа.Значение = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Частные лица");
		ИначеЕсли ТипКлиента.Компания Тогда
			ГруппаДоступа.Значение = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Покупатели (организация/ИП)");
		ИначеЕсли ТипКлиента.Бригадир Тогда
			ГруппаДоступа.Значение = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Бригадиры");
		КонецЕсли; 
		
		Партнер.Записать();
		
		АльтерраОбщегоНазначения.УстановитьДополнительныйРеквизит(СсылкаПартнера, "Согласие на получение информационной рассылки", Истина);		
		
		// Создание контрагента   
		Контрагент = Справочники.Контрагенты.СоздатьЭлемент();
		Контрагент.Партнер = СсылкаПартнера;      
		Контрагент.Наименование = Партнер.Наименование;
		Контрагент.НаименованиеПолное = Партнер.Наименование;
		Контрагент.ИНН = Выборка.ИНН;
		
		Если ТипКлиента.ЧастноеЛицо Или ТипКлиента.Бригадир тогда
			Контрагент.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;	
			Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
		Иначе
			Контрагент.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;	
			Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ЮрЛицо;
		КонецЕсли;       
		
		КонтрагентКонтактТелефон = Контрагент.КонтактнаяИнформация.Добавить();
		КонтрагентКонтактТелефон.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
		КонтрагентКонтактТелефон.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента;
		КонтрагентКонтактТелефон.Представление = Выборка.НомерТелефона;
		КонтрагентКонтактТелефон.НомерТелефона = Выборка.НомерТелефона;
		КонтрагентКонтактТелефон.НомерТелефонаБезКодов = "";
		КонтрагентКонтактТелефон.ЗначенияПолей	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(
			КонтрагентКонтактТелефон.Представление, КонтрагентКонтактТелефон.Вид);
			
		КонтрагентКонтактАдресЭП = Контрагент.КонтактнаяИнформация.Добавить();
		КонтрагентКонтактАдресЭП.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		КонтрагентКонтактАдресЭП.Вид = Справочники.ВидыКонтактнойИнформации.EmailКонтрагента;
		КонтрагентКонтактАдресЭП.Представление = Выборка.АдресЭП;
		КонтрагентКонтактАдресЭП.АдресЭП = Выборка.АдресЭП;
		КонтрагентКонтактАдресЭП.ЗначенияПолей	= УправлениеКонтактнойИнформациейСлужебный.КонтактнаяИнформацияПоПредставлению(
			КонтрагентКонтактАдресЭП.Представление, КонтрагентКонтактАдресЭП.Вид);
		
		Контрагент.Записать();
		
		// Источник первичного интереса
		ЗаписьОбИсточникеПервичногоИнтереса = РегистрыСведений.ИсточникиПервичногоИнтереса.СоздатьМенеджерЗаписи();
		ЗаписьОбИсточникеПервичногоИнтереса.Партнер = Партнер;
		ЗаписьОбИсточникеПервичногоИнтереса.КаналПервичногоИнтереса = ПланыВидовХарактеристик.КаналыРекламныхВоздействий.НайтиПоНаименованию("Интернет-сайт");
		ЗаписьОбИсточникеПервичногоИнтереса.Записать();  
		
		// Обновить очередь
		НаборЗаписей = РегистрыСведений.ОчередьЛичныйКабинет.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипИдентификатора.Установить(ИдентификаторПартнеры); 
		НаборЗаписей.Отбор.ТипДействия.Установить(ДействияДобавление);  		
		НаборЗаписей.Отбор.Идентификатор.Установить(Идентификатор);     
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() > 0 Тогда
			ЗаписьОчереди = НаборЗаписей[0];
			ЗаписьОчереди.ДатаИзменения = ДатаИзменения; 
			ЗаписьОчереди.ДатаЗавершения = ТекущаяДата();
			ЗаписьОчереди.КоличествоПопыток = ЗаписьОчереди.КоличествоПопыток + 1;
			ЗаписьОчереди.Статус = СтатусВыполнено;
			ЗаписьОчереди.ТекстОшибки = "";
			НаборЗаписей.Записать(Истина);
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();         
		
		Если ТипКлиента.Бригадир Или ТипКлиента.Компания Тогда
			ЗапуститьБПРегистрацияКлиента(Новый Структура("Наименование, АдресЭП, НомерТелефона", Выборка.Наименование, Выборка.АдресЭП, Выборка.НомерТелефона));
		КонецЕсли;	
		
		Возврат Новый Структура	("Результат, Сообщение", Истина, "");
		
	Исключение  
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();         
		КонецЕсли;
		
		Попытка
			// Записать неудачную попытку в очередь
			НаборЗаписей = РегистрыСведений.ОчередьЛичныйКабинет.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.ТипИдентификатора.Установить(ИдентификаторПартнеры); 
			НаборЗаписей.Отбор.ТипДействия.Установить(ДействияДобавление);  		
			НаборЗаписей.Отбор.Идентификатор.Установить(Идентификатор);     
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() > 0 Тогда
				ЗаписьОчереди = НаборЗаписей[0];
				ЗаписьОчереди.ДатаИзменения = ДатаИзменения; 
				ЗаписьОчереди.КоличествоПопыток = ЗаписьОчереди.КоличествоПопыток + 1;
				ЗаписьОчереди.Статус = СтатусОшибка;
				ЗаписьОчереди.ТекстОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
				НаборЗаписей.Записать(Истина);
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		Возврат Новый Структура	("Результат, Сообщение", Ложь, "Не удалось добавить " + Выборка.Наименование + " с номером " + Выборка.НомерТелефона + ": " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецФункции      

Функция ПодтвердитьИзменениеКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса, ОсновныеДанные) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ЗапуститьБПИзменениеКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса, ОсновныеДанные);
	
КонецФункции	

Функция ИзменитьКлиентаИзОчереди(ДанныеЗапроса) Экспорт   
	
	УстановитьПривилегированныйРежим(Истина);         
	
	ДатаИзменения = ТекущаяДата(); 
	
	ТипыИдентификаторов = ПолучитьТипыИдентификаторов(); 
	ТипыДействий = ПолучитьТипыДействий();
	ТипыКлиентов = ПолучитьТипыКлиентов();  
	СтатусыДействий = ПолучитьСтатусыДействий();
		
	ИдентификаторПартнеры = ТипыИдентификаторов["client"].Код;
	ДействиеИзменение = ТипыДействий["update"].Код;   
	СтатусВыполнено = СтатусыДействий["ok"].Код;
	СтатусОшибка = СтатусыДействий["error"].Код;
	
	НачатьТранзакцию();
	
	Попытка        
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ОчередьЛичныйКабинет");
		ЭлементБлокировкиДанных.УстановитьЗначение("ТипИдентификатора", ИдентификаторПартнеры);
		ЭлементБлокировкиДанных.УстановитьЗначение("ТипДействия", ДействиеИзменение);
		ЭлементБлокировкиДанных.УстановитьЗначение("Идентификатор", ДанныеЗапроса.УИДКлиента);
		ЭлементБлокировкиДанных.УстановитьЗначение("ДатаСоздания", ДанныеЗапроса.ДатаСоздания);
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Разделяемый;
		БлокировкаДанных.Заблокировать();	    
		
		НаборЗаписей = РегистрыСведений.ОчередьЛичныйКабинет.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.ТипИдентификатора.Установить(ИдентификаторПартнеры); 
		НаборЗаписей.Отбор.ТипДействия.Установить(ДействиеИзменение);  		
		НаборЗаписей.Отбор.Идентификатор.Установить(ДанныеЗапроса.УИДКлиента);  
		НаборЗаписей.Отбор.ДатаСоздания.Установить(ДанныеЗапроса.ДатаСоздания);
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() > 0 Тогда
			ЗаписьОчереди = НаборЗаписей[0];    
			
			// Обновление партнера при подтверждении изменений
			НаименованиеПартнера = "";
			ДатаРождения = Дата(1, 1, 1);
			НомерТелефонаПартнера = "";
			АдресЭППартнера = "";
			ЕстьИзменения = Ложь;
			Если СтатусыДействий[ДанныеЗапроса.Статус].Код = СтатусВыполнено Тогда
				
				Партнер = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор(ДанныеЗапроса.УИДклиента)).ПолучитьОбъект();
				
				НаименованиеПартнера = Партнер.НаименованиеПолное;
				Если ЗначениеЗаполнено(ЗаписьОчереди.Наименование) И Партнер.НаименованиеПолное <> ЗаписьОчереди.Наименование Тогда
					Партнер.НаименованиеПолное = ЗаписьОчереди.Наименование;
					ЕстьИзменения = Истина;
				КонецЕсли;     
				        
				ДатаРождения = Партнер.ДатаРождения;;				        
				Если ЗначениеЗаполнено(ЗаписьОчереди.ДатаРождения) И Партнер.ДатаРождения <> ЗаписьОчереди.ДатаРождения Тогда
					Партнер.ДатаРождения = ЗаписьОчереди.ДатаРождения;
					ЕстьИзменения = Истина;
				КонецЕсли;   				        
				
				НомерТелефонаПартнера = ПолучитьКонтактнуюИнформациюПартнера(Партнер, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонПартнера"), "НомерТелефона");
				Если ЗначениеЗаполнено(ЗаписьОчереди.НомерТелефона) И НомерТелефонаПартнера <> ЗаписьОчереди.НомерТелефона Тогда
					ИзменитьКонтактнуюИнформациюПартнера(Партнер, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонПартнера"), "НомерТелефона", ЗаписьОчереди.НомерТелефона);
					ЕстьИзменения = Истина;
				КонецЕсли;    
				 
				АдресЭППартнера = ПолучитьКонтактнуюИнформациюПартнера(Партнер, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.EmailПартнера"), "АдресЭП");
				Если ЗначениеЗаполнено(ЗаписьОчереди.АдресЭП) И АдресЭППартнера <> ЗаписьОчереди.АдресЭП Тогда
					ИзменитьКонтактнуюИнформациюПартнера(Партнер, ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.EmailПартнера"), "АдресЭП", ЗаписьОчереди.АдресЭП);
					ЕстьИзменения = Истина;     
				КонецЕсли;
				
				Если ЕстьИзменения Тогда
					Партнер.Записать();
				КонецЕсли;
			КонецЕсли;
			
			// Обновить очередь
			ЗаписьОчереди.ДатаИзменения = ДатаИзменения; 
			ЗаписьОчереди.ДатаЗавершения = ТекущаяДата();
			ЗаписьОчереди.КоличествоПопыток = ЗаписьОчереди.КоличествоПопыток + 1;
			ЗаписьОчереди.Статус = ДанныеЗапроса.Статус;
			ЗаписьОчереди.ТекстОшибки = ДанныеЗапроса.ТекстОшибки;
			ЗаписьОчереди.Комментарий = СтрЗаменить(СтрЗаменить(ДанныеЗапроса.Комментарий, "+", " "), Символы.ПС, " ");
			
			// Отправить колбэк и зафиксировать ответ
			Если СтатусыДействий[ДанныеЗапроса.Статус].Код = СтатусВыполнено Тогда
				ДанныеЛога = Новый Структура ("ТипЗапроса, ДатаЗапроса, ДатаМс, Запрос, Тело", 
					"client.update.callback", Формат(ТекущаяДатаСеанса(), "ДФ=дд.ММ.гггг ЧЧ:мм:сс"), ТекущаяУниверсальнаяДатаВМиллисекундах(), "", "");
				
				ПараметрыИзменений = Новый Структура("Колбэк, Идентификатор, АдресЭП, НомерТелефона, Фамилия, Имя, Отчество, ДатаРождения");
				ЗаполнитьЗначенияСвойств(ПараметрыИзменений, ЗаписьОчереди);
				Если Не ЗначениеЗаполнено(ПараметрыИзменений.Фамилия) И Не ЗначениеЗаполнено(ПараметрыИзменений.Имя) 
					И Не ЗначениеЗаполнено(ПараметрыИзменений.Отчество) И ЗначениеЗаполнено(НаименованиеПартнера)Тогда
						ФИО = СтрРазделить(НаименованиеПартнера, " ");
						ПараметрыИзменений.Фамилия 	= ?(ФИО.Количество() > 0, ФИО[0], ""); 
						ПараметрыИзменений.Имя 		= ?(ФИО.Количество() > 1, ФИО[1], "");
						ПараметрыИзменений.Отчество = ?(ФИО.Количество() > 2, ФИО[2], "");
				КонецЕсли;
				Если Не ЗначениеЗаполнено(ПараметрыИзменений.ДатаРождения) Тогда
					ПараметрыИзменений.ДатаРождения = ДатаРождения;	
				КонецЕсли;
				Если Не ЗначениеЗаполнено(ПараметрыИзменений.НомерТелефона) Тогда
					ПараметрыИзменений.НомерТелефона = НомерТелефонаПартнера;	
				КонецЕсли;
				Если Не ЗначениеЗаполнено(ПараметрыИзменений.АдресЭП) Тогда
					ПараметрыИзменений.АдресЭП = АдресЭППартнера;	
				КонецЕсли;
				
				ПодтверждениеИзмененийКлиента = ПолучитьПодтверждениеИзмененийКлиента(ПараметрыИзменений);
				ЗаписьОчереди.РезультатОтправлен = ПодтверждениеИзмененийКлиента.Результат;
				Если ЗначениеЗаполнено(ПодтверждениеИзмененийКлиента.Сообщение) Тогда
					Если ПодтверждениеИзмененийКлиента.Результат Тогда
						ЗаписьОчереди.Комментарий = ЗаписьОчереди.Комментарий + ?(ЗначениеЗаполнено(ЗаписьОчереди.Комментарий), "; ", "") + "callback: " + ПодтверждениеИзмененийКлиента.Сообщение;	
					Иначе
						ЗаписьОчереди.ТекстОшибки = ЗаписьОчереди.ТекстОшибки + ?(ЗначениеЗаполнено(ЗаписьОчереди.ТекстОшибки), "; ", "") + "callback: " + ПодтверждениеИзмененийКлиента.Сообщение;	
					КонецЕсли;
				КонецЕсли;
				
				ДанныеЛога.Запрос = ПодтверждениеИзмененийКлиента.Запрос;
				ДанныеЛога.Тело = ПодтверждениеИзмененийКлиента.Сообщение;
				ЗаписатьЛогЛК(ДанныеЛога, ПодтверждениеИзмененийКлиента.Ответ, Не ПодтверждениеИзмененийКлиента.Результат);
			КонецЕсли;			
			
			НаборЗаписей.Записать(Истина);   
			
			ЗафиксироватьТранзакцию();         
			
		КонецЕсли;			
		
	Исключение  
		
		Если ТранзакцияАктивна() Тогда
			ОтменитьТранзакцию();         
		КонецЕсли;
		
		Попытка
			ТекстСообщений = " ";
			МассивСообщений = ПолучитьСообщенияПользователю(Истина);
			Для Каждого Сообщение Из МассивСообщений Цикл
				ТекстСообщений = ТекстСообщений + Сообщение.Текст + " ";	
			КонецЦикла;			
			
			// Записать неудачную попытку в очередь
			НаборЗаписей = РегистрыСведений.ОчередьЛичныйКабинет.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.ТипИдентификатора.Установить(ИдентификаторПартнеры); 
			НаборЗаписей.Отбор.ТипДействия.Установить(ДействиеИзменение);  		
			НаборЗаписей.Отбор.Идентификатор.Установить(ДанныеЗапроса.УидКлиента);     
			НаборЗаписей.Отбор.ДатаСоздания.Установить(ДанныеЗапроса.ДатаСоздания);     
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() > 0 Тогда
				ЗаписьОчереди = НаборЗаписей[0];
				ЗаписьОчереди.ДатаИзменения = ДатаИзменения; 
				ЗаписьОчереди.КоличествоПопыток = ЗаписьОчереди.КоличествоПопыток + 1;
				ЗаписьОчереди.Статус = СтатусОшибка;
				ЗаписьОчереди.ТекстОшибки = ДанныеЗапроса.ТекстОшибки + " " + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()) + ТекстСообщений;
				НаборЗаписей.Записать(Истина);
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		Возврат Новый Структура	("Результат, Сообщение", Ложь, СтрШаблон("Не удалось изменить клиента с УИД %1 от %2: %3", 
			ДанныеЗапроса.УИДКлиента, ДанныеЗапроса.ДатаСоздания, КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
	КонецПопытки;		
	
КонецФункции	 

Функция ПолучитьКонтактнуюИнформациюПартнера(Партнер, ВидКонтактнойИнформации, ИмяКонтактнойИнформации)     
	
	Контакт = Партнер.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКонтактнойИнформации));
	
	Если Контакт.Количество() > 0 Тогда  
		Возврат Контакт[0][ИмяКонтактнойИнформации];
	КонецЕсли;
	
	Возврат "";
	
КонецФункции	

Процедура ИзменитьКонтактнуюИнформациюПартнера(Партнер, ВидКонтактнойИнформации, ИмяКонтактнойИнформации, ЗначениеКонтактнойИнформации)     
	
	Контакт = Партнер.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКонтактнойИнформации));
	ДобавитьКонтакт = Ложь;   
	
	Если Контакт.Количество() > 0 Тогда  
		Если Контакт[0][ИмяКонтактнойИнформации] <> ЗначениеКонтактнойИнформации Тогда
			Партнер.КонтактнаяИнформация.Удалить(Контакт[0]);
			ДобавитьКонтакт = Истина;
		КонецЕсли       
    Иначе
		ДобавитьКонтакт = Истина;
	КонецЕсли;

	Если ДобавитьКонтакт Тогда
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(Партнер, ЗначениеКонтактнойИнформации, ВидКонтактнойИнформации,, Истина);
		Контакт = Партнер.КонтактнаяИнформация.НайтиСтроки(Новый Структура("Вид", ВидКонтактнойИнформации));	
		Если Контакт[0][ИмяКонтактнойИнформации] <> ЗначениеКонтактнойИнформации Тогда
			Контакт[0][ИмяКонтактнойИнформации] = ЗначениеКонтактнойИнформации;
		КонецЕсли;	
	КонецЕсли; 
	
КонецПроцедуры				

#КонецОбласти

Функция ПолучитьПодтверждениеИзмененийКлиента(ДанныеОтправки)

	РезультатВыполнения = Новый Структура("Результат, Сообщение, Запрос, Ответ", Ложь, "", "", "");

	Попытка
		АдресСервера = ДанныеОтправки.Колбэк;
		АдресСервера = СтрЗаменить(АдресСервера, "https://", "");
		АдресСервера = СтрЗаменить(АдресСервера, "http://", "");
		Url = "";
   
		РазделительАдресUrl = СтрНайти(АдресСервера, "/");
		Если РазделительАдресUrl > 0 Тогда
			Url = Сред(АдресСервера, РазделительАдресUrl);
			АдресСервера = Лев(АдресСервера, РазделительАдресUrl - 1);      
		КонецЕсли;
   
		Соединение = Новый HTTPСоединение(АдресСервера, , , , Новый ИнтернетПрокси(Истина), , Новый ЗащищенноеСоединениеOpenSSL);          
       
		ЗапросСПараметрами = СтрШаблон("%1?user_id=%2&LOGIN=%3&EMAIL=%4&PERSONAL_PHONE=%5&NAME=%6&SECOND_NAME=%7&LAST_NAME=%8&BIRTHDAY=%9",
			Url, ДанныеОтправки.Идентификатор, ДанныеОтправки.АдресЭП, ДанныеОтправки.АдресЭП, ДанныеОтправки.НомерТелефона, 
       		ДанныеОтправки.Имя, ДанныеОтправки.Отчество, ДанныеОтправки.Фамилия, Формат(ДанныеОтправки.ДатаРождения, "ДФ=дд.ММ.гггг"));
       		
       	РезультатВыполнения.Запрос = АдресСервера + ЗапросСПараметрами;
       
		Запрос = Новый HTTPЗапрос(ЗапросСПараметрами);
		Запрос.Заголовки.Вставить("Content-Type", "application/json");
		Запрос.Заголовки.Вставить("Accept", "application/json");      
   
        Ответ = Соединение.ОтправитьДляОбработки(Запрос);       
                   
        Если ТипЗнч(Ответ) = Тип("HTTPОтвет") Тогда         
        	РезультатВыполнения.Ответ = Ответ.ПолучитьТелоКакСтроку(); 
            ОтветСтруктура = АльтерраОбщегоНазначения.ДесериализоватьИзJSON(РезультатВыполнения.Ответ);
            Если ТипЗнч(ОтветСтруктура) = Тип("Структура") Тогда
	            Если ОтветСтруктура.Свойство("error") И Не ОтветСтруктура.error Тогда
	            	РезультатВыполнения.Результат = Истина;
	            КонецЕсли;
	            
	            Если ОтветСтруктура.Свойство("response") И ОтветСтруктура.response.Свойство("description") Тогда
	            	РезультатВыполнения.Сообщение = Строка(ОтветСтруктура.response.description);
	            КонецЕсли;
            Иначе
           		РезультатВыполнения.Сообщение("Ответ не сериализован из JSON");		
            КонецЕсли;
        Иначе
        	РезультатВыполнения.Сообщение("Не получен HTTP-ответ");	
       	КонецЕсли;
	Исключение
   		РезультатВыполнения.Сообщение = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
	КонецПопытки;
	
	Возврат РезультатВыполнения;
               
КонецФункции  

