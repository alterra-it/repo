Функция ЗапуститьБПИзменениеКлиента(ПараметрыВходногоЗапроса, ДанныеЗапроса, ОсновныеДанные) 
	
	УстановитьПривилегированныйРежим(Истина);         
	
	КодЭлементаПроцесса =  Формат(ТекущаяДата(), "ДФ=ггггММддЧЧммсс");    
	
	СтарыйТелефон = ?(ЗначениеЗаполнено(ОсновныеДанные.НомерТелефона), ФорматированныйНомерТелефона(ОсновныеДанные.НомерТелефона), "");
	НовыйТелефон = ?(ЗначениеЗаполнено(ДанныеЗапроса.НомерТелефона), ФорматированныйНомерТелефона(ДанныеЗапроса.НомерТелефона), "");  
	СтарыйАдресЭП = ?(ЗначениеЗаполнено(ОсновныеДанные.АдресЭП), ОсновныеДанные.АдресЭП, "");
	НовыйАдресЭП = ?(ЗначениеЗаполнено(ДанныеЗапроса.АдресЭП), ДанныеЗапроса.АдресЭП, "");
	
	ТекстСообщения = "[B][U]Список изменений:[/U][/B] <br> " + 
		?(ЗначениеЗаполнено(ДанныеЗапроса.Наименование) И ОсновныеДанные.ПартнерНаименование <> ДанныеЗапроса.Наименование, "[I]Наименование c[/I] [B]" + ОсновныеДанные.ПартнерНаименование + "[/B] <br>[I]на[/I] [B]" + ДанныеЗапроса.Наименование + "[/B] <br> ", "") +
		?(ЗначениеЗаполнено(НовыйТелефон) И СтарыйТелефон <> НовыйТелефон, "[I]Номер телефона c[/I] [B]" + СтарыйТелефон + "[/B] <br>[I]на[/I] [B]" + НовыйТелефон + "[/B] <br> ", "") +
		?(ЗначениеЗаполнено(НовыйАдресЭП) И СтарыйАдресЭП <> НовыйАдресЭП, "[I]Электронная почта c[/I] [B]" + СтарыйАдресЭП + "[/B] <br>[I]на[/I] [B]" + НовыйАдресЭП + "[/B] <br> ", "");
		//+
		//?(ДанныеЗапроса.ТипКлиента = ПолучитьТипыКлиентов()["wholesale"].Код И ОсновныеДанные.ИНН <> ДанныеЗапроса.ИНН, "[I]ИНН c[/I] [B]" + ОсновныеДанные.ИНН + "[/B] [I]на[/I] [B]" + ДанныеЗапроса.ИНН + "[/B] <br>", "");
	
	ПоляБП  = Новый Структура();
	ПоляБП.Вставить("NAME", "Изменение клиента на сайте");
	ПоляБП.Вставить("PROPERTY_3925", ТекстСообщения);
	ПоляБП.Вставить("PROPERTY_3928", ПараметрыВходногоЗапроса.БазовыйURL + "/client.approve");
	ПоляБП.Вставить("PROPERTY_3926", ПолучитьТипыДействий()["update"].Код);
	ПоляБП.Вставить("PROPERTY_3927", XMLСтрока(ОсновныеДанные.Партнер));
	ПоляБП.Вставить("PROPERTY_3929", Формат(ДанныеЗапроса.ДатаСоздания, "ДФ=ггггММддЧЧммсс"));
		
    ПараметрыЗапроса = Новый Структура; 
	ПараметрыЗапроса.Вставить("IBLOCK_TYPE_ID","bitrix_processes");
	ПараметрыЗапроса.Вставить("IBLOCK_ID","216");
	ПараметрыЗапроса.Вставить("ELEMENT_CODE", КодЭлементаПроцесса);
	ПараметрыЗапроса.Вставить("FIELDS", ПоляБП);
    
    Возврат АльтерраВзаимодействиеСБитрикс24.ВыполнитьПроизвольныйЗапрос("lists.element.add", ПараметрыЗапроса);
	
КонецФункции

