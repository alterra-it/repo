#Область ФоновыеЗадания

Процедура ОжидатьПоВремени(КоличествоСекунд = 60, НачальноеКоличествоСекунд = 0, ИнтервалОповещения = 1) Экспорт         
	
	Если КоличествоСекунд - НачальноеКоличествоСекунд <= 0 Тогда
		Сообщить(СтрШаблон("%1;%2;%3", КоличествоСекунд, 0, 100));	
		Возврат;
	КонецЕсли;
	
	ДатаОкончания 		= ТекущаяДата() + КоличествоСекунд - НачальноеКоличествоСекунд;           
	ПрошлоСекунд 		= НачальноеКоличествоСекунд;    
	ОсталосьСекунд 		= КоличествоСекунд - ПрошлоСекунд;
	ПроцентВыполнения 	= ПрошлоСекунд * 100 / КоличествоСекунд;	
	
	Сообщить(ПолучитьСообщениеОжиданияПоВремени(ПрошлоСекунд, ОсталосьСекунд, ПроцентВыполнения));	
	
	Пока ТекущаяДата() <= ДатаОкончания Цикл     
		
		ТекДата = ТекущаяДата();
		
		ПрошлоСекундТекущее = КоличествоСекунд - (ДатаОкончания - ТекДата);
		
		Если ПрошлоСекундТекущее - ПрошлоСекунд < ИнтервалОповещения Тогда
			Продолжить;
		КонецЕсли;  
		
		ПрошлоСекунд 		= ПрошлоСекундТекущее; 
		ОсталосьСекунд 		= КоличествоСекунд - ПрошлоСекунд;
		ПроцентВыполнения 	= ПрошлоСекунд * 100 / КоличествоСекунд;
		
		Сообщить(ПолучитьСообщениеОжиданияПоВремени(ПрошлоСекунд, ОсталосьСекунд, ПроцентВыполнения));	
	КонецЦикла;  
	
	Сообщить(ПолучитьСообщениеОжиданияПоВремени(КоличествоСекунд, 0, 100));	
		
КонецПроцедуры 

Функция ПолучитьСообщениеОжиданияПоВремени(ПрошлоСекунд, ОсталосьСекунд, ПроцентВыполнения)  
	
	Возврат СтрШаблон("%1;%2;%3",
		Формат(ПрошлоСекунд, 		"ЧГ=;ЧН=0;ЧДЦ=0"), 
		Формат(ОсталосьСекунд, 		"ЧГ=;ЧН=0;ЧДЦ=0"), 
		Формат(ПроцентВыполнения, 	"ЧГ=;ЧН=0;ЧДЦ=0"))	 
		
КонецФУнкции

#КонецОбласти

#Область Служебные   

Функция ФорматированныйНомерТелефона(Номер) Экспорт
	
	Если СтрДлина(Номер) <> 10 Тогда
		Возврат Номер;
	КонецЕсли;                
	
	Возврат "+7 (" + Лев(Номер, 3) + ") " + Сред(Номер, 4, 3) + "-" + Сред(Номер, 7, 2) + "-" + Прав(Номер, 2); 
		
КонецФункции

Функция ФорматироватьJsonТекст(JsonТекст) Экспорт           
	
	Попытка
		JsonТекстСер = ?(ТипЗнч(JsonТекст) <> Тип("Структура") И ТипЗнч(JsonТекст) <> Тип("Массив"), 
			АльтерраОбщегоНазначения.ДесериализоватьИзJSON(JsonТекст), JsonТекст);  
			
		ЗаписьJSON = Новый ЗаписьJSON;  
		ЗаписьJSON.ПроверятьСтруктуру = Ложь;
		ПараметрыЗаписиJSON = Новый ПараметрыЗаписиJSON( , Символы.Таб);
		ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписиJSON);
		ЗаписатьJSON(ЗаписьJSON, JsonТекстСер);
		ТекстЗапроса = СтрЗаменить(ЗаписьJSON.Закрыть(),"\\","\");
		
		Возврат ТекстЗапроса;
	
	Исключение
		Возврат ?(ТипЗнч(JsonТекст) = Тип("Строка"), JsonТекст, "");
	КонецПопытки;
	
КонецФункции 

Функция СписокРеквизитов(ОбъектДанных) Экспорт
	
	СписокРеквизитовСтрокой = "";
	Для Каждого Реквизит Из ОбъектДанных.Метаданные().Реквизиты Цикл
		СписокРеквизитовСтрокой = СписокРеквизитовСтрокой + Реквизит.Имя + " = " + ОбъектДанных[Реквизит.Имя] + Символы.ПС;
	КонецЦикла;
	
	СписокРеквизитовТЧСтрокой = "";
	Для Каждого ТЧ из ОбъектДанных.Метаданные().ТабличныеЧасти Цикл
		Для Каждого СтрокаТЧ Из ОбъектДанных[ТЧ.Имя] Цикл
			Для Каждого РеквизитТЧ Из ТЧ.Реквизиты Цикл
				СписокРеквизитовТЧСтрокой = СписокРеквизитовТЧСтрокой + РеквизитТЧ.Имя + " = " + СтрокаТЧ[РеквизитТЧ.Имя] + Символы.ПС;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	СписокРеквизитовСтрокой = СписокРеквизитовСтрокой + СписокРеквизитовТЧСтрокой;
	Возврат СписокРеквизитовСтрокой;

КонецФункции

Функция ТипКонтентаКартинки(Расширение) Экспорт
	
	Если СтрНайти(Расширение, "jpg") > 0 Или СтрНайти(Расширение, "jpeg") > 0 Тогда
		Возврат "image/jpeg";
		
	ИначеЕсли СтрНайти(Расширение, "png") > 0 Тогда
		Возврат "image/png";
		
	ИначеЕсли СтрНайти(Расширение, "bmp") > 0 Тогда
		Возврат "image/bmp";
	КонецЕсли;
	
	Возврат "";
		
КонецФункции

