Функция СформироватьРазрешительныйРежимОФД(УИДЗапроса, ДатаРегистрацииЗапроса) Экспорт
	
	Возврат Стршаблон("UUID=%1&Time=%2",
		УИДЗапроса,
		?(ТипЗнч(ДатаРегистрацииЗапроса) = Тип("Число"), Формат(ДатаРегистрацииЗапроса, "ЧГ="), Строка(ДатаРегистрацииЗапроса)));
	
КонецФункции

Функция ПолучитьПараметрыРазрешительныйРежим(РазрешительныйРежимОФД) Экспорт
	
	РазрешительныйРежим = Новый Структура("УИДЗапроса, ДатаРегистрацииЗапроса", "", "");
	
	УИД = "UUID=";
	Дата = "&Time=";
	УИДИндекс = СтрНайти(РазрешительныйРежимОФД, УИД);	
	ДатаИндекс = СтрНайти(РазрешительныйРежимОФД, Дата);
	
	Если УИДИндекс > 0 И ДатаИндекс > 0 Тогда
		РазрешительныйРежим.УИДЗапроса = Сред(РазрешительныйРежимОФД, УИДИндекс + СтрДлина(УИД), ДатаИндекс - СтрДлина(УИД)  - 1);
		РазрешительныйРежим.ДатаРегистрацииЗапроса = Прав(РазрешительныйРежимОФД, СтрДлина(РазрешительныйРежимОФД) - ДатаИндекс - СтрДлина(УИД)); 
	КонецЕсли;
	
	Возврат РазрешительныйРежим;
	
КонецФункции	

