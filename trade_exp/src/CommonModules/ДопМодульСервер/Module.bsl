	ПечатныеФормы.utd.Вставить("Наименование", 		"Универсальный передаточный документ");
	ПечатныеФормы.utd.Вставить("Документ", 			"realization");
	ПечатныеФормы.utd.Вставить("ТипДокумента", 		"ДокументСсылка.РеализацияТоваровУслуг");
	ПечатныеФормы.utd.Вставить("Условие", 			"ЕстьСчетФактура");
	
	Возврат ПечатныеФормы;

КонецФункции  	

