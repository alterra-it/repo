Функция НастройкиПроверкиКМПоВидуПродукции(ВидПродукции, Операция = Неопределено) Экспорт
	
	Операция = ?(Операция = Неопределено,ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.ОтгрузкаПродажа"),Операция); 
	НастройкиСканированияКодовМаркировки = ОбщегоНазначенияИСМПВызовСервера.НастройкиСканированияКодовМаркировки();
	
    КонтрольСтатуса   = НужнаПроверкаПоПараметрамКонроляКМ(НастройкиСканированияКодовМаркировки.ПараметрыКонтроляСтатусов,ВидПродукции, Операция);
    КонтрольВладельца = НужнаПроверкаПоПараметрамКонроляКМ(НастройкиСканированияКодовМаркировки.ПараметрыКонтроляВладельцев,ВидПродукции, Операция);

	Возврат Новый Структура("КонтрольСтатуса,КонтрольВладельца",КонтрольСтатуса, КонтрольВладельца);
	
КонецФункции

функция  НужнаПроверкаПоПараметрамКонроляКМ(ПараметрыКонтроляКМ, ВидПродукции, Операция = Неопределено);
	
	НуженКонтроль = Ложь;
	
	Если ПараметрыКонтроляКМ.Включено Тогда 
		НуженКонтроль = Истина;
		Если ПараметрыКонтроляКМ.Исключения[ВидПродукции] <> Неопределено Тогда
			Если ПараметрыКонтроляКМ.Исключения[ВидПродукции][Операция] <> Неопределено Тогда	
				НуженКонтроль = Ложь;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
  
 Возврат НуженКонтроль;  
 
КонецФункции


Функция АктуализироватьМаркировку(Товары, ОбнулитьКоличествоМарк = Ложь) Экспорт
	
	ТабТовары = Товары.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК НоменклатураТЗ,
	|	Товары.НомерСтроки КАК НомерСтроки,
	|   Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|   Товары.Количество КАК Количество
	|
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки,
	|	Номенклатура.Ссылка КАК Номенклатура,
	|	Номенклатура.ВидНоменклатуры.ПродукцияМаркируемаяДляГИСМ КАК ПродукцияМаркируемаяДляГИСМ,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|   Товары.Количество КАК Количество
	|ИЗ
	|	ВТ_Товары КАК Товары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|		ПО Товары.НоменклатураТЗ = Номенклатура.Ссылка
	|ГДЕ
	|	Номенклатура.ВидНоменклатуры.ПродукцияМаркируемаяДляГИСМ = ИСТИНА";
	
	Запрос.УстановитьПараметр("Товары",ТабТовары);
	Запрос.УстановитьПараметр("ОбнулитьКоличествоМарк", ОбнулитьКоличествоМарк);
	
	Результат = Запрос.Выполнить().Выгрузить(); 
	
	ТабТовары.ЗаполнитьЗначения(Ложь,"Маркировка");
	
	Если Результат.Количество()>0 Тогда
		
		Если ОбнулитьКоличествоМарк Тогда
		   Результат.ЗаполнитьЗначения(0,"КоличествоУпаковок,Количество");  
		КонецЕсли;
		
		Для Каждого Строка из Результат Цикл
			СтрТовары = ТабТовары.Найти(Строка.НомерСтроки,"НомерСтроки");
			ЕстьМаркировка = Строка.ПродукцияМаркируемаяДляГИСМ;
			Если ЕстьМаркировка Тогда
		    	СтрТовары.Маркировка = НоменклатураПодлежитМаркировке(СтрТовары.Номенклатура);	
			КонецЕсли;	
		КонецЦикла; 
		Возврат ТабТовары;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
    
КонецФункции

Функция ОпределитьВидПродукции(Номенклатура,МассивВидовПродукции)Экспорт 
    ВидПродукции = ИнтеграцияИСУТКлиентСервер.ОсобенностьУчетаПоВидуПродукции(Номенклатура.ВидНоменклатуры.ОсобенностьУчета);
    ВидПродукции =  ?(МассивВидовПродукции.Найти(ВидПродукции) = Неопределено,МассивВидовПродукции[0],ВидПродукции);
    Возврат ВидПродукции;
КонецФункции


#Область ОбработкаКМ
Функция ПолучитьСтруктуруКодаМаркировки (ШКМаркировки) Экспорт  
	
	МассивКодовМаркировкиЧЗ = Новый Массив;
	МассивКодовМаркировкиЧЗ.Добавить(ШКМаркировки);

	ШтрихкодМаркировки = СтрЗаменить(ШКМаркировки,МенеджерОборудованияМаркировкаКлиентСервер.РазделительGS1(),""); 
		
	СтруктураКодаМаркировки = РазборКодаМаркировкиИССлужебный.РазобратьКодМаркировки(ШтрихкодМаркировки);
	СтруктураКодаМаркировки.Вставить("МассивКодовМаркировкиЧЗ",МассивКодовМаркировкиЧЗ);   
	
	Возврат СтруктураКодаМаркировки;
КонецФункции

Функция ПроверкаЧЗ(МассивКодовМаркировки,ВидПродукции,Операция) Экспорт 
	
        НастройкиПроверкиКМ = МаркировкаАльтерра.НастройкиПроверкиКМПоВидуПродукции(ВидПродукции, Операция);
		КодВалидный = Истина;
		СообщениеОбОшибках = "";
		
		Если АльтерраОбщегоНазначения.ЭтоРабочаяБаза() Тогда
			РежимПроверки = -1;
		Иначе
			РежимПроверки = 1; //тестовый положительный ответ по проверкам		
		КонецЕсли;    
		 
		// Проверка на владельца   
		Если НастройкиПроверкиКМ.КонтрольВладельца Тогда
			РезультатПроверки = МаркировкаАльтерра.ПолучениеИнформацииМаркировки(МассивКодовМаркировки, РежимПроверки, , Истина);
			Если РезультатПроверки.ЗапросНаПроверкуОтправлен Тогда 	
				Если НЕ РезультатПроверки.КодыМаркировки[0].ВладелецНашаОрганизация  Тогда							   
					СообщениеОбОшибках ="Код маркировки не прошел проверку по владельцу!";
					КодВалидный = Ложь; 
				КонецЕсли;		
			Иначе  
				СообщениеОбОшибках = "Не удалось выполнить запрос на проверку владельца кода маркировки в ЧЗ!";
			КонецЕсли;		
		КонецЕсли;
		
		//Проверка на статус  
		Если НастройкиПроверкиКМ.КонтрольСтатуса И КодВалидный Тогда 
			
			РезультатПроверки = МаркировкаАльтерра.ПроверитьМаркировку(МассивКодовМаркировки,РежимПроверки); 
			
			Если РезультатПроверки.ЗапросНаПроверкуОтправлен Тогда 	
				Если НЕ РезультатПроверки.КодыМаркировки[0].СтатусВОбороте  Тогда							   
					СообщениеОбОшибках =  СообщениеОбОшибках + "
				    |Код маркировки не в обороте!";
				 	КодВалидный = Ложь; 
				КонецЕсли;		
			Иначе  
				СообщениеОбОшибках = СообщениеОбОшибках + "
				|Не удалось выполнить запрос на проверку статуса кода маркировки в ЧЗ!";
			КонецЕсли;		
		КонецЕсли;
		
		СтруктураОтвета = Новый Структура("КодВалидный, СообщениеОбОшибках",КодВалидный,СообщениеОбОшибках);
			
	    Возврат СтруктураОтвета; 
		
КонецФункции   
	
#КонецОбласти



 
