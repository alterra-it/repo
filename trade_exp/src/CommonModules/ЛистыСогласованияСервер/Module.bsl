Функция ПолучитьОстатокДоступногоЛимита(Объект) Экспорт
	ИзросходованныйЛимит= 0;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИзросходованныйЛимитСогласованияОбороты.Согласовано,
	|	ИзросходованныйЛимитСогласованияОбороты.СуммаОборот
	|ИЗ
	|	РегистрНакопления.ИзросходованныйЛимитСогласования.Обороты(, , Регистратор, Согласовано = &Согласовано) КАК ИзросходованныйЛимитСогласованияОбороты
	|ГДЕ
	|	ИзросходованныйЛимитСогласованияОбороты.Регистратор <> &Регистратор
	|	И ИзросходованныйЛимитСогласованияОбороты.ВидОперации = &ВидОперации";
	
	Запрос.УстановитьПараметр("Согласовано", Объект.Согласовано);
	Запрос.УстановитьПараметр("Регистратор", Объект.Ссылка);
	Запрос.УстановитьПараметр("ВидОперации", Объект.ВидОперации);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ИзросходованныйЛимит= ИзросходованныйЛимит+ВыборкаДетальныеЗаписи.СуммаОборот;
	КонецЦикла;
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности Тогда
		ОстатокДоступногоЛимита= Объект.Согласовано.ДоступныйЛимитПоЗадолженности-ИзросходованныйЛимит;
	ИначеЕсли Объект.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов Тогда
		ОстатокДоступногоЛимита= Объект.Согласовано.ДоступныйЛимитПоТранзитам-ИзросходованныйЛимит;
	КонецЕсли;
	
	Возврат ОстатокДоступногоЛимита;
КонецФункции

Функция РасчетатьИтоговаяСуммаСогласования(Объект) Экспорт
	СуммаСогласования= 0;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистСогласования.Ссылка,
		|	ЛистСогласования.СуммаСогласования,
		|	ЛистСогласования.СуммаОплаты,
		|	ЛистСогласования.СуммаСогласования - ЛистСогласования.СуммаОплаты КАК Сумма
		|ИЗ
		|	Документ.ЛистСогласования КАК ЛистСогласования
		|ГДЕ
		|	ЛистСогласования.Ссылка <> &Ссылка
		|	И ЛистСогласования.ВидОперации = &ВидОперации
		|	И ЛистСогласования.Основание.Договор = &Договор
		|	И ЛистСогласования.Согласован = ИСТИНА
		|	И ЛистСогласования.Проведен = ИСТИНА
		|	И ЛистСогласования.Аннулирован = ЛОЖЬ
		|	И ЛистСогласования.Исполнен = ЛОЖЬ
		|	И ЛистСогласования.Дата <= &ДатаДок";
	
	Запрос.УстановитьПараметр("ВидОперации", Объект.ВидОперации);
	Запрос.УстановитьПараметр("Договор", Объект.Договор);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ДатаДок", Объект.Дата);

	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СуммаСогласования= СуммаСогласования+ВыборкаДетальныеЗаписи.Сумма;
	КонецЦикла;
	
	Возврат СуммаСогласования;
КонецФункции

