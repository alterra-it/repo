
функция ПолучитьОплатуДо(Документ) Экспорт
	ОплатаДо= Неопределено;
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Если ЗначениеЗаполнено(Документ.ЗаказКлиента) Тогда 
			ОплатаДо= ПолучитьОплатуДоИзЗаказа(Документ.ЗаказКлиента);
		Иначе
			ОплатаДо= ПолучитьОплатуДоИзРеализации(Документ);
		КонецЕсли;
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда			
		ОплатаДо= ПолучитьОплатуДоИзЗаказа(Документ);
	КонецЕсли;
	
	Возврат ОплатаДо;
КонецФункции

функция ПолучитьОплатуДоИзЗаказа(ЗаказКлиента)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиентаЭтапыГрафикаОплаты.ВариантОплаты,
		|	ЗаказКлиентаЭтапыГрафикаОплаты.ДатаПлатежа КАК ДатаПлатежа,
		|	ЗаказКлиентаЭтапыГрафикаОплаты.СуммаПлатежа
		|ИЗ
		|	Документ.ЗаказКлиента.ЭтапыГрафикаОплаты КАК ЗаказКлиентаЭтапыГрафикаОплаты
		|ГДЕ
		|	ЗаказКлиентаЭтапыГрафикаОплаты.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаПлатежа УБЫВ";
	
	Запрос.УстановитьПараметр("Ссылка", ЗаказКлиента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() тогда
		Возврат ВыборкаДетальныеЗаписи.ДатаПлатежа;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

функция ПолучитьОплатуДоИзРеализации(ДокументРеализации)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугЭтапыГрафикаОплаты.ВариантОплаты,
		|	РеализацияТоваровУслугЭтапыГрафикаОплаты.ДатаПлатежа КАК ДатаПлатежа,
		|	РеализацияТоваровУслугЭтапыГрафикаОплаты.СуммаПлатежа
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.ЭтапыГрафикаОплаты КАК РеализацияТоваровУслугЭтапыГрафикаОплаты
		|ГДЕ
		|	РеализацияТоваровУслугЭтапыГрафикаОплаты.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаПлатежа УБЫВ";
	
	Запрос.УстановитьПараметр("Ссылка", ДокументРеализации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() тогда
		Возврат ВыборкаДетальныеЗаписи.ДатаПлатежа;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Функция ПолучитьСуммуВзаиморасчетовПоДоговору(ДатаОстатков,Договор) Экспорт
	Если Не ЗначениеЗаполнено(Договор) Тогда 
		Возврат 0;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(РасчетыСКлиентамиОстатки.СуммаОстаток) КАК СуммаОстаток,
		|	СУММА(РасчетыСКлиентамиОстатки.КОплатеОстаток) КАК КОплатеОстаток,
		|	СУММА(РасчетыСКлиентамиОстатки.КОтгрузкеОстаток) КАК КОтгрузкеОстаток
		|ИЗ
		|	РегистрНакопления.РасчетыСКлиентами.Остатки(&ДатаОстатков, АналитикаУчетаПоПартнерам.Договор = &Договор) КАК РасчетыСКлиентамиОстатки";
	
	Запрос.УстановитьПараметр("ДатаОстатков", ДатаОстатков);
	Запрос.УстановитьПараметр("Договор", Договор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.СуммаОстаток;
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

Функция ПолучитьСуммуВзаиморасчетовПоПартнеру(ДатаОстатков,Партнер) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(ДоговорыКонтрагентов.ДопустимаяСуммаЗадолженности) КАК ДопустимаяСуммаЗадолженности
	|ПОМЕСТИТЬ ВТ_ДопустимаяСуммаЗадолжности
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Партнер = &Партнер
	|	И ДоговорыКонтрагентов.Статус = &Статус
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(РасчетыСКлиентамиОстатки.СуммаОстаток) КАК СуммаОстаток,
	|	СУММА(РасчетыСКлиентамиОстатки.КОплатеОстаток) КАК КОплатеОстаток,
	|	СУММА(РасчетыСКлиентамиОстатки.КОтгрузкеОстаток) КАК КОтгрузкеОстаток,
	|	ЕСТЬNULL(ВТ_ДопустимаяСуммаЗадолжности.ДопустимаяСуммаЗадолженности, 0) КАК ДопустимаяСуммаЗадолженности,
	|	ВЫБОР
	|		КОГДА РасчетыСКлиентамиОстатки.СуммаОстаток = 0
	|			ТОГДА РасчетыСКлиентамиОстатки.КОплатеОстаток
	|		ИНАЧЕ РасчетыСКлиентамиОстатки.СуммаОстаток
	|	КОНЕЦ - ЕСТЬNULL(ВТ_ДопустимаяСуммаЗадолжности.ДопустимаяСуммаЗадолженности, 0) КАК ЗадолженностьПоПартнеру
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(&ДатаОстатков, АналитикаУчетаПоПартнерам.Партнер = &Партнер) КАК РасчетыСКлиентамиОстатки,
	|	ВТ_ДопустимаяСуммаЗадолжности КАК ВТ_ДопустимаяСуммаЗадолжности
	|
	|СГРУППИРОВАТЬ ПО
	|	ЕСТЬNULL(ВТ_ДопустимаяСуммаЗадолжности.ДопустимаяСуммаЗадолженности, 0),
	|	ВЫБОР
	|		КОГДА РасчетыСКлиентамиОстатки.СуммаОстаток = 0
	|			ТОГДА РасчетыСКлиентамиОстатки.КОплатеОстаток
	|		ИНАЧЕ РасчетыСКлиентамиОстатки.СуммаОстаток
	|	КОНЕЦ - ЕСТЬNULL(ВТ_ДопустимаяСуммаЗадолжности.ДопустимаяСуммаЗадолженности, 0)";
	
	Запрос.УстановитьПараметр("ДатаОстатков", ДатаОстатков);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДоговоровКонтрагентов.Действует);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ЗадолженностьПоПартнеру;
	Иначе
		Возврат 0;
	КонецЕсли;
КонецФункции

Функция ПолучитьСуммуВзаиморасчетовПоТранзитам(ДатаОстатков, Договор) Экспорт
	
	Рез = Новый Структура("СуммаОстаток,КОплатеОстаток,КОтгрузкеОстаток",0,0,0);
	
	Если Не ЗначениеЗаполнено(Договор) Тогда 
		Возврат Рез;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СУММА(РасчетыСКлиентамиОстатки.СуммаОстаток) КАК СуммаОстаток,
	|	СУММА(РасчетыСКлиентамиОстатки.КОплатеОстаток) КАК КОплатеОстаток,
	|	СУММА(РасчетыСКлиентамиОстатки.КОтгрузкеОстаток) КАК КОтгрузкеОстаток
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(&ДатаОстатков,ОбъектРасчетов = &Договор) КАК РасчетыСКлиентамиОстатки";
	
	Запрос.УстановитьПараметр("ДатаОстатков", ДатаОстатков);
	Запрос.УстановитьПараметр("Договор", Договор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, ВыборкаДетальныеЗаписи);
	КонецЕсли;
	
	Возврат Рез
	
КонецФункции

Функция ПолучитьЛистыСогласования(Основание) Экспорт
	Отказ= Ложь;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистСогласования.Ссылка КАК Ссылка,
	|	ЛистСогласования.Согласован КАК Согласован,
	|	ЛистСогласования.Исполнен КАК Исполнен,
	|	ЛистСогласования.ВидОперации КАК ВидОперации,
	|	ЛистСогласования.СуммаОплаты КАК СуммаОплаты
	|ИЗ
	|	Документ.ЛистСогласования КАК ЛистСогласования
	|ГДЕ
	|	ЛистСогласования.Основание = &Основание
	|	И ЛистСогласования.Аннулирован = ЛОЖЬ
	|	И ЛистСогласования.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
КонецФункции

Процедура ЕстьНеисполненныеЛистыСогласования(Контрагент) Экспорт
	Если ЗначениеЗаполнено(Контрагент) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистСогласования.Ссылка КАК Ссылка,
		|	ПРЕДСТАВЛЕНИЕ(ЛистСогласования.Ссылка) КАК ПредставлениеСсылки
		|ИЗ
		|	Документ.ЛистСогласования КАК ЛистСогласования
		|ГДЕ
		|	ЛистСогласования.Контрагент = &Контрагент
		|	И НЕ ЛистСогласования.Аннулирован
		|	И НЕ ЛистСогласования.ПометкаУдаления
		|	И НЕ ЛистСогласования.Исполнен
		|	И ЛистСогласования.ВидОперации = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления)";
		                           
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		Пока РезультатЗапроса.Следующий() Цикл
			ОбщегоНазначения.СообщитьПользователю("По контрагенту '" + Контрагент + "'" + " есть неисполненный лист оформления: " + РезультатЗапроса.ПредставлениеСсылки, РезультатЗапроса.Ссылка);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

Функция ПолучитьСогласователя(Пользователь) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПользователиДляСогласованияЛистов.Ссылка КАК Ссылка,
	|	ПользователиДляСогласованияЛистов.Пользователь КАК Пользователь
	|ИЗ
	|	Справочник.ПользователиДляСогласованияЛистов КАК ПользователиДляСогласованияЛистов
	|ГДЕ
	|	ПользователиДляСогласованияЛистов.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат	 ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Функция ЕстьЛистыСогласования(Основание) Экспорт
	Отказ= Ложь;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистСогласования.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЛистСогласования КАК ЛистСогласования
	|ГДЕ
	|	ЛистСогласования.Основание = &Основание
	|	И ЛистСогласования.Аннулирован = ЛОЖЬ
	|	И ЛистСогласования.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Основание", Основание);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Отказ = Ложь Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По данному Основанию уже существуют Листы согласования: ");
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(ВыборкаДетальныеЗаписи.Ссылка), ВыборкаДетальныеЗаписи.Ссылка); 
		Отказ= Истина;
	КонецЦикла;
	
	Возврат Отказ;
КонецФункции
Функция ЕстьНеЗакрытыеЛистыПоКонтрагенту(Контрагент, ВидОперации) Экспорт
	Отказ= Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистСогласования.Ссылка КАК Ссылка,
	|	ЛистСогласования.СуммаСогласования КАК СуммаСогласования
	|ИЗ
	|	Документ.ЛистСогласования КАК ЛистСогласования
	|ГДЕ
	|	ЛистСогласования.Согласован = ИСТИНА
	|	И ЛистСогласования.Проведен = ИСТИНА
	|	И ЛистСогласования.Аннулирован = ЛОЖЬ
	|	И ЛистСогласования.Исполнен = ЛОЖЬ
	|	И ЛистСогласования.Контрагент = &Контрагент
	|	И ЛистСогласования.ВидОперации = &ВидОперации";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("ВидОперации", ВидОперации);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		"По данному контрагенту существует: "+Строка(ВыборкаДетальныеЗаписи.Ссылка),
		ВыборкаДетальныеЗаписи.Ссылка); 
		
		Отказ= Истина;
	КонецЦикла;
	Возврат Отказ;
КонецФункции
Функция ЕстьНеЗакрытыеЛистыПоДоговору(Объект) Экспорт
	СуммаСогласования= 0;
	Отказ= Ложь;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистСогласования.Ссылка,
	|	ЛистСогласования.СуммаСогласования
	|ИЗ
	|	Документ.ЛистСогласования КАК ЛистСогласования
	|ГДЕ
	|	ЛистСогласования.Ссылка <> &Ссылка
	|	И ЛистСогласования.ВидОперации = &ВидОперации
	|	И ЛистСогласования.Основание.Договор = &Договор
	|	И ЛистСогласования.Согласован = ИСТИНА
	|	И ЛистСогласования.Проведен = ИСТИНА
	|	И ЛистСогласования.Аннулирован = ЛОЖЬ
	|	И ЛистСогласования.Исполнен = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ВидОперации", Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Договор", Объект.Основание.Договор);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СуммаСогласования= СуммаСогласования+ВыборкаДетальныеЗаписи.СуммаСогласования;
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		"По данному договору уже существуют Листы согласования: "+Строка(ВыборкаДетальныеЗаписи.Ссылка)+" на сумму: "+СуммаСогласования,
		ВыборкаДетальныеЗаписи.Ссылка); 
		
		Отказ= Истина;
	КонецЦикла;
	Возврат Отказ;
КонецФункции
Функция ЕстьДругиеЛистыПоЗадолженности(Объект) Экспорт
	Отказ= Ложь;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЛистСогласования.Ссылка
	|ИЗ
	|	Документ.ЛистСогласования КАК ЛистСогласования
	|ГДЕ
	|	ЛистСогласования.Ссылка <> &Ссылка
	|	И ЛистСогласования.ВидОперации = &ВидОперации
	|	И ЛистСогласования.Основание = &Основание
	|	И ЛистСогласования.Аннулирован = ЛОЖЬ
	|	И ЛистСогласования.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ВидОперации", Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Основание", Объект.Основание);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Отказ = Ложь Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По данному Основанию уже существуют Листы согласования: ");
		КонецЕсли;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(ВыборкаДетальныеЗаписи.Ссылка), ВыборкаДетальныеЗаписи.Ссылка); 
		Отказ= Истина;
	КонецЦикла;
	
	Возврат Отказ;
КонецФункции
