
Функция ПрименитьНовыйПорядокРаспределенияБонусов(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	 
	ДатаНачала = Константы.ДатаНачалаРаспределенияБонусов.Получить();
	ТекДата = ТекущаяДата();
	
	Если ТипЗнч(Объект) = Тип("Неопределено") Тогда
		 Результат = ?(ДатаНачала <> Дата(1,1,1) И ТекДата > ДатаНачала, Истина, Ложь);
	     Возврат Результат;
	 КонецЕсли;
	 
	ТипДокумента = ТипЗнч(Объект.Ссылка);
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ТипДокумента = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ДокДата = Объект.ДатаСоздания;
		Иначе
			ДокДата = Объект.Дата;
		КонецЕсли;
	Иначе
		ДокДата = ТекДата;
	КонецЕсли;
	
	ДатаНачала = ?(ДатаНачала = Дата(1,1,1), ДокДата + 86400, ДатаНачала);
	Результат = Ложь;
	
	Если Не ТипДокумента = Тип("ДокументСсылка.РеализацияТоваровУслуг") И ДокДата > ДатаНачала Тогда
		Результат = Истина;
	КонецЕсли;
	
	Если ТипДокумента = Тип("ДокументСсылка.РеализацияТоваровУслуг") И ДокДата > ДатаНачала Тогда
		Заказ = Объект.ЗаказКлиента;
		Если ЗначениеЗаполнено(Заказ) Тогда
			Результат = ПрименитьНовыйПорядокРаспределенияБонусов(Заказ);
		Иначе 
			Результат = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
    УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции

Функция ПолучитьСтрокиИзРеализацийПоЗаказу(Ссылка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_Реализации
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Проведен
		|	И РеализацияТоваровУслуг.ЗаказКлиента = &ЗаказКлиента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.КодСтроки КАК КодСтроки
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТ_Реализации.Ссылка
		|			ИЗ
		|				ВТ_Реализации)";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;

КонецФункции

Функция ПолучитьСуммуБалловКСписаниюИзЗаказа(Заказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	isnull(СУММА(РезервБонусныхБаллов.СуммаБаллов), 0) КАК Сумма
		|ИЗ
		|	РегистрСведений.РезервБонусныхБаллов КАК РезервБонусныхБаллов
		|ГДЕ
		|	РезервБонусныхБаллов.Заказ = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат[0].Сумма;
	
КонецФункции

Функция ПолучитьСуммуБалловКНачислениюИзЗаказа(Заказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ЗаказКлиентаТовары.СуммаНачисленныхБонусныхБалловВВалюте), 0) КАК Сумма
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|ГДЕ
		|	ЗаказКлиентаТовары.Ссылка = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат[0].Сумма;
	
КонецФункции

Функция ПолучитьОбщийРезервБонусныхБаллов(Партнер, Заказ = Неопределено) Экспорт 
	
	Резерв = 0;
	ОтборПоЗаказу = ?(Заказ = Неопределено, Ложь, Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	isnull(СУММА(РезервБонусныхБаллов.СуммаБаллов), 0) КАК Сумма
		|ИЗ
		|	РегистрСведений.РезервБонусныхБаллов КАК РезервБонусныхБаллов
		|ГДЕ
		|	РезервБонусныхБаллов.Партнер = &Партнер
		|	И (НЕ &ОтборПоЗаказу
		|			ИЛИ НЕ РезервБонусныхБаллов.Заказ = &Заказ)
		|	И РезервБонусныхБаллов.Реализация = ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Запрос.УстановитьПараметр("ОтборПоЗаказу", ОтборПоЗаказу);
	Запрос.УстановитьПараметр("Заказ", Заказ);
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() > 0 Тогда
		Резерв = Результат[0].Сумма;
	КонецЕсли;
	
	Возврат Резерв;
	
КонецФункции

Функция ПолучитьСуммуБалловСРеализациейИзЗаказа(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	isnull(СУММА(isnull(РезервБонусныхБаллов.СуммаБаллов, 0)), 0) КАК СуммаБаллов
		|ИЗ
		|	РегистрСведений.РезервБонусныхБаллов КАК РезервБонусныхБаллов
		|ГДЕ
		|	РезервБонусныхБаллов.Заказ = &Заказ";
		//|	И НЕ РезервБонусныхБаллов.Реализация = ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Заказ", Ссылка);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат[0].СуммаБаллов;
	
КонецФункции

Процедура ОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		Если Не ЗначениеЗаполнено(Источник.ЗаказКлиента) Или Не ПрименитьНовыйПорядокРаспределенияБонусов(Источник.Ссылка) Тогда
			Возврат;
		КонецЕсли;
		
		Заказ = Источник.ЗаказКлиента;
		
		ТоварыЗаказа = Заказ.Товары;
		
		СтрокиСРасхождением = Новый ТаблицаЗначений();
		СтрокиСРасхождением.Колонки.Добавить("КодСтроки");
		СтрокиСРасхождением.Колонки.Добавить("Разница");
		СтрокиСРасхождением.Колонки.Добавить("ЗаСтатус");
		СтрокиСРасхождением.Колонки.Добавить("Прочее");
		СтрокиСРасхождением.Колонки.Добавить("Статус"); 
		
		//АвтоопределениеДистрибуция
		Если Источник.РаспределитьТранспортныеДистрибуция Тогда
			СтрокиСРасхождением.Колонки.Добавить("Коэфф");
		КонецЕсли;
	    //

		СтатусПартнераРеализации = Источник.СтатусПартнераВПрограммеЛояльности;
		
		Для каждого СтрокаРеализации Из Источник.Товары Цикл
			
			Отбор = Новый Структура;
			Отбор.Вставить("КодСтроки", СтрокаРеализации.КодСтроки);
			СтрокаЗаказа = ТоварыЗаказа.НайтиСтроки(Отбор);
			
			Если СтрокаЗаказа.Количество() = 0 Тогда 
				Отказ = Истина;
			    ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Номенклатура " + СтрокаРеализации.Номенклатура + " не найдена в заказе.",, ,, Отказ);
				Возврат;
			КонецЕсли;
			
			Если СтрокаРеализации.Количество < СтрокаЗаказа[0].Количество
				ИЛИ СтрокаРеализации.СуммаНачисленныхБалловЗаСтатус <> СтрокаЗаказа[0].СуммаНачисленныхБалловЗаСтатус
				ИЛИ СтатусПартнераРеализации <> СтрокаЗаказа[0].Статус
			Тогда
				СтрокаСРасхождением = СтрокиСРасхождением.Добавить();
				СтрокаСРасхождением.КодСтроки = СтрокаЗаказа[0].КодСтроки;
				СтрокаСРасхождением.Разница = СтрокаЗаказа[0].Количество - СтрокаРеализации.Количество;
				СтрокаСРасхождением.ЗаСтатус = СтрокаРеализации.СуммаНачисленныхБалловЗаСтатус;
				СтрокаСРасхождением.Прочее = СтрокаРеализации.СуммаНачисленныхБалловПрочее;  
				
				//АвтоопределениеДистрибуция
				Если Источник.РаспределитьТранспортныеДистрибуция Тогда
					Коэфф = СтрокаЗаказа[0].СуммаРТ/(СтрокаЗаказа[0].Сумма); 
					СтрокаРеализации.СуммаРТ=СтрокаРеализации.Сумма*Коэфф; 
					СтрокаСРасхождением.Коэфф = Коэфф;
				КонецЕсли;
				//
				
				Если СтатусПартнераРеализации = Справочники.СтатусыПартнеровВПрограммеЛояльности_Альтерра.ПустаяСсылка() Тогда
					СтрокаСРасхождением.Статус = ПолучитьИнформациюПоБаллам(Источник.Дата, Источник.Партнер, Неопределено, Заказ).Статус;
				Иначе
					СтрокаСРасхождением.Статус = СтатусПартнераРеализации; 
				КонецЕсли;
			КонецЕсли; 
			
		КонецЦикла;		
	
		Если СтрокиСРасхождением.Количество() > 0 Тогда  			
			ОбработатьСтрокиВЗаказе(Заказ, СтрокиСРасхождением);  
		КонецЕсли;

		НачислитьБонусныеБаллы(Источник);
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(Источник);
		
		Если ЗначениеЗаполнено(Источник.Кассир) Тогда
			РезервБонусов = РегистрыСведений.РезервБонусныхБаллов;
			НаборЗаписей = РезервБонусов.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Заказ.Установить(Заказ);
			НаборЗаписей.Прочитать();
			
			Для каждого Стр Из НаборЗаписей Цикл
				Отбор = Новый Структура;
				Отбор.Вставить("КодСтроки", Стр.КодСтроки);
				СтрокаЗаказа = Источник.Товары.НайтиСтроки(Отбор);
				
				Если СтрокаЗаказа.Количество() > 0 Тогда
					Стр.Реализация = Источник.Ссылка;
				КонецЕсли;
			КонецЦикла;
			
			НаборЗаписей.Записать();	
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		
		Если Не ПрименитьНовыйПорядокРаспределенияБонусов(Источник.Ссылка) Тогда
			Возврат;
		КонецЕсли;
		
		РезервБонусов = РегистрыСведений.РезервБонусныхБаллов;
		НаборЗаписей = РезервБонусов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Заказ.Установить(Источник.Ссылка);
		НаборЗаписей.Прочитать();
		
		Если Источник.Товары.Итог("СуммаБонусныхБалловКСписанию") > 0 Тогда
			
			Для Индекс = 1 - НаборЗаписей.Количество() По 0 Цикл
				Запись = НаборЗаписей[-Индекс];
				
				Отбор = Новый Структура;
				Отбор.Вставить("КодСтроки", Запись.КодСтроки);
				Отбор.Вставить("Отменено", Ложь);
				
				СтрокаЗаказа = Источник.Товары.НайтиСтроки(Отбор);
				Если СтрокаЗаказа.Количество() = 0 Тогда
					НаборЗаписей.Удалить(-Индекс);
				КонецЕсли;
			КонецЦикла;
			
			НаборЗаписей.Записать();
			
			Для каждого Строка Из Источник.Товары Цикл
				
				Если Не ЗапрещеноИспользоватьБонусы(Строка) Тогда
					
					НаборЗаписей.Отбор.КодСтроки.Установить(Строка.КодСтроки);
					НаборЗаписей.Прочитать();
					Если НаборЗаписей.Количество() = 0 Тогда
						Запись = НаборЗаписей.Добавить();
					Иначе
						Запись = НаборЗаписей[0];
					КонецЕсли;
					Запись.Партнер = Источник.Партнер;
					Запись.Заказ = Источник.Ссылка;
					Запись.КодСтроки = Строка.КодСтроки;
					Запись.Номенклатура = Строка.Номенклатура;
					Запись.Количество = Строка.КоличествоУпаковок;
					Запись.СуммаБаллов = Строка.СуммаБонусныхБалловКСписанию;
					
					НаборЗаписей.Записать(); 
					
				КонецЕсли;
				
			КонецЦикла;
		Иначе
			НаборЗаписей.Очистить();
			НаборЗаписей.Записать(Истина);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Источник, Отказ) Экспорт
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		
		Если Не ЗначениеЗаполнено(Источник.ЗаказКлиента) Или Не ПрименитьНовыйПорядокРаспределенияБонусов(Источник.Ссылка) Тогда
			Возврат;
		КонецЕсли;
		
		Заказ = Источник.ЗаказКлиента;
		
		Если  Заказ.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте") = 0 Тогда
			Возврат;
		КонецЕсли;
		
		РезервБонусов = РегистрыСведений.РезервБонусныхБаллов;
		НаборЗаписей = РезервБонусов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Заказ.Установить(Заказ);
		НаборЗаписей.Прочитать();
		Для каждого Стр Из НаборЗаписей Цикл
			Если Стр.Реализация = Источник.Ссылка Тогда
				Стр.Реализация = Документы.РеализацияТоваровУслуг.ПустаяСсылка();
			КонецЕсли;
		КонецЦикла;
		
		НаборЗаписей.Записать(Истина);
		
	КонецЕсли; 
	
	Если ТипЗнч(Источник) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		
		Если Источник.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте") = 0 
			Или Не ПрименитьНовыйПорядокРаспределенияБонусов(Источник.Ссылка) 
		Тогда
			Возврат;
		КонецЕсли;
		
		Заказ = Источник.Ссылка; 
		
		РезервБонусов = РегистрыСведений.РезервБонусныхБаллов;
		НаборЗаписей = РезервБонусов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Заказ.Установить(Заказ);
		НаборЗаписей.Прочитать();
		НаборЗаписей.Очистить();
		НаборЗаписей.Записать(Истина);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура КонтрольОстатковПоБонуснымБаллам(Док, Отказ) Экспорт
	
	СуммаОплаченныхБалловПриПродаже = Док.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	
	Если СуммаОплаченныхБалловПриПродаже = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Заказ = ?(ТипЗнч(Док.Ссылка) = Тип("ДокументСсылка.ЗаказКлиента"), Док.Ссылка, Неопределено);
	
	ДоступноБаллов = ПолучитьИнформациюПоБаллам(Док.Дата, Док.Партнер, Неопределено, Заказ).ДоступныеБаллы;
	
	ОтгруженоРеализациями = ПолучитьСуммуБалловСРеализациейИзЗаказа(Заказ);
	
	Если СуммаОплаченныхБалловПриПродаже > ДоступноБаллов + ОтгруженоРеализациями Тогда
		Отказ = Истина;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У партнера не хватает бонусных баллов для оплаты!"+Символы.ПС+"Необходимо обновить оплату в документе.",, ,, Отказ);
	КонецЕсли;
	
	//БонуснаяПрограммаЛояльности = ПолучитьБПЛ(Док.КартаЛояльности);
	//ДокДата = Док.Дата;
	//ДокДата = ?(ДокДата <> Дата(1,1,1), ДокДата, ТекущаяДата());
	//
	//Запрос = Новый Запрос;
	//Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	БонусныеБаллыОстатки.БонуснаяПрограммаЛояльности КАК БонуснаяПрограммаЛояльности,
	//	|	БонусныеБаллыОстатки.Партнер КАК Партнер,
	//	|	БонусныеБаллыОстатки.НачисленоОстаток КАК НачисленоОстаток
	//	|ИЗ
	//	|	РегистрНакопления.БонусныеБаллы.Остатки(
	//	|			&Дата,
	//	|			Партнер = &Партнер
	//	|				И БонуснаяПрограммаЛояльности = &БонуснаяПрограммаЛояльности) КАК БонусныеБаллыОстатки
	//	|ГДЕ
