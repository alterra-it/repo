&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	Док_УстановитьОтборОснование();
КонецПроцедуры

&НаКлиенте
Процедура Док_ОснованиеПриИзмененииПосле(Элемент)
	Док_УстановитьОтборОснование();
КонецПроцедуры

&НаСервере
Процедура Док_УстановитьОтборОснование()
	// сделано, потому что УстановитьОтборПоКонтакту Ссылки сверяет, так же, как необходимо нам
	Если ЗначениеЗаполнено(Основание) И ЗначениеЗаполнено(Контакт) Тогда // это вариант, когда форма Взаимодействий открыта из Партнера или Контактного лица
		Попытка
			// модифицировано из УстановитьОтборПоКонтакту()
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	КонтактыВзаимодействий.Взаимодействие КАК Ссылка
			|ИЗ
			|	ЖурналДокументов.Взаимодействия КАК Взаимодействия
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КонтактыВзаимодействий КАК КонтактыВзаимодействий
			|		ПО (Взаимодействия.Ссылка = КонтактыВзаимодействий.Взаимодействие)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЭлектронноеПисьмоИсходящее.Основания КАК ЭлектронноеПисьмоИсходящееОснования
			|		ПО (Взаимодействия.Ссылка = ЭлектронноеПисьмоИсходящееОснования.Ссылка)
			|			И (ЭлектронноеПисьмоИсходящееОснования.Документ = &Документ)
			|ГДЕ
			|	КонтактыВзаимодействий.Контакт В(&Контакт)");
					
			МассивПараметрКонтакт = ПараметрКонтактВЗависимостиОтТипа(Контакт);
			Если МассивПараметрКонтакт.Количество() = 0 Тогда
				МассивПараметрКонтакт.Добавить(Контакт);
			КонецЕсли;
			
			Запрос.УстановитьПараметр("Контакт", МассивПараметрКонтакт);
			Запрос.УстановитьПараметр("Документ", Основание);
			
			СписокОтбора = Новый СписокЗначений;
			СписокОтбора.ЗагрузитьЗначения(
			Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
			
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, 
			"Ссылка",СписокОтбора,ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
		Исключение
			Сообщить("Фильтр по Основанию не применен" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			Сообщить(Контакт);
		КонецПопытки;
	ИначеЕсли ЗначениеЗаполнено(Основание) Тогда // это вариант, если Форма открыта из Взаимодействия
		Попытка
			// модифицировано из УстановитьОтборПоКонтакту()
			Запрос = Новый Запрос(
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	Взаимодействия.Ссылка КАК Ссылка
			|ИЗ
			|	ЖурналДокументов.Взаимодействия КАК Взаимодействия
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЭлектронноеПисьмоИсходящее.Основания КАК ЭлектронноеПисьмоИсходящееОснования
			|		ПО (Взаимодействия.Ссылка = ЭлектронноеПисьмоИсходящееОснования.Ссылка)
			|			И (ЭлектронноеПисьмоИсходящееОснования.Документ = &Документ)");
			
			Запрос.УстановитьПараметр("Документ", Основание);
			
			СписокОтбора = Новый СписокЗначений;
			СписокОтбора.ЗагрузитьЗначения(
			Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка"));
			
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Список, 
			"Ссылка",СписокОтбора,ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
		Исключение
			Сообщить("Фильтр по Основанию не применен" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			Сообщить(Контакт);
		КонецПопытки;
	ИначеЕсли ЗначениеЗаполнено(Контакт) Тогда // вариант, если Основание не заполнено, но открыто из Партнера или Контактного лица
		УстановитьОтборПоКонтакту();
	Иначе // вариант, когда открыто из Взаимодействия, и Основание не заполнено
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(Список, "Ссылка");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ОснованиеНачалоВыбораВместо(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура;
	Если ЗначениеЗаполнено(Контакт) Тогда
		Партнер_ = ПолучитьПартнераПоКонтакту(Контакт);
		Если ЗначениеЗаполнено(Партнер_) Тогда
			ПараметрыОткрытия.Вставить("Партнер", Партнер_);
		КонецЕсли;
	КонецЕсли;
	ПараметрыОткрытия.Вставить("РежимВыбора", Истина);
	ПараметрыОткрытия.Вставить("МножественныйВыбор", Ложь);
	ПараметрыОткрытия.Вставить("ЗакрыватьПриВыборе", Истина);
	
	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбора", ЭтаФорма,"Подбор");
	
	ОткрытьФорму("Справочник.ДоговорыКонтрагентов.ФормаВыбора",ПараметрыОткрытия,ЭтаФорма,УникальныйИдентификатор,,,ОбработкаВыбора);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПартнераПоКонтакту(Контакт)
	Возврат ?(ТипЗнч(Контакт) = Тип("СправочникСсылка.Партнеры"), Контакт,
				?(ТипЗнч(Контакт) = Тип("СправочникСсылка.КонтактныеЛицаПартнеров"), Контакт.Владелец,
					?(ТипЗнч(Контакт) = Тип("СправочникСсылка.Контрагенты"), Контакт.Партнер, Неопределено)
					)
				)
КонецФункции

&НаКлиенте
Процедура ПриЗакрытииФормыВыбора(Значение, ДопПараметры) Экспорт
    Если Значение = Неопределено Тогда
        Возврат;
    КонецЕсли;
     
    Основание = Значение;
	Док_УстановитьОтборОснование();
КонецПроцедуры