  <attributes>
    <name>ЧекиККМ</name>
    <title>
      <key>ru</key>
      <value>Чеки ККМ</value>
    </title>
    <id>1000022</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ЧекиККМ.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЧекиККМ.Ссылка КАК Ссылка,
	ЧекиККМ.Номер КАК Номер,
	ЧекиККМ.Дата КАК Дата,
	ЧекиККМ.ПометкаУдаления КАК ПометкаУдаления,
	ЧекиККМ.Проведен КАК Проведен,
	ЧекиККМ.Статус КАК Статус,
	ВЫБОР
		КОГДА ЧекиККМ.Ссылка ССЫЛКА Документ.ЧекККМ
			ТОГДА ВЫБОР
					КОГДА ЧекиККМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.ОтложенБезРезервирования)
							ИЛИ ЧекиККМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.ОтложенСРезервированием)
						ТОГДА ИСТИНА
					ИНАЧЕ ЛОЖЬ
				КОНЕЦ
		ИНАЧЕ ВЫБОР
				КОГДА ЧекиККМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
					ТОГДА ЛОЖЬ
				ИНАЧЕ ИСТИНА
			КОНЕЦ
	КОНЕЦ КАК Отложен,
	ВЫРАЗИТЬ(&quot;&quot; КАК СТРОКА(10)) КАК НомерЧекаККМ,
	ЧекиККМ.КассаККМ КАК КассаККМ,
	ЧекиККМ.Организация КАК Организация,
	ЧекиККМ.СуммаДокумента КАК СуммаДокумента,
	ЧекиККМ.Валюта КАК Валюта,
	ЧекиККМ.Архивный КАК Архивный,
	ЧекиККМ.КассоваяСмена КАК КассоваяСмена,
	ЧекиККМ.Тип КАК Тип,
	ЗНАЧЕНИЕ(Документ.ЧекККМВозврат.ПустаяСсылка) КАК ОтложенныйЧекККМВозврат
ИЗ
	ЖурналДокументов.ЧекиККМ КАК ЧекиККМ</queryText>
      <mainTable>DocumentJournal.ЧекиККМ</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
