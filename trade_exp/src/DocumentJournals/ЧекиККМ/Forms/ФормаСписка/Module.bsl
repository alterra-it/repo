&НаКлиенте
Процедура Док_ОтложенныеЧекиВыборПосле(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущиеДанные = Элементы.ОтложенныеЧеки.ТекущиеДанные;
	ТекущиеДанныеСтатус = ТекущиеДанные.Статус;

	ИмяОткрываемойФормы = ИмяОткрываемойФормы(ТекущиеДанные.Ссылка,ТекущиеДанныеСтатус);
	
	ПараметрыОткрытия = Новый Структура("Ключ", ТекущиеДанные.Ссылка);
	
	Если ЧекнеПробит(ТекущиеДанные.Ссылка) Тогда
		СтандартнаяОбработка = Ложь;
		
		если ЯвляетсяКассиром() тогда
			если не значениезаполнено(КассаККМ) тогда
				ТекстСообщения = НСтр("ru = 'Касса ККМ не выбрана! Возможно не открыта кассовая смена.'");
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				возврат;
			конецесли;
			ПараметрыОткрытия.Вставить("Основание",Новый структура("КассаККМ",КассаККМ));
		конецесли;	
		
		ОткрытьФорму(ИмяОткрываемойФормы, ПараметрыОткрытия);
	КонецЕсли;
	
КонецПроцедуры
