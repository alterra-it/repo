&Вместо("ОбработатьШтрихкоды")
&НаКлиенте
Процедура Док_ОбработатьШтрихкоды(Данные)
	МассивСсылок = СсылкаНаЭлементСпискаПоШтрихкоду(Данные.Штрихкод);
	Если МассивСсылок.Количество() > 0 Тогда
		
		Ссылка = МассивСсылок[0];
		//+ Альтерра изменения
		Элементы.ЧекиККМ.ТекущаяСтрока = Ссылка;
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
			
			ИмяОткрываемойФормы = ИмяОткрываемойФормы(Ссылка,СтатусДокумента(Ссылка));
			
			ПараметрыОткрытия = Новый Структура("Ключ", Ссылка);
			если ЯвляетсяКассиром() тогда
				если не значениезаполнено(КассаККМ) тогда
					ТекстСообщения = НСтр("ru = 'Касса ККМ не выбрана! Возможно не открыта кассовая смена.'");
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
					возврат;
				конецесли;
				
				ПараметрыОткрытия.Вставить("Основание",Новый структура("КассаККМ",КассаККМ));
				
				Если ВозвратитьСтатус(ссылка) <> ПредопределенноеЗначение("Перечисление.СтатусыЧековККМ.Пробит") Тогда
					СтандартнаяОбработка = Ложь;
					ОткрытьФорму(ИмяОткрываемойФормы, ПараметрыОткрытия);
				Иначе 
					ОткрытьЗначение(Ссылка);
				КонецЕсли;
			Иначе 
				ОткрытьЗначение(Ссылка);
			КонецЕсли;
		иначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
			ИмяОткрываемойФормы = ИмяОткрываемойФормы(Ссылка,СтатусДокумента(Ссылка));
			ПараметрыОткрытия = Новый Структура("Ключ", Ссылка);
			Если ВозвратитьСтатус(ссылка) <> ПредопределенноеЗначение("Перечисление.СтатусыЧековККМ.Пробит") Тогда
				СтандартнаяОбработка = Ложь;
				ОткрытьФорму(ИмяОткрываемойФормы, ПараметрыОткрытия);
			Иначе 
				ОткрытьЗначение(Ссылка);
			КонецЕсли;
		иначе
			ОткрытьЗначение(Ссылка);
		конецесли;	
		//-
	Иначе
		ШтрихкодированиеПечатныхФормКлиент.ОбъектНеНайден(Данные.Штрихкод);
	КонецЕсли;
КонецПроцедуры

#Область ПоискПоQR

&НаСервере
Функция ПолучитьДокументПродажи(ДокументОплаты)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПриходныйКассовыйОрдерРасшифровкаПлатежа.ОснованиеПлатежа КАК ОснованиеПлатежа
	|ИЗ
	|	Документ.ПриходныйКассовыйОрдер.РасшифровкаПлатежа КАК ПриходныйКассовыйОрдерРасшифровкаПлатежа
	|ГДЕ
	|	ПриходныйКассовыйОрдерРасшифровкаПлатежа.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ДокументОплаты);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ОснованиеПлатежа;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции // ПолучитьДокументПродажи()

&НаКлиенте
Процедура Док_ОбработкаОповещенияПеред(ИмяСобытия, Параметр, Источник)
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Если Параметр.Количество() > 0 И ТипЗнч(Параметр[0])=Тип("Строка") Тогда
				СтрокаКода = Параметр[0];
				Если СтрНайти(НРег(СтрокаКода), "fn") <> 0 Тогда
					СФП_МаркерыКлиент.МаркерНачало("Журнал Чеки ККМ сканирование");
					
					ОчиститьСообщения();
					ВсеДокументы = Элементы.Группа1.ТекущаяСтраница.Заголовок<>"Основная";
					//СписокПоиска = ?(ВсеДокументы, ЧекиККМ, ЧекиККМ);
					СсылкаНаДокумент = АльтерраОбщегоНазначения.ПолучитьСсылкуНаДокументПоQR(СтрокаКода);
					Если ВсеДокументы=Истина И ТипЗнч(СсылкаНаДокумент)<>Тип("ДокументСсылка.ЧекККМ") Тогда
						ДокументПродажи = ПолучитьДокументПродажи(СсылкаНаДокумент);
						СсылкаНаДокумент = ДокументПродажи; 
					КонецЕсли;
					
					Если СсылкаНаДокумент<>Неопределено Тогда
						_ДокументПродажи = СсылкаНаДокумент;
						Если ВсеДокументы Тогда
							Элементы._ОчиститьПоискПоДокументу1.Видимость = Истина;
						Иначе
							Элементы._ОчиститьПоискПоДокументу.Видимость = Истина;
						КонецЕсли;
						
						_ОтборДокумент.Добавить(_ДокументПродажи);
						
						ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЧекиККМ,
						"Ссылка",
						_ОтборДокумент,
						ВидСравненияКомпоновкиДанных.Равно,
						,
						ЗначениеЗаполнено(_ОтборДокумент));
						МенеджерОборудованияУТКлиент.ОбработатьСобытие();
					Иначе
						ОчиститьПоискQR();
						//Сообщить("Документ " + Строка(СсылкаНаДокумент) + " не найден");
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док__ОтменитьПоискПоQRПосле(Команда)
	ОчиститьПоискQR();
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьПоискQR()
	Элементы._ОчиститьПоискПоДокументу.Видимость = Ложь;
	Элементы._ОчиститьПоискПоДокументу1.Видимость = Ложь;
	_ОтборДокумент.Очистить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЧекиККМ,
	"Ссылка",
	_ОтборДокумент,
	ВидСравненияКомпоновкиДанных.ВСписке,
	,
	ЗначениеЗаполнено(_ОтборДокумент));
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ЧекиККМ,
	"Ссылка",
	_ОтборДокумент,
	ВидСравненияКомпоновкиДанных.ВСписке,
	,
	ЗначениеЗаполнено(_ОтборДокумент));
	
КонецПроцедуры // ОчиститьПоискQR()

