&НаКлиенте
Функция ДОК_СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод)
	Менеджеры = Новый Массив();
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.РеализацияТоваровУслуг.ПустаяСсылка")); // ищем для быстроты только реализации
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ЧекККМ.ПустаяСсылка")); // ищем для быстроты только реализации
	
	Возврат ШтрихкодированиеПечатныхФормКлиент.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, Менеджеры);
КонецФункции

&НаКлиенте
Процедура Док_ЧекиККМПередНачаломДобавленияВместо(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	ТекущиеДанные = Элементы.ЧекиККМ.ТекущиеДанные; 
	ТекущиеДанныеСтатус = ТекущиеДанные.Статус;
	Отказ = Истина;
	
	Если Не (ЗначениеЗаполнено(КассаККМ) И ДоступноДобавлениеИзменениеЧековККМ) Тогда
		Возврат;
	КонецЕсли;
	
	Если Копирование = Истина Тогда
		
		ИмяОткрываемойФормы = ИмяОткрываемойФормы(ТекущиеДанные.Ссылка, ТекущиеДанныеСтатус);
		ПараметрыОткрытияФормы = Новый Структура("Основание", ТекущиеДанные.Ссылка);
		если не ЯвляетсяКассиром() тогда
			ПараметрыОткрытияФормы.Вставить("Склад",Склад);
		конецесли;
		
		ОткрытьФорму(
		"Документ.ЧекККМ.Форма.ФормаДокументаРМК",
		ПараметрыОткрытияФормы);
		
	Иначе
		
		ПараметрыОткрытияФормы = Новый Структура("Основание", Новый Структура("КассаККМ", КассаККМ));
		если не ЯвляетсяКассиром() тогда
			ПараметрыОткрытияФормы.Вставить("Склад",Склад);
		конецесли;
		
		ОткрытьФорму(
		"Документ.ЧекККМ.Форма.ФормаДокументаРМК",
		ПараметрыОткрытияФормы);
		
	КонецЕсли;
КонецПроцедуры

