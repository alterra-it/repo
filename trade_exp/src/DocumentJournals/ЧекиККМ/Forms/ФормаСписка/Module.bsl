&НаСервере
Функция ЯвляетсяКассиром()
	
	возврат рольдоступна("Полныеправа") или рольдоступна("ОтметкаКассы");
	
КонецФункции // ПроверитьПравоНаОтметкуКассы()
&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	если ЯвляетсяКассиром() тогда
		КассаККМ = КассаККМТекущегоПользователя();
		КассаККМОтборПриИзменении(Неопределено);
		возврат;
	конецесли;
	Элементы.ГруппаКасса.Видимость=ложь;
	Элементы.ЧекиККМСоздатьЧекККМ.Доступность=Истина;
	Элементы.ГруппаСостояниеКассовойСмены.Видимость=Ложь;
	Элементы._ГруппаМенеджер.Видимость=истина;
	КассаККМ="";
	если значениезаполнено(Склад) тогда
		КассаККМ=КассаККМПоумолчанию();
	конецесли;
	Элементы.ЧекиККМСоздатьЧекККМНаВозврат.Видимость=Ложь;
	ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(ЧекиККМ, "КассаККМ");
	
КонецПроцедуры
&НаСервере
Функция КассаККМПоумолчанию()
	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КассыККМ.Ссылка КАК кассаККМ
	|ИЗ
	|	Справочник.КассыККМ КАК КассыККМ
	|ГДЕ
	|	НЕ КассыККМ.ПометкаУдаления
	|	И КассыККМ.Подразделение = &Подразделение
	|	И КассыККМ.Владелец = КассыККМ.Подразделение.Организация
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	КассыККМ.Ссылка
	|ИЗ
	|	Справочник.КассыККМ КАК КассыККМ
	|ГДЕ
	|	НЕ КассыККМ.ПометкаУдаления
	|	И КассыККМ.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Дата",ТекущаяДата());
	Запрос.УстановитьПараметр("Подразделение",_Подразделение);
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		
		возврат ВыборкаДетальныеЗаписи.кассаККМ;
	иначе
		//возврат Справочники.КассыККМ.КассаККМФискальныйРегистраторДляРМК();
		возврат Справочники.КассыККМ.ПустаяСсылка();
	конецесли;
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	
КонецФункции // КассаККМПоумолчанию()()
&НаКлиенте
Процедура Док_СоздатьЧекККМВместо(Команда)
	
	Если КассаРаботаетЧерезАтолСервер(Строка(КассаККМ)) Тогда
		Сообщить(СтрШаблон("%1 не используется в рабочем месте кассира", КассаККМ));
		Возврат;
	КонецЕсли;
	
	если не значениезаполнено(КассаККМ) тогда
		ТекстСообщения = НСтр("ru = 'Касса ККМ не выбрана! Возможно не открыта кассовая смена.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		возврат;
	конецесли; 
	ИмяОткрываемойФормы = "Документ.ЧекККМ.Форма.ФормаДокументаРМК";
	
	ПараметрыОткрытияФормы = Новый Структура("Основание", Новый Структура("КассаККМ", КассаККМ));
	ПараметрыОткрытияФормы.Вставить("Склад",Склад);
	ОткрытьФорму(ИмяОткрываемойФормы, ПараметрыОткрытияФормы);
КонецПроцедуры

Функция КассаРаботаетЧерезАтолСервер(НаименованиеКассы)
	
	Возврат 	
		СтрНайти(НаименованиеКассы, 	"КСО") > 0
		Или СтрНайти(НаименованиеКассы, "МЕНЕДЖЕРОВ") > 0
		Или СтрНайти(НаименованиеКассы, "Сайт") > 0;
	
КонецФункции

