&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ)
	
	Если Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните подразделение пользователя");
		Отказ = Истина;
	КонецЕсли;
	
	Если Не Отказ И Не ЭтоНовый() И Недействителен И ЗначениеЗаполнено(Справочники.Пользователи.СписокМестИспользования(Ссылка)) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
			"Необходимо очистить список мест с данным сотрудником!", 
			, 
			, 
			, 
			Отказ);
	КонецЕсли;
	
КонецПроцедуры

