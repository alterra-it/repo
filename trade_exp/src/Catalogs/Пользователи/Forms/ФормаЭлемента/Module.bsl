
&НаСервере
Функция ПроверитьОтделы() 
	Отделы = УправлениеСвойствами.ЗначениеСвойства(Объект.Ссылка, ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Отделы"));
	Если ЗначениеЗаполнено(Отделы) Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;	
КонецФункции

&НаКлиенте
Процедура Док_ПередЗакрытиемПеред(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если Не Объект.Недействителен Тогда
		Если Не ПроверитьОтделы() И ЗначениеЗаполнено(Объект.Ссылка) Тогда  
			Отказ = Истина;
			Сообщить("Дополнительное сведение Отделы, должно быть заполнено!!!"); 
			ПараметрыФормы = Новый Структура("Ссылка",Объект.Ссылка); 
			ОткрытьФорму("ОбщаяФорма.РедактированиеДополнительныхСведений",ПараметрыФормы,ЭтаФорма,Ложь);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Если РольДоступна("РедактированиеПочтыПользователей") или  РольДоступна("полныеправа") Тогда
		Элементы.КонтактнаяИнформацияПолеEmailПользователя.Доступность=Истина;
		Элементы.ГруппаКонтактнаяИнформацияПолеEmailПользователя.Доступность=Истина;
	КонецЕсли;
КонецПроцедуры

