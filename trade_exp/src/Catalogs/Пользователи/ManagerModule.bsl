	
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
Функция СписокМестИспользования(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =                         
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Пользователь КАК Пользователь,
		|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Сотрудники.ПометкаУдаления КАК ПометкаУдаления,
		|	Сотрудники.Уволен КАК Уволен
		|ПОМЕСТИТЬ ВТСотрудники
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	&Условие
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Пользователь КАК Пользователь,
		|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТДействующиеСотрудники
		|ИЗ
		|	ВТСотрудники КАК Сотрудники
		|ГДЕ
		|	НЕ Сотрудники.ПометкаУдаления
		|	И НЕ Сотрудники.Уволен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Пользователь КАК Пользователь,
		|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТУволенныеСотрудники
		|ИЗ
		|	ВТСотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Уволен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УволенныеСотрудники.Ссылка КАК Сотрудник,
		|	Пользователи.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТУволенныеПользователи
		|ИЗ
		|	ВТУволенныеСотрудники КАК УволенныеСотрудники
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
		|		ПО УволенныеСотрудники.Пользователь = Пользователи.Ссылка
		|ГДЕ
		|	НЕ Пользователи.Ссылка В
		|				(ВЫБРАТЬ
		|					ВТДействующиеСотрудники.Пользователь КАК Пользователь
		|				ИЗ
		|					ВТДействующиеСотрудники)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УволенныеСотрудники.Ссылка КАК Сотрудник,
		|	ФизЛица.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТУволенныеФизЛица
		|ИЗ
		|	ВТУволенныеСотрудники КАК УволенныеСотрудники
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизЛица
		|		ПО УволенныеСотрудники.ФизическоеЛицо = ФизЛица.Ссылка
		|ГДЕ
		|	НЕ ФизЛица.Ссылка В
		|				(ВЫБРАТЬ
		|					ВТДействующиеСотрудники.ФизическоеЛицо КАК ФизическоеЛицо
		|				ИЗ
		|					ВТДействующиеСотрудники)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Отделы.Ссылка КАК Ссылка,
		|	Сотрудники.Ссылка КАК Сотрудник,
		|	""Справочник 'Отделы', реквизит 'Руководитель'"" КАК МестоИспользования,
		|	""Руководитель"" КАК НазваниеРеквизита,
		|	""Ссылка"" КАК НеобходимыйСправочникДляЗаписи
		|ИЗ
		|	Справочник.Отделы КАК Отделы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеСотрудники КАК Сотрудники
		|		ПО Отделы.Руководитель = Сотрудники.Ссылка
		|ГДЕ
		|	НЕ Отделы.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РабочиеУчастки.Ссылка,
		|	Сотрудники.Ссылка,
		|	""Справочник 'Рабочие участки', реквизит 'Руководитель'"",
		|	""Руководитель"",
		|	""Ссылка""
		|ИЗ
		|	Справочник.РабочиеУчастки КАК РабочиеУчастки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеСотрудники КАК Сотрудники
		|		ПО РабочиеУчастки.Руководитель = Сотрудники.Ссылка
		|ГДЕ
		|	НЕ РабочиеУчастки.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтруктураПредприятия.Ссылка,
		|	Пользователи.Сотрудник,
		|	""Справочник 'Структура предприятия', реквизит 'Бухгалтер подразделения'"",
		|	""БухгалтерПодразделения"",
		|	""Пользователь""
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеПользователи КАК Пользователи
		|		ПО СтруктураПредприятия.БухгалтерПодразделения = Пользователи.Ссылка
		|ГДЕ
		|	СтруктураПредприятия.БухгалтерПодразделения <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|	И НЕ СтруктураПредприятия.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтруктураПредприятия.Ссылка,
		|	Пользователи.Сотрудник,
		|	""Справочник 'Структура предприятия', реквизит 'Администратор ТЗ'"",
		|	""АдминистраторТЗ"",
		|	""Пользователь""
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеПользователи КАК Пользователи
		|		ПО СтруктураПредприятия.АдминистраторТЗ = Пользователи.Ссылка
		|ГДЕ
		|	СтруктураПредприятия.АдминистраторТЗ <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|	И НЕ СтруктураПредприятия.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтруктураПредприятия.Ссылка,
		|	Пользователи.Сотрудник,
		|	""Справочник 'Структура предприятия', реквизит 'Управляющий ТСК'"",
		|	""УправляющийТСК"",
		|	""Пользователь""
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеПользователи КАК Пользователи
		|		ПО СтруктураПредприятия.УправляющийТСК = Пользователи.Ссылка
		|ГДЕ
		|	СтруктураПредприятия.УправляющийТСК <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|	И НЕ СтруктураПредприятия.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтруктураПредприятия.Ссылка,
		|	ФизЛица.Сотрудник,
		|	""Справочник 'Структура предприятия', реквизит 'Руководитель подразделения'"",
		|	""ТекущийРуководитель"",
		|	""ФизическоеЛицо""
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеФизЛица КАК ФизЛица
		|		ПО СтруктураПредприятия.ТекущийРуководитель = ФизЛица.Ссылка
		|ГДЕ
		|	СтруктураПредприятия.ТекущийРуководитель <> ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)
		|	И НЕ СтруктураПредприятия.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РассылкиОтчетов.Ссылка,
		|	Пользователи.Сотрудник,
		|	""Справочник 'Рассылки отчетов', реквизит 'Ответственный'"",
		|	""Автор"",
		|	""Пользователь""
		|ИЗ
		|	Справочник.РассылкиОтчетов КАК РассылкиОтчетов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУволенныеПользователи КАК Пользователи
		|		ПО РассылкиОтчетов.Автор = Пользователи.Ссылка
		|ГДЕ
		|	РассылкиОтчетов.Подготовлена
		|	И РассылкиОтчетов.Автор <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|	И НЕ РассылкиОтчетов.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудник,
		|	Ссылка";
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст, 
			"&Условие", 
			"Сотрудники.Ссылка = &Ссылка ИЛИ Сотрудники.Пользователь = &Ссылка ИЛИ Сотрудники.ФизическоеЛицо = &Ссылка");
			
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Иначе
		Запрос.Текст = СтрЗаменить(
			Запрос.Текст, 
			"&Условие", 
			"ИСТИНА");
	КонецЕсли;
	
	Возврат Запрос.Выполнить().Выгрузить();
 
КонецФункции

#КонецЕсли

