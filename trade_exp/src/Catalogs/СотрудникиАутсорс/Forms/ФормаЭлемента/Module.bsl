
&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	НомерТелефона = Объект.НомерТелефона;
	СтрокаЧисел = 0;
	Для Индекс = 1 По СтрДлина(НомерТелефона) Цикл
		Символ = Сред(НомерТелефона, Индекс, 1);
		Если КодСимвола(Символ) >= 48 И КодСимвола(Символ) <= 57 Тогда
			СтрокаЧисел = СтрокаЧисел + 1;
		КонецЕсли;
	КонецЦикла;
	Если НомерТелефона <> "" Тогда
		Если СтрокаЧисел <> 11 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не верно заполнен номер телефона");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры