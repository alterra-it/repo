#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&После("ОбработкаПолученияДанныхВыбора")
Процедура Док_ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)

	если Параметры.Отбор.Свойство("ДатаОтбора") и ДопМодуль.НовоеЦенообразованиеЗакупа(Параметры.Отбор.ДатаОтбора) и Параметры.Отбор.Свойство("Подразделение") тогда 
		
		СтандартнаяОбработка = Ложь;
		ДанныеВыбора = Новый СписокЗначений;
		
		Запрос = Новый Запрос(
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВидыЦенПоставщиков.Ссылка КАК ВидЦен
		|ИЗ
		|	Справочник.ВидыЦенПоставщиков КАК ВидыЦенПоставщиков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|		ПО ВидыЦенПоставщиков.РегионПрисутствия = СтруктураПредприятия.РегионПрисутствия
		|			И ВидыЦенПоставщиков.ФорматПодразделения = СтруктураПредприятия.ФорматПодразделения
		|ГДЕ
		|	&ПодстановкаЦенаВключаетНДС
		|	И ВидыЦенПоставщиков.Владелец = &Владелец                      
		|	И СтруктураПредприятия.ссылка = &Подразделение                      
		|	И ВидыЦенПоставщиков.ГруппаВидовЦен = &ГруппаВидовЦен");   
		
		Запрос.УстановитьПараметр("Подразделение", Параметры.Отбор.Подразделение);
		Запрос.УстановитьПараметр("Владелец", Параметры.Отбор.Владелец);
		Запрос.УстановитьПараметр("ГруппаВидовЦен", Параметры.Отбор.ГруппаВидовЦен);
		
		
		// Если в параметрах передан отбор по реквизиту "ЦенаВключаетНДС"
		Если Параметры.Отбор.Свойство("ЦенаВключаетНДС") Тогда
			Запрос.Текст=Стрзаменить(Запрос.Текст,"&ПодстановкаЦенаВключаетНДС","ВидыЦенПоставщиков.ЦенаВключаетНДС = &ЦенаВключаетНДС");
			Запрос.УстановитьПараметр("ЦенаВключаетНДС", Параметры.Отбор.ЦенаВключаетНДС); 
		иначе
			Запрос.Текст=Стрзаменить(Запрос.Текст,"&ПодстановкаЦенаВключаетНДС","истина");
		КонецЕсли;
		
		ДанныеВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВидЦен"));
		
		ДанныеВыбора.Добавить(Справочники.ВидыЦен.ПустаяСсылка(), НСтр("ru='<произвольная>'")); 
	конецесли
	
	
КонецПроцедуры
  
#КонецЕсли         
  
  