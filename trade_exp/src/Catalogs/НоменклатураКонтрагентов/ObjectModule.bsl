
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ)
	ВладелецНоменклатуры = Владелец;
	
	Если Не Отказ И Не ЭтоГруппа И Не Недействителен Тогда
		Если ПометкаУдаления Тогда
			Недействителен = Истина;
		ИначеЕсли ЗначениеЗаполнено(Номенклатура) И ЗначениеЗаполнено(Владелец) И Не Владелец.Парсинг Тогда
			ЗаполнитьУпаковку();
			ПроверитьНаДубли(Отказ);
			ЗаполнитьИдентификатор(Отказ);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ЗаполнитьУпаковку()
	
	Если Не ЗначениеЗаполнено(Упаковка) Тогда
		СвойстваНоменклатурИБ = СопоставлениеНоменклатурыКонтрагентовСлужебный.СвойстваНоменклатурыИнформационнойБазы(Номенклатура);
		СвойстваНоменклатуры  = СвойстваНоменклатурИБ[Номенклатура];
		
		ЕдиницаИзмеренияПоУмолчанию = СвойстваНоменклатуры.ЕдиницаИзмеренияПоУмолчанию;
		Если ЗначениеЗаполнено(ЕдиницаИзмеренияПоУмолчанию) Тогда
			Упаковка = ЕдиницаИзмеренияПоУмолчанию;
		Иначе
			СопоставлениеНоменклатурыКонтрагентовПереопределяемый.БазоваяЕдиницаИзмеренияНоменклатуры(Номенклатура, ЕдиницаИзмеренияПоУмолчанию);
			Если ЗначениеЗаполнено(ЕдиницаИзмеренияПоУмолчанию) Тогда
				Упаковка = ЕдиницаИзмеренияПоУмолчанию;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьНаДубли(Отказ)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	НоменклатураКонтрагентов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.НоменклатураКонтрагентов КАК НоменклатураКонтрагентов
		|ГДЕ
		|	НЕ НоменклатураКонтрагентов.ЭтоГруппа
		|	И НЕ НоменклатураКонтрагентов.ПометкаУдаления
		|	И НЕ НоменклатураКонтрагентов.Недействителен
		|	И НоменклатураКонтрагентов.Ссылка <> &Ссылка
		|	И НоменклатураКонтрагентов.Владелец = &Владелец
		|	И НоменклатураКонтрагентов.Номенклатура = &Номенклатура
		|	И НоменклатураКонтрагентов.Характеристика = &Характеристика
		|	И НоменклатураКонтрагентов.Упаковка = &Упаковка";
	
	Запрос.УстановитьПараметр("Ссылка"        , Ссылка);
	Запрос.УстановитьПараметр("Владелец"	  , Владелец);
	Запрос.УстановитьПараметр("Номенклатура"  , Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Запрос.УстановитьПараметр("Упаковка"      , Упаковка);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		ОбщегоНазначения.СообщитьПользователю(
			СтрШаблон("Найдена номенклатура '%1', для которой заданы аналогичные свойства (Партнер, Номенклатура, Характеристика, Упаковка)", РезультатЗапроса.Ссылка), 
			РезультатЗапроса.Ссылка, 
			, 
			, 
			Отказ);
			
		ДополнительныеСвойства.Вставить("ОбнаруженоДублированиеКлючевыхЗначений", РезультатЗапроса.Ссылка);
	КонецЕсли;
	
КонецПроцедуры             

Процедура ЗаполнитьИдентификатор(Отказ)
	
	Если Не Отказ И (Не ЗначениеЗаполнено(Идентификатор)
		Или Номенклатура <> Ссылка.Номенклатура
		Или Характеристика <> Ссылка.Характеристика
		Или Упаковка <> Ссылка.Упаковка
		Или ДополнительныеСвойства.Свойство("ПерезаписатьИдентификатор")) Тогда

		Идентификатор = Справочники.НоменклатураКонтрагентов.ИдентификаторНоменклатурыКонтрагентаПоНаименованию(Номенклатура, Характеристика, Упаковка);	
		
		Идентификаторы = Новый Структура;
		Идентификаторы.Вставить("ИдентификаторНоменклатуры"  , "");
		Идентификаторы.Вставить("ИдентификаторХарактеристики", "");
		Идентификаторы.Вставить("ИдентификаторУпаковки"      , "");
		
		СопоставлениеНоменклатурыКонтрагентовКлиентСервер.РазделитьИдентификаторНаЧасти(Идентификатор, Идентификаторы);

		ИдентификаторНоменклатуры   = Идентификаторы.ИдентификаторНоменклатуры;
		ИдентификаторХарактеристики = Идентификаторы.ИдентификаторХарактеристики;
		ИдентификаторУпаковки       = Идентификаторы.ИдентификаторУпаковки;	
		
	КонецЕсли;
	
КонецПроцедуры

#КонецЕсли
