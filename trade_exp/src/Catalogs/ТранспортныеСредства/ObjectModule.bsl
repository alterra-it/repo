Процедура Спр_УстановитьФотографию(АдресФотографии) Экспорт
	Если ЗначениеЗаполнено(АдресФотографии) Тогда
		ДанныеФото= ПолучитьИзВременногоХранилища(АдресФотографии);
		Если ЗначениеЗаполнено(ДанныеФото) Тогда
			_Фотография = Новый ХранилищеЗначения(ДанныеФото);
		КонецЕсли;
	Иначе
		_Фотография = Неопределено;
	КонецЕсли;
	
	Если _Фотография<>Неопределено Тогда
		СтароеКоличествоФотографий = Фотографии.Количество();
		Если СтароеКоличествоФотографий > 0 Тогда
			НазваниеПоследнегоФото = Фотографии[СтароеКоличествоФотографий-1].Название;
			НомерПоследнегоФото = Число(Прав(НазваниеПоследнегоФото, СтрДлина(НазваниеПоследнегоФото)-5));
		Иначе
			НомерПоследнегоФото = 0;
		КонецЕсли;
		НовоеФото = Фотографии.Добавить();
		НовоеФото.Фотография = _Фотография;
		НовоеФото.Название = "Фото_"+Строка(НомерПоследнегоФото+1);
		Записать();
	КонецЕсли;
КонецПроцедуры

Процедура Спр_УдалитьФотографию(ИндексКартинки) Экспорт
	Фотографии.Удалить(ИндексКартинки);
	Записать();
КонецПроцедуры

