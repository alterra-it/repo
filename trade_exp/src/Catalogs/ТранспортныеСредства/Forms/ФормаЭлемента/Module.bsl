
&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	//Добавление картинки на форму--
	//добавление реквизитов
	ДобавляемыеРеквизиты = Новый Массив;
	ТипРеквизитовСтр = Новый ОписаниеТипов("Строка");
	АдресФотографии = Новый РеквизитФормы("_АдресФотографии", ТипРеквизитовСтр);
	ДобавляемыеРеквизиты.Добавить(АдресФотографии);
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	//добавление групп и элементов
	ГруппаФотография = Элементы.Добавить("_ГруппаФотография", Тип("ГруппаФормы"));//, Элементы.ГруппаРасходы);
	ГруппаФотография.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФотография.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаФотография.ОтображатьЗаголовок = Ложь;
	
	ГруппаКомандыФотографии = Элементы.Добавить("_ГруппаКомандыФотографии", Тип("ГруппаФормы"), Элементы._ГруппаФотография);
	ГруппаКомандыФотографии.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКомандыФотографии.ОтображатьЗаголовок = Истина;
	ГруппаКомандыФотографии.Заголовок = "Фотографии";
	
	ГруппаФотография = Элементы.Добавить("_ГруппаВыборФото", Тип("ГруппаФормы"), Элементы._ГруппаФотография);
	ГруппаФотография.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФотография.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	ГруппаФотография.ОтображатьЗаголовок = Ложь;
		
	ПолеКартинки = Элементы.Добавить("_Картинка", Тип("ПолеФормы"), Элементы._ГруппаВыборФото);
	ПолеКартинки.Вид = ВидПоляФормы.ПолеКартинки;
	ПолеКартинки.Заголовок = "Фотография";
	ПолеКартинки.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПолеКартинки.РазмерКартинки = РазмерКартинки.АвтоРазмер;
	ПолеКартинки.СпособПеретаскиванияФайлов = СпособПеретаскиванияФайлов.КакФайл;
	ПолеКартинки.ПутьКДанным = "_Картинка";
	ПолеКартинки.Ширина = 2;
	
	ТаблицаФотографий = Элементы.Добавить("_ТаблицаФотографии", Тип("ТаблицаФормы"), Элементы._ГруппаВыборФото);
	ТаблицаФотографий.ПутьКДанным = "Объект.Фотографии";
	ТаблицаФотографий.КоманднаяПанель.Видимость = Ложь;
	ТаблицаФотографий.ИзменятьСоставСтрок = Ложь;
	ТаблицаФотографий.УстановитьДействие("ПриАктивизацииСтроки", "_ПриАктивизацииСтроки_ТаблицаФотографии");
	ТаблицаФотографий.Ширина = 1;
	
	КолонкаНаименование = Элементы.Добавить("_ТаблицаФотографииНазвание", Тип("ПолеФормы"), Элементы._ТаблицаФотографии);
	КолонкаНаименование.ПутьКДанным = "Объект.Фотографии.Название";
		
	//добавить команд
	КомандаДобавитьФото = Команды.Добавить("ДобавитьФотографию");
	КомандаДобавитьФото.Заголовок = "Добавить фотографию";
	КомандаДобавитьФото.Действие = "КомандаДобавитьФотографию";
	
	КомандаУдалитьФото = Команды.Добавить("УдалитьФотографию");
	КомандаУдалитьФото.Заголовок = "Удалить фотографию";
	КомандаУдалитьФото.Действие = "КомандаУдалитьФотографию";
	
	//добавление кнопок
	КнопкаДобавитьФото = Элементы.Добавить("_ДобавитьФотографию", Тип("КнопкаФормы"), Элементы._ГруппаКомандыФотографии);
	КнопкаДобавитьФото.Заголовок = "Добавить фотографию";
	КнопкаДобавитьФото.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	КнопкаДобавитьФото.ИмяКоманды = "ДобавитьФотографию";
	КнопкаДобавитьФото.Отображение = ОтображениеКнопки.КартинкаИТекст;
	КнопкаДобавитьФото.Картинка = БиблиотекаКартинок.СоздатьЭлементСписка;
	
	КнопкаУдалитьФото = Элементы.Добавить("_УдалитьФотографию", Тип("КнопкаФормы"), Элементы._ГруппаКомандыФотографии);
	КнопкаУдалитьФото.Заголовок = "Удалить фотографию";
	КнопкаУдалитьФото.Вид = ВидКнопкиФормы.ОбычнаяКнопка;
	КнопкаУдалитьФото.ИмяКоманды = "УдалитьФотографию";
	КнопкаУдалитьФото.Отображение = ОтображениеКнопки.КартинкаИТекст;
	КнопкаУдалитьФото.Картинка = БиблиотекаКартинок.УдалитьЭлементСписка;
	
	//загрузка картинки из базы
	//получить картинки
	Для каждого Фото из Объект.Ссылка.Фотографии Цикл
		_СписокКартинок.Добавить(ПоместитьВоВременноеХранилище(Фото.Фотография.Получить(), УникальныйИдентификатор));
	КонецЦикла;
	
	ОбновитьКартинку();
	//--Добавление картинки на форму
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаДобавитьФотографию(Команда)
	АдресХранилища= "";
	ВыбранноеИмяФайла="";
	Если ПоместитьФайл (АдресХранилища,,ВыбранноеИмяФайла,Истина) Тогда
		ДанныеФото = Новый ДвоичныеДанные(ВыбранноеИмяФайла);
		_АдресФотографии = ПоместитьВоВременноеХранилище(ДанныеФото, УникальныйИдентификатор);
		_СписокКартинок.Добавить(_АдресФотографии);
		_Картинка = _АдресФотографии;
		УстановитьФотографиюСервер(_АдресФотографии);
		Если Элементы._ТаблицаФотографии.ТекущиеДанные<>Неопределено Тогда
			Элементы._ТаблицаФотографии.ТекущаяСтрока = Объект.Фотографии.Количество();
		КонецЕсли;
		ЭтаФорма.Прочитать();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КомандаУдалитьФотографию(Команда)
	_Картинка = Неопределено;
	ИндексКартинки = Элементы._ТаблицаФотографии.ТекущиеДанные.НомерСтроки-1;
	_СписокКартинок.Удалить(ИндексКартинки);
	УдалитьФотографиюСервер(ИндексКартинки);
	НоваяСтрокаПозиционирования = Объект.Фотографии.Количество()-2;
	Если НоваяСтрокаПозиционирования>=0 Тогда
		Элементы._ТаблицаФотографии.ТекущаяСтрока = НоваяСтрокаПозиционирования;
	КонецЕсли;
	ОбновитьКартинку(НоваяСтрокаПозиционирования+1);
	ЭтаФорма.Прочитать();
КонецПроцедуры 

&НаСервере
Процедура УстановитьФотографиюСервер(АдресФотографии)
	ОБ= РеквизитФормыВЗначение("Объект");
	ОБ.Спр_УстановитьФотографию(АдресФотографии);
КонецПроцедуры

&НаСервере
Процедура УдалитьФотографиюСервер(НазваниеФото)
	ОБ= РеквизитФормыВЗначение("Объект");
	ОБ.Спр_УдалитьФотографию(НазваниеФото);
КонецПроцедуры

&НаКлиенте
Процедура _ПриАктивизацииСтроки_ТаблицаФотографии(Элемент)
	Если Элемент.ТекущиеДанные <> Неопределено Тогда 
		НоваяСтр = Элемент.ТекущиеДанные.НомерСтроки;
		СтараяСтр = Элемент.ТекущаяСтрока;
		Если НоваяСтр<>СтараяСтр Тогда
			ОбновитьКартинку(НоваяСтр);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьКартинку(НомерСтроки=1)
	Если Объект.Ссылка.Фотографии.Количество() > 0 И НомерСтроки>0 Тогда
		СсылкаНаДвоичныеДанныеФайла = _СписокКартинок[НомерСтроки-1].Значение;
		_Картинка = СсылкаНаДвоичныеДанныеФайла;
		_АдресФотографии = _Картинка;
	Иначе
		_Картинка = "";
	КонецЕсли;
КонецПроцедуры 
