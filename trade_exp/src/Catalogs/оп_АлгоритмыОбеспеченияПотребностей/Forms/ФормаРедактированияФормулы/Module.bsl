Процедура ПоказателиНачалоПеретаскивания(Элемент, ПараметрыПеретаскивания, Выполнение)
	// Вставить содержимое обработчика.
	
	Если Элемент.Имя = "Показатели" Тогда
		Идентификатор = ?(ПоказательСПараметром(Элемент.ТекущиеДанные.Показатель),ВозвратитьИдентификатор(Элемент.ТекущиеДанные.Показатель)+"[]",ВозвратитьИдентификатор(Элемент.ТекущиеДанные.Показатель));
		ПараметрыПеретаскивания.Значение = СокрЛП(Идентификатор);
	Иначе
		Выполнение = Ложь;
	КонецЕсли;

КонецПроцедуры

