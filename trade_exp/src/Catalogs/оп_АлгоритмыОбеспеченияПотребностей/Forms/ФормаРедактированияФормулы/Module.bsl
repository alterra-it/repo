&НаСервере
Процедура ПроверитьФормулуНаСервере()
	ПараметрыТовара=Новый Структура();
	ПараметрыТовара.Вставить("Номенклатура",Номенклатура);
	ПараметрыТовара.Вставить("Характеристика",Характеристика);
	ПараметрыТовара.Вставить("Склад",Склад);
	
	БазовыеПараметры=Новый Структура();
	БазовыеПараметры.Вставить("ТекущаяДата",ТекущаяДата);
	БазовыеПараметры.Вставить("СрокПоставки",СрокПоставки);
	БазовыеПараметры.Вставить("ОбеспечиваемыйПериод",ОбеспечиваемыйПериод);
	БазовыеПараметры.Вставить("Датапоставки",ДатаПоставки);
	БазовыеПараметры.Вставить("МаксЗапас",МаксимальныйЗапас);
	БазовыеПараметры.Вставить("МинЗапас",МинимальныйЗапас);
	БазовыеПараметры.Вставить("ОстатокНаСкладе",Остаток);
	БазовыеПараметры.Вставить("ЗаказыКПоступлению",ЗаказыКПоступлению);
	БазовыеПараметры.Вставить("ТрендПараметр",ТрендПараметр);
	БазовыеПараметры.Вставить("ИспользоватьПеремещения",ИспользоватьПеремещения);
	
	Алгоритм=Новый Структура();
	Алгоритм.Вставить("Показатели",Показатели.Выгрузить());
	если типФормулы=0 тогда 
		Алгоритм.Вставить("ВидФормулыМакс",ВидФормулы);
		Алгоритм.Вставить("ФормулаМакс",Формула);
	иначе
		Алгоритм.Вставить("ВидФормулыМин",ВидФормулы);
		Алгоритм.Вставить("ФормулаМин",Формула);
	конецесли;	
	Результат=Справочники.оп_АлгоритмыОбеспеченияПотребностей.РезультатРасчета(ПараметрыТовара,БазовыеПараметры,Алгоритм,типФормулы);	
КонецПроцедуры



