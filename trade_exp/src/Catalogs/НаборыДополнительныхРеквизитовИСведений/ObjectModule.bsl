
&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ)
	ТЧ_ДополнительныеСведения_УдалитьДубли(Отказ);
КонецПроцедуры

Процедура ТЧ_ДополнительныеСведения_УдалитьДубли(Отказ)  
	Если Не Отказ И ЗначениеЗаполнено(ДополнительныеСведения) Тогда 
		КолонкиГруппировок = "Свойство, ПометкаУдаления, ИмяПредопределенногоНабора";	
		ТЗ = ДополнительныеСведения.Выгрузить( , КолонкиГруппировок);  
		ТЗ.Свернуть(КолонкиГруппировок);
		ДополнительныеСведения.Загрузить(ТЗ); 
	КонецЕсли;
КонецПроцедуры


