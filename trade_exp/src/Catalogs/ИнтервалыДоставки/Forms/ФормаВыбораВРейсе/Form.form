  <attributes>
    <name>Список</name>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СУММА(КолДоставок.КолЗаказов) КАК КолЗаказов,
	СУММА(КолДоставок.КолЗаказовСРазгрузкой) КАК КолЗаказовСРазгрузкой,
	КолДоставок.Интервал КАК Интервал
ПОМЕСТИТЬ КолДоставок
ИЗ
	(ВЫБРАТЬ
		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказНаДоставкуКлиенту.Ссылка) КАК КолЗаказов,
		ЗаказНаДоставкуКлиенту.Интервал КАК Интервал,
		0 КАК КолЗаказовСРазгрузкой
	ИЗ
		Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
	ГДЕ
		ЗаказНаДоставкуКлиенту.Проведен
		И ЗаказНаДоставкуКлиенту.Подразделение = &amp;Подразделение
		И ЗаказНаДоставкуКлиенту.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)
		И НАЧАЛОПЕРИОДА(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ДЕНЬ) = НАЧАЛОПЕРИОДА(&amp;ДатаОтгрузки, ДЕНЬ)
	
	СГРУППИРОВАТЬ ПО
		ЗаказНаДоставкуКлиенту.Интервал
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		0,
		ЗаказНаДоставкуКлиенту.Интервал,
		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказНаДоставкуКлиенту.Ссылка)
	ИЗ
		Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
	ГДЕ
		ЗаказНаДоставкуКлиенту.Проведен
		И ЗаказНаДоставкуКлиенту.Подразделение = &amp;Подразделение
		И ЗаказНаДоставкуКлиенту.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)
		И НАЧАЛОПЕРИОДА(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ДЕНЬ) = НАЧАЛОПЕРИОДА(&amp;ДатаОтгрузки, ДЕНЬ)
		И ЗаказНаДоставкуКлиенту.ДоставкаСРазгрузкой
	
	СГРУППИРОВАТЬ ПО
		ЗаказНаДоставкуКлиенту.Интервал) КАК КолДоставок

СГРУППИРОВАТЬ ПО
	КолДоставок.Интервал
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ИнтервалыДоставки.Ссылка КАК Ссылка,
	ИнтервалыДоставки.Наименование КАК Наименование,
	ИнтервалыДоставки.Подразделение КАК Подразделение,
	ИнтервалыДоставки.ВремяС КАК ВремяС,
	ИнтервалыДоставки.ВремяПо КАК ВремяПо,
	ИнтервалыДоставки.КоличествоДоставок КАК КоличествоДоставок,
	ИнтервалыДоставки.ДеньНедели КАК ДЕНЬНЕДЕЛИ,
	ИнтервалыДоставки.ИнтервалЗакрытия КАК ИнтервалЗакрытия,
	выбор когда &amp;ДоставкаСРазгрузкой тогда ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке иначе ДатаВремя(1,1,1) Конец КАК ЗакрытиеИнтервалаПоРазгрузке,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой КАК МксКолДоставокСРазгрузкой
ПОМЕСТИТЬ ИнтервалыДоставки
ИЗ
	Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
ГДЕ
	ИнтервалыДоставки.Подразделение = &amp;Подразделение
	И ИнтервалыДоставки.ДеньНедели = &amp;ДеньНедели
	И ИнтервалыДоставки.ПометкаУдаления = ЛОЖЬ
	И ИнтервалыДоставки.ВидДоставки = &amp;ВидДоставки
	И &amp;ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ИнтервалыДоставки.Ссылка,
	ИнтервалыДоставки.Наименование,
	ИнтервалыДоставки.Подразделение,
	ИнтервалыДоставки.ВремяС,
	ИнтервалыДоставки.ВремяПо,
	ИнтервалыДоставки.КоличествоДоставок,
	ИнтервалыДоставки.ДеньНедели,
	ИнтервалыДоставки.ИнтервалЗакрытия,
	выбор когда &amp;ДоставкаСРазгрузкой Тогда ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке иначе ДатаВремя(1,1,1) Конец,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой
ИЗ
	Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
ГДЕ
	ИнтервалыДоставки.Подразделение = &amp;Подразделение
	И ИнтервалыДоставки.ДеньНедели = 0
	И ИнтервалыДоставки.ПометкаУдаления = ЛОЖЬ
	И &amp;ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.СборнаяОРК)
	И ИнтервалыДоставки.ВидДоставки = &amp;ВидДоставки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ИнтервалыДоставки.Ссылка,
	ИнтервалыДоставки.Наименование,
	ИнтервалыДоставки.Подразделение,
	ИнтервалыДоставки.ВремяС,
	ИнтервалыДоставки.ВремяПо,
	ИнтервалыДоставки.КоличествоДоставок,
	ИнтервалыДоставки.ДеньНедели,
	ИнтервалыДоставки.ИнтервалЗакрытия,
	выбор когда &amp;ДоставкаСРазгрузкой Тогда ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке иначе ДатаВремя(1,1,1) Конец,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой
ИЗ
	Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
ГДЕ
	ИнтервалыДоставки.Подразделение = &amp;Подразделение
	И ИнтервалыДоставки.ДеньНедели = &amp;ДеньНедели
	И ИнтервалыДоставки.ПометкаУдаления = ЛОЖЬ
	И &amp;ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.СборнаяОРК)
	И ИнтервалыДоставки.ВидДоставки = &amp;ВидДоставки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ИнтервалыДоставки.Ссылка,
	ИнтервалыДоставки.Наименование,
	ИнтервалыДоставки.Подразделение,
	ИнтервалыДоставки.ВремяС,
	ИнтервалыДоставки.ВремяПо,
	ИнтервалыДоставки.КоличествоДоставок,
	ИнтервалыДоставки.ДеньНедели,
	ИнтервалыДоставки.ИнтервалЗакрытия,
	выбор когда &amp;ДоставкаСРазгрузкой Тогда ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке иначе ДатаВремя(1,1,1) Конец,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой
ИЗ
	Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
ГДЕ
	ИнтервалыДоставки.Подразделение = &amp;Подразделение
	И ИнтервалыДоставки.ДеньНедели = 0
	И ИнтервалыДоставки.ПометкаУдаления = ЛОЖЬ
	И &amp;ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Внутренняя)
	И ИнтервалыДоставки.ВидДоставки = &amp;ВидДоставки

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ИнтервалыДоставки.Ссылка,
	ИнтервалыДоставки.Наименование,
	ИнтервалыДоставки.Подразделение,
	ИнтервалыДоставки.ВремяС,
	ИнтервалыДоставки.ВремяПо,
	ИнтервалыДоставки.КоличествоДоставок,
	ИнтервалыДоставки.ДеньНедели,
	ИнтервалыДоставки.ИнтервалЗакрытия,
	выбор когда &amp;ДоставкаСРазгрузкой Тогда ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке иначе ДатаВремя(1,1,1) Конец,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой
ИЗ
	Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
ГДЕ
	ИнтервалыДоставки.Подразделение = &amp;Подразделение
	И ИнтервалыДоставки.ДеньНедели = &amp;ДеньНедели
	И ИнтервалыДоставки.ПометкаУдаления = ЛОЖЬ
	И &amp;ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Внутренняя)
	И ИнтервалыДоставки.ВидДоставки = &amp;ВидДоставки
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ИнтервалыДоставки.Ссылка КАК Ссылка,
	ЕСТЬNULL(КорректировкаДоставокВИнтервалах.КоличествоДоставок, ИнтервалыДоставки.КоличествоДоставок) - ЕСТЬNULL(КолДоставок.КолЗаказов, 0) КАК ДоступноНаСегодня,
	ЕСТЬNULL(КорректировкаДоставокВИнтервалахСРазгрузкой.КоличествоДоставок, ИнтервалыДоставки.МксКолДоставокСРазгрузкой) - ЕСТЬNULL(КолДоставок.КолЗаказовСРазгрузкой, 0) КАК ДоступноНаСегодняСРазгрузкой,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой - ЕСТЬNULL(КолДоставок.КолЗаказовСРазгрузкой, 0) КАК ДоступноНаСегодняСРазгрузкой1,
	ИнтервалыДоставки.КоличествоДоставок КАК КоличествоПоУмолчанию,
	ЕСТЬNULL(КорректировкаДоставокВИнтервалах.КоличествоДоставок, 0) КАК СкорректированноеКоличество,
	ЕСТЬNULL(КорректировкаДоставокВИнтервалахСРазгрузкой.КоличествоДоставок, 0) КАК СкорректированноеКоличествоСРазгрузкой,
	ИнтервалыДоставки.МксКолДоставокСРазгрузкой КАК КоличествоСРазгрузкойПоУмолчанию,
	ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(&amp;ДатаОтгрузки, ДЕНЬ), МИНУТА, ЧАС(ИнтервалыДоставки.ВремяС) * 60 + МИНУТА(ИнтервалыДоставки.ВремяС)) КАК ДатаИнтервала,
	ЕСТЬNULL(КолДоставок.КолЗаказов, 0) КАК КолЗаказов,
	ЕСТЬNULL(КолДоставок.КолЗаказовСРазгрузкой, 0) КАК КолЗаказовСРазгрузкой,
	&amp;ТекДата КАК ТекДата,
	ИнтервалыДоставки.Подразделение КАК Подразделение,
	ИнтервалыДоставки.ВремяС КАК ВремяС,
	ИнтервалыДоставки.ВремяПо КАК ВремяПо,
	ИнтервалыДоставки.ДЕНЬНЕДЕЛИ КАК ДЕНЬНЕДЕЛИ,
	выразить(Выбор когда &amp;ДоставкаСРазгрузкой И ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке > ИнтервалыДоставки.ИнтервалЗакрытия Тогда
	   ИнтервалыДоставки.ЗакрытиеИнтервалаПоРазгрузке
	Иначе
	   ИнтервалыДоставки.ИнтервалЗакрытия
	Конец как Число(4,0)) КАК ИнтервалЗакрытия,
	ИнтервалыДоставки.Наименование КАК Наименование,
	КорректировкаДоставокВИнтервалах.ДатаДействия КАК ДатаДействия
ПОМЕСТИТЬ ВТ_Результат1
ИЗ
	ИнтервалыДоставки КАК ИнтервалыДоставки
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаДоставокВИнтервалах КАК КорректировкаДоставокВИнтервалах
		ПО ИнтервалыДоставки.Ссылка = КорректировкаДоставокВИнтервалах.Интервал
			И (НАЧАЛОПЕРИОДА(&amp;ДатаОтгрузки, ДЕНЬ) = НАЧАЛОПЕРИОДА(КорректировкаДоставокВИнтервалах.ДатаДействия, ДЕНЬ))
			И (КорректировкаДоставокВИнтервалах.Проведен)
			И (НЕ КорректировкаДоставокВИнтервалах.ДляРазгрузки)
		ЛЕВОЕ СОЕДИНЕНИЕ КолДоставок КАК КолДоставок
		ПО (КолДоставок.Интервал = ИнтервалыДоставки.Ссылка)
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КорректировкаДоставокВИнтервалах КАК КорректировкаДоставокВИнтервалахСРазгрузкой
		ПО ИнтервалыДоставки.Ссылка = КорректировкаДоставокВИнтервалахСРазгрузкой.Интервал
			И (НАЧАЛОПЕРИОДА(&amp;ДатаОтгрузки, ДЕНЬ) = НАЧАЛОПЕРИОДА(КорректировкаДоставокВИнтервалахСРазгрузкой.ДатаДействия, ДЕНЬ))
			И (КорректировкаДоставокВИнтервалахСРазгрузкой.Проведен)
			И (КорректировкаДоставокВИнтервалахСРазгрузкой.ДляРазгрузки)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Результат1.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА (РАЗНОСТЬДАТ(Результат1.ТекДата, Результат1.ДатаИнтервала, МИНУТА)) &lt; (isnull(Результат1.ИнтервалЗакрытия,0) + &amp;КорИнтервала)
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК МожноВыбрать,
	Результат1.ДоступноНаСегодня КАК ДоступноНаСегодня,
	Результат1.ДоступноНаСегодняСРазгрузкой КАК ДоступноНаСегодняСРазгрузкой,
	Результат1.ДатаИнтервала КАК ДатаИнтервала,
	Результат1.ТекДата КАК ТекДата,
	Результат1.КоличествоПоУмолчанию КАК КоличествоПоУмолчанию,
	ВЫРАЗИТЬ(Результат1.СкорректированноеКоличество КАК ЧИСЛО(3, 0)) КАК СкорректированноеКоличество,
	Результат1.КоличествоСРазгрузкойПоУмолчанию КАК КоличествоСРазгрузкойПоУмолчанию,
	Результат1.СкорректированноеКоличествоСРазгрузкой КАК СкорректированноеКоличествоСРазгрузкой,
	Результат1.КолЗаказов КАК ЗаказовЗаСегодня,
	Результат1.КолЗаказовСРазгрузкой КАК ЗаказовСРазгрузкойЗаСегодя,
	Результат1.ИнтервалЗакрытия КАК ИнтервалЗакрытия,
	РАЗНОСТЬДАТ(Результат1.ТекДата, Результат1.ДатаИнтервала, МИНУТА) КАК РАЗНОСТЬДАТ,
	Результат1.ВремяС КАК ВремяС,
	Результат1.ВремяПо КАК ВремяПо,
	Результат1.ДЕНЬНЕДЕЛИ КАК ДЕНЬНЕДЕЛИ,
	ВЫБОР
		КОГДА (РАЗНОСТЬДАТ(Результат1.ТекДата, Результат1.ДатаИнтервала, МИНУТА)) &lt; (isnull(Результат1.ИнтервалЗакрытия,0) + &amp;КорИнтервала)
		      ИЛИ (Выбор Когда &amp;ДоставкаСРазгрузкой Тогда Результат1.ДоступноНаСегодняСРазгрузкой &lt;= 0 Иначе Результат1.ДоступноНаСегодня &lt;= 0 Конец)
			ТОГДА Истина 		
		ИНАЧЕ Ложь
	КОНЕЦ КАК Закрыт
	Из			
	ВТ_Результат1 КАК Результат1</queryText>
