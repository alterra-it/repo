
&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("ОтборПоДате") Тогда
		Док_ОтобратьПоДате();
	КонецЕсли;
КонецПроцедуры

Процедура Док_ОтобратьПоДате()
    
    //Идентификатор = Список.КомпоновщикНастроек.Настройки.Отбор.ИдентификаторПользовательскойНастройки;
//    Отбор = Список.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы.Найти(Идентификатор);
    
    Отбор = Список.КомпоновщикНастроек.Настройки.Отбор;
    ОтборПоДате = Неопределено;
    ПолеДата = Новый ПолеКомпоновкиДанных("ДатаНачала");
    
    Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл
        
        Если ТипЗнч(ЭлементОтбора = Тип("ЭлементОтбораКомпоновкиДанных")
            И ЭлементОтбора.ЛевоеЗначение = ПолеДата) Тогда
            
            ОтборПодате = ЭлементОтбора;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    Если ОтборПоДате = Неопределено Тогда
        
        ОтборПоДате = Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
        ОтборПоДате.ЛевоеЗначение = ПолеДата;
        ОтборПоДате.Использование = Истина;
        ОтборПоДате.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.БыстрыйДоступ;
        ОтборПоДате.ИдентификаторПользовательскойНастройки = Новый УникальныйИдентификатор;
        ОтборПоДате.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
        ОтборПоДате.ПравоеЗначение = ТекущаяДата() - 2592000;
        
        Элементы.Список.СоздатьЭлементыФормыПользовательскихНастроек();
        
    КонецЕсли;
        
    
КонецПроцедуры