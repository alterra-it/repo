&НаКлиенте
Процедура ОтправитьЧерезРостелеком(Команда)   
	
	ОтправитьСмсРостелеком();     
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьСмсРостелеком()
	
	ГСЧ = Новый ГенераторСлучайныхЧисел();
	СлучайноеЧисло = Формат(ГСЧ.СлучайноеЧисло(1000, 9999),"ЧГ = '0'");  
	КодОтправленный = Строка(СлучайноеЧисло);
	
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);
	
	НастройкиОтправкиSMS = ОтправкаSMS.НастройкиОтправкиSMS();
	ИмяОтправителя = НастройкиОтправкиSMS.ИмяОтправителя;
	
	Если Не ЗначениеЗаполнено(ИмяОтправителя)Тогда
		ИмяОтправителя = "Alterra"; 
	КонецЕсли;
	
	НомерПолучателя = "7" + НомерТелефона;
	Если ТекстСМС <> "" Тогда
		ТекстСообщения = СтрЗаменить(ТекстСМС, "%КодПроверки%", КодОтправленный);
	Иначе
		ТекстСообщения = "Ваш код для списания бонусов - " + КодОтправленный;
	КонецЕсли;   
	
	ОтправкаSMSЧерезРостелеком.ОтправитьНаСервереРостелеком(ИмяОтправителя, НомерПолучателя,ТекстСообщения, Истина, "\\TG-Storage01\Alterra - общая\Харина М.А\ИсторияПоСМСЧерезРостелеком\");
	
КонецПроцедуры 

