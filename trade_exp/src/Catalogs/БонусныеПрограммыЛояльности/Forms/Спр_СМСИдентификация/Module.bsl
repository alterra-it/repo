#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)  
	
	Если ЗначениеЗаполнено(Параметры.Владелец) Тогда
		Владелец = Параметры.Владелец;     
		НомерТелефона = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Владелец, Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	Иначе
		ФИОПартнера 	= ?(Параметры.Свойство("ФИОПартнера"), 			Параметры.ФИОПартнера, 			Ложь);     
		НомерТелефона	= ?(Параметры.Свойство("НомерТелефона"),		Параметры.НомерТелефона, 		Ложь);     
	КонецЕсли;     
	
	ТолькоОтправкаКода 	= ?(Параметры.Свойство("ТолькоОтправкаКода"),	Параметры.ТолькоОтправкаКода,	Ложь);     
	НовыйПартнер 		= ?(Параметры.Свойство("НовыйПартнер"),			Параметры.НовыйПартнер, 		Ложь);     
	ИзменениеТелефона 	= ?(Параметры.Свойство("ИзменениеТелефона"),	Параметры.ИзменениеТелефона, 	Ложь);     
	
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);
	ФорматированныйНомерТелефона = ДопМодульСервер.ФорматированныйНомерТелефона(НомерТелефона);    
	
	Если Параметры.Свойство("Действие") Тогда
		Действие = Параметры.Действие;   
	Иначе
		Действие = "1с_taskmaster_0";	
	КонецЕсли;	
	
	ТолькоСМС = Параметры.Свойство("ИдТолькоСМС");
	ТекстСМС =  ?(Параметры.Свойство("ТекстСМС"), Параметры.ТекстСМС, "");
	
	ИдентификацияЗвонком();

КонецПроцедуры	 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ВосстановитьКэшКлиента();       

	УстановитьНачальнуюСтраницу();
	УстановитьВидимостьПоВидуКлиента(); 
	УстановитьВидимостьПоСсылкеПартнера(); 
	УстановитьВидимостьПоВидуИдентификации(ТолькоСМС);
	
	ВосстановитьВыполнениеИдентификацииЗвонком();

КонецПроцедуры

#КонецОбласти              

#Область ПрименимостьЭлементов  

&НаСервере
Процедура УстановитьНачальнуюСтраницу()      
	
	Если ТолькоОтправкаКода Тогда  
		
		УстановитьВидимостьМеню(2); 
		Элементы.Назад.Видимость = Ложь;
		
	Иначе
		Если ИдентификацияЗвонком[СтатусНеНачиналась()] Тогда
			УстановитьВидимостьМеню(1);
		Иначе
			УстановитьВидимостьМеню(2);
		КонецЕсли;
	КонецЕсли;
	
	ИдентифицироватьПоВидуИдентификации(); 
	
КонецПроцедуры

&НаСервере  
Процедура УстановитьВидимостьМеню(НомерГруппы)
	
	Элементы.ГруппаВыборИдентификации.Видимость = НомерГруппы = 1;
	Элементы.ГруппаИдентификация.Видимость 		= НомерГруппы = 2;
	Элементы.ГруппаИдентификацияПоПин.Видимость	= НомерГруппы = 3;
	
КонецПроцедуры	

&НаСервере  
Процедура УстановитьВидимостьПоВидуКлиента()    
	
	ЭтоБригадир = АльтерраОбщегоНазначения.ЭтоБригадир(Владелец);
	
	Элементы.ИдентификацияПоПинКоду.Доступность	= ЭтоБригадир;
	Элементы.ИдентификацияПоПинКоду.Видимость 	= ЭтоБригадир;
	Элементы.ПредоставленПаспорт.Видимость 		= Не ЭтоБригадир;
	Элементы.ПредоставленПаспорт.Доступность 	= Не ЭтоБригадир;
	
КонецПроцедуры	

&НаСервере  
Процедура УстановитьВидимостьПоВидуИдентификации(ТолькоСМС)
	
	Если ТолькоСМС Тогда
		Элементы.ГруппаВыборИдентификации.Видимость	= Ложь;
		Элементы.ГруппаИдентификацияПоПин.Видимость	= Ложь;
		Элементы.ГруппаИдентификация.Видимость 		= Истина;
	КонецЕсли;		
	
КонецПроцедуры   

&НаСервере
Процедура ИдентифицироватьПоВидуИдентификации()       
	
	Элементы.ИдентифицироватьПоКоду.Заголовок = СтрШаблон("Идентифицировать %1", ?(Не ИдентификацияЗвонком[СтатусЗакончилась()], "звонком", "по смс"));
	Элементы.ГруппаПроцессВыполнения.Видимость 	= ИдентификацияЗвонком[СтатусВыполняется()] Или ИдентификацияЗвонком[СтатусНаПаузе()];
	Элементы.ГруппаОтправкаСмс.Видимость 		= ИдентификацияЗвонком[СтатусЗакончилась()];
		
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьИдентификацииПоКоду() 
	
	Элементы.ИдентифицироватьПоКоду.Доступность = Не (ИдентификацияЗвонком[СтатусВыполняется()] Или ИдентификацияЗвонком[СтатусНаПаузе()]);    
		
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоСсылкеПартнера()

	Элементы.ПартнерГлавная.Видимость 				= Не НовыйПартнер;
	Элементы.ФИОПартнераГлавная.Видимость 			= НовыйПартнер;
	Элементы.ПартнерТелефон.Видимость 				= Не НовыйПартнер;
	Элементы.ФИОПартнераТелефон.Видимость			= НовыйПартнер;
	Элементы.ПартнерПин.Видимость 					= Не НовыйПартнер;
	Элементы.ФИОПартнераПин.Видимость				= НовыйПартнер;
	
	Элементы.ФИОПартнераГлавная.Заголовок 			= ФИОПартнера;
	Элементы.ФИОПартнераТелефон.Заголовок 			= ФИОПартнера;
	Элементы.ФИОПартнераПин.Заголовок 				= ФИОПартнера;  
	
	Элементы.ГруппаЦифрыНомераГлавная.Видимость 	= ИзменениеТелефона;
	Элементы.ФорматНомерТелефонаГлавная.Видимость 	= Не ИзменениеТелефона;
	Элементы.ГруппаЦифрыНомера.Видимость 			= ИзменениеТелефона;
	Элементы.ФорматНомерТелефона.Видимость 			= Не ИзменениеТелефона;
	Элементы.ГруппаЦифрыНомераПин.Видимость 		= ИзменениеТелефона;
	Элементы.ФорматНомерТелефонаПин.Видимость 		= Не ИзменениеТелефона;

КонецПроцедуры

#КонецОбласти 

#Область НавигацияФиксацияРезультата      

&НаКлиенте
Процедура ОтправитьКодНаТелефон(Команда) 
	
	УстановитьВидимостьМеню(2);
	ИдентифицироватьПоВидуИдентификации();  
	ВосстановитьВыполнениеИдентификацииЗвонком();
	
КонецПроцедуры  

&НаКлиенте
Процедура ИдентифицироватьПоКоду(Команда)   

	ИдентифицироватьПоОтправленномуКоду();
	
КонецПроцедуры   

&НаКлиенте
Процедура Выполнено(Команда)             
	
	Если Не КодПолученный = "" И КодПолученный = КодОтправленный Тогда
		ОтменитьОжиданиеЗвонка();
		Результат = Истина;  
		СохранитьКэшКлиента(Не Результат);
		ОбновитьДанныеПартнера(Результат);	  
		Закрыть(Результат);
	Иначе
		ПоказатьОповещениеПользователя(СтрШаблон("Код %1неправильный", ?(ЗначениеЗаполнено(КодПолученный), КодПолученный + " ", "")), , 
			"Введите код, отправленный клиенту", БиблиотекаКартинок.Ошибка32, СтатусОповещенияПользователя.Информация);
	КонецЕсли;       
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПартнера(Результат)  
	
	Если ЗначениеЗаполнено(Владелец) Тогда     
		
		ВладелецОбъект = Владелец.ПолучитьОбъект();
		ВладелецОбъект.ДатаПодтвержденияНомераТелефона = ТекущаяДата();
		ВладелецОбъект.СостояниеНомераТелефона = Перечисления.СостояниеНомераТелефона.Актуален;
		
		Если ИзменениеТелефона Тогда
			Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;    
			Вид = Справочники.ВидыКонтактнойИнформации.ТелефонПартнера;  
			
			Отбор = Новый Структура("Тип,Вид", Тип, Вид); 
			ТЧКонтакты = ВладелецОбъект.КонтактнаяИнформация;
			НайденыеСтроки = ТЧКонтакты.НайтиСтроки(Отбор);
			
			Если НайденыеСтроки.Количество() > 0 Тогда
				СтрКонтакт = НайденыеСтроки[0]; 
				
				Если СтрКонтакт.НомерТелефона <> НомерТелефона Тогда
					СтрКонтакт.НомерТелефона = НомерТелефона;
					СтрКонтакт.НомерТелефонаБезКодов = НомерТелефона;
					СтрКонтакт.Представление = НомерТелефона;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;

		Попытка
		    ВладелецОбъект.Записать();    
			
			Если ИзменениеТелефона Тогда
				Сообщить("Номер телефона успешно обновлен");
			КонецЕсли;
			
		Исключение     
			Результат = Ложь;   
			
			Если ИзменениеТелефона Тогда
				Сообщить("Не удалось записать номер телефона" + Символы.ПС + ОписаниеОшибки());			
			КонецЕсли;
			
			ВызватьИсключение;  
		КонецПопытки; 
	КонецЕсли;
	
КонецПроцедуры    

&НаКлиенте
Процедура Назад(Команда) 
	
	Если ТолькоСмс Тогда
		Закрыть(Ложь);       
	Иначе    
		УстановитьВидимостьМеню(1); 
		ОтменитьОжиданиеЗвонка();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПредоставленПаспорт(Команда)    
	
	Результат = Истина;
	Закрыть(Результат);
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда) 
	
	ОтменитьОжиданиеЗвонка();
	СохранитьКэшКлиента(Не Результат);
	Закрыть(Результат); 
	
КонецПроцедуры  

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)

	ОтменитьОжиданиеЗвонка();
	СохранитьКэшКлиента(Не Результат);
	
КонецПроцедуры

#КонецОбласти     

#Область Кэш     

&НаКлиенте
Процедура ВосстановитьКэшКлиента()   
	
	КэшИдентификацияЗвонком = ?(ЗначениеЗаполнено(КэшИдентификацияЗвонком), КэшИдентификацияЗвонком, СтатусНеНачиналась());
	УстановитьИдентификацию(КэшИдентификацияЗвонком);
	
	// Есть актуальный кэш
	Если КэшНомерТелефона = НомерТелефона И КэшДействие = Действие 
		И Не ИдентификацияЗвонком[СтатусНеНачиналась()] 
		И ТекущаяДата() - ?(ЗначениеЗаполнено(КэшВремяСохранения), КэшВремяСохранения,  Дата(1, 1, 1)) < 60 Тогда 

		КодОтправленный 		= КэшКодВерификации;
		Прогресс 				= КэшПрогресс;
		ПрошлоСекунд 			= КэшПрошлоСекунд;
		ОсталосьСекунд 			= КэшОсталосьСекунд;

	// Очистить кэш
	Иначе                 
		КэшИдентификацияЗвонком	= СтатусНеНачиналась();
		УстановитьИдентификацию(КэшИдентификацияЗвонком);
		КэшВремяСохранения 		= Дата(1, 1, 1);  
		КэшПрогресс 			= 0;  
		КэшПрошлоСекунд 		= 0;  
		КэшОсталосьСекунд		= 0;  
		КэшНомерТелефона 		= НомерТелефона;  
		КэшДействие 			= Действие;
		КэшКодВерификации 		= "";
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьКэшКлиента(СохранитьТекущиеЗначения = Истина) 
	
	Если СохранитьТекущиеЗначения Тогда 
		КэшИдентификацияЗвонком	= ПолучитьИдентификациюЗвонком();   
		КэшВремяСохранения 		= ТекущаяДата();  
		КэшПрогресс 			= Прогресс;  
		КэшПрошлоСекунд 		= ПрошлоСекунд;  
		КэшОсталосьСекунд 		= ОсталосьСекунд;   
		КэшНомерТелефона 		= НомерТелефона;  
		КэшДействие 			= Действие;
		КэшКодВерификации 		= КодОтправленный;
		
	Иначе
		КэшИдентификацияЗвонком	= "";   
		КэшВремяСохранения 		= Дата(1, 1, 1);  
		КэшПрогресс 			= 0;  
		КэшПрошлоСекунд 		= 0;  
		КэшОсталосьСекунд 		= 0;   
		КэшНомерТелефона 		= "";  
		КэшДействие 			= "";
		КэшКодВерификации 		= "";
	КонецЕсли;
		
КонецПроцедуры		

#КонецОбласти  

#Область Параметры

&НаСервере
Функция ИдентификацияЗвонком()  

	ИдентификацияЗвонком = Новый Структура;
	ИдентификацияЗвонком.Вставить(СтатусНеНачиналась(),	Истина);
	ИдентификацияЗвонком.Вставить(СтатусВыполняется(), 	Ложь);
	ИдентификацияЗвонком.Вставить(СтатусНаПаузе(), 		Ложь);
	ИдентификацияЗвонком.Вставить(СтатусЗакончилась(), 	Ложь); 
	
КонецФункции   

&НаСервере
Функция СтатусНеНачиналась()
	
	Возврат "НеНачиналась"
	
КонецФункции

&НаСервере
Функция СтатусВыполняется()
	
	Возврат "Выполняется"
	
КонецФункции

&НаСервере
Функция СтатусНаПаузе()
	
	Возврат "НаПаузе"
	
КонецФункции

&НаСервере
Функция СтатусЗакончилась()
	
	Возврат "Закончилась"
	
КонецФункции

&НаСервере
Процедура ОчиститьИдентификацияЗвонком()
	
	Для Каждого Статус Из ИдентификацияЗвонком Цикл
	    ИдентификацияЗвонком[Статус.Ключ] = Ложь; 
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура УстановитьИдентификацию(Статус)
	
	ОчиститьИдентификацияЗвонком();
	ИдентификацияЗвонком[Статус] = Истина;  
	
КонецПроцедуры 

&НаСервере
Функция ПолучитьИдентификациюЗвонком()
	
	Для Каждого Статус Из ИдентификацияЗвонком Цикл
		Если ИдентификацияЗвонком[Статус.Ключ] Тогда
	    	Возврат Статус.Ключ; 
		КонецЕсли;
	КонецЦикла;
	
	Возврат ""; 

КонецФункции
            
#КонецОбласти      

#Область Звонки

&НаКлиенте
Процедура ИдентифицироватьПоОтправленномуКоду()   
	                                              
	// Идентификация звонком
	Если ИдентификацияЗвонком[СтатусНеНачиналась()] Или ИдентификацияЗвонком[СтатусНаПаузе()] Тогда 
	
		// Идентификации звонком не было, надо позвонить
		Если ИдентификацияЗвонком[СтатусНеНачиналась()] Тогда      
			КодОтправленный = ИнтеграцияЗвонки.FlashCall(НомерТелефона, Действие);
			Прогресс = 0;
			ПрошлоСекунд = 0;
			ОсталосьСекунд = 0;
			Элементы.ОбратныйОтсчет.Заголовок = "";
		КонецЕсли;
		                                
		УстановитьИдентификацию(СтатусВыполняется());
				
		ИдентифицироватьПоВидуИдентификации();
		УстановитьДоступностьИдентификацииПоКоду(); 
		
		ИдентификаторЗадания = ОжидатьПоВремениФоновоеЗадание(Действие, ПрошлоСекунд + ОсталосьСекунд, ПрошлоСекунд);
		ПодключитьОбработчикОжидания("ОбработчикОжиданияПоВремени", 1);
		
	// Идентификация звонком уже была, можно отправить смс
	ИначеЕсли ИдентификацияЗвонком[СтатусЗакончилась()]  Тогда    
		ОтправитьСмс();
	КонецЕсли;
		
КонецПроцедуры  

&НаСервереБезКонтекста
Функция ОжидатьПоВремениФоновоеЗадание(Действие, ВсегоСекунд = 0, НачальноеКоличествоСекунд = 0)
	
	НастройкиЗвонка = ИнтеграцияЗвонки.ПолучитьНастройкиЗапроса(Действие);

	ПараметрыВыполнения = Новый Массив();
	ПараметрыВыполнения.Добавить(?(ВсегоСекунд > 0, ВсегоСекунд, НастройкиЗвонка.ОжиданиеПоВремени));
	ПараметрыВыполнения.Добавить(НачальноеКоличествоСекунд);
	ПараметрыВыполнения.Добавить(НастройкиЗвонка.ИнтервалОповещения);

	ИмяПроцедуры = "ДопМодульСервер.ОжидатьПоВремени";
	КлючЗадания = Новый УникальныйИдентификатор();
	
	Задание = ФоновыеЗадания.Выполнить(ИмяПроцедуры, ПараметрыВыполнения, КлючЗадания, "Загрузка курсов валют");
	
	Возврат Задание.УникальныйИдентификатор;
	
КонецФункции  

&НаСервереБезКонтекста
Функция НайтиФоновоеЗаданиеПоИдентификатору(ИдентификаторЗадания)
	
	РезультатПоиска = Новый Структура("Состояние, Отменено, ИнформацияОбОшибке, МассивСообщений", Истина, Ложь, "", Новый Массив);
	
	НайденноеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);

	Если НайденноеЗадание <> Неопределено Тогда  
		
		Если НайденноеЗадание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			РезультатПоиска.Состояние = Ложь;                     
			
		ИначеЕсли НайденноеЗадание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
			РезультатПоиска.Состояние = Ложь;  
			РезультатПоиска.ИнформацияОбОшибке = СтрШаблон("Ошибка идентификации: %1", 
				НайденноеЗадание.ИнформацияОбОшибке.Описание); 
			
		ИначеЕсли НайденноеЗадание.Состояние = СостояниеФоновогоЗадания.Отменено Тогда
			РезультатПоиска.Состояние = Ложь;     
			РезультатПоиска.Отменено = Истина;     
		КонецЕсли; 
		
		РезультатПоиска.МассивСообщений = НайденноеЗадание.ПолучитьСообщенияПользователю(Истина);
		
	Иначе
		РезультатПоиска.Состояние = Ложь;
	КонецЕсли;

	Возврат РезультатПоиска;
	
КонецФункции    

&НаСервере
Процедура ОтменитьОжиданиеЗвонка()
	
	Если ИдентификацияЗвонком[СтатусВыполняется()] Тогда    
		УстановитьИдентификацию(СтатусНаПаузе());
		
		НайденноеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);	
		Если НайденноеЗадание <> Неопределено И  НайденноеЗадание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			НайденноеЗадание.Отменить();         
		КонецЕсли; 
	КонецЕсли
	
КонецПроцедуры  

&НаКлиенте
Процедура ВосстановитьВыполнениеИдентификацииЗвонком()
	
	Если ИдентификацияЗвонком[СтатусНаПаузе()] Или ИдентификацияЗвонком[СтатусВыполняется()] Тогда
		ИдентификаторЗадания = ОжидатьПоВремениФоновоеЗадание(Действие, ПрошлоСекунд + ОсталосьСекунд, ПрошлоСекунд);
		ПодключитьОбработчикОжидания("ОбработчикОжиданияПоВремени", 1);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработчикОжиданияПоВремени() 
	
	РезультатПоиска = НайтиФоновоеЗаданиеПоИдентификатору(ИдентификаторЗадания);
	
	Если РезультатПоиска.МассивСообщений.Количество() > 0 Тогда     
		
		МаксимальныйИндекс = РезультатПоиска.МассивСообщений.ВГраница();
		ОжиданиеВремени = РазделитьТекстСообщения(РезультатПоиска.МассивСообщений[МаксимальныйИндекс].Текст);
		
		Если ЗначениеЗаполнено(ОжиданиеВремени) Тогда
			Прогресс 			= ОжиданиеВремени.ПроцентВыполнения;           
			ПрошлоСекунд 		= ОжиданиеВремени.Прошло;           
			ОсталосьСекунд 		= ОжиданиеВремени.Осталось;           
			
			Если ОжиданиеВремени.Осталось <> 0 Тогда
				Элементы.ОбратныйОтсчет.Заголовок = СтрШаблон("Идентифицировать по sms через %1", ОжиданиеВремени.ОбратныйОтсчет);
				УстановитьИдентификацию(СтатусВыполняется());
			Иначе
				Элементы.ОбратныйОтсчет.Заголовок = "Требуется идентификация по sms"; 
				УстановитьИдентификацию(СтатусЗакончилась());
				Прогресс 		= 0;
				ПрошлоСекунд 	= 0;
				ОсталосьСекунд	= 0;
			КонецЕсли;                                   
		КонецЕсли; 
	КонецЕсли;

	Если Не РезультатПоиска.Состояние Тогда       
		
		ОтключитьОбработчикОжидания("ОбработчикОжиданияПоВремени");  
		
		Если РезультатПоиска.Отменено Тогда
			УстановитьИдентификацию(СтатусНаПаузе());	
		КонецЕсли;
		
		Если РезультатПоиска.ИнформацияОбОшибке <> "" Тогда
			ПоказатьПредупреждение(, РезультатПоиска.ИнформацияОбОшибке, 0, "Идентификация завершена");
		КонецЕсли;
	КонецЕсли;      

	ИдентифицироватьПоВидуИдентификации();
	УстановитьДоступностьИдентификацииПоКоду();
	
КонецПроцедуры  

&НаКлиенте
Функция РазделитьТекстСообщения(ТекстСообщения)  

	Если СтрНайти(ТекстСообщения, ";", , , 2) > 0 Тогда

		ПараметрыСообщения = СтрРазделить(ТекстСообщения, ";");
		
		РезультатВыполнения = Новый Структура("Прошло, Осталось, ПроцентВыполнения, ОбратныйОтсчет");
		РезультатВыполнения.Прошло 				= Число(ПараметрыСообщения[0]);
		РезультатВыполнения.Осталось 			= Число(ПараметрыСообщения[1]);
		РезультатВыполнения.ОбратныйОтсчет		= ПолучитьФорматВремени(ПараметрыСообщения[1]);
		РезультатВыполнения.ПроцентВыполнения 	= Число(ПараметрыСообщения[2]);
		
		Возврат РезультатВыполнения;                       
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции  

&НаКлиенте
Функция ПолучитьФорматВремени(КоличествоСекунд)  
	
	Время = КоличествоСекунд;  
	
	Попытка 
		Время = Число(Время);
	Исключение
		Время = 0;
	КонецПопытки;
	
	Если Время > 60 Тогда
		Время = СтрШаблон("%1:%2", Формат(Цел(Время/60), "ЧГ=;ЧДЦ=0"), Прав("00" + Формат(Время % 60, "ЧГ=;ЧДЦ=0"), 2));
	ИначеЕсли Время = 0 Тогда
		Время = "0";
	Иначе
		Время = Строка(Время) + " с";
	КонецЕсли;
	
	Возврат Время;   
	
КонецФункции

#КонецОбласти

#Область Смс  

#Область ОтправкаСмс

&НаСервере
Процедура ОтправитьСмс()      
	
	УстановитьПривилегированныйРежим(Истина); 
	
	ГСЧ = Новый ГенераторСлучайныхЧисел();
    СлучайноеЧисло = Формат(ГСЧ.СлучайноеЧисло(1000, 9999),"ЧГ = '0'");  
	КодОтправленный = Строка(СлучайноеЧисло);
	 
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);
	НомераТелефонов = Новый Массив;
	НомераТелефонов.Добавить("7" + НомерТелефона); 
	 
	Если ТекстСМС <> "" Тогда
		ТекстСообщения = ТекстСМС + КодОтправленный;
	Иначе              
		ТекстСообщения = СтрШаблон(ИнтеграцияЗвонки.ПолучитьТекстСмс(Действие), КодОтправленный);
	КонецЕсли;    
	 
	РезультатОтправки = ОтправкаSMS.ОтправитьSMS(НомераТелефонов,ТекстСообщения,,);
	 
	Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки,,);
		Возврат;
	
		Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки,,);
		КонецЕсли;
	КонецЕсли;
	 
	Если РезультатОтправки.ОтправленныеСообщения.Количество() > 0 Тогда
		ПолучитьСтатусДоставкиСообщения();	
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки,,);
	КонецЕсли;   
 
КонецПроцедуры  

#КонецОбласти

#Область СтатусДоставки

&НаКлиенте
Процедура Обновить(Команда)   
	
	ОбновитьСтатусНаСервере();
	
КонецПроцедуры      

&НаСервере
Процедура ОбновитьСтатусНаСервере()    
	
	УстановитьПривилегированныйРежим(Истина);     
	
	Если ЗначениеЗаполнено(РезультатОтправки) Тогда
		ПолучитьСтатусДоставкиСообщения();	
	КонецЕсли;
	
 КонецПроцедуры
 
 &НаКлиенте
 Процедура СтатусДоставкиСообщенияНажатие(Элемент, СтандартнаяОбработка)     
	 
	СтандартнаяОбработка = Ложь;
	ОбновитьСтатусНаСервере();
    ЭтаФорма.ОбновитьОтображениеДанных(ЭтаФорма.Элементы.СтатусДоставкиСообщения); 
	
КонецПроцедуры 

&НаСервере
Процедура ПолучитьСтатусДоставкиСообщения()

	СтатусДоставкиСообщения = ОтправкаSMS.СтатусДоставки(РезультатОтправки.ОтправленныеСообщения[0].ИдентификаторСообщения);
	СтатусДоставкиСообщения = СтрЗаменить(НРег(СтатусДоставкиСообщения), "не", "не ");
	СтатусДоставкиСообщения = ВРег(Лев(СтатусДоставкиСообщения, 1)) +  Сред(СтатусДоставкиСообщения, 2);
	
КонецПроцедуры

