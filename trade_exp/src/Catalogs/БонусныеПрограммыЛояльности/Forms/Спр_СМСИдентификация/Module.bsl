&НаКлиенте
Процедура ВыполнитьПИН(Команда)                 
	
	Если ПроверкаПИНКода(ПИН, Владелец) Тогда
		Результат = Истина;	
		Закрыть(Результат);
	Иначе    
		ПоказатьОповещениеПользователя(СтрШаблон("Пин-код %1неправильный", ?(ЗначениеЗаполнено(ПИН), ПИН + " ", "")), , 
			"Введите пин-код бригадира", БиблиотекаКартинок.Ошибка32, СтатусОповещенияПользователя.Информация);
	КонецЕсли;                                  
	
КонецПроцедуры

&НаСервере
Функция ПроверкаПИНКода(ПИН, Партнер)
	
	Если ПИН <> "" И ПИН = Партнер.ПИН_Код Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;	
	
КонецФункции 

