//Главный расчет
&НаСервере
Процедура Спр_ПриСозданииНаСервереВместо(Отказ, СтандартнаяОбработка)
	//строка изменений
	ВыборкаБПЛ = БонусныеБаллыСервер.БонуснаяПрограммаКартыЛояльности(Параметры.КартаЛояльности);
	БонуснаяПрограммаЛояльности = ВыборкаБПЛ.БонуснаяПрограммаЛояльности;
	ВалютаБонуснойПрограммы = ?(ЗначениеЗаполнено(ВыборкаБПЛ.Валюта), ВыборкаБПЛ.Валюта, Константы.ВалютаРегламентированногоУчета.Получить());
	
	Если Не ЗначениеЗаполнено(БонуснаяПрограммаЛояльности) Тогда
		БонуснаяПрограммаЛояльности = АльтерраОбщегоНазначения.ПолучитьБонуснуюПрограмму();
	КонецЕсли;
	
	ВалютаДокумента         = Параметры.Валюта;
	Партнер                 = Параметры.Партнер;
	Заказ 					= ?(Параметры.Свойство("Документ"), Параметры.Документ, Неопределено);
	СуммаБалловСРеализацией = ?(Заказ <> Неопределено, БонусыАльтерраРезерв.ПолучитьСуммуБалловСРеализациейИзЗаказа(Заказ), 0);
	
	// Альтерра
	СтруктураКурсовВалютыДокумента         = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаДокумента, ТекущаяДатаСеанса());
	СтруктураКурсовВалютыБонуснойПрограммы = РаботаСКурсамиВалют.ПолучитьКурсВалюты(ВалютаБонуснойПрограммы, ТекущаяДатаСеанса());
	КурсКонвертацииБонусовВВалюту          = БонуснаяПрограммаЛояльности.КурсКонвертацииБонусовВВалюту;
	//-

	// Расчет максимальной суммы оплаты бонусами
	ТЧ = ПолучитьИзВременногоХранилища(Параметры.АдресТабличнойЧастиТовары);
	ТабличнаяЧастьТовары = БонусыАльтерраРезерв.ОбработатьТабличнуюЧасть(ТЧ, БонуснаяПрограммаЛояльности,
																			СтруктураКурсовВалютыДокумента,
																			СтруктураКурсовВалютыБонуснойПрограммы,
																			КурсКонвертацииБонусовВВалюту);
	
	ОстаткиБонусныхБаллов.Загрузить(БонусныеБаллыСервер.ОстаткиИДвиженияБонусныхБаллов(БонуснаяПрограммаЛояльности, Параметры.Партнер));  //Функция заменена
	Резерв = БонусыАльтерраРезерв.ПолучитьОбщийРезервБонусныхБаллов(Партнер, Заказ);
	Для каждого Стр Из ОстаткиБонусныхБаллов Цикл
		Стр.Сумма = Стр.Сумма - Резерв;
	КонецЦикла;
	НачальныйОстатокВБаллах = ОстаткиБонусныхБаллов[0].Сумма;
	
	НачальныйОстаток = РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(НачальныйОстатокВБаллах * КурсКонвертацииБонусовВВалюту,
																			СтруктураКурсовВалютыБонуснойПрограммы,
																			СтруктураКурсовВалютыДокумента);
	
	МаксимальнаяСуммаОплаты        = Мин(ТабличнаяЧастьТовары.Итог("МаксимальнаяСуммаОплаты"), НачальныйОстаток);
	МаксимальнаяСуммаОплатыВБаллах = Мин(ТабличнаяЧастьТовары.Итог("МаксимальнаяСуммаОплатыВБаллах"), НачальныйОстатокВБаллах);
	
	ОписаниеМаксимальнаяСуммаОплаты = НСтр("ru = 'Максимальная сумма оплаты составляет %1 %2 или %3'");
	ОписаниеМаксимальнаяСуммаОплаты = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		ОписаниеМаксимальнаяСуммаОплаты,
		МаксимальнаяСуммаОплаты,
		ВалютаДокумента,
		СтроковыеФункцииКлиентСервер.ЧислоЦифрамиПредметИсчисленияПрописью(
			МаксимальнаяСуммаОплатыВБаллах,
			НСтр("ru = 'балл, балла, баллов'")));
			
	//+Альтерра
	Если СуммаОплаты = 0 Тогда
		СуммаОплаты        = Цел(МаксимальнаяСуммаОплаты);
		СуммаОплатыВБаллах = Цел(МаксимальнаяСуммаОплатыВБаллах);
		//Ограничение на поля, чтобы не списывать баллы в минус
		Элементы.СуммаОплаты.МаксимальноеЗначение = СуммаОплаты;
		Элементы.СуммаОплатыВБаллах.МаксимальноеЗначение = СуммаОплатыВБаллах;
	КонецЕсли;
	
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ТабличнаяЧастьТовары, УникальныйИдентификатор);
	СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
	Если Параметры.Свойство("ТолькоИнформация") Тогда
		Если Параметры.ТолькоИнформация Тогда
			Элементы.ГруппаСуммаОплаты.Видимость= Ложь;
			Элементы.ФормаОплатитьБаллами.Видимость= Ложь;
		КонецЕсли;
	КонецЕсли;
	//-
КонецПроцедуры

&НаКлиенте
Процедура Спр_ПриОткрытииПеред(Отказ)
	Если ЗначениеЗаполнено(Партнер) Тогда 
		Если  Не БонуснаяПрограммаАктивна() Тогда
			Предупреждение("Бонусная программа не активна! Оплата бонусами невозможна!",,);
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	Если Этаформа.ВладелецФормы.Объект.Свойство("КОплатеБаллами") Тогда
		КОплатеБаллами = Этаформа.ВладелецФормы.Объект.КОплатеБаллами;
		Если КОплатеБаллами > 0 Тогда
			СуммаОплаты = Мин(КОплатеБаллами, СуммаОплаты);				
			СуммаОплатыВБаллах = СуммаОплаты;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция БонуснаяПрограммаАктивна()
  Возврат Партнер.БонуснаяПрограммаАктивна;	
КонецФункции

&НаКлиенте
Процедура Спр_ОплатитьБалламиВместо(Команда)
	Если АльтерраОбщегоНазначения.ЭтоБригадир(Партнер) Тогда 
		ОткрытьПараметрыЗавершение(Истина, Неопределено);
	Иначе
		Если КОплатеБаллами = 0 Тогда
			ОткрытьФормуПроверки();
		Иначе
			ОткрытьПараметрыЗавершение(Истина, Неопределено)
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПроверки()        
	
	Оповещение = Новый ОписаниеОповещения("ОткрытьПараметрыЗавершение",ЭтотОбъект);   	
	ПараметрыФормы = Новый Структура("Владелец, Действие", Партнер, "1с_auth_payment");
	ОткрытьФорму("Справочник.БонусныеПрограммыЛояльности.Форма.Спр_СМСИдентификация", ПараметрыФормы,ЭтаФорма,,,,Оповещение,);
	
КонецПроцедуры

&НаКлиенте 
Процедура ОткрытьПараметрыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Истина тогда
		ПараметрыДанных = Новый Структура;
		ПараметрыДанных.Вставить("АдресВоВременномХранилище", Спр_АдресВХ(ВладелецФормы.УникальныйИдентификатор));
		ПараметрыДанных.Вставить("КОплатеБаллами", СуммаОплаты + СуммаБалловСРеализацией);
		
		Закрыть(ПараметрыДанных);
	Иначе
		 Сообщить("Клиент не идентифицирован!");
	КонецЕсли;   
	 
КонецПроцедуры

&НаКлиенте
Процедура Спр_СуммаОплатыПриИзмененииПосле(Элемент)
		СуммаОплатыВБаллах = Цел(СуммаОплатыВБаллах);// Альтерра ПроектЧеки
КонецПроцедуры

