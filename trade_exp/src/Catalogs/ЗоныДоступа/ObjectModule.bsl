&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ)
	
	Если НЕ ЭтотОбъект.ПометкаУдаления Тогда 
		ДатчикиСКУД = ПроверитьПрисутствиеДатчикаВДругихЗонах(Датчики.ВыгрузитьКолонку("Датчик"), Ссылка);
		Если ДатчикиСКУД.Количество() > 0 Тогда
			Для Каждого Стр Из ДатчикиСКУД Цикл
				Сообщить("Датчик: " + Стр.Датчик + " присутствует в другой зоне");
			КонецЦикла;
			Отказ = Истина;	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Функция ПроверитьПрисутствиеДатчикаВДругихЗонах(Датчики, Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗоныДоступаДатчики.Датчик КАК Датчик,
	|	ЗоныДоступаДатчики.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ЗоныДоступа.Датчики КАК ЗоныДоступаДатчики
	|ГДЕ
	|	НЕ ЗоныДоступаДатчики.Ссылка.ПометкаУдаления
	|	И ЗоныДоступаДатчики.Датчик В(&Датчики)
	|	И ЗоныДоступаДатчики.Ссылка <> &Ссылка";
	
	Запрос.УстановитьПараметр("Датчики", Датчики);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	Результат = Запрос.Выполнить().Выгрузить();
	
	Возврат Результат;
	
КонецФункции

