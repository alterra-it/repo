 #Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Функция ПолучитьТаблицуИдентификаторов(МассивОбъектов, Код, ПолучатьИДПапкиСФайлами = Ложь) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Объект1С КАК Объект,
		|	Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Идентификатор КАК Идентификатор
		|ИЗ
		|	Справочник.Альтерра_НастройкиОбменаБитрикс.ЗначенияСписковДляОбъекта КАК Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта
		|ГДЕ
		|	Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Ссылка.Код = &Код
		|	И Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Объект1С В(&МассивОбъектов)";
	
	Если ПолучатьИДПапкиСФайлами Тогда
		Запрос.Текст = Запрос.Текст + 
		"
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	""Ид папки с файлами"",
		|	Альтерра_НастройкиОбменаБитрикс.ИдПапкиСФайлами
		|ИЗ
		|	Справочник.Альтерра_НастройкиОбменаБитрикс КАК Альтерра_НастройкиОбменаБитрикс
		|ГДЕ
		|	Альтерра_НастройкиОбменаБитрикс.Код = &Код";	
	КонецЕсли;
		
	Запрос.УстановитьПараметр("Код", Код);
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса.Выгрузить();
		
КонецФункции

#КонецЕсли
