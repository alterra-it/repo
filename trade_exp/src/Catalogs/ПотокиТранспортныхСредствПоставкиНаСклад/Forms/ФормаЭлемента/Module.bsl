&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	//Если Период.ДатаНачала < КонецДня(ТекущаяДата()) Тогда
		//Сообщить("Вы пытаетесь внести изменения в закрытый период. Ваши изменения не могут быть сохранены.");
		//Если Не РольДоступна("ПолныеПрава") Тогда
			//Отказ = Истина;  //тест 
		//КонецЕсли;
	//КонецЕсли;
	
	Если Модифицированность И Объект.ПотокАктивный Тогда
		ТаблицаРасписания =  РасписаниеПотока.Элементы;
		День = Период.ДатаНачала;
		Пока День < Период.ДатаОкончания Цикл
			Если ИзмененныеДни.НайтиПоЗначению(День) <> Неопределено Тогда
				ОтборЗаписей = Новый Структура;
				ОтборЗаписей.Вставить("Поток", Объект.Ссылка);
				ОтборЗаписей.Вставить("ДатаДоставки", День); 
				НаборЗаписей = РегистрыСведений.РасписаниеСкладскихПотоков.СоздатьНаборЗаписей();
				КоличествоИнтервалов = ПолучитьКоличествоИнтерваловВДне(День);
				НаборЗаписей.Отбор.Поток.Установить(Объект.Ссылка);
				НаборЗаписей.Отбор.ДатаДоставки.Установить(День);
				НаборЗаписей.Прочитать();
				НаборЗаписей.Очистить();
				Ит = 0;
				Пока Ит<=КоличествоИнтервалов Цикл
					ЗаписьПланировщика = ТаблицаРасписания.Найти(Строка(День)+"_"+Ит);
					
					Если ЗаписьПланировщика = Неопределено И Ит<>0 Тогда
						Прервать;
					КонецЕсли;
					НоваяЗаписьВРегистр =НаборЗаписей.Добавить();
					НоваяЗаписьВРегистр.Период = ТекущаяДата();
					НоваяЗаписьВРегистр.АвторИзменений = Пользователи.ТекущийПользователь();
					НоваяЗаписьВРегистр.Поток = Объект.Ссылка;
					НоваяЗаписьВРегистр.ДатаДоставки = День;
					Если  ЗаписьПланировщика = Неопределено И Ит=0 Тогда
						НоваяЗаписьВРегистр.НачалоИнтервала = День;
						НоваяЗаписьВРегистр.ПродолжительностьИнтервала = 0;
					Иначе
						НоваяЗаписьВРегистр.НачалоИнтервала = ЗаписьПланировщика.Начало;
						НоваяЗаписьВРегистр.ПродолжительностьИнтервала = (ЗаписьПланировщика.Конец-ЗаписьПланировщика.Начало)/60;
					КонецЕсли;
					НоваяЗаписьВРегистр.НомерИнтервала = Ит;
					Ит = Ит + 1;
				КонецЦикла;
				НаборЗаписей.Записать();
			КонецЕсли;
			День = День + 3600*24;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

