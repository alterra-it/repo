&НаКлиенте
Процедура РасписаниеПотокаПриОкончанииРедактирования(Элемент, НовыйЭлемент, ОтменаРедактирования)
	//если повторять, то добавить элементы в планировщик
	РедактируемыйЭлемент = Элемент.ВыделенныеЭлементы[0];
	Расписание = РедактируемыйЭлемент.Расписание;
	ЭлементыРасписанияПотока = РасписаниеПотока.Элементы;
	Если Расписание <> Неопределено Тогда
		ИнтервалыПланировщика = РасписаниеПотока.Элементы;
		ВремяНачала = РедактируемыйЭлемент.Начало;
		ВремяКонца = РедактируемыйЭлемент.Конец;
		ДатаНачала = РедактируемыйЭлемент.Начало;
		ДатаНачалаГода = НачалоГода(ДатаНачала);
		//ДатаКонца = ?(Расписание.ДатаКонца<>'00010101', Расписание.ДатаКонца, НачалоДня(КонецМесяца(ДатаНачала)));
		
		ДатаИнтервала = ДатаНачала;//+3600*24;
		ДатаВремяНачала = ДатаИнтервала+Час(ВремяНачала)*3600+Минута(ВремяНачала)*60; 
		ДатаВремяКонца = ДатаИнтервала+Час(ВремяКонца)*3600+Минута(ВремяКонца)*60;
		
		МассивМесяцы = Новый Массив;
		МассивМесяцы = Расписание.Месяцы;
		ПоследнийМесяц = МассивМесяцы[МассивМесяцы.Количество()-1];
		ТекущийМесяц = Месяц(ДатаНачала); 
		
		Если ПоследнийМесяц = ТекущийМесяц Тогда   
			ДатаКонца = ДобавитьМесяц(ДатаНачала,1); 
		Иначе
			ДатаКонца = ДобавитьМесяц(ДатаНачала, ПоследнийМесяц - ТекущийМесяц); 
		КонецЕсли;  
	
		Если Расписание.ДатаКонца<>'00010101' Тогда
			ДатаКонца = Расписание.ДатаКонца;
		КонецЕсли;
		
		МассивДниНедели = Новый Массив;
		МассивДниНедели =  Расписание.ДниНедели;
		Пока ДатаИнтервала <= ДатаКонца Цикл
			Если МассивМесяцы.Количество() > 0 И МассивМесяцы.Количество() < 12 Тогда
				
				Если МассивМесяцы.Найти(Месяц(ДатаИнтервала)) <> Неопределено Тогда
					Если Расписание.ДниНедели.Количество() > 0 И МассивДниНедели.Количество() < 7 Тогда
						Если МассивДниНедели.Найти(ДеньНедели(ДатаИнтервала)) <> Неопределено Тогда
							НовЭлемент = ЭлементыРасписанияПотока.Добавить(ДатаВремяНачала, ДатаВремяКонца);
							НовЭлемент.Значение = Строка(ДатаИнтервала)+"_"+ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала);	
							НовЭлемент.ЦветФона = WebЦвета.СлоноваяКость;
							НовЭлемент.ЦветРамки = WebЦвета.Серебряный;
						КонецЕсли;
					Иначе
						НовЭлемент = ЭлементыРасписанияПотока.Добавить(ДатаВремяНачала, ДатаВремяКонца);
						НовЭлемент.Значение = Строка(ДатаИнтервала)+"_"+ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала);
						НовЭлемент.ЦветФона = WebЦвета.СлоноваяКость;
						НовЭлемент.ЦветРамки = WebЦвета.Серебряный;
					КонецЕсли;
				КонецЕсли;
			Иначе
				Если МассивДниНедели.Количество() > 0 И МассивДниНедели.Количество() < 7 Тогда
					Если МассивДниНедели.Найти(ДеньНедели(ДатаИнтервала)) <> Неопределено Тогда
						НовЭлемент = ЭлементыРасписанияПотока.Добавить(ДатаВремяНачала, ДатаВремяКонца);
						НовЭлемент.Значение = Строка(ДатаИнтервала)+"_"+ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала);
						НовЭлемент.ЦветФона = WebЦвета.СлоноваяКость;
						НовЭлемент.ЦветРамки = WebЦвета.Серебряный;
					КонецЕсли;
				Иначе
					НовЭлемент = ЭлементыРасписанияПотока.Добавить(ДатаВремяНачала, ДатаВремяКонца);
					НовЭлемент.Значение = Строка(ДатаИнтервала)+"_"+ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала);
					НовЭлемент.ЦветФона = WebЦвета.СлоноваяКость;
					НовЭлемент.ЦветРамки = WebЦвета.Серебряный;
				КонецЕсли;                        
			КонецЕсли;
			ИзмененныеДни.Добавить(ДатаИнтервала);
			ДатаВремяНачала = ДатаВремяНачала + 3600*24;
			ДатаВремяКонца = ДатаВремяКонца + 3600*24;
			ДатаИнтервала = ДатаИнтервала + 3600*24;
		КонецЦикла;
		РедактируемыйЭлемент.Расписание = Неопределено;	
	Иначе
		//простой элемент без расписания
		ДатаИнтервала = НачалоДня(РедактируемыйЭлемент.Начало);
		РедактируемыйЭлемент.Значение = Строка(ДатаИнтервала)+"_"+ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала);
		ИзмененныеДни.Добавить(ДатаИнтервала);
		Если РедактируемыйЭлемент.ЦветФона <> WebЦвета.СлоноваяКость Тогда
			РедактируемыйЭлемент.ЦветФона = WebЦвета.СлоноваяКость;
			РедактируемыйЭлемент.ЦветРамки = WebЦвета.Серебряный;
		КонецЕсли;
	КонецЕсли;
	
	Модифицированность = Истина;
КонецПроцедуры

&НаСервере
Функция ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала)
	КоличествоИнтерваловНаДату = 1;
	Интервалы = РасписаниеПотока.Элементы;
	
	Пока Интервалы.Найти(Строка(ДатаИнтервала)+ "_" + КоличествоИнтерваловНаДату) <> Неопределено Цикл
		КоличествоИнтерваловНаДату = КоличествоИнтерваловНаДату + 1;
	КонецЦикла;
	//Для каждого Интервал из Интервалы Цикл
	//	Если НачалоДня(Интервал.Начало)=ДатаИнтервала Тогда
	//		Интервал.Значение = Строка(ДатаИнтервала)+ "_" +Строка(КоличествоИнтерваловНаДату);
	//		КоличествоИнтерваловНаДату = КоличествоИнтерваловНаДату + 1;
	//	КонецЕсли;
	//КонецЦикла;
	Возврат КоличествоИнтерваловНаДату-1;
КонецФункции // ПолучитьКоличествоИнтерваловВДне(ДатаИнтервала)()

&НаКлиенте
Процедура РасписаниеПотокаПередУдалением(Элемент, Отказ)
	РедактируемыйЭлемент = Элемент.ВыделенныеЭлементы[0];
	Если РедактируемыйЭлемент.Значение <> Неопределено Тогда
		УдалитьЭлементРасписания(НачалоДня(РедактируемыйЭлемент.Начало), Число(Прав(РедактируемыйЭлемент.Значение, 1)));//номер интервала в пределах дня никогда не сможет быть двузначным числом. 
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УдалитьЭлементРасписания(ДатаДоставки, НомерИнтервала)

	     НаборЗаписи = РегистрыСведений.РасписаниеСкладскихПотоков.СоздатьНаборЗаписей();
		 НаборЗаписи.Отбор.Поток.Установить(Объект.Ссылка);
		 НаборЗаписи.Отбор.ДатаДоставки.Установить(ДатаДоставки);
		 НаборЗаписи.Отбор.НомерИнтервала.Установить(НомерИнтервала);
		 НаборЗаписи.Прочитать();
		 НаборЗаписи.Очистить();
		 НаборЗаписи.Записать();

КонецПроцедуры // УдалитьЭлементРасписания()

&НаКлиенте
Процедура ОчиститьРасписание(Команда)
	ЭлементыРасписания = РасписаниеПотока.Элементы;
	Инд = 0;
	Пока Инд < ЭлементыРасписания.Количество() Цикл 
		Элемент = ЭлементыРасписания[Инд];
		Если Элемент.Начало > Период.ДатаНачала  И Элемент.Начало < Период.ДатаОкончания Тогда
			ЭлементыРасписания.Удалить(Инд);	
			Инд = ?(Инд=0, 0, Инд - 1);
			ИзмененныеДни.Добавить(НачалоДня(Элемент.Начало));
		Иначе 
			Инд = Инд + 1;
		КонецЕсли;
	КонецЦикла;
	Модифицированность = Истина;
КонецПроцедуры
