&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Период.ДатаНачала = НачалоМесяца(ТекущаяДата());
	Период.ДатаОкончания = КонецМесяца(ТекущаяДата());
	ЗаполнитьПланировщик();
	Элементы.РасписаниеПотока.Доступность = Объект.ПотокАктивный;
	 Элементы.ОчиститьРасписание.Видимость = Объект.ПотокАктивный;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПланировщик()

	//Подготовка таблицы
	РасписаниеПотока.ТекущиеПериодыОтображения.Очистить();
	//ПустаяДата = '20200601'; //дата с началом в пн (для отображения интерфейса)
	//ДатаНачала = НачалоНедели(ПустаяДата);
	//ДатаОкончания = КонецНедели(ПустаяДата);
	ДатаНачала = Период.ДатаНачала;
	ДатаОкончания = Период.ДатаОкончания;
	
	РасписаниеПотока.ТекущиеПериодыОтображения.Очистить();
	РасписаниеПотока.ТекущиеПериодыОтображения.Добавить(ДатаНачала, ДатаОкончания);
	//закрасить интервалы фона
	Фон = РасписаниеПотока.ИнтервалыФона.Добавить(ДатаНачала, ДатаОкончания);
	Фон.Цвет = WebЦвета.СеребристоСерый;
	
	Если  ЗначениеЗаполнено(Объект.Ссылка) Тогда
		//Формирование таблицы данных
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасписаниеСкладскихПотоковСрезПоследних.Период КАК Период,
		|	РасписаниеСкладскихПотоковСрезПоследних.Поток КАК Поток,
		|	РасписаниеСкладскихПотоковСрезПоследних.ДатаДоставки КАК ДатаДоставки,
		|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(РасписаниеСкладскихПотоковСрезПоследних.ДатаДоставки, ЧАС, ЧАС(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)), МИНУТА, МИНУТА(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)) КАК НачалоИнтервала,
		|	ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(РасписаниеСкладскихПотоковСрезПоследних.ДатаДоставки, ЧАС, ЧАС(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)), МИНУТА, МИНУТА(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала) + РасписаниеСкладскихПотоковСрезПоследних.ПродолжительностьИнтервала) КАК КонецИнтервала,
		|	РасписаниеСкладскихПотоковСрезПоследних.ПродолжительностьИнтервала КАК ПродолжительностьИнтервала,
		|	РасписаниеСкладскихПотоковСрезПоследних.АвторИзменений КАК АвторИзменений,
		|	РасписаниеСкладскихПотоковСрезПоследних.НомерИнтервала
		|ИЗ
		|	РегистрСведений.РасписаниеСкладскихПотоков.СрезПоследних(
		|			,
		|			Поток = &Поток
		|				И ДатаДоставки >= &НачалоПериода
		|				И ДатаДоставки <= &КонецПериода
		|				И ПродолжительностьИнтервала > 0) КАК РасписаниеСкладскихПотоковСрезПоследних";
		Запрос.УстановитьПараметр("Поток", Объект.Ссылка);
		Запрос.УстановитьПараметр("НачалоПериода", Период.ДатаНачала);
		Запрос.УстановитьПараметр("КонецПериода", Период.ДатаОкончания);
		//Запрос.УстановитьПараметр("ПустаяДата", ПустаяДата);
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ДанныеТаблицы = РасписаниеПотока.Элементы;
		РасписаниеПотока.Элементы.Очистить();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			//заполнить планировщик
			Интервал = ДанныеТаблицы.Добавить(ВыборкаДетальныеЗаписи.НачалоИнтервала, ВыборкаДетальныеЗаписи.КонецИнтервала);
			Интервал.Текст = "Изменено: " + Строка(Формат(ВыборкаДетальныеЗаписи.Период, "ДФ=dd.MM.yyyy")) + "; Автор: " + ВыборкаДетальныеЗаписи.АвторИзменений;
			Интервал.Значение = Строка(ВыборкаДетальныеЗаписи.ДатаДоставки) + "_"+ Строка(ВыборкаДетальныеЗаписи.НомерИнтервала);
			Интервал.ЦветФона = WebЦвета.СлоноваяКость;
			Интервал.ЦветРамки = WebЦвета.Серебряный;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры // ЗаполнитьПланировщик()

