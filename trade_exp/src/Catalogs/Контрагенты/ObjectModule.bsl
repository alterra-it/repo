
&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ)
	Если (ВРег(СокрЛП(Наименование)) = "ФИЗИЧЕСКОЕ ЛИЦО" ИЛИ ВРег(СокрЛП(Ссылка.Наименование)) = "ФИЗИЧЕСКОЕ ЛИЦО") И Не РольДоступна("ПолныеПрава") Тогда
		Сообщить("Внесение изменений в контрагента ""ФИЗИЧЕСКОЕ ЛИЦО"" запрещено!");
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	Если ЭтотОбъект.ДатаОбновленияДанныхФНС = '00010101' Тогда
		Попытка 
			Справочники.Контрагенты.ПолучитьДанныеFNS(ЭтотОбъект.Ссылка);
			Сообщить("Данные ФНС обновлены");
		Исключение
       		Сообщить(ОписаниеОшибки());
		КонецПопытки;
	ЭтотОбъект.Прочитать();
	КонецЕсли;   	
КонецПроцедуры


