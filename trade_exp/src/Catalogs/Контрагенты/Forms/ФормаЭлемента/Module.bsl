
&НаСервере
Процедура Спр_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)   ///Зад № 65230 запрет редактирования ИНН 
	ЗапретИНН();
	//Заполение Доп.Реквизита ОГРН с ПомошникНового
	Если ЭтаФорма.Параметры.Свойство("ЗаполнятьОГРН") Тогда   
		ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "огрн", Объект.РегистрационныйНомер );
		ЭтаФорма.Записать();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Спр_ВидКонтрагентаПриИзмененииПосле(Элемент)
 ЗапретИНН()
КонецПроцедуры

&НаСервере
Процедура ЗапретИНН()
	
	Если не Объект.Ссылка.Пустая() и НЕ Пользователи.РолиДоступны("ПолныеПрава") и НЕ Пользователи.РолиДоступны("ВводИнформацииПоПартнеруБезКонтроля") Тогда
		ЭтаФорма.Элементы.ИНН.Доступность = Ложь;
		ЭтаФорма.Элементы.ИННФизЛицо.Доступность = Ложь;
		ЭтаФорма.Элементы.ИННИностранногоКонтрагента.Доступность = Ложь;
	Иначе
		ЭтаФорма.Элементы.ИНН.Доступность = Истина;
		ЭтаФорма.Элементы.ИННФизЛицо.Доступность = Истина;
		ЭтаФорма.Элементы.ИННИностранногоКонтрагента.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры	

#Область Данные_FNS
&НаКлиенте
Процедура Док_ЗапроситьСвежиеДанныеПосле(Команда)
	
	Если Объект.ИНН = "" Тогда
		Сообщить("Укажите ИНН контрагента на закладке ""Основное""");
		Возврат;
	КонецЕсли;
	
	Док_ЗапроситьСвежиеДанныеПослеНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура Док_ЗапроситьСвежиеДанныеПослеНаСервере()
	
	Попытка 
		Справочники.Контрагенты.ПолучитьДанныеFNS(Объект.Ссылка);
		Сообщить("Данные ФНС обновлены");
	Исключение
        Сообщить(ОписаниеОшибки());                               
	КонецПопытки;
	ПоказатьИнформациюФНС();
	ЭтаФорма.Прочитать();
	
КонецПроцедуры

&НаСервере
Процедура ПоказатьИнформациюФНС()
	
	ДопИнформация = Объект.Ссылка.ИнформацияФНС.Получить();	
	
КонецПроцедуры

&НаКлиенте
Процедура Док_СтраницыФормыПриСменеСтраницыПосле(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница.Имя = "СтраницаДополнительнаяИнформация" Тогда
		ПоказатьИнформациюФНС();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПолнаяИнформацияПосле(Команда)
		
	ПолнаяИнформацияФНС = Док_ПолнаяИнформацияПослеСервер();
	Если ПолнаяИнформацияФНС = Неопределено Тогда
		Сообщить("Нет данных по контрагенту");
	Иначе
		ПолнаяИнформацияФНС.Показать("Полная информация");
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция Док_ПолнаяИнформацияПослеСервер()
	
	ПолнаяИнформацияФНС = Объект.Ссылка.ПолнаяИнформацияФНС.Получить();		
	Возврат ПолнаяИнформацияФНС;
	
КонецФункции	

&НаСервере
Процедура Док_ПриЧтенииНаСервереПосле(ТекущийОбъект)
Если Не Объект.Ссылка.Пустая() тогда
	Если Не Пользователи.РолиДоступны("РазрешениеМенятьПартнераВКонтрагенте") тогда
		ЭтаФорма.Элементы.Партнер.ТолькоПросмотр=Истина;
	КонецЕсли;	
КонецЕсли;	
КонецПроцедуры

#КонецОбласти


