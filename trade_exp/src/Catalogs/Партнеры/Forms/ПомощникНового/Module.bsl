#Область События

//Открытие и закрытие формы Контрагента для заполения Доп.Реквизита ОГРН с ПомошникНового
&НаКлиенте
Процедура Док_ПриЗакрытииПосле(ЗавершениеРаботы)
	СсылкаНаКонтрагента 	= КонтрагентВыбор;
   	ПараметрыФормы 			= Новый Структура("Ключ, ЗаполнятьОГРН", СсылкаНаКонтрагента);
   	ОткрытьФорму("Справочник.Контрагенты.Форма.ФормаЭлемента", ПараметрыФормы);

	ФормаСОГРН 				= ПолучитьФорму("Справочник.Контрагенты.Форма.ФормаЭлемента", ПараметрыФормы);
	ФормаСОГРН.Закрыть();
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
	Элементы.ИсточникПервичногоИнтересаЧастноеЛицо.СвязьПоТипу = Новый СвязьПоТипу("КаналПервичногоИнтереса",0);
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ОсновнойМенеджер = "";
	МАП = "";
	УказатьДанныеКонтактногоЛица = Истина;
	УстановитьДоступностьДанныхКонтактногоЛица(ЭтотОбъект);
	Элементы.Парсинг.Доступность = АльтерраОбщегоНазначения._ЕстьРоль("УстановкаФлажкаПарсингВПартнерах");
	
	ИнициализацияПомощникаЗаведенияЧастногоКлиента(Параметры);
КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	ИнициализацияПомощникаЗаведенияЧастногоКлиента_НаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗакрытиемПеред(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Отказ = НеЗакрыватьФормуАвтоматически;
КонецПроцедуры

&НаКлиенте
&Перед("ОбработкаСобытияЭлементаКИТелефон")
Процедура Док_ОбработкаСобытияЭлементаКИТелефон(Элемент, ВидКонтактнойИнформации, ИмяРеквизитаПредставление, ИмяРеквизитаЗначенияПолей, Событие)
	СбросАктивацииБонуснойПрограммыПартнера(Истина);
КонецПроцедуры

#Область ИдентификацияПоТелефону 

&НаКлиенте
Процедура ОтправитьСМС(Команда)
	
	СбросАктивацииБонуснойПрограммыПартнера();
	
	Отказ = Ложь;
	ПроверкаЗаполнения(ТелефонПартнераФизЛицо, "ТелефонПартнераФизЛицо", "'Телефон'", Отказ);
	
	Если Не Отказ И Не ЕстьПартнерЧастноеЛицоСТакимТелефономНаСервере(Неопределено, Ложь, ТелефонПартнераФизЛицо) Тогда

		Оповещение = Новый ОписаниеОповещения("ЗавершениеИдентификацииПоКоду",ЭтотОбъект);   	
		ПараметрыФормы = Новый Структура("ТолькоОтправкаКода, НовыйПартнер, ФИОПартнера, НомерТелефона, Действие", 
			Истина, Истина, СтрШаблон("%1 %2 %3", ФамилияПартнера, ИмяПартнера, ОтчествоПартнера), ТелефонПартнераФизЛицо, "1c_register_card");
		ОткрытьФорму("Справочник.БонусныеПрограммыЛояльности.Форма.Спр_СМСИдентификация", ПараметрыФормы,ЭтаФорма,,,,Оповещение,);

	КонецЕсли;    
	
КонецПроцедуры

&НаКлиенте
Процедура СбросАктивацииБонуснойПрограммыПартнера(ВыводСообщения = Ложь)
	
	Если РежимПомощникаЗаведенияЧастногоКлиента Тогда  
		
		ОчиститьСообщения(); 
		
		Если АктивироватьБонуснуюПрограммуПартнера Тогда
           УстановитьБонуснуюПрограммуКлиента(Ложь);
			
			Если ВыводСообщения И _ГруппыПартнеров <> 3 Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("При редактировании номера телефона происходит сброс активации бонусной программы! Отправьте код повторно!");
			КонецЕсли;
		КонецЕсли;  
		
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте 
Процедура ЗавершениеИдентификацииПоКоду(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Истина тогда
		УстановитьБонуснуюПрограммуКлиента(Истина);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Бонусная программа будет активирована после записи данных")		
	Иначе
		 Сообщить("Клиент не идентифицирован. Бонусная программа не активирована.");
	КонецЕсли;   
	 
КонецПроцедуры      

Процедура УстановитьБонуснуюПрограммуКлиента(Активация)
	
	АктивироватьБонуснуюПрограммуПартнера = Активация;
	Элементы.ДекорацияАктивацияБонуснойПрограммы.Заголовок = СтрШаблон("Бонусная программа %1активирована", ?(Активация, "", "не "));
	Элементы.ДекорацияАктивацияБонуснойПрограммы.ЦветТекста = ?(Активация, WebЦвета.Зеленый, WebЦвета.Кирпичный);
	
КонецПроцедуры	

#КонецОбласти 

&НаКлиенте
&ИзменениеИКонтроль("ВыполнитьНеобходимыеДействияПриПереходеПоСтраницам")
Процедура Док_ВыполнитьНеобходимыеДействияПриПереходеПоСтраницам(Знач Оповещение, Команда)

	Если Команда.Имя = "Далее" Тогда

		Если Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаПервичнаяИнформация Тогда

			ВыполнитьПоискПоПервичнойИнформации();
#Удаление
			Если ТаблицаНайдено.Количество() > 0 Тогда
#КонецУдаления
#Вставка
			Если ТаблицаНайдено.Количество() > 0 И НЕ РежимПомощникаЗаведенияЧастногоКлиента Тогда
#КонецВставки
				ПерейтиНаСтраницуНайденныхСовпадений();
			Иначе
				ПерейтиНаСтраницуДополнительныхСведений();
			КонецЕсли;

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаНайдено Тогда

			ВыборПользователяПоРезультатамНайдено(Новый ОписаниеОповещения("ВыполнитьНеобходимыеДействияПриПереходеПоСтраницамПослеВыбора", ЭтотОбъект, Новый Структура("Оповещение", Оповещение)));
			Возврат;

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаДополнительныеСведения Тогда

			Если ИспользоватьДополнительныеРеквизиты Тогда

				Если ТребуетсяОбновлениеЭлементовДопРеквизитов Тогда
					ОбновитьЭлементыДополнительныхРеквизитов();
					ТребуетсяОбновлениеЭлементовДопРеквизитов = Ложь;
				КонецЕсли;

				Если Элементы.ГруппаДополнительныеРеквизиты.ПодчиненныеЭлементы.Количество() > 0 Тогда
					ПерейтиНаСтраницуДополнительныхРеквизитов();
				Иначе
					ПерейтиНаСтраницуРасчетногоСчетаИлиФинальную();
				КонецЕсли;

			Иначе

				ПерейтиНаСтраницуРасчетногоСчетаИлиФинальную();

			КонецЕсли;

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаДополнительныеРеквизиты Тогда

			ПерейтиНаСтраницуРасчетногоСчетаИлиФинальную();

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаРасчетныйСчет Тогда

			Если ИспользуютсяТолькоПартнеры
				Или (ДействиеСКонтрагентом = 1 И Не НаОснованииКонтрагента И УказыватьЮридическиеРеквизиты) Тогда

				Если ВидКомпании = 3 И Не ИспользуютсяТолькоПартнеры Тогда
					ПерейтиНаСтраницуВыбораГоловногоКонтрагента();
				ИначеЕсли ВидКомпании = 0 И ПартнерыИКонтрагентыЛокализацияКлиент.НеобходимПоискНепривязанныхОбособленныхПодразделений(ЭтотОбъект) Тогда
					ВыполнитьПоискНепривязанныхОбособленныхПодразделений();
					Если ОбособленныеПодразделения.Количество() > 0 Тогда
						ПерейтиНаСтраницуОбособленныхПодразделений();
					КонецЕсли;
				КонецЕсли;

			КонецЕсли;

			Если Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаРасчетныйСчет Тогда
				ПерейтиНаФинальнуюСтраницу();
			КонецЕсли;

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаОбособленныеПодразделения Тогда

			ПерейтиНаФинальнуюСтраницу();

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаГоловнойКонтрагент Тогда

			Если ВыбратьГоловногоКонтрагента = 1 Тогда
				ПерейтиНаСтраницуРасчетногоСчетаГоловногоКонтрагента();
			Иначе
				ПерейтиНаФинальнуюСтраницу();
			КонецЕсли;

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаРасчетныйСчетГоловногоКонтрагента Тогда

			ПерейтиНаФинальнуюСтраницу();

		ИначеЕсли Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы.СтраницаФинальная Тогда

			СписокСозданных = Новый СписокЗначений;
			ТребуетсяПереходНаСтраницуСовпадений = Ложь;
			СоздатьПартнера(СписокСозданных, ТребуетсяПереходНаСтраницуСовпадений);

			Если ТребуетсяПереходНаСтраницуСовпадений Тогда
				ПерейтиНаСтраницуНайденныхСовпадений();
				Возврат;
			КонецЕсли;

			Если СозданиеВыполнено Тогда

				РеквизитыПартнера = Новый Структура;

				Для Каждого ЭлементСписка Из СписокСозданных Цикл
					Если ТипЗнч(ЭлементСписка.Значение) = Тип("СправочникСсылка.Партнеры") Тогда
						РеквизитыПартнера.Вставить("Наименование", ЭлементСписка.Представление);
						РеквизитыПартнера.Вставить("ОсновнойМенеджер", ОсновнойМенеджер);
					КонецЕсли;
					ПоказатьОповещениеПользователя("Создание", ЭлементСписка.Значение, ЭлементСписка.Представление);
				КонецЦикла;

				Если РеквизитыПартнера.Количество() = 0 Тогда
					РеквизитыПартнера = ОбщегоНазначенияУТВызовСервера.ЗначенияРеквизитовОбъекта(ПартнерВыбор, "ОсновнойМенеджер, Наименование");
				КонецЕсли;

				ВыполнитьДействияЗакрытияФормы(Новый ОписаниеОповещения("ВыполнитьНеобходимыеДействияПриПереходеПоСтраницамЗавершение", ЭтотОбъект, Новый Структура("Оповещение", Оповещение)), РеквизитыПартнера, Истина);
				Возврат;

			КонецЕсли;

		КонецЕсли;

	Иначе

		РазмерСписка = СтекПредыдущихСтраниц.Количество();
		ИмяПредыдущейСтраницы = СтекПредыдущихСтраниц[РазмерСписка - 1].Значение;
		Элементы.СтраницыПомощника.ТекущаяСтраница = Элементы[ИмяПредыдущейСтраницы];
		СтекПредыдущихСтраниц.Удалить(РазмерСписка -1);

	КонецЕсли;

	ВыполнитьНеобходимыеДействияПриПереходеПоСтраницамФрагмент(Оповещение);

КонецПроцедуры

&НаКлиенте
Процедура Спр_ДалееВместо(Команда)   
	ПолноеНаименование_ЕстьПарсинг = ДопМодульКлиентСервер.ЕстьПарсинг(ПолноеНаименование);
	Название_ЕстьПарсинг = ДопМодульКлиентСервер.ЕстьПарсинг(Название);
	
	// +Альтерра +
	Отказ = Ложь;		
	Если ЭтоКомпания = 1 Тогда
		Если ПустаяСтрока(ТелефонПартнераФизЛицо) Тогда
			ПартнерыИКонтрагентыКлиент.ВывестиСообщениеПользователю(НСтр("ru = 'Необходимо задать номер телефона!'"),ИспользуютсяТолькоПартнеры,"ТелефонПартнераФизЛицо");
			Отказ = Истина;
		КонецЕсли;
		Если ПустаяСтрока(ОтчествоПартнера) Тогда
			ПартнерыИКонтрагентыКлиент.ВывестиСообщениеПользователю(НСтр("ru = 'Необходимо задать отчество!'"),ИспользуютсяТолькоПартнеры,"ОтчествоПартнера");
			Отказ = Истина;
		КонецЕсли;
		АдресЭПКонтактногоЛицаОбязателен = ложь;
		
		Отказ = ЕстьПартнерЧастноеЛицоСТакимТелефономНаСервере(, Отказ, ТелефонПартнераФизЛицо);
		
		Если Отказ Тогда 
			Возврат;
		КонецЕсли;
	иначе                      
		Если ПолноеНаименование_ЕстьПарсинг Тогда  
			АдресЭПКонтактногоЛицаОбязателен = Ложь;
		Иначе                           
			АдресЭПКонтактногоЛицаОбязателен = истина;
			Если ПустаяСтрока(АдресЭПКЛ) Тогда
				ПартнерыИКонтрагентыКлиент.ВывестиСообщениеПользователю(НСтр("ru = 'Необходимо задать E-mail контактного лица!'"),ИспользуютсяТолькоПартнеры,"АдресЭПКЛ");
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Страница = Элементы.СтраницыПомощника.ТекущаяСтраница; 
	
	//СтраницаПервичнаяИнформация
	Если Страница = Элементы.СтраницаПервичнаяИнформация Тогда
		Если ЭтоКомпания = 1 Тогда
			Если ПолноеНаименование_ЕстьПарсинг Тогда
				ПолноеНаименование = АльтерраОбщегоНазначения.СтрЗаменить_(ПолноеНаименование, "(ПАРСИНГ)");
			КонецЕсли; 
			
			Если Название_ЕстьПарсинг Тогда       
				Название = АльтерраОбщегоНазначения.СтрЗаменить_(Название, "(ПАРСИНГ)");
			КонецЕсли;    
			
			ОчиститьФлажки();
		Иначе
			Если ПолноеНаименование_ЕстьПарсинг Тогда  
				Если ЗначениеЗаполнено(Название) И Не Название_ЕстьПарсинг Тогда       
					Название = Название + " (Парсинг)";
				КонецЕсли;
				
				ОчиститьФлажки(Истина);       
			Иначе      
				Если Название_ЕстьПарсинг Тогда       
					Название = АльтерраОбщегоНазначения.СтрЗаменить_(Название, "(ПАРСИНГ)");
				КонецЕсли;    
				
				ОчиститьФлажки();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	//СтраницаДополнительныеСведения
	Если Страница = Элементы.СтраницаДополнительныеСведения Тогда
		Если ПустаяСтрока(БизнесРегион) Тогда
			ПартнерыИКонтрагентыКлиент.ВывестиСообщениеПользователю(НСтр("ru = 'Необходимо указать Бизнес-регион!'"),ИспользуютсяТолькоПартнеры,"БизнесРегион");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	//СтраницаДополнительныеРеквизиты
	Если Страница = Элементы.СтраницаДополнительныеРеквизиты Тогда
		
		ГруппаПартнер = Спр_ПолучитьЗначениеДополнительногоРеквизитаНаФорме("Группы партнеров");
		Если ГруппаПартнер.Пустая() Тогда
			Сообщить(НСтр("ru = 'Необходимо выбрать Группу партнера!'"));
			Отказ = Истина;
		ИначеЕсли ГруппаПартнер = Спр_НайтиПоНаименованию("Частные лица") И Не ЗначениеЗаполнено(ДатаРождения) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Необходимо заполнить Дату рождения на предыдущем шаге!");
			Отказ = Истина;
		КонецЕсли;
		
		ТипПокупателя = Спр_ПолучитьЗначениеДополнительногоРеквизитаНаФорме("Тип покупателя");
		
		Если Не ГруппаПартнер.Пустая() Тогда
			мГруппаПартнера = Новый Массив;
			мГруппаПартнера.Добавить("Покупатели (организация/ИП)");
			мГруппаПартнера.Добавить("Покупатели-поставщики");                     
			
			Для каждого Группа Из мГруппаПартнера Цикл
				Если ГруппаПартнер = Спр_НайтиПоНаименованию(Группа) И ТипПокупателя.Пустая() Тогда
					Сообщить(НСтр("ru = 'Необходимо заполнить Тип покупателя!'"));
					Отказ = Истина;
					Прервать;
				КонецЕсли; 
			КонецЦикла;
		КонецЕсли; 
		
		Если НРег(ТипПокупателя) = НРег(Спр_НайтиПоНаименованию("строительная"))
			Или ГруппаПартнер = Спр_НайтиПоНаименованию("Бригадиры") Тогда
			ВидДеятельности = Спр_ПолучитьЗначениеДополнительногоРеквизитаНаФорме("Вид деятельности");
			Если ВидДеятельности.Пустая() Тогда
				Сообщить(НСтр("ru = 'Необходимо заполнить Вид деятельности!'"));
				Отказ = Истина;
			КонецЕсли; 
		КонецЕсли;
		
		Если ПустаяСтрока(ТелефонПартнера) И Не ЭтоКомпания = 1 И Не Отказ Тогда
			мГруппаПартнераТел = Новый Массив;
			мГруппаПартнераТел.Добавить("Покупатели (организация/ИП)");
			мГруппаПартнераТел.Добавить("Бригадиры");
			мГруппаПартнераТел.Добавить("Частные лица");
			мГруппаПартнераТел.Добавить("Сотрудники");
			
			Для каждого ГруппаТел Из мГруппаПартнераТел Цикл
				Если ГруппаПартнер = Спр_НайтиПоНаименованию(ГруппаТел) Тогда
					Сообщить(НСтр("ru = 'Необходимо заполнить Телефон Партнера!'"));
					Отказ = Истина;
				КонецЕсли; 
			КонецЦикла;
		КонецЕсли; 
		
	КонецЕсли; 
	
	Если Отказ Тогда 
		Возврат;
	КонецЕсли;
	// -Альтерра +
	
	ВыполнитьПереходПоСтраницам(Неопределено, Команда); 
	
КонецПроцедуры

&НаСервере
Функция Спр_ПолучитьПолеДополнительногоРеквизитаНаФорме(ИмяРеквизита) 
	
	Список = ЭтаФорма.Свойства_ОписаниеДополнительныхРеквизитов;
	Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию(ИмяРеквизита);
	
	Если ЗначениеЗаполнено(Свойство) Тогда
	    НайденныеСтроки = Список.НайтиСтроки(Новый Структура("Свойство", Свойство));
		Если НайденныеСтроки.Количество() > 0 Тогда
			Возврат НайденныеСтроки[0];		
		КонецЕсли; 		
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция Спр_ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ИмяРеквизита)
	Перем ЗначениеРеквизита;
	
	ПолеДополнительногоРеквизитаНаФорме = Спр_ПолучитьПолеДополнительногоРеквизитаНаФорме(ИмяРеквизита);
	
	Если не ПолеДополнительногоРеквизитаНаФорме = Неопределено Тогда
		Возврат ЭтаФорма[ПолеДополнительногоРеквизитаНаФорме.ИмяРеквизитаЗначение];
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция Спр_НайтиПоНаименованию(ИмяРеквизита)
	
	Реквизит = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию(ИмяРеквизита);
	
	Если не Реквизит = Неопределено Тогда
		Возврат Реквизит;
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область ПомощникЗаведенияЧастногоКлиента

&НаСервере
Процедура ИнициализацияПомощникаЗаведенияЧастногоКлиента(Параметры)
	Если Параметры.Свойство("РежимПомощникаЗаведенияЧастногоКлиента") Тогда
		Элементы.Переместить(Элементы.ФамилияПартнера, Элементы.ФормаРегистрацииЧЛ_ОсновныеРеквизиты);
		Элементы.Переместить(Элементы.ИмяПартнера, Элементы.ФормаРегистрацииЧЛ_ОсновныеРеквизиты);
		Элементы.Переместить(Элементы.ОтчествоПартнера, Элементы.ФормаРегистрацииЧЛ_ОсновныеРеквизиты);
		Элементы.Переместить(Элементы.ДатаРождения, Элементы.ФормаРегистрацииЧЛ_ОсновныеРеквизиты);
		Элементы.Переместить(Элементы.Пол, Элементы.ФормаРегистрацииЧЛ_ОсновныеРеквизиты); 
		Элементы.ФамилияПартнера.АвтоОтметкаНезаполненного = Ложь;
		Элементы.ИмяПартнера.АвтоОтметкаНезаполненного = Ложь;
		Элементы.ОтчествоПартнера.АвтоОтметкаНезаполненного = Ложь;
		
		Элементы.Переместить(Элементы.ФактическийАдресЧастноеЛицо, Элементы.ФормаРегистрацииЧЛ_Адрес, Элементы.УказатьАдресНаКарте);
		Элементы.ФактическийАдресЧастноеЛицо.РедактированиеТекста = Ложь;
		
		Элементы.Переместить(Элементы.БизнесРегионЧастноеЛицо, Элементы.ФормаРегистрацииЧЛ_ДопРеквизиты_Основные);
		Элементы.Переместить(Элементы.АдресЭППартнераФизЛицо, Элементы.ФормаРегистрацииЧЛ_ДопРеквизиты_Основные);
		
		Элементы.Переместить(Элементы.ТелефонПартнераФизЛицо, Элементы.ФормаРегистрацииЧЛ_ДопРеквизиты_Телефон_1, Элементы.ОтправитьСМС);
		
		ДопМодуль.ПереместитьДополнительныйРеквизит(ЭтаФорма, "ВидДеятельности", "ФормаРегистрацииЧЛ_ДопРеквизиты_Прочее");
		
		Элементы.Переместить(Элементы.Сегмент, Элементы.ФормаРегистрацииЧЛ_ДопРеквизиты_Прочее);
		
		РежимПомощникаЗаведенияЧастногоКлиента = Истина;
		Элементы.ВыбратьПартнера.Видимость = Параметры.Свойство("РежимПомощникаЗаведенияЧастногоКлиента_ФормаВыбора");
		
		_ГруппыПартнеров = 1; // "Частные лица"
		ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "ГруппыПартнеров", Спр_НайтиПоНаименованию("Частные лица"));
		ПолучитьЭлементДополнительногоРеквизита("ВидДеятельности").Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ИнициализацияПомощникаЗаведенияЧастногоКлиента_НаКлиенте()
	Если РежимПомощникаЗаведенияЧастногоКлиента Тогда
		ЭтаФорма.Заголовок = "Помощник заведения частного клиента";
		
		ЭтоКомпания = 1;
		ЭтоКомпанияПриИзменении(Элементы.ЭтоКомпания);
		Спр_ЭтоКомпанияПриИзмененииПосле(Элементы.ЭтоКомпания);
		
		Клиент = Истина;
		ФлагПризнакПартнераПриИзменении(Элементы.Клиент);
		Док_КлиентПриИзмененииПосле(Элементы.Клиент);
		
		ДействиеПоРезультатамНайдено = 2;
		ДействиеСКонтрагентом = 1;
		ОткрытьПослеСоздания = Ложь;
		
		Элементы.СтраницыПомощника.Видимость = Ложь;
		Элементы.ГруппаПодвал.Видимость = Ложь;
		
		ТребуетсяОбновлениеЭлементовДопРеквизитов = Ложь;
	Иначе
		Элементы.ФормаРегистрацииЧЛ.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

