Процедура Док_ПерейтиНаФинальнуюСтраницу()
	//Проверка вхождения в сегмент запрет продаж
	ПараметрыПроверки= Новый Структура;
	ПараметрыПроверки.Вставить("Наименование", Название);
	ПараметрыПроверки.Вставить("НаименованиеПолное", ПолноеНаименование);
	ПараметрыПроверки.Вставить("Почта", ?(ПустаяСтрока(АдресЭППартнераФизЛицо), АдресЭППартнера, АдресЭППартнераФизЛицо));
	ПараметрыПроверки.Вставить("Телефон", ?(ПустаяСтрока(ТелефонПартнераФизЛицо), ТелефонПартнера, ТелефонПартнераФизЛицо));
	ПараметрыПроверки.Вставить("Адрес", ?(ПустаяСтрока(ФактическийАдрес), ЮридическийАдрес, ФактическийАдрес));

	мОтветов= ПроверитьПоСегментуЗапретОтгрузки(ПараметрыПроверки);
	Для Каждого Ответ Из мОтветов Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон("Найден похожий клиент ""%1"" в сегменте ""Запрет отгрузки"" %2", Ответ.Партнер, Ответ.Проверка), Ответ.Партнер);
	КонецЦикла;
