Процедура Спр_ЭтоКомпанияПриИзмененииПосле(Элемент)
	Если ЭтоКомпания = 1 Тогда
	   УказыватьЮридическиеРеквизиты = Истина;
	    ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаДанныеКонтрагентаЧастноеЛицо",
	    		"Доступность", УказыватьЮридическиеРеквизиты, Истина);
	    	Если УказыватьЮридическиеРеквизиты Тогда
	    		УстановитьДоступностьДанныхДокументаФизлица(ЭтотОбъект);
	    	КонецЕсли;
        Элементы.ИННПартнерФизЛицо.Видимость = Ложь;
		Сегмент = СегментБонусы();
	КонецЕсли;    
	
	Если ДопМодульКлиентСервер.ЕстьПарсинг(ПолноеНаименование) Тогда 
		ПолноеНаименование = АльтерраОбщегоНазначения.СтрЗаменить_(ПолноеНаименование, "(ПАРСИНГ)");
	КонецЕсли;
	
	Если ДопМодульКлиентСервер.ЕстьПарсинг(Название) Тогда 
		Название = АльтерраОбщегоНазначения.СтрЗаменить_(Название, "(ПАРСИНГ)");
	КонецЕсли;      
	
	ОчиститьФлажки();
