&НаКлиенте
Процедура Док_ОсновнойМенеджерЧастноеЛицоПриИзмененииПосле(Элемент)
	НужнаПроверка = ИСТИНА;

	ОтборНужныхПользователей(НужнаПроверка);
	
	Если НужнаПроверка Тогда
		ОбработатьОтветНет= Новый ОписаниеОповещения("ОбработатьОтветНет", ЭтаФорма);
		ПоказатьВопрос(ОбработатьОтветНет, "Основной менеджер не является сотрудником оптовых отделов, выберите другого менеджера или очистите поле ""Основной менеджер""!", РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Сохранить клиента с выбранным ОМ?", КодВозвратаДиалога.Нет);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ОсновнойМенеджерПриИзмененииПосле(Элемент)
	НужнаПроверка = ИСТИНА;

	ОтборНужныхПользователей(НужнаПроверка);
	
	Если НужнаПроверка  Тогда
		ОбработатьОтветНет= Новый ОписаниеОповещения("ОбработатьОтветНет", ЭтаФорма);
		ПоказатьВопрос(ОбработатьОтветНет, "Основной менеджер не является сотрудником оптовых отделов, выберите другого менеджера или очистите поле ""Основной менеджер""!", РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Сохранить клиента с выбранным ОМ?", КодВозвратаДиалога.Нет);
	КонецЕсли;
	
	
КонецПроцедуры

 &НаКлиенте
Процедура ОбработатьОтветНет(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Нет Тогда
		ЭтотОбъект.ОсновнойМенеджер = "";
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ОтборНужныхПользователей(НужнаПроверка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|		Пользователи.Ссылка КАК Ссылка,
		|		ДополнительныеСведения.Значение.Наименование КАК ЗначениеНаименование
		|	ИЗ
		|		Справочник.Пользователи КАК Пользователи
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|			ПО (Пользователи.Ссылка = ДополнительныеСведения.Объект)
		|	ГДЕ
		|		ДополнительныеСведения.Свойство = &Свойство
		|        И ДополнительныеСведения.Значение.Наименование ПОДОБНО &Отдел1
		|        ИЛИ ДополнительныеСведения.Значение.Наименование ПОДОБНО &Отдел2"; 		
	
	Запрос.УстановитьПараметр("Свойство", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Отделы")); 
	Запрос.УстановитьПараметр("Отдел1", "Отдел Дистрибуции");  
	Запрос.УстановитьПараметр("Отдел2", "Коммерческий отдел");

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать(); 
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ЭтотОбъект.ОсновнойМенеджер = ВыборкаДетальныеЗаписи.Ссылка Тогда 
			НужнаПроверка = ЛОЖЬ;
		КонецЕсли;
	КонецЦикла;
		
	Возврат НужнаПроверка;
		
КонецФункции
