#Область ЭтапыСтроительства
&НаСервере                     
Процедура ОбновитьДоступностьЭлементовСтроительства()
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	Элементы._ГруппаАктивнаяФаза.Доступность = (Параметры.Ключ.Пустая() ИЛИ ТекущийПользователь=Объект.МАП ИЛИ ПользовательИмеетПраваУТСК(ТекущийПользователь) ИЛИ Объект.АктивнаяФаза=Справочники.ЭтапыСтроительства.ПустаяСсылка()); 
	Элементы.АктивнаяФаза.ТолькоПросмотр = НЕ (Параметры.Ключ.Пустая() ИЛИ ТекущийПользователь=Объект.МАП ИЛИ ПользовательИмеетПраваУТСК(ТекущийПользователь) ИЛИ Объект.АктивнаяФаза=Справочники.ЭтапыСтроительства.ПустаяСсылка()); 
	Элементы.ДатаНачалаАктивнойФазы.ТолькоПросмотр = Элементы.АктивнаяФаза.ТолькоПросмотр; 
	//Доступность назначения МАПа
	ДоступностьМАПа = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ОтделАналитики");
	//Если Не Объект.Ссылка.Пустая() И Модифицированность=Ложь И Объект.МАП <> ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка") И ДоступностьМАПа Тогда 
	//	ДоступностьМАПа = (ТекущийПользователь=Объект.МАП);
	//КонецЕсли;
	Элементы.МАП.Доступность =  ДоступностьМАПа;
КонецПроцедуры

