	          УидПартнера = Объект.Ссылка.УникальныйИдентификатор();
	          ssl = Новый ЗащищенноеСоединениеOpenSSL;
		      HTTPСоединение = Новый HTTPСоединение("tg-alterra.ru",,,,,200,ssl); 
              HTTPЗапрос = Новый HTTPЗапрос("api/v1/profile/client.acceptChanges?XML_ID=" + УидПартнера +"&PERSONAL_PHONE=" + Телефон);
