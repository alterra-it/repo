&НаКлиенте
Процедура Док_СоглашениеДляРассылокНачалоВыбораПосле(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПараметрыВыбораСоглашения = ПродажиКлиент.ПараметрыНачалаВыбораСоглашенияСКлиентом();
	
	ПараметрыВыбораСоглашения.Элемент                     = Элемент;
	ПараметрыВыбораСоглашения.Партнер                     = Объект.Ссылка;
	ПараметрыВыбораСоглашения.Документ                    = Объект.СоглашениеДляРассылок;
	ПараметрыВыбораСоглашения.ДатаДокумента               = ТекущаяДата();
	ПараметрыВыбораСоглашения.ДанныеФормыСтруктура        = Объект;
	
	ПродажиКлиент.НачалоВыбораСоглашенияСКлиентом(ПараметрыВыбораСоглашения, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПарсингПриИзмененииПосле(Элемент)  
	
	Если Объект.Парсинг Тогда
		Если Объект.Клиент Тогда
			Объект.Парсинг = Ложь;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отметки 'Клиент' и 'Парсинг' не могут быть выбраны одновремено");
		ИначеЕсли Объект.ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.КомпанияЧастноеЛицо.ЧастноеЛицо") Тогда  
			Объект.Парсинг = Ложь;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для парсинга необходимо выбрать 'Компания', а не 'Частное лицо'!");
		ИначеЕсли Не ДопМодульКлиентСервер.ЕстьПарсинг(Объект.Наименование) Тогда
			Объект.Парсинг = Ложь;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Рабочее наименование должно содержать слово '(Парсинг)'!");
		ИначеЕсли Не ДопМодульКлиентСервер.ЕстьПарсинг(Объект.НаименованиеПолное) Тогда
			Объект.Парсинг = Ложь;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Публичное наименование должно содержать слово '(Парсинг)'!");
		КонецЕсли; 
	Иначе
		Если ДопМодульКлиентСервер.ЕстьПарсинг(Объект.НаименованиеПолное) ИЛИ
			ДопМодульКлиентСервер.ЕстьПарсинг(Объект.НаименованиеПолное) Тогда 
			
			Объект.Парсинг = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Наименование содержит слово '(Парсинг)', флажок нельзя убрать!");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_КлиентПриИзмененииПосле(Элемент)
	
	Если Объект.Парсинг И Объект.Клиент Тогда
		Объект.Клиент = Ложь;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отметки 'Клиент' и 'Парсинг' не могут быть выбраны одновремено");
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПосле(Отказ, ПараметрыЗаписи)
	Если Объект.Парсинг Тогда
		Если Объект.Клиент Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отметки 'Клиент' и 'Парсинг' не могут быть выбраны одновремено");
		КонецЕсли; 
		
		Если Не ЗначениеЗаполнено(Объект.НаименованиеПолное) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("'Публичное наименование' должно быть заполнено!");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.Наименование) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("'Рабочее наименование' должно быть заполнено!");
		КонецЕсли;               
		
		Если Не ДопМодульКлиентСервер.ЕстьПарсинг(Объект.НаименованиеПолное) ИЛИ 
			Не ДопМодульКлиентСервер.ЕстьПарсинг(Объект.Наименование) Тогда  
			
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Публичное и рабочее наименования должны содержать слово '(парсинг)'!");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.БизнесРегион) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("'Бизнес-регион' должен быть указан!");
		КонецЕсли;
	КонецЕсли;            	
КонецПроцедуры

&НаСервере
Процедура Док_ПередЗаписьюНаСервереПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	ОсновнойМенеджер, МАП
		|ИЗ
		|	Справочник.Партнеры
		|ГДЕ 
		|	Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ТекущийОбъект.Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если ТекущийОбъект.ОсновнойМенеджер <> Выборка.ОсновнойМенеджер Тогда
			ПараметрыЗаписи.Вставить("ИзменениеОсновнойМенеджер", Истина);
		КонецЕсли;
		Если ТекущийОбъект.МАП <> Выборка.МАП Тогда
			ПараметрыЗаписи.Вставить("ИзменениеМАП", Истина);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьТелефонНаСайте()
	Если ОбновитьТелефонНаСайте Тогда
	Если АльтерраОбщегоНазначения.ЭтоРабочаяБаза() Тогда
	   ОтборТелефона = Новый Структура("Вид",ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.ТелефонПартнера"));
	   Телефоны = Объект.КонтактнаяИнформация.НайтиСтроки(ОтборТелефона);
	   Если Телефоны.Количество() >0 Тогда  
	       Телефон = Телефоны[0].НомерТелефона;
