	КонецЕсли;                                  
   КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаписатьЗакреплениеМенеджерМАП(ПараметрыЗаписи);
	
	УстановитьПривилегированныйРежим(Истина);

	Если ПараметрыЗаписи.Свойство("ИзменениеОсновнойМенеджер") Тогда
		ЗаписатьЗакрепление(Объект.ОсновнойМенеджер, Истина);
	КонецЕсли;

	Если ПараметрыЗаписи.Свойство("ИзменениеМАП") Тогда
		ЗаписатьЗакрепление(Объект.МАП, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьЗакрепление(СсылкаМенеджер, ОсновнойМенджер)
	
	ДатаУстановки = ТекущаяДатаСеанса();
	ВидМенеджера = ?(ОсновнойМенджер, Перечисления.ВидМенеджераКлиента.ОсновнойМенеджер, Перечисления.ВидМенеджераКлиента.МАП);
	ДанныеПользователя = ПолучитьДанныеМенеджера(СсылкаМенеджер);
	
	Попытка
		НаборЗаписей = РегистрыСведений.ЗакреплениеКлиентов.СоздатьНаборЗаписей();
		
		НаборЗаписей.Отбор.Период.Установить(ДатаУстановки); 
		НаборЗаписей.Отбор.Клиент.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.ВидМенеджераКлиента.Установить(ВидМенеджера); 
	
		НоваяЗапись = НаборЗаписей.Добавить();      
		НоваяЗапись.Период = ДатаУстановки; 
	   	НоваяЗапись.Клиент = Объект.Ссылка; 
		НоваяЗапись.ВидМенеджераКлиента = ВидМенеджера; 
		НоваяЗапись.ЗакрепленныйПользователь = ДанныеПользователя.Пользователь;
		НоваяЗапись.ПодразделениеПользователя = ДанныеПользователя.ПодразделениеПользователя; 
		НоваяЗапись.ОтделПользователя = ДанныеПользователя.ОтделПользователя; 
		НоваяЗапись.НаправлениеПользователя = ДанныеПользователя.НаправлениеПользователя; 
		НоваяЗапись.АвторИзменения = АльтерраОбщегоНазначения.ТекущийПользователь(); 
		НоваяЗапись.ДатаИВремяЗаписи = ДатаУстановки; 
		НаборЗаписей.Записать();
		
	Исключение
	КонецПопытки;

КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеМенеджера(Менеджер)
	
	Запрос = Новый Запрос;
    Запрос.Текст = 
		"ВЫБРАТЬ 
		|	ДопСведенияОтдел.Объект КАК Пользователь,  
		|	ДопСведенияОтдел.Значение КАК ОтделПользователя
		|ПОМЕСТИТЬ втОтделыПользователей	
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ДопСведенияОтдел 
		|СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДопРеквизитыОтдел
		|	ПО ДопСведенияОтдел.Свойство = ДопРеквизитыОтдел.Ссылка 
		|	И ДопРеквизитыОтдел.Имя = &ИмяОтдела
		|ГДЕ 
		|	ДопСведенияОтдел.Объект ССЫЛКА Справочник.Пользователи      
		|;   
		|
		|//////////////////////////////////////////////////////////////////////////////// 	
		|ВЫБРАТЬ 
		|	ДопСведенияНаправление.Объект КАК Пользователь,  
		|	ДопСведенияНаправление.Значение КАК НаправлениеПользователя
		|ПОМЕСТИТЬ втНаправленияПользователей	
		|ИЗ
		|	РегистрСведений.ДополнительныеСведения КАК ДопСведенияНаправление 
		|СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДопРеквизитыНаправление
		|	ПО ДопСведенияНаправление.Свойство = ДопРеквизитыНаправление.Ссылка 
		|	И ДопРеквизитыНаправление.Имя = &ИмяНаправления
		|ГДЕ 
		|	ДопСведенияНаправление.Объект ССЫЛКА Справочник.Пользователи      
		|;
		|	     
		|//////////////////////////////////////////////////////////////////////////////// 		     
		|ВЫБРАТЬ
		|	Пользователи.Ссылка КАК Пользователь,
		|	Пользователи.Подразделение КАК ПодразделениеПользователя,
		|	втОтделыПользователей.ОтделПользователя,
		|	втНаправленияПользователей.НаправлениеПользователя	
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи  
		|ЛЕВОЕ СОЕДИНЕНИЕ втОтделыПользователей	
		|	ПО Пользователи.Ссылка = втОтделыПользователей.Пользователь
		|ЛЕВОЕ СОЕДИНЕНИЕ втНаправленияПользователей	
		|	ПО Пользователи.Ссылка = втНаправленияПользователей.Пользователь
		|ГДЕ
		|	Пользователи.Ссылка = &Пользователь";
		
	Запрос.УстановитьПараметр("ИмяОтдела", "Отделы");       
	Запрос.УстановитьПараметр("ИмяНаправления", "Направление_a6534376afdf4540a6eac88535d3665b");       
	Запрос.УстановитьПараметр("Пользователь", Менеджер);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ДанныеМенеджера = Новый Структура;
	ДанныеМенеджера.Вставить("Пользователь", 				ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка"));
	ДанныеМенеджера.Вставить("ПодразделениеПользователя", 	ПредопределенноеЗначение("Справочник.СтруктураПредприятия.ПустаяСсылка"));
	ДанныеМенеджера.Вставить("ОтделПользователя", 			ПредопределенноеЗначение("Справочник.ЗначенияСвойствОбъектов.ПустаяСсылка"));
	ДанныеМенеджера.Вставить("НаправлениеПользователя", 	ПредопределенноеЗначение("Справочник.ЗначенияСвойствОбъектов.ПустаяСсылка"));
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеМенеджера, Выборка);
	КонецЕсли;
		
	Возврат ДанныеМенеджера;
	
КонецФункции	

