&НаКлиенте
Процедура Док_СостояниеНомераТелефонаНажатиеПосле(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
		
	Если Объект.СостояниеНомераТелефона = ПредопределенноеЗначение("Перечисление.СостояниеНомераТелефона.Уточнить")
		Или Объект.СостояниеНомераТелефона = ПредопределенноеЗначение("Перечисление.СостояниеНомераТелефона.Подтвердить") Тогда
			ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьЭлементы", ЭтотОбъект);

			ПараметрыФормы = Новый Структура("ТолькоОтправкаКода, НовыйПартнер, Владелец, ИзменениеТелефона, Действие", 
				Истина, Ложь, Объект.Ссылка, Истина, "1c_verify_phone");
			ОткрытьФорму("Справочник.БонусныеПрограммыЛояльности.Форма.Спр_СМСИдентификация", ПараметрыФормы, Неопределено,,,,ОписаниеОповещения);		
	КонецЕсли;

КонецПроцедуры    

&НаКлиенте 
&После("Подключаемый_КонтактнаяИнформацияНачалоВыбора")
Процедура Док_Подключаемый_КонтактнаяИнформацияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Попытка
		Если ТипЗнч(Элемент) = Тип("ПолеФормы") И СтрНайти(Элемент.Имя, "КонтактнаяИнформация") = 1 
			И Элемент.ТекстРедактирования = ПолучитьСохраненныйНомерТелефона() Тогда
				ИзменениеНомераТелефона = Истина;
			КонецЕсли
	Исключение
	КонецПопытки;
	
КонецПроцедуры 

&НаКлиенте   
