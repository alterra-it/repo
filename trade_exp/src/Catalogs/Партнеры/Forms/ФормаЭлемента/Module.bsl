&НаСервере
Процедура Спр_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Элементы.Парсинг.Доступность = АльтерраОбщегоНазначения._ЕстьРоль("УстановкаФлажкаПарсингВПартнерах");
	
	// Альтерра Устинов В.А. Начало блока 14.03.2013 15:26:55
	Элементы.ОсновнойМенеджер.Доступность=рольДоступна("ПолныеПрава") или рольДоступна("ОтделАналитики");
	//Светлакова
	Элементы.БонуснаяПрограммаАктивна.ТолькоПросмотр = не (рольДоступна("ПолныеПрава") или рольДоступна("НазначениеСтатусовКлиентовВБонуснойПрограмме")) или Объект.БонуснаяПрограммаАктивна = 1 ;
	Элементы.ПИН_Код.Видимость = рольДоступна("ПолныеПрава"); //или рольДоступна("НазначениеСтатусовКлиентовВБонуснойПрограмме")) ;
	
	//Этапы строительства+
	//добавление элемента на форму
	ПолеЛюбимыйМагазин = Элементы.Добавить("ЛюбимыйМагазин", Тип("ПолеФормы"), Элементы.ГруппаМенеджерДоступ);
	ПолеЛюбимыйМагазин.ПутьКДанным = "Объект.ЛюбимыйМагазин";
	ПолеЛюбимыйМагазин.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЛюбимыйМагазин.Заголовок = "Любимый магазин";
	
	ПолеСпособОтгрузки = Элементы.Добавить("СпособОтгрузки", Тип("ПолеФормы"), Элементы.ГруппаМенеджерДоступ);
	ПолеСпособОтгрузки.ПутьКДанным = "Объект.СпособОтгрузки";
	ПолеСпособОтгрузки.Вид = ВидПоляФормы.ПолеВвода;
	ПолеСпособОтгрузки.Заголовок = "Способ отгрузки";
	
	//Элементы.МАП.Доступность = рольДоступна("ПолныеПрава") или рольДоступна("ИзменениеОсновногоМенеджераПартнера");
	Элементы._ГруппаЭтапСтроительства.Видимость = АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Объект.Ссылка);
	ОбновитьДоступностьЭлементовСтроительства();
	РасчетПотенциала();
	//+Этапы строительства
	
	//Видимость для «Группа партнеров» «Частные лица» и "Сотрудники"
	Если АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Объект.Ссылка) Или АльтерраОбщегоНазначения.ЭтоСотрудник(Объект.Ссылка)Тогда
		Элементы.ГруппаСостояниеНомераТелефона.Видимость = Истина;
	КонецЕсли; 
	
	//Видимость для Годового оборота (для последующей доработки)
	Элементы.ГруппаГодовойОборот.Видимость = Ложь;
	//Элементы.ГруппаГодовойОборот.Видимость = ?(АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Объект.Ссылка) Или Не ЗначениеЗаполнено(Объект.ГодовойОборот) , Ложь, Истина);
	
	Элементы.НормативПоУмолчанию.Видимость = Объект.Поставщик;
	
	Если Параметры.Ключ.Пустая() Тогда
    	Объект.БонуснаяПрограммаАктивна = Ложь;
	КонецЕсли;
	
   ОбновитьТелефонНаСайте = Ложь;//
	
КонецПроцедуры

&НаКлиенте
Процедура Спр_БонуснаяПрограммаАктивнаПриИзмененииПосле(Элемент)
		Если  Объект.БонуснаяПрограммаАктивна = 1 и  Объект.ДатаАктивацииБонуснойПрограммы = '00010101000000' Тогда
	  	   Объект.ДатаАктивацииБонуснойПрограммы = ТекущаяДата();
		  иначеЕсли  Объект.БонуснаяПрограммаАктивна = 0 Тогда  
		   Объект.ДатаАктивацииБонуснойПрограммы = '00010101000000'; 
	    КонецЕсли;
КонецПроцедуры

