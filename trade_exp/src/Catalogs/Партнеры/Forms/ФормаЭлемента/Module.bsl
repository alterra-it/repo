&НаСервере
Функция ПользовательИмеетПраваУТСК(Пользователь)
	ЕстьПрава = Ложь;
	Если  Объект.АктивнаяФаза <> Справочники.ЭтапыСтроительства.ПустаяСсылка() Тогда
		ТекОбъект = РеквизитФормыВЗначение("Объект");
		АктуальныйУТСК = ТекОбъект.ПолучитьАктуальногоУТСК(Объект.Ссылка);
		ЕстьПрава = АктуальныйУТСК=Пользователь;
	Иначе
		ГруппаПользователейРТСК = Справочники.ГруппыПользователей.НайтиПоНаименованию("Руководитель ТСК");
		МассивУТСК = ГруппаПользователейРТСК.Состав.Выгрузить().ВыгрузитьКолонку("Пользователь");
		ЕстьПрава = МассивУТСК.Найти(Пользователь)<>Неопределено;
	КонецЕсли;
	Возврат ЕстьПрава; 
КонецФункции // ПолучитьУТСК()

&НаСервере 
Процедура РасчетПотенциала()
	Если ЗначениеЗаполнено(Объект.АктивнаяФаза) Тогда
		Потенциал = Объект.АктивнаяФаза.СтроительныйОбъем*Объект.ОбъемСтроительства*3600;
	КонецЕсли;
КонецПроцедуры

&НаСервере 
Процедура ОткрытьПараметрыЗавершениеСервер(Результат) Экспорт 
	Если ТипЗнч(Результат) = Тип("ДанныеФормыКоллекция") тогда 
		Для каждого Строка из Результат Цикл
			Для каждого СтрокаТЗ из Объект.ВидыНоменклатурыАктивнойФазы Цикл
				Если СтрокаТЗ.ВидНоменклатуры = Строка.ВидНоменклатуры Тогда
					Объект.ВидыНоменклатурыАктивнойФазы.Удалить(СтрокаТЗ);
				КонецЕсли;
			КонецЦикла;
			НоваяСтрока = Объект.ВидыНоменклатурыАктивнойФазы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
		КонецЦикла;
	конецесли;
КонецПроцедуры 

