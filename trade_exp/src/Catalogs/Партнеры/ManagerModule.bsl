		Если ЗначениеЗаполнено(ПараметрыПроверки) Тогда
			Запрос.УстановитьПараметр("Партнер", Справочники.Партнеры.ПустаяСсылка());
			Запрос.УстановитьПараметр("ТипПочта", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
