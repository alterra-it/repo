
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
//Функция возвращает ссылку справочника по входящим параметрам
// Передана строка - по наименованию, число - по коду
// Структура - по параметрам в структуре
// если не найдено - создает элемент,если в структуре нет реквизита "НеСоздавать" 
Функция ВернутьСобытиеОбъекта(ПараметрСобытия) экспорт
	СтруктураПараметра=Новый Структура();
	если  типзнч(ПараметрСобытия)=тип("Строка") тогда
		СпрСобытие=Справочники.СобытияОбъектовАльтерра.НайтиПоНаименованию(ПараметрСобытия,истина);
		если Не ЗначениеЗаполнено(СпрСобытие) тогда
			СтруктураПараметра.Вставить("Наименование",ПараметрСобытия);
		иначе
			Возврат СпрСобытие;
		конецесли;
	иначеесли типзнч(ПараметрСобытия)=тип("число") тогда 
		СпрСобытие=Справочники.СобытияОбъектовАльтерра.НайтиПоКоду(ПараметрСобытия);
		если Не ЗначениеЗаполнено(СпрСобытие) тогда
		СтруктураПараметра.Вставить("Код",ПараметрСобытия);
		иначе
			Возврат СпрСобытие;
		конецесли;
	иначеесли типзнч(ПараметрСобытия)=тип("Структура") тогда 	
		если ПараметрСобытия.Свойство("Код") тогда
			СпрСобытие=Справочники.СобытияОбъектовАльтерра.НайтиПоКоду(ПараметрСобытия.Код);
			если Не ЗначениеЗаполнено(СпрСобытие) тогда
				СтруктураПараметра.Вставить("Код",ПараметрСобытия.Код);
			иначе	
				Возврат СпрСобытие;
			конецесли;	
		конецесли;
		если ПараметрСобытия.Свойство("Наименование") тогда
			СпрСобытие=Справочники.СобытияОбъектовАльтерра.НайтиПоНаименованию(ПараметрСобытия.Наименование);
			если Не ЗначениеЗаполнено(СпрСобытие) тогда
				СтруктураПараметра.Вставить("Наименование",ПараметрСобытия.Наименование);
			иначе	
				Возврат СпрСобытие;
			конецесли;	
		конецесли;
		если ПараметрСобытия.Свойство("НеСоздавать") тогда
			Возврат НЕОПРЕДЕЛЕНО;
		конецесли;	
	конецесли;
	
		попытка
				Спр=Справочники.СобытияОбъектовАльтерра.СоздатьЭлемент();
				ЗаполнитьЗначенияСвойств(спр,СтруктураПараметра);
				Спр.Записать();
		исключение
				
		конецпопытки;
	    Возврат Спр.Ссылка;

КонецФункции // СобытиеСправочникаПоСтроке()

