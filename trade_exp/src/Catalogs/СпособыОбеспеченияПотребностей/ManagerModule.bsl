#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Функция ПолучитьНовыйНомер() экспорт
 	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СпособыОбеспеченияПотребностей.Ссылка) КАК Количество
	|ИЗ
	|	Справочник.СпособыОбеспеченияПотребностей КАК СпособыОбеспеченияПотребностей";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если  ВыборкаДетальныеЗаписи.Следующий() тогда
		возврат ВыборкаДетальныеЗаписи.Количество+1;
	иначе 
		возврат 1;
	Конецесли;
КонецФункции // ()

