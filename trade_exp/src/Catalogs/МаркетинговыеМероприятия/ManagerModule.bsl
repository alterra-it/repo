	Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
		Возврат ЗначениеЗаполнено(Объект.Кассир);
	ИначеЕсли ТипЗнч(Объект) = Тип("ДокументОбъект.ЧекККМ") Тогда
		Возврат Объект.Статус = Перечисления.СтатусыЧековККМ.Пробит;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

Функция ЕстьЗапретНаБонусы(Объект, РазрешитьЮЛ = Ложь, НовыйПорядокНачисления = Ложь);    
	
	Запрет = Ложь;
	Если Не БонусыАльтерра.УчаствуетПартнерВБонуснойПрограмме(Объект.Партнер, РазрешитьЮЛ) Тогда
		Запрет = Истина;
	КонецЕсли;
	Если НовыйПорядокНачисления Тогда
		Если БонусыАльтерраРезерв.ПроверитьЗапретБонусов(Объект, РазрешитьЮЛ, Ложь) Тогда
			Запрет = Истина;
		КонецЕсли;
	Иначе
		Если БонусыАльтерра.ПроверитьЗапретБонусов(Объект, РазрешитьЮЛ) Тогда
			Запрет = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Запрет;
КонецФункции

Функция РассчитатьСкидкиНаценкиВДокументе(Объект) 
	
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Истина);
	Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(Объект, "РеализацияПоЗаказам") Тогда
		СтруктураПараметры.Вставить("РеализацияСверхЗаказа", Объект.РеализацияПоЗаказам)
	КонецЕсли;

	ПримененныеСкидки = СкидкиНаценкиСервер.Рассчитать(Объект, СтруктураПараметры);
	Объект.СкидкиРассчитаны = Истина;    
	
	Если  ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		Объект.ЭтапыГрафикаОплаты.Очистить();
		ВзаимоРасчетыСервер.ПроверитьЗаполнитьЭтапыГрафикаОплаты(Объект); 
	КонецЕсли;
КонецФункции
#КонецОбласти

#КонецЕсли
