#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область Акции

Процедура РасчетПоМаркетинговымМероприятиям(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	ЭтоЗаказ = ?(ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента"),Истина,Ложь);
	РеализацияПоЗаказу = ?(ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") И ЗначениеЗаполнено(Объект.ЗаказКлиента),Истина,Ложь);
	
	НовыйПорядокНачисления = БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Объект);
	
	ДокДата = ?(НовыйПорядокНачисления И ЭтоЗаказ, Объект.ДатаСоздания, Объект.Дата);
	ДокДата = ?(НовыйПорядокНачисления И РеализацияПоЗаказу И ЗначениеЗаполнено(Объект.ЗаказКлиента), Объект.ЗаказКлиента.ДатаСоздания, Объект.Дата);
	 
	Если ПолучитьВсеДействующиеМероприятия(ДокДата).Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
    //Очищение таблицы по акциям
	Объект.Акции.Очистить();

	ТаблицаПримененныхАкций = Новый ТаблицаЗначений();
	ТаблицаПримененныхАкций.Колонки.Добавить("МаркетинговоеМероприятие");
	ТаблицаПримененныхАкций.Колонки.Добавить("Действие");
	ТаблицаПримененныхАкций.Колонки.Добавить("Баллы");
	ТаблицаПримененныхАкций.Колонки.Добавить("НеПрименено");
	
	//Проверка по алгоритмам
	Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказНаДоставкуКлиенту") Тогда 
		
		Если Не ЗаказНаДоставкуПодходитПодУсловия(Объект.Ссылка) Тогда
			Возврат;
		КонецЕсли;
		
		Если ТипЗнч(Объект.Партнер) = Тип("СправочникСсылка.Партнеры") Тогда
			Если Не БонусыАльтерра.УчаствуетПартнерВБонуснойПрограмме(Объект.Партнер) Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;  
		
		АкцииНаДоставку = ДействующиеМаркетинговыеМероприятияПоАлгоритмуАкции(Перечисления.АлгоритмыАкций.ЗаДоставку,Объект.Подразделение,ДокДата);
		
		//Проверяем подходит ли заказ под условия и существуют ли мероприятия с типом алгоритма "За доставку"
		Если АкцииНаДоставку.Количество()>0 Тогда
			ТЗНоменклатуры = ПолучитьНоменклатуруДляРасчета(Объект.Основания.Выгрузить(,"Документ"));
			СтруктураДействийИМероприятий = ПолучитьСтруктуруДействийИМероприятийПоОтборуПартнураИНоменклатуры(Объект.Партнер,ТЗНоменклатуры.ВыгрузитьКолонку("Номенклатура"),АкцииНаДоставку,ТаблицаПримененныхАкций);
			ЗаполнитьЗначенияСвойств(ТаблицаПримененныхАкций,СтруктураДействийИМероприятий);
		Иначе
			Возврат;
		КонецЕсли;
		
	Иначе
		МожноНачислитьБонусы = Не ЕстьЗапретНаБонусы(Объект,,НовыйПорядокНачисления);
		
		АкцииЗаТовар = ДействующиеМаркетинговыеМероприятияПоАлгоритмуАкции(Перечисления.АлгоритмыАкций.ЗаТовар,Объект.Подразделение,ДокДата);  
		
		ТЗНоменклатуры = БонусыАльтерраРезерв.ПолучитьТоварыКРасчетуБаллов(Объект.Товары, ЭтоЗаказ, Объект.Дата, Истина);  
		МассивНоменклатуры = ТЗНоменклатуры.ВыгрузитьКолонку("Номенклатура");
		ТЗНоменклатурыБезБонусов = БонусыАльтерраРезерв.ПолучитьТоварыКРасчетуБаллов(Объект.Товары, ЭтоЗаказ, Объект.Дата, Ложь);
		МассивНоменклатурыБезБонусов = ТЗНоменклатурыБезБонусов.ВыгрузитьКолонку("Номенклатура");
		
		//Проверяем существуют ли мероприятия с типом алгоритма "За товар"
		Если АкцииЗаТовар.Количество() > 0 Тогда
			СтруктураДействийИМероприятий = ПолучитьСтруктуруДействийИМероприятийПоОтборуПартнураИНоменклатуры(Объект.Партнер, МассивНоменклатуры, АкцииЗаТовар,ТаблицаПримененныхАкций);
			ЗаполнитьЗначенияСвойств(ТаблицаПримененныхАкций,СтруктураДействийИМероприятий);
		КонецЕсли;
		
		АкцииЗаПромокод = ДействующиеМаркетинговыеМероприятияПоАлгоритмуАкции(Перечисления.АлгоритмыАкций.ЗаПромокод,Объект.Подразделение,ДокДата);
		
		//Проверяем существуют ли мероприятия с типом алгоритма "За промокод"
		Если АкцииЗаПромокод.Количество() > 0 Тогда  
			
			Если МожноНачислитьБонусы Тогда 
			
				Если ЗначениеЗаполнено(Объект.Промокод) Тогда
					
					МероприятияПоОтборуПромокод = ПолучитьМероприятияПоОтборуПромокод(Объект.Промокод,Объект.Подразделение,ДокДата);
					
					Для каждого СтрокаМероприятие из МероприятияПоОтборуПромокод Цикл
						
						Для каждого СтрокаДействие из СтрокаМероприятие.Ссылка.Действия Цикл
							
							НоваяСтрока = ТаблицаПримененныхАкций.Добавить();
							НоваяСтрока.МаркетинговоеМероприятие = СтрокаМероприятие.Ссылка;
							НоваяСтрока.Действие = СтрокаДействие.Действие;
							
						КонецЦикла;	
						
					КонецЦикла;
					
				КонецЕсли;
				
				Если ЗначениеЗаполнено(Объект.ПривелКлиент) Тогда
					
					СтруктураДействийИМероприятий = ПолучитьСтруктуруДействийИМероприятийПоОтборуПартнураИНоменклатуры(Объект.ПривелКлиент, МассивНоменклатуры, АкцииЗаПромокод,ТаблицаПримененныхАкций,Истина);
					
					Если СтруктураДействийИМероприятий.ТаблицаПримененныхАкций.Количество()>0 Тогда
						ЗаполнитьЗначенияСвойств(ТаблицаПримененныхАкций,СтруктураДействийИМероприятий);
					КонецЕсли;
					
				КонецЕсли;
			
			КонецЕсли;
						
		КонецЕсли;
		
	КонецЕсли;
	
	//Выполнение действий
	Если ТаблицаПримененныхАкций.Количество() > 0 Тогда
		
		ПересчитатьБонусныеБаллы = Ложь;
		СтатусИзменен = Ложь;       
		РассчитатьСкидкиНаценки = Ложь;   
		СтрокиСРеализацией = Новый Массив;
		
		
		Для каждого СтрокаТаблицы из ТаблицаПримененныхАкций Цикл
			
			Если СтрокаТаблицы.Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.УстановитьВидЦены Тогда     
				
				Если Не ЕстьЗапретНаБонусы(Объект, Истина, НовыйПорядокНачисления) Тогда 
				
					ПересчитатьБонусныеБаллы = Ложь;
					
					Для Каждого СтрокаТовар Из ТЗНоменклатуры Цикл
						
						НовыйВидЦены = Справочники.МаркетинговыеМероприятия.ПолучитьПроцентБонусовВидЦеныПоНоменклатуре(СтрокаТаблицы.МаркетинговоеМероприятие,СтрокаТовар.Номенклатура,СтрокаТовар.Характеристика,СтрокаТаблицы.Действие);		
						
						Если ЗначениеЗаполнено(НовыйВидЦены) Тогда
							
							НоваяЦена = АльтерраОбщегоНазначения.ПолучитьЦену(СтрокаТовар.Номенклатура, НовыйВидЦены);
							
							НайденнаяСтрока = Объект.Товары[СтрокаТовар.НомерСтроки-1];
							
							Если НоваяЦена < НайденнаяСтрока.Цена Тогда  
								НайденнаяСтрока.ВидЦены = НовыйВидЦены;
								НайденнаяСтрока.Цена = НоваяЦена;					
								АльтерраОбщегоНазначения.ПересчитатьСуммыВСтрокеТовара(Объект, НайденнаяСтрока);
								
								НайденнаяСтрока.Сумма = НайденнаяСтрока.Сумма - НайденнаяСтрока.СуммаБонусныхБалловКСписанию;
								НайденнаяСтрока.СуммаСНДС = НайденнаяСтрока.СуммаСНДС - НайденнаяСтрока.СуммаБонусныхБалловКСписанию;

								Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
									Объект.ПричинаОтклоненияОтЦеновыхУсловий = Объект.ПричинаОтклоненияОтЦеновыхУсловий + " Акция: " + СтрокаТаблицы.МаркетинговоеМероприятие.Наименование + " - Строка №" + Строка(СтрокаТовар.НомерСтроки) + " " ;
								КонецЕсли;
								
								ПересчитатьБонусныеБаллы = Истина; 
								РассчитатьСкидкиНаценки = Истина;
								
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЦикла;
					
				Иначе
					СтрокаТаблицы.НеПрименено = Истина;	
				КонецЕсли;
							
			КонецЕсли;
			
			Если СтрокаТаблицы.Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.СменитьСтатусУчастникаБонуснойПрограммы Тогда 
				
				Если МожноНачислитьБонусы Тогда
				
					СтарыйСтатус = Объект.СтатусПартнераВПрограммеЛояльности;
					НовыйСтатус = СтрокаТаблицы.Действие.СтатусУчастникаБонуснойПрограммы;
					
					Если НовыйСтатус.Коэффициент > СтарыйСтатус.Коэффициент Тогда    
					
						БонусыАльтерра.ОбновитьСтатусВРегистре(Объект.Партнер,НовыйСтатус);
						СтатусИзменен = Истина;
						
						Если Не ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЗаказНаДоставкуКлиенту") Тогда 
							
							ПересчитатьБонусныеБаллы = Истина;
							
						КонецЕсли;
						
					КонецЕсли;
				Иначе
					СтрокаТаблицы.НеПрименено = Истина;				
				КонецЕсли
				
			КонецЕсли;
				
		КонецЦикла;

		Если ПересчитатьБонусныеБаллы Тогда
			БонусыАльтерраРезерв.НачислитьБонусныеБаллы(Объект);
		КонецЕсли;
		
		Если РассчитатьСкидкиНаценки Тогда
			РассчитатьСкидкиНаценкиВДокументе(Объект);
		КонецЕсли;
		
		Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЗаказНаДоставкуКлиенту") Тогда
			ДокументОплачен = Истина;
		ИначеЕсли ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
			ДокументОплачен = Объект.Статус = Перечисления.СтатусыЧековККМ.Пробит;
		Иначе
			ДокументОплачен = ЗначениеЗаполнено(Объект.Кассир);
		Конецесли;
		
		Если Не ДокументОплачен И СтатусИзменен Тогда
			
			Набор = РегистрыСведений.СтатусыПартнеровВПрограммеЛояльности_Альтерра.СоздатьНаборЗаписей();
			Набор.Отбор.Период.Установить(ТекущаяДата());
			Набор.Отбор.БонуснаяПрограммаЛояльности.Установить(Справочники.БонусныеПрограммыЛояльности.НайтиПоНаименованию("Бонус от ALTERRA", Истина));
			Набор.Отбор.Партнер.Установить(Объект.Партнер);
			Набор.Записать();
			
		КонецЕсли;
		
		СуммаББПрочее = 0;
		
		Для каждого СтрокаТаблицы из ТаблицаПримененныхАкций Цикл
			
			Если СтрокаТаблицы.Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.НачислитьБонусыПроцентом Тогда      
				
				Если МожноНачислитьБонусы Тогда
				
					ПримененоНаТовар = Ложь;
				
					СуммаДополнительныхБонусов = 0;
					Для Каждого СтрокаТовар Из ТЗНоменклатуры Цикл			
						
						Если Не СтрокаТовар.БезБонусов Тогда 
							
							ДополнительныйПроцент = 0;
							ДополнительныйПроцент = Справочники.МаркетинговыеМероприятия.ПолучитьПроцентБонусовВидЦеныПоНоменклатуре(СтрокаТаблицы.МаркетинговоеМероприятие,СтрокаТовар.Номенклатура,СтрокаТовар.Характеристика,СтрокаТаблицы.Действие);
							Если ДополнительныйПроцент > 0 Тогда
								НайденнаяСтрока = Объект.Товары[СтрокаТовар.НомерСтроки-1];
								СуммаДополнительныхБонусовПоНоменклатуре = Цел(НайденнаяСтрока.Сумма*ДополнительныйПроцент);
								Если НовыйПорядокНачисления Тогда
									НайденнаяСтрока.СуммаНачисленныхБалловПрочее = СуммаДополнительныхБонусовПоНоменклатуре;
									НайденнаяСтрока.СуммаНачисленныхБонусныхБалловВВалюте = НайденнаяСтрока.СуммаНачисленныхБалловЗаСтатус
																							+ НайденнаяСтрока.СуммаНачисленныхБалловЗаКП
																							+ НайденнаяСтрока.СуммаНачисленныхБалловПрочее;
								Иначе
									НайденнаяСтрока.СуммаНачисленныхБонусныхБалловВВалюте = НайденнаяСтрока.СуммаНачисленныхБонусныхБалловВВалюте + СуммаДополнительныхБонусовПоНоменклатуре;
								КонецЕсли;
								
								СуммаДополнительныхБонусов = СуммаДополнительныхБонусов + СуммаДополнительныхБонусовПоНоменклатуре;	
								
								ПримененоНаТовар = Истина;	
							КонецЕсли;	
						КонецЕсли;
					КонецЦикла;
					
					СтрокаТаблицы.Баллы = СуммаДополнительныхБонусов;
					СуммаББПрочее = СуммаББПрочее + СуммаДополнительныхБонусов;
					
					Если Не ПримененоНаТовар Тогда 
						СтрокаТаблицы.НеПрименено = Истина;				
					КонецЕсли
				Иначе
					СтрокаТаблицы.НеПрименено = Истина				
				КонецЕсли;
				
			КонецЕсли;
			
			Если СтрокаТаблицы.Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.НачислитьБонусыСуммой Тогда 
				
				Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказНаДоставкуКлиенту") Тогда
					МассивНоменклатурыБезБонусов = ТЗНоменклатуры.ВыгрузитьКолонку("Номенклатура");
				КонецЕсли;
				
				ТЗ = ПолучитьМероприятияПоОтборуНоменклатуры(МассивНоменклатурыБезБонусов, СтрокаТаблицы.МаркетинговоеМероприятие);
				
				Если МожноНачислитьБонусы И (ТЗ.Количество() > 0 ИЛИ СтрокаТаблицы.Действие.Алгоритм = Перечисления.АлгоритмыАкций.ЗаПромокод) Тогда 

					Если ДокументОплачен(Объект, НовыйПорядокНачисления) И Не СозданоНачислениеПоДокументу(Объект.Ссылка,СтрокаТаблицы.МаркетинговоеМероприятие,Справочники.ПричиныНачисленияБонусныхБаллов.ПоАкции) Тогда
						СоздатьНачислениеБонусов(АльтерраОбщегоНазначения.ПолучитьБонуснуюПрограмму(),Объект.Ссылка,Объект.Партнер,СтрокаТаблицы.МаркетинговоеМероприятие,СтрокаТаблицы.Действие.СуммаБонусов,"Начислено по акции на основании документа " + Строка(Объект.Номер) + " от " + Строка(Объект.Дата),Справочники.ПричиныНачисленияБонусныхБаллов.ПоАкции);
					КонецЕсли; 
					
				Иначе
					СтрокаТаблицы.НеПрименено = Истина									
				КонецЕсли;
				
			КонецЕсли;
			
			Если СтрокаТаблицы.Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.НачислитьБонусыЗаНовогоКлиента И ЗначениеЗаполнено(Объект.ПривелКлиент) Тогда
				
				Если МожноНачислитьБонусы Тогда
				
					Если ДокументОплачен(Объект, НовыйПорядокНачисления) И Не СозданоНачислениеПоДокументу(Объект.Ссылка,СтрокаТаблицы.МаркетинговоеМероприятие,Справочники.ПричиныНачисленияБонусныхБаллов.ЗаНовогоКлиента) Тогда
						СоздатьНачислениеБонусов(АльтерраОбщегоНазначения.ПолучитьБонуснуюПрограмму(),Объект.Ссылка,Объект.ПривелКлиент,СтрокаТаблицы.МаркетинговоеМероприятие,СтрокаТаблицы.Действие.СуммаБонусов,"Начислено по акции на основании документа " + Строка(Объект.Номер) + " от " + Строка(Объект.Дата),Справочники.ПричиныНачисленияБонусныхБаллов.ЗаНовогоКлиента);
					КонецЕсли;
					
				Иначе
					СтрокаТаблицы.НеПрименено = Истина				
				КонецЕсли;
				
			КонецЕсли;			
			
		КонецЦикла;
		
		Если СуммаББПрочее > 0 Тогда
			
			Если Не НовыйПорядокНачисления Тогда
				НоваяСтрока = Объект.БонусныеБаллы.Добавить();
				НоваяСтрока.БонуснаяПрограммаЛояльности = АльтерраОбщегоНазначения.ПолучитьБонуснуюПрограмму();
				НоваяСтрока.ДатаНачисления = НачалоДня(Объект.Дата)+3600*24*3;
				НоваяСтрока.СуммаБонусныхБаллов = СуммаББПрочее;
			Иначе
				Если Объект.БонусныеБаллы.Количество() > 0 Тогда
					НоваяСтрока = Объект.БонусныеБаллы[0];
				Иначе
					НоваяСтрока = Объект.БонусныеБаллы.Добавить();
					НоваяСтрока.БонуснаяПрограммаЛояльности = АльтерраОбщегоНазначения.ПолучитьБонуснуюПрограмму();
					НоваяСтрока.ДатаНачисления = НачалоДня(Объект.Дата)+3600*24*3;
				КонецЕсли;
				
				НоваяСтрока.СуммаБонусныхБалловПрочее = СуммаББПрочее; 
				НоваяСтрока.СуммаБонусныхБаллов = НоваяСтрока.СуммаБонусныхБалловЗаСтатус
				+ НоваяСтрока.СуммаБонусныхБалловЗаКП
				+ НоваяСтрока.СуммаБонусныхБалловПрочее;
				
			КонецЕсли;
		КонецЕсли;
		
		ТаблицаАкций = Новый ТаблицаЗначений;
		ПараметрыОтбора = Новый Структура("НеПрименено", Неопределено);
		ТаблицаАкций = ТаблицаПримененныхАкций.Скопировать(ПараметрыОтбора);   
		
		Объект.Акции.Загрузить(ТаблицаАкций);
			
	Иначе
		Возврат;
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

