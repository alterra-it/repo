Функция ПолучитьСтруктуруДействийИМероприятийПоОтборуПартнураИНоменклатуры(Партнер,Товары,МассивМероприятий,ТаблицаПримененныхАкций,ОтборТолькоПоПартнеру = Ложь) Экспорт
	
	МероприятияПоОтборуПартнера = ПолучитьМероприятияПоОтборуПартнера(Партнер,МассивМероприятий);
	//Проверяем подходит ли документ по партнеру из документов оснований
	Если МероприятияПоОтборуПартнера.Количество()>0 Тогда
		
		Если ОтборТолькоПоПартнеру Тогда
			Для каждого СтрокаМероприятие из МероприятияПоОтборуПартнера Цикл
				
				Для каждого СтрокаДействие из СтрокаМероприятие.Ссылка.Действия Цикл
					
					НоваяСтрока = ТаблицаПримененныхАкций.Добавить();
					НоваяСтрока.МаркетинговоеМероприятие = СтрокаМероприятие.Ссылка;
					НоваяСтрока.Действие = СтрокаДействие.Действие;
										
				КонецЦикла;	
			КонецЦикла;
				
			Иначе
				МероприятияПоОтборуНоменклатуры = ПолучитьМероприятияПоОтборуНоменклатуры(Товары,МероприятияПоОтборуПартнера);
				//Проверяем подходит ли документ по товару из документов оснований	
				Если МероприятияПоОтборуНоменклатуры.Количество()>0 Тогда
					
					Для каждого СтрокаМероприятие из МероприятияПоОтборуНоменклатуры Цикл
						
						Для каждого СтрокаДействие из СтрокаМероприятие.Ссылка.Действия Цикл
							
							НоваяСтрока = ТаблицаПримененныхАкций.Добавить();
							НоваяСтрока.МаркетинговоеМероприятие = СтрокаМероприятие.Ссылка;
							НоваяСтрока.Действие = СтрокаДействие.Действие;
							
						КонецЦикла;	
						
					КонецЦикла;	
					
				КонецЕсли;
			КонецЕсли;
			
	КонецЕсли;

	Возврат Новый Структура("ТаблицаПримененныхАкций",ТаблицаПримененныхАкций);
	
КонецФункции

Функция ПолучитьМероприятияПоОтборуНоменклатуры(МассивНоменклатуры, МассивМероприятий) Экспорт
	 		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|ГДЕ
		|	МаркетинговыеМероприятия.ТипОтбора = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоСписку)
		|	И МаркетинговыеМероприятия.Ссылка В(&Ссылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркетинговыеМероприятия.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|		ПО МаркетинговыеМероприятия.СегментНоменклатуры = НоменклатураСегмента.Сегмент
		|ГДЕ
		|	НоменклатураСегмента.Номенклатура В(&Номенклатура)
		|	И МаркетинговыеМероприятия.Ссылка В(&Ссылка)
		|	И МаркетинговыеМероприятия.ТипОтбора = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоСегменту)
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркетинговыеМероприятия.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|ГДЕ
		|	МаркетинговыеМероприятия.Ссылка В(&Ссылка)
		|	И МаркетинговыеМероприятия.ТипОтбора = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоВсемЭлементам)
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркетинговыеМероприятия.Ссылка";

	
	Запрос.УстановитьПараметр("Номенклатура", МассивНоменклатуры);
	Запрос.УстановитьПараметр("Ссылка", МассивМероприятий);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Акции = Новый ТаблицаЗначений;
	Акции.Колонки.Добавить("Ссылка");
	
	Пока РезультатЗапроса.Следующий() Цикл
		Если РезультатЗапроса.Ссылка.ТипОтбора = Перечисления.ТипОтбора.ПоСписку Тогда
			НоменклатураПоАкцииЕсть = Ложь;
			Для каждого СтрокаТоварыАкции из РезультатЗапроса.Ссылка.ТоварыАкции Цикл
				Если ЗначениеЗаполнено(СтрокаТоварыАкции.Номенклатура) Тогда
					НоменклатураПоАкцииЕсть = Не МассивНоменклатуры.Найти(СтрокаТоварыАкции.Номенклатура) = Неопределено;
				ИначеЕсли ЗначениеЗаполнено(СтрокаТоварыАкции.ВидНоменклатуры) Тогда
					НоменклатураПоАкцииЕсть = СоотвествиеВидуНоменклатуры(МассивНоменклатуры,СтрокаТоварыАкции.ВидНоменклатуры); 
				Иначе
					НоменклатураПоАкцииЕсть = СоотвествиеГруппеНоменклатуры(МассивНоменклатуры,СтрокаТоварыАкции.ГруппаНоменклатуры); 
				КонецЕсли;
				Если НоменклатураПоАкцииЕсть Тогда
					НоваяСтрока = Акции.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока,РезультатЗапроса);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		Иначе
			НоваяСтрока = Акции.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,РезультатЗапроса);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Акции;

КонецФункции

Функция СоотвествиеВидуНоменклатуры(МассивНоменклатуры,ВидНоменклатуры)
	 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В(&Ссылка)
		|	И Номенклатура.ВидНоменклатуры = &ВидНоменклатуры";
	
	Запрос.УстановитьПараметр("Ссылка", МассивНоменклатуры);
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

Функция СоотвествиеГруппеНоменклатуры(МассивНоменклатуры,ГруппаНоменклатуры)
	 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В(&Ссылка)
		|	И Номенклатура.Родитель В ИЕРАРХИИ(&Родитель)";
	
	Запрос.УстановитьПараметр("Ссылка", МассивНоменклатуры);
	Запрос.УстановитьПараметр("Родитель", ГруппаНоменклатуры);
		
	Возврат Не Запрос.Выполнить().Пустой();

	
КонецФункции

Функция ПолучитьМероприятияПоОтборуПартнера(Партнер,МассивМероприятий) Экспорт	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПартнерыСегмента.Сегмент КАК Сегмент
		|ПОМЕСТИТЬ СегментыПартнера
		|ИЗ
		|	РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
		|ГДЕ
		|	ПартнерыСегмента.Партнер = &Клиент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|ГДЕ
		|	МаркетинговыеМероприятия.Ссылка В(&Ссылка)
		|	И МаркетинговыеМероприятия.ТипОтбораПартнер = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоСегменту)
		|	И ВЫБОР
		|			КОГДА МаркетинговыеМероприятия.Клиент = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
		|				ТОГДА МаркетинговыеМероприятия.СегментПартнеров В
		|						(ВЫБРАТЬ
		|							СегментыПартнера.Сегмент КАК Ссылка
		|						ИЗ
		|							СегментыПартнера)
		|			ИНАЧЕ МаркетинговыеМероприятия.Клиент = &Клиент
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркетинговыеМероприятия.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.МаркетинговыеМероприятия.ПартнерыАкции КАК МаркетинговыеМероприятияПартнерыАкции
		|		ПО МаркетинговыеМероприятия.Ссылка = МаркетинговыеМероприятияПартнерыАкции.Ссылка
		|ГДЕ
		|	МаркетинговыеМероприятия.Ссылка В(&Ссылка)
		|	И МаркетинговыеМероприятия.ТипОтбораПартнер = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоСписку)
		|	И ВЫБОР
		|			КОГДА НЕ МаркетинговыеМероприятияПартнерыАкции.СегментПартнеров = ЗНАЧЕНИЕ(Справочник.СегментыПартнеров.ПустаяСсылка)
		|				ТОГДА МаркетинговыеМероприятияПартнерыАкции.СегментПартнеров В
		|						(ВЫБРАТЬ
		|							СегментыПартнера.Сегмент КАК Ссылка
		|						ИЗ
		|							СегментыПартнера)
		|			ИНАЧЕ ВЫБОР
		|					КОГДА НЕ МаркетинговыеМероприятияПартнерыАкции.Партнер = ЗНАЧЕНИЕ(Справочник.Партнеры.ПустаяСсылка)
		|						ТОГДА МаркетинговыеМероприятияПартнерыАкции.Партнер = &Клиент
		|					ИНАЧЕ (МаркетинговыеМероприятияПартнерыАкции.Свойство, МаркетинговыеМероприятияПартнерыАкции.Значение) В
		|							(ВЫБРАТЬ
		|								ПартнерыДополнительныеРеквизиты.Свойство КАК Свойство,
		|								ПартнерыДополнительныеРеквизиты.Значение КАК Значение
		|							ИЗ
		|								Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|							ГДЕ
		|								ПартнерыДополнительныеРеквизиты.Ссылка = &Клиент)
		|				КОНЕЦ
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	МаркетинговыеМероприятия.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|ГДЕ
		|	МаркетинговыеМероприятия.Ссылка В(&Ссылка)
		|	И МаркетинговыеМероприятия.ТипОтбораПартнер = ЗНАЧЕНИЕ(Перечисление.ТипОтбора.ПоВсемЭлементам)";
	
	Запрос.УстановитьПараметр("Клиент", Партнер);
	Запрос.УстановитьПараметр("Ссылка", МассивМероприятий);
		
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса;
	
КонецФункции	

Функция ПолучитьПроцентБонусовВидЦеныПоНоменклатуре(Мероприятие,Номенклатура,Характеристика,Действие) Экспорт
	
	ВозвращаемоеЗначение = Неопределено;
	
	ИмяКолонки = "";
	ИмяРеквизита = "";
	
	Если Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.НачислитьБонусыПроцентом Тогда
		ИмяКолонки = "Процент";
		ЗначениеДействия = Действие.ПроцентБонусов/100;
	ИначеЕсли Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.УстановитьВидЦены Тогда
		ИмяКолонки = "ВидЦены";
		ЗначениеДействия  = Действие.ВидЦены;		
	КонецЕсли;
	
	
	Если Не ПустаяСтрока(ИмяКолонки) Тогда
		
		Если Мероприятие.ТипОтбора = Перечисления.ТипОтбора.ПоСписку Тогда
			
			Для каждого СтрокаТовары из Мероприятие.ТоварыАкции Цикл
				
				НоменклатураПоАкцииЕсть = Ложь;
				
				Если ЗначениеЗаполнено(СтрокаТовары.Номенклатура) Тогда
					НоменклатураПоАкцииЕсть = СтрокаТовары.Номенклатура = Номенклатура;	
				ИначеЕсли ЗначениеЗаполнено(СтрокаТовары.ВидНоменклатуры) Тогда
					НоменклатураПоАкцииЕсть = СтрокаТовары.ВидНоменклатуры = Номенклатура.ВидНоменклатуры; 
				Иначе
					МассивНоменклатуры = Новый Массив;
					МассивНоменклатуры.Добавить(Номенклатура);
					НоменклатураПоАкцииЕсть = СоотвествиеГруппеНоменклатуры(МассивНоменклатуры,СтрокаТовары.ГруппаНоменклатуры); 
				КонецЕсли;	
				
				Если НоменклатураПоАкцииЕсть Тогда
					
					Если ТипЗнч(СтрокаТовары[ИмяКолонки]) = Тип("Число") Тогда
						ВозвращаемоеЗначение = ?(СтрокаТовары[ИмяКолонки]>0,СтрокаТовары[ИмяКолонки]/100,ЗначениеДействия);
					Иначе
						ВозвращаемоеЗначение = ?(ЗначениеЗаполнено(СтрокаТовары[ИмяКолонки]),СтрокаТовары[ИмяКолонки],ЗначениеДействия);
					КонецЕсли;
					Прервать; 
					
				Иначе
					
					Если ТипЗнч(СтрокаТовары[ИмяКолонки]) = Тип("Число") Тогда
						ВозвращаемоеЗначение = 0;
					Иначе
						ВозвращаемоеЗначение = "";
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		ИначеЕсли Мероприятие.ТипОтбора = Перечисления.ТипОтбора.ПоСегменту Тогда
			Если ЗначениеЗаполнено(Мероприятие.СегментНоменклатуры) Тогда
				ДинамическийСегмент = Мероприятие.СегментНоменклатуры.СпособФормирования=Перечисления.СпособыФормированияСегментов.ФормироватьДинамически;
				Если СегментыСервер.ВходитВСегмент(Номенклатура,Мероприятие.СегментНоменклатуры,Характеристика,ДинамическийСегмент) Тогда
					ВозвращаемоеЗначение = ЗначениеДействия;
				КонецЕсли;
			КонецЕсли;
		Иначе
			ВозвращаемоеЗначение =ЗначениеДействия;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
	
КонецФункции

Функция ПолучитьМероприятияПоОтборуПромокод(Промокод,Подразделение,ДатаДокумента=Неопределено) Экспорт 
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка КАК Ссылка,
		|	МаркетинговыеМероприятияПодразделения.Подразделение КАК Подразделение,
		|	МаркетинговыеМероприятияПодразделения.НомерСтроки КАК НомерСтроки,
		|	МаркетинговыеМероприятия.Алгоритм КАК Алгоритм,
		|	МаркетинговыеМероприятия.Промокод КАК Промокод
		|ПОМЕСТИТЬ ВТ_Мероприятия
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.МаркетинговыеМероприятия.Подразделения КАК МаркетинговыеМероприятияПодразделения
		|		ПО МаркетинговыеМероприятия.Ссылка = МаркетинговыеМероприятияПодразделения.Ссылка
		|ГДЕ
		|	(МаркетинговыеМероприятияПодразделения.НомерСтроки ЕСТЬ NULL
		|			ИЛИ МаркетинговыеМероприятияПодразделения.Подразделение = &Подразделение)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Мероприятия.Ссылка КАК Ссылка
		|ИЗ
		|	ВТ_Мероприятия КАК ВТ_Мероприятия
		|ГДЕ
		|	ВТ_Мероприятия.Алгоритм = &Алгоритм
		|	И ВТ_Мероприятия.Ссылка В(&Ссылка)
		|	И ВТ_Мероприятия.Промокод = &Промокод";
	
	Запрос.УстановитьПараметр("Промокод", Промокод);
	Запрос.УстановитьПараметр("Алгоритм", Перечисления.АлгоритмыАкций.ЗаПромокод);
	Запрос.УстановитьПараметр("Ссылка", ПолучитьВсеДействующиеМероприятия(?(ДатаДокумента=Неопределено,ТекущаяДата(),ДатаДокумента)));
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);

	Возврат РезультатЗапроса;
	
КонецФункции

Процедура СоздатьНачислениеБонусов(БонуснаяПрограммаЛояльности,Документ,Партнер,МаркетинговоеМероприятие,СуммаБонусов,Комментарий,Причина) Экспорт
	
	ДокументНачислениеСписаниеБонусовОбъект = Документы.НачислениеИСписаниеБонусныхБаллов.СоздатьДокумент();
	ДокументНачислениеСписаниеБонусовОбъект.Дата = ТекущаяДата();
	ДокументНачислениеСписаниеБонусовОбъект.МаркетинговоеМероприятие = МаркетинговоеМероприятие;
	ДокументНачислениеСписаниеБонусовОбъект.БонуснаяПрограммаЛояльности = БонуснаяПрограммаЛояльности;
	ДокументНачислениеСписаниеБонусовОбъект.Комментарий = Комментарий;
    ДокументНачислениеСписаниеБонусовОбъект.Причина = Причина;
	ДокументНачислениеСписаниеБонусовОбъект.Документ = Документ;
    ДокументНачислениеСписаниеБонусовОбъект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление;
	ДокументНачислениеСписаниеБонусовОбъект.Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Исполнен;
    НоваяСтрокаНачисления = ДокументНачислениеСписаниеБонусовОбъект.Начисление.Добавить();
	НоваяСтрокаНачисления.Партнер = Партнер;
	НоваяСтрокаНачисления.Баллы = СуммаБонусов; 
    ДокументНачислениеСписаниеБонусовОбъект.Записать(РежимЗаписиДокумента.Проведение);
	
КонецПроцедуры

Функция СозданоНачислениеПоДокументу(Документ,МаркетинговоеМероприятие,Причина) Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧекККМ.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_Основания
		|ИЗ
		|	Документ.ЧекККМ КАК ЧекККМ
		|ГДЕ
		|	ЧекККМ.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Заказ.Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ
		|ГДЕ
		|	Заказ.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиенту.Ссылка
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РеализацияТоваровУслуг.ЗаказКлиента
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ПО (РеализацияТоваровУслуг.ЗаказКлиента = Заказ.Ссылка)
		|			И (РеализацияТоваровУслуг.Проведен = ИСТИНА)
		|ГДЕ
		|	Заказ.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИСТИНА КАК ЕстьДокумент
		|ИЗ
		|	ВТ_Основания КАК ВТ_Основания
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеИСписаниеБонусныхБаллов КАК НачислениеИСписаниеБонусныхБаллов
		|		ПО (ВТ_Основания.Ссылка = НачислениеИСписаниеБонусныхБаллов.Документ)
		|ГДЕ
		|	НачислениеИСписаниеБонусныхБаллов.Проведен = ИСТИНА
		|	И НачислениеИСписаниеБонусныхБаллов.МаркетинговоеМероприятие = &МаркетинговоеМероприятие
		|	И НачислениеИСписаниеБонусныхБаллов.Причина = &Причина";

	
	Запрос.УстановитьПараметр("МаркетинговоеМероприятие", МаркетинговоеМероприятие);
	Запрос.УстановитьПараметр("Причина", Причина);
	Запрос.УстановитьПараметр("Ссылка", Документ);

	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

Функция ПолучитьНоменклатуруДляРасчета(МассивОснований) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
		|	ЗаказКлиентаТовары.НомерСтроки КАК НомерСтроки
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|ГДЕ
		|	ЗаказКлиентаТовары.Ссылка В(&Ссылка)
		|	И ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ ЗаказКлиентаТовары.Номенклатура В ИЕРАРХИИ (&ГрТара)
		|	И НЕ ЗаказКлиентаТовары.Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Номенклатура,
		|	РеализацияТоваровУслугТовары.НомерСтроки
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка В(&Ссылка)
		|	И РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ РеализацияТоваровУслугТовары.Номенклатура В ИЕРАРХИИ (&ГрТара)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЧекККМТовары.Номенклатура,
		|	ЧекККМТовары.НомерСтроки
		|ИЗ
		|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
		|ГДЕ
		|	ЧекККМТовары.Ссылка В(&Ссылка)
		|	И ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|	И НЕ ЧекККМТовары.Номенклатура В ИЕРАРХИИ (&ГрТара)";
	
	Запрос.УстановитьПараметр("ГрТара", Справочники.Номенклатура.НайтиПоКоду("00448      "));
	Запрос.УстановитьПараметр("Ссылка", МассивОснований);
	
	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции

