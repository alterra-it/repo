Функция ДействующиеМаркетинговыеМероприятияПоАлгоритмуАкции(АлгоритмАкции,Подразделение,Дата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаркетинговыеМероприятия.Ссылка КАК Ссылка,
		|	МаркетинговыеМероприятияПодразделения.Подразделение КАК Подразделение,
		|	МаркетинговыеМероприятияПодразделения.НомерСтроки КАК НомерСтроки,
		|	МаркетинговыеМероприятия.Алгоритм КАК Алгоритм
		|ПОМЕСТИТЬ ВТ_Мероприятия
		|ИЗ
		|	Справочник.МаркетинговыеМероприятия КАК МаркетинговыеМероприятия
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.МаркетинговыеМероприятия.Подразделения КАК МаркетинговыеМероприятияПодразделения
		|		ПО МаркетинговыеМероприятия.Ссылка = МаркетинговыеМероприятияПодразделения.Ссылка
		|ГДЕ
		|	(МаркетинговыеМероприятияПодразделения.НомерСтроки ЕСТЬ NULL
		|			ИЛИ МаркетинговыеМероприятияПодразделения.Подразделение = &Подразделение)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Мероприятия.Ссылка КАК Ссылка
		|ИЗ
		|	ВТ_Мероприятия КАК ВТ_Мероприятия
		|ГДЕ
		|	ВТ_Мероприятия.Алгоритм = &Алгоритм
		|	И ВТ_Мероприятия.Ссылка В(&Ссылка)";
	
	Запрос.УстановитьПараметр("Алгоритм", АлгоритмАкции);
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("Ссылка", ПолучитьВсеДействующиеМероприятия(Дата));
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
	Возврат РезультатЗапроса; 

