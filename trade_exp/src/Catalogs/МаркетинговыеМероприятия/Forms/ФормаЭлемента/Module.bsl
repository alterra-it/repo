КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Док__ЗагрузитьИзExcelПосле(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ЗагрузкаЗавершение",ЭтотОбъект,"ТоварыАкции"); 
	ПараметрыФормы = Новый Структура("ИмяТаблицы,Колонки","Товары","Код,Наименование,Подразделение");
	ОткрытьФорму("Справочник.МаркетинговыеМероприятия.Форма.Док_Форма_ЗагрузкаExel",ПараметрыФормы,ЭтаФорма,,,,Оповещение,);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыДействия

&НаКлиенте
Процедура Док_ДействияПриАктивизацииСтрокиПосле(Элемент)
	
	ТекущаяСтрока = Элементы.Действия.ТекущиеДанные;
	
	Если Не ТекущаяСтрока = Неопределено Тогда
		Элементы._НадписьДействия.Заголовок = СформироватьСтрокуПоРеквизитамЭлементаСправочника(ТекущаяСтрока.Действие);
	Иначе
		Элементы._НадписьДействия.Заголовок = "";
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
&НаСервере
Процедура УстановитьВидимостьПоНоменклатуре()
		
	Элементы.ТоварыАкции.Видимость = (Объект.ТипОтбора = Перечисления.ТипОтбора.ПоСписку);
    Элементы.СегментНоменклатуры.Видимость = (Объект.ТипОтбора = Перечисления.ТипОтбора.ПоСегменту);

КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоПартнеру()
		
	Элементы.ПартнерыАкции.Видимость = (Объект.ТипОтбораПартнер = Перечисления.ТипОтбора.ПоСписку);
    Элементы.СегментПартнеров.Видимость = (Объект.ТипОтбораПартнер = Перечисления.ТипОтбора.ПоСегменту);

КонецПроцедуры

&НаСервере
Процедура УстановитьДоступность()
	Элементы.Завершено.Доступность = РольДоступна("ПолныеПрава");
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоНоменклатуреОбщаяСтраница()
		
	Элементы.ТоварыАкции1.Видимость = (Объект.ТипОтбора = Перечисления.ТипОтбора.ПоСписку);
    Элементы.СегментНоменклатуры1.Видимость = (Объект.ТипОтбора = Перечисления.ТипОтбора.ПоСегменту);

КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоАлгоритму()
	
	Элементы.Промокод.Видимость = (Объект.Алгоритм = Перечисления.АлгоритмыАкций.ЗаПромокод);
    Элементы._ГруппаОтборКлиентов.Видимость = Не (Объект.Алгоритм = Перечисления.АлгоритмыАкций.ЗаПромокод);
	Элементы._ГруппаОтборТоваров.Видимость = Не (Объект.Алгоритм = Перечисления.АлгоритмыАкций.ЗаПромокод);

КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьПоВидуАкции()
	
	Элементы._ГруппаУсловияАкции.Видимость = (Объект.ВидАкции = Перечисления.ВидыАкций.Алгоритм);
    Элементы._ТоварыАкции.Видимость = НЕ (Объект.ВидАкции = Перечисления.ВидыАкций.Алгоритм);

КонецПроцедуры


&НаСервере
Функция СформироватьСтрокуПоРеквизитамЭлементаСправочника(Действие)
	
	Возврат ?(Не Действие.Пустая(),"Тип - "+Строка(Действие.Тип)+ ?(ЗначениеЗаполнено(Действие.ПроцентБонусов), ", Процент бонусов - " + Строка(Действие.ПроцентБонусов),"") 
	+ ?(ЗначениеЗаполнено(Действие.СтатусУчастникаБонуснойПрограммы), ", Статус участника бонусной программы - " + Строка(Действие.СтатусУчастникаБонуснойПрограммы),"") + ?(ЗначениеЗаполнено(Действие.ВидЦены), ", Вид цены - " + Строка(Действие.ВидЦены),"")
	+ ?(ЗначениеЗаполнено(Действие.СуммаБонусов), ", Сумма бонусов - " + Строка(Действие.СуммаБонусов),"") + ?(ЗначениеЗаполнено(Действие.Причина), ", Причина - " + Строка(Действие.Причина), ""),"");
	
КонецФункции

&НаКлиенте 
Процедура ЗагрузкаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	ЗагрузкаЗавершениеСервер(Результат, ДополнительныеПараметры);
КонецПроцедуры 

&НаСервере 
Процедура ЗагрузкаЗавершениеСервер(Результат, ДополнительныеПараметры)
	Если Результат <> Неопределено тогда
		 Объект[ДополнительныеПараметры].Загрузить(Результат.Выгрузить());	
	конецесли;
КонецПроцедуры 

&НаКлиенте
Процедура Док_ДействияПередНачаломДобавленияПосле(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Если Объект.Действия.Количество()=1 Тогда
		Сообщить("Больше одного действия добавить нельзя!");
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

