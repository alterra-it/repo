КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
	

	Если Объект.ВидАкции = ПредопределенноеЗначение("Перечисление.ВидыАкций.Алгоритм") Тогда
		
		СообщениеОшибки = "";
		
		Если Объект.Действия.Количество()=0 Тогда
			СообщениеОшибки = СообщениеОшибки + "Укажите действия в табличной части." + Символы.ПС;
		КонецЕсли;
		
		Если Объект.Алгоритм = ПредопределенноеЗначение("Перечисление.АлгоритмыАкций.ЗаПромокод") Тогда
			Если Не ПустаяСтрока(СообщениеОшибки) Тогда
				Сообщить(СообщениеОшибки);
				Отказ = Истина;
			КонецЕсли;
			Возврат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.ТипОтбора) Тогда
			СообщениеОшибки = СообщениеОшибки + "Укажите тип отбора номенклатуры." + Символы.ПС;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.ТипОтбораПартнер) Тогда
			СообщениеОшибки = СообщениеОшибки + "Укажите тип отбора партнера." + Символы.ПС;
		КонецЕсли;  
		
		Если ПроверкаЗаполненияТаблицыТоварыАкции() Тогда 
			СообщениеОшибки = СообщениеОшибки + "Присутствуют пустые строки в таблице товары Акции" + Символы.ПС;
		КонецЕсли;
		
		Если Не ПустаяСтрока(СообщениеОшибки) Тогда
			Сообщить(СообщениеОшибки);
			Отказ = Истина;
		КонецЕсли

	КонецЕсли; 
						
КонецПроцедуры  

&НаСервере
Функция ПроверкаЗаполненияТаблицыТоварыАкции()
	
	Для каждого Строка из Объект.ТоварыАкции Цикл 
			Если Строка.ВидНоменклатуры = Справочники.ВидыНоменклатуры.ПустаяСсылка() 
				И Строка.ГруппаНоменклатуры = Справочники.Номенклатура.ПустаяСсылка() 
				И Строка.Номенклатура = Справочники.Номенклатура.ПустаяСсылка() Тогда 
				
					Возврат Истина; 
				КонецЕсли; 
			КонецЦикла;
			Возврат Ложь; 
КонецФункции

#Область ИнформацияПоЦеновымГРуппамБезБонусов

&НаКлиенте
Процедура Док_ПередЗакрытиемПеред(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ВыполняетсяЗакрытие Тогда
		СообщениеБезБонусов = ПроверитьЦеновыеГруппыБезБонусов(); 
	
		Если СообщениеБезБонусов <> "" Тогда   
			
			СообщениеБезБонусов = 
				"В этом маркетинговом мероприятии присутствует товар, 
				|относящийся к ценовым группам без начисления бонусов:"
				+ СообщениеБезБонусов;

	    	Отказ = Истина;
			ПоказатьПредупреждение(Новый ОписаниеОповещения("ПередЗакрытиемЗавершение", ЭтотОбъект), СообщениеБезБонусов, 0, "Бонусы начислены не будут");
	
		КонецЕсли;
	
	КонецЕсли;

КонецПроцедуры  

&НаКлиенте
Процедура ПередЗакрытиемЗавершение(Параметры) Экспорт
	ВыполняетсяЗакрытие = Истина;
    Закрыть();
КонецПроцедуры

&НаСервере
Функция ПроверитьЦеновыеГруппыБезБонусов() 
	
	ТекстСообщения = "";
	
	Если Не Объект.ПометкаУдаления И Не Объект.Завершено И Объект.ДатаОкончания >= НачалоДня(ТекущаяДата()) 
		И Объект.Алгоритм = ПредопределенноеЗначение("Перечисление.АлгоритмыАкций.ЗаТовар")
		И Объект.Действия.Количество() > 0  
		И (Объект.Действия[0].Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.НачислитьБонусыПроцентом 
			Или Объект.Действия[0].Действие.Тип = Перечисления.ТипыДействияМаркетинговыхМероприятий.НачислитьБонусыСуммой) Тогда
		
		Запрос = Новый Запрос;  
		Запрос.Текст = "	
			|ВЫБРАТЬ 
			|	ЦеноваяГруппа,
			|	ДатаОкончанияДействия
			|ПОМЕСТИТЬ втЦеновыеГруппыБезБонусовПоследние
			|ИЗ
			|	РегистрСведений.ЦеновыеГруппыБезБонусов.СрезПоследних(&Дата)
			|;
			|////////////////////////////////////////////////////////////////////////////////     
			|ВЫБРАТЬ 
			|	ЦеноваяГруппа
			|ПОМЕСТИТЬ втЦеновыеГруппыБезБонусов
			|ИЗ
			|	втЦеновыеГруппыБезБонусовПоследние
			|ГДЕ 
			|	ДатаОкончанияДействия = ДАТАВРЕМЯ(1, 1, 1)  
			|ОБЪЕДИНИТЬ
			|ВЫБРАТЬ 
			|	ЦеноваяГруппа    
			|ИЗ
			|	втЦеновыеГруппыБезБонусовПоследние
			|ГДЕ 
			|	ДатаОкончанияДействия >= &Дата
			|;";
		
		Если Объект.ТипОтбора = ПредопределенноеЗначение("Перечисление.ТипОтбора.ПоВсемЭлементам") Тогда   
			
			Запрос.Текст = Запрос.Текст + "	
				|ВЫБРАТЬ 
				|    втЦеновыеГруппыБезБонусов.ЦеноваяГруппа,
				|    ЦеновыеГруппы.Наименование КАК ЦеноваяГруппаНаименование		
				|ИЗ 
				|	втЦеновыеГруппыБезБонусов 
				|	СОЕДИНЕНИЕ 
				|		Справочник.ЦеновыеГруппы КАК ЦеновыеГруппы
				|		ПО втЦеновыеГруппыБезБонусов.ЦеноваяГруппа = ЦеновыеГруппы.Ссылка";	
			
		Иначе	// Отборы по сегменту и списку
			
			Запрос.Текст = Запрос.Текст + "	
				|ВЫБРАТЬ
				|	 СпрНоменклатура.Ссылка КАК Номенклатура,
				|    втЦеновыеГруппыБезБонусов.ЦеноваяГруппа,
				|    втЦеновыеГруппыБезБонусов.ЦеноваяГруппа.Наименование КАК ЦеноваяГруппаНаименование		
				|ПОМЕСТИТЬ 
				|	втНоменклатураБезБонусов
				|ИЗ 
				|	Справочник.Номенклатура КАК СпрНоменклатура
				|	СОЕДИНЕНИЕ 
				|		втЦеновыеГруппыБезБонусов  
				|	ПО  СпрНоменклатура.ЦеноваяГруппа = втЦеновыеГруппыБезБонусов.ЦеноваяГруппа			
				|;";
			
			
			// Отборы по сегменту
			Если Объект.ТипОтбора = ПредопределенноеЗначение("Перечисление.ТипОтбора.ПоСегменту") Тогда   
				
				Запрос.Текст = Запрос.Текст + "					
					|ВЫБРАТЬ РАЗЛИЧНЫЕ 
					|	Номенклатура   
					|ПОМЕСТИТЬ 
					|	втНоменклатураМероприятия
					|ИЗ 
					|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
					|ГДЕ 
					|	Сегмент = &Сегмент  
					|;";  
				
				Запрос.УстановитьПараметр("Сегмент", Объект.СегментНоменклатуры);
				
			Иначе // Отборы по списку    
				
				Запрос.Текст = Запрос.Текст + "					
					|ВЫБРАТЬ 
					| Номенклатура   
					|ПОМЕСТИТЬ 
					|	втНоменклатураМероприятия
					|ИЗ 
					|	&ТаблицаНоменклатурыМероприятия КАК ТаблицаНоменклатурыМероприятия
					|;";  
				
				ТЗНоменклатурыМероприятия = Новый ТаблицаЗначений;    
				ТЗНоменклатурыМероприятия.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
				
				Для Каждого СтрокаТовары Из Объект.ТоварыАкции Цикл
					
					Если ЗначениеЗаполнено(СтрокаТовары.ВидНоменклатуры) Или ЗначениеЗаполнено(СтрокаТовары.ГруппаНоменклатуры) Тогда
					
						Если ЗначениеЗаполнено(СтрокаТовары.ВидНоменклатуры) Тогда	
							ТЗ = ПолучитьНоменклатуруПоВиду(СтрокаТовары.ВидНоменклатуры); 
						Иначе	
							ТЗ = ПолучитьНоменклатуруПоГруппе(СтрокаТовары.ГруппаНоменклатуры); 	
						КонецЕсли;	
						
						Если ТЗ.Количество() > 0 Тогда
							Для Счетчик = 1 По ТЗ.Количество() Цикл
								ТЗНоменклатурыМероприятия.Вставить(0);	
							КонецЦикла;        
							ТЗНоменклатурыМероприятия.ЗагрузитьКолонку(ТЗ.ВыгрузитьКолонку(0), 0);
						КонецЕсли;
						
					Иначе // Номенклатура
						СтрокаНоменклатурыМероприятия = ТЗНоменклатурыМероприятия.Добавить();
						СтрокаНоменклатурыМероприятия.Номенклатура = СтрокаТовары.Номенклатура;
					КонецЕсли;  
					
				КонецЦикла; 
				
				Запрос.УстановитьПараметр("ТаблицаНоменклатурыМероприятия", ТЗНоменклатурыМероприятия);
				
			КонецЕсли;   
				
			Запрос.Текст = Запрос.Текст + "	
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|    втНоменклатураБезБонусов.ЦеноваяГруппа,
				|    втНоменклатураБезБонусов.ЦеноваяГруппаНаименование		
				|ИЗ 
				|	втНоменклатураМероприятия
				|	СОЕДИНЕНИЕ 
				|		втНоменклатураБезБонусов
				|	ПО втНоменклатураМероприятия.Номенклатура = втНоменклатураБезБонусов.Номенклатура
				|УПОРЯДОЧИТЬ ПО 
				|	втНоменклатураБезБонусов.ЦеноваяГруппаНаименование		
				|;";
			
		КонецЕсли;
		
		Запрос.УстановитьПараметр("Дата", НачалоДня(ТекущаяДата()));
		Результат = Запрос.Выполнить();
		
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл        
			ТекстСообщения = ТекстСообщения + Символы.ПС + Выборка.ЦеноваяГруппаНаименование;
		КонецЦикла;		
	КонецЕсли;
	
	Возврат ТекстСообщения;
КонецФункции	

