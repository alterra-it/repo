
&НаСервереБезКонтекста
Процедура Док_СписокПриПолученииДанныхНаСервереПосле(ИмяЭлемента, Настройки, Строки)
	
	Для Каждого Элемент Из Строки Цикл
		
		Если Элемент.Значение.Данные["ВыполнятьПоРасписанию"] Тогда
		
			ИдентификаторЗадания = Элемент.Значение.Данные["РегламентноеЗадание"];
	        
			Задание = РегламентныеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);
			Если Задание <> Неопределено Тогда
				
				Расписание = Задание.Расписание;
				
				Если Элемент.Значение.Данные["ПериодичностьРасписания"] <> Перечисления.ПериодичностиРасписанийРассылокОтчетов.Произвольное Тогда
					Расписание.ВремяКонца = '00010101';
				КонецЕсли;
				
				Элемент.Значение.Данные["ИтоговоеРасписание"] = Задание.Расписание;
				Элемент.Значение.Данные["ВремяНачала"] = Задание.Расписание.ВремяНачала;
				
			КонецЕсли;
			
		ИначеЕсли Не Элемент.Значение.Данные["ЭтоГруппа"] Тогда
			
			Элемент.Значение.Данные["ИтоговоеРасписание"] = "Расписание не активно";	
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры
