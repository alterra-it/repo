#Область ОписаниеПеременных

&НаКлиенте
Перем ДатаДоИзменения;

&НаСервере
Перем СтарыйЧисловойНомер, СтараяДата;

#КонецОбласти // ОписаниеПеременных

#Область Методы_автонумерации

&НаСервере
Функция ПолучитьНовыйНомер(НомерЧислом)
	
	Если Объект.Дата = Дата('00010101000000') Тогда
		НомерЧислом = 0;
		Возврат "Укажите дату договора!";
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПериодНумерации = НачалоГода(Объект.Дата);
	СтруктураИзмерений = Новый Структура;
	СтруктураИзмерений.Вставить("ПериодНумерации", ПериодНумерации);
	ПоследнийНомер = РегистрыСведений.АвтоНумерацияДоговоровКонтрагента.Получить(СтруктураИзмерений).ТекущийНомер;
	Если Не ЗначениеЗаполнено(ПоследнийНомер) Тогда
		ПоследнийНомер = 0;
	КонецЕсли;
	
	НомерЧислом = Мин(ПоследнийНомер + 1, 99999);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат "";
	
КонецФункции

&НаСервере
Процедура УстановитьНомер(НомерЧислом, ИзменитьПризнакМодифицированности = Истина)
	
	Если НомерЧислом > 0 Тогда
		НомерТекстом = Формат(НомерЧислом, "ЧЦ=5; ЧВН=; ЧГ=0") + "/" + Формат(Объект.Дата, "ДФ=гг");
	Иначе
		НомерТекстом = "";
	КонецЕсли;
	
	Если НомерТекстом <> Объект.Номер Тогда
		Объект.Номер = НомерТекстом;
		Модифицированность = ИзменитьПризнакМодифицированности;
	КонецЕсли;
	Если НомерЧислом <> Объект.ЧисловойНомер Тогда
		Объект.ЧисловойНомер = НомерЧислом;
		Модифицированность = ИзменитьПризнакМодифицированности;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьАвтонумерации()

	ГиперссылкаКакЧисловойНомер	= Объект.ЧисловойНомер > 0;
	Если ГиперссылкаКакЧисловойНомер Тогда	
		Элементы.Автонумерация.Вид			= ВидДекорацииФормы.Надпись;
		Элементы.Автонумерация.Заголовок	= Объект.ЧисловойНомер;
	Иначе
		Элементы.Автонумерация.Вид							= ВидДекорацииФормы.Картинка;
		Элементы.Автонумерация.Картинка						= БиблиотекаКартинок.Настройка;
		Элементы.Автонумерация.РазмерКартинки				= РазмерКартинки.Пропорционально;
		Элементы.Автонумерация.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
	КонецЕсли;
	ДоговорНеЗакрыт						= Объект.Статус <> Перечисления.СтатусыДоговоровКонтрагентов.Закрыт;
	Элементы.Номер.Толькопросмотр		= ГиперссылкаКакЧисловойНомер;
	Элементы.Автонумерация.Видимость	= ГиперссылкаКакЧисловойНомер ИЛИ ДоговорНеЗакрыт;
	Элементы.Автонумерация.Доступность	= ДоговорНеЗакрыт;
	Элементы.Автонумерация.Подсказка	= "Сгенерировать новый номер по формату ЧЧЧЧЧ/ГГ";
	Элементы.Автонумерация.Гиперссылка	= Истина;
	Элементы.Автонумерация.УстановитьДействие("Нажатие", "Док_НажатиеГиперссылкиАвтонумерации");
	
КонецПроцедуры

#КонецОбласти // Методы_автонумерации

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура Док_ДатаОкончаниеВводаТекстаПеред(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ДатаДоИзменения = ДатаДоИзменения(Текст, СтандартнаяОбработка);
	Если СтандартнаяОбработка = Ложь Тогда
		// обработчик этого события ("Док_ДатаОкончаниеВводаТекстаПеред") в платформе 1С по состоянию на релиз 8.3.27.1719
		// до сих пор работает некорректно при отключении стандартной обработки и не всегда отменяет ввод текста в поле формы,
		// по этому приходится делать вот такой "финт ушами",
		// чтобы после этого обработчика была вызвана процедура "Док_ДатаОбработкаВыбораПеред",
		// которая в вопросе отмены выбора значения работает нормально 
		ДанныеВыбора = Новый СписокЗначений;
		ДанныеВыбора.Добавить(ДатаДоИзменения);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ДатаОбработкаВыбораПеред(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	ДатаДоИзменения = ДатаДоИзменения(ВыбранноеЗначение, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Функция ДатаДоИзменения(ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		СравниваемаяДата = СтроковыеФункцииКлиентСервер.СтрокаВДату(ВыбранноеЗначение);
	Иначе
		СравниваемаяДата = ВыбранноеЗначение;
	КонецЕсли;
	
	ДатаВОбъекте = Объект.Дата;
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыДоговоровКонтрагентов.Закрыт")
		И Объект.ЧисловойНомер > 0
		И СравниваемаяДата <> ДатаВОбъекте Тогда
		ПредупреждениеАсинх("Внимание, изменена дата закрытого договора! "+Символы.ПС+"Новый номер не будет сгенерирован!");
		СтандартнаяОбработка = Ложь;
		// возвращаем значение до изменения
		Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
			ВыбранноеЗначение = Формат(ДатаВОбъекте, "ДЛФ=Д");
		Иначе
			ВыбранноеЗначение = ДатаВОбъекте;
		КонецЕсли;
		// и всё же можно обмануть код, если вернуть статус договора из закрытого в другой, сгенерировать новый номер,
		// а затем снова поменять статус на закрыт, но эту логику, на мой взгляд, нужно контролировать вне рамок задачи автонумерации,
		// потому что вывод договора из состояния закрыт означает также изменение любых других реквизитов договора,
		// которые не контролируются в рамках задачи автонумерации
	КонецЕсли;
	
	Возврат ДатаВОбъекте;
		
КонецФункции

&НаКлиенте
Процедура Док_ДатаПриИзмененииПосле(Элемент)
	
	Если Год(ДатаДоИзменения) <> Год(Объект.Дата)
		 И Объект.ЧисловойНомер > 0
		 И Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыДоговоровКонтрагентов.Закрыт") Тогда
		НомерЧислом = 0;
		ТекстПредупреждения = ПолучитьНовыйНомер(НомерЧислом);
		Если Не ПустаяСтрока(ТекстПредупреждения) Тогда
			ПредупреждениеАсинх(ТекстПредупреждения);
		КонецЕсли;

		ПослеВводаНомера(НомерЧислом);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_НажатиеГиперссылкиАвтонумерации(Элемент, СтандартнаяОбработка)
	
	// задам вопрос о том что делать
	СтандартнаяОбработка = Ложь;
	
	Если Объект.ЧисловойНомер > 0 Тогда
		// предложим выбор, генераци\я или очистка номер
		ТекстВопроса = СтрШаблон("Текущий числовой номер документа ""%1"".%2Выберите варианты действий.", Объект.ЧисловойНомер, Символы.ПС);
		ВариантыДляВыбора = Новый СписокЗначений();
		ВариантыДляВыбора.Добавить("очистить", "Очистить текущий номер");
		ВариантыДляВыбора.Добавить("сгенерировать", "Сгенерировать новый номер по формату ЧЧЧЧЧ/ГГ");
		ВариантыДляВыбора.Добавить("отменить", "Отменить");

		ПроцедураЗавершения = Новый ОписаниеОповещения("ПослеВыбораВариантаНумерации", ЭтотОбъект);
		ПоказатьВопрос(ПроцедураЗавершения, ТекстВопроса, ВариантыДляВыбора, 30, "отменить", , "отменить"); 
	Иначе // переходим сразу к генерации нового номера
		ПослеВыбораВариантаНумерации("сгенерировать", Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораВариантаНумерации(Результат, Параметры) Экспорт
	
	Если Результат = "сгенерировать" Тогда
		НомерЧислом = 0;
		ТекстПредупреждения = ПолучитьНовыйНомер(НомерЧислом);
		Если Не ПустаяСтрока(ТекстПредупреждения) Тогда
			ПредупреждениеАсинх(ТекстПредупреждения);
			Возврат;
		КонецЕсли;

		ПроцедураЗавершения = Новый ОписаниеОповещения("ПослеВводаНомера", ЭтотОбъект);
		ПоказатьВводЧисла(ПроцедураЗавершения, НомерЧислом, "Новый числовой номер договора будет:", 5, 0);
	ИначеЕсли Результат = "очистить" Тогда
		ПослеВводаНомера(0);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаНомера(ВведеноеЧисло, ДопПараметры = Неопределено) Экспорт
	
	Если ВведеноеЧисло = Неопределено Тогда // пользователь отказался от ввода
		Возврат;
	КонецЕсли;
	
	УстановитьНомер(ВведеноеЧисло);
	УстановитьВидимостьАвтонумерации();
	
КонецПроцедуры

&НаКлиенте
Процедура Док_СтатусПриИзмененииПосле(Элемент)
	
	Если Элемент.ВыделенныйТекст = "Закрыт" Тогда
		
		Объект.ОграничиватьСуммуЗадолженности = Ложь;
		Объект.ДопустимаяСуммаЗадолженности = 0;
		Объект.ЗапрещаетсяПросроченнаяЗадолженность = Ложь;		
		Объект.КоличествоДнейПросрочки = 0;				
		Объект.РазрешитьОтгрузкуПриПревышении = Ложь;
		
	КонецЕсли;
	
	УстановитьВидимостьАвтонумерации();
	
КонецПроцедуры

&После ("ОрганизацияПриИзмененииСервер")
&НаСервере
Процедура Док_ОрганизацияПриИзмененииСервер()
		Объект.СтавкаНДС=УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация);
КонецПроцедуры

#КонецОбласти // ОбработчикиСобытийЭлементовШапкиФормы

#Область ОбработчикиСобытийФормы

&Перед("ПриСозданииНаСервере")
&НаСервере
Процедура Док_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)

	// Автонумерация +++
	СоздатьЭлементИРеквизитФормы("Автонумерация", , "ГруппаНомерДата", "Дата");
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Дата = ТекущаяДатаСеанса();
		НомерЧислом = 0;
		ПолучитьНовыйНомер(НомерЧислом);
		УстановитьНомер(НомерЧислом, Ложь);
	КонецЕсли;
	УстановитьВидимостьАвтонумерации();
	// Автонумерация ---
	
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов;
		//	    УстановитьДоступностьЭлементовПоСтатусуСервер();
		Объект.СтатьяДвиженияДенежныхСредств =?(Объект.ТипДоговора=Перечисления.ТипыДоговоров.СПокупателем или Объект.ТипДоговора=Перечисления.ТипыДоговоров.СКомитентом ,Справочники.СтатьиДвиженияДенежныхСредств.ПоступлениеОплатыОтКлиента,Справочники.СтатьиДвиженияДенежныхСредств.ОплатаПоставщику);
	    ЗаполнитьВариантПриемкиТоваровДляЗакупки();
	КонецЕсли;
	Доступ = Пользователи.РолиДоступны("ИзменениеОсновногоМенеджераПартнера");
	Элементы.РазрешитьОтгрузкуПриПревышении1.Доступность		= Доступ;
	Элементы.КоличествоДнейПросрочки1.Доступность				= Доступ;
	Элементы.ОграничиватьСуммуЗадолженности.Доступность			= Доступ;
	Элементы.ДопустимаяСуммаЗадолженности.Доступность			= Доступ;
	Элементы.ЗапрещаетсяПросроченнаяЗадолженность.Доступность	= Доступ;
	
	ЗаполнитьДанныеЛимитаДоговора();

КонецПроцедуры

&НаСервере
Процедура СоздатьЭлементИРеквизитФормы(ИмяЭлемента, ИмяТипаЭлемента = "ДекорацияФормы", ИмяРодителяЭлемента, ИмяМестаРасположенияЭлемента, СоздатьРеквизит = Ложь)
	
	// найду элементы формы для позиционирования нового элемента
	НовыйЭлемент = Элементы.Найти(ИмяЭлемента);
	Если ТипЗнч(НовыйЭлемент) = Тип(ИмяТипаЭлемента) Тогда
		// элемент уже был создан (ПриСозданииНаСервере почемуто запускается два раза при открытии элемента из списка)
		Возврат;
	КонецЕсли;
	
	РодительЭлемента	= Элементы.Найти(ИмяРодителяЭлемента); // было тут - Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.СтраницаОсновное.ПодчиненныеЭлементы.ГруппаШапкаДоговора.ПодчиненныеЭлементы.ГруппаШапкаПраво.ПодчиненныеЭлементы.ГруппаНомерДата
	ЭлементРасположения	= Элементы.Найти(ИмяМестаРасположенияЭлемента);
	ВызватьИсключениеЕслиНеНайден(РодительЭлемента,		ИмяРодителяЭлемента);
	ВызватьИсключениеЕслиНеНайден(ЭлементРасположения,	ИмяМестаРасположенияЭлемента);
	
	// создаю сам элемент
	НовыйЭлемент = Элементы.Добавить(ИмяЭлемента, Тип(ИмяТипаЭлемента), РодительЭлемента);
	
	Элементы.Переместить(НовыйЭлемент, РодительЭлемента, ЭлементРасположения);
	
	Если СоздатьРеквизит Тогда
		ТипСтрока = Новый ОписаниеТипов("Строка");
		Реквизит = Новый РеквизитФормы(ИмяЭлемента, ТипСтрока);
		МасРеквизитов = Новый Массив();
		МасРеквизитов.Добавить(Реквизит);
		ИзменитьРеквизиты(МасРеквизитов);
		НовыйЭлемент.ПутьКДанным = ИмяЭлемента;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВызватьИсключениеЕслиНеНайден(ПроверяемыйЭлемент, ИмяПроверяемогоЭлемента)
	
	Если ПроверяемыйЭлемент = Неопределено Тогда
		ВызватьИсключение "Для размещения нового элемента на форме не найден элемент """ + ИмяПроверяемогоЭлемента + """."
						  + Символы.ПС
						  + "Обратитесь к программистам.";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_ПередЗаписьюНаСервереПеред(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	Если ТекущийОбъект.ЧисловойНомер > 0 Тогда
		
		ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
					   |	ДоговорыКонтрагентов.Ссылка КАК Ссылка,
					   |	ДоговорыКонтрагентов.Дата КАК Дата,
					   |	ДоговорыКонтрагентов.Номер КАК Номер,
					   |	ДоговорыКонтрагентов.Наименование КАК Наименование
					   |ИЗ
					   |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
					   |ГДЕ
					   |	ДоговорыКонтрагентов.ЧисловойНомер = &ЧисловойНомер
					   |	И НАЧАЛОПЕРИОДА(ДоговорыКонтрагентов.Дата, Год) = &ПериодНумерации
					   |	И ДоговорыКонтрагентов.ПометкаУдаления = ЛОЖЬ
					   |	И ДоговорыКонтрагентов.Ссылка <> &СсылкаТекущегоДоговора";
		Запрос = Новый Запрос();
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("ЧисловойНомер", ТекущийОбъект.ЧисловойНомер);
		Запрос.УстановитьПараметр("ПериодНумерации", НачалоГода(ТекущийОбъект.Дата));
		Запрос.УстановитьПараметр("СсылкаТекущегоДоговора", ТекущийОбъект.Ссылка);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			Если Не Отказ Тогда
				Отказ = Истина;
			КонецЕсли;
			Сообщение = Новый СообщениеПользователю();
			Сообщение.Текст = СтрШаблон("Уже есть договор ""%1"" с номером %2 от %3 (сообщение кликабельно)",
										Выборка.Наименование,
										Выборка.Номер,
										Формат(Выборка.Дата, "ДЛФ=Д"));
			Сообщение.Поле = "Номер";
			Сообщение.КлючДанных = Выборка.Ссылка;
			Сообщение.ПутьКДанным = "Объект";
			Сообщение.Сообщить();
			Возврат;
		КонецЕсли;
		
	КонецЕсли;

	Если Не Отказ И ЗначениеЗаполнено(ТекущийОбъект.Ссылка) Тогда
		ТекстЗапроса = "ВЫБРАТЬ
					   |	ДоговорыКонтрагентов.Дата КАК Дата,
					   |	ДоговорыКонтрагентов.ЧисловойНомер КАК ЧисловойНомер
					   |ИЗ
					   |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
					   |ГДЕ
					   |	ДоговорыКонтрагентов.Ссылка = &Ссылка";

		Запрос = Новый Запрос();
		Запрос.Текст = ТекстЗапроса;
		Запрос.УстановитьПараметр("Ссылка", ТекущийОбъект.Ссылка);
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Следующий() Тогда
			СтарыйЧисловойНомер = Выборка.ЧисловойНомер;
			СтараяДата = Выборка.Дата;
		Иначе
			СтарыйЧисловойНомер = 0;
			СтараяДата = Дата('00010101000000');
		КонецЕсли;
	Иначе
		СтарыйЧисловойНомер = 0;
		СтараяДата = Дата('00010101000000');
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_ПриЗаписиНаСервереПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	// Автонумерация +++
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		ПустаяДата			= Дата('00010101000000');
		ПериодНумерации		= НачалоГода(ТекущийОбъект.Дата);
		СохраняемыйНомер	= ТекущийОбъект.ЧисловойНомер;
	
		// необходимо попробовать освободить старый номер, если таковой был
		// это шанс на одну ошибку с автоматическим восстановлением нумерации
		Если СтараяДата <> ПустаяДата И СтарыйЧисловойНомер > 0 Тогда
			ПериодСтаройНумерации = НачалоГода(СтараяДата);
			Если ПериодНумерации <> ПериодСтаройНумерации ИЛИ СохраняемыйНомер = 0 Тогда
				ПоследнийНомер = ПолучитьПоследнийНомер(ПериодСтаройНумерации);
				Если СтарыйЧисловойНомер = ПоследнийНомер Тогда
					ЗаписатьНомер(ПериодСтаройНумерации, СтарыйЧисловойНомер - 1);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		// записываем новый номер
		Если ПериодНумерации <> ПустаяДата И СохраняемыйНомер > 0 Тогда
			НовыйНомер = ПолучитьПоследнийНомер(ПериодНумерации) + 1;
			Если СохраняемыйНомер >= НовыйНомер Тогда
				ЗаписатьНомер(ПериодНумерации, СохраняемыйНомер);
			КонецЕсли;
		КонецЕсли;
	Исключение
		Если Не Отказ Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецПопытки;

	УстановитьПривилегированныйРежим(Ложь);
	
	// Автонумерация ---

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПоследнийНомер(ПериодНумерации)

	Блокировка = Новый БлокировкаДанных();
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.АвтоНумерацияДоговоровКонтрагента");
	ЭлементБлокировки.УстановитьЗначение("ПериодНумерации", ПериодНумерации);
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
	Блокировка.Заблокировать();
		
	СтруктураИзмерений = Новый Структура();
	СтруктураИзмерений.Вставить("ПериодНумерации", ПериодНумерации);
	ПоследнийНомер = РегистрыСведений.АвтоНумерацияДоговоровКонтрагента.Получить(СтруктураИзмерений).ТекущийНомер;
	Если Не ЗначениеЗаполнено(ПоследнийНомер) Тогда
		ПоследнийНомер = 0;
	КонецЕсли;
	
	Возврат ПоследнийНомер;

КонецФункции

&НаСервереБезКонтекста
Функция ЗаписатьНомер(ПериодНумерации, ЧисловойНомер)

	СтруктураИзмерений = Новый Структура();
	СтруктураИзмерений.Вставить("ПериодНумерации", ПериодНумерации);
	МенеджерЗаписи = РегистрыСведений.АвтоНумерацияДоговоровКонтрагента.СоздатьМенеджерЗаписи();
	ЗаполнитьЗначенияСвойств(МенеджерЗаписи, СтруктураИзмерений);
	МенеджерЗаписи.ТекущийНомер = ЧисловойНомер;
	МенеджерЗаписи.Записать();
	
КонецФункции

