&НаСервере
Процедура ЗаполнитьДанныеЛимитаДоговора()

	Макет= РегистрыСведений.ЛимитыДоговоров.ПолучитьМакет("ИнформацияПоДоговору");
	ОбластьЗаголовок=Макет.ПолучитьОбласть("Заголовок");
	ОбластьСтрока=Макет.ПолучитьОбласть("Строка");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛимитыДоговоров.СуммаЛимита КАК СуммаЛимита,
		|	ЛимитыДоговоров.КоличествоДнейОтсрочки КАК КоличествоДнейПросрочки,
		|	ЛимитыДоговоров.ДатаНачала КАК ДатаНачала,
		|	ЛимитыДоговоров.ДатаОкончания КАК ДатаОкончания,
		|	ЛимитыДоговоров.ВариантВыбора КАК ВариантВыбора
		|ИЗ
		|	РегистрСведений.ЛимитыДоговоров КАК ЛимитыДоговоров
		|ГДЕ
		|	ЛимитыДоговоров.Договор = &Договор";
	
	Запрос.УстановитьПараметр("Договор", Объект.ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	ОбластьЗаголовок.Параметры.ТекстЗаголовка="По условиям договора";
	_ИнформацияПоДоговору.Вывести(ОбластьЗаголовок); 
	Выборка = РезультатЗапроса.Выбрать();
	
	пока Выборка.Следующий() цикл
	ОбластьСтрока.Параметры.ТекстСтроки="Отсрочка "+Выборка.КоличествоДнейПросрочки+" дней";	
	_ИнформацияПоДоговору.Вывести(ОбластьСтрока); 
	ОбластьСтрока.Параметры.ТекстСтроки="Сумма лимита "+Выборка.СуммаЛимита+" р. в период с "+
	Формат(Выборка.ДатаНачала,"ДФ=дд.ММ.гггг")+" по "+Формат(Выборка.ДатаОкончания,"ДФ=дд.ММ.гггг");	
	_ИнформацияПоДоговору.Вывести(ОбластьСтрока); 
	Конеццикла;


КонецПроцедуры

