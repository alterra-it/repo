&НаСервере
Процедура ЗаполнитьСтатьяДвиженияДенежныхСредств()
    // № 78469
    МассивГруппыПартнеров = Новый Массив;
    МассивГруппыПартнеров.Добавить(ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Тип поставщика (Поставщики)")); 
    МассивГруппыПартнеров.Добавить(ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров (Общие)"));

    МассивПоставщикТранспортныхУслуг = Новый Массив;
    МассивПоставщикТранспортныхУслуг.Добавить(Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Поставщики")); 
    МассивПоставщикТранспортныхУслуг.Добавить(Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Поставщик транспортных услуг"));    
	
	Запрос = Новый Запрос;
    ТекстЗапроса = 
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |    ПартнерыДополнительныеРеквизиты.Ссылка
    |ИЗ
    |    Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
    |ГДЕ
    |    ПартнерыДополнительныеРеквизиты.Ссылка = &Ссылка
    |    И ПартнерыДополнительныеРеквизиты.Свойство В(&ПоставщикиИПоставщикТУСвойство)
    |    И ПартнерыДополнительныеРеквизиты.Значение В(&ПоставщикиИПоставщикТУЗначение)";    
	
    Запрос.Текст = ТекстЗапроса;
    Запрос.УстановитьПараметр("Ссылка", Объект.Партнер);
    Запрос.УстановитьПараметр("ПоставщикиИПоставщикТУСвойство", МассивГруппыПартнеров);
    Запрос.УстановитьПараметр("ПоставщикиИПоставщикТУЗначение", МассивПоставщикТранспортныхУслуг);
		
	ЕстьДополнительныеРеквизиты = Не Запрос.Выполнить().Пустой();
    
   	Если ЕстьДополнительныеРеквизиты И Объект.Партнер.Поставщик = Истина Тогда
   		Если Объект.ТипДоговора = ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПоставщиком") Тогда	
        
            Статья = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоНаименованию("РАСЧЕТЫ С ПОСТАВЩИКАМИ / Доставка товара");
            // Повторная проверка по коду если было изменено наименование 
            Если Не ЗначениеЗаполнено(Статья) Тогда
                Статья = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("01-000011");
            КонецЕсли;
        
            Если ЗначениеЗаполнено(Статья) Тогда
                Объект.СтатьяДвиженияДенежныхСредств = Статья;
            Иначе
                Сообщить("Статья 'РАСЧЕТЫ С ПОСТАВЩИКАМИ / Доставка товара' не найдена!");
                Объект.СтатьяДвиженияДенежныхСредств = Неопределено;
            КонецЕсли;        
    	Иначе
        	Объект.СтатьяДвиженияДенежныхСредств = Неопределено;	
    	КонецЕсли; 
	КонецЕсли;   
	
КонецПроцедуры

#КонецОбласти // Не_распределённые