	#Вставка
	Результат.Добавить("ВидДоговора");
	#КонецВставки

	Возврат Результат;
КонецФункции


Процедура УдалитьПорядокОплаты(Приемник, Источник) Экспорт
	
	УдалитьПорядокОплаты = ?(ОбщегоНазначения.ЕстьРеквизитОбъекта("УдалитьПорядокОплаты", Источник.Метаданные()),
							Источник.УдалитьПорядокОплаты, Неопределено);
							
	Если ЗначениеЗаполнено(УдалитьПорядокОплаты) Тогда
		Приемник.РасчетыВВалюте = 
			(УдалитьПорядокОплаты = Перечисления.УдалитьПорядокОплатыПоСоглашениям.РасчетыВВалютеОплатаВВалюте 
			ИЛИ УдалитьПорядокОплаты = Перечисления.УдалитьПорядокОплатыПоСоглашениям.РасчетыВВалютеОплатаВРублях);
			
		Приемник.УдалитьПорядокОплаты = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

#КонецЕсли