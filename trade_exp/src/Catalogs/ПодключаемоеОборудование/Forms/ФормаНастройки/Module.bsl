&НаКлиенте
Процедура Док_УстановитьРеквизитыПосле(Команда)
	
	УстановитьРеквизиты();
	
КонецПроцедуры
	
&НаСервере
Процедура УстановитьРеквизиты()
	
	МассивРеквизитов = ЭтаФорма.ПолучитьРеквизиты();
	
	Для Каждого Реквизит Из МассивРеквизитов Цикл
		
		//Сообщить(Реквизит.Имя + " (" + Реквизит.ТипЗначения + ") """  + Реквизит.Заголовок + """ " + Строка(ЭтаФорма[Реквизит.Имя]));
		
		Если Реквизит.Заголовок = "Адрес ОФД" Тогда
			ЭтаФорма[Реквизит.Имя] = "f1.taxcom.ru";
			
		ИначеЕсли Реквизит.Заголовок = "Порт ОФД" Тогда
			ЭтаФорма[Реквизит.Имя] = 7777;
		
		ИначеЕсли Реквизит.Заголовок = "Канал обмена с ОФД" Тогда
			ЭтаФорма[Реквизит.Имя] = 1;

		ИначеЕсли Реквизит.Заголовок = "Адрес ИСМ" Тогда
			ЭтаФорма[Реквизит.Имя] = "f1.taxcom.ru";
		
		ИначеЕсли Реквизит.Заголовок = "Порт ИСМ" Тогда
			ЭтаФорма[Реквизит.Имя] = 8777;

		ИначеЕсли Реквизит.Заголовок = "Адрес ОКП" Тогда
			ЭтаФорма[Реквизит.Имя] = "s01-a.prod.okp-fn.ru";

		ИначеЕсли Реквизит.Заголовок = "Порт ОКП" Тогда
			ЭтаФорма[Реквизит.Имя] = "26101";

		ИначеЕсли Реквизит.Заголовок = "Количество повторов при проверке КМ" Тогда
			ЭтаФорма[Реквизит.Имя] = 1;

		ИначеЕсли Реквизит.Заголовок = "Время открытия соединения при проверке КМ" Тогда
			ЭтаФорма[Реквизит.Имя] = 1;

		ИначеЕсли Реквизит.Заголовок = "Время ожидания ответа при проверке КМ" Тогда
			ЭтаФорма[Реквизит.Имя] = 1;

		ИначеЕсли Реквизит.Заголовок = "Время задержки перед повтором при проверке КМ" Тогда
			ЭтаФорма[Реквизит.Имя] = 0;

		ИначеЕсли Реквизит.Заголовок = "Время открытого соединения при проверке КМ" Тогда
			ЭтаФорма[Реквизит.Имя] = 30;
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры
	
