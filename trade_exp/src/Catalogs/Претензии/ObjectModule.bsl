#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда  
	
&ИзменениеИКонтроль("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	
	Если Статус = Перечисления.СтатусыПретензийКлиентов.Зарегистрирована Тогда
		МассивНепроверяемыхРеквизитов.Добавить("ПричинаВозникновения");
	КонецЕсли;
	
	#Вставка 
	//Доработки для претензий поставщику
	Если ЭтоПретензияПоставщику Тогда
		
		Если НЕ РезультатПоПретензии = Перечисления.РезультатыРассмотренияПретензииПоставщику.УдовлетворенаЧастично Тогда
			МассивНепроверяемыхРеквизитов.Добавить("СуммаУдовлетворения");
		КонецЕсли;	
		
		МассивНепроверяемыхРеквизитов.Добавить("ДатаОкончания");
		Если НЕ СтатусПретензииПоставщику = Перечисления.СтатусыПретензийПоставщику.Завершена Тогда
			МассивНепроверяемыхРеквизитов.Добавить("РезультатыОтработки");
			МассивНепроверяемыхРеквизитов.Добавить("РезультатПоПретензии");
		КонецЕсли;    
		МассивНепроверяемыхРеквизитов.Добавить("Товары.Количество");
			
	Иначе
		МассивНепроверяемыхРеквизитов.Добавить("СуммаУдовлетворения"); 
		МассивНепроверяемыхРеквизитов.Добавить("ИсточникПретензии"); 
		МассивНепроверяемыхРеквизитов.Добавить("НомерИсходящегоПисьмаПоставщику");
		МассивНепроверяемыхРеквизитов.Добавить("РезультатПоПретензии");  
		МассивНепроверяемыхРеквизитов.Добавить("СтатусПретензииПоставщику");	
	#КонецВставки
		Если Статус = Перечисления.СтатусыПретензийКлиентов.Зарегистрирована ИЛИ Статус = Перечисления.СтатусыПретензийКлиентов.Обрабатывается Тогда
			МассивНепроверяемыхРеквизитов.Добавить("ДатаОкончания");
			МассивНепроверяемыхРеквизитов.Добавить("РезультатыОтработки");
		КонецЕсли; 
	#Вставка
	КонецЕсли;
	#КонецВставки
	
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПартнеровКакКонтрагентов") Тогда
		МассивНепроверяемыхРеквизитов.Добавить("ПартнерыИКонтактныеЛица.Партнер");
		Для ТекИндекс = 0 По ПартнерыИКонтактныеЛица.Количество() - 1 Цикл
			Если Не ЗначениеЗаполнено(ПартнерыИКонтактныеЛица[ТекИндекс].Партнер) Тогда
				
				АдресОшибки = " " + НСтр("ru = 'в строке %НомерСтроки% списка ""Участники""'");
				АдресОшибки = СтрЗаменить(АдресОшибки, "%НомерСтроки%", ПартнерыИКонтактныеЛица[ТекИндекс]["НомерСтроки"]);
				
				ТекстОшибки = НСтр("ru = 'Не заполнена колонка ""Контрагент""'");
				ОбщегоНазначения.СообщитьПользователю(
				ТекстОшибки + АдресОшибки,
				ЭтотОбъект,
				ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("ПартнерыИКонтактныеЛица", ПартнерыИКонтактныеЛица[ТекИндекс].НомерСтроки, "Партнер"),
				,
				Отказ);
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(Партнер) Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Партнер");
		ТекстОшибки = НСтр("ru = 'Поле ""Клиент"" не заполнено'");
		Если ЭтоПретензияПоставщику Тогда
			ТекстОшибки = НСтр("ru = 'Поле ""Поставщик"" не заполнено'");
		КонецЕсли;
		ОбщегоНазначения.СообщитьПользователю(
		ТекстОшибки,
		ЭтотОбъект,
		"Партнер",
		,
		Отказ);
	КонецЕсли;
	
	Если НЕ ВестиРасчетыПоПретензии Тогда
		МассивНепроверяемыхРеквизитов.Добавить("Организация");
		МассивНепроверяемыхРеквизитов.Добавить("Контрагент");
		МассивНепроверяемыхРеквизитов.Добавить("Валюта");
	КонецЕсли;
	
	МассивНепроверяемыхРеквизитов.Добавить("Наименование");   
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(
	ПроверяемыеРеквизиты,
	МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	//Доработки для претензий поставщику
	Если ЭтоПретензияПоставщику Тогда
		ДатаОтветаПоставщика = ДатаРегистрации + 864000;
		Исполнитель = Пользователи.ТекущийПользователь();
	КонецЕсли;
КонецПроцедуры
                                   
&ИзменениеИКонтроль("ПередЗаписью")
Процедура Док_ПередЗаписью1(Отказ) 
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	Если ПустаяСтрока(Код) Тогда
		УстановитьНовыйКод();
	КонецЕсли;
	Если ПустаяСтрока(Наименование) Тогда
		Наименование = Справочники.Претензии.АвтоНаименование(ЭтотОбъект);
	КонецЕсли; 
	
	#Вставка
	//Доработки для претензий поставщику
	Если ЭтоПретензияПоставщику Тогда  
		
		Если ЕстьСтрокиСПустымКоличеством() Тогда
			Отказ = Истина;
		КонецЕсли; 
		
		Если РезультатПоПретензии = Перечисления.РезультатыРассмотренияПретензииПоставщику.УдовлетворенаВПолномОбъеме Тогда
			СуммаУдовлетворения = СуммаПретензии;
		КонецЕсли;   
		
		Если СтатусПретензииПоставщику = Перечисления.СтатусыПретензийПоставщику.ВРаботе Тогда   
			Если Комментарий = "" Тогда
				Отказ = Истина;
				Сообщить("Комментарий не заполнен!");
			КонецЕсли;
			Если Исполнитель = Справочники.Пользователи.ПустаяСсылка() Тогда 
				Отказ = Истина; 
				Сообщить("Исполнитель не заполнен!");
			КонецЕсли;
		КонецЕсли;
		
		Если СтатусПретензииПоставщику = Перечисления.СтатусыПретензийПоставщику.Завершена    Тогда   
			
			Если Ссылка.СтатусПретензииПоставщику <> Перечисления.СтатусыПретензийПоставщику.Завершена Тогда 
				ДатаОкончания = ТекущаяДата();  
			КонецЕсли;  
			
		Иначе
			ДатаОкончания = Дата(1, 1, 1);
			РезультатПоПретензии = Перечисления.РезультатыРассмотренияПретензииПоставщику.ПустаяСсылка();
			СуммаУдовлетворения = 0;
		КонецЕсли;
	Иначе
		
		#КонецВставки
		
		Если (Статус = Перечисления.СтатусыПретензийКлиентов.Зарегистрирована)
			Или (Статус = Перечисления.СтатусыПретензийКлиентов.Обрабатывается) Тогда
			ДатаОкончания = Дата(1, 1, 1);
		КонецЕсли; 
		
		#Вставка  
	КонецЕсли;
	#КонецВставки
	
	ВзаиморасчетыСервер.ПередЗаписью(ЭтотОбъект, Отказ);
	
КонецПроцедуры 

Функция ЕстьСтрокиСПустымКоличеством()
	
	Запрос = Новый Запрос; 
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВтТовары
	|ИЗ
	|	&Товары КАК Товары
	|ГДЕ
	|	Товары.Количество = 0
	|	И Товары.КоличествоБрак = 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВтТовары.НомерСтроки КАК НомерСтроки
	|ИЗ
	|	ВтТовары КАК ВтТовары";
	
	Запрос.УстановитьПараметр("Товары", Товары.Выгрузить()); 
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	НомераСтрок = "";
	
	Пока Выборка.Следующий() Цикл
		Если НомераСтрок = "" Тогда
			НомераСтрок = НомераСтрок + Выборка.НомерСтроки;	
		Иначе 
			НомераСтрок = НомераСтрок + ", " +  Выборка.НомерСтроки;	
		КонецЕсли;
	КонецЦикла;
	
	Если Выборка.Количество()>0 Тогда   
		Сообщить("Пустое количество в строках: " + НомераСтрок);
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	КонецФункции
	
#КонецЕсли
