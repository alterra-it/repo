&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
Если ЗначениеЗаполнено(Параметры.Основание) Тогда
	Если Не Параметры.Основание = Неопределено Тогда
		
		Если ТипЗнч(Параметры.Основание) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
			ИмяТабличнойЧасти = "Расхождения";
		Иначе
			ИмяТабличнойЧасти = "Товары";
		КонецЕсли;

		Если Не Параметры.Основание.ПолучитьОбъект().Метаданные().ТабличныеЧасти.Найти(ИмяТабличнойЧасти) = Неопределено Тогда
			Товары.Очистить();
			Для каждого Строка из Параметры.Основание[ИмяТабличнойЧасти] Цикл
				Коэффициент = 1;
				Если Строка.Количество < 0 Тогда
					Коэффициент = -1;
				Иначе
					Коэффициент = 1;
				КонецЕсли;
				Если Строка.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга Тогда
					НоваяСтрока = Товары.Добавить();
					НоваяСтрока.Номенклатура = Строка.Номенклатура;
					НоваяСтрока.Количество = Коэффициент*Строка.Количество;
					НоваяСтрока.Цена = Строка.Сумма/Строка.Количество;
					НоваяСтрока.Оборот = Коэффициент*Строка.Сумма;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьВсе(Команда)
	 ВыборНаСервере(Истина);
КонецПроцедуры

&НаСервере
Процедура ВыборНаСервере(Значение=Ложь)
ТаблицаЗначений = Товары.Выгрузить();
ТаблицаЗначений.ЗаполнитьЗначения(Значение,"Выбрать");
Товары.Загрузить(ТаблицаЗначений);	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВыбор(Команда)
	ВыборНаСервере(Ложь);
КонецПроцедуры

&НаСервере
Процедура ПеренестиВДокументНаСервере()
Структура = Новый Структура ("Выбрать",Истина);
//ТЗ.Загрузить(Товары.Выгрузить(Структура,"Номенклатура,Количество,Оборот,Цена"));
ТЗ.Загрузить(Товары.Выгрузить(Структура,"Номенклатура,Цена"));

КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	ПеренестиВДокументНаСервере();
	Закрыть(ТЗ);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
   СтрокаТабличнойЧасти = Элементы.Товары.ТекущиеДанные;
   СтрокаТабличнойЧасти.Оборот = СтрокаТабличнойЧасти.Количество * СтрокаТабличнойЧасти.Цена;
КонецПроцедуры
