Процедура БлокировкаФормыДляРедактирования() 
		
	Элементы.ГруппаБП.ТолькоПросмотр = Ложь;
	Элементы.ГруппаСтраницы.ТолькоПросмотр = Ложь;
    Элементы.Статус.ТолькоПросмотр = Ложь;
    Элементы.СтатусПретензииПоставщику.ТолькоПросмотр = Ложь;
	Элементы.Товары1.КоманднаяПанель.ТолькоПросмотр = Ложь;
	
	Если Объект.ЭтоПретензияПоставщику Тогда	
		Если (Объект.СтатусПретензииПоставщику = Перечисления.СтатусыПретензийПоставщику.НеВыставляем 
			ИЛИ Объект.СтатусПретензииПоставщику = Перечисления.СтатусыПретензийПоставщику.Завершена) Тогда
			
			Элементы.ГруппаБП.ТолькоПросмотр = Истина;
			Элементы.ГруппаСтраницы.ТолькоПросмотр = Истина;
			Элементы.Статус.ТолькоПросмотр = Истина;
            Элементы.Товары1.КоманднаяПанель.ТолькоПросмотр = Истина; 
			
			Если НЕ(РольДоступна("ПолныеПрава") ИЛИ РольДоступна("РедактированиеЗавершенныхПретензийПоставщику")) Тогда  
			     Элементы.СтатусПретензииПоставщику.ТолькоПросмотр = Истина;
			КонецЕсли;
			
		КонецЕсли; 
	КонецЕсли; 
	

КонецПроцедуры 

