Функция  ПолучитьМассивЗначений()
	
    МассивЗначений = Новый Массив();
			
	МассивЗначений.Добавить(Справочники.ПричиныВозникновенияПретензий.НайтиПоНаименованию("Количество")); 
	МассивЗначений.Добавить(Справочники.ПричиныВозникновенияПретензий.НайтиПоНаименованию("Качество"));
	
	Возврат МассивЗначений;
