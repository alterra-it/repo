 &НаСервере
Процедура ИзменитьФормуПоТипуПретензии()
//Доработки для претензий поставщику    

	ЭтоПретензияПоставщику = Объект.ЭтоПретензияПоставщику;  
	
	//Установка видимости реквизитов Претензии Поставщику
	Элементы.ГруппаДаты.Видимость                      = ЭтоПретензияПоставщику;
	Элементы.СчетФактураПолученный.Видимость           = ЭтоПретензияПоставщику;
	Элементы.ИсточникПретензии.Видимость               = ЭтоПретензияПоставщику;
    Элементы.СчетФактураПолученный.Видимость           = ЭтоПретензияПоставщику; 
	Элементы.СтраницаВРаботе.Видимость                 = ЭтоПретензияПоставщику; 
	Элементы.СтатусПретензииПоставщику.Видимость       = ЭтоПретензияПоставщику;
    Элементы.ГруппРезПоПретензСуммУдовл.Видимость      = ЭтоПретензияПоставщику;
	Элементы.НомерИсходящегоПисьмаПоставщику.Видимость = ЭтоПретензияПоставщику;
	Элементы.НомерЗадачиВБитриксе.Видимость            = ЭтоПретензияПоставщику;                                                     
	Элементы.Контрагент.Видимость                      = ЭтоПретензияПоставщику;           
	
	Элементы.Товары1КоличествоБрак.Видимость           = ЭтоПретензияПоставщику;
	
	//Скрытие видимости реквизитов Претензии Клиента  
	Элементы.Наименование.Видимость                    = Не ЭтоПретензияПоставщику;
	Элементы.СтраницаПартнерыКонтактныеЛица.Видимость  = Не ЭтоПретензияПоставщику;
	Элементы.ОснованиеЧекККМ.Видимость                 = Не ЭтоПретензияПоставщику;
	Элементы.ЗаданиеНаПеревозкуРейс.Видимость          = Не ЭтоПретензияПоставщику;
	Элементы.Комментарий.Видимость                     = Не ЭтоПретензияПоставщику;
	Элементы.Статус.Видимость                          = Не ЭтоПретензияПоставщику;
	Элементы.ФИО.Видимость                             = Не ЭтоПретензияПоставщику;  
	Элементы.ПредоставлениеФотоВидео.Видимость         = Не ЭтоПретензияПоставщику;
	Элементы.ЕстьПисьменнаяПретензия.Видимость         = Не ЭтоПретензияПоставщику;
	Элементы.МестонахождениеТовара.Видимость           = Не ЭтоПретензияПоставщику;
    Элементы.ДатаПисьменнойПретензии.Видимость         = Не ЭтоПретензияПоставщику;    
	Элементы.ВестиРасчетыПоПретензии.Видимость         = Не ЭтоПретензияПоставщику; 
	Элементы.ИДБизнесПроцесса.Видимость                = Не ЭтоПретензияПоставщику; 
    Элементы.Партнер.Видимость                         = Не ЭтоПретензияПоставщику;      
	
	Если ЭтоПретензияПоставщику Тогда 
		Если Объект.ДатаОтветаПоставщика = '00010101' Тогда
			Объект.ДатаОтветаПоставщика = Объект.ДатаРегистрации + 864000;
			Исполнитель = Пользователи.ТекущийПользователь();
		КонецЕсли;
		Элементы.Товары1Количество.Заголовок = "Количество недовоз / излишек";  	
		УстановитьДоступностьТоварыНедовоз();		
		//Счет фактура  
		Если Объект.Основание <> Неопределено Тогда
			ПараметрыРегистрации = Документы.ПриобретениеТоваровУслуг.ПараметрыРегистрацииСчетовФактурПолученных(Объект.Основание);
			СчетаФактурыПолученныеНаОсновании = УчетНДСУП.СчетаФактурыПолученныеНаОсновании(ПараметрыРегистрации); 
			Если  СчетаФактурыПолученныеНаОсновании.СчетаФактуры.Количество() > 0 Тогда
				СчетФактураПолученный  = СчетаФактурыПолученныеНаОсновании.СчетаФактуры[0]; 
			КонецЕсли; 
		КонецЕсли;  	
	КонецЕсли;  
	
   БлокировкаФормыДляРедактирования();
КонецПроцедуры 


&НаКлиенте
Процедура Док_ПричинаВозникновенияНачалоВыбораВместо(Элемент, ДанныеВыбора, СтандартнаяОбработка)   
	
	Если Объект.ЭтоПретензияПоставщику Тогда
		СтандартнаяОбработка = Истина
	Иначе   
		
	МассивЗначений = ПолучитьМассивЗначений(); 
	ДанныеВыбора = МассивЗначений;	
	СтандартнаяОбработка = Ложь; 
	
	Форма = ОткрытьФорму("Справочник.ПричиныВозникновенияПретензий.ФормаВыбора",, Элемент);
	
		ОтборВладелец = Форма.Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
		ОтборВладелец.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; 
		ОтборВладелец.Использование = Истина; 
		ОтборВладелец.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка"); 
		ОтборВладелец.ПравоеЗначение = МассивЗначений;    
	КонецЕсли;	
	
КонецПроцедуры

