Функция ПолучитьПрисоединенныеФайлы(ВладелецФайлов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПретензииПрисоединенныеФайлы.Ссылка КАК Ссылка,
		|	ПретензииПрисоединенныеФайлы.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ПретензииПрисоединенныеФайлы КАК ПретензииПрисоединенныеФайлы
		|ГДЕ
		|	ПретензииПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла
		|	И НЕ ПретензииПрисоединенныеФайлы.Ссылка.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";
	
	
	Запрос.УстановитьПараметр("ВладелецФайла", ВладелецФайлов);
	//Альтерра+ Проходим по упорядоченному запросу в поиске дублей, как только нашли дубль, делаем возврат, сообщая об ошибке
	Результат =  Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	ИмяДляСравнения = ""; 
	Пока Выборка.Следующий() Цикл 
		Если ИмяДляСравнения = Выборка.Наименование Тогда 
			Сообщить("В присоединенных файлах есть файлы с одинаковым названием. Переименуйте дубли или удалите один из них");
			Возврат неопределено;
		КонецЕсли;
		ИмяДляСравнения = Выборка.Наименование
	КонецЦикла;
	//-
	Возврат Результат.Выгрузить();
	
КонецФункции

Функция ПолучитьОписаниеПретенизии(Основание)
	 СтрокаВозврата = "Товары:" + Символы.ПС;
	 
	 Для каждого Строка из Объект.Товары Цикл
		 СтрокаВозврата = СтрокаВозврата + Строка.Номенклатура + " - " + Строка.Количество + " - " + Строка.Оборот + Символы.ПС;
	 КонецЦикла;
	 
	 СтрокаВозврата = СтрокаВозврата + "Описание претензии: " + Объект.ОписаниеПретензии+Символы.ПС;

	 СтрокаВозврата = СтрокаВозврата + ПолучитьРейс(Основание,Ложь)+Символы.ПС;
	 
	 СтрокаВозврата = СтрокаВозврата + "Комментарий: " + Объект.Комментарий;
	 Возврат СтрокаВозврата;
КонецФункции

Функция ПолучитьДокументПродажи(Основание)
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
		ДокументПродажи = Основание.ЧекККМ;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		ДокументПродажи = Основание.ДокументРеализации;
	ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
		ДокументПродажи = Основание.ДокументОснование;
	Иначе
		ДокументПродажи = Основание;
	КонецЕсли;
	
	Возврат ДокументПродажи;
	
КонецФункции

Функция ПолучитьРейс(ДокументПродажи,ТолькоРейс) 	
	
	ВозвращаемоеЗначение = "";
	
	ДокументРейс = "";	
	ДокументРейс = ПолучитьРейсПоДокументуПродажи(ДокументПродажи);
	
	Если ЗначениеЗаполнено(ДокументРейс) Тогда
		Если ТолькоРейс Тогда
			ВозвращаемоеЗначение = ДокументРейс;
		Иначе
			ВозвращаемоеЗначение = "По документу продажи есть рейс: " + ДокументРейс;
		КонецЕсли;
	Иначе
		Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Если ЗначениеЗаполнено(ДокументПродажи.ЗаказКлиента) Тогда
				ДокументРейс = ПолучитьРейсПоДокументуПродажи(ДокументПродажи.ЗаказКлиента);
				Если ЗначениеЗаполнено(ДокументРейс) Тогда
					Если ТолькоРейс Тогда
						ВозвращаемоеЗначение = ДокументРейс;
					Иначе
						ВозвращаемоеЗначение = "По документу продажи есть рейс: " + ДокументРейс;
					КонецЕсли;
				Иначе
					ВозвращаемоеЗначение = "По документу продажи нет рейса.";
				КонецЕсли;
			Иначе
				ВозвращаемоеЗначение = "По документу продажи нет рейса.";
			КонецЕсли;
		Иначе
			ВозвращаемоеЗначение = "По документу продажи нет рейса.";
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВозвращаемоеЗначение;
    	
КонецФункции

Функция ПолучитьРейсПоДокументуПродажи(ДокументПродажи) 	
	ДокументРейс = "";
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказыКДоставке.Рейс КАК Рейс
		|ИЗ
		|	РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
		|ГДЕ
		|	ЗаказыКДоставке.ДокументПродажи = &ДокументПродажи";
	
	Запрос.УстановитьПараметр("ДокументПродажи", ДокументПродажи);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Количество()>0 Тогда
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДокументРейс = ВыборкаДетальныеЗаписи.Рейс;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ДокументРейс;
    	
КонецФункции

Функция ПолучитьПодразделениеОснование(ДокументОснование)
	
	//ПодразделениеДокумента=Справочники.СтруктураПредприятия.ПустаяСсылка();
	если не значениезаполнено(ДокументОснование) тогда
		ПодразделениеДокумента=Пользователи.ТекущийПользователь().Подразделение;
	иначе
		Если Не ДокументОснование.ПолучитьОбъект().Метаданные().Реквизиты.Найти("Подразделение") = Неопределено Тогда
			ОснованиеДокументОбъект = ДокументОснование.ПолучитьОбъект();
		ИначеЕсли Не ДокументОснование.ПолучитьОбъект().Метаданные().Реквизиты.Найти("ЧекККМ") = Неопределено Тогда
			ОснованиеДокументОбъект = ДокументОснование.ЧекККМ.ПолучитьОбъект();	
		КонецЕсли;
		
		ПодразделениеДокумента = ОснованиеДокументОбъект.Подразделение;
	конецесли;
	Возврат ПодразделениеДокумента;
	
КонецФункции

Функция ТабличнаяЧастьТоварыНеЗаполнена()
	
	Результат = 0;
	
	ОснованиеПретензии = ?(ЗначениеЗаполнено(Объект.ОснованиеЧекККМ), Объект.ОснованиеЧекККМ,?(ЗначениеЗаполнено(Объект.Основание),Объект.Основание,Неопределено));
	Если Не ОснованиеПретензии = Неопределено Тогда
		Если Не ОснованиеПретензии.ПолучитьОбъект().Метаданные().ТабличныеЧасти.Найти("Товары") = Неопределено Тогда
			Если Объект.Товары.Количество()=0 Тогда
			Результат = 1;	 
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ?(Результат = 1, Истина, Ложь)
	
КонецФункции

