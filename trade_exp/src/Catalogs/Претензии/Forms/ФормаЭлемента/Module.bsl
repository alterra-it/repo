	ТекущаяСтрока.Цена = ПолучитьЦенуПоСебестоимости(ТекущаяСтрока.Номенклатура);
	
	ПересчитатьСуммуИКоличествоВСтроке(Элементы.Товары1.ТекущиеДанные);
	ПересчитатьСуммуПретензии();
КонецПроцедуры 

&НаСервере 
Функция ПолучитьЦенуПоСебестоимости(Номенклатура)
	Запрос = Новый Запрос;
	Запрос.Текст =

	"ВЫБРАТЬ
	|	(СебестоимостьТоваровОстатки.СтоимостьОстаток + СебестоимостьТоваровОстатки.ДопРасходыОстаток) / СебестоимостьТоваровОстатки.КоличествоОстаток КАК ЦенаТовара
	|ИЗ
	|	РегистрНакопления.СебестоимостьТоваров.Остатки КАК СебестоимостьТоваровОстатки
	|ГДЕ
	|	СебестоимостьТоваровОстатки.АналитикаУчетаНоменклатуры.Номенклатура = &Номенклатура";
 
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ЦенаТовара;
	Иначе 
		Возврат 0;
	КонецЕсли;	
КонецФункции


