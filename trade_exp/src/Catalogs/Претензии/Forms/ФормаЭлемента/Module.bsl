#Область ОтправкаСообщенияПостановкаЗадачиПоСумме
&НаСервере
Процедура ОтправкаСообщенияПостановкаЗадачиПоСумме()
	Если Объект.ЭтоПретензияПоставщику И Объект.СтатусПретензииПоставщику = Перечисления.СтатусыПретензийПоставщику.Отправлена Тогда
		СтруктураПараметров = ДопМодуль.ПолучитьНастройкиХранилища("НастройкиСуммИЧатаДляПретензий","НастройкиХранилища.epf"); 
		Если СтруктураПараметров = Неопределено Тогда
			АльтерраОбщегоНазначения.СообщитьПользователю(, "Не заданы настройки отправки уведомлений/постановки задачи, обратитесь в тех. поддержку");
			Возврат;
		Иначе
			СуммаНаОповещение = СтруктураПараметров.СуммаНаОповещение;
			СуммаНаЗадачу = СтруктураПараметров.СуммаНаЗадачу;
			КодЧата = СтруктураПараметров.КодЧата;
			ДолжностьИсполнитель = СтруктураПараметров.ДолжностьИсполнитель;
			ДолжностьНаблюдатель = СтруктураПараметров.ДолжностьНаблюдатель;
			Руководители = ПолучитьРуководителей(ДолжностьИсполнитель, ДолжностьНаблюдатель);
			Если НЕ ЗначениеЗаполнено(Руководители) Тогда
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		СобытиеСообщение = Справочники.СобытияОбъектовАльтерра.НайтиПоНаименованию("Претензия отправка сообщения");
		СобытиеЗадача = Справочники.СобытияОбъектовАльтерра.НайтиПоНаименованию("Претензия задача на руководителя ОК");
		
		Если Объект.СуммаПретензии >= СуммаНаЗадачу И ЗначениеЗаполнено(СобытиеЗадача) И НЕ РегистрыСведений.СобытияОбъектовАльтерра.БылоСобытие(Объект.Ссылка, СобытиеЗадача) Тогда
			СтруктураПараметров = ПолучитьСтруктуруПараметровЗадачи(Руководители);
			СтруктураПараметров.Заголовок = "Претензия поставщику " + Объект.Контрагент + " на сумму " + Объект.СуммаПретензии + ", Исх. " + Объект.НомерИсходящегоПисьмаПоставщику;
			
			СтруктураПараметров.Описание = Объект.ОписаниеПретензии + Символы.ПС
										+ ПолучитьТоварыСтрокой() + Символы.ПС
										+ "Ссылка на претензию в 1С: " + ПолучитьНавигационнуюСсылку(Объект.Ссылка);
			
			АльтерраВзаимодействиеСБитрикс24.СоздатьЗадачу(СтруктураПараметров);
			РегистрыСведений.СобытияОбъектовАльтерра.ЗаписатьСобытие(Объект.Ссылка, СобытиеЗадача);
		КонецЕсли;
		
		Если Объект.СуммаПретензии >= СуммаНаОповещение И ЗначениеЗаполнено(СобытиеСообщение) И НЕ РегистрыСведений.СобытияОбъектовАльтерра.БылоСобытие(Объект.Ссылка, СобытиеСообщение) Тогда
			
			ТекстСообщения = "[b]Претензия поставщику " + Объект.Контрагент + " на сумму " + Объект.СуммаПретензии + ", Исх. " + Объект.НомерИсходящегоПисьмаПоставщику + "[/b]" + Символы.ПС
							+ ПолучитьТоварыСтрокой() + Символы.ПС
							+ ПолучитьНавигационнуюСсылку(Объект.Ссылка);
							
			АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитриксПоИДЧата(ТекстСообщения, КодЧата);
			РегистрыСведений.СобытияОбъектовАльтерра.ЗаписатьСобытие(Объект.Ссылка, СобытиеСообщение);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьТоварыСтрокой()
	ТоварыСтрока = "Товары: ";
	Шаблон = "%1) %2, кол-во %3 ед., брак %4 ед., цена %5 руб., оборот %6 руб.";
	Для каждого стр из Объект.Товары Цикл
		ТоварыСтрока = ТоварыСтрока + Символы.ПС +
					СтрШаблон(Шаблон, стр.НомерСтроки, стр.Номенклатура, стр.Количество, стр.КоличествоБрак, стр.Цена, стр.Оборот);
				КонецЦикла;
	Возврат ТоварыСтрока;
КонецФункции

&НаСервере
Функция ПолучитьСтруктуруПараметровЗадачи(Руководители)
	СтруктураПараметров = Новый Структура("
		|Постановщик,
		|Ответственные,
	    |Наблюдатели,
		|Заголовок,
		|Описание,
		|КрайнийСрок,
		|ИДГруппы,
		|ИДРодительскойЗадачи");
	

	Ответственные = Новый Массив();
	Ответственные.Добавить(Руководители.Исполнитель); //Исполнитель задачи
	Ответственные.Добавить(Объект.Исполнитель); //Соисполнитель
	
	Наблюдатели = Новый Массив();
	Наблюдатели.Добавить(Руководители.Наблюдатель);
	
	СтруктураПараметров.Постановщик = Руководители.Исполнитель;
	СтруктураПараметров.Ответственные = Ответственные;
	СтруктураПараметров.Наблюдатели = Наблюдатели;
    Возврат СтруктураПараметров;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьРуководителей(ДолжностьИсполнитель, ДолжностьНаблюдатель)
	Руководители = Новый Структура();
	СписокДолжностей = Новый Массив();
	СписокДолжностей.Добавить(ДолжностьИсполнитель);
	СписокДолжностей.Добавить(ДолжностьНаблюдатель);
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	Сотрудники.Ссылка КАК Ссылка,
	                      |	ВЫБОР
	                      |		КОГДА Сотрудники.Должность = &ДолжностьИсполнитель
	                      |			ТОГДА ""Исполнитель""
	                      |		ИНАЧЕ ""Наблюдатель""
	                      |	КОНЕЦ КАК Ключ
	                      |ИЗ
	                      |	Справочник.Сотрудники КАК Сотрудники
	                      |ГДЕ
	                      |	НЕ Сотрудники.Уволен
	                      |	И Сотрудники.Должность В(&СписокДолжностей)");
	
	Запрос.УстановитьПараметр("ДолжностьИсполнитель", ДолжностьИсполнитель);
	Запрос.УстановитьПараметр("СписокДолжностей", СписокДолжностей);
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Количество() <> 2 Тогда
		АльтерраОбщегоНазначения.СообщитьПользователю(, "Не найден " + Строка(ДолжностьИсполнитель) + " или " + Строка(ДолжностьНаблюдатель) + "!");
		Возврат Неопределено;
	КонецЕсли;
	
	Пока Результат.Следующий() Цикл
		Руководители.Вставить(Результат.Ключ, Результат.Ссылка);
	КонецЦикла;
	
	Возврат Руководители;
КонецФункции

#КонецОбласти