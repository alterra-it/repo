#Область ОбработчикиСобытийФормы_Справочники    

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка) 
	НовыйРеквизит = Элементы.Добавить("СтатусПретензииПоставщику", Тип("ПолеФормы"), Элементы.ГруппаТипСтатус); 
	НовыйРеквизит.Заголовок = "Статус"; 
	НовыйРеквизит.Вид = ВидПоляФормы.ПолеВвода; 
	НовыйРеквизит.ПутьКДанным = "Объект.СтатусПретензииПоставщику";   
	НовыйРеквизит.УстановитьДействие("ПриИзменении", "СтатусПретензииПоставщикуПриИзмененииПосле");	
КонецПроцедуры

&НаКлиенте
Процедура Спр_ПередЗакрытиемПосле(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	//Доработки для претензий поставщику
	Если Объект.ЭтоПретензияПоставщику Тогда
		Возврат;
	КонецЕсли;
	
	Если ПустаяСтрока(Объект.ИДБизнесПроцесса) Тогда
	
	Режим = РежимДиалогаВопрос.ДаНет;
      

    Ответ = Вопрос("Создать бизнес-процесс?", Режим,0) ;
      
	
	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		КодЭлементаСписка = Спр_СоздатьБППослеНаСервере();
		Если Не ПустаяСтрока(КодЭлементаСписка) Тогда
			Объект.ИДБизнесПроцесса = КодЭлементаСписка;
			Сообщить("БП создан!");
			ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма);
			
			ЭтаФорма.элементы.ФормаСоздатьБП.Доступность=Ложь;
		Иначе
			Объект.ИДБизнесПроцесса = "";
			Сообщить("БП не создан!");
		КонецЕсли;
		
	КонецЕсли ;
	
КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Спр_ПриОткрытииПосле(Отказ) 
	
	
	Основание = "";
	
	Если ЗначениеЗаполнено(Объект.ОснованиеЧекККМ) Тогда
		Основание =  Объект.ОснованиеЧекККМ;
	ИначеЕсли ЗначениеЗаполнено(Объект.Основание) Тогда
		Основание = Объект.Основание;
	КонецЕсли;
	
	Подразделение = ПолучитьПодразделениеОснование(Основание);

	Если ЗначениеЗаполнено(Основание) Тогда
		ДокументПродажи = ПолучитьДокументПродажи(Основание);
		ЗаданиеНаПеревозкуРейс = ПолучитьРейс(ДокументПродажи,Истина);
	КонецЕсли;
	
	Если Не ПустаяСтрока(Объект.ИДБизнесПроцесса) Тогда
		ЭтаФорма.элементы.ФормаСоздатьБП.Доступность=Ложь;
	КонецЕсли;
	
	Если Не ДоступныПолныеПрава() Тогда
		ЭтаФорма.Элементы.ОчиститьИДБП.Видимость = Ложь;
	КонецЕсли;
	
	УстановитьЗначенияСпискаВыбора();
	
	ИзменитьФормуПоТипуПретензии();
    
	
КонецПроцедуры

&НаСервере
Процедура Док_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	Если Объект.ПричинаВозникновения = Справочники.ПричиныВозникновенияПретензий.НайтиПоНаименованию("Качество") Тогда
		Элементы.ПредоставлениеФотоВидео.Доступность = Истина;
		Если Объект.ПредоставлениеФотоВидео = "Планируемая дата получения" Тогда
			Элементы.ДатаПредоставления.Видимость = Истина;
		Иначе
			Элементы.ДатаПредоставления.Видимость = Ложь;
		КонецЕсли;
	Иначе
		Элементы.ПредоставлениеФотоВидео.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьЗначенияСпискаВыбора()
	Элементы.ПредоставлениеФотоВидео.РежимВыбораИзСписка = Истина;
	Элементы.ПредоставлениеФотоВидео.СписокВыбора.Добавить("Приложены");
	Элементы.ПредоставлениеФотоВидео.СписокВыбора.Добавить("Клиент не может предоставить");
	Элементы.ПредоставлениеФотоВидео.СписокВыбора.Добавить("В фото нет необходимости");
	Элементы.ПредоставлениеФотоВидео.СписокВыбора.Добавить("Планируемая дата получения");
КонецПроцедуры


&НаКлиенте
Процедура Спр_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи) 
	
	Если Не Объект.ЭтоПретензияПоставщику Тогда	      
		Если Строка(Объект.ПричинаВозникновения) = "Качество" И Объект.ПредоставлениеФотоВидео = "" Тогда
			СообщитьПользователю("Объект.ПредоставлениеФотоВидео", "Заполните поле Предоставление фото/видео!");
			Отказ = Истина;
		КонецЕсли;
		
		Если Объект.ПредоставлениеФотоВидео = "Планируемая дата получения" И Объект.ДатаПредоставления = '00010101' Тогда
			СообщитьПользователю("Объект.ДатаПредоставления", "Заполните дату предоставления фото/видео!");
			Отказ = Истина;
		КонецЕсли;
				
		Если Объект.ЕстьПисьменнаяПретензия И Не ЗначениеЗаполнено(Объект.ДатаПисьменнойПретензии) Тогда
			СообщитьПользователю("Объект.ДатаПисьменнойПретензии","Дата письменной претензии не заполнена!");
			Отказ = Истина;
		КонецЕсли;
		Если  Не ЗначениеЗаполнено(Объект.МестонахождениеТовара) Тогда
			СообщитьПользователю("Объект.МестонахождениеТовара","Местонахождение товара не заполнено!");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ТабличнаяЧастьТоварыНеЗаполнена() Тогда
			СообщитьПользователю("Объект.Товары","Табличная часть 'Товары' не заполнена!");
			Отказ = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область КомандыФормы_Справочники

&НаКлиенте
Процедура Док_ЗаполнитьПоОснованиюПосле(Команда)
	
	Если Элементы.Товары1.КоманднаяПанель.ТолькоПросмотр = Истина Тогда 
		Предупреждение("Невозможно редакртировать данные");
	Иначе
		Оповещение = Новый ОписаниеОповещения("ОткрытьПараметрыЗавершение",ЭтотОбъект);   	
		Если ЗначениеЗаполнено(Объект.ОснованиеЧекККМ) Тогда
			ПараметрыФормы = Новый Структура("Основание", Объект.ОснованиеЧекККМ);
		Иначе
			ПараметрыФормы = Новый Структура("Основание", Объект.Основание);
		КонецЕсли;
		ОткрытьФорму("Справочник.Претензии.Форма.Спр_ФормаТовары", ПараметрыФормы,ЭтаФорма,,,,Оповещение);
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте 
Процедура ОткрытьПараметрыЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	ОткрытьПараметрыЗавершениеСервер(Результат);
КонецПроцедуры 

&НаСервере 
Процедура ОткрытьПараметрыЗавершениеСервер(Результат) Экспорт 
	Если ТипЗнч(Результат) = Тип("ДанныеФормыКоллекция") тогда 
		 Объект.Товары.Загрузить(Результат.Выгрузить());
		 ПересчитатьСуммуПретензии();
	конецесли;
КонецПроцедуры 

&НаКлиенте
Процедура Док_ОчиститьПосле(Команда)  
	
    Если Элементы.Товары1.КоманднаяПанель.ТолькоПросмотр = Истина Тогда 
		Предупреждение("Невозможно редакртировать данные");
	Иначе
		Объект.Товары.Очистить();
		ПересчитатьСуммуПретензии();		
	КонецЕсли;  
КонецПроцедуры

&НаКлиенте
Процедура Спр_КорректировкаСуммыПретензииВручнуюПриИзмененииПосле(Элемент)
	Элементы.СуммаПретензии.ТолькоПросмотр = Не Объект.КорректировкаСуммыПретензииВручную;
КонецПроцедуры

&НаКлиенте
Процедура Спр_ЕстьПисьменнаяПретензияПриИзмененииПосле(Элемент)
	Элементы.ДатаПисьменнойПретензии.ТолькоПросмотр = Не Объект.ЕстьПисьменнаяПретензия;
КонецПроцедуры

&НаКлиенте
Процедура СообщитьПользователю(Поле,Текст)
	Сообщение = Новый СообщениеПользователю;
    Сообщение.Поле  = Поле;
    Сообщение.Текст = Текст;
    Сообщение.Сообщить();
КонецПроцедуры

&НаСервере
Функция Спр_СоздатьБППослеНаСервере()
	
	ПустаяСтрокаОтвета = "";
	ПретензияПоКачеству = Объект.ПричинаВозникновения = Справочники.ПричиныВозникновенияПретензий.НайтиПоНаименованию("Качество");
	
	Если НЕ (ЗначениеЗаполнено(Объект.Основание) ИЛИ ЗначениеЗаполнено(Объект.ОснованиеЧекККМ)) Тогда
		Сообщить("Претензия создана не на основании документа, создание БП невозможно!");
		Возврат ПустаяСтрокаОтвета;
	КонецЕсли;

	Если НЕ (ЗначениеЗаполнено(Объект.ПричинаВозникновения) И ЗначениеЗаполнено(Объект.Партнер) И Объект.СуммаПретензии > 0) Тогда
		Сообщить("Не заполнено одно из следующих полей - Причина возникновения, Партнер или Сумма претензии, создание БП невозможно!");
		Возврат ПустаяСтрокаОтвета;
	КонецЕсли;
	
	Если ПретензияПоКачеству Тогда
		Если Объект.ПредоставлениеФотоВидео = "" Тогда
			Сообщить("Не заполнено Предоставление фото/видео!");
			Возврат ПустаяСтрокаОтвета;
		КонецЕсли;
		
		Если Объект.ПредоставлениеФотоВидео = "Планируемая дата получения" И Объект.ДатаПредоставления = '00010101' Тогда
			Сообщить("Не заполнена дата предоставления фото/видео!");
			Возврат ПустаяСтрокаОтвета;
		КонецЕсли;
	КонецЕсли;

	КодЭлементаПроцесса = Строка(Объект.Ссылка.УникальныйИдентификатор());

	АвторЗаписи = АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя();

	Если Не ЗначениеЗаполнено(АвторЗаписи) Тогда
		Сообщить("Текущий пользователь не найден в базе данных битрикса!");
		Возврат ПустаяСтрокаОтвета;
	КонецЕсли;
	 
	СформироватьАктНесоответствия();
	ПрисоединенныеФайлыСписок = ПолучитьПрисоединенныеФайлы(Объект.Ссылка).ВыгрузитьКолонку("Ссылка");
	ЕстьПрисоединенныеФайлы = ПрисоединенныеФайлыСписок.Количество()> 0 ;
		
	//--ОтправкаДанныхЧерезRestApiБитрикса не используется
	//НомерФайла = 0;
	//Для каждого СтрокаФайл Из ПрисоединенныеФайлыСписок Цикл
	//	ИдФайла = ОтправкаДанныхЧерезRestApiБитрикса.ЗагрузитьФайлНаСервере("280481",СтрокаФайл.Ссылка,АвторЗаписи,КодЭлементаПроцесса);
	//	Если ЗначениеЗаполнено(ИдФайла) Тогда
	//		НомерФайла = НомерФайла + 1;
	//		Ид = СтрЗаменить(Строка(ИдФайла.result.ID),Символы.НПП,"");;
	//		МассивИдФайлов.Вставить("n"+Строка(НомерФайла),"n"+Ид);
	//		НомерФайла = НомерФайла + 1;
	//	КонецЕсли;
	//КонецЦикла;
	//--
	МассивОбъектовДляИдентификации = Новый Массив;
	МассивОбъектовДляИдентификации.Добавить(Подразделение);
	
	ТаблицаИдентификаторовБ24 = Справочники.Альтерра_НастройкиОбменаБитрикс.ПолучитьТаблицуИдентификаторов(МассивОбъектовДляИдентификации, "Претензии_клиентов", ЕстьПрисоединенныеФайлы);
	
	ОтборПоиска = Новый Структура;
	ОтборПоиска.Вставить("Объект");
	
	СтруктураД  = Новый Структура();
	
	СтруктураД.Вставить("NAME", Объект.Наименование);
	
	ОтборПоиска.Объект = Подразделение;
	СтрокиПодразделение = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска);
	Если СтрокиПодразделение.Количество()> 0 Тогда
		СтруктураД.Вставить("PROPERTY_1022", СтрокиПодразделение[0].Идентификатор);
	Иначе
		Сообщить("Для обязательного поля в значении " + Строка(Подразделение) + " не задан идентификатор Битрикс");
		Возврат ПустаяСтрокаОтвета;
	КонецЕсли;     
	
    Основание = ?(ЗначениеЗаполнено(Объект.ОснованиеЧекККМ), Объект.ОснованиеЧекККМ, Объект.Основание);	
	СтруктураД.Вставить("PROPERTY_1023", ?(Объект.ПричинаВозникновения = Справочники.ПричиныВозникновенияПретензий.НайтиПоНаименованию("Качество"), "1366", "1367"));
	СтруктураД.Вставить("PROPERTY_1017", Строка(Объект.Партнер));
	СтруктураД.Вставить("PROPERTY_1018", Строка(Основание.Ссылка));
	СтруктураД.Вставить("PROPERTY_1019", Строка(Основание.Дата));
	СтруктураД.Вставить("PROPERTY_1021", Объект.СуммаПретензии);
	СтруктураД.Вставить("PROPERTY_1051", Строка(Объект.МестонахождениеТовара));
	СтруктураД.Вставить("PROPERTY_1024", ?(Объект.ЕстьПисьменнаяПретензия, "1368", "1369"));
	СтруктураД.Вставить("PROPERTY_1035", Строка(Объект.ДатаПисьменнойПретензии));
	СтруктураД.Вставить("PROPERTY_1081", "1406");
	СтруктураД.Вставить("PROPERTY_1255", Строка(Объект.Код));
	
	Если ПретензияПоКачеству Тогда
		ТекстСтроки = Объект.ПредоставлениеФотоВидео;
		PROPERTY_3533 = ?(ТекстСтроки = "Планируемая дата получения", ТекстСтроки + ": " + Строка(Формат(Объект.ДатаПредоставления, "ДФ=dd.MM.yyyy")), ТекстСтроки); 
		СтруктураД.Вставить("PROPERTY_3533", PROPERTY_3533);
	КонецЕсли;
	
	Если ЕстьПрисоединенныеФайлы Тогда
		ОтборПоиска.Объект = "Ид папки с файлами";
		Строки = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска);
		Если Строки.Количество()> 0 Тогда
			Если Строки[0].Идентификатор = "" Тогда
				Сообщить("Не задан Ид папки с файлами");
				Возврат ПустаяСтрокаОтвета;
			Иначе
				МассивИДФайлов = АльтерраВзаимодействиеСБитрикс24.ЗагрузитьФайлыВБитрикс(Строки[0].Идентификатор, ПрисоединенныеФайлыСписок, АвторЗаписи, КодЭлементаПроцесса);
				СтруктураД.Вставить("PROPERTY_1127", МассивИДФайлов);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	
	СтруктураД.Вставить("CREATED_BY", АвторЗаписи);
	 
	Описание = ПолучитьОписаниеПретенизии(Основание);
	
	СтруктураД.Вставить("DETAIL_TEXT",Описание);
		
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовыйЭлементСписка("lists_socnet", "83", КодЭлементаПроцесса,СтруктураД);
	
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
	КонецЕсли;
	Если СтруктураОтвета.Свойство("Результат") или СтруктураОтвета.Свойство("result") Тогда
		Возврат СтруктураОтвета.result;
	Иначе
		Возврат ПустаяСтрокаОтвета;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура Спр_СоздатьБППосле(Команда)
	Если Объект.ЭтоПретензияПоставщику Тогда
		Сообщить("Для Претензии Поставщику пока не предусмотрено создание БП!");
		Возврат; 
	КонецЕсли;
	КодЭлементаСписка = Спр_СоздатьБППослеНаСервере();
	Если Не ПустаяСтрока(КодЭлементаСписка) Тогда
		Объект.ИДБизнесПроцесса = КодЭлементаСписка;
		Сообщить("БП создан!");
		ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма);
		
		ЭтаФорма.элементы.ФормаСоздатьБП.Доступность=Ложь;
	Иначе
		Сообщить("БП не создан!");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Спр_ОчиститьИДБППосле(Команда)
	Объект.ИДБизнесПроцесса = "";
КонецПроцедуры

&НаКлиенте
Процедура Док_ДобавитьНоменклатуруПосле(Команда)             
	Элементы.Товары1.ДобавитьСтроку();
КонецПроцедуры

&НаСервере
Процедура СформироватьАктНесоответствия()
	
	Если ЗначениеЗаполнено(Объект.ОснованиеЧекККМ) Тогда
		Основание =  Объект.ОснованиеЧекККМ;
	ИначеЕсли ЗначениеЗаполнено(Объект.Основание) Тогда
		Основание = Объект.Основание;
	Иначе
		Отказ = Истина;
	КонецЕсли; 
	
	Если Объект.ПричинаВозникновения = Справочники.ПричиныВозникновенияПретензий.НайтиПоНаименованию("Количество") Тогда
		
		ТабДок = Новый ТабличныйДокумент;
		ТабДок.АвтоМасштаб = Истина;
		Макет = ПолучитьМакетНаСервере("АктНесоответствияТовараПоКоличеству");
		
		ОбрезатьКод = СтрРазделить(Объект.Код, "-");
		НомерАкта = Формат(Число(ОбрезатьКод[1]), "ЧГ=");
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьЗаголовок.Параметры.НомерАкта = НомерАкта;
		ОбластьЗаголовок.Параметры.Дата = Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy");
		ТабДок.Вывести(ОбластьЗаголовок);
		
		ОбластьРеквизиты = Макет.ПолучитьОбласть("Реквизиты");
		ОбластьРеквизиты.Параметры.Поставщик = Основание.Организация;
		ОбластьРеквизиты.Параметры.Покупатель = Объект.Партнер.Наименование;
		ТабДок.Вывести(ОбластьРеквизиты);
		
		ОбластьОснование = Макет.ПолучитьОбласть("Основание");
		ОбластьОснование.Параметры.ДокОснование = Основание;
		ОбластьОснование.Параметры.ДокОснованиеСумма = Основание.СуммаДокумента;
		ТабДок.Вывести(ОбластьОснование);
		
		Если ЗаданиеНаПеревозкуРейс <> Неопределено Тогда
			ОбластьРейс = Макет.ПолучитьОбласть("Рейс");
			ОбластьРейс.Параметры.Рейс = ЗаданиеНаПеревозкуРейс;
			ТабДок.Вывести(ОбластьРейс);
		КонецЕсли;
		
		ОбластьШапкаТЧ = Макет.ПолучитьОбласть("ШапкаТЧ");
        ТабДок.Вывести(ОбластьШапкаТЧ);
		
		ОбластьТЧ = Макет.ПолучитьОбласть("ТЧ");
		Стр = 0;
		Для каждого Строка Из Объект.Товары Цикл
			Стр = Стр + 1; 
			ОбластьТЧ.Параметры.Стр = Стр;
			ОбластьТЧ.Параметры.Наименование = Строка.Номенклатура;
			ОбластьТЧ.Параметры.Код = Строка.Номенклатура.Код;
			ОбластьТЧ.Параметры.ЕдИзм = Строка.Номенклатура.ЕдиницаИзмерения;
			СтрокаВОсновании = Основание.Товары.Найти(Строка.Номенклатура);
			Если Строка.Количество > 0 Тогда
				ОбластьТЧ.Параметры.Отклонение = Строка("+" + Строка.Количество);
			Иначе
				ОбластьТЧ.Параметры.Отклонение = Строка.Количество;
			КонецЕсли;
						
			Если СтрокаВОсновании <> Неопределено Тогда
				ОбластьТЧ.Параметры.КоличествоДок = СтрокаВОсновании.Количество;
				ОбластьТЧ.Параметры.КоличествоФакт = Формат(СтрокаВОсновании.Количество + Строка.Количество, "ЧН=0");
			Иначе
				ОбластьТЧ.Параметры.КоличествоДок = "0";
				ОбластьТЧ.Параметры.КоличествоФакт = Формат(Строка.Количество, "ЧН=0");
			КонецЕсли; 
			 
			ТабДок.Вывести(ОбластьТЧ);
		КонецЦикла;
		
		//ОбластьКомментарий = Макет.ПолучитьОбласть("Комментарий");
		//ОбластьКомментарий.Параметры.Комментарий = Объект.Комментарий;
		//ТабДок.Вывести(ОбластьКомментарий);
		
		ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
        ТабДок.Вывести(ОбластьПодвал);
		
		ВременныйФайл = ПолучитьИмяВременногоФайла(".pdf");
		ТабДок.Записать(ВременныйФайл, ТипФайлаТабличногоДокумента.PDF);
		ДвоичныеДанные = Новый ДвоичныеДанные(ВременныйФайл);
		АдресВХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные);
		ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
		ПараметрыФайла.Автор = ПараметрыСеанса.ТекущийПользователь.Наименование;
		ПараметрыФайла.ВладелецФайлов = Объект.Ссылка;
		ИмяФайла = Строка("Акт о несоответствии №" + НомерАкта);
		ПараметрыФайла.ИмяБезРасширения = ИмяФайла;
		ПараметрыФайла.РасширениеБезТочки = "pdf";
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПретензииПрисоединенныеФайлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПретензииПрисоединенныеФайлы КАК ПретензииПрисоединенныеФайлы
		|ГДЕ
		|	ПретензииПрисоединенныеФайлы.Наименование = &Наименование
		|	И ПретензииПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла
		|   И Не ПретензииПрисоединенныеФайлы.Ссылка.ПометкаУдаления";
		
		Запрос.УстановитьПараметр("Наименование", ИмяФайла);
		Запрос.УстановитьПараметр("ВладелецФайла", Объект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СтарыйФайл = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			СтарыйФайл.УстановитьПометкуУдаления(Истина);
		КонецЦикла;
		
		РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресВХранилище);
		УдалитьФайлы(ВременныйФайл);
	
	КонецЕсли; 

КонецПроцедуры

