  <attributes>
    <name>СписокАдресов</name>
    <title>
      <key>ru</key>
      <value>Список адресов</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СправочникОбъектыДоставки.Ссылка КАК Ссылка,
	СправочникОбъектыДоставки.Адрес КАК Адрес,
	СправочникОбъектыДоставки.ТелефонНаВыгрузке КАК ТелефонНаВыгрузке
ИЗ
	Справочник.ОбъектыДоставки КАК СправочникОбъектыДоставки
ГДЕ
	НЕ СправочникОбъектыДоставки.ПометкаУдаления
	И СправочникОбъектыДоставки.Владелец = &amp;Владелец
	И НЕ СправочникОбъектыДоставки.Широта = 0
	И НЕ СправочникОбъектыДоставки.Долгота = 0</queryText>
      <mainTable>Catalog.ОбъектыДоставки</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
