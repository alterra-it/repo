#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СПТипов = АльтерраОбщегоНазначения.ПолучитьСписокЗначениеДопРеквизита("Тип покупателя");
	АльтерраОбщегоНазначения.ЗаполнитьСписокВыбора(СПТипов, Элементы.ТипПокупателя.СписокВыбора);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если Не Элементы.ГруппаСуббота.Видимость Тогда
		
		Если ЗначениеЗаполнено(Объект.ВремяРаботыСубботаС) Тогда
			Объект.ВремяРаботыСубботаС = Дата(1,1,1,0,0,0);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ВремяРаботыСубботаПО) Тогда
			Объект.ВремяРаботыСубботаПО = Дата(1,1,1,0,0,0);
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не Элементы.ГруппаВоскресенье.Видимость Тогда
		
		Если ЗначениеЗаполнено(Объект.ВремяРаботыВоскресеньеС) Тогда
			Объект.ВремяРаботыВоскресеньеС = Дата(1,1,1,0,0,0);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ВремяРаботыВоскресеньеПО) Тогда
			Объект.ВремяРаботыВоскресеньеПО = Дата(1,1,1,0,0,0);
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыбратьНаКарте(Команда)

	ПараметрыФормы= Новый Структура;
	ПараметрыФормы.Вставить("ОткрытИзДокумента", Истина);
	ПараметрыФормы.Вставить("Партнер", Объект.Владелец);
	ПараметрыФормы.Вставить("Филиал", ТекущееПодразделение());
	ПараметрыФормы.Вставить("ВидДоставки", ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная"));
	ПараметрыФормы.Вставить("Тариф", Тариф());
	ПараметрыФормы.Вставить("Адрес", Объект.АдресДоставкиКарта);		
	ПараметрыФормы.Вставить("НомерДома", Объект.НомерДома);
	ПараметрыФормы.Вставить("НомерКвартиры", Объект.НомерКвартиры);
	ПараметрыФормы.Вставить("ЭтоЧастныйДом", Объект.НомерКвартиры=0 И Объект.НомерОфиса=0);  
	ПараметрыФормы.Вставить("НомерКорпуса", Объект.НомерКорпуса);
	ПараметрыФормы.Вставить("НомерОфиса", Объект.НомерОфиса);
	ПараметрыФормы.Вставить("ДополнениеКАдресу", Объект.ДополнениеКАдресу);	
	ПараметрыФормы.Вставить("Широта", Объект.Широта);
	ПараметрыФормы.Вставить("Долгота", Объект.Долгота);
	ПараметрыФормы.Вставить("ТарифВРучную", Ложь);
	
	ПараметрыФормы.Вставить("ПараметрыРазгрузкиАдресВХранилище",ПолучитьПараметрыРазгрузки());
	
	ОписаниеОповещения= Новый ОписаниеОповещения("РассчитатьСтоимостьДоставкиЗавершение", ЭтаФорма);
	ОткрытьФорму("Обработка.КартографическийИнтерфейсДоставка.Форма.Карта", ПараметрыФормы, ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ВыходныеПриИзменении(Элемент)
	
	УстановитьОформление();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыходныеОчистка(Элемент, СтандартнаяОбработка)
	
	УстановитьОформление();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура РассчитатьСтоимостьДоставкиЗавершение(ДанныеКарты, ДопПараметры) Экспорт 
	
	Если ДанныеКарты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭтаФорма.Модифицированность= Истина;
		
	Объект.Широта= ДанныеКарты.Широта;
	Объект.Долгота= ДанныеКарты.Долгота;
	Объект.ЗонаДоставкиДляВодителя = Обработки.КартографическийИнтерфейсДоставка.ПолучитьЗонуДоставкиПоНаименованию(ДанныеКарты.Зона);
		
	Объект.АдресДоставкиКарта = ДанныеКарты.Адрес;
	Объект.Адрес= Объект.АдресДоставкиКарта;
	
	ЗаполнитьЗначенияСвойств(Объект,ДанныеКарты,"НомерДома,НомерКвартиры,НомерКорпуса,НомерОфиса,ДополнениеКАдресу");

	//адрес детально
	Если Прав(Объект.Адрес, СтрДлина(Объект.НомерДома)) = Объект.НомерДома Тогда
		Объект.Адрес = Лев(Объект.Адрес, СтрДлина(Объект.Адрес) - СтрДлина(Объект.НомерДома))	+ "дом " + Объект.НомерДома
	Иначе
		Объект.Адрес = Объект.Адрес + ", дом " + Объект.НомерДома;
	КонецЕсли;
		
	Если Объект.НомерКорпуса<>0 Тогда
		Объект.Адрес = Объект.Адрес + ", корп. " + Объект.НомерКорпуса;
	КонецЕсли;
	
	Если Объект.НомерКвартиры<>0 Тогда
		Объект.Адрес = Объект.Адрес + ", кв. " + Объект.НомерКвартиры;
	КонецЕсли;
	
	Если Объект.НомерОфиса<>0 Тогда
		Объект.Адрес = Объект.Адрес + ", оф. " + Объект.НомерОфиса;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Объект.ДополнениеКАдресу) Тогда
		Объект.Адрес = Объект.Адрес + ", " + Объект.ДополнениеКАдресу;
	КонецЕсли;
	

КонецПроцедуры

Функция ТекущееПодразделение()
	
	Возврат Пользователи.ТекущийПользователь().Подразделение;
	
КонецФункции

Функция Тариф()
	
	Возврат Справочники.ТарифыПеревозчиков.ПустаяСсылка();
	
КонецФункции

&НаКлиенте
Процедура УстановитьОформление()
	
	Если ЗначениеЗаполнено(Объект.Выходные) Тогда
		Элементы.ГруппаСуббота.Видимость = Не (Объект.Выходные = "суббота" ИЛИ Объект.Выходные = "суббота, воскресенье");
		Элементы.ГруппаВоскресенье.Видимость = Не (Объект.Выходные = "воскресенье" ИЛИ Объект.Выходные = "суббота, воскресенье");
	Иначе
		Элементы.ГруппаСуббота.Видимость = Истина;
		Элементы.ГруппаВоскресенье.Видимость = Истина;
	КонецЕсли;
	ВидимостьСписков();
	
КонецПроцедуры	

Функция ПолучитьПараметрыРазгрузки()
	
	ПараметрыРазгрузки = УправлениеЛогистикойСервер.ПолучитьСтруктуруПараметровРазгрузки();
		
	ПараметрыРазгрузкиАдресВХранилище = ПоместитьВоВременноеХранилище(ПараметрыРазгрузки,ЭтотОбъект.УникальныйИдентификатор);
		
	Возврат ПараметрыРазгрузкиАдресВХранилище;
	
КонецФункции

&НаКлиенте
Процедура СтендПриИзменении(Элемент)
	 ВидимостьСписков();
КонецПроцедуры

&НаКлиенте
Процедура ВидимостьСписков()

	Элементы.Стенды.Видимость=Объект.Стенд;
	Элементы.Субдилеры.Видимость=Объект.Субдилер;
	

КонецПроцедуры

&НаКлиенте
Процедура СубдиллерПриИзменении(Элемент)
	ВидимостьСписков();
КонецПроцедуры

#КонецОбласти