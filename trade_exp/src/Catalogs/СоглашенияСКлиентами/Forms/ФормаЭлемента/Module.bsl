Процедура Расш1__ЗаполнитьГруппуВместо(Команда)
	ЗаполнитьГруппуНаКлиенте();	
КонецПроцедуры
&НаКлиенте
Процедура ИерархияНоменклатурыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
ЗаполнитьГруппуНаКлиенте();	
	СтандартнаяОбработка=ложь;	
КонецПроцедуры
&НаКлиенте
Процедура ЗаполнитьГруппуНаКлиенте()
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("РезультатВопроса", ложь);
	если ЕстьЦеновыеГруппы(Элементы.ИерархияНоменклатуры.текущиеданные.Ссылка) тогда
		ТекстВопроса = НСтр("ru = 'В списке пристутсвуют заполняемые ценовые группы. Заменить существующие? '");
		ПоказатьВопрос(
		Новый ОписаниеОповещения("ЗаполнитьЦеновуюГруппуФрагментВопросЗавершение", ЭтотОбъект,ДополнительныеПараметры),
		ТекстВопроса,
		РежимДиалогаВопрос.ДаНет);
	иначе
		ЗаполнитьГруппуНаСервере(Элементы.ИерархияНоменклатуры.текущиеданные.Ссылка,истина);
	конецесли;
КонецПроцедуры	
&НаКлиенте
Процедура  ЗаполнитьЦеновуюГруппуФрагментВопросЗавершение(ОтветнаВопрос,ДополнительныеПараметры) экспорт
	результатВопроса=ложь;
	если  ОтветНаВопрос=КодВозвратаДиалога.Да тогда
		результатВопроса=истина;
	конецесли;	
	ЗаполнитьГруппуНаСервере(Элементы.ИерархияНоменклатуры.текущиеданные.Ссылка,результатВопроса);
КонецПроцедуры	
&НаСервере
Функция ЕстьЦеновыеГруппы(родитель)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.ЦеноваяГруппа КАК ЦеноваяГруппа
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В ИЕРАРХИИ(&Родитель)
	|	И НЕ Номенклатура.ЦеноваяГруппа.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Родитель", Родитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		найдена_строка=Объект.ЦеновыеГруппы.НайтиСтроки(Новый Структура("ЦеноваяГруппа",ВыборкаДетальныеЗаписи.ЦеноваяГруппа));
		если найдена_строка.количество()>0 тогда
			возврат истина;
		конецесли;	
	КонецЦикла;
	возврат ложь;
КонецФункции

&НаСервере
Процедура ЗаполнитьГруппуНаСервере(Родитель,результатВопроса)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Номенклатура.ЦеноваяГруппа КАК ЦеноваяГруппа
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В ИЕРАРХИИ(&Родитель)
	|	И НЕ Номенклатура.ЦеноваяГруппа.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Родитель", Родитель);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		найдена_строка=Объект.ЦеновыеГруппы.НайтиСтроки(Новый Структура("ЦеноваяГруппа",ВыборкаДетальныеЗаписи.ЦеноваяГруппа));
		если найдена_строка.количество()=0 тогда
			стр=Объект.ЦеновыеГруппы.Добавить();
			заполнитьзначениясвойств(стр,ВыборкаДетальныеЗаписи);
		иначе
			если результатВопроса тогда
				найдена_строка[0].Видцен="";
			конецесли;	
		конецесли;
	КонецЦикла;
КонецПроцедуры

