
&НаКлиенте
Процедура Док__ЗагрузитьИзФайла_АльтерраПосле(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗагрузкиИзФайла", ЭтотОбъект);
	ПараметрыФормы= Новый Структура();
	ПараметрыФормы.Вставить("НастройкиТаблицы",СтруктураТаблицы());
	ОткрытьФорму("Обработка.ЗагрузкаИзВнешнегоФайла_Альтерра.Форма.ФормаПроизвольная", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры
&НаКлиенте
Функция СтруктураТаблицы()
	
	СтруктураТаблицы=Новый Структура();
	СтруктураТаблицы.Вставить("Код","строка#Код#15#1#Справочники.Номенклатура.НайтиПоКоду(""&Ячейка&"")#Номенклатура");
	СтруктураТаблицы.Вставить("Номенклатура","СправочникСсылка.Номенклатура#Номенклатура#100#1#Справочники.Номенклатура.НайтиПоНаименованию(""&Ячейка&"")#Номенклатура");

	возврат  СтруктураТаблицы;
КонецФункции 

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Элементы.ОбластьДействия_ЗагрузитьИзФайла_Альтерра.Видимость=ВариантОбластиДействия = НСтр("ru='список товаров'");
КонецПроцедуры

&НаКлиенте
Процедура Док_ВариантОбластиДействияПриИзмененииПосле(Элемент)
	Элементы.ОбластьДействия_ЗагрузитьИзФайла_Альтерра.Видимость=ВариантОбластиДействия = НСтр("ru='список товаров'");
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗагрузкиИзФайла(Результат, ДополнительныеПараметры) Экспорт
	
	ПослеЗагрузкиИзФайлаСервер(Результат, ДополнительныеПараметры);

КонецПроцедуры

&НаСервере
Процедура ПослеЗагрузкиИзФайлаСервер(Результат, ДополнительныеПараметры)
	
	Если Не Результат = Неопределено Тогда
		ТаблицаДанных=ПолучитьИзВременногоХранилища(Результат);
		Если ТаблицаДанных<>Неопределено Тогда
			для каждого стр из ТаблицаДанных цикл
				СтрТаблицы=ОбластьДействия.Добавить();
				СтрТаблицы.ВидНоменклатуры=стр.Номенклатура.ВидНоменклатуры;
				СтрТаблицы.Номенклатура=стр.Номенклатура;
				если не стр.Номенклатура.ВестиУчетСертификатовНоменклатуры тогда
					попытка
						СпрОбъект=стр.Номенклатура.ПолучитьОбъект();
						СпрОбъект.ВестиУчетСертификатовНоменклатуры=истина;
						ОбновлениеИнформационнойБазы.ЗаписатьДанные(СпрОбъект);
					исключение
						ТекстОшибки = НСтр("ru='Не удалось записать %Элемент%. %ОписаниеОшибки%'");
						ТекстОшибки = СтрЗаменить(ТекстОшибки, "%Элемент%",        стр.Номенклатура);
						ТекстОшибки = СтрЗаменить(ТекстОшибки, "%ОписаниеОшибки%", КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
					конецпопытки;	
				конецесли;	
			конеццикла;	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Док_ПечатьCертификатаПосле(Команда)
	
	ДанныеФайла = РаботаСФайламиСлужебныйВызовСервера.ДанныеФайлаДляОткрытия(
		ПрисоединенныйФайл, Неопределено, УникальныйИдентификатор);
		
	РаботаСФайламиКлиент.ОткрытьФайл(ДанныеФайла, Ложь); 
	
КонецПроцедуры

