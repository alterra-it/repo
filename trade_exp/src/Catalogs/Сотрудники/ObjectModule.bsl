
&Вместо("ПриУстановкеНовогоКода")
Процедура ПриУстановкеНовогоКода(СтандартнаяОбработка, Префикс)
	Префикс="";
	ДополнитьСтрокуНулямиСлева(Код, 13);
КонецПроцедуры

Процедура ДополнитьСтрокуНулямиСлева(Строка, ДлинаСтроки)
	
	Строка = СтроковыеФункцииКлиентСервер.ДополнитьСтроку(Строка, ДлинаСтроки, "0", "Слева");
	
КонецПроцедуры

Процедура УстановитьФотографию(АдресФотографии) Экспорт
	Если ЗначениеЗаполнено(АдресФотографии) Тогда
		ДанныеФото= ПолучитьИзВременногоХранилища(АдресФотографии);
		Если ЗначениеЗаполнено(ДанныеФото) Тогда
			Фотография= Новый ХранилищеЗначения(ДанныеФото);
		КонецЕсли;
	Иначе
		Фотография= Неопределено;
	КонецЕсли;
	Записать();
КонецПроцедуры

Процедура УдалитьФотографию() Экспорт
	Фотография= Неопределено;
	Записать();
КонецПроцедуры

&После("ПриКопировании")
Процедура Док_ПриКопировании(ОбъектКопирования)
	
	Реквизиты = Метаданные.Справочники.Сотрудники.Реквизиты;
	Для Каждого Реквизит Из Реквизиты Цикл
		Если Реквизит.Имя = "Подразделение" Или Реквизит.Имя = "Организация" Или Реквизит.Имя = "Отдел"
			Или Реквизит.Имя = "Должность" Или Реквизит.Имя = "Склад" Или Реквизит.Имя = "СкладскаяДолжность" 
			Или Реквизит.Имя = "РольМобильногоКлиента" Тогда
			Продолжить
		КонецЕсли;
		ЭтотОбъект[Реквизит.Имя] = "";	
	КонецЦикла;	
	Если РабочиеУчастки.Количество() > 0  Тогда
    	РабочиеУчастки.Очистить();
	КонецЕсли;	
	Если БейджыВодителя.Количество() > 0  Тогда
    	БейджыВодителя.Очистить();
	КонецЕсли
	
КонецПроцедуры
