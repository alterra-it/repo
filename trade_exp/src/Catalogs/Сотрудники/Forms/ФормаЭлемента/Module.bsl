&НаКлиенте
Процедура ПоказатьДокументMSWord(ИмяМакета)
	Сотрудник = Объект.Ссылка;
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		ДанныеДляПечати = ПолучитьДанныеПоДокументуИДоговоруWord(Сотрудник);
		
		Макет = ПолучитьМакетСервер(ИмяМакета);
		
		ВремФайл = ПолучитьИмяВременногоФайла("doc");
		Ворд = УправлениеПечатьюMSWordКлиент.ПолучитьМакетMSWord(Макет, ВремФайл);
		ActiveDocument = Ворд.COMСоединение.ActiveDocument;
		
		Для Каждого стрДанные Из ДанныеДляПечати Цикл
			АльтерраОбщегоНазначенияКлиент.ЗаменитьВWord(ActiveDocument, стрДанные.Ключ, стрДанные.Значение);
		КонецЦикла;
		
		УправлениеПечатьюMSWordКлиент.ПоказатьДокументMSWord(Ворд);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьМакетСервер(ИмяМакета)
