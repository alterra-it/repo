	ПромежуточныйРезультат = РезультатыЗапросов[9].Выбрать();
	Если ПромежуточныйРезультат.Следующий() Тогда
		Данные.Вставить("ПочтовыйАдресОрганизации", ПромежуточныйРезультат.Представление);
	КонецЕсли;
	
	ПромежуточныйРезультат = РезультатыЗапросов[10].Выбрать();
	Если ПромежуточныйРезультат.Следующий() Тогда
		Данные.Вставить("ЮрАдресКонтрагента", ПромежуточныйРезультат.Представление);
	КонецЕсли;
	
	ПромежуточныйРезультат = РезультатыЗапросов[11].Выбрать();
	Если ПромежуточныйРезультат.Следующий() Тогда
		Данные.Вставить("АдресПоПропискеФизическиеЛицаПартнер", ПромежуточныйРезультат.Представление);
	КонецЕсли;
	
	ПромежуточныйРезультат = РезультатыЗапросов[12].Выбрать();
	Если ПромежуточныйРезультат.Следующий() Тогда
		РуководительОрганизации = ПромежуточныйРезультат.ФИО;
		Данные.Вставить("РуководительОрганизацииРод", СклонениеПредставленийОбъектов.ПросклонятьФИО(РуководительОрганизации, 2));
		Данные.Вставить("РуководительОрганизации", РуководительОрганизации);
		Данные.Вставить("РуководительОрганизацииИнициалы", ПромежуточныйРезультат.Наименование);
	КонецЕсли;
	
	ПромежуточныйРезультат = РезультатыЗапросов[13].Выбрать();
	Если ПромежуточныйРезультат.Следующий() Тогда
		Данные.Вставить("ИнициалыФизЛица", ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ПромежуточныйРезультат.ФизическоеЛицо));
		
		ФизическоеЛицоПредставление = ПромежуточныйРезультат.ФизическоеЛицоПредставление;
		Данные.Вставить("ФизическоеЛицоПредставление", ФизическоеЛицоПредставление);
		Данные.Вставить("ФизическоеЛицоПредставлениеРод", СклонениеПредставленийОбъектов.ПросклонятьФИО(ФизическоеЛицоПредставление, 3));
		
		Данные.Вставить("ДатаРожденияФизЛица", Формат(ПромежуточныйРезультат.ДатаРожденияФизЛица, "ДФ=dd.MM.yyyy"));
		Данные.Вставить("ФизЛицоСерия", ПромежуточныйРезультат.ФизЛицоСерия);
		Данные.Вставить("ФизЛицоНомер", ПромежуточныйРезультат.ФизЛицоНомер);
		Данные.Вставить("ФизЛицоДатаВыдачи", ПромежуточныйРезультат.ФизЛицоДатаВыдачи);
		Данные.Вставить("ФизЛицоКемВыдан", ПромежуточныйРезультат.ФизЛицоКемВыдан);
