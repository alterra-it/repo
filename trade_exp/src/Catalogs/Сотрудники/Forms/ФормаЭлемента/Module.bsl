&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если Не ПустаяСтрока(ПарольФорма) Тогда
		//md5
		
		//ХешированиеДанных = Новый ХешированиеДанных(ХешФункция.MD5);
		//ХешированиеДанных.Добавить(ПарольФорма);
		//ХешСумма = СтрЗаменить(Строка(ХешированиеДанных.ХешСумма), " ", "");
		
		//Base64
		ХешСумма= АльтерраОбщегоНазначения.КодироватьВBase64(ПарольФорма);
		
		ТекущийОбъект.Пароль= ХешСумма;
	КонецЕсли;
	
	Телефон = Объект.Телефон;
	ЕстьСотрудникСТакимНомером = ЕстьСотрудникСТакимНомеромТелефона(Телефон, Объект.Ссылка);
	Если ЕстьСотрудникСТакимНомером <> Неопределено Тогда
		Сообщить("Сотрудник с номером телефона " + Телефон + " уже есть в базе: " + ЕстьСотрудникСТакимНомером + ". ");
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры

Функция ЕстьСотрудникСТакимНомеромТелефона(НомерТелефона, Сотрудник) 
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Телефон КАК Телефон,
	|	Сотрудники.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Телефон = &НомерТелефона
	|	И Сотрудники.Ссылка <> &Сотрудник";
	Запрос.УстановитьПараметр("НомерТелефона", НомерТелефона);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если НЕ РезультатЗапроса.Пустой()Тогда
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		Если Выборка.Телефон <> "" Тогда
			СотрудникСТакимНомером = Выборка.Ссылка;	
			Возврат СотрудникСТакимНомером;
		КонецЕсли;	
	КонецЕсли;
	
КонецФункции

