//Фотографии
&НаКлиенте
Процедура ДобавитьФотографию(Команда)
	АдресХранилища= "";
	ВыбранноеИмяФайла="";
	Если ПоместитьФайл (АдресХранилища,,ВыбранноеИмяФайла,Истина) Тогда
		ДанныеФото= Новый ДвоичныеДанные(ВыбранноеИмяФайла);
		АдресФотографии= ПоместитьВоВременноеХранилище(ДанныеФото, УникальныйИдентификатор);
		
		Картинка=  АдресФотографии;
		
		УстановитьФотографиюСервер(АдресФотографии);
		ЭтаФорма.Прочитать();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьФотографию(Команда)
	Картинка=  Неопределено;
	
	УдалитьФотографиюСервер();
	ЭтаФорма.Прочитать();
КонецПроцедуры

