&НаКлиенте
Перем ЗакрытьБезВопроса;

&НаКлиенте
Перем МодифицированностьФормыДляЗакрытия;

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	МодифицированностьОбъекта = ЭтаФорма.Модифицированность ИЛИ ?(МодифицированностьФормыДляЗакрытия = Неопределено, Ложь, МодифицированностьФормыДляЗакрытия);
	Если МодифицированностьОбъекта и ЗакрытьБезВопроса = Неопределено И Не ЗначениеЗаполнено(Объект.Пользователь) Тогда
		Отказ = Истина;
		Оповещение = Новый ОписаниеОповещения("ПослеВопросаЗаполнитеСотруднка", ЭтаФорма, );
		Режим = РежимДиалогаВопрос.ДаНет;
		ПоказатьВопрос(Оповещение,
		"Некоторые процессы 1С (создание задач в Битрикс, ордеров...) используют привязку Сотрудник - Пользователь. В случае, если это поле не заполнено, 1С выдает различные ошибки",
		Режим,
		,
		,
		"Закрыть, не заполнив пользователя сотрудника?");
		МодифицированностьФормыДляЗакрытия = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаЗаполнитеСотруднка(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		ЭтаФорма.ТекущийЭлемент = Элементы.Пользователь;
	Иначе
		ЗакрытьБезВопроса = Истина;
        Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	МодифицированностьФормыДляЗакрытия = ЭтаФорма.Модифицированность;
	
	Если МодифицированностьФормыДляЗакрытия И Не ЗначениеЗаполнено(Объект.Пользователь) Тогда
		Сообщить("Заполните, пожалуйста, пользователя сотрудника, если это возможно!");
		ЭтаФорма.ТекущийЭлемент = Элементы.Пользователь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЭтаФорма.Элементы.Код.ТолькоПросмотр = Не РольДоступна("ПолныеПрава");
	
	//Фотография
	СсылкаНаДвоичныеДанныеФайла = ПоместитьВоВременноеХранилище(Объект.Ссылка.Фотография.Получить());
	Картинка=  СсылкаНаДвоичныеДанныеФайла;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	НадписьПароль = Объект.Пароль;
	
	Если РольДоступна("ПолныеПрава") Тогда
		Элементы.ИдентификаторМобильногоПриложения.Доступность = Истина;
	КонецЕсли;
	
	Если РольДоступна("АдминистрированиеПропускнойСистемы") ИЛИ РольДоступна("ПолныеПрава") Тогда
		Элементы.СКУД.Видимость = Истина;
		Элементы.ГруппаИндивидуально.Доступность = Объект.Индивидуально;
	КонецЕсли;
	
	Если НЕ(РольДоступна("ПечатьБейджика") ИЛИ РольДоступна("ПолныеПрава") ИЛИ РольДоступна("АдминистрированиеПропускнойСистемы")) Тогда
		Элементы.ПодменюПечатьОбычное_МакетШтрихкода.Видимость = Ложь;
	КонецЕсли;
	Элементы.Уволен.ТолькоПросмотр=значениезаполнено(Объект.ТабельныйНомер);
	Элементы.ДатаУвольнения.ТолькоПросмотр=значениезаполнено(Объект.ТабельныйНомер);
	Элементы.ДатаПриема.ТолькоПросмотр=значениезаполнено(Объект.ТабельныйНомер);
	
	Элементы.ГруппаУтверждениеБонусныхБаллов.Видимость = (Объект.ДопУтверждениеББ = Истина Или Объект.Должность.УтверждениеББ = Истина); 
    Элементы.ДопУтверждениеББ.ТолькоПросмотр = Не ДопМодуль.РольДоступнаОтделАналитики();
КонецПроцедуры

