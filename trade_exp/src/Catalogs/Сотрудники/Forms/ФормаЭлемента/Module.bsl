&НаКлиенте
Процедура ВодительПриИзменении(Элемент)
	ОтображениеБейджейВодителя(); 
КонецПроцедуры

&НаКлиенте                                                    
Процедура ОтображениеБейджейВодителя()
	Если Объект.Водитель Тогда 
		Элементы.КнопкиБейджей.ТолькоПросмотр = Ложь;
		Элементы.ГруппаБейджиВодителей.ТолькоПросмотр = Ложь;
	Иначе 
		Элементы.КнопкиБейджей.ТолькоПросмотр = Истина;
		Элементы.ГруппаБейджиВодителей.ТолькоПросмотр = Истина;
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура СформироватьШтрихкод(Команда) 
	Для каждого Строка из Объект.БейджыВодителя Цикл 
		Если Строка.Штрихкод = "" или Строка.Штрихкод = Неопределено Тогда 
			Строка.Штрихкод = ПолучитьШтрихкод(Строка.НомерСтроки); 
			Строка.Наименование = Объект.Наименование + " " + Строка.ТранспортноеСредство;
		КонецЕсли;  
	КонецЦикла;  
	
КонецПроцедуры  
	
	
&НаСервере 
Функция ПолучитьШтрихкод(НомерСтроки) 
	QRкод = "9999"; 
	ВременнаяСтрока = Прав(Объект.Код, 8); 
	Если НомерСтроки < 10 Тогда 
		QRкод = "9999" + ВременнаяСтрока + "0" + Строка(НомерСтроки); 
	Иначе 
	   QRкод = "9999" + ВременнаяСтрока + Строка(НомерСтроки);
   КонецЕсли; 
  	Возврат QRкод; 
КонецФункции 

&НаКлиенте
Процедура БейджыВодителяПередУдалением(Элемент, Отказ)
	Если не Элементы.БейджыВодителя.ТекущиеДанные.Штрихкод = "" Тогда
		Если Не ЭтоВсевышний() Тогда
			Сообщить("Запрещено удалять строки со сформированным штрихкодом"); 
			Отказ = Истина;  
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 

&НаСервере 
Функция ЭтоВсевышний()
	Возврат РольДоступна("ПолныеПрава"); 
КонецФункции




	