		ПартнерПредставление = ПромежуточныйРезультат.ПартнерПредставление;
		ПартнерПредставлениеБезИП = СокрЛП(СтрЗаменить(ПартнерПредставление, "ИП", ""));
		Данные.Вставить("ПартнерПредставлениеБезИП", ПартнерПредставлениеБезИП);
		Данные.Вставить("ИППлюсФИОПартнера", "ИП " + ПартнерПредставлениеБезИП);
		Данные.Вставить("ПартнерИППлюсИнициалы", "ИП " + ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ПартнерПредставлениеБезИП));
		
		Данные.Вставить("ПартнерПредставление", ПартнерПредставление);
		Данные.Вставить("Контрагент", ПромежуточныйРезультат.Контрагент);
		Данные.Вставить("ИННКонтрагенты", ПромежуточныйРезультат.ИННКонтрагенты);
		Данные.Вставить("Организация", ПромежуточныйРезультат.Организация);
				
		ПолноеНаименованиеОрганизации = ПромежуточныйРезультат.ПолноеНаименованиеОрганизации;
		Запрос.Текст = СтрЗаменить(ПолноеНаименованиеОрганизации, "ООО", "Общество с ограниченной ответственностью");
		Данные.Вставить("ПолноеНаименованиеОрганизации", ПолноеНаименованиеОрганизации);	
		
		Данные.Вставить("СокращенноеНаименованиеОрганизации", ПромежуточныйРезультат.СокращенноеНаименованиеОрганизации);
		
		Данные.Вставить("ИННОрганизации", ПромежуточныйРезультат.ИННОрганизации);
		Данные.Вставить("КППОрганизации", ПромежуточныйРезультат.КППОрганизации);
		Данные.Вставить("ОГРНОрганизации", ПромежуточныйРезультат.ОГРНОрганизации);
		
		Данные.Вставить("ФизЛицоПартнера", ПромежуточныйРезультат.ФизЛицоПартнера);
		Данные.Вставить("ФизЛицоПартнераПредставление", ПромежуточныйРезультат.ФизЛицоПартнераПредставление);
		Данные.Вставить("ФизЛицоПартнераДатаРождения", Формат(ПромежуточныйРезультат.ФизЛицоПартнераДатаРождения, "ДФ=dd.MM.yyyy"));
		Данные.Вставить("ФизЛицоПартнераСерия", ПромежуточныйРезультат.ФизЛицоПартнераСерия);
		Данные.Вставить("ФизЛицоПартнераНомер", ПромежуточныйРезультат.ФизЛицоПартнераНомер);
		Данные.Вставить("ФизЛицоПартнераДатаВыдачи", ПромежуточныйРезультат.ФизЛицоПартнераДатаВыдачи);
		Данные.Вставить("ФизЛицоПартнераКемВыдан", ПромежуточныйРезультат.ФизЛицоПартнераКемВыдан);
		Данные.Вставить("ФизЛицоПартнераКодПодразделения", ПромежуточныйРезультат.ФизЛицоПартнераКодПодразделения);
		
		Данные.Вставить("ОГРН", ПромежуточныйРезультат.ОГРН);
			
		Данные.Вставить("НаименованиеОсновногоБанковскогоСчета", 
			ПромежуточныйРезультат.НаименованиеОсновногоБанковскогоСчета + 
			" " +
			ВРег(ПромежуточныйРезультат.НаименованиеОсновногоБанковскогоСчетаГород));
			
		Данные.Вставить("РасчетныйСчет", ПромежуточныйРезультат.РасчетныйСчет);
		Данные.Вставить("КоррСчет", ПромежуточныйРезультат.КоррСчет);
		Данные.Вставить("БИК", ПромежуточныйРезультат.БИК);		
	КонецЕсли;

	Возврат Данные; 
КонецФункции      

