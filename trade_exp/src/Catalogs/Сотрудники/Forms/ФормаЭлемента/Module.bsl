		Запрос.Текст = СтрЗаменить(ЗапросТекст, "И ОтветственныеЛицаОрганизаций.Должность = &Должность", "");
	КонецЕсли;
	
	РезультатыЗапросов = Запрос.ВыполнитьПакет(); 
	
