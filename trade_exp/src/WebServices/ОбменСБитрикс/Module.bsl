Функция PutKlient(klient)
	УстановитьПривилегированныйРежим(Истина);
	НовыйПартнер= Ложь;
	
	ДанныеКлиентаJSON= СериализаторXDTO.ПрочитатьXDTO(klient);
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ДанныеКлиентаJSON);
	СоответствиеКлиента    =  ПрочитатьJSON(ЧтениеJSON, Истина);
	
	Если СоответствиеКлиента.Количество() = 0 Тогда
		Возврат "emptyklient";
	КонецЕсли;
	ДанныеПартнера= Новый Структура;
	
	Фамилия= СоответствиеКлиента["Фамилия"];
	Имя= СоответствиеКлиента["Имя"];
	Отчество= СоответствиеКлиента["Отчество"];
	
	ДанныеПартнера.Вставить("Наименование", СокрЛП(Фамилия+" "+Имя+" "+Отчество));
	ДанныеПартнера.Вставить("Телефон", СоответствиеКлиента["Телефон"]);
	ДанныеПартнера.Вставить("Почта", СоответствиеКлиента["E-mail"]);
	ДанныеПартнера.Вставить("СогласенПолучатьПочту",  Булево(Число(СоответствиеКлиента["soglasen"])));
	ДанныеПартнера.Вставить("ДатаРождения", Дата(СоответствиеКлиента["ДатаРождения"]));
	//ДанныеПартнера.Вставить("БизнесРегион= СоответствиеКлиента["Регион"];
	ДанныеПартнера.Вставить("БизнесРегион", "Сайт");
	ДанныеПартнера.Вставить("БонуснаяПрограммаАктивна", Истина);
	ДанныеПартнера.Вставить("Комментарий", "Создан автоматически с сайта");
	ДанныеПартнера.Вставить("Б_Идентификатор", СоответствиеКлиента["Б_Идентификатор"]);
	
	Если Не ЗначениеЗаполнено(ДанныеПартнера.Телефон) Тогда
		Возврат  "emptytel";
	КонецЕсли;
	
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(ДанныеПартнера.Телефон);
	
	Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоТелефону(ДанныеПартнера.Телефон);
	
	Если Не ЗначениеЗаполнено(Партнер) Тогда 
		Партнер= АльтерраОбщегоНазначения.СоздатьПартнера(ДанныеПартнера);
		НовыйПартнер= Истина;
	Иначе 
		Если АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Партнер) Или АльтерраОбщегоНазначения.ЭтоБригадир(Партнер) Тогда
			Успешно= АльтерраОбщегоНазначения.АктивироватьПартнера(Партнер);
			Если Не Успешно Тогда
				Возврат "notcreateklient";
			КонецЕсли;
		Иначе
			Возврат "notprivateclient";
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(Партнер) = Тип("Строка") Тогда
		Возврат Партнер;
	КонецЕсли;
	
	ТЗ= АльтерраОбщегоНазначения.ПолучитьДанныеПартнера(Партнер.Ссылка);
	ТЗ.Колонки.Добавить("Новый");
	Если ТЗ.Количество() > 0 Тогда
		ТЗ[0].Новый= НовыйПартнер;
		стрJSON= АльтерраОбщегоНазначения.СформироватьСтрокуJSON(ТЗ);
	Иначе
		Возврат "errorgetklient";
	КонецЕсли;
	
	Возврат  стрJSON;
КонецФункции

Функция PutAnketa(tel, anketa)
	УстановитьПривилегированныйРежим(Истина);
	
	Телефон= СериализаторXDTO.ПрочитатьXDTO(tel);
	Если ПустаяСтрока(Телефон) Тогда
		Возврат "emptytel";
	КонецЕсли;
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(Телефон);
	
	ДанныеАнкетыJSON= СериализаторXDTO.ПрочитатьXDTO(anketa);
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ДанныеАнкетыJSON);
	СоответствиеАнкеты    =  ПрочитатьJSON(ЧтениеJSON, Истина);
	
	Если СоответствиеАнкеты.Количество() = 0 Тогда
		Возврат "emptyanketa";
	КонецЕсли;
	
	Партнер= АльтерраОбщегоНазначения.ПолучитьПартнераПоТелефону(Телефон);
	
	Если Не ЗначениеЗаполнено(Партнер) Тогда 
		Возврат "klientnotfound";
	КонецЕсли;
	
	Если Не АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Партнер) И Не АльтерраОбщегоНазначения.ЭтоБригадир(Партнер) Тогда
		Возврат "notprivateclient";
	КонецЕсли;
	
	Если АльтерраОбщегоНазначения.ЕстьАнкета50Баллов(Партнер) Тогда
		Возврат "isanketa50ballov";
	КонецЕсли;
	
	//АНКЕТА
	ШаблонАнкеты= Справочники.ШаблоныАнкетАльтерра2.НайтиПоНаименованию("Анкета 50 бонусов", Истина);
	НаборЗаписей= РегистрыСведений.АнкетированиеОтветы.СоздатьНаборЗаписей();
	Для Каждого Вопрос Из  СоответствиеАнкеты Цикл 
		Если Вопрос.Значение = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Ключ= Вопрос.Ключ;
		мЗначений= Вопрос.Значение;
		спрВопрос= Справочники.ВопросыАнкетАльтерра.НайтиПоКоду(Вопрос.Ключ);
		
		НомерВарианта= 0;
		Для Каждого  Значение Из мЗначений Цикл
			Если Не ЗначениеЗаполнено(спрВопрос) ИЛИ Не ЗначениеЗаполнено(Значение) Тогда
				Продолжить;
			КонецЕсли;
			
			НаваяЗапись= НаборЗаписей.Добавить();
			НаваяЗапись.Активность= Истина;
			НаваяЗапись.Дата= ТекущаяДата();
			НаваяЗапись.ДатаЗаполнения= ТекущаяДата();
			НаваяЗапись.Респондент= Партнер;
			НаваяЗапись.ШаблонАнкеты= ШаблонАнкеты;
			НаваяЗапись.Вопрос= спрВопрос;
			НаваяЗапись.НомерВарианта= НомерВарианта;
			НаваяЗапись.Ответ= Значение;
			
			НомерВарианта= НомерВарианта+1;
		КонецЦикла;
	КонецЦикла;
	
	Если НаборЗаписей.Количество() > 0 Тогда
		Попытка
			//Регистр
			НаборЗаписей.Записать(Ложь);
			//Начислить 50 баллов
			ВидыПравилНачисленияБонусныхБаллов= Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление;
			БонусыАльтерра.НачислитьБаллыВручную(ВидыПравилНачисленияБонусныхБаллов, Партнер, 50, "Баллы начислены");
		Исключение
			Ошибка= "notcreateanketa";
			Сообщить(Ошибка);
			ЗаписьЖурналаРегистрации("Создание анкеты с сайта", УровеньЖурналаРегистрации.Ошибка, , , Ошибка);
			Возврат Ошибка;
		КонецПопытки;
	Иначе
		Возврат "notcreateanketa";
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат  "ok";
КонецФункции

