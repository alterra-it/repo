 #Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Функция ПолучитьДанныеПечати(знач МассивДокументов, знач МассивИменМакетов) Экспорт
	
	Возврат Новый Структура("Данные,Макеты",
				ПолучитьДанныеОбъектаПоМакетам(МассивДокументов, МассивИменМакетов),
				ПолучитьМакетыИОписанияСекций(МассивИменМакетов));
	
КонецФункции

Функция ПолучитьДанныеОбъектаПоМакетам(знач МассивДокументов, знач МассивИменМакетов) Экспорт
	
	ДанныеПоВсемОбъектам = Новый Соответствие;
	
	РезультатЗапроса = ПолучитьДанныеДляПечати(МассивДокументов);
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ДанныеОбъектаПоМакетам = Новый Структура;
		ДанныеОбъекта = ПолучитьДанныеОбъектаПоВыборке(Выборка);
		Для Каждого ИмяМакета Из МассивИменМакетов Цикл
			ДанныеОбъектаПоМакетам.Вставить(ИмяМакета, ДанныеОбъекта);
		КонецЦикла;
		ДанныеПоВсемОбъектам.Вставить(Выборка.Ссылка, ДанныеОбъектаПоМакетам);
	КонецЦикла;
	
	Возврат ДанныеПоВсемОбъектам;
	
КонецФункции

Функция ПолучитьДанныеДляПечати(МассивОбъектов)
	
	Запрос = Новый Запрос();
    	
	ВыбСвойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ОГРН");
	Запрос.УстановитьПараметр("КонтрагентОГРН",ВыбСвойство);
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	Договоры.Организация КАК Организация,
	               |	Договоры.БанковскийСчет КАК БанковскийСчет,
	               |	Договоры.Контрагент КАК Контрагент,
	               |	Договоры.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	               |	Договоры.Ссылка,
	               |	Договоры.ВидДоговора,
	               |	Договоры.ДатаОкончанияДействия,
	               |	Договоры.КоличествоДнейПросрочки,
	               |	Договоры.ДопустимаяСуммаЗадолженности,
	               |	Договоры.КонтактноеЛицо,
	               |	Договоры.ТипДоговора,
	               |	Договоры.Дата,
	               |	Договоры.НаименованиеДляПечати,
	               |	Договоры.Руководитель,
	               |	Договоры.Менеджер
	               |ПОМЕСТИТЬ Договоры
	               |ИЗ
	               |	Справочник.ДоговорыКонтрагентов КАК Договоры
	               |ГДЕ
	               |	Договоры.Ссылка В(&МассивОбъектов)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	               |	МАКСИМУМ(СчетаОрг.НомерСчета) КАК ОрганизацияНомерСчета,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА СчетаОрг.РучноеИзменениеРеквизитовБанка
	               |				ТОГДА СчетаОрг.БИКБанка
	               |			ИНАЧЕ БанкиОрг.Код
	               |		КОНЕЦ) КАК ОрганизацияБИК,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА СчетаОрг.РучноеИзменениеРеквизитовБанка
	               |				ТОГДА СчетаОрг.НаименованиеБанка + "" "" + СчетаОрг.ГородБанка
	               |			ИНАЧЕ БанкиОрг.Наименование + "" "" + БанкиОрг.Город
	               |		КОНЕЦ) КАК ОрганизацияБанк,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА СчетаОрг.РучноеИзменениеРеквизитовБанка
	               |				ТОГДА СчетаОрг.КоррСчетБанка
	               |			ИНАЧЕ БанкиОрг.КоррСчет
	               |		КОНЕЦ) КАК ОрганизацияКоррСчет,
	               |	Организации.НаименованиеСокращенное КАК ОрганизацияНаименование,
	               |	МАКСИМУМ(Организации.ОГРН) КАК ОрганизацияОГРН,
	               |	МАКСИМУМ(Организации.ИНН) КАК ОрганизацияИНН,
	               |	МАКСИМУМ(Организации.КПП) КАК ОрганизацияКПП,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации)
	               |				ТОГДА АдресаОрг.Представление
	               |		КОНЕЦ) КАК ОрганизацияЮрАдрес,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПочтовыйАдресОрганизации)
	               |				ТОГДА АдресаОрг.Представление
	               |		КОНЕЦ) КАК ОрганизацияПочтАдрес,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailОрганизации)
	               |				ТОГДА АдресаОрг.Представление
	               |		КОНЕЦ) КАК ОрганизацияЭП,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксОрганизации)
	               |				ТОГДА АдресаОрг.Представление
	               |		КОНЕЦ) КАК ОрганизацияФакс,
	               |	МАКСИМУМ(СчетаКонтр.НомерСчета) КАК КонтрагентНомерСчета,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА СчетаКонтр.РучноеИзменениеРеквизитовБанка
	               |				ТОГДА СчетаКонтр.БИКБанка
	               |			ИНАЧЕ БанкиКонтр.Код
	               |		КОНЕЦ) КАК КонтрагентБИК,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА СчетаКонтр.РучноеИзменениеРеквизитовБанка
	               |				ТОГДА СчетаКонтр.НаименованиеБанка + "" "" + СчетаКонтр.ГородБанка
	               |			ИНАЧЕ БанкиКонтр.Наименование + "" "" + БанкиКонтр.Город
	               |		КОНЕЦ) КАК КонтрагентБанк,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА СчетаКонтр.РучноеИзменениеРеквизитовБанка
	               |				ТОГДА СчетаКонтр.КоррСчетБанка
	               |			ИНАЧЕ БанкиКонтр.КоррСчет
	               |		КОНЕЦ) КАК КонтрагентКоррСчет,
	               |	Контрагенты.НаименованиеПолное КАК КонтрагентНаименование,
	               |	МАКСИМУМ(Контрагенты.ИНН) КАК КонтрагентИНН,
	               |	МАКСИМУМ(Контрагенты.КПП) КАК КонтрагентКПП,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаКонтр.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента)
	               |				ТОГДА АдресаКонтр.Представление
	               |		КОНЕЦ) КАК КонтрагентЮрАдрес,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаКонтр.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПочтовыйАдресКонтрагента)
	               |				ТОГДА АдресаКонтр.Представление
	               |		КОНЕЦ) КАК КонтрагентПочтАдрес,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаКонтр.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailКонтрагента)
	               |				ТОГДА АдресаКонтр.Представление
	               |		КОНЕЦ) КАК КонтрагентЭП,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаКонтр.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФаксКонтрагенты)
	               |				ТОГДА АдресаКонтр.Представление
	               |		КОНЕЦ) КАК КонтрагентФакс,
	               |	МАКСИМУМ(Договоры.Ссылка) КАК Ссылка,
	               |	МАКСИМУМ(Договоры.ВидДоговора) КАК ВидДоговора,
	               |	МАКСИМУМ(Контрагенты.ЮрФизЛицо) КАК ЮрФизЛицо,
	               |	МАКСИМУМ(Договоры.ДатаОкончанияДействия) КАК ДатаОкончанияДействия,
	               |	МАКСИМУМ(Договоры.КоличествоДнейПросрочки) КАК КоличествоДнейПросрочки,
	               |	МАКСИМУМ(Договоры.ДопустимаяСуммаЗадолженности) КАК ДопустимаяСуммаЗадолженности,
	               |	МАКСИМУМ(Договоры.КонтактноеЛицо.Наименование) КАК КонтактноеЛицоФИО,
	               |	МАКСИМУМ(Договоры.КонтактноеЛицо.ДолжностьПоВизитке) КАК КонтактноеЛицоДолжностьПоВизитке,
	               |	МАКСИМУМ(Договоры.КонтактноеЛицо.ДатаРождения) КАК КонтактноеЛицоДатаРождения,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА АдресаКонтЛица.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)
	               |				ТОГДА АдресаКонтЛица.Представление
	               |		КОНЕЦ) КАК КонтактноеЛицоРегистрация,
	               |	МАКСИМУМ(ДокументыКонтЛиц.Представление) КАК КонтактноеЛицоПаспорт,
	               |	МАКСИМУМ(КонтрагентыДопРекв.Значение) КАК КонтрагентОГРН,
	               |	МАКСИМУМ(Договоры.ТипДоговора) КАК ТипДоговора,
	               |	МАКСИМУМ(Договоры.Дата) КАК ДоговорДатаОт,
	               |	МАКСИМУМ(Договоры.НаименованиеДляПечати) КАК ДоговорНаимДляПечати,
	               |	МАКСИМУМ(ОтветственныеЛицаОрганизаций.ФизическоеЛицо) КАК РуководительФИО,
	               |	МАКСИМУМ(ОтветственныеЛицаОрганизаций.Должность) КАК РуководительДолжность,
	               |	МАКСИМУМ(Договоры.Менеджер) КАК Менеджер,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА ПользКонтИнф.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПользователя)
	               |				ТОГДА ПользКонтИнф.Представление
	               |		КОНЕЦ) КАК МенеджерТелефон
	               |ИЗ
	               |	Договоры КАК Договоры
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчетаОрганизаций КАК СчетаОрг
	               |		ПО Договоры.БанковскийСчет = СчетаОрг.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК БанкиОрг
	               |		ПО (СчетаОрг.Банк = БанкиОрг.Ссылка)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации КАК Организации
	               |		ПО Договоры.Организация = Организации.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК АдресаОрг
	               |		ПО Договоры.Организация = АдресаОрг.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.БанковскиеСчетаКонтрагентов КАК СчетаКонтр
	               |		ПО Договоры.БанковскийСчетКонтрагента = СчетаКонтр.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КлассификаторБанков КАК БанкиКонтр
	               |		ПО (СчетаКонтр.Банк = БанкиКонтр.Ссылка)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	               |		ПО Договоры.Контрагент = Контрагенты.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК АдресаКонтр
	               |		ПО Договоры.Контрагент = АдресаКонтр.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.КонтактнаяИнформация КАК АдресаКонтЛица
	               |		ПО Договоры.КонтактноеЛицо = АдресаКонтЛица.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыКонтЛиц
	               |		ПО Договоры.КонтактноеЛицо = ДокументыКонтЛиц.Физлицо
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДопРекв
	               |		ПО Договоры.Контрагент = КонтрагентыДопРекв.Ссылка
	               |			И (КонтрагентыДопРекв.Свойство = &КонтрагентОГРН)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОтветственныеЛицаОрганизаций КАК ОтветственныеЛицаОрганизаций
	               |		ПО Договоры.Руководитель = ОтветственныеЛицаОрганизаций.Ссылка
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК ПользКонтИнф
	               |		ПО Договоры.Менеджер = ПользКонтИнф.Ссылка
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Организации.НаименованиеСокращенное,
	               |	Контрагенты.НаименованиеПолное";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Функция ПолучитьДанныеОбъектаПоВыборке(Выборка)
	
	ДанныеОбъекта = Новый Структура;
	
	ВставитьДанныеОбъекта(ДанныеОбъекта,"Ссылка", Выборка.Ссылка);
	
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияНаименование",Выборка.ОрганизацияНаименование);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияЮрАдрес",Выборка.ОрганизацияЮрАдрес);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияПочтАдрес",Выборка.ОрганизацияПочтАдрес);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияЭП",Выборка.ОрганизацияЭП);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияФакс",Выборка.ОрганизацияФакс);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияИНН",Выборка.ОрганизацияИНН);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияКПП",Выборка.ОрганизацияКПП);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияБИК",Выборка.ОрганизацияБИК);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияНомерСчета",Выборка.ОрганизацияНомерСчета);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияБанк",Выборка.ОрганизацияБанк);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияКоррСчет",Выборка.ОрганизацияКоррСчет);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентНаименование",Выборка.КонтрагентНаименование);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентАдрес",Выборка.КонтрагентЮрАдрес);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентПочтАдрес",Выборка.КонтрагентПочтАдрес);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентЭП",Выборка.КонтрагентЭП);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентФакс",Выборка.КонтрагентФакс);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентИНН",Выборка.КонтрагентИНН);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентКПП",Выборка.КонтрагентКПП);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентБИК",Выборка.КонтрагентБИК);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентНомерСчета",Выборка.КонтрагентНомерСчета);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентБанк",Выборка.КонтрагентБанк);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентКоррСчет",Выборка.КонтрагентКоррСчет);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияОГРН",Выборка.ОрганизацияОГРН);
    ВставитьДанныеОбъекта(ДанныеОбъекта,"ВидДоговора",Выборка.ВидДоговора);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ЮрФизЛицо",Выборка.ЮрФизЛицо);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ДатаОкончанияДействия",Формат(Выборка.ДатаОкончанияДействия,"ДЛФ=D"));
	
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КоличествоДнейПросрочки",Выборка.КоличествоДнейПросрочки);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КоличествоДнейПросрочкиПрописью",
							НРег(ЧислоПрописью(Выборка.КоличествоДнейПросрочки,
							"Л = ru_RU; ДП = Ложь; НП = Ложь; НД = Ложь;", ",,,,,,,,0")));
	
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ДопустимаяСуммаЗадолженности",Выборка.ДопустимаяСуммаЗадолженности);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ДопустимаяСуммаЗадолженностиПрописью",
	                      	ЧислоПрописью(Выборка.ДопустимаяСуммаЗадолженности,
						  	"Л = ru_RU; ДП = Ложь; НП = Истина; НД = Истина;",
						  	"рубль, рубля, рублей, м, копейка, копейки, копеек, ж, 2"));
	
	Если Выборка.ВидДоговора = ПредопределенноеЗначение("Перечисление.ВидДоговора.ФедеральныйБюджет")
		Тогда ВставитьДанныеОбъекта(ДанныеОбъекта,"ВидБюджета","федерального");
	ИначеЕсли Выборка.ВидДоговора = ПредопределенноеЗначение("Перечисление.ВидДоговора.МестныйБюджет") 
		Тогда ВставитьДанныеОбъекта(ДанныеОбъекта,"ВидБюджета","местного"); 
	КонецЕсли;
	
	Если Выборка.ВидДоговора = ПредопределенноеЗначение("Перечисление.ВидДоговора.Транзитный")Тогда
		ВставитьДанныеОбъекта(ДанныеОбъекта,"СторонаДоговора","Поставщик");
		ВставитьДанныеОбъекта(ДанныеОбъекта,"НазваниеДоговора","Договор поставки");
	Иначе 
		ВставитьДанныеОбъекта(ДанныеОбъекта,"СторонаДоговора","Продавец");
		ВставитьДанныеОбъекта(ДанныеОбъекта,"НазваниеДоговора","Договор купли-продажи");
	КонецЕсли;
		
	//Область "Подвал"
	
 	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтактноеЛицоДолжностьПоВизитке",Выборка.КонтактноеЛицоДолжностьПоВизитке);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтактноеЛицоФИО",Выборка.КонтактноеЛицоФИО);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтактноеЛицоДатаРождения",Формат(Выборка.КонтактноеЛицоДатаРождения,"ДЛФ=D"));
    ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтактноеЛицоФИОСокр", ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(Выборка.КонтактноеЛицоФИО));
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтактноеЛицоРегистрация",Выборка.КонтактноеЛицоРегистрация);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтактноеЛицоПаспорт",Выборка.КонтактноеЛицоПаспорт);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентОГРН",Выборка.КонтрагентОГРН);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"РуководительДолжность",Выборка.РуководительДолжность);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"РуководительФИО",Выборка.РуководительФИО);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"РуководительФИОСокр", ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(Выборка.РуководительФИО));
	                                                                                              
	//Область "Лист согласования"
	
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ДоговорНаимДляПечати",Выборка.ДоговорНаимДляПечати);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ОрганизацияНаименование",Выборка.ОрганизацияНаименование);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентНаименование",Выборка.КонтрагентНаименование);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"ДоговорДатаОт",Формат(Выборка.ДоговорДатаОт,"ДЛФ=D"));
	ВставитьДанныеОбъекта(ДанныеОбъекта,"Менеджер",Выборка.Менеджер);
	ВставитьДанныеОбъекта(ДанныеОбъекта,"МенеджерТелефон",Выборка.МенеджерТелефон);

	
	Возврат ДанныеОбъекта;
	
КонецФункции

Функция ПолучитьМакетыИОписанияСекций(знач МассивИменМакетов) Экспорт
	
	ОписаниеСекций = Новый Структура;
	ДвоичныеДанныеМакетов = Новый Структура;
	
	Для Каждого ИмяМакета Из МассивИменМакетов Цикл
		
		Макет = Неопределено;
		ОписаниеСекцийМакета = Неопределено;
		
		ОписаниеСекцийМакета = ПолучитьОписаниеОбластейДоговора();
		Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.ПечатьДоговораВWord.ПФ_DOC_Договор");
				
		Если ОписаниеСекцийМакета <> Неопределено И Макет <> Неопределено Тогда
			
			ОписаниеСекций.Вставить(ИмяМакета, ОписаниеСекцийМакета);
			ДвоичныеДанныеМакетов.Вставить(ИмяМакета, Макет);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Новый Структура(
						"ОписаниеСекций,ДвоичныеДанныеМакетов",
						ОписаниеСекций,
						ДвоичныеДанныеМакетов
					);
	
КонецФункции
				
Функция ПолучитьОписаниеОбластейДоговора()

	Секции = Новый Структура;
	
	
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "ВерхнийКолонтитул",	"ВерхнийКолонтитул");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "Заголовок",    "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "Бюджет",    "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "Предоплата",    "Общая");
    УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "Отсрочка",    "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "Транзитный",    "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "ПодвалЮрЛицо",    "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "ПодвалИП",    "Общая");
	УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "ЛистСогласования",    "Общая");
    УправлениеПечатью.ДобавитьОписаниеОбласти(Секции, "НижнийКолонтитул",	"НижнийКолонтитул");
			
	Возврат Секции;

КонецФункции

Процедура ВставитьДанныеОбъекта(ДанныеОбъекта,ИмяПоля,ТекЗначение,ПустоеЗначение=" ")
	Если ЗначениеЗаполнено(ТекЗначение) Тогда
		НовоеЗначение=ТекЗначение;
	Иначе
		НовоеЗначение=ПустоеЗначение;
	КонецЕсли;
	
	ДанныеОбъекта.Вставить(ИмяПоля,НовоеЗначение);
КонецПроцедуры

 #КонецЕсли
