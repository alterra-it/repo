&НаСервере
Процедура ЗаписатьЗначениеВХМЛ(ХМЛ,ИмяЭлемента,Значение)
	ХМЛ.ЗаписатьНачалоЭлемента(ИмяЭлемента);
	ЗаписатьXML(ХМЛ,Значение);
	ХМЛ.ЗаписатьКонецЭлемента();
КонецПроцедуры

&НаСервере
Функция СчитатьЗначениеИзХМЛ(ХМЛ)
	ВозврЗнач=Неопределено;
	Попытка
		Если ХМЛ.Прочитать() Тогда
			ТипУзла=ХМЛ.ТипУзла;
			Если (ТипУзла=ТипУзлаXML.НачалоЭлемента) Тогда
				ВозврЗнач=ПрочитатьXML(ХМЛ);
			КонецЕсли;
		КонецЕсли;
	Исключение
		
	КонецПопытки;
	
	Возврат ВозврЗнач;
КонецФункции

&НаСервере
Процедура СохранитьНастройкиПечатиНаСервере()
	
	ГлобальныеНастройки=Новый Структура;
	ГлобальныеНастройки.Вставить("ГлобальныйТипМакета",ГлобальныйТипМакета);
	ГлобальныеНастройки.Вставить("ГлобальноеМестоХраненияШаблонов",ГлобальноеМестоХраненияШаблонов);
	ГлобальныеНастройки.Вставить("ГлобальныйДержательШаблонов",ГлобальныйДержательШаблонов);
	ХранилищеОбщихНастроек.Сохранить("ПечатьДоговораВOffice_ГлобальныеНастройки",,ГлобальныеНастройки);
	
	Попытка
		
		ЗаписьНастроек=Новый ЗаписьXML;
		ЗаписьНастроек.УстановитьСтроку();
		ЗаписьНастроек.ЗаписатьОбъявлениеXML();
		ЗаписьНастроек.ЗаписатьНачалоЭлемента(НаименованиеНастройки);
		
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"НомерДоговора",НомерДоговора);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"ДатаДоговора",ДатаДоговора);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"ДатаДействияДоговора",ДатаДействияДоговора);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"СрокДействияДоговора",СрокДействияДоговора);
		
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"ОрганизацияВЛице",ОрганизацияВЛице);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"ОрганизацияДействуетНаОсновании",ОрганизацияДействуетНаОсновании);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"ОрганизацияДолжностьПодписанта",ОрганизацияДолжностьПодписанта);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"ОрганизацияПодписант",ОрганизацияПодписант);
		
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"КонтрагентВЛице",КонтрагентВЛице);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"КонтрагентДействуетНаОсновании",КонтрагентДействуетНаОсновании);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"КонтрагентДолжностьПодписанта",КонтрагентДолжностьПодписанта);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"КонтрагентПодписант",КонтрагентПодписант);
		ЗаписатьЗначениеВХМЛ(ЗаписьНастроек,"НазваниеШаблона",НазваниеШаблона);
		
		
		ЗаписьНастроек.ЗаписатьКонецЭлемента();
		
		СтрокаНастроек=ЗаписьНастроек.Закрыть();
		
		Если НЕ ЗначениеЗаполнено(ФайлНастроек) Тогда
			// ссылка не заполнена - создаём новый элемент
			Настройки=Справочники.ДоговорыКонтрагентовПрисоединенныеФайлы.СоздатьЭлемент();
			Настройки.Автор=Пользователи.ТекущийПользователь();
			Настройки.ВладелецФайла=Договор;
			Настройки.ДатаСоздания=ТекущаяДата();
			Настройки.Наименование=НаименованиеНастройки;
			Настройки.Расширение=РасширениеНастройки;
			Настройки.ТипХраненияФайла=Перечисления.ТипыХраненияФайлов.ВИнформационнойБазе;
			Настройки.Том=Справочники.ТомаХраненияФайлов.ПустаяСсылка();
			Настройки.ПутьКФайлу="";
			
		Иначе
			// получаем существующий элемент файла настроек
			Настройки=ФайлНастроек.ПолучитьОбъект();
		КонецЕсли;
		
		Настройки.Описание="служебные данные (не изменять!)";
		
		Настройки.ТекстХранилище=Новый ХранилищеЗначения(СтрокаНастроек,Новый СжатиеДанных(6));
		Настройки.Размер=СтрДлина(СтрокаНастроек);
		Настройки.ДатаМодификацииУниверсальная=ТекущаяДата();
		Настройки.Изменил=Пользователи.ТекущийПользователь();
		
		Настройки.Записать();
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройкиОрганизацийНаСервере()
	
	ГлобальныеНастройкиОрганизаций=Новый Соответствие;
	
	// заменяем настройку по текущей организации
	НовоеЗначение=Новый Структура;
	НовоеЗначение.Вставить("ОрганизацияВЛице",ОрганизацияВЛице);
	НовоеЗначение.Вставить("ОрганизацияДействуетНаОсновании",ОрганизацияДействуетНаОсновании);
	НовоеЗначение.Вставить("ОрганизацияДолжностьПодписанта",ОрганизацияДолжностьПодписанта);
	НовоеЗначение.Вставить("ОрганизацияПодписант",ОрганизацияПодписант);
	НовоеЗначение.Вставить("НазваниеШаблона",НазваниеШаблона);
	
	Если ТипЗнч(НастройкиОрганизаций)=Тип("ФиксированноеСоответствие") Тогда
		Для каждого НастройкаОрг Из НастройкиОрганизаций Цикл
			Если (НастройкаОрг.Ключ=Организация) Тогда
				// заменяем настройку по текущей организации
				ГлобальныеНастройкиОрганизаций.Вставить(НастройкаОрг.Ключ,НовоеЗначение);
			Иначе
				// просто переносим сохранённую настройку
				ГлобальныеНастройкиОрганизаций.Вставить(Организация,НовоеЗначение);
			КонецЕсли;
		КонецЦикла;
	Иначе
		// сохранённых настроек нет, создаём новую
		ГлобальныеНастройкиОрганизаций.Вставить(Организация,НовоеЗначение);
	КонецЕсли;
	
	ХранилищеОбщихНастроек.Сохранить("ПечатьДоговораВOffice_ГлобальныеНастройкиОрганизаций",,ГлобальныеНастройкиОрганизаций);
КонецПроцедуры

&НаСервере
Процедура СчитатьНастройкиПечатиНаСервере()
	Если НЕ ЗначениеЗаполнено(ФайлНастроек) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		
		Настройки=ФайлНастроек.ПолучитьОбъект();
		СтрокаНастроек=Настройки.ТекстХранилище.Получить();
		
		Если ТипЗнч(СтрокаНастроек)=Тип("Строка") Тогда
			ЧтениеНастроек=Новый ЧтениеXML;
			ЧтениеНастроек.УстановитьСтроку(СтрокаНастроек);
			
			ВошлиВНастройки=Ложь;
			Пока ЧтениеНастроек.Прочитать() Цикл
				ТипУзла=ЧтениеНастроек.ТипУзла;
				Если (ТипУзла=ТипУзлаXML.НачалоЭлемента) Тогда
					Если ВошлиВНастройки Тогда
						ИмяПоля=ЧтениеНастроек.Имя;
						ЭтаФорма[ИмяПоля]=СчитатьЗначениеИзХМЛ(ЧтениеНастроек);
					Иначе
						Если (ЧтениеНастроек.Имя=НаименованиеНастройки) Тогда
							ВошлиВНастройки=Истина;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
			ЧтениеНастроек.Закрыть();
		КонецЕсли;
		
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки
	
КонецПроцедуры

&НаКлиенте
Процедура Сохранить(Команда)
	СохранитьНастройкиПечатиНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПечатьИзФормы(Команда)
	ПараметрКоманды=Новый Массив;
	ПараметрКоманды.Добавить(Договор);
	Печать("ПечатьДоговораИзФормы",ПараметрКоманды);
КонецПроцедуры

&НаСервере
Процедура ОбновитьПолеИзВыборки(ИмяПоля,Выборка)
	Если НЕ ЗначениеЗаполнено(ЭтаФорма[ИмяПоля]) И ЗначениеЗаполнено(Выборка[ИмяПоля]) Тогда
		ЭтаФорма[ИмяПоля]=Выборка[ИмяПоля];
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ОбновитьПолеИзЗначения(ИмяПоля,НовоеЗначение)
	Если НЕ ЗначениеЗаполнено(ЭтаФорма[ИмяПоля]) И ЗначениеЗаполнено(НовоеЗначение) Тогда
		ЭтаФорма[ИмяПоля]=НовоеЗначение;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ПроверитьГлобальныеНастройки()	
	Если (НЕ ЗначениеЗаполнено(ГлобальныйТипМакета)) ИЛИ ((ГлобальныйТипМакета<>"DOC") И (ГлобальныйТипМакета<>"ODT")) Тогда
		ГлобальныйТипМакета="DOC";
	КонецЕсли;
	Если (НЕ ЗначениеЗаполнено(ГлобальноеМестоХраненияШаблонов)) ИЛИ ((ГлобальноеМестоХраненияШаблонов<>"МакетыОбработки") И (ГлобальноеМестоХраненияШаблонов<>"СправочникФизЛица")) Тогда
		ГлобальноеМестоХраненияШаблонов="МакетыОбработки";
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеФормы()
	
	ГлобальныеНастройки=ХранилищеОбщихНастроек.Загрузить("ПечатьДоговораВOffice_ГлобальныеНастройки");
	Если ТипЗнч(ГлобальныеНастройки)=Тип("Структура") Тогда
		ГлобальныйТипМакета=ГлобальныеНастройки.ГлобальныйТипМакета;
		ГлобальноеМестоХраненияШаблонов=ГлобальныеНастройки.ГлобальноеМестоХраненияШаблонов;
		ГлобальныйДержательШаблонов=ГлобальныеНастройки.ГлобальныйДержательШаблонов;
	КонецЕсли;
	
	ГлобальныеНастройкиОрганизаций=ХранилищеОбщихНастроек.Загрузить("ПечатьДоговораВOffice_ГлобальныеНастройкиОрганизаций");
	Если ТипЗнч(ГлобальныеНастройкиОрганизаций)=Тип("Соответствие") Тогда
		НастройкиОрганизаций=Новый ФиксированноеСоответствие(ГлобальныеНастройкиОрганизаций);
	КонецЕсли;
	
	ПроверитьГлобальныеНастройки();
	ЭтаФорма.Элементы.ГлобальныйДержательШаблонов.Доступность=(ГлобальноеМестоХраненияШаблонов="СправочникФизЛица");
	
	// поиск существующих настроек печати договора
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|select allowed top 1
	| ФайлыНастроек.Ссылка
	|from
	| Справочник.ДоговорыКонтрагентовПрисоединенныеФайлы as ФайлыНастроек
	|where (ФайлыНастроек.ВладелецФайла=&ТекДоговор) and НЕ(ФайлыНастроек.ПометкаУдаления) and (ФайлыНастроек.Наименование=&НаименованиеНастройки) and (ФайлыНастроек.Расширение=&РасширениеНастройки)
	
	|";
	
	Запрос.УстановитьПараметр("ТекДоговор",Договор);
	Запрос.УстановитьПараметр("НаименованиеНастройки",НаименованиеНастройки);
	Запрос.УстановитьПараметр("РасширениеНастройки",РасширениеНастройки);
	РезЗапроса=Запрос.Выполнить();
	
	Если НЕ РезЗапроса.Пустой() Тогда
		// найден
		Выборка=РезЗапроса.Выбрать();
		Выборка.Следующий();
		ФайлНастроек=Выборка.Ссылка;
		СчитатьНастройкиПечатиНаСервере();
	КонецЕсли;
	
	// заполнение пустых полей данными из договора
	
	Запрос=Новый Запрос;
	Запрос.Текст="
	|select allowed top 1
	| Договоры.Номер as НомерДоговора
	|,Договоры.Дата as ДатаДоговора
	|,Договоры.ДатаНачалаДействия as ДатаДействияДоговора
	|,Договоры.ДатаОкончанияДействия as СрокДействияДоговора
	|,Договоры.ТипДоговора as ТипДоговора
	|,Договоры.Организация as Организация
	|//,Договоры.Организация.ТекущаяДолжностьРуководителя as ОрганизацияДолжностьРуководителя
	|//,Договоры.Организация.ТекущийРуководитель.Наименование as ОрганизацияРуководитель
	|,Договоры.Контрагент as Контрагент
	|from
	| Справочник.ДоговорыКонтрагентов as Договоры
	|where (Договоры.Ссылка=&ТекДоговор)
	
	|";
	
	Запрос.УстановитьПараметр("ТекДоговор",Договор);
	РезЗапроса=Запрос.Выполнить();
	
	Если НЕ РезЗапроса.Пустой() Тогда
		// найден
		Выборка=РезЗапроса.Выбрать();
		Выборка.Следующий();
		
		ТипДоговора=Выборка.ТипДоговора;
		Организация=Выборка.Организация;
		Контрагент=Выборка.Контрагент;
		
		Если ТипЗнч(НастройкиОрганизаций)=Тип("ФиксированноеСоответствие") Тогда
			НастрТекОрг=НастройкиОрганизаций.Получить(Организация);
			Если ТипЗнч(НастрТекОрг)=Тип("Структура") Тогда
				ОрганизацияВЛице=НастрТекОрг.ОрганизацияВЛице;
				ОрганизацияДействуетНаОсновании=НастрТекОрг.ОрганизацияДействуетНаОсновании;
				ОрганизацияДолжностьПодписанта=НастрТекОрг.ОрганизацияДолжностьПодписанта;
				ОрганизацияПодписант=НастрТекОрг.ОрганизацияПодписант;
				НазваниеШаблона = НастрТекОрг.НазваниеШаблона;
			КонецЕсли;
		КонецЕсли;
		
		ОбновитьПолеИзВыборки("НомерДоговора",Выборка);
		ОбновитьПолеИзВыборки("ДатаДоговора",Выборка);
		ОбновитьПолеИзВыборки("ДатаДействияДоговора",Выборка);
		ОбновитьПолеИзВыборки("СрокДействияДоговора",Выборка);
		ОбновитьПолеИзЗначения("ОрганизацияДействуетНаОсновании","Устава");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НаименованиеНастройки="НастройкиПечатиДоговораВOffice";
	РасширениеНастройки="xml";
	Договор=Параметры["ОбъектыНазначения"];
	
	ЗагрузитьДанныеФормы();
КонецПроцедуры

&НаКлиенте
Процедура ГлобальноеМестоХраненияШаблоновПриИзменении(Элемент)
	ЭтаФорма.Элементы.ГлобальныйДержательШаблонов.Доступность=(ГлобальноеМестоХраненияШаблонов="СправочникФизЛица");
КонецПроцедуры

&НаКлиенте
Процедура СохранитьГлобальныеНастройкиОрганизации(Команда)
	СохранитьНастройкиОрганизацийНаСервере();
КонецПроцедуры

