		ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентАдрес",Выборка.КонтрагентЮрАдрес, Лев(ПустаяСтрока,30));
		ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентПочтАдрес",Выборка.КонтрагентПочтАдрес, Лев(ПустаяСтрока,30));
		ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентЭП",Выборка.КонтрагентЭП, Лев(ПустаяСтрока,5));
		ВставитьДанныеОбъекта(ДанныеОбъекта,"КонтрагентФакс",Выборка.КонтрагентФакс, Лев(ПустаяСтрока,30));
