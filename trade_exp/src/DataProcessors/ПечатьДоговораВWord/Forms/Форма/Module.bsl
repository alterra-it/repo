
&НаСервере
Функция ПолучитьВерсиюБСП()
	Возврат СтандартныеПодсистемыСервер.ВерсияБиблиотеки();
КонецФункции

&НаКлиенте
Функция РазложитьСтрокуНаМассивПодстрок(Знач Строка, Разделитель = ";", ПропускатьПустыеСтроки = Истина)
	
	Результат = Новый Массив;
	
	Позиция = Найти(Строка, Разделитель);
	Пока Позиция > 0 Цикл
		Подстрока = Лев(Строка, Позиция - 1);
		Если Не ПустаяСтрока(Подстрока) или не ПропускатьПустыеСтроки Тогда
			Результат.Добавить(Подстрока);
		КонецЕсли;
		Строка = Сред(Строка, Позиция + СтрДлина(Разделитель));
		Позиция = Найти(Строка, Разделитель);
	КонецЦикла;
	
	Результат.Добавить(Строка);
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура Печать(ИдентификаторКоманды,ПараметрКоманды) Экспорт
	
	Состояние(НСтр("ru = 'Выполняется формирование печатных форм'"));
	
	ПроверитьГлобальныеНастройки();
	
	Попытка
		
		ИменаМакетов=Новый Массив;
		ИменаМакетов.Добавить("ПокупательБюджетныйDOC");
		
		МакетыИОбласти=ПолучитьМакетыИОбласти(ИменаМакетов);
		ДвоичныеДанныеМакетов=МакетыИОбласти.ДвоичныеДанныеМакетов;
		ОписанияОбластей=МакетыИОбласти.ОписанияОбластей;
		
		Для каждого ОбъектСсылка Из ПараметрКоманды Цикл
			Если (ИдентификаторКоманды="ПечатьДоговораИзФормы") Тогда
				// ничего не делаем - данные формы уже загружены
			Иначе
				Если (Договор=ОбъектСсылка) Тогда
					// ничего не делаем - данные формы уже загружены
				Иначе
					Договор=ОбъектСсылка;
					ЗагрузитьДанныеФормы();
				КонецЕсли;
			КонецЕсли;
			
			Если ТипДоговора=ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПокупателем") Тогда
				ИмяМакета="Покупатель";
			ИначеЕсли ТипДоговора=ПредопределенноеЗначение("Перечисление.ТипыДоговоров.СПоставщиком") Тогда
				ИмяМакета="Поставщик";
			Иначе
				Предупреждение(""+Организация+"\"+Контрагент+"\"+Договор+": "+"Печать договоров с типом '"+ТипДоговора+"' не поддерживается!",10);
				Продолжить;
			КонецЕсли;
			
			ТипМакета=ГлобальныйТипМакета;
			ИмяМакета=ИмяМакета+Строка(НазваниеШаблона)+ТипМакета;
			
			ДвоичныеДанныеМакета=ДвоичныеДанныеМакетов[ИмяМакета];
			Если (ДвоичныеДанныеМакета=Неопределено) Тогда
				Предупреждение(""+Организация+"\"+Контрагент+"\"+Договор+": "+"Шаблон '"+ИмяМакета+"' не найден!",10);
				Продолжить;
			КонецЕсли;
			
			ДанныеОбъекта=ПолучитьДанныеОбъекта(Договор, ИмяМакета);
			ВерсияБСП=ПолучитьВерсиюБСП();
			МасСтр=РазложитьСтрокуНаМассивПодстрок(ВерсияБСП,".");
			ВерсияБСП_старш=0;
			ВерсияБСП_младш=0;
			Если МасСтр.Количество()>=2 Тогда
				Попытка
					ВерсияБСП_старш=Число(МасСтр[0]);
					ВерсияБСП_младш=Число(МасСтр[1]);
				Исключение
				КонецПопытки;
			КонецЕсли;
			
			Макет=УправлениеПечатьюКлиент.ИнициализироватьМакет(ДвоичныеДанныеМакета,ТипМакета);
			НастройкиСтраницыМакета=Макет.НастройкиСтраницыМакета;
			Если (ВерсияБСП_старш>=2) Тогда
				ПечатнаяФорма=УправлениеПечатьюКлиент.ИнициализироватьПечатнуюФорму(ТипМакета,НастройкиСтраницыМакета,Макет);
			Иначе
				ПечатнаяФорма=УправлениеПечатьюКлиент.ИнициализироватьПечатнуюФорму(ТипМакета,НастройкиСтраницыМакета);
			КонецЕсли;
			
			Если (ПечатнаяФорма<>Неопределено) И (Макет<>Неопределено) Тогда
				Область=УправлениеПечатьюКлиент.ПолучитьОбласть(Макет,ОписанияОбластей[ИмяМакета]["ВерхнийКолонтитул"]);
				УправлениеПечатьюКлиент.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма,Область,ДанныеОбъекта);
				
				Область=УправлениеПечатьюКлиент.ПолучитьОбласть(Макет,ОписанияОбластей[ИмяМакета].Договор);
				УправлениеПечатьюКлиент.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма,Область,ДанныеОбъекта);
				Если (ВерсияБСП_старш<2) Тогда
					УправлениеПечатьюКлиент.ЗаполнитьПараметры(ПечатнаяФорма,ДанныеОбъекта);
				КонецЕсли;
				
				Область=УправлениеПечатьюКлиент.ПолучитьОбласть(Макет,ОписанияОбластей[ИмяМакета]["НижнийКолонтитул"]);
				УправлениеПечатьюКлиент.ПрисоединитьОбластьИЗаполнитьПараметры(ПечатнаяФорма,Область,ДанныеОбъекта);
				
				УправлениеПечатьюКлиент.ПоказатьДокумент(ПечатнаяФорма);
			КонецЕсли;
			
			УправлениеПечатьюКлиент.ОчиститьСсылки(ПечатнаяФорма, Ложь);
			УправлениеПечатьюКлиент.ОчиститьСсылки(Макет);
		КонецЦикла;
		
		Состояние(НСтр("ru = 'Формирование печатных форм завершено'"));
		
	Исключение
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		УправлениеПечатьюКлиент.ОчиститьСсылки(ПечатнаяФорма);
		УправлениеПечатьюКлиент.ОчиститьСсылки(Макет);
		
		Возврат;
		
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьДвоичныеДанныеМакетов(ИменаМакетов)
	
	ДвоичныеДанныеМакетов=Новый Соответствие;
	
	Если (ГлобальноеМестоХраненияШаблонов="МакетыОбработки") Тогда
		ОбработкаОбъект=РеквизитФормыВЗначение("Объект");
		
		Для каждого ИмяМакета Из ИменаМакетов Цикл
			Попытка
				Макет=ОбработкаОбъект.ПолучитьМакет(ИмяМакета);
				ДвоичныеДанныеМакетов.Вставить(ИмяМакета,Макет);
			Исключение
				// нет такого макета
			КонецПопытки;
		КонецЦикла; 
	ИначеЕсли (ГлобальноеМестоХраненияШаблонов="СправочникФизЛица") Тогда
		
		Если ЗначениеЗаполнено(ГлобальныйДержательШаблонов) Тогда
			// поиск шаблонов в справочнике ФизическиеЛицаПрисоединенныеФайлы
			
			Запрос=Новый Запрос;
			Запрос.Текст="
			|select allowed
			| ФайлыШаблонов.Ссылка as Ссылка
			|,ФайлыШаблонов.Наименование as ИмяШаблона
			|,ФайлыШаблонов.Расширение as РасширениеШаблона
			|from
			| Справочник.ФизическиеЛицаПрисоединенныеФайлы as ФайлыШаблонов
			|where (ФайлыШаблонов.ВладелецФайла=&ТекДержатель) and НЕ(ФайлыШаблонов.ПометкаУдаления) and (ФайлыШаблонов.Наименование in (&ИменаШаблонов)) and (ФайлыШаблонов.Расширение in (&РасширенияШаблонов))
			
			|";
			
			РасширенияШаблонов=Новый Массив;
			РасширенияШаблонов.Добавить("DOC");
			РасширенияШаблонов.Добавить("ODT");
			
			Запрос.УстановитьПараметр("ТекДержатель",ГлобальныйДержательШаблонов);
			Запрос.УстановитьПараметр("ИменаШаблонов",ИменаМакетов);
			Запрос.УстановитьПараметр("РасширенияШаблонов",РасширенияШаблонов);
			РезЗапроса=Запрос.Выполнить();
			
			Если НЕ РезЗапроса.Пустой() Тогда
				// найден
				Выборка=РезЗапроса.Выбрать();
				Пока Выборка.Следующий() Цикл
					Для каждого ИмяМакета Из ИменаМакетов Цикл
						Если (ВРЕГ(Выборка.ИмяШаблона)=ВРЕГ(ИмяМакета)) И (ВРЕГ(Выборка.РасширениеШаблона)=ВРЕГ(Прав(ИмяМакета,3))) Тогда
							
							Макет=Неопределено;
							ШаблонСсылка=Выборка.Ссылка;
							
							ПараметрыДанныхФайла = РаботаСФайламиКлиентСервер.ПараметрыДанныхФайла();
							ПараметрыДанныхФайла.ИдентификаторФормы = УникальныйИдентификатор;
							ДанныеФайла = РаботаСФайлами.ДанныеФайла(ШаблонСсылка, ПараметрыДанныхФайла);
							
							СсылкаНаДвоичныеДанныеФайла=ДанныеФайла.СсылкаНаДвоичныеДанныеФайла;
							Если ЭтоАдресВременногоХранилища(СсылкаНаДвоичныеДанныеФайла) Тогда
								Макет=ПолучитьИзВременногоХранилища(СсылкаНаДвоичныеДанныеФайла);
								УдалитьИзВременногоХранилища(СсылкаНаДвоичныеДанныеФайла);
							КонецЕсли;
							
							ДвоичныеДанныеМакетов.Вставить(ИмяМакета,Макет);
							
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
				
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ДвоичныеДанныеМакетов;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьОписанияОбластейМакетов(ИменаМакетов)
	
	ОписанияОбластей=Новый Структура;
	
	Для каждого ИмяМакета Из ИменаМакетов Цикл
		
		НаборОбластей=Новый Структура;
		Если (ИмяМакета="ПокупательБюджетныйDOC") ИЛИ (ИмяМакета="ПокупательODT") ИЛИ (ИмяМакета="ПоставщикDOC") ИЛИ (ИмяМакета="ПоставщикODT") Тогда
			УправлениеПечатью.ДобавитьОписаниеОбласти(НаборОбластей, "ВерхнийКолонтитул",	"ВерхнийКолонтитул");
			УправлениеПечатью.ДобавитьОписаниеОбласти(НаборОбластей, "Договор",				"Общая");
			УправлениеПечатью.ДобавитьОписаниеОбласти(НаборОбластей, "НижнийКолонтитул",	"НижнийКолонтитул");
		КонецЕсли;
		ОписанияОбластей.Вставить(ИмяМакета,НаборОбластей);
	КонецЦикла;
	
	Возврат ОписанияОбластей;
	
КонецФункции

&НаСервере
Функция ПолучитьМакетыИОбласти(ИменаМакетов)
	
	МакетыИОбласти=Новый Структура;
	ДвоичныеДанныеМакетов=ПолучитьДвоичныеДанныеМакетов(ИменаМакетов);
	МакетыИОбласти.Вставить("ДвоичныеДанныеМакетов",ДвоичныеДанныеМакетов);
	ОписанияОбластей=ПолучитьОписанияОбластейМакетов(ИменаМакетов);
	МакетыИОбласти.Вставить("ОписанияОбластей",ОписанияОбластей);
	
	Возврат МакетыИОбласти;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ВставитьДанныеОбъекта(ДанныеОбъекта,ИмяПоля,ТекЗначение,ПустоеЗначение=" ")
	Если ЗначениеЗаполнено(ТекЗначение) Тогда
		НовоеЗначение=ТекЗначение;
	Иначе
		НовоеЗначение=ПустоеЗначение;
	КонецЕсли;
	
	ДанныеОбъекта.Вставить(ИмяПоля,НовоеЗначение);
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеОбъекта(СсылкаНаОбъект, ИмяМакета)
	
	ПустаяДатаПрописью="""___"" ___________ 20__ г.";
	ПустаяСтрока="                                                                                                                            ";
	
	ДанныеОбъекта=Новый Структура;
	
	ТекстЗапроса1 = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Договоры.Организация КАК Организация,
	|	Договоры.БанковскийСчет КАК БанковскийСчет,
	|	Договоры.Контрагент КАК Контрагент,
	|	Договоры.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента
	|ПОМЕСТИТЬ Договоры
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК Договоры
	|ГДЕ
	|	Договоры.Ссылка = &ТекДоговор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	МАКСИМУМ(СчетаОрг.НомерСчета) КАК ОрганизацияНомерСчета,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СчетаОрг.РучноеИзменениеРеквизитовБанка
	|				ТОГДА СчетаОрг.БИКБанка
	|			ИНАЧЕ БанкиОрг.Код
	|		КОНЕЦ) КАК ОрганизацияБИК,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СчетаОрг.РучноеИзменениеРеквизитовБанка
	|				ТОГДА СчетаОрг.НаименованиеБанка + "" "" + СчетаОрг.ГородБанка
	|			ИНАЧЕ БанкиОрг.Наименование + "" "" + БанкиОрг.Город
	|		КОНЕЦ) КАК ОрганизацияБанк,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА СчетаОрг.РучноеИзменениеРеквизитовБанка
	|				ТОГДА СчетаОрг.КоррСчетБанка
	|			ИНАЧЕ БанкиОрг.КоррСчет
	|		КОНЕЦ) КАК ОрганизацияКоррСчет,
	|	Организации.НаименованиеСокращенное КАК ОрганизацияНаименование,
	|	МАКСИМУМ(Организации.ОГРН) КАК ОрганизацияОГРН,
	|	МАКСИМУМ(Организации.ИНН) КАК ОрганизацияИНН,
	|	МАКСИМУМ(Организации.КПП) КАК ОрганизацияКПП,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации)
	|				ТОГДА АдресаОрг.Представление
	|		КОНЕЦ) КАК ОрганизацияЮрАдрес,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ПочтовыйАдресОрганизации)
	|				ТОГДА АдресаОрг.Представление
	|		КОНЕЦ) КАК ОрганизацияПочтАдрес,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА АдресаОрг.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EmailОрганизации)
