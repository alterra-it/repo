
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ТекущийСотрудникТСД") Тогда
		ТекущийСотрудникТСД = Параметры.ТекущийСотрудникТСД;
	КонецЕсли;
	
	Если Параметры.Свойство("СписокОрдеров") Тогда
		Для Каждого Ордер Из Параметры.СписокОрдеров Цикл
			Если ЗначениеЗаполнено(Ордер) Тогда
				НС = ОрдераИРаспоряжения.Добавить();
				НС.Ордер = Ордер;
				
				ОпределитьАвтора(Ордер, НС);
			КонецЕсли;
		КонецЦикла; 
		
		Если ОрдераИРаспоряжения.Количество() = 0 Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет ордеров!");
		ИначеЕсли ОрдераИРаспоряжения.Количество() = 1 Тогда
			ОрдераИРаспоряжения[0].Отметка = Истина;
			Элементы.ОрдераИРаспоряжения.Видимость = Ложь;
		КонецЕсли;                      
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОпределитьАвтора(Ордер, СтрокаТЧ)
	
	УстановитьПривилегированныйРежим(Истина);

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка,
		|	ПриходныйОрдерНаТовары.Распоряжение КАК Распоряжение,
		|	ПриходныйОрдерНаТовары.Распоряжение.Автор КАК ЗаказПоставщику_Автор,
		|	ЗаказНаДоставкуОтПоставщика.Ссылка КАК ЗаказНаДоставкуОтПоставщика,
		|	ЗаказНаДоставкуОтПоставщика.Ссылка.Автор КАК ЗаказНаДоставкуОтПоставщика_Автор,
		|	РейсОтПоставщика.Ссылка КАК РейсОтПоставщика,
		|	РейсОтПоставщика.Ссылка.Автор КАК РейсОтПоставщика_Автор
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуОтПоставщика.Основания КАК ЗаказНаДоставкуОтПоставщика
		|		ПО (ЗаказНаДоставкуОтПоставщика.Документ = ПриходныйОрдерНаТовары.Распоряжение)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщика
		|		ПО (РейсОтПоставщика.ЗаказНаДоставку = ЗаказНаДоставкуОтПоставщика.Ссылка)
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Распоряжение ССЫЛКА Документ.ЗаказПоставщику
		|	И ПриходныйОрдерНаТовары.Ссылка = &Ордер";

	Запрос.УстановитьПараметр("Ордер", Ордер);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если ЗначениеЗаполнено(Выборка.РейсОтПоставщика_Автор) Тогда
			СтрокаТЧ.Автор = Выборка.РейсОтПоставщика_Автор;
		ИначеЕсли ЗначениеЗаполнено(Выборка.ЗаказПоставщику_Автор) Тогда
			СтрокаТЧ.Автор = Выборка.ЗаказПоставщику_Автор;
		ИначеЕсли ЗначениеЗаполнено(ТекущийСотрудникТСД) Тогда 
			СтрокаТЧ.Автор = ТекущийСотрудникТСД;
		Иначе
			СтрокаТЧ.Автор = ПользователиКлиентСервер.ТекущийПользователь();
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПропускНеСоответствуетЗаказу(Команда)
	ОбработатьОрдера_НаКлиенте("Заказ поставщика не соответствует товару");
КонецПроцедуры

&НаКлиенте
Процедура ФиктивныйКроссДокинг(Команда)
	ОбработатьОрдера_НаКлиенте("Фиктивный кросс-докинг, товар пришел не по местам");
КонецПроцедуры

&НаКлиенте
Функция ОбработатьОрдера_НаКлиенте(ШаблонСообщения)
	Если НЕ ЗначениеЗаполнено(ОрдераИРаспоряжения.НайтиСтроки(Новый Структура("Отметка", Истина))) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выберите необходимые ордера из списка!");
	ИначеЕсли ОбработатьОрдера_НаСервере(ШаблонСообщения) Тогда
		Закрыть("Данные отправлены в Битрикс!");
	КонецЕсли;
КонецФункции

&НаСервере
Функция ОбработатьОрдера_НаСервере(ШаблонСообщения)
	Если АльтерраОбщегоНазначения.ЭтоРабочаяБаза() Тогда
		Для Каждого Стр Из ОрдераИРаспоряжения Цикл
			Если Стр.Отметка И 
				НЕ Стр.БПЗапущен И 
				НЕ СоздатьБП(ШаблонСообщения, Стр) Тогда
				
				Возврат Ложь;
			КонецЕсли;
		КонецЦикла;
		
		Возврат Истина;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Механизм действует только в рабочей базе!");
		Возврат Ложь;
	КонецЕсли;
КонецФункции

&НаСервере	
Функция ПодразделениеПользователя(Автор)

	Подразделение = "" + Автор.Подразделение;
	
	Если СтрНайти(Подразделение, "Центр") > 0 Тогда 
		Возврат "941"; // Центральный офис 
	ИначеЕсли СтрНайти(Подразделение, "Барнаул") > 0 Тогда
		Возврат "942"; // Филиал Барнаул
	ИначеЕсли СтрНайти(Подразделение, "Бийск") > 0 Тогда
		Возврат "943"; // Филиал Бийск
	ИначеЕсли СтрНайти(Подразделение, "Выбор") > 0 Тогда
		Возврат "26644"; // Филиал Выбор
	ИначеЕсли СтрНайти(Подразделение, "Новоалтайск") > 0 Тогда
		Возврат "944"; // Филиал Новоалтайск
	ИначеЕсли СтрНайти(Подразделение, "Майма") > 0 Тогда
		Возврат "26435"; // Филиал Майма
	ИначеЕсли СтрНайти(Подразделение, "Альтерра") > 0 Тогда
		Возврат "945"; // ТГ Альтерра
	ИначеЕсли СтрНайти(Подразделение, "МД") > 0 Тогда
		Возврат "5402"; // Магазин у дома
	Иначе
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Подразделение пользователя не удалось определить!");
		Возврат "";
	КонецЕсли;
	
КонецФункции     

&НаСервере	
Функция ОтделПользователя(Автор)
	
	Если ТипЗнч(Автор) <> Тип("СправочникСсылка.Сотрудники") Тогда
		Возврат "939"; // все отделы
	КонецЕсли;

	Отдел = "" + Автор.Отдел;

	Если СтрНайти(Отдел, "Бухгалтер") > 0 Тогда // Бухгалтерия
		Возврат "929"; // Бухгалтерия
	ИначеЕсли СтрНайти(Отдел, "Касса") > 0 Тогда // Касса
		Возврат "928"; // Касса
	ИначеЕсли СтрНайти(Отдел, "Коммерческий") > 0 Тогда // Коммерческий отдел
		Возврат "26262"; // Коммерческий отдел
	ИначеЕсли СтрНайти(Отдел, "Контактный") > 0 Тогда // Контактный центр
		Возврат "1225"; // Контактный центр              
	ИначеЕсли СтрНайти(Отдел, "информационных") > 0 Тогда // Отдел информационных технологий
		Возврат "936"; // ИТ-отдел
	ИначеЕсли СтрНайти(Отдел, "аналитик") > 0 Тогда // Отдел аналитики и развития бизнеса
		Возврат "937"; // Отдел аналитики           
	ИначеЕсли СтрНайти(Отдел, "качества") > 0 Тогда // Отдел качества и материального контроля
		Возврат "932"; // Отдел качества
	ИначеЕсли СтрНайти(Отдел, "логист") > 0 Тогда // Отдел транспортной логистики
		Возврат "938"; // Отдел логистики
	ИначеЕсли СтрНайти(Отдел, "реклам") > 0 Тогда // Сектор рекламы
		Возврат "935"; // Сектор рекламы        
	ИначеЕсли СтрНайти(Отдел, "поставок") > 0 Тогда // Отдел поставок
		Возврат "927"; // Отдел поставок
	ИначеЕсли СтрНайти(Отдел, "развития") > 0 Тогда // Отдел развития
		Возврат "940"; // Отдел развития
	ИначеЕсли СтрНайти(Отдел, "Склад") > 0 ИЛИ Отдел = "РСК" ИЛИ Отдел = "РСН" ИЛИ СтрНайти(Отдел, "Секция") > 0 Тогда // Склад
		Возврат "924"; // Склад           
	ИначеЕсли СтрНайти(Отдел, "инженер") > 0 Тогда // Служба главного инженера
		Возврат "931"; // Служба гл. инженера
	ИначеЕсли СтрНайти(Отдел, "персонал") > 0 Тогда // Служба персонала
		Возврат "934"; // Служба персонала
	ИначеЕсли СтрНайти(Отдел, "Торгов") > 0 Тогда // Торговый зал
		Возврат "925"; // Торговый зал/сектор выписки
	ИначеЕсли СтрНайти(Отдел, "Юридический") > 0 Тогда // Юридический отдел
		Возврат "930"; // Юр. отдел
	ИначеЕсли СтрНайти(Отдел, "Оптов") > 0 Тогда // Отдел оптовых продаж
		Возврат "926"; // Оптовый отдел
	ИначеЕсли СтрНайти(Отдел, "безопас") > 0 Тогда // Служба безопасности
		Возврат "933"; // Служба безопасности
	Иначе
		//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отдел пользователя не удалось определить!");
		Возврат "939"; // все отделы 
	КонецЕсли;

КонецФункции

&НаСервере	
Функция СоздатьБП(ШаблонСообщения, СтрокаТЧ)
	
	FIELDS = Новый Структура;

	FIELDS.Вставить("NAME", "Обращение");
	FIELDS.Вставить("CREATED_BY", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(СтрокаТЧ.Автор)); // Автор обращения 

	FIELDS.Вставить("PROPERTY_404", "918"); // Вид обращения (918 - Нарушение процессов, 916 - Предложение по улучшению)
	FIELDS.Вставить("PROPERTY_405", "" + СтрокаТЧ.Автор); // От кого исходит обращение (заполняется, если автор процесса отличается от автора обращения)
	FIELDS.Вставить("PROPERTY_3973", "Да"); // Требуется согласование автора


	FIELDS.Вставить("DETAIL_TEXT", 
		СтрШаблон(ШаблонСообщения + ", Поставщик - %1. №%2", СтрокаТЧ.Ордер.Отправитель, СтрокаТЧ.Ордер.Распоряжение.Номер) +
		Символы.ПС + Символы.ПС + "(Автор обращения: " + ТекущийСотрудникТСД + ")"); // Суть обращения

	FIELDS.Вставить("PROPERTY_413", ПодразделениеПользователя(СтрокаТЧ.Автор));
	FIELDS.Вставить("PROPERTY_408", ОтделПользователя(СтрокаТЧ.Автор));
	FIELDS.Вставить("PROPERTY_1487", "7328"); // Процесс для улучшения/ с нарушением

	Попытка
		НовыйЭлемент = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовыйЭлементСписка(
			"bitrix_processes",
			"95", // Обращения/жалобы сотрудников
			Строка(Новый УникальныйИдентификатор), 
			FIELDS);    
			
		Если ТипЗнч(НовыйЭлемент) = Тип("Структура") И 
			НовыйЭлемент.Свойство("result") И 
			ТипЗнч(НовыйЭлемент.result) = Тип("Число") И 
			НовыйЭлемент.result <> 0 Тогда
			
			СтрокаТЧ.БПЗапущен = Истина;
			Возврат Истина;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось отправить сообщение...");
		КонецЕсли;
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Исключение: Не удалось отправить сообщение... " + ОписаниеОшибки());
	КонецПопытки;
	
КонецФункции







