&НаКлиенте
Перем УстановочныйФайл;


#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
    Элементы.ДляТестовойБазы.Видимость = НЕ АльтерраОбщегоНазначения.ЭтоРабочаяБаза();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено,ЭтаФорма, "СканерШтрихкода");
	ИнициализироватьСканер();	
	ПодключитьОбработчикОжидания("ОбновитьДанныеПоКоличествуЗаданий", 60, Ложь);
	ПодключитьОбработчикОжидания("ПроверкаВерсииПриложения", 1, Истина); 
	
	Если ЗначениеЗАполнено(Сотрудник) ТОгда 
		//Подключение оповещений из очереди

					Секции = СекцииСотрудника();
					СообщениеОбработано = Истина;
					Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
						Если Не ПолучитьСостояниеОповещений() Тогда
							ОповещенияИзОчереди = Истина;
						Иначе
							ОповещенияИзОчереди = ОповещенияПоСотруднику(); 
						КонецЕсли;
					Иначе 
						ОповещенияИзОчереди = Ложь; 	
					КонецЕсли; 
					Инт = 60;
					Для каждого Стр Из Секции Цикл
						ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
						Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
							Инт = ЗнчИнтервала;
						КонецЕсли; 
					КонецЦикла; 
					ИнтервалОповещений = Инт; 
					
					Если ОповещенияИзОчереди Тогда 
						Элементы.ГруппаСписокОчереди.Видимость = Истина; 
						ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь); 
						ПроверкаЭлектроннойОчереди(); 
					Иначе 
						Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
					КонецЕсли;
				КонецЕсли;
				
		
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если  ИмяСобытия = "ScanData" ИЛИ ИмяСобытия = "Barcode" Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;
			Данные= ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Штрихкод1);
			Штрихкод= Данные.Штрихкод;
			
			Если ПустаяСтрока(Штрихкод) Тогда
				Элементы.Декорация1.Заголовок = "Не удалось прочитать штрихкод! Считайте штрихкод еще раз!";
				Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
				Элементы.Декорация1.Видимость = Истина;
				Элементы.СчитатьШтрихкод.Видимость = Истина;
				ЭтаФорма.Элементы.ГруппаГлавноеМеню.Видимость = Ложь;
				Возврат;
			КонецЕсли;
			
			Если Лев(Штрихкод, 4) = "8888" Тогда//Это сотрудник
				Сотрудник = НайтиСотрудникаПоКоду(Штрихкод);
				Если Сотрудник.Пустая() Тогда
					Элементы.Декорация1.Заголовок = "Нет сотрудника с данным штрихкодом или у cотрудника в карточке не заполнена табличная часть 'Рабочие участки (ТСД)'!";
					Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
					Элементы.Декорация1.Видимость = Истина;
					Элементы.СчитатьШтрихкод.Видимость = Истина;
					ЭтаФорма.Элементы.ГруппаГлавноеМеню.Видимость = Ложь;
				Иначе
					СотрудникНайден(); 
					Возврат;
				КонецЕсли;
			Иначе
				Элементы.Декорация1.Заголовок = "Не удалось прочитать штрихкод! Считайте штрихкод еще раз!";
				Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
				Элементы.Декорация1.Видимость = Истина;
				Элементы.СчитатьШтрихкод.Видимость = Истина;
				ЭтаФорма.Элементы.ГруппаГлавноеМеню.Видимость = Ложь;
				Возврат;
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаКлиенте
Процедура _Вход(Команда)
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		СотрудникНайден();
		Элементы.ДляТестовойБазы.Видимость = Ложь;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Введите сотрудника!");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СотрудникНайден()
	ЭтаФорма.Заголовок = Строка(Сотрудник);
	ЭтаФорма.Элементы.ГруппаГлавноеМеню.Видимость = Истина;
	Элементы.Декорация1.Видимость = Ложь;
	ОбновитьДанныеПоКоличествуЗаданийНаСервере();

	УстановитьТекущегоСотрудника(Сотрудник);
	Альтерра_СкладСервер.ЗаписьВРегистрЖурналРаботыТСД(ПредопределенноеЗначение("Перечисление.СобытияРаботыТСД.Вход"));
			
	СсылкаНаПоследнийДокумент = ПолучитьПоследнийДокументНеВыполненный(Сотрудник);

	//Подключение оповещений из очереди

	Секции = СекцииСотрудника();
	СообщениеОбработано = Истина;
	Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
		Если Не ПолучитьСостояниеОповещений() Тогда
			ОповещенияИзОчереди = Истина;
		Иначе
			ОповещенияИзОчереди = ОповещенияПоСотруднику(); 
		КонецЕсли;
	Иначе 
		ОповещенияИзОчереди = Ложь; 	
	КонецЕсли; 
	Инт = 60;
	Для каждого Стр Из Секции Цикл
		ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
		Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
			Инт = ЗнчИнтервала;
		КонецЕсли; 
	КонецЦикла; 
	ИнтервалОповещений = Инт; 
	 
	Если ОповещенияИзОчереди Тогда 
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь); 
		ПроверкаЭлектроннойОчереди(); 
	Иначе 
		Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
	КонецЕсли;


	Если Не СсылкаНаПоследнийДокумент = Неопределено Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеВыбораВарианта",ЭтотОбъект,Новый Структура("Документ",СсылкаНаПоследнийДокумент));
		ПоказатьВопрос(Оповещение,"Открыть последний документ?",РежимДиалогаВопрос.ДаНет,0,КодВозвратаДиалога.Да);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
    Отказ = Истина;
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса",
		ЭтотОбъект);
		
		ПоказатьВопрос(Оповещение,
		"Спасибо за работу! Завершить?",
		РежимДиалогаВопрос.ДаНет,
		0, // таймаут в секундах
		КодВозвратаДиалога.Да, // (необ.) кнопка по умолчанию
		"Завершение работы"
		);

КонецПроцедуры

