#Область СлужебныеПроцедурыИФункции   

#Область ПроверкаВерсииПриложения  

&НаКлиенте
Процедура ПроверкаВерсииПриложения()        
	
	Если АльтерраОбщегоНазначения.ЭтоРабочаяБаза() Тогда     
		
		СистемнаяИнформация = Новый СистемнаяИнформация;
		АктуальнаяВерсия = ПолучитьАктуальнуюВерсию();   
		
		Если ЗначениеЗаполнено(АктуальнаяВерсия) И АктуальнаяВерсия <> СистемнаяИнформация.ВерсияПриложения  Тогда    

			ПоказатьВопрос(Новый ОписаниеОповещения("ОбновитьВерсиюЗавершение", ЭтаФорма), 
			"Версия вашего приложения: "  + СистемнаяИнформация.ВерсияПриложения + Символы.ПС +
			"не совпадает с актуальной: "  + АктуальнаяВерсия + "." + Символы.ПС + 
			"Обновить?", РежимДиалогаВопрос.ДаНет);
		КонецЕсли;     
	КонецЕсли;
	
КонецПроцедуры	

&НаСервере
Функция ПолучитьАктуальнуюВерсию()   
	УстановитьПривилегированныйРежим(Истина);
	Возврат Константы.ВерсияМобильногоКлиента.Получить();
КонецФункции	 
	 
&НаКлиенте
Процедура ОбновитьВерсиюЗавершение(РезультатВопроса, Параметры) Экспорт 
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда   
		
		СкачиваемыйФайл = СохранитьФайлНаСервере();     
		
		Если СкачиваемыйФайл.ПолноеИмяФайла <> "" Тогда                   
			
			ВключитьОжидание(Истина);
			
			ПутьНаУстройстве = "/storage/emulated/0/Download/"; 
			ЛокальноеИмяФайла = ПутьНаУстройстве + СкачиваемыйФайл.ИмяФайла;           
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ПутьКФайлу", ПутьНаУстройстве);
			ДополнительныеПараметры.Вставить("ИмяФайла", СкачиваемыйФайл.ИмяФайла);
			
			ОписаниеОповещения = Новый ОписаниеОповещения("ПослеПолученияФайлаССервера", ЭтотОбъект, ДополнительныеПараметры);
			НачатьПолучениеФайлаССервера(ОписаниеОповещения, СкачиваемыйФайл.Адрес, ЛокальноеИмяФайла);     
			
			ПодключитьОбработчикОжидания("ЗапустьСкачанныйФайлУстановки", 1, Ложь);
		Иначе
			ПоказатьПредупреждение(, "Отсутствует файл обновления " + Символы.ПС + СкачиваемыйФайл.ПолноеИмяФайла, 0, "Обновление не найдено");	
		КонецЕсли;
	КонецЕсли;                                                      
КонецПроцедуры   

 &НаСервере
 Функция СохранитьФайлНаСервере()   
	УстановитьПривилегированныйРежим(Истина);    
	
	НахождениеОбновленияМобильногоКлиента = Константы.НахождениеОбновленияМобильногоКлиента.Получить();
	СкачиваемыйФайл = Новый Структура("ПолноеИмяФайла, ИмяФайла, Адрес", "", "", "");
	
	ФайлНаДиске = Новый Файл(НахождениеОбновленияМобильногоКлиента);
	Если ФайлНаДиске.Существует() Тогда                                        
		
		СкачиваемыйФайл.ПолноеИмяФайла = НахождениеОбновленияМобильногоКлиента;
		СкачиваемыйФайл.ИмяФайла = ПолучитьИмяФайла(НахождениеОбновленияМобильногоКлиента);

		Двоичное = Новый ДвоичныеДанные(НахождениеОбновленияМобильногоКлиента); 
		СкачиваемыйФайл.Адрес = ПоместитьВоВременноеХранилище(Двоичное, ЭтаФорма.УникальныйИдентификатор); 
	КонецЕсли;
	
	Возврат СкачиваемыйФайл; 
 КонецФункции

&НаКлиенте
Процедура ПослеПолученияФайлаССервера(ПолученныйФайл, ДополнительныеПараметры) Экспорт
	УстановочныйФайл = ДополнительныеПараметры;
КонецПроцедуры  
	
&НаКлиенте
Процедура ЗапустьСкачанныйФайлУстановки()

	Если ЗначениеЗаполнено(УстановочныйФайл) Тогда 
	  
		ОтключитьОбработчикОжидания("ЗапустьСкачанныйФайлУстановки"); 
		ВключитьОжидание(Ложь);       
		
		ФайлНаДиске = Новый Файл(УстановочныйФайл.ПутьКФайлу + УстановочныйФайл.ИмяФайла);
		Если ФайлНаДиске.Существует() Тогда    
			
			Если ТекущаяДата() - ФайлНаДиске.ПолучитьВремяИзменения() < 60*30 Тогда // файл получасовой свежести
				Заголовок = "Обновление скачано";
				ТекстСообщения = "Перейдите в папку загрузок " + УстановочныйФайл.ПутьКФайлу + Символы.ПС + "и запустите файл " + УстановочныйФайл.ИмяФайла;
			Иначе     
				Заголовок = "Обновление не скачано";
				ТекстСообщения = "В папке загрузок " + УстановочныйФайл.ПутьКФайлу + Символы.ПС + "старый файл " + УстановочныйФайл.ИмяФайла;
			КонецЕсли;
		Иначе
			Заголовок = "Обновление не скачано";
			ТекстСообщения = "В папке загрузок " + УстановочныйФайл.ПутьКФайлу + Символы.ПС + "нет файла " + УстановочныйФайл.ИмяФайла;
		КонецЕсли;                                                                                                            
		
		ПоказатьПредупреждение(, ТекстСообщения, 0, Заголовок);
	КонецЕсли;  
КонецПроцедуры  	

Функция ПолучитьИмяФайла(СтрокаПути)   
	
	ИмяФайла = СтрокаПути;
	
	Пока Не Найти(ИмяФайла, "\") = 0 Цикл
		ИмяФайла = Сред(ИмяФайла, Найти(ИмяФайла, "\") + 1);
	КонецЦикла;  
	
	Возврат ИмяФайла;
КонецФункции

&НаКлиенте
Процедура ВключитьОжидание(НадоПодождать)
	Элементы.ГруппаОжидание.Видимость = НадоПодождать;
	Элементы.Декорация1.Видимость = Не НадоПодождать;
	Элементы.СчитатьШтрихкод.Видимость = Не НадоПодождать;
КонецПроцедуры
 
