	|	РаспоряженияИСостояния.Документ КАК Документ,
	|	ЗаказНаДоставкуОснования.Ссылка КАК ЗаказНаДоставку,
	|	ДополнительныеСведения.Значение КАК СведениеМаркетплейс
	|ПОМЕСТИТЬ ВТ_ПродажаДоставка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваров
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Промежуточный КАК РаспоряженияИСостояния
	|		ПО РеализацияТоваров.Ссылка = РаспоряженияИСостояния.Документ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
	|		ПО (РеализацияТоваров.Ссылка = ЗаказНаДоставкуОснования.Документ
	|				ИЛИ РеализацияТоваров.ЗаказКлиента <> ЗНАЧЕНИЕ(Документ.ЗаказКлиента.ПустаяСсылка)
	|					И РеализацияТоваров.ЗаказКлиента = ЗаказНаДоставкуОснования.Документ)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО РеализацияТоваров.Партнер = ДополнительныеСведения.Объект
	|			И (ДополнительныеСведения.Свойство.Наименование = ""Маркетплейс"")
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПродажаДоставка.Документ КАК Документ,
	|	ВТ_ПродажаДоставка.ЗаказНаДоставку КАК ЗаказНаДоставку,
	|	ДокЗаказ.ОбъектДоставки КАК Объектдоставки,
	|	ОбъектыДоставки.Маркетплейс КАК Маркетплейс
	|ПОМЕСТИТЬ ПродажиМаркетплейс
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту КАК ДокЗаказ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПродажаДоставка КАК ВТ_ПродажаДоставка
	|		ПО ДокЗаказ.Ссылка = ВТ_ПродажаДоставка.ЗаказНаДоставку
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбъектыДоставки КАК ОбъектыДоставки
	|		ПО ДокЗаказ.ОбъектДоставки = ОбъектыДоставки.Ссылка
	|ГДЕ
	|	ОбъектыДоставки.Маркетплейс <> """"
	|	И ВТ_ПродажаДоставка.СведениеМаркетплейс = ОбъектыДоставки.Маркетплейс
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РаспоряженияИСостояния.Заказ КАК Распоряжение,
	|	РаспоряженияИСостояния.Документ КАК Документ,
	|	РаспоряженияИСостояния.Получатель КАК Получатель,
	|	ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) КАК ТипДокумента,
	|	0 КАК ИндексКартинки,
	|	РаспоряженияИСостояния.РабочийУчасток КАК Секция,
	|	РаспоряженияИСостояния.ОтметкаКассы КАК ОтметкаКассы,
	|	ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку1,
	|	МАКСИМУМ(ЗаказыКДоставке.Рейс) КАК Рейс1,
	|	ДОБАВИТЬКДАТЕ(ЗаказыКДоставке.ЗаказНаДоставку.ПрибытиеНаОтгрузку, ЧАС, ЧАС(ЗаказыКДоставке.ЗаказНаДоставку.ВремяДоставкиС) - 2) КАК ДатаОтгрузки,
	|	РаспоряженияИСостояния.ОжидаетсяОтбор КАК ОжидаетсяОтбор,
	|	РаспоряженияИСостояния.Набирается КАК Набирается,
	|	РаспоряженияИСостояния.Набран КАК Набран,
	|	РаспоряженияИСостояния.ЧастичноОтгружен КАК ЧастичноОтгружен,
	|	РаспоряженияИСостояния.Отгружен КАК Отгружен,
	|	РаспоряженияИСостояния.Ошибка КАК Ошибка,
	|   РаспоряженияИСостояния.ЕстьНарезка КАК ЕстьНарезка,
	|   РаспоряженияИСостояния.Нарезка КАК Нарезка
	|ПОМЕСТИТЬ Итоговый
	|ИЗ
	|	Промежуточный КАК РаспоряженияИСостояния
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЗаказыНаДоставку КАК ЗаказыКДоставке
	|		ПО РаспоряженияИСостояния.Документ = ЗаказыКДоставке.Документ
	|
	|СГРУППИРОВАТЬ ПО
	|	РаспоряженияИСостояния.Заказ,
	|	РаспоряженияИСостояния.Документ,
	|	РаспоряженияИСостояния.Получатель,
	|	РаспоряженияИСостояния.РабочийУчасток,
	|	ЗаказыКДоставке.ЗаказНаДоставку,
	|	РаспоряженияИСостояния.ОжидаетсяОтбор,
	|	РаспоряженияИСостояния.Набирается,
	|	РаспоряженияИСостояния.Набран,
	|	РаспоряженияИСостояния.ЧастичноОтгружен,
	|	РаспоряженияИСостояния.Отгружен,
	|	РаспоряженияИСостояния.Ошибка,
	|	РаспоряженияИСостояния.ОтметкаКассы,
	|	ДОБАВИТЬКДАТЕ(ЗаказыКДоставке.ЗаказНаДоставку.ПрибытиеНаОтгрузку, ЧАС, ЧАС(ЗаказыКДоставке.ЗаказНаДоставку.ВремяДоставкиС) - 2),
	|   РаспоряженияИСостояния.ЕстьНарезка,
	|   РаспоряженияИСостояния.Нарезка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Итоговый.Распоряжение КАК Распоряжение,
	|	Итоговый.Документ КАК Документ,
	|	Итоговый.Документ.Номер КАК Номер,
	|	ВЫБОР
	|		КОГДА &ДатаСортировки = ""ДатаДокумента""
	|			ТОГДА Итоговый.Документ.Дата
	|		ИНАЧЕ ВЫБОР
	|				КОГДА Итоговый.ДатаОтгрузки ЕСТЬ NULL
	|					ТОГДА Итоговый.Документ.Дата
	|				ИНАЧЕ Итоговый.ДатаОтгрузки
	|			КОНЕЦ
	|	КОНЕЦ КАК Дата,
	|   Итоговый.Нарезка КАК Нарезка,
	|	Итоговый.Получатель КАК Получатель,
	|	Итоговый.ТипДокумента КАК ТипДокумента,
	|	Итоговый.ИндексКартинки КАК ИндексКартинки,
	|	Итоговый.Секция КАК Секция,
	|	Итоговый.ОтметкаКассы КАК ОтметкаКассы,
	|	Итоговый.ЗаказНаДоставку1 КАК ЗаказНаДоставку,
	|	Итоговый.Рейс1 КАК Рейс,
	|	Итоговый.ОжидаетсяОтбор КАК ОжидаетсяОтбор,
	|	Итоговый.Набирается КАК Набирается,
	|	Итоговый.Набран КАК Набран,
	|	Итоговый.ЧастичноОтгружен КАК ЧастичноОтгружен,
	|	Итоговый.Отгружен КАК Отгружен,
	|   Итоговый.ЕстьНарезка КАК ЕстьНарезка,
	|	ВЫБОР
	|		КОГДА НЕ ПродажиМаркетплейс.Маркетплейс ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Маркетплейс
	|ИЗ
	|	Итоговый КАК Итоговый
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПродажиМаркетплейс КАК ПродажиМаркетплейс
	|		ПО Итоговый.Документ = ПродажиМаркетплейс.Документ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";	
	
	УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка();   
	
КонецПроцедуры  

&НаСервере
Процедура ЗаполняемДинамическийСписокПересчет() 
	РаспоряженияНаПересчет.ТекстЗапроса=" 
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПересчетТоваров.Ссылка КАК Документ,
	|	ПересчетТоваров.Склад Как Склад, 
	|   ПересчетТоваров.Дата Как Дата,
	|	ПересчетТоваров.Номер Как Номер,
	|	ПересчетТоваров.ТипПересчета Как ТипПересчета,
	|	ПересчетТоваров.ТочкаПересчета Как ТочкаПересчета,
	|	ПересчетТоваров.Статус Как Статус,
	|	ПересчетТоваров.Ответственный Как Ответственный
	|ИЗ
	|	Документ.ПересчетТоваров КАК ПересчетТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|			ПО ПересчетТоваровТовары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|				И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ПересчетТоваровТовары.Ссылка.Склад)
	|				И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|		ПО (ПересчетТоваровТовары.Ссылка = ПересчетТоваров.Ссылка)
	|ГДЕ
	|	ВЫБОР
	|		КОГДА &ИспользоватьСклад ТОГДА
	|			ПересчетТоваров.Склад = &Склад
	|		ИНАЧЕ НЕ &ИспользоватьСклад 
	|	КОНЕЦ
	|	И
	|	ВЫБОР 
	|		КОГДА &ИспользоватьСекции ТОГДА
	|			ВЫБОР			
	|				КОГДА ПересчетТоваров.Склад.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток 
	|					В (&Секции, ЗНАЧЕНИЕ(Справочник.РабочиеУчастки.ПустаяСсылка))
	|				ИНАЧЕ
	|					&ИспользоватьСекции
	|			КОНЕЦ
	|		ИНАЧЕ
	|			НЕ &ИспользоватьСекции
	|	КОНЕЦ
	|	И 
	|	ПересчетТоваров.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|    И НЕ ПересчетТоваров.ПометкаУдаления
	|    И ПересчетТоваров.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыПересчетовТоваров.Отменено) ";  

	УстанавливаемЗначенияПараметровДинамическихСписковПересчет();
КонецПроцедуры
                  
&НаСервере
Процедура ЗаполняемДинамическийСписокПроверкаЦенников()  
	ПроверкиЦенников.ТекстЗапроса=" 
	|ВЫБРАТЬ
	|	ДокументПроверкаЦенников.Ссылка КАК Ссылка,
	|	ДокументПроверкаЦенников.Склад КАК Склад,
	|	ДокументПроверкаЦенников.Номер КАК Номер,
	|	ДокументПроверкаЦенников.Дата КАК Дата, 
	|	ДокументПроверкаЦенников.ВидПроверки КАК ВидПроверки
	|ИЗ
	|	Документ.ПроверкаЦенников КАК ДокументПроверкаЦенников
	|ГДЕ
	|	ДокументПроверкаЦенников.Склад = &Склад
	|	И ДокументПроверкаЦенников.Дата >= &Дата "; 

	УстанавливаемЗначенияПараметровДинамическихСписковПроверкаЦенников();
КонецПроцедуры

&НаСервере
Процедура ЗаполняемДинамическийСписокИзучениеАссортимента()
	ТаблицаИзученийАссортимента.ТекстЗапроса="
|ВЫБРАТЬ
|	СкладскиеЯчейки.Ссылка КАК Ячейка
|ПОМЕСТИТЬ ВТ_Ячейки
|ИЗ
|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
|ГДЕ
|	СкладскиеЯчейки.РабочийУчасток В(&РабочийУчасток)
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ РАЗЛИЧНЫЕ
|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура.ВидНоменклатуры КАК Вид
|ПОМЕСТИТЬ ВТ_Виды
|ИЗ
|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки КАК ТоварыНаСкладахОстатки
|		ПО РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
|			И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ТоварыНаСкладахОстатки.Склад
|ГДЕ
|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка В
|			(ВЫБРАТЬ
|				ВТ_Ячейки.Ячейка
|			ИЗ
|				ВТ_Ячейки)
|	И ТоварыНаСкладахОстатки.ВНаличииОстаток > 0
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ РАЗЛИЧНЫЕ
|	ТочкиПересчетаОбучение.Ссылка КАК Точка,
|	ТочкиПересчетаОбучение.Родитель КАК Родитель
|ПОМЕСТИТЬ ВТ_Точки
|ИЗ
|	Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТочкиПересчетаОбучение КАК ТочкиПересчетаОбучение
|		ПО ВидыНоменклатуры.ТочкаПересчетаОбучение = ТочкиПересчетаОбучение.Ссылка
|ГДЕ
|	ВидыНоменклатуры.Ссылка В
|			(ВЫБРАТЬ
|				Вт_Виды.Вид
|			ИЗ
|				Вт_Виды)
|	И ТочкиПересчетаОбучение.ЭтоТочка
|	И НЕ ТочкиПересчетаОбучение.Порядок = 168
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ
|	ИзучениеАссортиментаСрезПоследних.Регистратор КАК Ссылка,
|	ИзучениеАссортиментаСрезПоследних.ТочкаПересчетаОбучение КАК ТочкаПересчетаОбучение,
|	ИзучениеАссортиментаСрезПоследних.Статус КАК Статус,
|	ИзучениеАссортиментаСрезПоследних.ПоследняяОткрытаяСтрока КАК ПоследняяОткрытаяСтрока,
|	ИзучениеАссортиментаСрезПоследних.КоличествоОшибок КАК КоличествоОшибок
|ПОМЕСТИТЬ ВТ_СписокДокументов
|ИЗ
|	РегистрСведений.ИзучениеАссортимента.СрезПоследних КАК ИзучениеАссортиментаСрезПоследних
|ГДЕ
|	ИзучениеАссортиментаСрезПоследних.Сотрудник = &Сотрудник
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ
|	ВТ_Точки.Точка КАК ТочкаПересчетаОбучение,
|	ВТ_СписокДокументов.Ссылка КАК Ссылка,
|	ВТ_Точки.Точка.Порядок КАК Порядок,
|	ВТ_СписокДокументов.Статус КАК Статус,
|	ВТ_СписокДокументов.ПоследняяОткрытаяСтрока КАК СтрокНабрано,
|	ВТ_СписокДокументов.КоличествоОшибок КАК ОшибокДопущено,
|	ВТ_Точки.Родитель КАК Родитель
|ИЗ
|	ВТ_Точки КАК ВТ_Точки
|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СписокДокументов КАК ВТ_СписокДокументов
|		ПО ВТ_Точки.Точка = ВТ_СписокДокументов.ТочкаПересчетаОбучение 
|
|ГДЕ
|	(НЕ &ТолькоНеИзученное
|			ИЛИ НЕ ЕСТЬNULL(ВТ_СписокДокументов.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыИзученияАссортимента.НеИзучено)) = ЗНАЧЕНИЕ(Перечисление.СтатусыИзученияАссортимента.Завершено))
|";
	УстанавливаемЗначенияПараметровДинамическихСписковИзучениеАссортимента(); 
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено,ЭтаФорма, "СканерШтрихкода");
		
	ИнициализироватьСканер();
	
	УстановитьВидимость(ИмяКоманды);
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		  ЭтаФорма.Элементы.ДополнительнаяИнформация.Видимость=Ложь;
	#Иначе
		 ЭтаФорма.Элементы.ДополнительнаяИнформация.Видимость=Истина;
	#КонецЕсли
	
	Если ОповещенияИзОчереди Тогда 
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);
		ПроверкаЭлектроннойОчереди(); 
	Иначе 
		Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
	КонецЕсли; 
		
	Если ОтрытьСписокОчереди Тогда        
		ПоказатьСписокОчередиКлиент(); 
		ОтрытьСписокОчереди = Ложь;
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	    ОтключитьСканер();

		ОтключитьОбработчикОжидания("ОбновитьДанныеНаКлиенте");	

КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" ИЛИ ИмяСобытия = "Barcode" Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;
			
			ОбработатьШтрихкоды(ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Штрихкод1));
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяСобытия = "РасходныйОрдер_СтатусИзменение_Доп" И ИмяКоманды="Отгрузка" И ВводДоступен() Тогда 
        УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка();
	КонецЕсли; 

КонецПроцедуры

