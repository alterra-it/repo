Процедура УстанавливаемЗначенияПараметровДинамическихСписковПересчет()
	
	
	ПараметрСклад = ПредопределенноеЗначение("Справочник.Склады.ПустаяСсылка"); 
	ПараметрСекции = ПредопределенноеЗначение("Справочник.РабочиеУчастки.ПустаяСсылка"); 
	Если ЗначениеЗаполнено(РольМобильногоКлиента) И РольМобильногоКлиента = ПредопределенноеЗначение("Перечисление.РолиМобильногоКлиента.Бухгалтер") Тогда
		ПараметрСклад = ФильтрПересчетовСклад;
		ПараметрСекции = ФильтрПересчетовСекция;
	Иначе
		Если НЕ ЗначениеЗаполнено(Склад) Или Секции.Количество() = 0 Тогда
			Сообщить("У сотрудника в карточке должны быть заполнены реквизит 'Склад' и табличная часть 'Рабочие участки (ТСД)'!");
			Возврат;
		КонецЕсли;
		ПараметрСклад = Склад;
		ПараметрСекции = Секции;
	КонецЕсли;
	
	РаспоряженияНаПересчет.Отбор.Элементы.Очистить();
	
	Если ЗначениеЗаполнено(ФильтрПересчетовСтатус) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(РаспоряженияНаПересчет, "Статус", ФильтрПересчетовСтатус, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	КонецЕсли;
	
	РаспоряженияНаПересчет.Параметры.УстановитьЗначениеПараметра("ДатаНачала",?(ЗначениеЗаполнено(ДатаПересчета.ДатаНачала),НачалоДня(ДатаПересчета.ДатаНачала), НачалоМесяца(ТекущаяДата())));
	РаспоряженияНаПересчет.Параметры.УстановитьЗначениеПараметра("ДатаОкончания",?(ЗначениеЗаполнено(ДатаПересчета.ДатаОкончания),КонецДня(ДатаПересчета.ДатаОкончания), КонецДня(ТекущаяДата())));
	
	РаспоряженияНаПересчет.Параметры.УстановитьЗначениеПараметра("ИспользоватьСклад",?(ЗначениеЗаполнено(ПараметрСклад), Истина, Ложь));
	РаспоряженияНаПересчет.Параметры.УстановитьЗначениеПараметра("Склад",ПараметрСклад);
	РаспоряженияНаПересчет.Параметры.УстановитьЗначениеПараметра("ИспользоватьСекции",?(ЗначениеЗаполнено(ПараметрСекции), Истина, Ложь));
	РаспоряженияНаПересчет.Параметры.УстановитьЗначениеПараметра("Секции",ПараметрСекции);
	
	
	
КонецПроцедуры

