&НаКлиенте
Функция СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод)
	Менеджеры = Новый Массив();
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ЗаказПоставщику.ПустаяСсылка"));
    Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ПеремещениеТоваров.ПустаяСсылка"));
    Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ПриходныйОрдерНаТовары.ПустаяСсылка"));
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ВозвратТоваровОтКлиента.ПустаяСсылка"));
    Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ЧекККМВозврат.ПустаяСсылка"));
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.КорректировкаРеализации.ПустаяСсылка"));
	
	Возврат ШтрихкодированиеПечатныхФормКлиент.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, Менеджеры);
КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкоды(Данные)
	
	МассивСсылок = СсылкаНаЭлементСпискаПоШтрихкоду(Данные.Штрихкод);
	
	Если МассивСсылок.Количество() > 0 Тогда
		
		СсылкаДокумента = МассивСсылок[0];	
		
		Если СсылкаДокумента <> Неопределено Тогда
			Если ТипЗнч(СсылкаДокумента)=Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда
				СсылкаНаОрдер = СсылкаДокумента;
				СсылкаДокумента = Неопределено;
				ПараметрыФормы = Новый Структура("Ключ, ТекущийСотрудникТСД", СсылкаНаОрдер, Исполнитель); 
                ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.Док_ФормаДокументаТСД",ПараметрыФормы);
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		ПоискШтрихкодаСтруктура = ПоискШтрихкодаСекции(Данные.Штрихкод);						
		СсылкаДокумента = ПоискШтрихкодаСтруктура.Документ;
	КонецЕсли;
		
	Если СсылкаДокумента <> Неопределено Тогда
			
		Если ЭтаФорма.Заголовок = "Приемка" Тогда
			
			РаспоряженияНаПоступление.Отбор.Элементы.Очистить();
			
			ЭлементОтбора = РаспоряженияНаПоступление.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Распоряжение");
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбора.Использование = Истина;
			ЭлементОтбора.ПравоеЗначение = СсылкаДокумента;
			
			ОрдераВРаботе.Отбор.Элементы.Очистить();
			
			ЭлементОтбора = ОрдераВРаботе.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка.Распоряжение");
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбора.Использование = Истина;
			ЭлементОтбора.ПравоеЗначение = СсылкаДокумента;
				
		ИначеЕсли ЭтаФорма.Заголовок = "Отгрузка" Тогда
			
			РаспоряженияНаОтгрузку.Отбор.Элементы.Очистить();
			//Тест поиск 
			
			СостояниеОтгрузки = "";
			УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка();
			
			
			ЭлементОтбора = РаспоряженияНаОтгрузку.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Документ");
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбора.Использование = Истина;
			ЭлементОтбора.ПравоеЗначение = СсылкаДокумента;
			
			ОрдераВРаботеОтгрузка.Отбор.Элементы.Очистить();
			
			ЭлементОтбора = ОрдераВРаботеОтгрузка.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка.Накладная");
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбора.Использование = Истина;
			ЭлементОтбора.ПравоеЗначение = СсылкаДокумента;

        КонецЕсли;
			
	КонецЕсли;
		
	
КонецПроцедуры

