&НаКлиенте
Процедура ПриемкаПоРейсу(Команда)
	
	СозданныеОрдера = Новый Массив();
	
	Для каждого Строка из Элементы.РаспоряженияНаПоступление.ВыделенныеСтроки Цикл
		
		ДанныеСтроки = Элементы.РаспоряженияНаПоступление.ДанныеСтроки(Строка);
		
		Ордера = Новый Массив;
		
		Ордера = ПолучитьОрдерПоСекцииИРаспоряжению(ДанныеСтроки.РабочийУчасток,ДанныеСтроки.Распоряжение);
		
		Если Ордера.Количество()>0 Тогда
			Для каждого Строка из Ордера Цикл
				СозданныеОрдера.Добавить(Строка);
			КонецЦикла;
		Иначе
			СозданныйОрдер = СоздатьОрдер(ДанныеСтроки);
			
			СозданныеОрдера.Добавить(СозданныйОрдер);
			
		КонецЕсли;
			
	КонецЦикла;         
	
	ОчиститьСообщения(); 
	
	ОткрытьФорму("Обработка.РабочееМестоКладовщикаАльтерра.Форма.ФормаПриемПоРейсу",  Новый Структура("Сотрудник,СписокОрдеров",Исполнитель,СозданныеОрдера));
КонецПроцедуры

Функция СоздатьОрдер(Строка)
	
	ОрдерОбъект = Документы.ПриходныйОрдерНаТовары.СоздатьДокумент();
	
	ОрдерОбъект.Статус = Перечисления.СтатусыПриходныхОрдеров.КПоступлению;
	ОрдерОбъект.Склад = Склад;
	ОрдерОбъект.Распоряжение = Строка.Распоряжение;
	ОрдерОбъект.Дата = ТекущаяДата();
	ОрдерОбъект.Отправитель = Строка.Отправитель;
	ОрдерОбъект.ДатаВходящегоДокумента =  Строка.ДатаВходящегоДокумента;
	ОрдерОбъект.НомерВходящегоДокумента =   Строка.НомерВходящегоДокумента;
	ОрдерОбъект.ХозяйственнаяОперация =     Строка.ХозяйственнаяОперация;
	ОрдерОбъект.РабочийУчасток = Строка.РабочийУчасток;
	ОрдерОбъект.Исполнитель = ПолучитьПользователяСотрудника();
	ОрдерОбъект.Ответственный = Пользователи.ТекущийПользователь();
	ОрдерОбъект.СкладскаяОперация = СкладыКлиентСервер.СкладскаяОперацияПриемкиПоХозяйственнойОперации(Строка.ХозяйственнаяОперация);
	
	ОрдерОбъект.ЗаполнитьТоварыПоТоварамКПоступлению("Номенклатура",ТекущаяДата());
	
	Если ЗначениеЗаполнено(ОрдерОбъект.РабочийУчасток) И ОрдерОбъект.Товары.Количество()>0 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
