	|	ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_Распоряжения.Распоряжение.СуммаДокумента, 0) КАК ЧИСЛО(15, 2)),
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ВТ_Распоряжения.Распоряжение.Комментарий, """") КАК СТРОКА(1024)),
