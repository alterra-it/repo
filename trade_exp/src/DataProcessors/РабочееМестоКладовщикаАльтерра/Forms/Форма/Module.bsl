&НаКлиенте
Процедура ПроверкаЭлектроннойОчереди() Экспорт
	ОбновитьСписокОчереди(); 

	Если ПолучитьСписокОчереди() Тогда
		Если ЕстьОповещениеПоОрдеруВРаботе ИЛИ СписокДокументовВОчереди.Количество() > 0 Тогда
			ТекДата = ТекущаяДата();
			Если ВремяПоследнегоОповещения > ТекДата-5 Или ВремяПоследнегоОповещения < ТекДата - ИнтервалОповещений Тогда
				#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
					Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
						СредстваМультимедиа.ВоспроизвестиТекст("Клиент на выдаче!","ru-RU");
					Иначе
						СредстваМультимедиа.ВоспроизвестиЗвуковоеОповещение();
					КонецЕсли;   
					СредстваМультимедиа.ВоспроизвестиЗвуковоеОповещение();

				#КонецЕсли 
				ВремяПоследнегоОповещения = ТекДата;
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли; 
КонецПроцедуры


&НаСервере
Процедура ОбновитьСписокОчереди() 

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЭлектроннаяОчередьКлиентов.Документ КАК Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления КАК Получатель
	|ИЗ
	|	РегистрСведений.ЭлектроннаяОчередьКлиентов КАК ЭлектроннаяОчередьКлиентов 
	|ГДЕ
	|   ЭлектроннаяОчередьКлиентов.ТребуетсяОповещениеКладовщику = Истина 
	|	И ЭлектроннаяОчередьКлиентов.ПолучательУведомления В (&Секции)   
	|	И не ЭлектроннаяОчередьКлиентов.Состояние = &Статус
	|
	|
	|СГРУППИРОВАТЬ ПО
	|	ЭлектроннаяОчередьКлиентов.Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления";
	
	
	Запрос.УстановитьПараметр("Секции", Секции);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЭлектроннойОчереди.Выдан);
    РезультатЗапроса = Запрос.Выполнить();
	
	Если не РезультатЗапроса.Пустой() Тогда
		КлиентовВОчереди = РезультатЗапроса.Выбрать().Количество(); 
	Иначе
       КлиентовВОчереди = 0;
	КонецЕсли; 
КонецПроцедуры 	

&НаСервере
Функция ПолучитьСписокОчереди()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЭлектроннаяОчередьКлиентов.Документ КАК Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления КАК Получатель
	|ИЗ
	|	РегистрСведений.ЭлектроннаяОчередьКлиентов КАК ЭлектроннаяОчередьКлиентов 
	|ГДЕ
	|   ЭлектроннаяОчередьКлиентов.ТребуетсяОповещениеКладовщику = Истина 
	|	И ЭлектроннаяОчередьКлиентов.ПолучательУведомления В (&Секции)  
	|	И не ЭлектроннаяОчередьКлиентов.Состояние = &Статус
	|
	|
	|СГРУППИРОВАТЬ ПО
	|	ЭлектроннаяОчередьКлиентов.Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления";
	
	
	Запрос.УстановитьПараметр("Секции", Секции);
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЭлектроннойОчереди.Выдан);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		СписокДокументовВОчереди.Очистить();
		Результат = Ложь;
	Иначе
		Результат = Истина;
		Выборка = РезультатЗапроса.Выбрать();
		СпВОчереди = Новый СписокЗначений;
		СпКВыдаче  = Новый СписокЗначений;
		ЕстьОповещениеПоОрдеруВРаботе = Ложь;
		Пока Выборка.Следующий() Цикл
			Если ТипЗнч(Выборка.Получатель) = Тип("СправочникСсылка.РабочиеУчастки") Тогда
				ДатаДок = Выборка.Документ.Дата;
				СпВОчереди.Добавить(Выборка.Документ);
				ЭлементСписка = СписокДокументовВОчереди.НайтиПоЗначению(Выборка.Документ);
				Если ЭлементСписка = Неопределено Тогда
					ВремяПоследнегоОповещения = ТекущаяДата();
				КонецЕсли; 
				Если ДатаДок < ДатаОтгрузки.ДатаНачала Тогда
					ДатаОтгрузки.ДатаНачала = ДатаДок;
				КонецЕсли; 
			Иначе
				Если Выборка.Получатель = Исполнитель Тогда
					СпКВыдаче.Добавить(Выборка.Документ);
					ЭлементСписка = СписокДокументовКВыдаче.НайтиПоЗначению(Выборка.Документ);
					Если ЭлементСписка = Неопределено Тогда
						ЕстьОповещениеПоОрдеруВРаботе = Истина;
					КонецЕсли;
				КонецЕсли; 
			КонецЕсли; 
		КонецЦикла;
		
		Если ЕстьОповещениеПоОрдеруВРаботе Тогда
			СписокДокументовКВыдаче  = СпКВыдаче.Скопировать();
		КонецЕсли; 
		СписокДокументовВОчереди = СпВОчереди.Скопировать();
		
	КонецЕсли; 
	
	Возврат Результат;

КонецФункции

&НаКлиенте
Процедура ПоказатьДокументыКВыдаче()
	МассивДокументов = СписокДокументовКВыдаче.ВыгрузитьЗначения();
	Стр = СтрСоединить(МассивДокументов, Символы.ПС);
	Предупреждение(Стр,,"Клиенты ожидают выдачу по документам");
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьДокументыОчереди(РезультатВопроса, ДополнительныеПараметры) Экспорт
	СообщениеОбработано = Истина;
	Если РезультатВопроса = "Показать документы" Тогда
		ПолучитьСписокОчереди();
		Если СписокДокументовВОчереди.Количество() > 0 Тогда
			НайтиОткрытуюФормуДокумента();
			
			//Скидываем отбор 
			СостояниеОтгрузки = "";
			УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка();

			УстановитьВидимость("Список очереди");
			УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка();
		Иначе 
			Сообщить("Все документы уже в работе");
		КонецЕсли;
	Иначе
		Возврат;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Оповещения(Команда)
	
	Если ОповещенияИзОчереди Тогда
		ПричинаОтказа = "";
		ОповещенияПоСекцииПодключены = ПолучитьСостояниеОповещений();
		
		Если (СписокДокументовКВыдаче.Количество() + СписокДокументовВОчереди.Количество()) > 2 Тогда
			ПричинаОтказа = "Нельзя отключить, пока в очереди более двух клиентов" 
		ИначеЕсли Не ОповещенияПоСекцииПодключены Тогда
			ПричинаОтказа = "Нельзя отключить, пока оповещения отключены у других сотрудников секции";
		КонецЕсли;
		
		Если ПричинаОтказа = "" Тогда
			ОповещенияИзОчереди = Не ОповещенияИзОчереди;
			Сообщить("Оповещения отключены");
			Элементы.ГруппаСписокОчереди.Видимость = Ложь;
			ОтключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди"); 
			ПроверкаЭлектроннойОчереди(); 
		Иначе
			Сообщить(ПричинаОтказа);
		КонецЕсли;
	Иначе
		ОповещенияИзОчереди = Не ОповещенияИзОчереди;
		Сообщить("Оповещения подключены");
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);  
		ПроверкаЭлектроннойОчереди(); 
	КонецЕсли;
	ЗаписатьЗначениеОповещения();

КонецПроцедуры

&НаСервере
Функция ПолучитьСостояниеОповещений()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиРабочиеУчастки.Ссылка.ОповещенияИзОчереди КАК ОповещенияИзОчереди
		|ИЗ
		|	Справочник.Сотрудники.РабочиеУчастки КАК СотрудникиРабочиеУчастки
		|ГДЕ
		|	СотрудникиРабочиеУчастки.РабочийУчасток В(&РабочийУчасток)
		|	И СотрудникиРабочиеУчастки.Ссылка <> &Сотрудник
		|
		|СГРУППИРОВАТЬ ПО
		|	СотрудникиРабочиеУчастки.Ссылка.ОповещенияИзОчереди";
	
	Запрос.УстановитьПараметр("РабочийУчасток", Секции);
	Запрос.УстановитьПараметр("Сотрудник", Исполнитель);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() = 1 И Результат.Найти(Истина, "ОповещенияИзОчереди") = Неопределено Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ЭлектроннаяОчередьНаСекции()
	Запрос = Новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ
				 |	РабочиеУчастки.Ссылка КАК Ссылка,
				 |	РабочиеУчастки.ЭлектроннаяОчередь КАК ЭлектроннаяОчередь
				 |ИЗ
				 |	Справочник.РабочиеУчастки КАК РабочиеУчастки
				 |ГДЕ
				 |	РабочиеУчастки.Ссылка В(&Секции)
				 |	И РабочиеУчастки.ЭлектроннаяОчередь = Истина" ;
	Запрос.УстановитьПараметр("Секции", Секции); 
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 
		Возврат Истина; 
	Иначе 
		Возврат Ложь; 
	КонецЕсли;
	
КонецФункции 
	
	

&НаКлиенте
Процедура НайтиОткрытуюФормуДокумента()
	// Получение всех открытых окон приложения
	ОкнаПриложения = ПолучитьОкна();
	Для каждого ОкноПриложения Из ОкнаПриложения Цикл
		// Анализ заголовка окна
		Если Найти(ОкноПриложения.Заголовок, "товар") > 0 Тогда
			// Получение формы
			НайденнаяФорма = ОкноПриложения.Содержимое[0];
			//Если есть изменения - записываем
			Если НайденнаяФорма.Модифицированность Тогда
				ОбщегоНазначенияУТКлиент.ЗаписатьИЗакрыть(НайденнаяФорма);
			Иначе
				НайденнаяФорма.Закрыть()
			КонецЕсли; 
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры 

&НаСервере
Процедура ЗаписатьЗначениеОповещения() 
	УстановитьПривилегированныйРежим(Истина);
	ОбъектСотрудник = Исполнитель.ПолучитьОбъект();
	ОбъектСотрудник.ОповещенияИзОчереди = ОповещенияИзОчереди;
	ОбъектСотрудник.Записать();
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

