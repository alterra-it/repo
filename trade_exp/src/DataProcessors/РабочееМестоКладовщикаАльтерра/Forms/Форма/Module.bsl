&НаКлиенте
Процедура РаспоряженияНаПересчетВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.РаспоряженияНаПересчет.ТекущиеДанные; 
	Если ТекущиеДанные <> Неопределено Тогда 
		СсылкаНаЭлемент	= ТекущиеДанные.Документ; 
		
		
		ПараметрыФормы = Новый Структура("Ключ, Сотрудник", СсылкаНаЭлемент, Исполнитель);
		ОткрытьФорму("Документ.ПересчетТоваров.Форма.Док_ФормаДокументаТСД", ПараметрыФормы);
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура РаспоряженияНаПоступлениеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда
			Если ПоРаспоряжениюИСекцииЕстьОрдера(ТекущиеДанные.Распоряжение) Тогда
			
			Оповещение = Новый ОписаниеОповещения("ПослеОтветаНаВопрос",ЭтотОбъект); 
			
			ПоказатьВопрос(Оповещение, "Создать новый?",  РежимДиалогаВопрос.ДаНетОтмена,0,КодВозвратаДиалога.Да, "Найдены созданные ордера");
		Иначе	
			ЗаполнитьТовары(ТекущиеДанные.РабочийУчасток,ТекущиеДанные.Распоряжение);
			
			Основание = Новый Структура;
			Основание.Вставить("Распоряжение",               ТекущиеДанные.Распоряжение);
			Основание.Вставить("Отправитель",                ТекущиеДанные.Отправитель);
			Основание.Вставить("Склад",                      Склад);
			Основание.Вставить("ДатаВходящегоДокумента",     ТекущиеДанные.ДатаВходящегоДокумента);
			Основание.Вставить("НомерВходящегоДокумента",    ТекущиеДанные.НомерВходящегоДокумента);
			Основание.Вставить("ДатаПоступления",            ТекущаяДата());
			Основание.Вставить("ХозяйственнаяОперация",      ТекущиеДанные.ХозяйственнаяОперация);
			Основание.Вставить("РабочийУчасток",      ТекущиеДанные.РабочийУчасток);
			Основание.Вставить("Товары", Товары);
			Основание.Вставить("Исполнитель", ПолучитьПользователяСотрудника());
			Основание.Вставить("Секции", Секции);
			Основание.Вставить("Сотрудник", Исполнитель);
			
			ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.Док_ФормаДокументаТСД",
			Новый Структура("Основание, ТекущийСотрудникТСД",Основание, Исполнитель));
		КонецЕсли;
	Иначе
		
		ТекстПредупреждения = НСтр("ru = 'Выберите распоряжение на поступление товаров.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПредупреждения);
		
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеОтветаНаВопрос(Результат, Параметры) Экспорт 
	
	ТекущиеДанные = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗаполнитьТовары(ТекущиеДанные.РабочийУчасток,ТекущиеДанные.Распоряжение);
		
		Основание = Новый Структура;
		Основание.Вставить("Распоряжение",               ТекущиеДанные.Распоряжение);
		Основание.Вставить("Отправитель",                ТекущиеДанные.Отправитель);
		Основание.Вставить("Склад",                      Склад);
		Основание.Вставить("ДатаВходящегоДокумента",     ТекущиеДанные.ДатаВходящегоДокумента);
		Основание.Вставить("НомерВходящегоДокумента",    ТекущиеДанные.НомерВходящегоДокумента);
		Основание.Вставить("ДатаПоступления",            ТекущаяДата());
		Основание.Вставить("ХозяйственнаяОперация",      ТекущиеДанные.ХозяйственнаяОперация);
		Основание.Вставить("РабочийУчасток",      ТекущиеДанные.РабочийУчасток);
		Основание.Вставить("Товары", Товары);
		Основание.Вставить("Исполнитель", ПолучитьПользователяСотрудника());
		Основание.Вставить("Секции", Секции.ВыгрузитьЗначения());
		Основание.Вставить("Сотрудник", Исполнитель);

		ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.Док_ФормаДокументаТСД",
		Новый Структура("Основание, ТекущийСотрудникТСД",Основание, Исполнитель));
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		
		Элементы.ГруппаСтраницыПриемка.ТекущаяСтраница = Элементы.ПриходныеОрдера;
		
		ОрдераВРаботе.Отбор.Элементы.Очистить();
		
		ЭлементОтбора = ОрдераВРаботе.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка.Распоряжение");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.Использование = Истина;
		ЭлементОтбора.ПравоеЗначение = ТекущиеДанные.Распоряжение;
		
	КонецЕсли;
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОрдераВРаботеВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	СсылкаНаЭлемент = Элементы.ОрдераВРаботе.ТекущиеДанные;
