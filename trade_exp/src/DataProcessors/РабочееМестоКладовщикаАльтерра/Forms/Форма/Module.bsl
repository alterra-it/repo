#Область ИзучениеМатериала
&НаСервере
Функция ПолучитьСсылкуНаДокументИзучениеАссортимента()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИзучениеАссортимента.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ИзучениеАссортимента КАК ИзучениеАссортимента
	|ГДЕ
	|	ИзучениеАссортимента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыИзученияАссортимента.ВРаботе)
	|			И НЕ ИзучениеАссортимента.ПометкаУдаления
	|			И ИзучениеАссортимента.Сотрудник = &Сотрудник";
	
	Запрос.УстановитьПараметр("Сотрудник", Исполнитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Док = Неопределено;
	Иначе
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Док = ВыборкаДетальныеЗаписи.Ссылка;
		КонецЦикла;
	КонецЕсли; 
	
	Возврат Док;
	
КонецФункции

&НаКлиенте
Процедура НачатьИзучениеПоПорядку(Команда)
	СсылкаНаДокумент = ПолучитьСсылкуНаДокументИзучениеАссортимента();
	НачатьИзучение(СсылкаНаДокумент);
КонецПроцедуры

&НаКлиенте
Процедура НачатьИзучение(СсылкаНаДокумент)
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ключ", СсылкаНаДокумент);
	ПараметрыФормы.Вставить("Сотрудник", Исполнитель);
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияДокументаИзучения", ЭтотОбъект);
	
	ОткрытьФорму("Документ.ИзучениеАссортимента.Форма.ФормаДокументаТСД", ПараметрыФормы,,,,,Оповещение);
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаИзученийАссортиментаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Элемент.ТекущиеДанные.Свойство("Порядок") Тогда
		СтандартнаяОбработка = Ложь;
		
		Если ЗначениеЗаполнено(Элемент.ТекущиеДанные.Ссылка) Тогда
			
			ДокСсылка = Элемент.ТекущиеДанные.Ссылка;
			Статус = Элемент.ТекущиеДанные.Статус;
			
			Если Статус = ПредопределенноеЗначение("Перечисление.СтатусыИзученияАссортимента.Завершено") Тогда

				ПараметрыФормы = Новый Структура;
				ПараметрыФормы.Вставить("Повтор", Истина);
				ПараметрыФормы.Вставить("Сотрудник", Исполнитель);
				ПараметрыФормы.Вставить("ЗначениеКопирования", Элемент.ТекущиеДанные.Ссылка);
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ПараметрыФормы", ПараметрыФормы);
				ПоказатьВопрос(Новый ОписаниеОповещения("СоздатьНовоеИзучение", ЭтотОбъект, ДополнительныеПараметры), "Изучение по этой точке пересчета завершено, Вы хотите повторить обучение?", РежимДиалогаВопрос.ДаНет);

				
			ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыИзученияАссортимента.ВРаботе") Тогда
				ПараметрыФормы = Новый Структура;
				ПараметрыФормы.Вставить("Ключ", ДокСсылка);
				ПараметрыФормы.Вставить("Сотрудник", Исполнитель);
				Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияДокументаИзучения", ЭтотОбъект);
				ОткрытьФорму("Документ.ИзучениеАссортимента.Форма.ФормаДокументаТСД", ПараметрыФормы,,,,,Оповещение);
				
			ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.СтатусыИзученияАссортимента.НеИзучено") Тогда
				ПараметрыФормы = Новый Структура;
				ПараметрыФормы.Вставить("Повтор", Истина);
				ПараметрыФормы.Вставить("Сотрудник", Исполнитель);
				ПараметрыФормы.Вставить("ЗначениеКопирования", Элемент.ТекущиеДанные.Ссылка);
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ПараметрыФормы", ПараметрыФормы);
				ПоказатьВопрос(Новый ОписаниеОповещения("СоздатьНовоеИзучение", ЭтотОбъект, ДополнительныеПараметры), "Начать повторное изучение по точке?", РежимДиалогаВопрос.ДаНет);
			КонецЕсли;
			
		Иначе
			
			Точка = Элемент.ТекущиеДанные.ТочкаПересчетаОбучение;
			
			ПараметрыФормы = Новый Структура;
			ПараметрыФормы.Вставить("Сотрудник", Исполнитель);
			ПараметрыФормы.Вставить("Повтор", Истина);
			ПараметрыФормы.Вставить("ТочкаПересчетаОбучение", Точка);
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияДокументаИзучения", ЭтотОбъект);
			ОткрытьФорму("Документ.ИзучениеАссортимента.Форма.ФормаДокументаТСД", ПараметрыФормы,,,,,Оповещение);
			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

