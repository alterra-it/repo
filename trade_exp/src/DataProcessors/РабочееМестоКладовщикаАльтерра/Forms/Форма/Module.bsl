КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПериод(Команда)
	Если ИмяКоманды = "Приемка" Тогда
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();                                 
		Диалог.Период = ДатаПоступления;        
		Если Диалог.Редактировать() Тогда
			ДатаПоступления = Диалог.Период;
		КонецЕсли;
		УстанавливаемЗначенияПараметровДинамическихСписковПриемка();
	ИначеЕсли ИмяКоманды = "Отгрузка" Тогда
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();                                 
		Диалог.Период = ДатаОтгрузки;        
		Если Диалог.Редактировать() Тогда
			ДатаОтгрузки = Диалог.Период;
		КонецЕсли;
		УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка();
	ИначеЕсли ИмяКоманды = "Пересчет" Тогда
		Диалог = Новый ДиалогРедактированияСтандартногоПериода();                                 
		Диалог.Период = ДатаПересчета;        
		Если Диалог.Редактировать() Тогда
			ДатаПересчета = Диалог.Период;
		КонецЕсли;
		УстанавливаемЗначенияПараметровДинамическихСписковПересчет();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КПриемке(Команда)
