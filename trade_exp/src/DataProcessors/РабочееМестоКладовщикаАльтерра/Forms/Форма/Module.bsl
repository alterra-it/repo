
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    
    ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);

    Если Параметры.Свойство("Сотрудник") Тогда
       Исполнитель = Параметры.Сотрудник;
       //ДляТеста
       Если Исполнитель.Отдел = Справочники.Отделы.НайтиПоНаименованию("ИТ отдел") Тогда
           Элементы.ОбновитьСписокДляТеста.Видимость =Истина;
           Элементы.ОтключитьОбновлениеСпискаДляТеста.Видимость = Истина;
       КонецЕсли;  
       //
   КонецЕсли;
   
   Если Параметры.Свойство("ИмяКоманды") Тогда
	   ИмяКоманды = Параметры.ИмяКоманды;
   КонецЕсли;
   
   Если Параметры.Свойство("РольМобильногоКлиента") Тогда
	   РольМобильногоКлиента = Параметры.РольМобильногоКлиента;
   КонецЕсли;
   
    ТекущийПользователь = Пользователи.ТекущийПользователь();
		
    Если Не ЗначениеЗаполнено(Исполнитель) Тогда
        #Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
            Отказ = Истина;
        #Иначе
            Сотрудник = Справочники.Сотрудники.НайтиПоРеквизиту("Пользователь",ТекущийПользователь);
            Если ЗначениеЗаполнено(Сотрудник) Тогда
            Исполнитель = Сотрудник;
        Иначе
            Сообщить("У пользователя нет карточки сотрудника!");
            Отказ = Истина;
            КонецЕсли;
        #КонецЕсли
    КонецЕсли;
    
    Дата = Текущаядата();
    ДатаСортировки = "Дата";
    
    ДатаПоступления.Вариант = ВариантСтандартногоПериода.ЭтаНеделя;
	ДатаОтгрузки.Вариант = ВариантСтандартногоПериода.ЭтаНеделя;
	ДатаПересчета.Вариант = ВариантСтандартногоПериода.ЭтаНеделя;
	
	СостояниеОтгрузки = "ОжидаетсяОтбор";   //ОжидаетсяОтбор
	СостояниеПоступленияФильтр = "КПриемке";
	ОтборОрдеровПоСотруднику = Ложь; 
	
	Склад = Исполнитель.Склад;
	Секции.ЗагрузитьЗначения(Исполнитель.РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток"));
	
	ИспользуетсяОтгрузкаПоНакладным = АльтерраОбщегоНазначения.ОтгрузкаПоНакладным(ТекущаяДата(),Склад);

	Если АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков() Тогда
		Для каждого Секция Из Секции Цикл
			Если Секция.Значение.СкрытьКоличествоПоУчету Тогда
				Элементы.ПроверитьОстатки.Заголовок = "Карточка товара с АХ";
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	//Подключение оповещений из очереди
	СообщениеОбработано = Истина;
	Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
		Если Не ПолучитьСостояниеОповещений() Тогда
			ОповещенияИзОчереди = Истина;
		Иначе
			ОповещенияИзОчереди = Исполнитель.ОповещенияИзОчереди; 
		КонецЕсли;
	Иначе 
		ОповещенияИзОчереди = Ложь; 	
	КонецЕсли; 
	Инт = 60;
	Для каждого Стр Из Секции Цикл
		ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
		Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
			Инт = ЗнчИнтервала;
		КонецЕсли; 
	КонецЦикла; 
	ИнтервалОповещений = Инт;   
	
	Если Параметры.Свойство("ОткрытьОчередь") Тогда 
		ОтрытьСписокОчереди = Истина;
	Иначе
		ОтрытьСписокОчереди = Ложь; 
	КонецЕсли;
 
	
КонецПроцедуры  

&НаКлиенте
Процедура ЗаполнитьНужныйСписок(ИмяКоманды) 
	
	Если ИмяКоманды = "Приемка" Тогда
		ЗаполняемДинамическийСписокПриемка(); 
	ИначеЕсли ИмяКоманды = "Отгрузка" Тогда 
		ЗаполняемДинамическийСписокОтгрузка(); 
	ИначеЕсли ИмяКоманды = "Пересчет" Тогда
		ЗаполняемДинамическийСписокПересчет(); 
	ИначеЕсли ИмяКоманды = "ПроверкаЦенников" Тогда   
		ЗаполняемДинамическийСписокПроверкаЦенников(); 
	ИначеЕсли ИмяКоманды = "ИзучениеАссортимента" Тогда  
		ЗаполняемДинамическийСписокИзучениеАссортимента(); 
		СгруппироватьПоТипу();
	ИначеЕсли ИмяКоманды = "ПриемкаСдачаРабот" Тогда
		ЗаполняемДинамическийСписокПриемкаСдачаРабот();
	КонецЕсли; 
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполняемДинамическийСписокПриемкаСдачаРабот()
	ДокументыПриемкаСдачаРабот.ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ПриемкаСдачаВыполненныхРаботУслуг.Дата КАК Дата,
	|	ПриемкаСдачаВыполненныхРаботУслуг.Ссылка КАК Ссылка,
	|	ПриемкаСдачаВыполненныхРаботУслуг.Заказчик КАК Заказчик,
	|	ПриемкаСдачаВыполненныхРаботУслуг.Подрядчик КАК Подрядчик,
	|	ПриемкаСдачаВыполненныхРаботУслуг.Подразделение КАК Подразделение
	|ИЗ
	|	Документ.ПриемкаСдачаВыполненныхРаботУслуг КАК ПриемкаСдачаВыполненныхРаботУслуг
	|ГДЕ
	|	ПриемкаСдачаВыполненныхРаботУслуг.Дата Между &ДатаНачало и &ДатаКонец
	|	И ПриемкаСдачаВыполненныхРаботУслуг.Подразделение = &Подразделение";
	УстанавливаемЗначенияПараметровДинамическихСписковПриемкаСдачаРабот();
КонецПроцедуры

&НаСервере
Процедура ЗаполняемДинамическийСписокПриемка() 
	ОрдераВРаботе.ТекстЗапроса = " 
	|ВЫБРАТЬ
	|	ЖурналДокументовСкладскиеОрдера.Ссылка КАК Ссылка,
	|	ЖурналДокументовСкладскиеОрдера.Дата КАК Дата,
	|	ЖурналДокументовСкладскиеОрдера.ПометкаУдаления КАК ПометкаУдаления,
	|	ЖурналДокументовСкладскиеОрдера.Номер КАК Номер,
	|	ЖурналДокументовСкладскиеОрдера.Проведен КАК Проведен,
	|	ЖурналДокументовСкладскиеОрдера.Склад КАК Склад,
	|	ЖурналДокументовСкладскиеОрдера.Статус КАК Статус,
	|	ЖурналДокументовСкладскиеОрдера.ПомещениеОтправитель КАК ПомещениеОтправитель,
	|	ЖурналДокументовСкладскиеОрдера.ПомещениеПолучатель КАК ПомещениеПолучатель,
	|	ЖурналДокументовСкладскиеОрдера.Приоритет КАК Приоритет,
	|	ЖурналДокументовСкладскиеОрдера.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ЖурналДокументовСкладскиеОрдера.ЗаданиеНаПеревозку КАК ЗаданиеНаПеревозку,
	|	ЖурналДокументовСкладскиеОрдера.ОтгрузкаПоЗаданиюНаПеревозку КАК ОтгрузкаПоЗаданиюНаПеревозку,
	|	ЖурналДокументовСкладскиеОрдера.Комментарий КАК Комментарий,
	|	ЖурналДокументовСкладскиеОрдера.ПолучательОтправитель КАК ПолучательОтправитель,
	|	ЖурналДокументовСкладскиеОрдера.ПорядокДоставки КАК ПорядокДоставки,
	|	ЖурналДокументовСкладскиеОрдера.Тип КАК Тип
	|ИЗ
	|	ЖурналДокументов.СкладскиеОрдера КАК ЖурналДокументовСкладскиеОрдера
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ЖурналДокументовСкладскиеОрдера.Ссылка) = ТИП(Документ.ПриходныйОрдерНаТовары)
	|	И ЖурналДокументовСкладскиеОрдера.Дата >= &ДатаПоступленияНачало
	|	И ЖурналДокументовСкладскиеОрдера.Дата <= &ДатаПоступленияОкончание
	|	И ЖурналДокументовСкладскиеОрдера.Ссылка.РабочийУчасток в (&РабочиеУчастки)
	|	И ЖурналДокументовСкладскиеОрдера.Склад = &Склад"; 
	
	
	РаспоряженияНаПоступление.ТекстЗапроса=	
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТоварыКПоступлению.ДокументПоступления КАК ДокументПоступления
	|ПОМЕСТИТЬ Распоряжения
	|ИЗ
	|	РегистрНакопления.ТоварыКПоступлению КАК ТоварыКПоступлению
	|ГДЕ
	|	ТоварыКПоступлению.Период МЕЖДУ &ДатаПоступленияНачало И &ДатаПоступленияОкончание
	|	  И ТоварыКПоступлению.Склад = &Склад
    |	  И НЕ(ТоварыКПоступлению.ДокументПоступления ССЫЛКА Документ.ЗаказНаПеремещение
    |     ИЛИ ТоварыКПоступлению.ДокументПоступления ССЫЛКА Документ.ЗаказНаСборку
    |     ИЛИ (ТоварыКПоступлению.ДокументПоступления ССЫЛКА Документ.ЗаказПоставщику
    |     	И ВЫРАЗИТЬ(ТоварыКПоступлению.ДокументПоступления КАК Документ.ЗаказПоставщику).Договор.ВариантПриемкиТоваров
    |            = ЗНАЧЕНИЕ(Перечисление.ВариантыПриемкиТоваров.РазделенаТолькоПоНакладным))
    |    )
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Распоряжения.ДокументПоступления КАК ДокументПоступления,
	|	ТоварыКПоступлениюОстаткиНаДату.Отправитель КАК Отправитель,
	|	ТоварыКПоступлениюОстаткиНаДату.Склад КАК Склад,
	|	ТоварыКПоступлениюОстаткиНаДату.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ТоварыКПоступлениюОстаткиНаДату.Назначение КАК Назначение,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК ЯчейкаРабочийУчасток,
	|	ТоварыКПоступлениюОстаткиНаДату.Номенклатура КАК Номенклатура,
	|	ТоварыКПоступлениюОстаткиНаДату.Характеристика КАК Характеристика,
	|	СУММА(ВЫБОР
	|			КОГДА ТоварыКПоступлениюОстаткиНаДату.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА ТоварыКПоступлениюОстаткиНаДату.КОформлениюОрдеров
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КОформлениюОрдеровПриход,
	|	СУММА(ВЫБОР
	|			КОГДА ТоварыКПоступлениюОстаткиНаДату.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА ТоварыКПоступлениюОстаткиНаДату.КОформлениюПоступленийПоОрдерам
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КОформлениюПоступленийПоОрдерамПриход,
	|	СУММА(ВЫБОР
	|			КОГДА ТоварыКПоступлениюОстаткиНаДату.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА ТоварыКПоступлениюОстаткиНаДату.Принимается
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ПринимаетсяПриход,
	|	СУММА(ВЫБОР
	|			КОГДА ТоварыКПоступлениюОстаткиНаДату.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|				ТОГДА ТоварыКПоступлениюОстаткиНаДату.КОформлениюОрдеров
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КОформлениюОрдеровРасход,
	|	СУММА(ВЫБОР
	|			КОГДА ТоварыКПоступлениюОстаткиНаДату.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|				ТОГДА ТоварыКПоступлениюОстаткиНаДату.КОформлениюПоступленийПоОрдерам
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК КОформлениюПоступленийПоОрдерамРасход,
	|	СУММА(ВЫБОР
	|			КОГДА ТоварыКПоступлениюОстаткиНаДату.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
	|				ТОГДА ТоварыКПоступлениюОстаткиНаДату.Принимается
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК ПринимаетсяРасход
	|ПОМЕСТИТЬ ТоварыКПоступлениюОстаткиНаДату
	|ИЗ
	|	Распоряжения КАК Распоряжения
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКПоступлению КАК ТоварыКПоступлениюОстаткиНаДату
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|			ПО ТоварыКПоступлениюОстаткиНаДату.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|				И ТоварыКПоступлениюОстаткиНаДату.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|				И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|		ПО Распоряжения.ДокументПоступления = ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В (&РабочиеУчастки)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ

	|СГРУППИРОВАТЬ ПО
	|	ТоварыКПоступлениюОстаткиНаДату.Отправитель,
	|	ТоварыКПоступлениюОстаткиНаДату.Склад,
	|	ТоварыКПоступлениюОстаткиНаДату.ХозяйственнаяОперация,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток,
	|	ТоварыКПоступлениюОстаткиНаДату.Номенклатура,
	|	ТоварыКПоступлениюОстаткиНаДату.Характеристика,
	|	ТоварыКПоступлениюОстаткиНаДату.Назначение,
	|	Распоряжения.ДокументПоступления

	|ИНДЕКСИРОВАТЬ ПО
	|	Склад,
	|	ДокументПоступления,
	|	Отправитель,
	|	ХозяйственнаяОперация
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления КАК Распоряжение,
	|	ТоварыКПоступлениюОстаткиНаДату.Отправитель КАК Отправитель,
	|	ВЫБОР
	|		КОГДА ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления ССЫЛКА Документ.ЗаказПоставщику
	|			ТОГДА ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления.Контрагент
	|		ИНАЧЕ ТоварыКПоступлениюОстаткиНаДату.Отправитель
	|	КОНЕЦ КАК ОтправительКонтрагент,
	|	ТоварыКПоступлениюОстаткиНаДату.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	ТоварыКПоступлениюОстаткиНаДату.Номенклатура КАК Номенклатура,
	|	ТоварыКПоступлениюОстаткиНаДату.Характеристика КАК Характеристика,
	|	ТоварыКПоступлениюОстаткиНаДату.ЯчейкаРабочийУчасток КАК ЯчейкаРабочийУчасток,
	|	ВЫБОР
	|		КОГДА ТоварыКПоступлениюОстаткиНаДату.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьНазначение,
	|	ВЫБОР
	|		КОГДА ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления ССЫЛКА Справочник.СоглашенияСПоставщиками
	|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления КАК Справочник.СоглашенияСПоставщиками).Номер КАК СТРОКА(11))
	|		КОГДА ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления ССЫЛКА Справочник.ДоговорыКонтрагентов
	|			ТОГДА ВЫРАЗИТЬ(ВЫРАЗИТЬ(ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления КАК Справочник.ДоговорыКонтрагентов).Номер КАК СТРОКА(11))
	|		ИНАЧЕ ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления.Номер
	|	КОНЕЦ КАК Номер,
	|	ВЫБОР
	|		КОГДА ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления ССЫЛКА Справочник.СоглашенияСПоставщиками
	|			ТОГДА ВЫРАЗИТЬ(ТоварыКПоступлениюОстаткиНаДату.ДокументПоступления КАК Справочник.СоглашенияСПоставщиками).Дата
