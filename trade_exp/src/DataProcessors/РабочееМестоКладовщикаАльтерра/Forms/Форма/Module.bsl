&НаКлиенте
Процедура РаспоряженияНаОтгрузку1Выбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные = Элементы.РаспоряженияНаОтгрузку1.ТекущиеДанные;
	
	СтруктураОрдераПоДокументу = ПолучитьРасходныеОрдераПоНакладной(ТекущиеДанные.Документ,ТекущиеДанные.Секция); 
	ОрдераПоДокументу = СтруктураОрдераПоДокументу.МассивОрдеров;
	ПодготовленныеОрдераПоДокументу = СтруктураОрдераПоДокументу.МассивОрдеровВСтатусеПодготовлено;
	СобранныеОрдераПоДокументу =  СтруктураОрдераПоДокументу.МассивОрдеровВСтатусеСобрано;
	ОрдераВРаботеПоДокументу =  СтруктураОрдераПоДокументу.МассивОрдеровВСтатусеВРаботе;
	ОтгруженныеОрдераПоДокументу =  СтруктураОрдераПоДокументу.МассивОрдеровВСтатусеОтгружен;

	ОжидаетсяОтбор = ТекущиеДанные.ОжидаетсяОтбор;
	Набирается = ТекущиеДанные.Набирается;
	Набран = ТекущиеДанные.Набран;
	ЧастичноОтгружен = ТекущиеДанные.ЧастичноОтгружен;
	Отгружен = ТекущиеДанные.Отгружен;
	
	Если СтруктураОрдераПоДокументу.ИзменитьСтатусы Тогда
		ОжидаетсяОтбор = СтруктураОрдераПоДокументу.ОжидаетсяОтбор;
	    Набирается = ОрдераВРаботеПоДокументу.Количество()>0;
	    Набран = СобранныеОрдераПоДокументу.Количество()>0;
	    ЧастичноОтгружен = ОтгруженныеОрдераПоДокументу.Количество()>0;
	    Отгружен = ОтгруженныеОрдераПоДокументу.Количество()>0;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ПослеОтветаНаВопросОтгрузка",ЭтотОбъект); 
    СписокКнопок = Новый СписокЗначений; 	
	ЗаголовокВопроса="";
	
	ОрдеровНет = Ложь;
	ОрдерОдин = Ложь;
	ОрдеровНесколько = Ложь;
	
	Если ОрдераПоДокументу.Количество()=0 Тогда
		ОрдеровНет = Истина;
	Иначе
		Если ОрдераПоДокументу.Количество()=1 Тогда
			ОрдерОдин = Истина;
			ТекущийРасходныйОрдер = ОрдераПоДокументу[0];
		Иначе
			ОрдеровНесколько = Истина;  
		КонецЕсли;
	КонецЕсли;
	
	Если ОжидаетсяОтбор Тогда
		Если Набирается ИЛИ Набран ИЛИ ЧастичноОтгружен Тогда
			#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
				Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
					СредстваМультимедиа.ВоспроизвестиТекст("Документ не собран полностью!","ru-RU");	
				КонецЕсли;
			#КонецЕсли
			Вопрос = "Документ не собран полностью";
		Иначе
			Вопрос = "Документ не собирался";
		КонецЕсли;
		Если ПодготовленныеОрдераПоДокументу.Количество()=0 Тогда
			СписокКнопок.Добавить(КодВозвратаДиалога.ОК, "Начать сборку"); 
		ИначеЕсли ПодготовленныеОрдераПоДокументу.Количество()=1 Тогда
			ТекущийРасходныйОрдер = ПодготовленныеОрдераПоДокументу[0];
			СписокКнопок.Добавить(КодВозвратаДиалога.Да, "Начать сборку");
		Иначе
			СписокКнопок.Добавить(КодВозвратаДиалога.Нет, "Перейти к ордерам"); 
		КонецЕсли;
		СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "Отмена");	
	ИначеЕсли Набирается Тогда
		Если ЧастичноОтгружен Тогда
			Вопрос = "Документ частично отгружен, но не собран полностью";
			Если ОрдерОдин Тогда
				СписокКнопок.Добавить(КодВозвратаДиалога.Да, "Дособирать");
			Иначе
				СписокКнопок.Добавить(КодВозвратаДиалога.Нет, "Перейти к ордерам");
			КонецЕсли;
			СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "Отмена");
		Иначе
			Вопрос = "Документ в работе";
			Если ОрдерОдин Тогда
				СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "ОК");  //Доработано по желаниюю Красновой. Собирает только 1
			Иначе
				СписокКнопок.Добавить(КодВозвратаДиалога.Нет, "Перейти к ордерам");
			КонецЕсли; 
		КонецЕсли;
	ИначеЕсли Набран Тогда
		Если ЧастичноОтгружен Тогда
			Вопрос = "Документ частично отгружен и собран";
			Если ОрдерОдин Тогда
				СписокКнопок.Добавить(КодВозвратаДиалога.Да, "Выдать");
			Иначе
				СписокКнопок.Добавить(КодВозвратаДиалога.Нет, "Перейти к ордерам");
			КонецЕсли;
			СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "Отмена");
		Иначе
			Вопрос = "Документ собран";
			Если ОрдерОдин Тогда
				СписокКнопок.Добавить(КодВозвратаДиалога.Да, "Выдать");
			Иначе
				СписокКнопок.Добавить(КодВозвратаДиалога.Нет, "Перейти к ордерам");
			КонецЕсли; 
			СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "Отмена");
		КонецЕсли;
	ИначеЕсли Отгружен Тогда
		    Вопрос = "Документ отгружен";
			Если ОрдерОдин Тогда
				СписокКнопок.Добавить(КодВозвратаДиалога.Да, "Перейти к ордеру");
			Иначе
				СписокКнопок.Добавить(КодВозвратаДиалога.Нет, "Перейти к ордерам");
			КонецЕсли; 
			СписокКнопок.Добавить(КодВозвратаДиалога.Отмена, "Отмена");
	КонецЕсли;
	
	Для Каждого Ордер_ Из ОрдераПоДокументу Цикл
		Вопрос = ДобавитьЗначениеЯчейкаПромежуточногоХранения(Вопрос, Ордер_);
	КонецЦикла;

	ПоказатьВопрос(Оповещение, Вопрос,  СписокКнопок,0,, "Текущее состояние");
	
КонецПроцедуры

&НаСервере
Функция ДобавитьЗначениеЯчейкаПромежуточногоХранения(Вопрос, Объект)
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("ЯчейкаПромежуточногоХранения", Объект.Метаданные()) Тогда
		Если Объект.ЯчейкаПромежуточногоХранения.Ссылка <> Справочники.СкладскиеЯчейки.ПустаяСсылка() Тогда
			Вопрос = Вопрос + ", ячейка хранения " + Объект.ЯчейкаПромежуточногоХранения;
			Возврат Вопрос;
		КонецЕсли;
	КонецЕсли;
	Возврат Вопрос;
КонецФункции

&НаКлиенте
Процедура ПослеОтветаНаВопросОтгрузка(Результат, Параметры) Экспорт 
	
	ТекущиеДанные = Элементы.РаспоряженияНаОтгрузку1.ТекущиеДанные;
	
	Если Результат = КодВозвратаДиалога.ОК Тогда	
		
		
		ТекущийРасходныйОрдер = СоздатьОрдераСервер(ТекущиеДанные.Распоряжение,ТекущиеДанные.Получатель,ТекущиеДанные.Документ,ТекущиеДанные.Секция);
		
		ОткрытьФорму("Документ.РасходныйОрдерНаТовары.Форма.Док_ФормаДокументаДляТСД",Новый Структура("Ключ,Сотрудник,Секции", ТекущийРасходныйОрдер, Исполнитель, Секции.ВыгрузитьЗначения()),,,,,Новый ОписаниеОповещения("ОбновитьСписокОтгрузка",ЭтотОбъект)); 	
		
	ИначеЕсли Результат = КодВозвратаДиалога.Да Тогда

		ОткрытьФорму("Документ.РасходныйОрдерНаТовары.Форма.Док_ФормаДокументаДляТСД",Новый Структура("Ключ,Сотрудник,Секции", ТекущийРасходныйОрдер, Исполнитель, Секции.ВыгрузитьЗначения()),,,,,Новый ОписаниеОповещения("ОбновитьСписокОтгрузка",ЭтотОбъект)); 
		

	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
		
		Элементы.ГруппаСтраницыОтгрузки.ТекущаяСтраница = Элементы.РасходныеОрдера;
		
		ОрдераВРаботеОтгрузка.Отбор.Элементы.Очистить();
		
		ЭлементОтбора = ОрдераВРаботеОтгрузка.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка.Накладная");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.Использование = Истина;
		ЭлементОтбора.ПравоеЗначение = ТекущиеДанные.Документ;
		
	КонецЕсли;  
		
КонецПроцедуры

Функция СоздатьОрдераСервер(Распоряжение,Получатель, ТекущаяНакладная, ТекущийРабочийУчасток)
	ТекущийДокумент = Неопределено; 
	
	Если АльтерраОбщегоНазначения.ОтгрузкаПоНакладным(ТекущаяНакладная.Дата,Склад) Тогда 
		
		РО = Документы.РасходныйОрдерНаТовары.СоздатьДокумент();
		РО.Дата = ТекущаяДата(); 
		РО.ДатаОтгрузки = ТекущаяДата(); 
		РО.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен;		
		РО.Ответственный = Пользователи.ТекущийПользователь();
		РО.Приоритет = Справочники.Приоритеты.ПолучитьПриоритетПоУмолчанию();
		РО.Склад = Склад;
		РО.Получатель = Документы.РасходныйОрдерНаТовары.ПолучательДляЗаполнения(ТекущаяНакладная); 
		РО.РабочийУчасток = ТекущийРабочийУчасток;
		РО.Накладная = ТекущаяНакладная;
		РО.Контролер = ПолучитьПользователяСотрудника();
		РО.Сотрудник = Исполнитель;
		РО.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;
		РО.СкладскаяОперация = ПолучитьСкладскуюОперацию(ТекущаяНакладная);
		
		ТЧТовары = Документы.РасходныйОрдерНаТовары.ПолучитьТоварыДляЗаполнения(ТекущаяНакладная,ТекущийРабочийУчасток,Склад);
		РО.ТоварыПоРаспоряжениям.Загрузить(ТЧТовары);				
		РО.ОтгружаемыеТовары.Загрузить(ТЧТовары); 
		РО.ОтгружаемыеТовары.Свернуть("Действие,Номенклатура,Характеристика,Назначение,Серия,Упаковка","Количество,КоличествоУпаковок");
		ЗаполнитьНарезку(РО);
		РО.Записать(РежимЗаписиДокумента.Проведение);    
		
		Возврат РО.Ссылка;	
		
	КонецЕсли;
	
	Получатели = Новый Соответствие;
	ЗаданияНаПеревозку = Новый Массив; 
	
	СтруктураПараметровСозданияРасходныхОрдеров = СкладыСервер.ПараметрыПереоформленияРасходныхОрдеров();
	
	СтруктураПараметровСозданияРасходныхОрдеров.Склад = Склад;	
	СтруктураПараметровСозданияРасходныхОрдеров.Получатель = Получатель;
	МассивРаспоряжение = Новый Массив();
	МассивРаспоряжение.Добавить(Распоряжение);
	СтруктураПараметровСозданияРасходныхОрдеров.РаспоряженияНаОтгрузку = ПолучитьМассивРаспоряжений(ТекущаяНакладная,МассивРаспоряжение);
	ОформОрдера = СкладыСервер.ПереоформитьРасходныеОрдера(СтруктураПараметровСозданияРасходныхОрдеров); 	
	Если ОформОрдера.Количество()>0 Тогда
		Если ЗначениеЗаполнено(ТекущийРабочийУчасток) Тогда
				Для каждого Строка из ОформОрдера.ОформленныеОрдера Цикл
					
					Если Не ЗначениеЗаполнено(Строка.РасходныйОрдер.РабочийУчасток) ИЛИ 
						Строка.РасходныйОрдер.РабочийУчасток = ТекущийРабочийУчасток Тогда
						РО = Строка.РасходныйОрдер.ПолучитьОбъект();
						ТекущийДокумент = РО.Ссылка;
						РО.РабочийУчасток = ТекущийРабочийУчасток;
						РО.Накладная = ТекущаяНакладная;
						РО.Контролер = ПолучитьПользователяСотрудника();
						РО.Сотрудник = Исполнитель;
						РО.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;
						
						ТоварыПоРаспоряжениям = РО.ТоварыПоРаспоряжениям.Выгрузить();
						РО.ТоварыПоРаспоряжениям.Очистить();
						РО.ТоварыПоРаспоряжениям.Загрузить(ПолучитьТоварыПоРаспоряжениямПоСекции(Распоряжение,ТоварыПоРаспоряжениям,Склад,ТекущийРабочийУчасток,ТекущаяНакладная));
						
						ОтгружаемыеТовары = РО.ОтгружаемыеТовары.Выгрузить(); 
						РО.ОтгружаемыеТовары.Очистить();
						РО.ОтгружаемыеТовары.Загрузить(ПолучитьОтгружаемыеТоварыПоСекции(Распоряжение,ОтгружаемыеТовары,Склад,ТекущийРабочийУчасток,ТекущаяНакладная));
						ЗаполнитьНарезку(РО);

						
						РО.Записать(РежимЗаписиДокумента.Проведение);
					Иначе
						РО =  Строка.РасходныйОрдер.Скопировать();
						РО.Дата = ТекущаяДата();
						РО.РабочийУчасток = ТекущийРабочийУчасток;
						РО.Накладная = ТекущаяНакладная;
						РО.Контролер = ПолучитьПользователяСотрудника();
						РО.Сотрудник = Исполнитель;
						РО.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;

						ТекущийДокумент = РО.Ссылка;
						
						ТоварыПоРаспоряжениям = РО.ТоварыПоРаспоряжениям.Выгрузить();
						РО.ТоварыПоРаспоряжениям.Очистить();
						РО.ТоварыПоРаспоряжениям.Загрузить(ПолучитьТоварыПоРаспоряжениямПоСекции(Распоряжение,ТоварыПоРаспоряжениям,Склад,ТекущийРабочийУчасток,ТекущаяНакладная));
						
						ОтгружаемыеТовары = РО.ОтгружаемыеТовары.Выгрузить(); 
						РО.ОтгружаемыеТовары.Очистить();
						РО.ОтгружаемыеТовары.Загрузить(ПолучитьОтгружаемыеТоварыПоСекции(Распоряжение,ОтгружаемыеТовары,Склад,ТекущийРабочийУчасток,ТекущаяНакладная));
						ЗаполнитьНарезку(РО);

						РО.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
				КонецЦикла;
			Иначе
				Для каждого Строка из ОформОрдера.ОформленныеОрдера Цикл
					РО = Строка.РасходныйОрдер.ПолучитьОбъект();
					ТекущийДокумент = РО.Ссылка;
					РО.Накладная = ТекущаяНакладная;					
					РО.Контролер = ПолучитьПользователяСотрудника();
					РО.Сотрудник = Исполнитель;
					РО.ОтгрузкаПоЗаданиюНаПеревозку = Ложь;
					ЗаполнитьНарезку(РО); 
					
					РО.Записать(РежимЗаписиДокумента.Запись);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		

	Возврат ТекущийДокумент;
	
КонецФункции 

  &НаСервере
 Процедура ЗаполнитьНарезку(РасходныйОрдер)
     ПредРаспоряжение = Документы.РеализацияТоваровУслуг.ПустаяСсылка();
     
     Для каждого строка из РасходныйОрдер.ТоварыПоРаспоряжениям цикл 
    	Распоряжение = Строка.Распоряжение;
    	Если ПредРаспоряжение = Распоряжение Тогда
    		Прервать; 
    	Иначе 
    		ПредРаспоряжение = Распоряжение;
    		РаспоряжениеОбъект = Распоряжение.ПолучитьОбъект();
    		Если РаспоряжениеОбъект.Метаданные().ТабличныеЧасти.Найти("Нарезка")<>Неопределено
            И ЗначениеЗаполнено(Распоряжение.Нарезка) Тогда
    		   
    	    Для Каждого Строка Из Распоряжение.Нарезка Цикл
    			  ЗаполнитьЗначенияСвойств(РасходныйОрдер.Нарезка.Добавить(), Строка); 
    	    КонецЦикла; 
    		  
    	   КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    КонецПроцедуры
    


&НаКлиенте
Процедура ОрдераВРаботеОтгрузкаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	СсылкаНаЭлемент = Элементы.ОрдераВРаботеОтгрузка.ТекущиеДанные;
	ПараметрыФормы = Новый Структура("Ключ,Сотрудник,Секции", СсылкаНаЭлемент.Ссылка, Исполнитель, Секции.ВыгрузитьЗначения()); 

	ОткрытьФорму("Документ.РасходныйОрдерНаТовары.Форма.Док_ФормаДокументаДляТСД",
						ПараметрыФормы);
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивРаспоряжений(Накладная,МассивРаспоряжений)
	
	Распоряжение = Документы.ЗаказНаПеремещение.ПустаяСсылка();
	
	Если МассивРаспоряжений.Количество()=1 Тогда
		Если ТипЗнч(МассивРаспоряжений[0]) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			Распоряжение = МассивРаспоряжений[0];
		Иначе
			Возврат МассивРаспоряжений;
		КонецЕсли;
	Иначе
		Возврат МассивРаспоряжений;
	КонецЕсли;
	 
	Если Не Распоряжение.Пустая() Тогда
		  	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.ЗаказНаПеремещение КАК ЗаказНаПеремещение
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка = &Ссылка
		|	И ПеремещениеТоваровТовары.ЗаказНаПеремещение <> &ЗаказНаПеремещение
		|
		|СГРУППИРОВАТЬ ПО
		|	ПеремещениеТоваровТовары.ЗаказНаПеремещение";
	
	Запрос.УстановитьПараметр("Ссылка", Накладная);
	Запрос.УстановитьПараметр("ЗаказНаПеремещение", Распоряжение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивРаспоряжений.Добавить(ВыборкаДетальныеЗаписи.ЗаказНаПеремещение);
	КонецЦикла;
	
	Возврат МассивРаспоряжений;

	КонецЕсли;
	
КонецФункции

Функция ПолучитьОтгружаемыеТоварыПоСекции(Распоряжение,Таблица,Склад,Секция,Накладная)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
	|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
	|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
	|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ВнешняяТаблицаНоменклатуры.Действие КАК Действие,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
	|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
	|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
	|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
	|ИЗ
	|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
	|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
	|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
	|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ВнешняяТаблицаНоменклатуры.Действие КАК Действие,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
	|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
	|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
	|ИЗ
	|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВнешняяТаблицаНоменклатуры.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешняяТаблицаНоменклатуры.Номенклатура В(&МассивНоменклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Наименование";
	
	Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры",Таблица);
	Запрос.УстановитьПараметр("Склад",Склад);
	Запрос.УстановитьПараметр("РабочиеУчастки",Секция);
	Запрос.УстановитьПараметр("МассивНоменклатура",Накладная.Товары.ВыгрузитьКолонку("Номенклатура"));
	
	Результат = Запрос.Выполнить().Выгрузить();
	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") ИЛИ ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
		ТоварыПоНакладной = Накладная.Товары.Выгрузить();
		ТоварыПоНакладной.Свернуть("Номенклатура", "КоличествоУпаковок, Количество");
		Для Каждого Строка Из Результат Цикл
			Для Каждого СтрокаН Из ТоварыПоНакладной Цикл 
				Если Строка.Номенклатура = СтрокаН.Номенклатура И Строка.Количество > СтрокаН.Количество Тогда
					Строка.Количество = СтрокаН.Количество;
					Строка.КоличествоУпаковок = СтрокаН.КоличествоУпаковок;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
			
	Возврат Результат;

КонецФункции

Функция ПолучитьТоварыПоРаспоряжениямПоСекции(Распоряжение,Таблица,Склад,Секция,Накладная)
	ЗапросТ = Новый Запрос;
	ЗапросТ.Текст = 
	"ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
	|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
	|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ВнешняяТаблицаНоменклатуры.Распоряжение КАК Распоряжение,
	|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
	|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
	|ИЗ
	|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
	|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
	|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ВнешняяТаблицаНоменклатуры.Распоряжение КАК Распоряжение,
	|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
	|ИЗ
	|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВнешняяТаблицаНоменклатуры.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешняяТаблицаНоменклатуры.Номенклатура В(&МассивНоменклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Наименование";
	
	ЗапросТ.УстановитьПараметр("ВнешняяТаблицаНоменклатуры",Таблица);
	ЗапросТ.УстановитьПараметр("Склад",Склад);
	ЗапросТ.УстановитьПараметр("РабочиеУчастки",Секция);
    ЗапросТ.УстановитьПараметр("МассивНоменклатура",Накладная.Товары.ВыгрузитьКолонку("Номенклатура"));

	Результат = ЗапросТ.Выполнить().Выгрузить();
	Если ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") ИЛИ ТипЗнч(Распоряжение) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
		ТоварыПоНакладной = Накладная.Товары.Выгрузить();
		ТоварыПоНакладной.Свернуть("Номенклатура", "Количество");
		Для Каждого Строка Из Результат Цикл
			Для Каждого СтрокаН Из ТоварыПоНакладной Цикл 
				Если Строка.Номенклатура = СтрокаН.Номенклатура И Строка.Количество > СтрокаН.Количество Тогда
					Строка.Количество = СтрокаН.Количество;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;


КонецФункции

&НаСервере
Функция ПолучитьРасходныеОрдераПоНакладной(Документ,Секция)
	
	СтруктураВозврата = Новый Структура;
	
	МассивОрдеров = Новый Массив();
	МассивОрдеровВСтатусеПодготовлено = Новый Массив();
	МассивОрдеровВСтатусеВРаботе = Новый Массив();
	МассивОрдеровВСтатусеСобрано = Новый Массив();
	МассивОрдеровВСтатусеОтгружен = Новый Массив();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
		|ГДЕ
		|	РасходныйОрдерНаТовары.Проведен = ИСТИНА
		|	И РасходныйОрдерНаТовары.Накладная = &Накладная
		|	И РасходныйОрдерНаТовары.РабочийУчасток = &РабочийУчасток";
	
	Запрос.УстановитьПараметр("Накладная", Документ);
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		 МассивОрдеров.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
		 Если ВыборкаДетальныеЗаписи.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Подготовлен Тогда
			 МассивОрдеровВСтатусеПодготовлено.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
		 КонецЕсли;
		 Если ВыборкаДетальныеЗаписи.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке Тогда
			 МассивОрдеровВСтатусеСобрано.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
		 КонецЕсли;
		 Если ВыборкаДетальныеЗаписи.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтбору Тогда
			 МассивОрдеровВСтатусеВРаботе.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
		 КонецЕсли;
		 Если ВыборкаДетальныеЗаписи.Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
			 МассивОрдеровВСтатусеОтгружен.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
		 КонецЕсли;
	КонецЦикла;

	СтруктураВозврата.Вставить("МассивОрдеров",МассивОрдеров);
	СтруктураВозврата.Вставить("МассивОрдеровВСтатусеПодготовлено",МассивОрдеровВСтатусеПодготовлено);
    СтруктураВозврата.Вставить("МассивОрдеровВСтатусеВРаботе",МассивОрдеровВСтатусеВРаботе);
    СтруктураВозврата.Вставить("МассивОрдеровВСтатусеСобрано",МассивОрдеровВСтатусеСобрано);
    СтруктураВозврата.Вставить("МассивОрдеровВСтатусеОтгружен",МассивОрдеровВСтатусеОтгружен);

	ИзменитьСтатусы = Ложь;
	ОжидаетсяОтбор = Ложь;
	
	Если ТипЗнч(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Если Документ.РеализацияПоЗаказам Тогда
			
			ИзменитьСтатусы = Истина;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
			|	РеализацияТоваровУслугТовары.Характеристика КАК Характеристика,
			|	РеализацияТоваровУслугТовары.Назначение КАК Назначение,
			|	СУММА(РеализацияТоваровУслугТовары.КоличествоУпаковок) КАК КоличествоУпаковок1
			|ПОМЕСТИТЬ ВТ_РТ
			|ИЗ
			|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
			|		ПО (РеализацияТоваровУслугТовары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
			|				И РеализацияТоваровУслугТовары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад)
			|ГДЕ
			|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
			|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочийУчасток
			|
			|СГРУППИРОВАТЬ ПО
			|	РеализацияТоваровУслугТовары.Номенклатура,
			|	РеализацияТоваровУслугТовары.Характеристика,
			|	РеализацияТоваровУслугТовары.Назначение
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура КАК Номенклатура,
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика КАК Характеристика,
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Назначение КАК Назначение,
			|	СУММА(РасходныйОрдерНаТоварыОтгружаемыеТовары.КоличествоУпаковок) КАК КоличествоУпаковок
			|ПОМЕСТИТЬ ВТ_РО
			|ИЗ
			|	Документ.РасходныйОрдерНаТовары.ОтгружаемыеТовары КАК РасходныйОрдерНаТоварыОтгружаемыеТовары
			|ГДЕ
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Накладная = &Ссылка
			|	И РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Проведен
			|	И РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.РабочийУчасток = &РабочийУчасток
			|	И НЕ РасходныйОрдерНаТоварыОтгружаемыеТовары.Ссылка.Статус = &Статус
			|
			|СГРУППИРОВАТЬ ПО
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Номенклатура,
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Характеристика,
			|	РасходныйОрдерНаТоварыОтгружаемыеТовары.Назначение
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ИСТИНА КАК ОжидаетсяОтбор
			|ИЗ
			|	ВТ_РТ КАК ВТ_РТ
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РО КАК ВТ_РО
			|		ПО ВТ_РТ.Номенклатура = ВТ_РО.Номенклатура
			|			И ВТ_РТ.Характеристика = ВТ_РО.Характеристика
			|			И ВТ_РТ.Назначение = ВТ_РО.Назначение
			|
			|ИМЕЮЩИЕ
			|	МАКСИМУМ(ЕСТЬNULL(ВТ_РТ.КоличествоУпаковок1, 0) - ЕСТЬNULL(ВТ_РО.КоличествоУпаковок, 0)) > 0";
			
			Запрос.УстановитьПараметр("Ссылка", Документ); 
			Запрос.УстановитьПараметр("РабочийУчасток", Секция);
			Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
			
			ОжидаетсяОтбор = Не Запрос.Выполнить().Пустой();
			
		КонецЕсли;
	КонецЕсли;
	
	СтруктураВозврата.Вставить("ИзменитьСтатусы",ИзменитьСтатусы);
	СтруктураВозврата.Вставить("ОжидаетсяОтбор",ОжидаетсяОтбор);   
	
	Возврат СтруктураВозврата;
	
КонецФункции

Функция ПолучитьСтатусОрдера(РасходныйОрдер)
	Возврат РасходныйОрдер.Статус;
КонецФункции

&НаКлиенте
Процедура ОбновитьОтгрузку(Команда)
	УстанавливаемЗначенияПараметровДинамическихСписковОтгрузка(); 
