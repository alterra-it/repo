Функция ПолучитьОрдерПоСекцииИРаспоряжению(Секция,Распоряжение)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Распоряжение = &Распоряжение
		|	И ПриходныйОрдерНаТовары.РабочийУчасток = &РабочийУчасток
		|	И ПриходныйОрдерНаТовары.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса.ВыгрузитьКолонку("Ссылка");
	
КонецФункции	

&НаКлиенте
Процедура ПриемкаПоРейсуОрдера(Команда)
	
	СозданныеОрдера = Новый Массив();
	
	Для каждого Строка из Элементы.ОрдераВРаботе.ВыделенныеСтроки Цикл
		
		ДанныеСтроки = Элементы.ОрдераВРаботе.ДанныеСтроки(Строка);
		
		СозданныеОрдера.Добавить(ДанныеСтроки.Ссылка);
		
	КонецЦикла;        
	
	ОчиститьСообщения();
	
	ОткрытьФорму("Обработка.РабочееМестоКладовщикаАльтерра.Форма.ФормаПриемПоРейсу", Новый Структура("Сотрудник,СписокОрдеров",Исполнитель,СозданныеОрдера));

КонецПроцедуры

