
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Сотрудник") Тогда
		Сотрудник = Параметры.Сотрудник;
		Склад = Сотрудник.Склад;
		Подразделение = Сотрудник.Подразделение;
		
		ЭтоКладовщик = ?(Сотрудник.РольМобильногоКлиента = Перечисления.РолиМобильногоКлиента.Кладовщик,Истина,Ложь);
		
		//+ Для тестов
		//ЭтоКладовщик = Истина;
		//-
	Иначе
		Отказ = Истина;
	КонецЕсли;  
	
	 Если ЭтоКладовщик Тогда
		
		ЭтаФорма.Заголовок = "Проверить остатки";
		
		СекцииСотрудника = Сотрудник.РабочиеУчастки.Выгрузить();
		Если СекцииСотрудника.Количество()>0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДоступныеЯчейки, "РабочийУчасток", СекцииСотрудника.ВыгрузитьКолонку("РабочийУчасток"), ВидСравненияКомпоновкиДанных.ВСписке,,Истина);	
		КонецЕсли;
		
	КонецЕсли; 
	Если АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков() Тогда
		Для каждого Секция Из Сотрудник.РабочиеУчастки Цикл
			Если Секция.РабочийУчасток.СкрытьКоличествоПоУчету Тогда
				Элементы.ГруппаОстаток.Видимость = Ложь;
				ЭтаФорма.Заголовок = "Карточка товара с АХ";
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	//Подключение оповещений из очереди
	СообщениеОбработано = Истина;
	Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
		Если Не ПолучитьСостояниеОповещений() Тогда
			ОповещенияИзОчереди = Истина;
		Иначе
			ОповещенияИзОчереди = Сотрудник.ОповещенияИзОчереди; 
		КонецЕсли;
	Иначе 
		ОповещенияИзОчереди = Ложь; 	
	КонецЕсли; 
	Инт = 60;    
	СекцииСотрудника = СекцииСотрудника();
	Для каждого Стр Из СекцииСотрудника Цикл
		ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
		Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
			Инт = ЗнчИнтервала;
		КонецЕсли; 
	КонецЦикла; 
	ИнтервалОповещений = Инт;

	//+
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма); 
	//-

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	//+
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено,ЭтаФорма, "СканерШтрихкода");
	//-                  
	Если ОповещенияИзОчереди Тогда
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);
		ПроверкаЭлектроннойОчереди(); 
	Иначе 
		Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
	КонецЕсли;
	ИнициализироватьСканер();
КонецПроцедуры

&НаКлиенте
Процедура ИнициализироватьСканер()
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		Попытка   //+
			глВКRSDriver.УстановитьПараметр("Barcode_BEEP",Истина);
			глВКRSDriver.УстановитьПараметр("Barcode_BZZ",Истина);
			глВКRSDriver.Подключить("Barcode");	
		Исключение //-
		КонецПопытки; //-

		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОтключитьСканер()
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		Попытка
			глВКRSDriver.Отключить("Barcode");	
		Исключение
		КонецПопытки;
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник) 
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "Barcode" Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;
			
			Данные = ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Штрихкод1);
			
			Штрихкод = Данные.Штрихкод;
			
			Если ПустаяСтрока(Штрихкод) Тогда
				Элементы.Декорация1.Заголовок = "Не удалось прочитать штрихкод! Считайте штрихкод еще раз!";
				Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
				Если ЭтоКладовщик Тогда
					Элементы.ГруппаСклад.Видимость=Ложь;
				Иначе
					Элементы.ГруппаНоменклатура.Видимость=Ложь;
				КонецЕсли;
				Возврат;
			КонецЕсли;
			
			Если Элементы.ГруппаСклад.Видимость = Ложь И Элементы.ВыборЯчейки.Видимость = Истина Тогда
				 ОбработатьШтрихкод(Штрихкод1[0]);
			КонецЕсли;
			
			СтруктураДанных = НоменклатураПоШтрихкоду(Штрихкод,Подразделение,Склад);
			
			Если ЗначениеЗаполнено(СтруктураДанных.Номенклатура)  Тогда
				Номенклатура = СтруктураДанных.Номенклатура; 
				Характеристика = СтруктураДанных.Характеристика; 
				ТочкаПересчета = СтруктураДанных.ТочкаПересчета;
				Упаковка =  СтруктураДанных.Упаковка; 
				ОстатокТЗ =  СтруктураДанных.ОстаткиТЗ;
				ОстатокНаСкладе = СтруктураДанных.ОстатокНаСкладе;
				Ячейка = СтруктураДанных.Ячейка;
				ЦенаПоКарте = СтруктураДанных.ЦенаПоКарте; 
				ЦенаБезКарты = СтруктураДанных.ЦенаБезКарты;
				Попытка
					ПолучитьАдресКартинки(Номенклатура);
				Исключение
				КонецПопытки;
				
				Элементы.Декорация1.Видимость = Ложь;
				Если ЭтоКладовщик Тогда
					Элементы.ГруппаСклад.Видимость=Истина;
				Иначе
					Элементы.ГруппаНоменклатура.Видимость=Истина;
				КонецЕсли;
			Иначе
				Элементы.Декорация1.Заголовок = "Не удалось прочитать штрихкод! Считайте штрихкод еще раз!";
				Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
				Если ЭтоКладовщик Тогда
					Элементы.ГруппаСклад.Видимость=Ложь;
				Иначе
					Элементы.ГруппаНоменклатура.Видимость=Ложь;
				КонецЕсли;
				Возврат;
			КонецЕсли;
			
			
			
		КонецЕсли;
	КонецЕсли;
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаСервереБезКонтекста
Функция НоменклатураПоШтрихкоду(ШтрихкодНоменклатуры,Подразделение,Склад)
	
	СтруктураДанныхОтвета = Новый Структура("Номенклатура,Характеристика,ТочкаПересчета, Упаковка,ОстаткиТЗ,ЦенаБезКарты,ЦенаПоКарте,ОстатокНаСкладе,Ячейка",,,,,);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Упаковка КАК Упаковка,
	|	ТочкиПересчетаОбучение.Наименование КАК ТочкаПересчета
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ТочкиПересчетаОбучение КАК ТочкиПересчетаОбучение
	|			ПО ВидыНоменклатуры.ТочкаПересчетаОбучение = ТочкиПересчетаОбучение.Ссылка
	|		ПО ШтрихкодыНоменклатуры.Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 
	|ВЫБРАТЬ
	|	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
	|	ВТ_Номенклатура.Характеристика КАК Характеристика,
	|	ВТ_Номенклатура.ТочкаПересчета КАК ТочкаПересчета,
	|	ВТ_Номенклатура.Упаковка КАК Упаковка,
	|	РаспределениеЗапасов.ВНаличии - РаспределениеЗапасов.Резерв КАК ОстаткиТЗ,
	|	ЦенаБезКарты.Цена КАК ЦенаБезКарты,
	|	ЦенаПоКарте.Цена КАК ЦенаПоКарте,
	|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ОстатокНаСкладе,
	|	ТоварыНаСкладахОстатки.Склад КАК Склад,
	|	ТоварыНаСкладахОстатки.Помещение КАК Помещение
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	ВТ_Номенклатура КАК ВТ_Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
	|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК ВНаличии,
	|			СУММА(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Резерв
	|		ИЗ
	|			РегистрНакопления.ЗапасыИПотребности.Остатки(
	|					,
	|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|						И Склад = &СкладТЗ) КАК ЗапасыИПотребностиОстатки
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗапасыИПотребностиОстатки.Номенклатура,
	|			ЗапасыИПотребностиОстатки.Характеристика) КАК РаспределениеЗапасов
	|		ПО ВТ_Номенклатура.Номенклатура = РаспределениеЗапасов.Номенклатура
	|			И ВТ_Номенклатура.Характеристика = РаспределениеЗапасов.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦены = &БезКарты) КАК ЦенаБезКарты
	|		ПО ВТ_Номенклатура.Номенклатура = ЦенаБезКарты.Номенклатура
	|			И ВТ_Номенклатура.Характеристика = ЦенаБезКарты.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦены = &ПоКарте) КАК ЦенаПоКарте
	|		ПО ВТ_Номенклатура.Номенклатура = ЦенаПоКарте.Номенклатура
	|			И ВТ_Номенклатура.Характеристика = ЦенаПоКарте.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(, Склад = &СкладТЗ) КАК ТоварыНаСкладахОстатки
	|		ПО ВТ_Номенклатура.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|			И ВТ_Номенклатура.Характеристика = ТоварыНаСкладахОстатки.Характеристика
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Номенклатура КАК Номенклатура,
	|	ВТ.Характеристика КАК Характеристика,
	|	ВТ.ТочкаПересчета КАК ТочкаПересчета,
	|	ВТ.Упаковка КАК Упаковка,
	|	ВТ.ОстаткиТЗ КАК ОстаткиТЗ,
	|	ВТ.ЦенаБезКарты КАК ЦенаБезКарты,
	|	ВТ.ЦенаПоКарте КАК ЦенаПоКарте,
	|	ВТ.ОстатокНаСкладе КАК ОстатокНаСкладе,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
	|ИЗ
	|	ВТ КАК ВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВТ.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И ВТ.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|			И ВТ.Помещение = РазмещениеНоменклатурыПоСкладскимЯчейкам.Помещение";
	
	Запрос.УстановитьПараметр("Штрихкод", ШтрихкодНоменклатуры);
	Запрос.УстановитьПараметр("СкладТЗ", Склад);
	Запрос.УстановитьПараметр("ПоКарте", Подразделение.ЦенаПоКарте);
    Запрос.УстановитьПараметр("БезКарты", Подразделение.ЦенаБезКарты);

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ЗаполнитьЗначенияСвойств(СтруктураДанныхОтвета,Выборка);
				
	КонецЕсли;	
	
	Возврат СтруктураДанныхОтвета;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкод(Штрихкод1) 
	
	СсылкаНаЯчейку = ПолучитьЯчейкуПоШтрихкоду(Штрихкод1); 
	Если СсылкаНаЯчейку <> Неопределено Тогда
		ДоступныеЯчейки.Отбор.Элементы.Очистить();
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДоступныеЯчейки, "Ссылка", СсылкаНаЯчейку, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	Иначе
		Сообщить("Ячейка не найдена!");
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьЯчейкуПоШтрихкоду(ШтрихКод1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладскиеЯчейки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
	|ГДЕ
	|	СкладскиеЯчейки.Штрихкод = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод1);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда	
		Возврат ВыборкаДетальныеЗаписи.Ссылка;   
	Иначе 
		Возврат Неопределено; 
	КонецЕсли;
КонецФункции



