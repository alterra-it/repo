&НаКлиенте
Процедура СчитатьШтрихкод(Команда)
	#Если МобильныйКлиент Тогда
		Если СредстваМультимедиа.ПоддерживаетсяСканированиеШтрихКодов() Тогда
			ОповещениеСканирования = Новый ОписаниеОповещения("ОбработкаОтсканированногоШтрихкода",ЭтотОбъект);
			СредстваМультимедиа.ПоказатьСканированиеШтрихКодов("Scan code",ОповещениеСканирования,,ТипШтрихкода.Все);
		Иначе
			Сообщить("Сканирование не поддерживается!");
		КонецЕсли;
	#КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтсканированногоШтрихкода(Штрихкод,Результат,Сообщение,ДопПараметры) Экспорт
	
	Если Результат и ЗначениеЗаполнено(Штрихкод) Тогда
		
		#Если МобильныйКлиент Тогда
		    СредстваМультимедиа.ЗакрытьСканированиеШтрихКодов();
		#КонецЕсли
		
		    Если ПустаяСтрока(Штрихкод) Тогда
				Элементы.Декорация1.Заголовок = "Не удалось прочитать штрихкод! Считайте штрихкод еще раз!";
				Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
				Элементы.Декорация1.Видимость = Истина;
				ЭтаФорма.Элементы.ГруппаГлавноеМеню.Видимость = Ложь;
				Возврат;
			КонецЕсли;
			
			СтруктураДанных = НоменклатураПоШтрихкоду(Штрихкод,Подразделение,Склад);
			
			Если ЗначениеЗаполнено(СтруктураДанных.Номенклатура)  Тогда
				Номенклатура = СтруктураДанных.Номенклатура; 
				Характеристика = СтруктураДанных.Характеристика; 
				ТочкаПересчета = СтруктураДанных.ТочкаПересчета;
				Упаковка =  СтруктураДанных.Упаковка; 
				ОстатокТЗ =  СтруктураДанных.ОстаткиТЗ;
				ОстатокНаСкладе = СтруктураДанных.ОстатокНаСкладе;
				Ячейка = СтруктураДанных.Ячейка;
				ЦенаПоКарте = СтруктураДанных.ЦенаПоКарте; 
				ЦенаБезКарты = СтруктураДанных.ЦенаБезКарты;
				Попытка
					ПолучитьАдресКартинки(Номенклатура);
				Исключение
				КонецПопытки;
				
				Элементы.Декорация1.Видимость = Ложь;
				Если ЭтоКладовщик Тогда
					Элементы.ГруппаСклад.Видимость=Истина;
				Иначе
					Элементы.ГруппаНоменклатура.Видимость=Истина;
				КонецЕсли;
			Иначе
				Элементы.Декорация1.Заголовок = "Не удалось прочитать штрихкод! Считайте штрихкод еще раз!";
				Элементы.Декорация1.ЦветТекста= WebЦвета.Красный;
				Если ЭтоКладовщик Тогда
					Элементы.ГруппаСклад.Видимость=Ложь;
				Иначе
					Элементы.ГруппаНоменклатура.Видимость=Ложь;
				КонецЕсли;
				Возврат;
			КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура _ВернутьсяКТЧ(Команда)
		
	Элементы.Декорация1.Заголовок = "Считайте штрихкод номенклатуры";
