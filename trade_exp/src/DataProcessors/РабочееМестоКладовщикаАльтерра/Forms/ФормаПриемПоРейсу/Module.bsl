&НаКлиенте
Процедура СортироватьПоВесу(Команда)
	
	Действия = Новый Структура();
	Действия.Вставить("ЗаполнитьВесУпаковки",Новый Структура("Номенклатура, Упаковка", "ВесУпаковки"));
	Действия.Вставить("ЗаполнитьОбъемУпаковки",Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки"));
	Действия.Вставить("ПересчитатьВесОбъем");
	Для каждого Строка Из Объект.Товары Цикл
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(Строка, Действия, КэшированныеЗначения);
		Строка.Вес = Строка.КоличествоПлан*Строка.ВесУпаковки;
	КонецЦикла; 

	СортироватьСтроки("ТоварыВес", "УБЫВ");
	Элементы.ТоварыВес.Видимость = Ложь;
	Элементы.ТоварыВесУпаковки.Видимость = Ложь;
	Элементы.ТоварыЯчейка.Видимость = Истина;
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаСервере
Процедура СортироватьСтроки(ИмяКолонки, Направление)
	ИмяКолонкиНаправление = СтрЗаменить(Элементы[ИмяКолонки].ПутьКДанным, "Объект.Товары.","") + " " + Направление; 
	
	Объект.Товары.Сортировать(ИмяКолонкиНаправление);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ЗаполнениеИИнициализация

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыТЧТовары(Перенумеровать = Истина, КэшированныеЗначения = Неопределено)
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьВесОбъем");
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
		Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры",
		Новый Структура("Номенклатура", "ТипНоменклатуры"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул",
		Новый Структура("Номенклатура", "Артикул"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
	СтруктураДействий.Вставить("ЗаполнитьВесУпаковки",Новый Структура("Номенклатура, Упаковка", "ВесУпаковки"));
	СтруктураДействий.Вставить("ЗаполнитьОбъемУпаковки",Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки"));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияВеса",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса"));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияОбъема",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема"));
		
	// Для заполнения признака ШтрихкодНеОпределен получим данные по штрихкодам
	ТЗШтрихкоды = Объект.Товары.Выгрузить(,"Штрихкод");
	ТЗШтрихкоды.Свернуть("Штрихкод");
	МассивШтрихкодов = ТЗШтрихкоды.ВыгрузитьКолонку("Штрихкод");
	
	КешированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодам(КешированныеЗначения, МассивШтрихкодов);
	
	Если Объект.Товары.НайтиСтроки(Новый Структура("ЭтоУпаковочныйЛист", Истина)).Количество() > 0 Тогда
		Документы.УпаковочныйЛист.ДополнитьДанныеПоШтрихкодам(КешированныеЗначения, МассивШтрихкодов);
	КонецЕсли;
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьПризнакТовМестаТребуетсяОбработка");
	
	Для Каждого СтрокаТЧ Из Объект.Товары Цикл
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Штрихкод)
			Или ЗначениеЗаполнено(КешированныеЗначения.Штрихкоды[СтрокаТЧ.Штрихкод])
				И КешированныеЗначения.Штрихкоды[СтрокаТЧ.Штрихкод].Количество() > 0 Тогда
			СтрокаТЧ.ШтрихкодНеОпределен = 0;
		Иначе
			СтрокаТЧ.ШтрихкодНеОпределен = 1;
		КонецЕсли;
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТЧ, СтруктураДействий, Неопределено);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПлановоеКоличество()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПриходныйОрдерНаТовары.Распоряжение КАК Распоряжение
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Ссылка В (&Ссылка)";
	
	Запрос.УстановитьПараметр("Ссылка", СписокОрдеров.ВыгрузитьЗначения());
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Распоряжение", РезультатЗапроса);
	Запрос.УстановитьПараметр("Ордера", СписокОрдеров.ВыгрузитьЗначения());
	Запрос.УстановитьПараметр("ДатаОстатков", КонецДня(ТекущаяДата()));
	
	ТекстЗапроса =
	    "ВЫБРАТЬ
	    |	ТоварыКПоступлению.Номенклатура КАК Номенклатура,
	    |	ТоварыКПоступлению.Характеристика КАК Характеристика,
	    |	ВЫБОР
	    |		КОГДА ЕСТЬNULL(ТоварыКПоступлению.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
	    |			ТОГДА ТоварыКПоступлению.Назначение
	    |		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	    |	КОНЕЦ КАК Назначение,
	    |	СУММА(ТоварыКПоступлению.Количество) КАК КоличествоПлан,
	    |	ТоварыКПоступлению.Распоряжение КАК Распоряжение
	    |ИЗ
	    |	(ВЫБРАТЬ
	    |		ТоварыКПоступлению.Номенклатура КАК Номенклатура,
	    |		ТоварыКПоступлению.Характеристика КАК Характеристика,
	    |		ТоварыКПоступлению.Назначение КАК Назначение,
	    |		ТоварыКПоступлению.КОформлениюОрдеровОстаток - ТоварыКПоступлению.ПринимаетсяОстаток КАК Количество,
	    |		ТоварыКПоступлению.ДокументПоступления КАК Распоряжение
	    |	ИЗ
	    |		РегистрНакопления.ТоварыКПоступлению.Остатки(&ДатаОстатков, ДокументПоступления В (&Распоряжение)) КАК ТоварыКПоступлению
	    |	
	    |	ОБЪЕДИНИТЬ ВСЕ
	    |	
	    |	ВЫБРАТЬ
	    |		ТоварыКПоступлению.Номенклатура,
	    |		ТоварыКПоступлению.Характеристика,
	    |		ТоварыКПоступлению.Назначение,
	    |		ВЫБОР
	    |			КОГДА ТоварыКПоступлению.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	    |				ТОГДА -ТоварыКПоступлению.КОформлениюОрдеров
	    |			ИНАЧЕ ТоварыКПоступлению.КОформлениюОрдеров
	    |		КОНЕЦ - ВЫБОР
	    |			КОГДА ТоварыКПоступлению.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	    |				ТОГДА -ТоварыКПоступлению.Принимается
	    |			ИНАЧЕ ТоварыКПоступлению.Принимается
	    |		КОНЕЦ,
	    |		ТоварыКПоступлению.ДокументПоступления
	    |	ИЗ
	    |		РегистрНакопления.ТоварыКПоступлению КАК ТоварыКПоступлению
	    |	ГДЕ
	    |		ТоварыКПоступлению.Активность
		|		И ТоварыКПоступлению.Регистратор В(&Ордера)
	    |		И ТоварыКПоступлению.ДокументПоступления В(&Распоряжение)) КАК ТоварыКПоступлению
	    |
	    |СГРУППИРОВАТЬ ПО
	    |	ТоварыКПоступлению.Номенклатура,
	    |	ТоварыКПоступлению.Характеристика,
	    |	ТоварыКПоступлению.Назначение,
	    |	ВЫБОР
	    |		КОГДА ЕСТЬNULL(ТоварыКПоступлению.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
	    |			ТОГДА ТоварыКПоступлению.Назначение
	    |		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	    |	КОНЕЦ,
	    |	ТоварыКПоступлению.Распоряжение
	    |
	    |ИМЕЮЩИЕ
	    |	СУММА(ТоварыКПоступлению.Количество) > 0";
	
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.Выполнить();
	ТоварыПоРаспоряжению.Загрузить(Результат.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОжидание() Экспорт
	
	Если Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.Принят") Тогда
		Возврат;
	КонецЕсли;
	
	АктивнаСтрокаРедактирования = Элементы._РедактированиеСтрокиНаТСД.Видимость;
	
	Если АктивнаСтрокаРедактирования Тогда
		НомерСтроки = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД).НомерСтроки;
	КонецЕсли;
	
	Если ЗаписатьИзменениеТабличнойЧасти() Тогда
		
		ЗаполнитьПлановоеКоличествоВТаблице();
		ЗаполнитьПризнакРасхождение();
		ЗаполнитьТоварыЯчейка();
		
		Если АктивнаСтрокаРедактирования Тогда
			ТекущаяСтрокаТСД = Объект.Товары[НомерСтроки-1].ПолучитьИдентификатор();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьИзменениеТабличнойЧасти() 
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДобавитьТоварыБезОрдераКПервомуОрдеру();
	
	ДанныеИзменены = Ложь;
	
	Для Каждого Ордер Из СписокОрдеров Цикл
		ОбъектОрдер = Ордер.Значение.ПолучитьОбъект();
		
		Если ОбъектОрдер.Статус = Перечисления.СтатусыПриходныхОрдеров.Принят Тогда
			Продолжить;
		КонецЕсли;
		
		ТЗТовары = ВернутьДанныеПоОрдеру(ОбъектОрдер.Ссылка);
		
		Если АльтерраОбщегоНазначения.ТабличнаяЧастьИзменилась(ОбъектОрдер.Товары.Выгрузить(), ТЗТовары) Тогда
			ОбъектОрдер.ВсегоМест = УпаковочныеЛистыСервер.КоличествоМестВТЧ(ТЗТовары);
			ОбъектОрдер.Товары.Загрузить(ТЗТовары);
			
			Если ЗначениеЗаполнено(НомерВходящегоДокумента) И ОбъектОрдер.НомерВходящегоДокумента <> НомерВходящегоДокумента Тогда
				ОбъектОрдер.НомерВходящегоДокумента = НомерВходящегоДокумента;
			КонецЕсли;

			Если ЗначениеЗаполнено(ДатаВходящегоДокумента) И ОбъектОрдер.ДатаВходящегоДокумента <> ДатаВходящегоДокумента Тогда
				ОбъектОрдер.ДатаВходящегоДокумента = ДатаВходящегоДокумента
			КонецЕсли;
		
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ОбъектОрдер, Истина);
			
			ДанныеИзменены = Истина;
		КонецЕсли;
	КонецЦикла;   
	
	Возврат ДанныеИзменены;
	
КонецФункции

#КонецОбласти

#Область ШтрихкодыИТорговоеОборудование

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов)
	
	СтруктураДействийСДобавленнымиСтроками = Новый Структура("ПересчитатьКоличествоЕдиниц");
				
	СтруктураДействийСИзмененнымиСтроками = Новый Структура("ПересчитатьКоличествоЕдиниц");
	
	СтруктураДействий = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	СтруктураДействий.Штрихкоды                              = ДанныеШтрихкодов;
	СтруктураДействий.СтруктураДействийСДобавленнымиСтроками = СтруктураДействийСДобавленнымиСтроками;
	СтруктураДействий.СтруктураДействийСИзмененнымиСтроками  = СтруктураДействийСИзмененнымиСтроками;
	СтруктураДействий.НеИспользоватьУпаковки                 = Истина;   
	СтруктураДействий.ШтрихкодыВТЧ                           = Истина;
	СтруктураДействий.ИмяТЧ                                  = "Товары";
	СтруктураДействий.ИмяКолонкиКоличество                   = "КоличествоУпаковок";
	СтруктураДействий.БлокироватьДанныеФормы                 = Истина;
	
	Если АльтерраОбщегоНазначения._РольДоступна("РаботаСТСД") Тогда
		СтруктураДействий.ДействияСНеизвестнымиШтрихкодами = "НетДействий";
	КонецЕсли;
	
	СтароеКоличествоСтрок = Объект.Товары.Количество();
	
	ОбработатьШтрихкодыСервер(СтруктураДействий,КэшированныеЗначения);
	
	Если СтароеКоличествоСтрок <> Объект.Товары.Количество() Тогда
   		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОбработатьШтрихкодыДалее", ЭтотОбъект, СтруктураДействий), 
			"Выбранный товар не найден в ордерах. Добавить его?", 
			РежимДиалогаВопрос.ДаНет);
	Иначе
		ОбработатьШтрихкодыИтог(СтруктураДействий);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкодыДалее(Результат, СтруктураДействий) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработатьШтрихкодыИтог(СтруктураДействий);
	Иначе
		Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
			Объект.Товары.Удалить(Объект.Товары.НайтиПоИдентификатору(СтруктураДействий.ТекущаяСтрока));
		КонецЕсли;
	КонецЕсли;	
 
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкодыИтог(СтруктураДействий)    
	
	Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
		Элементы.Товары.ТекущаяСтрока = СтруктураДействий.ТекущаяСтрока;
	КонецЕсли;
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		ТекущаяСтрокаТСД = СтруктураДействий.ТекущаяСтрока;
		ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
		
		Если типзнч(ЭлементСписка) <> Тип("Неопределено") Тогда
			Если ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоПлан Тогда
				
				Элементы._РедактированиеДокументаНаТСД.Видимость=Истина;
				Элементы._РедактированиеСтрокиНаТСД.Видимость=Ложь;
				
				ЗаполнитьПризнакРасхождение();
				
			Иначе
							
				Элементы._РедактированиеДокументаНаТСД.Видимость=Ложь;
				Элементы._РедактированиеСтрокиНаТСД.Видимость=Истина;
				
				НоваяЯчейка = "";
				НовыйШтрихкод = "";
				
				ТекущийОрдер = ЭлементСписка.Ссылка;
			    Распоряжение = ЭлементСписка.Распоряжение;
				Номенклатура = ЭлементСписка.Номенклатура;
				Характеристика = ЭлементСписка.Характеристика;
				Количество = ЭлементСписка.КоличествоУпаковок;
				ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;
				ПоУчету = ЭлементСписка.КоличествоПлан;
				Комментарий = ЭлементСписка.Комментарий;
				ПолучитьЯчейку(Номенклатура, Склад);
				ПолучитьАдресКартинки(Номенклатура);
	        Конецесли;
		Иначе
				Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
				СредстваМультимедиа.ВоспроизвестиТекст("Товар не найден!","ru-RU");	
				КонецЕсли;
			ОбщегоНазначенияКлиент.СообщитьПользователю("Штрихкод не найден!");
		КонецЕсли;
		
	#КонецЕсли

    ЭтаФорма.ОбновитьОтображениеДанных();	
КонецПроцедуры

&НаСервере
Процедура ОбработатьШтрихкодыСервер(СтруктураДействий,КэшированныеЗначения)
	
	ШтрихкодированиеНоменклатурыСервер.ОбработатьШтрихкоды(ЭтаФорма,Объект,СтруктураДействий,КэшированныеЗначения);
	
	Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
		СтруктураДействийСТекущейСтрокой = Новый Структура;
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьВесУпаковки",Новый Структура("Номенклатура, Упаковка", "ВесУпаковки"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьОбъемУпаковки",Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьЕдиницуИзмеренияВеса",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьЕдиницуИзмеренияОбъема",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема"));
		СтруктураДействийСТекущейСтрокой.Вставить("ПересчитатьВесОбъем");
		
		ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(СтруктураДействий.ТекущаяСтрока);

		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействийСТекущейСтрокой, КэшированныеЗначения);
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти
#КонецОбласти

#Область Прочее

&НаКлиентеНаСервереБезКонтекста
Функция ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(Форма, Действия)
	
	Действия.Вставить("ПересчитатьКоличествоЕдиниц");
	
КонецФункции

Процедура ПолучитьЯчейку(НоменклатураСсылка, СкладСсылка)
	Документы.ПриходныйОрдерНаТовары.ПолучитьЯчейку(НоменклатураСсылка, СкладСсылка, Ячейка);
КонецПроцедуры

&НаКлиенте
Процедура ПоФактуПриИзменении(Элемент)
	
	ИзменитьКоличествоВСтрокеПоИдентификатору(ТекущаяСтрокаТСД,Количество,Комментарий);
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
	
	СтруктураДействий = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ЭтотОбъект,СтруктураДействий);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);

КонецПроцедуры

&НаКлиенте
Процедура ИзменитьКоличествоВСтрокеПоИдентификатору(Идентификатор,Количество,ТекстКоммент)
	 СтрокаИзменения = Объект.Товары.НайтиПоИдентификатору(Идентификатор);
	 СтрокаИзменения.КоличествоУпаковок = Количество;
	 СтрокаИзменения.Количество = Количество;
	 СтрокаИзменения.Комментарий = ТекстКоммент; 
КонецПроцедуры

&НаКлиенте
Процедура КомментарийПриИзменении(Элемент)
	ИзменитьКоличествоВСтрокеПоИдентификатору(ТекущаяСтрокаТСД,Количество,Комментарий);
КонецПроцедуры

Функция ИзменитьЯчейку()
	Возврат Документы.ПриходныйОрдерНаТовары.ИзменитьЯчейку(Номенклатура, Склад, Ячейка, НоваяЯчейка);
КонецФункции

Процедура СоздатьШК(Штрихкод)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика,
	|	ШтрихкодыНоменклатуры.Упаковка,
	|	ШтрихкодыНоменклатуры.Номенклатура.Наименование КАК НоменклатураПредставление,
	|	ШтрихкодыНоменклатуры.Характеристика.Наименование КАК ХарактеристикаПредставление,
	|	ШтрихкодыНоменклатуры.Упаковка.Наименование КАК УпаковкаПредставление
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ОписаниеОшибки = НСтр("ru='Такой штрихкод уже назначен для номенклатуры %Номенклатура%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%Номенклатура%", """" + Выборка.НоменклатураПредставление + """"
		+ ?(ЗначениеЗаполнено(Выборка.Характеристика), " " + НСтр("ru='с характеристикой'") + " """ + Выборка.ХарактеристикаПредставление + """", "")
		+ ?(ЗначениеЗаполнено(Выборка.Упаковка), " " + НСтр("ru='в упаковке'") + " """ + Выборка.УпаковкаПредставление + """", ""));
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;
		Сообщение.Сообщить();
		
	Иначе
		МенеджерЗаписи = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Штрихкод = Штрихкод;
		МенеджерЗаписи.Номенклатура = Номенклатура;
		МенеджерЗаписи.Характеристика = Характеристика;

		МенеджерЗаписи.Записать();
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Штрихкод записан!";
		Сообщение.Сообщить();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ДоступныеЯчейкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Элементы._РедактированиеСтрокиНаТСД.Видимость=Истина;
	Элементы._ВыборЯчейки.Видимость = Ложь;

	НоваяЯчейка = Элементы.ДоступныеЯчейки.ТекущиеДанные.Ссылка;
	Если ИзменитьЯчейку() Тогда
			ПолучитьЯчейку(Номенклатура, Склад);	
			Сообщить("Ячейка изменена!");
	Иначе
			Ячейка = "";
			Сообщить("При измененеии ячейки произошли проблемы! Ячейка не изменена!");
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура НоменклатураПриИзмененииСервер(КэшированныеЗначения)
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(Элементы.Товары.ТекущаяСтрока);
	
	СтруктураДействийСТекущейСтрокой = Новый Структура;
	СтруктураДействийСТекущейСтрокой.Вставить("ПроверитьХарактеристикуПоВладельцу", ТекущаяСтрока.Характеристика);
	СтруктураДействийСТекущейСтрокой.Вставить("ПроверитьЗаполнитьУпаковкуПоВладельцу", ТекущаяСтрока.Упаковка);
	СтруктураДействийСТекущейСтрокой.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействийСТекущейСтрокой.Вставить("НоменклатураПриИзмененииПереопределяемый", Новый Структура("ИмяФормы, ИмяТабличнойЧасти",
		ЭтаФорма.ИмяФормы, "Товары"));
		
	УпаковочныеЛистыСервер.НоменклатураУпаковочныйЛистПриИзменении(ЭтаФорма, Объект.Товары,
		"ТоварыНоменклатура", КэшированныеЗначения, СтруктураДействийСТекущейСтрокой);
		
	
КонецПроцедуры

