#Область НеопознанныйТовар

&НаКлиенте
Процедура _НеопознанныйТовар(Команда)
	
	Если ЗначениеЗаполнено(ПервыйОрдер) Тогда
		НеопознанныйТовар = ПолучитьНеопознанныйТовар(ПервыйОрдер);
		Если ЗначениеЗаполнено(НеопознанныйТовар) Тогда	
			Если ТипЗнч(ПервыйОрдерРаспоряжение) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
				Оповещение = Новый ОписаниеОповещения("ДобавитьНеопознанныйТоварЗавершение", ЭтотОбъект); 
				
				ПараметрыФормы = Новый Структура();
				ПараметрыФормы.Вставить("Номенклатура", НеопознанныйТовар);
				ПараметрыФормы.Вставить("ЗаказПоставщику", ПервыйОрдерРаспоряжение); 
				ПараметрыФормы.Вставить("ПриходныйОрдерНаТовары", ПервыйОрдер);

				ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.Док_НеопознаннаяНоменклатура", ПараметрыФормы, ЭтаФорма, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			Иначе
				ДобавитьНеопознанныйТоварЗавершение(НеопознанныйТовар, Неопределено);
			КонецЕсли;
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю("Не удалось получить неопознанный товар");
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНеопознанныйТовар(Ордер)
	Возврат Документы.ПриходныйОрдерНаТовары.ПолучитьНеопознанныйТовар(Ордер.Склад, Ордер.Номер);
КонецФункции

&НаКлиенте
Процедура ДобавитьНеопознанныйТоварЗавершение(НеопознанныйТовар, ДопПараметры) Экспорт
	Если ЗначениеЗаполнено(НеопознанныйТовар) Тогда
		НоваяСтрока = Объект.Товары.Добавить();
		ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		НоваяСтрока.Номенклатура = НеопознанныйТовар;
		ВвестиЧисло(Количество, "Введите количество");
		НоваяСтрока.КоличествоУпаковок = Количество;
		НоваяСтрока.Количество = Количество;
		НоваяСтрока.Ссылка = ПервыйОрдер;
		НоваяСтрока.Распоряжение = ПервыйОрдерРаспоряжение;
	КонецЕсли;
КонецПроцедуры

// Запуск БП

&НаКлиенте
Процедура ПроверитьНеобходимостьЗапускаБП_Клиент()
	Если ТипЗнч(ПервыйОрдерРаспоряжение) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Если ПроверитьНеобходимостьЗапускаБП(ПервыйОрдер) Тогда  
    		ПоказатьВопрос(
				Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект), 
				"В документе присутствует ""Неопознанная номенклатура"", запустить БП в Битриксе?", 
				РежимДиалогаВопрос.ДаНет);
				
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ПроверитьНеобходимостьЗапускаБП_Клиент_Завершение();
КонецПроцедуры

