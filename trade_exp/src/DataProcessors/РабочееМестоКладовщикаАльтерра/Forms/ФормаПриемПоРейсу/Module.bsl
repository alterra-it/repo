	НовыйТовар = Элементы.СписокНоменклатура1.ТекущиеДанные.Ссылка; 
	СтруктураПоиска = Новый Структура("Номенклатура", НовыйТовар);

	МассивСтрок = Объект.Товары.НайтиСтроки(СтруктураПоиска);
