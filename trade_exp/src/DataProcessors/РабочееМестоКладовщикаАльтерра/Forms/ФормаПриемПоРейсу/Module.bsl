		МассивСтрок = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура,Характеристика,Назначение,Распоряжение",Строка.Номенклатура,Строка.Характеристика,Строка.Назначение,Строка.Распоряжение));
