#Область ОписаниеПеременных

&НаКлиенте
Перем КэшированныеЗначения; //используется механизмом обработки изменения реквизитов ТЧ

&НаКлиенте
Перем ТекущиеДанныеИдентификатор; //используется для передачи текущей строки в обработчик ожидания

&НаКлиенте
Перем ПараметрыДляЗаписи Экспорт;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьПривилегированныйРежим(Истина);
	ВремяСохраненияДокументов=Константы.ВремяСохраненияДокументов.Получить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);                                           
	
	Если Параметры.Свойство("Сотрудник") Тогда
	   ТекущийИсполнительПриемТовара = Параметры.Сотрудник;
	   Сотрудник = Параметры.Сотрудник;
	   Склад = ТекущийИсполнительПриемТовара.Склад;
	   СекцииСотрудника.ЗагрузитьЗначения(ТекущийИсполнительПриемТовара.РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток"));
	КонецЕсли;                       

	Если Параметры.Свойство("СписокОрдеров") тогда
		СписокОрдеров.ЗагрузитьЗначения(Параметры.СписокОрдеров);
		Если ЗначениеЗаполнено(СписокОрдеров) Тогда
			ПервыйОрдер = СписокОрдеров[0].Значение;
			ПервыйОрдерРаспоряжение = ПервыйОрдер.Распоряжение;
			ПервыйОрдерРабочийУчасток = ПервыйОрдер.РабочийУчасток;
			ЗаполнитьТовары();
		КонецЕсли;
	КонецЕсли;            
	
	Статус = Перечисления.СтатусыПриходныхОрдеров.КПоступлению;
	
	ДоступныеЯчейки.Параметры.УстановитьЗначениеПараметра("Ссылка",Склад);

	ЗаполнитьПлановоеКоличество();
	
	ЗаполнитьТоварыЯчейка(); 
	
	//Подключение оповещений из очереди
	СообщениеОбработано = Истина;
	Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
		Если Не ПолучитьСостояниеОповещений() Тогда
			ОповещенияИзОчереди = Истина;
		Иначе
			ОповещенияИзОчереди = Сотрудник.ОповещенияИзОчереди; 
		КонецЕсли;
	Иначе 
		ОповещенияИзОчереди = Ложь; 	
	КонецЕсли; 
	Инт = 60;    
	СекцииСотрудника = СекцииСотрудника();
	Для каждого Стр Из СекцииСотрудника Цикл
		ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
		Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
			Инт = ЗнчИнтервала;
		КонецЕсли; 
	КонецЦикла; 
	ИнтервалОповещений = Инт;

		
КонецПроцедуры       

Процедура ЗаполнитьТовары()
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходныйОрдерНаТоварыТовары.Ссылка КАК Ссылка,
		|	ПриходныйОрдерНаТоварыТовары.Номенклатура КАК Номенклатура,
		|	ПриходныйОрдерНаТоварыТовары.Характеристика КАК Характеристика,
		|	ПриходныйОрдерНаТоварыТовары.Назначение КАК Назначение,
		|	ПриходныйОрдерНаТоварыТовары.Упаковка КАК Упаковка,
		|	ПриходныйОрдерНаТоварыТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ПриходныйОрдерНаТоварыТовары.Количество КАК Количество,
		|	ПриходныйОрдерНаТоварыТовары.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	ПриходныйОрдерНаТоварыТовары.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ПриходныйОрдерНаТоварыТовары.УпаковочныйЛист КАК УпаковочныйЛист,
		|	ПриходныйОрдерНаТоварыТовары.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
		|	ПриходныйОрдерНаТоварыТовары.Штрихкод КАК Штрихкод,
		|	ПриходныйОрдерНаТоварыТовары.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
		|	ПриходныйОрдерНаТоварыТовары.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
		|	ПриходныйОрдерНаТоварыТовары.Комментарий КАК Комментарий,
		|	ПриходныйОрдерНаТоварыТовары.Серия КАК Серия,
		|	ПриходныйОрдерНаТоварыТовары.Ссылка.Распоряжение КАК Распоряжение
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
		|ГДЕ
		|	ПриходныйОрдерНаТоварыТовары.Ссылка В(&Ссылка)";
	
	Запрос.УстановитьПараметр("Ссылка", СписокОрдеров.ВыгрузитьЗначения());
	
	Объект.Товары.Загрузить(Запрос.Выполнить().Выгрузить());  
	
КонецПроцедуры 
			
Процедура ЗаполнитьНомераДокументов()
	НомераДокументов = "";
	
	Для Каждого Ордер Из СписокОрдеров Цикл   
		Номер_ = Ордер.Значение.Номер;
		Если ЗначениеЗаполнено(НомераДокументов) Тогда
			НомераДокументов = НомераДокументов + ", " + Номер_;
		Иначе
			НомераДокументов = Номер_; 
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры        

&НаКлиенте
Процедура СообщитьОбИзмененииСтатуса()  
	Если ЗначениеЗаполнено(Статус) И ЗначениеЗаполнено(НомераДокументов) Тогда
		Сообщить("Документы:" + Символы.ПС + НомераДокументов + Символы.ПС + "переведены в статус '" + Статус + "'");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	

	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	
	ИнициализироватьСканер();
	
	ЗаполнитьПлановоеКоличествоВТаблице();

	ОтображатьХарактеристики = Ложь;

	УстановитьВидимостьХарактеристик();
	
	Если ВремяСохраненияДокументов > 0 Тогда
		ПодключитьОбработчикОжидания("ОбработатьОжидание", ВремяСохраненияДокументов, Ложь);
	КонецЕсли;
	
	Если ОповещенияИзОчереди Тогда
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);
		ПроверкаЭлектроннойОчереди(); 
	Иначе 
		Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
	КонецЕсли;

	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
		
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если (ИмяСобытия = "ScanData" ИЛИ ИмяСобытия = "Barcode") И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;

			Если ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.НовыйШтрихкод Тогда
				НовыйШтрихкод = "";
				Если ТипЗнч(Параметр) = Тип("Строка") Тогда
				НовыйШтрихкод = Параметр;
				КонецЕсли;
			Иначе
			    ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Штрихкод1));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)

	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтаФорма);
	
	ОтключитьСканер();
	
    Если НЕ ЗавершениеРаботы Тогда
        СообщитьОбИзмененииСтатуса();
	КонецЕсли;
	
	Если ВремяСохраненияДокументов > 0 Тогда
		ОтключитьОбработчикОжидания("ОбработатьОжидание");
	КонецЕсли;
 
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицы

&НаКлиенте
Процедура ТоварыПередНачаломИзменения(Элемент, Отказ)

	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		ТекущаяСтрокаТСД = Элементы.Товары.ТекущаяСтрока;
		ТекущиеДанныеТСД = Элементы.Товары.ТекущиеДанные;
		
		Если типзнч(ТекущаяСтрокаТСД) <> Тип("Неопределено") Тогда
			
			ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
						
			Номенклатура = "";
			Характеристика = "";
			ПоУчету = 0;
		    Количество = 0;
			Комментарий = "";
		    Ячейка = "";
			НоваяЯчейка = "";
			НовыйШтрихкод = "";
			ТекущийОрдер = "";
			Распоряжение = "";
						
			Если ЭлементСписка <> Неопределено Тогда
				Элементы._РедактированиеДокументаНаТСД.Видимость=Ложь;
				Элементы._РедактированиеСтрокиНаТСД.Видимость=Истина;
				ТекущийОрдер = ЭлементСписка.Ссылка;
			    Распоряжение = ЭлементСписка.Распоряжение;
				Номенклатура = ЭлементСписка.Номенклатура;
				Характеристика = ЭлементСписка.Характеристика;
				Количество = ЭлементСписка.КоличествоУпаковок;
				ПоУчету = ЭлементСписка.КоличествоПлан;
				Комментарий = ЭлементСписка.Комментарий;
				ПолучитьЯчейку(Номенклатура, Склад);
			Конецесли;
	 
		Иначе
				Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
				СредстваМультимедиа.ВоспроизвестиТекст("Товар не найден!","ru-RU");	
				КонецЕсли;
			Сообщить("Штрихкод не найден!");
		КонецЕсли;
		
	#КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		Отказ = Истина;
		
		Элементы._РедактированиеДокументаНаТСД.Видимость = Ложь;
		Элементы._ВыборНоменклатуры.Видимость = Истина;
    #КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущаяСтрокаТСД = Элементы.Товары.ТекущаяСтрока;
	ТоварыВыбор_Обработка(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор_Обработка(ВызовИзОбработчика)
	Если типзнч(ТекущаяСтрокаТСД) <> Тип("Неопределено") Тогда

		ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
				
		Номенклатура = "";
		Характеристика = "";
		Количество = 0;
		ПоУчету = 0;
		Комментарий = "";
		Ячейка = "";
		НоваяЯчейка = "";
		НовыйШтрихкод = "";
		ТекущийОрдер = "";
		Распоряжение = "";
		АдресКартинки="";

		Если ЭлементСписка <> Неопределено Тогда
			Если ВызовИзОбработчика Тогда
				Элементы._РедактированиеДокументаНаТСД.Видимость=Ложь; 
			Иначе   
				Элементы._ВыборНоменклатуры.Видимость = Ложь;
			Конецесли; 
			
			Элементы._РедактированиеСтрокиНаТСД.Видимость = Истина;
			
			ТекущийОрдер = ЭлементСписка.Ссылка;
			Распоряжение = ЭлементСписка.Распоряжение;
			Номенклатура = ЭлементСписка.Номенклатура;
			Характеристика = ЭлементСписка.Характеристика;
			Количество = ЭлементСписка.КоличествоУпаковок;
			ПоУчету = ЭлементСписка.КоличествоПлан;
			Комментарий = ЭлементСписка.Комментарий;
			ПолучитьЯчейку(Номенклатура, Склад);
			ПолучитьАдресКартинки(Номенклатура);
		Конецесли;

	Иначе
		Сообщить("Штрихкод не найден!");
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура _ВернутьсяКТЧ(Команда)
	
	ЗаполнитьПризнакРасхождение();

	Элементы._РедактированиеДокументаНаТСД.Видимость=Истина;
	Элементы._РедактированиеСтрокиНаТСД.Видимость=Ложь;
	
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаСервере
Процедура ДобавитьТоварыБезОрдераКПервомуОрдеру()
	Для Каждого Стр Из Объект.Товары Цикл
		Если Не ЗначениеЗаполнено(Стр.Ссылка) Тогда
			Стр.Ссылка = ПервыйОрдер;
			Стр.Распоряжение = ПервыйОрдерРаспоряжение;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ЗавершитьНаСервере(Статус_, ПричинаБлокировки = "")    
	
	УстановитьПривилегированныйРежим(Истина); 
	
	Статус = Статус_;
	
	ДобавитьТоварыБезОрдераКПервомуОрдеру();
	
	Для Каждого Ордер Из СписокОрдеров Цикл
		ОбъектОрдер = Ордер.Значение.ПолучитьОбъект();
		ОбъектОрдер.Статус = Статус;       
		
		ТЗТовары = ВернутьДанныеПоОрдеру(ОбъектОрдер.Ссылка);
		ОбъектОрдер.ВсегоМест = УпаковочныеЛистыСервер.КоличествоМестВТЧ(ТЗТовары);
		ОбъектОрдер.Товары.Загрузить(ТЗТовары);

		Если ЗначениеЗаполнено(НомерВходящегоДокумента) И ОбъектОрдер.НомерВходящегоДокумента <> НомерВходящегоДокумента Тогда
			ОбъектОрдер.НомерВходящегоДокумента = НомерВходящегоДокумента;
		КонецЕсли;

		Если ЗначениеЗаполнено(ДатаВходящегоДокумента) И ОбъектОрдер.ДатаВходящегоДокумента <> ДатаВходящегоДокумента Тогда
			ОбъектОрдер.ДатаВходящегоДокумента = ДатаВходящегоДокумента
		КонецЕсли;     
		
		Попытка     
			ОбъектОрдер.Записать(РежимЗаписиДокумента.Проведение);
			
			Если Не ЗначениеЗаполнено(ТЗТовары) Тогда
				ОбъектОрдер.УстановитьПометкуУдаления(Истина);
				СписокОрдеров.Удалить(Ордер);
			ИначеЕсли ЗначениеЗаполнено(ПричинаБлокировки) Тогда
				Обработки.РабочееМестоКладовщикаАльтерра.ЗаблокироватьВсёНаСервере(ПричинаБлокировки, ОбъектОрдер);
			КонецЕсли;
		Исключение
			ОбщегоНазначения.СообщитьПользователю("Не удалось провести документ: '" + Ордер.Значение + "'", Ордер.Значение);
		КонецПопытки;
	КонецЦикла;   

КонецПроцедуры 

&НаСервере
Функция ВернутьДанныеПоОрдеру(Ордер)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
		|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
		|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
		|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВнешняяТаблицаНоменклатуры.КоличествоПлан КАК КоличествоПлан,
		|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
		|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	ВнешняяТаблицаНоменклатуры.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
		|	ВнешняяТаблицаНоменклатуры.Штрихкод КАК Штрихкод,
		|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
		|	ВнешняяТаблицаНоменклатуры.Комментарий КАК Комментарий,
		|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия,
		|	ВнешняяТаблицаНоменклатуры.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
		|ИЗ
		|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
		|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
		|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
		|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
		|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	ВнешняяТаблицаНоменклатуры.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
		|	ВнешняяТаблицаНоменклатуры.Штрихкод КАК Штрихкод,
		|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
		|	ВнешняяТаблицаНоменклатуры.Комментарий КАК Комментарий,
		|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
		|ИЗ
		|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
		|ГДЕ
		|	ВнешняяТаблицаНоменклатуры.Ссылка = &Ссылка";   
		
	Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры", Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("Ссылка", Ордер);  
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

&НаКлиенте
Процедура ВзятьВРаботу(Команда)		
	ЗавершитьНаСервере(ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.ВРаботе"));
	Элементы.ВзятьВРаботу.Видимость = Ложь;
	Элементы.СообщитьОбОшибке.Видимость = Ложь;
	ЗаполнитьНомераДокументов();
КонецПроцедуры

&НаСервере
Функция ПроверкаПоРаспоряжениям()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ                                       
		|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка,
		|	ПриходныйОрдерНаТовары.Распоряжение КАК Распоряжение
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Ссылка В (&Ссылки)";
	
	Запрос.УстановитьПараметр("Ссылки", СписокОрдеров.ВыгрузитьЗначения());
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Пока РезультатЗапроса.Следующий() Цикл 
		Если ТипЗнч(РезультатЗапроса.Распоряжение) = Тип("ДокументСсылка.ЗаказПоставщику") И 
			Не ПроверитьПрикрепленныеФайлыПоПрефиксу("Scan_", РезультатЗапроса.Ссылка) Тогда
			
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;	
	
	Возврат Истина;
КонецФункции

&НаКлиенте
Процедура Завершить(Команда)                
	
	Если НомерВходящегоДокумента = "" Тогда
		Сообщить("Заполните номер и дату вх. документа");
		Возврат;
	КонецЕсли;     
	
	Если Не ПроверкаПоРаспоряжениям() Тогда  
		Сообщить("Загрузите скан для вх. документов");
		Возврат;
	КонецЕсли;
	
	ПроверитьНеобходимостьЗапускаБП_Клиент();
	
КонецПроцедуры

