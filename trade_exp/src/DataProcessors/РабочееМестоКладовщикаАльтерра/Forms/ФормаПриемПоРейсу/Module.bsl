	Если Результат = КодВозвратаДиалога.Да Тогда
		Номенклатура = СтруктураДопПараметры.Номенклатура;
		ТекущийОрдер = ПервыйОрдер;
		Распоряжение = ПервыйОрдерРаспоряжение;
    	ПолучитьЯчейку(Номенклатура, Склад);
	
		Характеристика = "";
		ПоУчету = 0;
		Количество = 0;
		Комментарий = "";
		НоваяЯчейка = "";
		НовыйШтрихкод = "";
		
		НоваяСтрока = Объект.Товары.Добавить();
		НоваяСтрока.Номенклатура = Номенклатура;
		НоваяСтрока.Распоряжение = Распоряжение;
		НоваяСтрока.Ссылка = ТекущийОрдер;
		
		ТекущаяСтрокаТСД = НоваяСтрока.ПолучитьИдентификатор(); 
		
		Элементы._РедактированиеСтрокиНаТСД.Видимость = Истина;
		Элементы._ВыборНоменклатуры.Видимость = Ложь;
	КонецЕсли;	
 
