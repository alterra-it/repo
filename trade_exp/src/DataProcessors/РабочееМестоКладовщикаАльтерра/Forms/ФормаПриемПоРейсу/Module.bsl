		ТекущаяСтрокаТСД = МассивСтрок[0].ПолучитьИдентификатор();
		ТоварыВыбор_Обработка(Ложь);
	Иначе		
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОповещениеОНовомТоваре", ЭтотОбъект, СтруктураПоиска), 
			"Выбранный товар не найден в ордерах. Добавить его?", 
			РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
	
