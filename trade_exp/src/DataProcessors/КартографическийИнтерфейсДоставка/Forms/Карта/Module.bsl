#Область СобытияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОткрытИзДокумента= Ложь;
	Если Параметры.Свойство("ОткрытИзДокумента") Тогда
		ОткрытИзДокумента= Параметры.ОткрытИзДокумента;
	КонецЕсли;
	
	Если ОткрытИзДокумента Тогда
		Партнер= Параметры.Партнер;
		Филиал= Параметры.Филиал;
		ВидДоставки= Параметры.ВидДоставки;
		Элементы.Тариф.Видимость = НЕ Параметры.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная");
		Тариф= Параметры.Тариф;
		Адрес= Параметры.Адрес;
		Широта = Параметры.Широта;
		Долгота = Параметры.Долгота;
		ТарифВРучную=  Параметры.ТарифВРучную;  
		БезСтоимостиФилиалов = Ложь;
		Если Параметры.Свойство("БезСтоимостиФилиалов") Тогда  
			БезСтоимостиФилиалов = Параметры.БезСтоимостиФилиалов;	
		КонецЕсли;	

		Если ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
			ВариантДоставки= "ОРК";
			НДС= "СНДС";
			ВидСтоимости= "СтоимостьДляВодителя";
		ИначеЕсли ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда	
			ВариантДоставки= "Внутренняя";
			НДС= "СНДС";
			ВидСтоимости= "СтоимостьДляКлиента";
		Иначе   
			ВариантДоставки= "Розница";
			Если  ВидДоставки = Перечисления.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы Тогда 	
				НДС = "СНДС"; 
				БезСтоимостиФилиалов = Истина;  
				ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
				
				Если РольДоступна("ПолныеПрава") Или РольДоступна("ОтделЛогистики") Тогда
					Элементы.ГруппаРазгрузки.Видимость = Истина;
				Иначе 
					Элементы.ГруппаРазгрузки.Видимость = Ложь;
				КонецЕсли;			
			Иначе
				НДС= "БезНДС"; 
			КонецЕсли;
			ВидСтоимости= "СтоимостьДляКлиента";  
		КонецЕсли;
		
		ПараметрыРазгрузкиАдресВХранилище = Параметры.ПараметрыРазгрузкиАдресВХранилище;
		ПараметрыРазгрузки = ПолучитьИзВременногоХранилища(ПараметрыРазгрузкиАдресВХранилище);
		
		Если ТипЗнч(ПараметрыРазгрузки) = Тип("Структура") Тогда 
			Этаж = ПараметрыРазгрузки.Этаж;
			НомерКвартиры = ПараметрыРазгрузки.НомерКвартиры;
			ВариантРазгрузки = ПараметрыРазгрузки.ВариантРазгрузки;
		КонецЕсли;
		
	Иначе
		Подразделение= Пользователи.ТекущийПользователь().Подразделение;
		Если ЗначениеЗаполнено(Подразделение.Родитель) Тогда
			Филиал= Подразделение.Родитель;
		Иначе
			Филиал= Подразделение;
		КонецЕсли;
		
		ВариантДоставки= "Розница";
		НДС= "БезНДС";
		ВидСтоимости= "СтоимостьДляКлиента";
		ВидДоставки= Перечисления.ВидыДоставокДоКлиента.Розничная;
		Тариф= Справочники.ТарифыПеревозчиков.НайтиПоКоду("000000003");//До 1,5 тонн до 6м
		ТарифВРучную= Ложь;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Тариф) Тогда
		Тариф= Справочники.ТарифыПеревозчиков.НайтиПоКоду("000000003");//До 1,5 тонн до 6м
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Адрес) Тогда
		Если ЗначениеЗаполнено(Партнер) Тогда
			Адрес= АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформацию(Партнер, Справочники.ВидыКонтактнойИнформации.АдресПартнера);
		КонецЕсли
	КонецЕсли;

	//детали адреса
	Если ЗначениеЗаполнено(Адрес) Тогда
		НомерДома = Параметры.НомерДома;
		НомерКвартиры = Параметры.НомерКвартиры;
		ЧастныйДом = Параметры.ЭтоЧастныйДом;
		НомерКорпуса = Параметры.НомерКорпуса;
		НомерОфиса = Параметры.НомерОфиса;
		ДополнениеКАдресу = Параметры.ДополнениеКАдресу;
		
		НомерДомаКарта = ПолучитьДомИзАдреса();
		УстановитьДоступностьДома();
	КонецЕсли;

	Элементы.ФормаПередатьВДокумент.Видимость= ОткрытИзДокумента;
	Элементы.Тариф.ТолькоПросмотр= Не ТарифВРучную;
	
	Элементы.ГруппаРазгрузки.Доступность = РасчетРазгрузкиДействует(ТекущаяДата());
	
	ИнициализироватьКарту();
КонецПроцедуры

