		НДС= "СНДС";
	ИначеЕсли ВариантДоставки = "Выписка/Актив" Тогда
		ВидСтоимости= "СтоимостьДляВодителя";
		ВидДоставки= Перечисления.ВидыДоставокДоКлиента.Розничная;
		НДС= "БезНДС";
	ИначеЕсли ВариантДоставки = "Выписка/АктивДо1т" Тогда 
		ВидСтоимости= "СтоимостьДляКлиента";
		ВидДоставки= Перечисления.ВидыДоставокДоКлиента.Розничная;
		НДС= "БезНДС";
	Иначе
		ВидСтоимости= "СтоимостьДляКлиента";
		ВидДоставки= Перечисления.ВидыДоставокДоКлиента.Розничная;
