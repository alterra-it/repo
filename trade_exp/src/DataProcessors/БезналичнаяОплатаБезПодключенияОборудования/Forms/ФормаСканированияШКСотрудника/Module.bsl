
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если Источник = "ПодключаемоеОборудование"  Тогда//Ввод доступен ставить не нужно, т.к. окно теряет фокус
		
		Если ИмяСобытия = "ScanData" Тогда
			Данные= ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
			Штрихкод= Данные.Штрихкод;
			
			Если ПустаяСтрока(Штрихкод) Тогда
				НадписьСообщения= "Не удалось прочитать штрихкод!";
				Возврат;
			КонецЕсли;

			Если Лев(Штрихкод, 4) = "8888" Тогда//Это сотрудник
				Пользователь = ПоискСотрудникаПоШК(Штрихкод);
				
				Если Пользователь <> Неопределено Тогда
					Сотрудник = Строка(Пользователь);
					ЕстьПравоНаПодтверждениеОплаты = ЕстьПравоПодтверждатьОплату(Пользователь);
					Элементы.ОшибкаСчитывания.Видимость = Ложь;
					Элементы.ТекстОшибки.Видимость = НЕ ЕстьПравоНаПодтверждениеОплаты;
					
					Если ЕстьПравоНаПодтверждениеОплаты Тогда
						Закрыть(Пользователь);
						Сообщить("Оплата подтверждена сотрудником "+Строка(Пользователь));
					КонецЕсли;
					
				КонецЕсли;
			Иначе
				Элементы.ОшибкаСчитывания.Видимость = Истина;
				Элементы.ТекстОшибки.Видимость = Ложь;
				Сотрудник = "";
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПоискСотрудникаПоШК(Штрихкод)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Сотрудники.Пользователь КАК Пользователь
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Код = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Пользователь;
	КонецЕсли;
	Возврат Неопределено;

КонецФункции

&НаСервере
Функция ЕстьПравоПодтверждатьОплату(Пользователь)

	УстановитьПривилегированныйРежим(Истина);
		
    РабочийПользователь = Пользователь;
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(РабочийПользователь.ИдентификаторПользователяИБ);
	
	Если Не (ПользовательИБ = Неопределено) Тогда
		РольПолныеПрава = ПользовательИБ.Роли.Содержит(Метаданные.Роли.ПолныеПрава);
		РольПодтверждениеОплаты = ПользовательИБ.Роли.Содержит(Метаданные.Роли.Док_ПодтвердитьОплатуНаСтойкеМенеджера);
	КонецЕсли;
	
	Возврат РольПолныеПрава или РольПодтверждениеОплаты;
	
	УстановитьПривилегированныйРежим(Ложь);
КонецФункции

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтаФорма);
КонецПроцедуры


