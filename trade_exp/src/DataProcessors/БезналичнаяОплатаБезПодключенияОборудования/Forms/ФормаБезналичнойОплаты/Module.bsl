&НаКлиенте
Процедура ВводИДТранзакцииЗавершение(Результат, ДополнительныеПараметры)  Экспорт 
	Если Результат <> "" и ИнтеграцияСБПГазпромбанк.БылаОперацияСБП(Результат) Тогда
		ОткрытьФормуСБПГазпромбанк(Результат);
	Иначе	
		ОбщегоНазначенияКлиент.СообщитьПользователю("По такому ID транзакции не было оплаты по СБП");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуСБПГазпромбанк(Идентификатор)
	
	Если СуммаДокумента <> 0 Тогда
		ПараметрыОткрытияФормы = Новый Структура;
		ПараметрыОткрытияФормы.Вставить("КОплате", СуммаДокумента);
		ПараметрыОткрытияФормы.Вставить("Идентификатор", Идентификатор);
		ПараметрыОткрытияФормы.Вставить("Документ", ДокументОплаты);
		
		ОткрытьФорму("ОбщаяФорма.СБПГазпромбанк", ПараметрыОткрытияФормы, ЭтотОбъект,,,, Новый ОписаниеОповещения("Док_ЗавершениеОплатыСБП", ЭтотОбъект),РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	Иначе
		Сообщить("Сумма оплаты равна 0");
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура Док_ЗавершениеОплатыСБП(Результат, ДополнительныеПараметры)   Экспорт
	Если Результат = Неопределено
		ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	ОплатаВыполнена = Истина; 
	БылаОплатаПоСБП = Истина;
	Элементы.ПринятьОплату.Доступность = Не БылаОплатаПоСБП;
	Элементы.ГруппаКомандПодключаемый.Доступность = Не БылаОплатаПоСБП;
	Элементы.ПробитьЧек.Доступность = Не БылаОплатаПоСБП;
	Элементы.ПробитьЧекСБП.Доступность = БылаОплатаПоСБП;
	Док_ОбработкаОплатыСБП(Результат);
	Сообщить("Оплата выполнена, можно подтвержать оплату и пробивать чек");
КонецПроцедуры 

&НаСервере
Процедура Док_ОбработкаОплатыСБП(Результат) 
	УстановитьПривилегированныйРежим(Истина);
	
	ДокОбъект = ДокументОплаты.ПолучитьОбъект();
	
	Если ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМ") Тогда
		ИнтеграцияСБПГазпромбанк.ОбработатьОплатуВЧекККМ(Результат, ДокОбъект);	
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда
		ИнтеграцияСБПГазпромбанк.ОбработатьОплатуВЧекККМНаВозврат(Результат, ДокОбъект);
	ИначеЕсли ТипЗнч(ДокументОплаты) = Тип("ДокументСсылка.ОперацияПоПлатежнойКарте") Тогда
		ИнтеграцияСБПГазпромбанк.ОбработатьОплатуВЭквайринге(Результат, ДокОбъект);	
	КонецЕсли;
	
	ДокОбъект.Записать(); 
	УстановитьПривилегированныйРежим(Ложь);
	//	
КонецПроцедуры 

&НаКлиенте
Процедура ПробитьЧекСБП(Команда)
	
	Если Не ОплатаВыполнена Тогда
		Сообщить("Подтвердите успешную оплату!");
		Возврат;
	КонецЕсли;
	
	Если ВариантЧека = "Почта" Тогда
		
		Если Email <> "" Тогда 
			СтрокаВопроса = "Чек будет отправлен на почту: " + Email + ". Все верно?";
		Иначе
			Сообщить("Введите EMAIL!"); 
			Возврат;
		КонецЕсли;
		
	ИначеЕсли ВариантЧека = "Смс" Тогда	
		
		Если (СтрДлина(Телефон) = 12) Тогда 
			СтрокаВопроса = "Чек будет отправлен на телефон: " + Прав(Телефон, 4) + ". Все верно?";
		Иначе
			Сообщить("Введите Телефон!");
			Возврат;
		КонецЕсли;
		
	ИначеЕсли ВариантЧека = "Бумажный" Тогда 	 
		
		СтрокаВопроса = "Чек будет напечатан. Все верно?";	
		
	ИначеЕсли ВариантЧека = "Фиктивный" Тогда 
		
		СтрокаВопроса = "Покупатель отказался от чека. Все верно?"; 
		
	Иначе
		
		Сообщить("Выберите вариант отправки чека!");
		Возврат;  
		
	КонецЕсли; 	
		
	Оповещение = Новый ОписаниеОповещения("ПробитьЧекСБПЗавершение", ЭтотОбъект);    
	ПоказатьВопрос(Оповещение,СтрокаВопроса,РежимДиалогаВопрос.ОКОтмена,0);  
		
КонецПроцедуры

&НаКлиенте
Процедура ПробитьЧекСБПЗавершение(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.ОК Тогда
		ЗаписатьКомментарий();
		//Сообщить("Была оплата по СБП "+БылаОплатаПоСБП);
		ПробитьДокументОплатыСБП();
		
		//Попытка
		//	АльтерраОбщегоНазначенияКлиент.ИзвлечьIDТранзакции(ДокументОплаты,ТекущаяДата(),СуммаДокумента);
		//	ОплатаВыполнена = Истина;
		//Исключение 			
		//	ЗарегистрироватьОшибкуВЖурнале(ОписаниеОшибки());
		//КонецПопытки;
		
	КонецЕсли;   
	
КонецПроцедуры 

Процедура ПробитьДокументОплатыСБП()
		
	Обработки.БезналичнаяОплатаБезПодключенияОборудования.ДобавитьОплатуИПробитьДокументСБП(ДокументОплаты,Касса,КассаККМ,ЭквайринговыйТерминал,СуммаДокумента,НомерПлатежнойКарты,КодАвторизации,НомерЧекаЭТ,АдресУведомленияКлиента,ПечататьЧек,ДокументОснование);
	
	Если ДокументПробит() Тогда
		
		КодАвторизации = "";
		НомерПлатежнойКарты = "";
		НомерЧекаЭТ = "";
		БылаОплатаПоСБП = Ложь;
		
		Элементы.ГруппаЧек.Доступность = Ложь;
		СостояниеДокумента = Строка(ДокументОплаты) + " - Пробит, оплата принята.";
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ПроблемыДеактивацииКСФормаСБП" Тогда
		Сообщить(Параметр);
	КонецЕсли;
КонецПроцедуры

