#Область ОбработчикиСобытийФормы   

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтотОбъект, "");
	
	ЗаполнитьНастройкиХранилища();

	УстановитьПараметрыДинамическихСписков();
	
	Если Не ЗначениеЗаполнено(Касса) Тогда
		Сообщить("На рабочем месте не настроена касса, обратитесь в техническую поддержку!");
		Отказ = Истина;
	КонецЕсли;
	
	Если ОшибкаПроверкиКассы() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	ОборудованиеПодключено = МенеджерОборудованияВызовСервера.ОборудованиеПоПараметрам(
	"ЭквайринговыйТерминал",
	Неопределено,
	МенеджерОборудованияВызовСервера.РабочееМестоКлиента()).Количество() > 0;
	Элементы.ГруппаКомандПодключаемый.Видимость = ОборудованиеПодключено;
	//Вставка сбп
	Если ЗначениеЗаполнено(ЭквайринговыйТерминал) и ЗначениеЗаполнено(КассаККМ) Тогда
		ДанныеКС = ИнтеграцияСБПГазпромбанк.ПолучитьКассовуюСсылкуДляТерминалаКассы(КассаККМ, ЭквайринговыйТерминал);
		Если ДанныеКС <> Неопределено Тогда
			ИдентификаторКС = ДанныеКС.grcId; 
			Элементы.ОплатитьВернутьСБП.Доступность = Истина; 
		КонецЕсли;
	КонецЕсли;
    //КонецВставки сбп
	Если Параметры.Свойство("ДокументПродажи") Тогда
		
		ДокументОснование = Параметры.ДокументПродажи;
			
		ЗаполнитьДанныеПоДокументуОплаты(ДокументОснование);
		
		ОбновитьВариантОтправкиЧека();  
		
		ОбновитьКонтактнуюИнформациюПартнера();
		
		УстановитьУсловноеОформлениеЭлементовФормы();

	КонецЕсли; 

	Если Не РольДоступна("ПолныеПрава") Тогда
		 Элементы.ДанныеБезналичныхОплат.Видимость = Ложь;
	 КонецЕсли;
	 БылиОшибки = Ложь;
КонецПроцедуры   

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "ЭквайринговыйТерминал");
	
КонецПроцедуры

#КонецОбласти  

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура ОтправкаНаСмсПриИзменении(Элемент)
	
	ОтправкаНаПочту = Не ОтправкаНаСМС; 
	
	ВариантЧека = ?(ОтправкаНаСмс,"Смс","Почта"); 
	   
	ОбновитьУсловноеОформлениеВариантаОтправкиЧека();  

КонецПроцедуры

&НаКлиенте
Процедура ОтправкаНаПочтуПриИзменении(Элемент)
	
	ОтправкаНаСМС = Не ОтправкаНаПочту;
	
	ВариантЧека = ?(ОтправкаНаПочту,"Почта","Смс"); 

	ОбновитьУсловноеОформлениеВариантаОтправкиЧека();  
	
КонецПроцедуры

#КонецОбласти 

#Область ОбработчикиКомандФормы  

  &НаКлиенте
Процедура Док_НапечататьЧекВместо(Команда)
	
    ВариантЧека = "Бумажный"; 
	ОбновитьУсловноеОформлениеВариантаОтправкиЧека();
	
КонецПроцедуры                     

&НаКлиенте
Процедура Док_ЭлектронныйЧекНеТребуетсяПосле(Команда)

  ВариантЧека = "Фиктивный"; 
  ОбновитьУсловноеОформлениеВариантаОтправкиЧека();
  
КонецПроцедуры   

 &НаКлиенте
Процедура ПодтвердитьОплату(Команда)  

	//Если ПустаяСтрока(НомерПлатежнойКарты) Тогда
	//	Сообщить("Введите номер платежной карты!");
	//Иначе
	//	ОплатаВыполнена = Истина;
	//	Элементы.ГруппаОплата.Доступность = Не ОплатаВыполнена;
	//КонецЕсли;
	Если ПустаяСтрока(НомерПлатежнойКарты) и НЕ БылаОплатаПоСБП Тогда
		ОчиститьСообщения();
		Сообщить("Введите номер платежной карты!");
	ИначеЕсли БылиОшибки И НЕ ОплатаВыполнена Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ПодтвердитьОплатуЗавершение", ЭтаФорма);
		ОчиститьСообщения();
		ОткрытьФорму("Обработка.БезналичнаяОплатаБезПодключенияОборудования.Форма.ФормаСканированияШКСотрудника",,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	Иначе
		ОплатаВыполнена = Истина;
		Элементы.ГруппаОплата.Доступность = Не ОплатаВыполнена;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПодтвердитьОплатуЗавершение(Результат, ДополнительныеПараметры) Экспорт
	КтоПодтвердилОплату = Результат;
	Если ПустаяСтрока(НомерПлатежнойКарты) Тогда
		ОчиститьСообщения();
		Сообщить("Введите номер платежной карты!");
	Иначе
		Если НЕ КтоПодтвердилОплату = ПредопределенноеЗначение("Справочник.Пользователи.ПустаяСсылка") Тогда
			ОплатаВыполнена = Истина;
		Иначе
			ОчиститьСообщения();
			Сообщить("Оплата не подтверждена");
		КонецЕсли;
		Элементы.ГруппаОплата.Доступность = Не ОплатаВыполнена;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанные(Команда)
	
	Закрыть(Новый Структура("ЭквайринговыйТерминал,НомерПлатежнойКарты,ОплатаВыполнена",ЭквайринговыйТерминал,НомерПлатежнойКарты,ОплатаВыполнена)); 
	
КонецПроцедуры

&НаКлиенте
Процедура ПробитьЧек(Команда)
	
	Если Не ОплатаВыполнена Тогда
		Сообщить("Подтвердите успешную оплату!");
		Возврат;
	КонецЕсли;
	
	Если ВариантЧека = "Почта" Тогда
		
		Если Email <> "" Тогда 
			СтрокаВопроса = "Чек будет отправлен на почту: " + Email + ". Все верно?";
		Иначе
			Сообщить("Введите EMAIL!"); 
			Возврат;
		КонецЕсли;
		
	ИначеЕсли ВариантЧека = "Смс" Тогда	
		
		Если (СтрДлина(Телефон) = 12) Тогда 
			СтрокаВопроса = "Чек будет отправлен на телефон: " + Прав(Телефон, 4) + ". Все верно?";
		Иначе
			Сообщить("Введите Телефон!");
			Возврат;
		КонецЕсли;
		
	ИначеЕсли ВариантЧека = "Бумажный" Тогда 	 
		
		СтрокаВопроса = "Чек будет напечатан. Все верно?";	
		
	ИначеЕсли ВариантЧека = "Фиктивный" Тогда 
		
		СтрокаВопроса = "Покупатель отказался от чека. Все верно?"; 
		
	Иначе
		
		Сообщить("Выберите вариант отправки чека!");
		Возврат;  
		
	КонецЕсли; 	
		
	Оповещение = Новый ОписаниеОповещения("ПробитьЧекЗавершение", ЭтотОбъект);    
	ПоказатьВопрос(Оповещение,СтрокаВопроса,РежимДиалогаВопрос.ОКОтмена,0);  
		
КонецПроцедуры

&НаКлиенте
Процедура ОплатитьПлатежнойКартой(Команда)

	Если ОшибкаПроверкиКассы() Тогда
