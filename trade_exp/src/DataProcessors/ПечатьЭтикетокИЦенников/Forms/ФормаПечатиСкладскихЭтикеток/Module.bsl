
&НаКлиенте
Процедура Обработать(Команда)
	ОбработатьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ОбработатьНаСервере()
	
	ТаблицаНоменклатуры.Очистить();
	НомерСтроки = 2;		
	Пока Истина Цикл
		стрНомерСтроки = XMLСтрока(НомерСтроки);
		
		Код			 		= СокрЛП(ТаблицаПоиска.Область("R"+Строка(стрНомерСтроки)+"C1").Текст);
		Наименование  		= СокрЛП(ТаблицаПоиска.Область("R"+Строка(стрНомерСтроки)+"C2").Текст);
		НомерПартии			= СокрЛП(ТаблицаПоиска.Область("R"+Строка(стрНомерСтроки)+"C3").Текст);
		ДатаИзготовления 	= СокрЛП(ТаблицаПоиска.Область("R"+Строка(стрНомерСтроки)+"C4").Текст);
		КоличествоЭтикеток	= СокрЛП(ТаблицаПоиска.Область("R"+Строка(стрНомерСтроки)+"C5").Текст);
		
		Если ПустаяСтрока(Код) Тогда 
			Прервать;
		КонецЕсли;
		
		Номенклатура = Справочники.Номенклатура.НайтиПоКоду(Код);
		Если Не ЗначениеЗаполнено(Номенклатура) Тогда
			ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Номенклатура: %1 '%2' не найдена!", Код, Наименование));
			УстановитьЦветТекстаДляСтроки(WebЦвета.ТусклоРозовый, стрНомерСтроки);
		Иначе
			НоваяСтрока = ТаблицаНоменклатуры.Добавить();
			НоваяСтрока.НомерСтроки = стрНомерСтроки-1;
			НоваяСтрока.Код = Номенклатура.Код;
			НоваяСтрока.Номенклатура = Номенклатура;
			НоваяСтрока.ИнформацияПоГост = Номенклатура.ГостСТО;
			НоваяСтрока.МассаОбъем = ПолучитьВесОбъем(Код);
			НоваяСтрока.Цвет = ПолучитьЦвет(Код);
			НоваяСтрока.СрокГодности = Номенклатура.СрокГодностиТовара;
			НоваяСтрока.Штрихкод = ПолучитьШтрихкодНоменклатуры(Код);
			НоваяСтрока.ШаблонЭтикетки = Номенклатура.ШаблонЭтикетокДляСклада;
			НоваяСтрока.ДатаИзготовления = ОбщегоНазначенияКлиентСервер.СтрокаВДату(ДатаИзготовления);
			НоваяСтрока.КоличествоЭтикеток = КоличествоЭтикеток;
			НоваяСтрока.НомерПартии = НомерПартии;
			
			Если НоваяСтрока.ДатаИзготовления = Дата(1, 1, 1) Тогда
				Сообщить("По строке №"+Строка(стрНомерСтроки-1)+" дата не была определена");
			КонецЕсли;
			
			ТаблицаПоиска.Область("R"+Строка(стрНомерСтроки)+"C2").Текст = Номенклатура.Наименование;
			УстановитьЦветТекстаДляСтроки(WebЦвета.НейтральноЗеленый, стрНомерСтроки);
		КонецЕсли;
	
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;	
КонецПроцедуры

&НаСервере
Процедура УстановитьЦветТекстаДляСтроки(Цвет, НомерСтроки)
	
	ТаблицаПоиска.Область("R"+Строка(НомерСтроки)+"C1").ЦветФона = Цвет;
	ТаблицаПоиска.Область("R"+Строка(НомерСтроки)+"C2").ЦветФона = Цвет;
	ТаблицаПоиска.Область("R"+Строка(НомерСтроки)+"C3").ЦветФона = Цвет;
	ТаблицаПоиска.Область("R"+Строка(НомерСтроки)+"C4").ЦветФона = Цвет;
	ТаблицаПоиска.Область("R"+Строка(НомерСтроки)+"C5").ЦветФона = Цвет;

КонецПроцедуры

&НаСервере
Функция ПолучитьВесОбъем(КодНоменклатуры)

	Обработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", "ПечатьСкладскихЭтикетокПоНоменклатуре.epf");
	ОбработкаОбъект = Обработка.ПолучитьОбъект();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"Выбрать
		|	Настройки.ВидНоменклатуры КАК ВидНоменклатуры,
		|	Настройки.РеквизитДляВесаОбъема КАК РеквизитДляВеса
		|ПОМЕСТИТЬ ВТНастройки
		|ИЗ 
		|	&Настройки КАК Настройки;
		|///////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НоменклатураДополнительныеРеквизиты.Значение КАК Значение,
		|	НоменклатураДополнительныеРеквизиты.Свойство КАК Свойство,
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры,
		|	Номенклатура.Ссылка КАК Номенклатура
		|ИЗ
		|	Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура   
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТНастройки КАК ВТНастройки
		|			ПО ВТНастройки.ВидНоменклатуры = Номенклатура.ВидНоменклатуры
		|		ПО НоменклатураДополнительныеРеквизиты.Ссылка = Номенклатура.Ссылка
		|ГДЕ
		|	Номенклатура.Код = &Код
		|	И НоменклатураДополнительныеРеквизиты.Свойство.Наименование ПОДОБНО ВТНастройки.РеквизитДляВеса";
	
	Запрос.УстановитьПараметр("Код", КодНоменклатуры);
	Запрос.УстановитьПараметр("Настройки", Обработка.ХранилищеНастроек.Получить().СопоставлениеВИдовНоменклатурыСРеквизитом);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Значение;
	КонецЕсли;
	
	Возврат "";

КонецФункции

&НаСервере
Функция ПолучитьЦвет(КодНоменклатуры)

	Обработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", "ПечатьСкладскихЭтикетокПоНоменклатуре.epf");
	ОбработкаОбъект = Обработка.ПолучитьОбъект();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"Выбрать
		|	Настройки.ВидНоменклатуры КАК ВидНоменклатуры,
		|	Настройки.РеквизитДляЦвета КАК РеквизитДляЦвета
		|ПОМЕСТИТЬ ВТНастройки
		|ИЗ 
		|	&Настройки КАК Настройки;
		|///////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НоменклатураДополнительныеРеквизиты.Значение КАК Значение,
		|	НоменклатураДополнительныеРеквизиты.Свойство КАК Свойство,
		|	Номенклатура.ВидНоменклатуры КАК ВидНоменклатуры,
		|	Номенклатура.Ссылка КАК Номенклатура
		|ИЗ
		|	Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура   
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТНастройки КАК ВТНастройки
		|			ПО ВТНастройки.ВидНоменклатуры = Номенклатура.ВидНоменклатуры
		|		ПО НоменклатураДополнительныеРеквизиты.Ссылка = Номенклатура.Ссылка
		|ГДЕ
		|	Номенклатура.Код = &Код
		|	И НоменклатураДополнительныеРеквизиты.Свойство.Наименование ПОДОБНО ВТНастройки.РеквизитДляЦвета";
	
	Запрос.УстановитьПараметр("Код", КодНоменклатуры);
	Запрос.УстановитьПараметр("Настройки", Обработка.ХранилищеНастроек.Получить().СопоставлениеВИдовНоменклатурыСРеквизитом);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Значение;
	КонецЕсли;
	
	Возврат "";

КонецФункции

&НаСервере
Функция ПолучитьШтрихкодНоменклатуры(КодНоменклатуры)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ первые 1
		|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
		|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура,
		|	ШтрихкодыНоменклатуры.Наш КАК Наш
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	НЕ ШтрихкодыНоменклатуры.Наш
		|	И ШтрихкодыНоменклатуры.Штрихкод ПОДОБНО ""4%""
		|	И ШтрихкодыНоменклатуры.Номенклатура.Код = &Код";
	
	Запрос.УстановитьПараметр("Код", КодНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Штрихкод;
	КонецЕсли;
	
	Возврат "";

КонецФункции

&НаКлиенте
Процедура Предпросмотр(Команда)
	ОчиститьСообщения();
	
	ВыполнитьПроверку(ЭтаФорма);
	Если ТаблицаНоменклатуры.Количество() = 0 Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("ru = 'Не выбрано ни одного товара'"));
		Возврат;
	КонецЕсли;
	
	ПараметрКоманды = Новый Массив;
	ПараметрКоманды.Добавить(ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка"));
	ИменаМакетов = "ЭтикеткаТовары";
	
	УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
			"Обработка.ПечатьЭтикетокИЦенников",
			ИменаМакетов,
			ПараметрКоманды,
			ЭтаФорма,
			ПолучитьПараметры());

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ВыполнитьПроверку(Форма)
	ЕстьОшибки = Ложь;
	Для Каждого СтрокаТЧ Из Форма.ТаблицаНоменклатуры Цикл
		НомерСтроки = СтрокаТЧ.НомерСтроки - 1;
		Если СтрокаТЧ.КоличествоЭтикеток = 0 Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не заполнено количество этикеток в строке: %1'"),
				НомерСтроки + 1);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				ТекстСообщения,,
				"Объект.Товары["+НомерСтроки+"].КоличествоЭтикеток",,
				ЕстьОшибки);
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(СтрокаТЧ.ШаблонЭтикетки) Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не выбран шаблон этикетки в строке: %1'"),
				НомерСтроки + 1);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				ТекстСообщения,,
				"Объект.Товары["+НомерСтроки+"].ШаблонЭтикетки",,
				ЕстьОшибки);
		КонецЕсли;	
	КонецЦикла;
	
КонецФункции

&НаСервере
Функция ПолучитьПараметры()
	
	ТоварыДляСкладскихЯчеек = Новый ТаблицаЗначений;
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("Упаковка", Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("Цена", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ЦенаДополнительно", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("Штрихкод", Новый ОписаниеТипов("Строка"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ШаблонЦенника", Новый ОписаниеТипов("СправочникСсылка.ШаблоныЭтикетокИЦенников"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("КоличествоЦенников", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ШаблонЭтикетки", Новый ОписаниеТипов("СправочникСсылка.ШаблоныЭтикетокИЦенников"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ШаблонЭтикеткиПодготовлено", Новый ОписаниеТипов("СправочникСсылка.ШаблоныЭтикетокИЦенников"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("КоличествоЭтикеток", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ОстатокНаСкладе", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("КоличествоВДокументе", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("Весовой", Новый ОписаниеТипов("Булево"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ДатаПоследнегоИзмененияЦены", Новый ОписаниеТипов("Дата"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ДатаПоследнегоИзмененияЦеныДополнительно", Новый ОписаниеТипов("Дата"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ДатаИзготовления", Новый ОписаниеТипов("Строка"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("ИнформацияПоГост", Новый ОписаниеТипов("Строка"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("НомерПартии", Новый ОписаниеТипов("Число"));
	ТоварыДляСкладскихЯчеек.Колонки.Добавить("СрокГодности", Новый ОписаниеТипов("Число"));
	
	Для Каждого СтрокаТЧ Из ТаблицаНоменклатуры Цикл
		НоваяСтрока = ТоварыДляСкладскихЯчеек.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
		НоваяСтрока.ДатаИзготовления = Формат(СтрокаТЧ.ДатаИзготовления, "ДФ=dd.MM.yyyy");
		Если НЕ ЗначениеЗаполнено(НоваяСтрока.ШаблонЭтикетки) Тогда
			НоваяСтрока.КоличествоЭтикеток = 0;
		КонецЕсли;
	КонецЦикла;
	
	МаксимальныйКодВесовогоТовара = ПодключаемоеОборудованиеOfflineВызовСервера.МаксимальныйКодВесовогоТовара();
	УстановитьПривилегированныйРежим(Истина);
	ПравилоВыгрузкиВВесы = (ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ПравилоОбмена, "ТипПодключаемогоОборудования") = Перечисления.ТипыПодключаемогоОборудования.ВесыСПечатьюЭтикеток);
	УстановитьПривилегированныйРежим(Ложь);
	
	СтранаРегистрации = ?(ЗначениеЗаполнено(Объект.Организация), ЗначениеНастроекКлиентСерверПовтИсп.СтранаРегистрацииОрганизации(Объект.Организация), Константы.ОсновнаяСтрана.Получить());
	
	ПараметрыПечати = Новый Структура;
	ПараметрыПечати.Вставить("Товары", ПоместитьВоВременноеХранилище(ТоварыДляСкладскихЯчеек, УникальныйИдентификатор));
	ПараметрыПечати.Вставить("Организация",   Объект.Организация);
	ПараметрыПечати.Вставить("СтранаРегистрации", СтранаРегистрации);
	ПараметрыПечати.Вставить("ПравилоОбмена", Объект.ПравилоОбмена);
	ПараметрыПечати.Вставить("МаксимальныйКодВесовогоТовара", МаксимальныйКодВесовогоТовара);
	ПараметрыПечати.Вставить("ПравилоВыгрузкиВВесы",          ПравилоВыгрузкиВВесы);
	ПараметрыПечати.Вставить("ВидЦены",       Объект.ВидЦены);
	ПараметрыПечати.Вставить("Дата",          Объект.Дата);
	ПараметрыПечати.Вставить("Склад",         Объект.Склад);
	ПараметрыПечати.Вставить("ВидЦеныДополнительно", Объект.ВидЦеныДополнительно);
	ПараметрыПечати.Вставить("ДатаДополнительно",    Объект.ДатаДополнительно);
	ПараметрыПечати.Вставить("СтруктураМакетаШаблона", Неопределено);
