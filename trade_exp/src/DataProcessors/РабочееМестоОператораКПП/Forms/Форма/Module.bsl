

#Область ОбработчикиСобытий

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Период.ДатаНачала= НачалоДня(ТекущаяДата());
	Период.ДатаОкончания= КонецДня(ТекущаяДата());
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	
	ЭтоСКУД= Датчик.СКУД; 
	
	ПоследнееСканированиеШлагбаумаВъезд = ТекущаяДата();
	ПоследнееСканированиеШлагбаумаВыезд = ТекущаяДата();
		
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода"); 
	
	Ip = ОпределитьIp() ;
	ПолучитьЗначенияПараметров(); 
	
	Если ЭтоСКУД Тогда
		Если ПодключитьВнешнююКомпоненту("ОбщийМакет.RgSoft","RgSoft",AddInType.Native) = Ложь Тогда 
			УстановитьВнешнююКомпоненту("ОбщийМакет.RgSoft"); 
			Если  ПодключитьВнешнююКомпоненту("ОбщийМакет.RgSoft","RgSoft",AddInType.Native) Тогда
				СКУД = Новый("AddIn.RgSoft.RgSoftExtension");
				Сообщить("Подключен СКУД");
			Иначе
				Сообщить("НЕ Подключен СКУД"); 
			КонецЕсли; 
		Иначе
			СКУД = Новый("AddIn.RgSoft.RgSoftExtension");
			Сообщить("СКУД подключен");
		КонецЕсли; 
		Элементы.ФормаОткрытьШлагбаум.Видимость = Истина; 
		Элементы.ФормаОткрытьШлагбаум2.Видимость = Истина; 
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция ВернутьТипСканера(СканерСтрокой) 
	Если СканерСтрокой = "Ручной" Тогда 
		Возврат Перечисления.ТипСканераКПП.Ручной; 
	ИначеЕсли СканерСтрокой = "СтационарныйВъезд" Тогда 
		Возврат Перечисления.ТипСканераКПП.СтационарныйВъезд; 
	ИначеЕсли СканерСтрокой = "СтационарныйВыезд" Тогда 
		Возврат Перечисления.ТипСканераКПП.СтационарныйВыезд;
	ИначеЕсли СканерСтрокой = "СтационарныйСотрудники" Тогда 
		Возврат Перечисления.ТипСканераКПП.СтационарныйСотрудники; 
	Иначе 
		Возврат Перечисления.ТипСканераКПП.Ручной;	
	КонецЕсли; 
КонецФункции  

&НаСервере 
Функция ОбработатьРезультатСканирования(Результат) 
	Если Результат = Перечисления.РезультатСканированияКПП.ПовторныйВход
			ИЛИ Результат = Перечисления.РезультатСканированияКПП.ОбъектНеНайден
			ИЛИ Результат = Перечисления.РезультатСканированияКПП.НеНайденДатчик
			ИЛИ Результат = Перечисления.РезультатСканированияКПП.НетДоступа
			ИЛИ Результат = Перечисления.РезультатСканированияКПП.ОбъектУдален
			ИЛИ Результат = Перечисления.РезультатСканированияКПП.ОбъектПросрочен
			ИЛИ Результат = Перечисления.РезультатСканированияКПП.Ошибка Тогда 
			
			Возврат "fail"; 
		КонецЕсли;
		
		Если Результат = Перечисления.РезультатСканированияКПП.УспешныйВход Тогда 
			Возврат "ok";
		КонецЕсли; 
		
		Если Результат = Перечисления.РезультатСканированияКПП.УспешныйВыход Тогда 
			Возврат "out"; 
		КонецЕсли;  
		Возврат "null"; 
КонецФункции	
		


&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)                     	
	ДанныеДатчика = ПолучитьДанныеДатчика(Ip); 
	Если Источник = "ПодключаемоеОборудование"  Тогда
		Если ИмяСобытия = "ScanData" Тогда
			ТипСканераСтрокой = "Ручной"; 
		КонецЕсли;
	КонецЕсли;
	Если Источник = "Шлагбаум" И ДанныеДатчика.СКУД Тогда
		Если ИмяСобытия = "Въезд" Тогда	
			ТипСканераСтрокой = "СтационарныйВъезд"; 
		КонецЕсли;
	КонецЕсли; 
	Если Источник = "Шлагбаум" И ДанныеДатчика.СКУД Тогда
		Если ИмяСобытия = "Выезд" Тогда	
			ТипСканераСтрокой = "СтационарныйВыезд"; 
		КонецЕсли;
	КонецЕсли;
	Если Источник = "СканерСотрудники" И ДанныеДатчика.СКУД Тогда
		Если ИмяСобытия = "ScanData" Тогда	
			ТипСканераСтрокой = "СтационарныйСотрудники"; 
		КонецЕсли;
	КонецЕсли;

	
	БлокировкаОбработки = Ложь;  
	
	Если ТипСканераСтрокой = "СтационарныйВъезд" Тогда 
		Если (ТекущаяДата() - ПоследнееСканированиеШлагбаумаВъезд) < 5 Тогда 
			БлокировкаОбработки = Истина; 
		Иначе	
			ПоследнееСканированиеШлагбаумаВъезд = ТекущаяДата(); 	
		КонецЕсли; 
	КонецЕсли;
	
	Если ТипСканераСтрокой = "СтационарныйВыезд" Тогда 
		Если (ТекущаяДата() - ПоследнееСканированиеШлагбаумаВыезд) < 5 Тогда 
			БлокировкаОбработки = Истина;
		Иначе	
			ПоследнееСканированиеШлагбаумаВыезд = ТекущаяДата();
		КонецЕсли; 
	КонецЕсли; 
	
	Если Не БлокировкаОбработки И ТипЗнч(Параметр) = Тип("Массив") Тогда 
		Данные = ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
		Штрихкод = Данные.Штрихкод;	
		ЗарегистрированВход = Неопределено; 
		Попытка 
			РезультатСканирования = УправлениеДоступомСервер.ОбработатьЗапросSKUD(Ip, Штрихкод, Датчик, ЗонаДоступа, ВернутьТипСканера(ТипСканераСтрокой));
		Исключение 
			Сообщить("Неиницилизированная ошибка"); 
		КонецПопытки; 
		Результат = ОбработатьРезультатСканирования(РезультатСканирования); 
		Если Результат <> "null" Тогда 
			ПроигратьЗвук(Результат); 
			Если ТипСканераСтрокой = "СтационарныйВъезд" и Результат = "ok" Тогда
				ОткрытьШлагбаумОбщая(ДанныеДатчика.АдресСервераСКУД, ДанныеДатчика.IDШлагбаумаВъезд);
			КонецЕсли;   
			Если ТипСканераСтрокой = "СтационарныйВыезд" и Результат = "out" Тогда 
				ОткрытьШлагбаумОбщая(ДанныеДатчика.АдресСервераСКУД, ДанныеДатчика.IDШлагбаумаВыезд);
			КонецЕсли;
		КонецЕсли; 
		
	КонецЕсли;
		
	ЗаполнитьТЗСервер();
КонецПроцедуры

