&НаСервере
Функция ПроверитьНеобходимостьПодтвержднияЗаписи(Датчик, ДатаСобытия)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсторияДоступа.Событие КАК Событие,
	|	ИсторияДоступа.ДатаСобытия КАК ДатаСобытия,
	|	ИсторияДоступа.Объект КАК Документ
	|ИЗ
	|	РегистрСведений.ИсторияДоступа КАК ИсторияДоступа
	|ГДЕ
	|	ИсторияДоступа.ТребуетсяПодтверждение
	|	И ИсторияДоступа.Событие = ЗНАЧЕНИЕ(Перечисление.СобытиеСКУД.ПустаяСсылка)
	|	И ИсторияДоступа.Датчик = &Датчик
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСобытия УБЫВ";
	Запрос.УстановитьПараметр("Датчик", Датчик);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	ДатаСобытия = Выборка.ДатаСобытия; 
	Возврат Выборка.Документ;
	
КонецФункции

