&НаСервере 
Процедура ЗаполнитьТЗСервер() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсторияДоступа.Объект КАК Пропуск,
	|	ИсторияДоступа.Событие КАК Событие,
	|	ИсторияДоступа.ДатаСобытия КАК ДатаСобытия,
	|	ИсторияДоступа.ЦельПосещения КАК ЦельПосещения,
	|	ИсторияДоступа.Комментарий КАК Ошибка,
	|	ИсторияДоступа.ЗонаДоступа КАК ЗонаДоступа,
	|	ИсторияДоступа.ФИО КАК ФИО,
	|	ИсторияДоступа.ТипСканераКПП КАК ТипСканера
	|ИЗ
	|	РегистрСведений.ИсторияДоступа КАК ИсторияДоступа
	|ГДЕ
	|	ИсторияДоступа.ДатаСобытия МЕЖДУ &Дата1 И &Дата2
	|	И ИсторияДоступа.ЗонаДоступа = &ЗонаДоступа
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаСобытия УБЫВ";
	
	Запрос.УстановитьПараметр("Дата1", Период.ДатаНачала);
	Запрос.УстановитьПараметр("Дата2", Период.ДатаОкончания);
	Запрос.УстановитьПараметр("ЗонаДоступа", ЗонаДоступа);
	//Запрос.УстановитьПараметр("Датчик", Датчик);
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗСобытияСКУД.Загрузить(РезультатЗапроса.Выгрузить());
КонецПроцедуры

