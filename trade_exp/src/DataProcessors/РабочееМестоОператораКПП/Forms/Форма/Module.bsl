#Область ФункцииРаботыСоЗвуком
&НаКлиенте
Процедура ПроигратьЗвук(Звук)
	
	Попытка
		ДанныеЗвука = ПолучитьМакет(Звук);
		ИмяВременногоФайла = КаталогВременныхФайлов() + Звук + ".wav";
		ДанныеЗвука.Записать(ИмяВременногоФайла);	
		oVoice = Новый COMObject("SAPI.SpVoice");
		oSpFileStream = Новый COMObject("SAPI.SpFileStream");
		oSpFileStream.Open(ИмяВременногоФайла);
		oVoice.SpeakStream(oSpFileStream);
		oSpFileStream.Close();
	Исключение
		Сообщить("Ошибка: " + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

