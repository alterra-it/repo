&НаСервере
Функция НайтиНаСервере()

	НомерДокумента = ДобавитьНули(НомерДокумента,6);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказПоставщику.Ссылка КАК ЗаказПоставщику,
		|	РейсОтПоставщикаРасчетДоставки.Ссылка КАК РейсОтПоставщика
		|ИЗ
		|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		|		ПО (РейсОтПоставщикаРасчетДоставки.ДокументОснование = ЗаказПоставщику.Ссылка)
		|			И (РейсОтПоставщикаРасчетДоставки.Ссылка.Проведен = ИСТИНА)
		|ГДЕ
		|	ЗаказПоставщику.Подразделение = &Подразделение
		|	И ЗаказПоставщику.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
		|	И ЗаказПоставщику.Проведен = ИСТИНА
		|	И ВЫБОР
		|			КОГДА &Номер <> """"
		|				ТОГДА ЗаказПоставщику.Номер ПОДОБНО ""%"" + &Номер
		|		КОНЕЦ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЗаказПоставщику.Дата УБЫВ";	
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	Запрос.УстановитьПараметр("ДатаНачала",ДобавитьМесяц(НачалоГода(Текущаядата()),-2));
	Запрос.УстановитьПараметр("ДатаОкончания",КонецГода(Текущаядата()));
	Запрос.УстановитьПараметр("Номер",НомерДокумента);

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Заказы.Очистить();
		
	Если РезультатЗапроса.Количество()>0 Тогда
		РезультатПоиска = "";
		Рейс = РезультатЗапроса[0].РейсОтПоставщика;
		Если ЗначениеЗаполнено(Рейс) Тогда
			ПолучитьЗаказыПоРейсу(Рейс);
		Иначе
			НоваяСтрока = Заказы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,РезультатЗапроса[0]);
		КонецЕсли;
	Иначе
		РезультатПоиска = "Для подразделения '" + Подразделение + "' не найден Заказ поставщику № " + НомерДокумента;
	КонецЕсли;
	
	Возврат РезультатПоиска;
КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкоды(Данные)
	
МассивСсылок = СсылкаНаЭлементСпискаПоШтрихкоду(Данные.Штрихкод);

НайтиНаСервереПоСсылке(МассивСсылок);

РаспечататьПропуск();	
КонецПроцедуры

&НаСервере
Процедура НайтиНаСервереПоСсылке(МассивСсылок)
	
	МассивЗаказов = Новый Массив;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказПоставщику.Ссылка КАК ЗаказПоставщику,
		|	РейсОтПоставщикаРасчетДоставки.Ссылка КАК РейсОтПоставщика
		|ИЗ
		|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		|		ПО (РейсОтПоставщикаРасчетДоставки.ДокументОснование = ЗаказПоставщику.Ссылка)
		|			И (РейсОтПоставщикаРасчетДоставки.Ссылка.Проведен = ИСТИНА)
		|ГДЕ
		|	ЗаказПоставщику.Подразделение = &Подразделение
		|	И ЗаказПоставщику.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
		|	И ЗаказПоставщику.Проведен = ИСТИНА
		|	И ЗаказПоставщику.Ссылка В(&Ссылка)";
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	Запрос.УстановитьПараметр("ДатаНачала",ДобавитьМесяц(НачалоГода(Текущаядата()),-2));
	Запрос.УстановитьПараметр("ДатаОкончания",КонецГода(Текущаядата()));
	Запрос.УстановитьПараметр("Ссылка",МассивСсылок);

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Заказы.Очистить();
		
	Если РезультатЗапроса.Количество()>0 Тогда
		Рейс = РезультатЗапроса[0].РейсОтПоставщика;
		Если ЗначениеЗаполнено(Рейс) Тогда
			ПолучитьЗаказыПоРейсу(Рейс);
		Иначе
			НоваяСтрока = Заказы.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,РезультатЗапроса[0]);
		КонецЕсли;
	КонецЕсли;
Конецпроцедуры

&НаСервере
Процедура ПолучитьЗаказыПоРейсу(Рейс)
	
	Заказы.Очистить();
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РейсОтПоставщикаРасчетДоставки.ДокументОснование.Ссылка КАК ЗаказПоставщику
	|ИЗ
	|	Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
	|ГДЕ
	|	РейсОтПоставщикаРасчетДоставки.ДокументОснование.Подразделение = &Подразделение
	|	И РейсОтПоставщикаРасчетДоставки.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Подразделение",Подразделение);
	Запрос.УстановитьПараметр("Ссылка",Рейс);	
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	МассивЗаказов = Новый Массив;
	
	Для каждого строка из РезультатЗапроса Цикл
		НоваяСтрока = Заказы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,строка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗарегистрироватьПрибытиеПоставкиНаСклад(МассивЗаказов)
	ВремяИСостояниеПоставки = Альтерра_СеткаПоставок.ПолучитьТекущееСостояниеПоставки(МассивЗаказов, Истина);
	Если ВремяИСостояниеПоставки.Количество() > 0 И СтрНайти(ВремяИСостояниеПоставки[0].СостояниеПоставки, "апланирована") <> 0 Тогда
		ИзменяемыеПараметры = Новый Структура;
		ИзменяемыеПараметры.Вставить("ДатаВремяПриездаФакт",  НачалоМинуты(ТекущаяДата()));
		Альтерра_СеткаПоставок.ИзменитьДанныеСеткиПоставок(МассивЗаказов, "Редактирование", ИзменяемыеПараметры);
	КонецЕсли;
КонецПроцедуры // ЗарегистрироватьПрибытиеПоставкиНаСклад()

&НаКлиенте
Функция СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод)
	Менеджеры = Новый Массив();
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ЗаказПоставщику.ПустаяСсылка"));
	
	Возврат ШтрихкодированиеПечатныхФормКлиент.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, Менеджеры);
КонецФункции

&НаКлиенте
Процедура РаспечататьПропуск()
	
	МассивЗаказов = Новый Массив;
	Для каждого Строка из Заказы Цикл
		МассивЗаказов.Добавить(Строка.ЗаказПоставщику);
	КонецЦикла;
	Если МассивЗаказов.Количество()>0 Тогда
			ПараметрыПечати = Новый Структура();
			ПараметрыПечати.Вставить("Регистрация", Истина);
			УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер(
							"Обработка.Самообслуживание",
							"ПФ_MXL_ПропускНаСклад",
							МассивЗаказов,
							ПараметрыПечати);

			//Сетка поставок
			ЗарегистрироватьПрибытиеПоставкиНаСклад(МассивЗаказов);	
			
			НомерДокумента = "";
			
			ПодключитьОбработчикОжидания("ЗакрытиеФормыПослеСканирования", 10, Ложь);
	Иначе
		//Сообщить("Нет данных для печати!");
	КонецЕсли;
КонецПроцедуры

Функция ДобавитьНули(Значение, НужнаяДлинаЗначения)

Значение  = СтрЗаменить(Формат(Значение, "ЧГ="), " ", "");
НадоНулей =  НужнаяДлинаЗначения - СтрДлина(Значение);
ВедущиеНули =  Формат(0,"ЧЦ="+НадоНулей+";ЧН=; ЧВН=; ЧГ=0");
Возврат ВедущиеНули  + Значение;

КонецФункции  

&НаКлиенте
Процедура ЗакрытиеФормыПослеСканирования() Экспорт
 Закрыть();	
КонецПроцедуры

