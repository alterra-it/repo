
#Область СобытияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	ВремяПоследнегоСканирования= ТекущаяДата();
	
	СтрукЦветаСтиля= ПолучитьЦвета();
	
	АдрессЗапрещено= ПоместитьВоВременноеХранилище(БиблиотекаКартинок.Запрещено300.ПолучитьДвоичныеДанные(), УникальныйИдентификатор);
	АдрессРазрешено= ПоместитьВоВременноеХранилище(БиблиотекаКартинок.Разрешено300.ПолучитьДвоичныеДанные(), УникальныйИдентификатор);
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
КонецПроцедуры

//СТАРТ
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	НадписьСообщения= "";
	Картинка= Неопределено;
	Элементы.Картинка.Обновить();
	Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Красный;
	Элементы.НадписьСотрудник.Видимость= Ложь;
	Элементы.НадписьДокумент.Видимость= Ложь;
	Если Источник = "ПодключаемоеОборудование"  Тогда//Ввод доступен ставить не нужно, т.к. окно теряет фокус
		Если ИмяСобытия = "ScanData" Тогда
			Данные= ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
			Штрихкод= Данные.Штрихкод;
			
			Если ПустаяСтрока(Штрихкод) Тогда
				НадписьСообщения= "Не удалось прочитать штрихкод!";
				ПроигратьЗвук("fail");
				Возврат;
			КонецЕсли;
			
			
			Если Лев(Штрихкод, 4) = "8888" Тогда//Это сотрудник
				ЗарегистрироватьСотрудникаПоШтрихкоду(Штрихкод);
				
			Иначе//Это документ
				
				МассивСсылок = СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод);
				Если МассивСсылок.Количество() = 0 Тогда
					//Провереим не печать ли по секциям просканировали
					Ссылка= РСОбщийМодульВызовСервера.ПоискДокументаПоШК(Штрихкод);
					Если Не ЗначениеЗаполнено(Ссылка) Тогда
						НадписьСообщения = "Документ не найден";
						ЗафиксироватьОшибку(Неопределено, ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументНеНайден"), Штрихкод);
						Возврат;
					Иначе
						НадписьСообщения = "Просканировали печать по секциям";
						ЗафиксироватьОшибку(Ссылка, ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.СканировалиПечатьПоСекциям"), Штрихкод);
					КонецЕсли;
				Иначе
					Ссылка = МассивСсылок[0];
				КонецЕсли;
				
				НадписьДокумент= Ссылка;
				Элементы.НадписьДокумент.Видимость= Истина;
				
				Если ЭтоОшибочноеСканирование(Ссылка) Тогда
					ПодключитьОбработчикОжидания("НачальноеСостониеФормы", 2);
					Возврат;
				КонецЕсли;
				
				//Если есть рейс запускам все документы
				Рейс = ПолучитьРейс(Ссылка);
				Если ЗначениеЗаполнено(Рейс) Тогда
					ЗарегистрироватьСостояниеПоРейсу(Рейс, Штрихкод, Ложь);
					Возврат;
				Иначе
					Рейс = УправлениеДоступомСервер.ПолучитьРейсОтПоставщика(Ссылка);
					Если ЗначениеЗаполнено(Рейс) Тогда
						Для Каждого Заказ Из Рейс Цикл	
							ОбработатьДокументНаВъездВыезд(Заказ, Штрихкод, Ложь);
						КонецЦикла;
						Возврат;
					Иначе
						ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;		
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область РегистрацияВъездаВыезда
//ГЛАВНАЯ
&НаКлиенте
Процедура ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод="", ЭтоРейс=Ложь)
	ОтключитьОбработчикОжидания("НачальноеСостониеФормы");
	ПоследнийПросканированныйДокумент= Неопределено;
	
	Попытка
		//Если машина на складе регестрируем выезд без проверок
		Если МашинаНаСкладе(Ссылка) Тогда
			РегистрацияСостоянияВыезда(Ссылка, Штрихкод);
			Возврат;
		КонецЕсли;
		
		//Повторный заезд
		Если МашинаУжеВыезжала(Ссылка) Тогда
			Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ПовторныйЗаезд");
			ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод);	
		КонецЕсли;
		
		//ОБРАБОТКА ДОКУМЕНТОВ			
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			ОбработатьРеализацию(Ссылка, Штрихкод, ЭтоРейс);
			
		ИначеЕсли  ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
			ОбработатьЧек(Ссылка, Штрихкод, ЭтоРейс);

		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда 
			ОбработатьЗаказПоставщику(Ссылка, Штрихкод);
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда 
			ОбработатьПеремещение(Ссылка, Штрихкод);
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаданиеНаПеревозкуРейс") Тогда 
			ЗарегистрироватьСостояниеПоРейсу(Ссылка, Штрихкод, Истина);
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМВозврат") Тогда 
			ОбработатьВозврат(Ссылка, Штрихкод);
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ОбработатьЗаказКлиента(Ссылка, Штрихкод);
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.БлокировкаДвиженияТоваров") Тогда
			ОбработатьБлокировку(Ссылка, Штрихкод);

		Иначе
			ОбработатьЛюбойДругой(Ссылка, Штрихкод);
		КонецЕсли;
		
	Исключение
		ПодключитьОбработчикОжидания("НачальноеСостониеФормы", 2);
	КонецПопытки;
	
	ПодключитьОбработчикОжидания("НачальноеСостониеФормы", 2);
КонецПроцедуры

//ОБРАБОТКА ДОКУМЕНТОВ
&НаКлиенте
Процедура ОбработатьРеализацию(Ссылка, Штрихкод, ЭтоРейс= Ложь)
	Ошибка= Неопределено; 
	
	Если Не ЭтоРейс Тогда
		Рейс= ПолучитьРейс(Ссылка);
		Если ЗначениеЗаполнено(Рейс) Тогда
			Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДолженСканироватсяМаршрутныйЛист");
		КонецЕсли;
	КонецЕсли;

	Если Не ДокументОплачен(Ссылка) Тогда
		Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументНеОплачен");
	ИначеЕсли ДокументОтгружен(Ссылка) Тогда
		Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументПолностьюОтгружен");
	КонецЕсли;
	
	Если Ошибка <> Неопределено Тогда
		ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод);					
	КонецЕсли;
	
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод, Ошибка);
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьЧек(Ссылка, Штрихкод, ЭтоРейс= Ложь)
	Ошибка= Неопределено;
	
	Если Не ЭтоРейс Тогда
		Рейс= ПолучитьРейс(Ссылка);
		Если ЗначениеЗаполнено(Рейс) Тогда
			Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДолженСканироватсяМаршрутныйЛист");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЧекПробит(Ссылка) Тогда
		Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументНеОплачен");
	ИначеЕсли ДокументОтгружен(Ссылка) Тогда
		Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ДокументПолностьюОтгружен");
	КонецЕсли;
	
	Если Ошибка <> Неопределено Тогда
		ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод);					
	КонецЕсли;
	
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод, Ошибка);
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьЗаказПоставщику(Ссылка, Штрихкод)
	Ошибка= Неопределено;
	СтатусДокумента = ПолучитьСтатус(Ссылка);
	Если СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.НеСогласован") ИЛИ СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.Закрыт") Тогда
		Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.СтатусЗаказаНеКПоступлению");
	КонецЕсли;
	
	Если Ошибка <> Неопределено Тогда
		ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод);					
	КонецЕсли;
	
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод, Ошибка);
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьПеремещение(Ссылка, Штрихкод)
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод);
КонецПроцедуры
&НаКлиенте
Процедура ОбработатьПоставкуНаСклад(Ссылка, Штрихкод)
	Ошибка= Неопределено;

	Если ПолучитьСтатус(Ссылка) = ПредопределенноеЗначение("Перечисление.СтатусыПоставокНаСклад.Прибыл")  Тогда					
		РегистрацияСостоянияЗаезда(Ссылка, Штрихкод);
	ИначеЕсли ПолучитьСтатус(Ссылка) = ПредопределенноеЗначение("Перечисление.СтатусыПоставокНаСклад.Разгружается") Тогда
	Иначе
		Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.НеВерныйСтатусДокумента");
		ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод);					
		РегистрацияСостоянияЗаезда(Ссылка, Штрихкод, Ошибка);
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Функция ЗарегистрироватьСостояниеПоРейсу(Рейс, Штрихкод, ЭтоРейс=Ложь)
	мДокументовПродажи= УправлениеДоступомСервер.ПолучитьДокументыПродажиСервер(Рейс);
	
	Для Каждого Ссылка Из мДокументовПродажи Цикл	
		ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод, ЭтоРейс);
	КонецЦикла;
	
	УстановитьСтатусРейса(Рейс);
КонецФункции
&НаКлиенте
Процедура ОбработатьВозврат(Ссылка, Штрихкод)
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЗаказКлиента(Ссылка, Штрихкод)
	мДокументовПродажи = УправлениеДоступомСервер.ПолучитьДокументыПродажиСервер(Ссылка); 
	Для Каждого Ссылка Из мДокументовПродажи Цикл	
		ОбработатьДокументНаВъездВыезд(Ссылка, Штрихкод);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьБлокировку(Ссылка, Штрихкод)
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод);
КонецПроцедуры	
	
&НаСервереБезКонтекста
Процедура УстановитьСтатусРейса(Ссылка)
	Рейс= Ссылка.ПолучитьОбъект();
	Если Ссылка.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ДокументыНаПогрузкуГотовы") ИЛИ Ссылка.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ВодительДокументыПолучил") Тогда
		Рейс.Статус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСНаПогрузке");
	ИначеЕсли Ссылка.Статус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСНаПогрузке") Тогда
		Рейс.Статус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСВПути");
	КонецЕсли;
	Рейс.Записать(РежимЗаписиДокумента.Проведение);
	
	АльтерраОбщегоНазначения.УстановитьСтатусВодителю(Рейс.Водитель, Перечисления.СтатусыВодителей.ВРейсе, "установлен из КПП",, Рейс.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьЛюбойДругой(Ссылка, Штрихкод)
	Ошибка= ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.НеПредусмотренДляСканирования");
	ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод);					
	
	РегистрацияСостоянияЗаезда(Ссылка, Штрихкод, Ошибка);
КонецПроцедуры

#КонецОбласти

#Область ЗаписьВРегистр
&НаСервереБезКонтекста
Функция МашинаНаСкладе(Ссылка)
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостояниеОтгрузкиДокументаСрезПоследних.Период
	|ИЗ
	|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(, Документ = &Ссылка) КАК СостояниеОтгрузкиДокументаСрезПоследних
	|ГДЕ
	|	СостояниеОтгрузкиДокументаСрезПоследних.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Заехал)";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции
&НаСервереБезКонтекста
Функция МашинаУжеВыезжала(Ссылка)
	Результат = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СостояниеОтгрузкиДокументаСрезПоследних.Период КАК Период
	|ИЗ
	|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(
	|			,
	|			Документ = &Ссылка
	|				И Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Выехал)) КАК СостояниеОтгрузкиДокументаСрезПоследних";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Результат = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция РегистрацияСостояния(Ссылка, Состояние, Штрихкод="", Ошибка)
	УстановитьПривилегированныйРежим(Истина);
	Результат = Истина;
	
	ДатаСобытия = ТекущаяДата();
	
	Запись = РегистрыСведений.СостояниеОтгрузкиДокумента.СоздатьМенеджерЗаписи();
	
	Запись.Документ			= Ссылка;
	Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", Ссылка.Метаданные()) Тогда
		Запись.Филиал			= Ссылка.Подразделение;
	КонецЕсли;
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.БлокировкаДвиженияТоваров") Тогда
		Запись.Филиал			= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка.Склад,"Подразделение");
	КонецЕсли;
	Запись.Период				= ДатаСобытия;	
	Запись.Состояние		= ?(Состояние="Заезд", Перечисления.СостоянияОтгрузкиДокумента.Заехал, Перечисления.СостоянияОтгрузкиДокумента.Выехал);
	Запись.Штрихкод			= Штрихкод;
	Запись.Ошибка= Ошибка;
	Запись.НомерЗаезда = ПолучитьНомерЗаезда(Ссылка)+1;
	
	Попытка
		Запись.Записать(Ложь);
	Исключение
		Сообщить(ИнформацияОбОшибке().Описание);
		Результат = Ложь;	
	КонецПопытки;
		
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Результат;
КонецФункции
&НаСервереБезКонтекста
Функция РегистрацияСостоянияОшибка(Ссылка, Ошибка, Штрихкод="")
	УстановитьПривилегированныйРежим(Истина);
	Результат = Истина;
	
	ДатаСобытия = ТекущаяДата();
	
	Запись = РегистрыСведений.СостояниеОтгрузкиДокумента.СоздатьМенеджерЗаписи();
	Если ЗначениеЗаполнено(Ссылка) Тогда 
		Запись.Документ			= Ссылка;
		Если ОбщегоНазначения.ЕстьРеквизитОбъекта("Подразделение", Ссылка.Метаданные()) Тогда
			Запись.Филиал			= Ссылка.Подразделение;
		КонецЕсли;
	КонецЕсли;
	Запись.Период				= ДатаСобытия;	
	Запись.Состояние		= Перечисления.СостоянияОтгрузкиДокумента.Ошибка;
	Запись.Ошибка			= Ошибка;
	Запись.Штрихкод			= Штрихкод;
	
	Попытка
		Запись.Записать(Ложь);
	Исключение
		Результат = Ложь;	
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Результат;
	
КонецФункции
&НаСервереБезКонтекста
Функция ЗаписатьОтзывКлиента(Ссылка, ОценкаКлиента)
	УстановитьПривилегированныйРежим(Истина);
	Результат = Истина;
	
	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	СостояниеОтгрузкиДокументаСрезПоследних.Период КАК Период,
	|	СостояниеОтгрузкиДокументаСрезПоследних.Документ,
	|	СостояниеОтгрузкиДокументаСрезПоследних.Филиал,
	|	СостояниеОтгрузкиДокументаСрезПоследних.Состояние,
	|	СостояниеОтгрузкиДокументаСрезПоследних.Ошибка,
	|	СостояниеОтгрузкиДокументаСрезПоследних.ОценкаКлиента
	|ИЗ
	|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(
	|			,
	|			Документ = &Документ
	|				И Состояние = &Состояние
	|				И Филиал = &Филиал) КАК СостояниеОтгрузкиДокументаСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период УБЫВ";
	
	Запрос.УстановитьПараметр("Документ", Ссылка);
	Запрос.УстановитьПараметр("Состояние", Перечисления.СостоянияОтгрузкиДокумента.Выехал);
	Запрос.УстановитьПараметр("Филиал", Ссылка.Подразделение);
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	Если ТЗ.Количество() = 1 Тогда
		РСНЗСостояниеОтгрузкиДокумента = РегистрыСведений.СостояниеОтгрузкиДокумента.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(РСНЗСостояниеОтгрузкиДокумента, ТЗ[0]);
		РСНЗСостояниеОтгрузкиДокумента.Прочитать();
		Если РСНЗСостояниеОтгрузкиДокумента.Выбран() Тогда
			РСНЗСостояниеОтгрузкиДокумента.ОценкаКлиента= ОценкаКлиента;
			
			Попытка
				РСНЗСостояниеОтгрузкиДокумента.Записать();
			Исключение
				Результат = Ложь;	
			КонецПопытки;
		Иначе
			Возврат Ложь;
		КонецЕсли;
	Иначе
		Результат = Ложь;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
		Возврат Результат;
	КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьНомерЗаезда(Документ)

	МассивСтатусов = Новый Массив();
	МассивСтатусов.Добавить(Перечисления.СостоянияОтгрузкиДокумента.Заехал);
	МассивСтатусов.Добавить(Перечисления.СостоянияОтгрузкиДокумента.Выехал);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостояниеОтгрузкиДокументаСрезПоследних.НомерЗаезда КАК НомерЗаезда
		|ИЗ
		|	РегистрСведений.СостояниеОтгрузкиДокумента.СрезПоследних(
		|			&Период,
		|			Документ = &Документ
		|				И Состояние В (&МассивСтатусов)) КАК СостояниеОтгрузкиДокументаСрезПоследних";
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.НомерЗаезда;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции	
	
&НаКлиенте
Процедура РегистрацияСостоянияЗаезда(Ссылка, Штрихкод="", Ошибка=Неопределено)
	Если РегистрацияСостояния(Ссылка, "Заезд", Штрихкод, Ошибка) Тогда
		Если Не ЗначениеЗаполнено(Ошибка) Тогда
			Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Зеленый;
			НадписьСообщения= "Машина заехала.";
			Картинка= АдрессРазрешено;
			ПроигратьЗвук("ok");
		КонецЕсли;
	Иначе
		ЗафиксироватьОшибку(Ссылка, ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ОшибкаРегистрацииЗаезда"), Штрихкод);					
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура РегистрацияСостоянияВыезда(Ссылка, Штрихкод="", Ошибка=Неопределено)
	Если ОшибочнаяРегистрацияНаВъезд(Ссылка) Тогда
		Возврат;
	КонецЕсли;
	Если РегистрацияСостояния(Ссылка, "Выезд", Штрихкод, Ошибка) Тогда
		Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Синий;
		НадписьСообщения= "Машина выехала.";
		Картинка= АдрессРазрешено;
		ПроигратьЗвук("out");
		ПоследнийПросканированныйДокумент= Ссылка;
	Иначе
		ЗафиксироватьОшибку(Ссылка, ПредопределенноеЗначение("Перечисление.ОшибкиНаКПП.ОшибкаРегистрацииВыезда"), Штрихкод);				
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура  ЗафиксироватьОшибку(Ссылка, Ошибка, Штрихкод="")
	Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Красный;
	НадписьСообщения= Строка(Ошибка)+" ("+Штрихкод+")!";
	Картинка= АдрессЗапрещено;
	РегистрацияСостоянияОшибка(Ссылка, Ошибка, Штрихкод);
	ПроигратьЗвук("fail");
	Пауза(1);
КонецПроцедуры

#КонецОбласти

#Область РегистрацияСотрудников
&НаКлиенте
Процедура ЗарегистрироватьСотрудникаПоШтрихкоду(Штрихкод)
	Результат= ЗрегестрироватьСотрудникаПоШтрихкодуСервер(Штрихкод);
	
	Если Результат.Ошибка Тогда
		Картинка= АдрессЗапрещено;
		Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Красный;
		НадписьСообщения= Результат.ТекстОшибки;
		ПроигратьЗвук("fail");
	Иначе
		Если Не ЗначениеЗаполнено(Картинка) Тогда
			Картинка= АдрессРазрешено;
		КонецЕсли;
		Если  Результат.Событие = ПредопределенноеЗначение("Перечисление.СостоянияСотрудников.Зашел") Тогда 
			Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Зеленый;
			НадписьСообщения= "Сотрудник зашел!";
			ПроигратьЗвук("ok");
		Иначе
			Элементы.НадписьСообщения.ЦветТекста= СтрукЦветаСтиля.Синий;
			НадписьСообщения= "Сотрудник вышел!";
			ПроигратьЗвук("out");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ЗрегестрироватьСотрудникаПоШтрихкодуСервер(Штрихкод)
	Ошибка= Ложь;
	Сотрудник= Справочники.Сотрудники.НайтиПоКоду(Штрихкод);
	Событие= Перечисления.СостоянияСотрудников.Вышел;
	
	Результат= АльтерраОбщегоНазначения.СотрудникВОфисе(Сотрудник);
	
	ПредыдущееСостояние= Результат.Состояние;
	ПериодПредудущегоСобытия= Результат.Период;
	
	//Проверяем двойное сканирование
	Если (ПериодПредудущегоСобытия+5*1) >= ТекущаяДата() Тогда
		Ошибка= Истина;
		Событие= ПредыдущееСостояние;
		Возврат  Новый Структура("Событие, Ошибка,ТекстОшибки", Событие, Ошибка, "Между последним сконированием прошло меньше 5 минут!");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		НадписьСотрудник= Сотрудник.Наименование+", "+Сотрудник.Должность;
		Элементы.НадписьСотрудник.Видимость= Истина;
		Если Сотрудник.Уволен Или Сотрудник.ПометкаУдаления Тогда
			Возврат Новый Структура("Событие,Ошибка,ТекстОшибки", Неопределено, Истина, "Сотрудник уволен!");
		Иначе
			НаборЗаписей= РегистрыСведений.УчетРабочегоВремениСотрудников.СоздатьНаборЗаписей();
			НоваяЗапись= НаборЗаписей.Добавить();
			НоваяЗапись.Период= ТекущаяДата();
			НоваяЗапись.Сотрудник= Сотрудник;
			НоваяЗапись.Пользователь= Сотрудник.Пользователь;
			НоваяЗапись.Подразделение= ?(ЗначениеЗаполнено(Сотрудник.Подразделение), Сотрудник.Подразделение, Сотрудник.Пользователь.ТекущееПодразделение);
			
			Если НачалоДня(ПериодПредудущегоСобытия) < НачалоДня(ТекущаяДата()) Тогда
				НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Зашел;
			Иначе
				// Общая проверка
				Если  ПредыдущееСостояние = Перечисления.СостоянияСотрудников.Вышел Тогда//Вышел или ещё не было
					НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Зашел;
				Иначе
					НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Вышел;
				КонецЕсли;
			КонецЕсли;
			Событие= НоваяЗапись.Событие;
			
			НаборЗаписей.Записать(Ложь);
			
			ДанныеФотографии= Сотрудник.Фотография.Получить();
			Если ЗначениеЗаполнено(ДанныеФотографии) Тогда
				Картинка= ПоместитьВоВременноеХранилище(ДанныеФотографии);
			Иначе
				Картинка= Неопределено;
			КонецЕсли;
		КонецЕсли;
	Иначе 
		Ошибка= Истина;
		Возврат  Новый Структура("Событие,Ошибка,ТекстОшибки", Событие, Истина, "Сотрудник не найден!");
	КонецЕсли;
	
	Возврат  Новый Структура("Событие,Ошибка,ТекстОшибки", Событие, Ошибка, "");
КонецФункции
