	 "ВызовСерверногоМетода",    
	 Истина,                        
	 "ЗапускПоРасписанию",                 
	 );
	 
	 ПараметрыРегистрации.Вставить("Команды", ТаблицаКоманд);
	 
	 Возврат ПараметрыРегистрации;
	 
 КонецФункции
 
 Функция ПолучитьТаблицу_Команд()
	 
	 Команды = Новый ТаблицаЗначений;
	 Команды.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	 Команды.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	 Команды.Колонки.Добавить("Использование", Новый ОписаниеТипов("Строка"));
	 Команды.Колонки.Добавить("ПоказыватьОповещение", Новый ОписаниеТипов("Булево"));
	 Команды.Колонки.Добавить("Модификатор", Новый ОписаниеТипов("Строка"));
	 
	 Возврат Команды;
	 
 КонецФункции
 
 Процедура ДобавитьКоманду(ТаблицаКоманд, Представление, Идентификатор, Использование, ПоказыватьОповещение = Ложь, Модификатор = "", Назначение)
	 
	 НоваяКоманда = ТаблицаКоманд.Добавить();
	 НоваяКоманда.Представление = Представление;
	 НоваяКоманда.Идентификатор = Идентификатор;
	 НоваяКоманда.Использование = Использование;
	 НоваяКоманда.ПоказыватьОповещение = ПоказыватьОповещение;
	 НоваяКоманда.Модификатор = Модификатор;
	 
 КонецПроцедуры
 
 // Интерфейс для запуска логики обработки.
 Процедура ВыполнитьКоманду(ИдентификаторКоманды) Экспорт
	 Если ИдентификаторКоманды =  "ЗапускПоРасписанию" Тогда
		 ОтправитьПисьма();
	 КонецЕсли;
 КонецПроцедуры
 
Процедура ОтправитьПисьма() Экспорт
	 ЗаписьЖурналаРегистрации("РегламентноеЗадание.РассылкаПисемОНачисленныхБонусныхБаллах", УровеньЖурналаРегистрации.Примечание, , , "Начало отправки писем");
	 
	 УчетнаяЗапись= Справочники.УчетныеЗаписиЭлектроннойПочты.НайтиПоНаименованию("tg-alterra2@yandex.ru", Истина);
	 
	 ВыборкаДетальныеЗаписи= ЗапросКБаллам();
	 
	 Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		 Почта= ВыборкаДетальныеЗаписи.Почта;
		 
		 Если Не ПроверкаАдресаПочты(Почта) Тогда
			 ЗаписьЖурналаРегистрации("РегламентноеЗадание.РассылкаПисемОНачисленныхБонусныхБаллах", УровеньЖурналаРегистрации.Примечание, , , "У партнера "+ВыборкаДетальныеЗаписи.Партнер+" не корректно задана почта: "+Почта);
			 Продолжить;
		 КонецЕсли;
		 
		 Попытка
			 Письмо=  Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
			 
			 Почта= "bespalov.alexey@ya.ru";

			 СкрытаяПочта= "";
			 СкрытаяПочта= "ryabushkina@tg-alterra.ru";
			 
			 ЗаполнитьПисьмо(Письмо, ВыборкаДетальныеЗаписи, Почта, СкрытаяПочта);
			 
			 Письмо.Записать();
			 
			 
			 ЗаписьЖурналаРегистрации("РегламентноеЗадание.РассылкаПисемОНачисленныхБонусныхБаллах", УровеньЖурналаРегистрации.Примечание, , , "Отправлено письмо на адресс: "+Почта);
		 Исключение
			 ЗаписьЖурналаРегистрации("РегламентноеЗадание.РассылкаПисемОНачисленныхБонусныхБаллах", УровеньЖурналаРегистрации.Примечание, , , "Не удалось отправить письмо на адресс: "+Почта);
		 КонецПопытки;
	 КонецЦикла;
	 
	 ЗаписьЖурналаРегистрации("РегламентноеЗадание.РассылкаПисемОНачисленныхБонусныхБаллах", УровеньЖурналаРегистрации.Примечание, , , "Окончание отправки писем");
 КонецПроцедуры
 
 Функция ЗапросКБаллам() 
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	БонусныеБаллыОстаткиИОбороты.Партнер КАК Партнер,
	 |	ЕСТЬNULL(ПартнерыКонтактнаяИнформация.АдресЭП, """") КАК Почта,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоНачальныйОстаток) КАК КоличествоНачальныйОстаток,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоПриход) КАК КоличествоПриход,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоРасход) КАК КоличествоРасход,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоКонечныйОстаток) КАК КоличествоКонечныйОстаток,
	 |	СУММА(ВЫБОР
	 |			КОГДА РезервБонусныхБаллов.Реализация = ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)
	 |				ТОГДА РезервБонусныхБаллов.СуммаБаллов
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ВРезервеКонечныйОстаток,
	 |	БонусныеБаллыОстаткиИОбороты.Партнер.Наименование КАК КлиентФИО
	 |ИЗ
	 |	РегистрНакопления.БонусныеБаллы.ОстаткиИОбороты(&Дата1, &Дата2, Период, , ) КАК БонусныеБаллыОстаткиИОбороты
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
	 |		ПО (БонусныеБаллыОстаткиИОбороты.Партнер = ПартнерыКонтактнаяИнформация.Ссылка)
	 |			И (&ТипПочта = ПартнерыКонтактнаяИнформация.Тип)
	 |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РезервБонусныхБаллов КАК РезервБонусныхБаллов
	 |		ПО (БонусныеБаллыОстаткиИОбороты.Партнер = РезервБонусныхБаллов.Партнер)
	 |ГДЕ
	 |	БонусныеБаллыОстаткиИОбороты.НачисленоОборот <> 0
	 |	И ЕСТЬNULL(ПартнерыКонтактнаяИнформация.АдресЭП, """") <> """"
	 |
	 |СГРУППИРОВАТЬ ПО
	 |	БонусныеБаллыОстаткиИОбороты.Партнер,
	 |	ЕСТЬNULL(ПартнерыКонтактнаяИнформация.АдресЭП, """"),
	 |	БонусныеБаллыОстаткиИОбороты.Партнер.Наименование";
	 
	 Запрос.УстановитьПараметр("ТипПочта", Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	 Вчера= НачалоДня(ТекущаяДата())-1;
	 Запрос.УстановитьПараметр("Дата1", НачалоДня(Вчера));
	 Запрос.УстановитьПараметр("Дата2", КонецДня(Вчера));
	 
	 РезультатЗапроса = Запрос.Выполнить();
	 ВыборкаДетальныеЗаписи= РезультатЗапроса.Выбрать();
	 
	 Возврат ВыборкаДетальныеЗаписи;
 КонецФункции
 
 Функция ПроверкаАдресаПочты(Почта)
	 Если ПустаяСтрока(Почта) Тогда
		 Возврат Ложь;
	 КонецЕсли;
	 
	 мСтрок= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Почта, "@", Истина);
	 Если мСтрок.Количество() <> 2 Тогда
		 Возврат Ложь;
	 КонецЕсли;
	 
	 мСтрок2= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(мСтрок[1], ".", Истина);
	 Если мСтрок.Количество() < 2 Тогда
		 Возврат Ложь;
	 КонецЕсли;
	 
	 Если мСтрок.Количество() > 3 Тогда
		 Возврат Ложь;
	 КонецЕсли;
	 
	 Возврат Истина;
 КонецФункции
 
 Процедура ЗаполнитьПисьмо(Письмо, ВыборкаДетальныеЗаписи, Почта, СкрытаяПочта)
	 УчетнаяЗапись= Справочники.УчетныеЗаписиЭлектроннойПочты.НайтиПоНаименованию("tg-alterra@yandex.ru", Истина);
	 
	 ТекстHTML= ПолучитьМакет("ТекстHTML").ПолучитьТекст();
	 
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*КлиентФИО*", ВыборкаДетальныеЗаписи.КлиентФИО);
	 
	 Если ВыборкаДетальныеЗаписи.КоличествоПриход > 0 Тогда
		 ТекстHTML= СтрЗаменить(ТекстHTML, "*ФразаНачисленоБаллов*", "На ваш счет начислено "+Строка(ВыборкаДетальныеЗаписи.КоличествоПриход) +" бонусов.");
	 Иначе
		 ТекстHTML= СтрЗаменить(ТекстHTML, "*ФразаНачисленоБаллов*", "");	
	 КонецЕсли;
	 Если ВыборкаДетальныеЗаписи.КоличествоРасход > 0 Тогда
		 ТекстHTML= СтрЗаменить(ТекстHTML, "*ФразаСписаниеБаллов*", "С вашего счета списано "+Строка(ВыборкаДетальныеЗаписи.КоличествоРасход) +" бонусов.");
	 Иначе
		 ТекстHTML= СтрЗаменить(ТекстHTML, "*ФразаСписаниеБаллов*", "");	
	 КонецЕсли;
	 Если ВыборкаДетальныеЗаписи.ВРезервеКонечныйОстаток > 0 Тогда
		 ТекстHTML= СтрЗаменить(ТекстHTML, "*ФразаВРезервеПоЗаказам*", "В резерве по заказам "+Строка(ВыборкаДетальныеЗаписи.ВРезервеКонечныйОстаток) +" бонусов.");
	 Иначе
		 ТекстHTML= СтрЗаменить(ТекстHTML, "*ФразаВРезервеПоЗаказам*", "");	
	 КонецЕсли;
	 
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*Баланс*", Строка(ВыборкаДетальныеЗаписи.КоличествоКонечныйОстаток - ВыборкаДетальныеЗаписи.ВРезервеКонечныйОстаток));
	 
	 //Создаем письмо
	 Письмо.Дата= ТекущаяДата();
	 Письмо.Автор= Пользователи.ТекущийПользователь();
	 Письмо.Автор= ТекущаяДата();
	 Письмо.Ответственный= Пользователи.ТекущийПользователь();
	 Письмо.Важность= Перечисления.ВариантыВажностиВзаимодействия.Низкая;
	 Письмо.Кодировка= "UTF-8"; 
	 Письмо.ОтправительПредставление= "www.tg-alterra.ru - Интернет-магазин";
	 Письмо.СписокПолучателейПисьма= Почта;
	 Письмо.СписокПолучателейСкрытыхКопий= СкрытаяПочта;
	 Письмо.СтатусПисьма= Перечисления.СтатусыИсходящегоЭлектронногоПисьма.Исходящее;
	 Письмо.Текст= "";
	 Письмо.ТекстHTML= ТекстHTML;
	 Письмо.Тема= "Информация по бонусному счету";
	 Письмо.ТипТекста= Перечисления.ТипыТекстовЭлектронныхПисем.HTML;
	 Письмо.УчетнаяЗапись= УчетнаяЗапись;
	 Письмо.Комментарий= "Отправлено автоматически";
	 
	 НоваяСтрока = Письмо.ПолучателиПисьма.Добавить();
	 НоваяСтрока.Представление = Почта;
	 НоваяСтрока.Адрес = Почта;
	 
	 Если не ПустаяСтрока(СкрытаяПочта) Тогда
		 НоваяСтрока = Письмо.ПолучателиСкрытыхКопий.Добавить();
		 НоваяСтрока.Представление = СкрытаяПочта;
		 НоваяСтрока.Адрес = СкрытаяПочта;
	 КонецЕсли;
 КонецПроцедуры
 
 // Отправка из партнера 
 Функция СоздатьПисьмоПартнеру(Партнер)  Экспорт
	 
	 ВыборкаДетальныеЗаписи= ЗапросКБалламПоПартнеру(Партнер);
	 
	 Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		 Почта= ВыборкаДетальныеЗаписи.Почта;
		 
		 Если Не ПроверкаАдресаПочты(Почта) Тогда
			 Сообщить("У партнера "+Партнер+" не корректно задана почта: "+Почта);
			 Возврат Неопределено;
		 КонецЕсли;
		 
		 Письмо=  Документы.ЭлектронноеПисьмоИсходящее.СоздатьДокумент();
		 
		 СкрытаяПочта= "";
		 
		 ЗаполнитьПисьмоИндивидуально(Письмо, ВыборкаДетальныеЗаписи, Почта, СкрытаяПочта);
		 
		 Письмо.Записать();
		 Возврат Письмо.Ссылка;
	 Иначе 
		 Возврат Неопределено;
	 КонецЕсли;
 КонецФункции
 
 Процедура ЗаполнитьПисьмоИндивидуально(Письмо, ВыборкаДетальныеЗаписи, Почта, СкрытаяПочта)
	 УчетнаяЗапись= Справочники.УчетныеЗаписиЭлектроннойПочты.НайтиПоНаименованию("tg-alterra@yandex.ru", Истина);
	 
	 ТекстHTML= ПолучитьМакет("ТекстHTMLИндивидуально").ПолучитьТекст();
	 
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*КлиентФИО*", ВыборкаДетальныеЗаписи.КлиентФИО);
	 
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*Начислено*", Строка(ВыборкаДетальныеЗаписи.КоличествоПриход));
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*Списано*", Строка(ВыборкаДетальныеЗаписи.КоличествоРасход));
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*Резерв*", Строка(ВыборкаДетальныеЗаписи.ВРезервеКонечныйОстаток));
	 ТекстHTML= СтрЗаменить(ТекстHTML, "*Остаток*", Строка(ВыборкаДетальныеЗаписи.КоличествоКонечныйОстаток));
	 
	 //Создаем письмо
	 Письмо.Дата= ТекущаяДата();
	 Письмо.Автор= Пользователи.ТекущийПользователь();
	 Письмо.Автор= ТекущаяДата();
	 Письмо.Ответственный= Пользователи.ТекущийПользователь();
	 Письмо.Важность= Перечисления.ВариантыВажностиВзаимодействия.Низкая;
	 Письмо.Кодировка= "UTF-8"; 
	 Письмо.ОтправительПредставление= "www.tg-alterra.ru - Интернет-магазин";
	 Письмо.СписокПолучателейПисьма= Почта;
	 Письмо.СписокПолучателейСкрытыхКопий= СкрытаяПочта;
	 Письмо.СтатусПисьма= Перечисления.СтатусыИсходящегоЭлектронногоПисьма.Исходящее;
	 Письмо.Текст= "";
	 Письмо.ТекстHTML= ТекстHTML;
	 Письмо.Тема= "Информация по бонусному счету";
	 Письмо.ТипТекста= Перечисления.ТипыТекстовЭлектронныхПисем.HTML;
	 Письмо.УчетнаяЗапись= УчетнаяЗапись;
	 Письмо.Комментарий= "Отправлено из партнера";
	 
	 НоваяСтрока = Письмо.ПолучателиПисьма.Добавить();
	 НоваяСтрока.Представление = Почта;
	 НоваяСтрока.Адрес = Почта;
	 
	 Если не ПустаяСтрока(СкрытаяПочта) Тогда
		 НоваяСтрока = Письмо.ПолучателиСкрытыхКопий.Добавить();
		 НоваяСтрока.Представление = СкрытаяПочта;
		 НоваяСтрока.Адрес = СкрытаяПочта;
	 КонецЕсли;
 КонецПроцедуры
 
 Функция ЗапросКБалламПоПартнеру(Партнер) 
	 
	 Запрос = Новый Запрос;
	 Запрос.Текст = 
	 "ВЫБРАТЬ
	 |	БонусныеБаллыОстаткиИОбороты.Партнер КАК Партнер,
	 |	ЕСТЬNULL(ПартнерыКонтактнаяИнформация.АдресЭП, """") КАК Почта,
	 |	БонусныеБаллыОстаткиИОбороты.Партнер.Наименование КАК КлиентФИО,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоПриход) КАК НачисленоПриход,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоРасход) КАК НачисленоРасход,
	 |	СУММА(ВЫБОР
	 |			КОГДА РезервБонусныхБаллов.Реализация = ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)
	 |				ТОГДА РезервБонусныхБаллов.СуммаБаллов
	 |			ИНАЧЕ 0
	 |		КОНЕЦ) КАК ВРезервеКонечныйОстаток,
	 |	СУММА(БонусныеБаллыОстаткиИОбороты.НачисленоКонечныйОстаток) КАК НачисленоКонечныйОстаток
	 |ИЗ
