
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Карта = Истина;
	РежимРаботы = 1;
	ЗаполнитьПериод();
	ИнициализироватьКартуНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериод()
	Период = ТекущаяДата();
	
	Для Час = 8 По 22 Цикл
		Время = Дата(1,1,1,Час,0,0);
		ФорматВремя = Формат(Время,"ДФ=ЧЧ:мм");
		Элементы.ВремяДоставкиС.СписокВыбора.Добавить(Время, ФорматВремя);
		Элементы.ВремяДоставкиПо.СписокВыбора.Добавить(Время, ФорматВремя);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьВидимостьДоступность();
	СброситьТС(); 
	ДостуностьТаблицыЗаказов(); 
	СброситьТС();
КонецПроцедуры

&НаКлиенте
Процедура ПулЗаказовПриАктивизацииСтроки(Элемент)
	ТекущаяСтрока= Элементы.ПулЗаказов.ТекущиеДанные;
	Если ТекущаяСтрока <> Неопределено Тогда 
		МассивОснования = ПолучитьМассивОснования(ТекущаяСтрока.ЗаказНаДоставку);
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ДокументыПродажи, "Основания", МассивОснования, Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ТоварОснований, "Основания", МассивОснования, Истина);
	Иначе
		РеализацияТоваровУслугПустаяСсылка = ПредопределенноеЗначение("Документ.РеализацияТоваровУслуг.ПустаяСсылка");
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ДокументыПродажи, "Основания", РеализацияТоваровУслугПустаяСсылка, Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ТоварОснований, "Основания", РеализацияТоваровУслугПустаяСсылка, Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДокументыПродажиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ОткрытьЗначение(Элемент.ТекущиеДанные.Ссылка);
КонецПроцедуры

&НаКлиенте 
Процедура ДостуностьТаблицыЗаказов()
	ТипТСВыбран = ПроверитьВыборТС(); 
	Элементы.ДокументыДоставкиОтметка.Доступность = ТипТСВыбран;
	Элементы.Декорация.Видимость = не ТипТСВыбран; 
КонецПроцедуры

&НаСервере
Функция ПроверитьВыборТС() 
	Если ТипТС = Справочники.ТипыТранспортныхСредств.ПустаяСсылка() Тогда 
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли; 
КонецФункции

&НаКлиенте
Процедура ПулЗаказовОтметкаПриИзменении(Элемент)
	Если не ПроверитьВыборТС() Тогда 
		Сообщить("Не выбран тип ТС!"); 
	КонецЕсли; 
	Попытка
		ДобавитьУдалитьЗаказВРейс();
	Исключение
		Сообщить("Ошибка сервиса геокодирования Яндекс");
	КонецПопытки;	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииДанныхДляДоставки()
	ОбновитьСписокДоставкиНаСервере();
	УстановитьВидимостьДоступность();
	ОбновитьТочкиНаКарте();	
КонецПроцедуры

&НаКлиенте
Процедура ФилиалПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры

&НаКлиенте
Процедура ВидДоставкиПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьОтборПоТарифамПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры

&НаКлиенте
Процедура ТипТСПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
	ДостуностьТаблицыЗаказов();
КонецПроцедуры

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры

&НаКлиенте
Процедура ВремяДоставкиСПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры

&НаКлиенте
Процедура ВремяДоставкиПоПриИзменении(Элемент)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры

&НаКлиенте
Процедура КартаПриИзменении(Элемент)
	УстановитьВидимостьДоступность();
КонецПроцедуры
#КонецОбласти

#Область КомандыИСобытия
&НаКлиенте
Процедура ОтборПоТарифам(Команда)
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("РежимВыбора",Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор",Истина);
	ПараметрыФормы.Вставить("ВыделитьСтрокиМассив", ПолучитьМассивТарифов());
	
	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбораТарифов", ЭтаФорма);

	ОткрытьФорму("Справочник.ТарифыПеревозчиков.Форма.ФормаВыбора",ПараметрыФормы,ЭтаФорма, , , , ОбработкаВыбора);
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивТарифов()
	Возврат Тарифы.Выгрузить().ВыгрузитьКолонку("Тариф");
КонецФункции

&НаКлиенте
Процедура ПриЗакрытииФормыВыбораТарифов(МассивТарифов, ДопПараметры) Экспорт
	Если МассивТарифов <> Неопределено Тогда
		Тарифы.Очистить();
		
		Для Каждого ЭлементМассива Из МассивТарифов Цикл
			НоваяСтрока = Тарифы.Добавить();
			НоваяСтрока.Тариф = ЭлементМассива;
		КонецЦикла;
		
		Если ИспользоватьОтборПоТарифам Тогда 
			ПриИзмененииДанныхДляДоставки();
		КонецЕсли;
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписокДоставки(Команда)
	ПриИзмененииДанныхДляДоставки();
КонецПроцедуры
&НаСервере
Процедура ОбновитьСписокДоставкиНаСервере()
	ЗаказыВРейс.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РегистрНакопленияЗаказыКДоставкеОстатки.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|	СУММА(РегистрНакопленияЗаказыКДоставкеОстатки.КоличествоОстаток) КАК КоличествоОстаток
		|ПОМЕСТИТЬ ВТ_ЗаказыКДоставке
		|ИЗ
		|	РегистрНакопления.ЗаказыКДоставке.Остатки КАК РегистрНакопленияЗаказыКДоставкеОстатки
		|ГДЕ
		|	РегистрНакопленияЗаказыКДоставкеОстатки.КоличествоОстаток > 0
		|
		|СГРУППИРОВАТЬ ПО
		|	РегистрНакопленияЗаказыКДоставкеОстатки.ЗаказНаДоставку
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапасыИПотребностиОстатки.Назначение КАК Назначение,
		|	ЗапасыИПотребностиОстатки.Назначение.Заказ КАК НазначениеЗаказ
		|ПОМЕСТИТЬ ВТ_ЗаказыПодНазначение
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(, Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)) КАК ЗапасыИПотребностиОстатки
		|ГДЕ
		|	ЗапасыИПотребностиОстатки.КОбеспечениюОстаток + ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток + ЗапасыИПотребностиОстатки.ОтложитьРезервированиеОстаток + ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток = ЗапасыИПотребностиОстатки.ПоступитОстаток
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗапасыИПотребностиОстатки.Назначение,
		|	ЗапасыИПотребностиОстатки.Назначение.Заказ
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Документ КАК ДокументПродажи,
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК ЗаказНаДоставку,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ЗаказНаДоставкуКлиентуОснования.Документ.Кассир.Ссылка, 0) = 0
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК ОтметкаКассы,
		|	НЕОПРЕДЕЛЕНО КАК ПодНазначение
		|ПОМЕСТИТЬ ВТ_ОтметкаКассы
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТ_ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку
		|			ИЗ
		|				ВТ_ЗаказыКДоставке КАК ВТ_ЗаказыКДоставке)
		|	И ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.РеализацияТоваровУслуг
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Документ,
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка,
		|	ВЫБОР
		|		КОГДА ЗаказНаДоставкуКлиентуОснования.Документ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
		|			ТОГДА 1
		|		ИНАЧЕ 0
		|	КОНЕЦ,
		|	НЕОПРЕДЕЛЕНО
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТ_ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку
		|			ИЗ
		|				ВТ_ЗаказыКДоставке КАК ВТ_ЗаказыКДоставке)
		|	И ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.ЧекККМ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Документ,
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(РеализацияТоваровУслуг.Кассир.Ссылка, 0) = 0
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ,
		|	ЕСТЬNULL(ВТ_ЗаказыПодНазначение.Назначение, НЕОПРЕДЕЛЕНО)
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ПО ЗаказНаДоставкуКлиентуОснования.Документ = РеализацияТоваровУслуг.ЗаказКлиента
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗаказыПодНазначение КАК ВТ_ЗаказыПодНазначение
		|		ПО ЗаказНаДоставкуКлиентуОснования.Документ = ВТ_ЗаказыПодНазначение.НазначениеЗаказ
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка В
		|			(ВЫБРАТЬ
		|				ВТ_ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку
		|			ИЗ
		|				ВТ_ЗаказыКДоставке КАК ВТ_ЗаказыКДоставке)
		|	И ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.ЗаказКлиента
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ОтметкаКассы.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|	МИНИМУМ(ВТ_ОтметкаКассы.ОтметкаКассы) КАК ОтметкаКассы,
		|	ВТ_ОтметкаКассы.ПодНазначение КАК ПодНазначение
		|ПОМЕСТИТЬ ВТ_ОтметкаКассыОбъединение
		|ИЗ
		|	ВТ_ОтметкаКассы КАК ВТ_ОтметкаКассы
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_ОтметкаКассы.ЗаказНаДоставку,
		|	ВТ_ОтметкаКассы.ПодНазначение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ИтогРеализацииИЧеки.КоличествоДокументовПродажи) КАК КоличествоДокументовПродажи,
		|	ИтогРеализацииИЧеки.ЗаказНаДоставку КАК ЗаказНаДоставку
		|ПОМЕСТИТЬ ВТ_РеализацииИЧеки
		|ИЗ
		|	(ВЫБРАТЬ
		|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ОтметкаКассы.ДокументПродажи) КАК КоличествоДокументовПродажи,
		|		ВТ_ОтметкаКассы.ЗаказНаДоставку КАК ЗаказНаДоставку
		|	ИЗ
		|		ВТ_ОтметкаКассы КАК ВТ_ОтметкаКассы
		|	ГДЕ
		|		ВТ_ОтметкаКассы.ДокументПродажи ССЫЛКА Документ.РеализацияТоваровУслуг
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ОтметкаКассы.ЗаказНаДоставку
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ОтметкаКассы.ДокументПродажи),
		|		ВТ_ОтметкаКассы.ЗаказНаДоставку
		|	ИЗ
		|		ВТ_ОтметкаКассы КАК ВТ_ОтметкаКассы
		|	ГДЕ
		|		ВТ_ОтметкаКассы.ДокументПродажи ССЫЛКА Документ.ЧекККМ
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ОтметкаКассы.ЗаказНаДоставку
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_ОтметкаКассы.ДокументПродажи),
		|		ВТ_ОтметкаКассы.ЗаказНаДоставку
		|	ИЗ
		|		(ВЫБРАТЬ
		|			ВТ_ОтметкаКассы_Заказ.ДокументПродажи КАК ДокументПродажи,
		|			ВТ_ОтметкаКассы_Заказ.ЗаказНаДоставку КАК ЗаказНаДоставку
		|		ИЗ
		|			ВТ_ОтметкаКассы КАК ВТ_ОтметкаКассы_Заказ
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК Реализация
		|				ПО ВТ_ОтметкаКассы_Заказ.ДокументПродажи = Реализация.Ссылка.ЗаказКлиента
		|		ГДЕ
		|			ВТ_ОтметкаКассы_Заказ.ДокументПродажи ССЫЛКА Документ.ЗаказКлиента) КАК ВТ_ОтметкаКассы
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТ_ОтметкаКассы.ЗаказНаДоставку) КАК ИтогРеализацииИЧеки
		|
		|СГРУППИРОВАТЬ ПО
		|	ИтогРеализацииИЧеки.ЗаказНаДоставку
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК Ссылка,
		|	ИСТИНА КАК ЕстьОснование
		|ПОМЕСТИТЬ ВТ_ЗаказыСОбращениемВОсновании
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|		ПО ЗаказНаДоставкуКлиентуОснования.Документ = ОбращениеКлиента.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаказНаДоставкуКлиенту.ТипТС КАК ТипТС, 
		|	ЗаказНаДоставкуКлиенту.ТипТС.Приоритет КАК ПриоритетТипаТС, 
		|	ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку КАК ПрибытиеНаОтгрузку,
		|	ЗаказНаДоставкуКлиенту.ВремяДоставкиС КАК ВремяДоставкиС,
		|	ЗаказНаДоставкуКлиенту.ВремяДоставкиПо КАК ВремяДоставкиПо,
		|	ЗаказНаДоставкуКлиенту.Вес КАК Вес,
		|	ЗаказНаДоставкуКлиенту.Объем КАК Объем,
		|	ЗаказНаДоставкуКлиенту.АдресДоставки КАК АдресДоставки,
		|	ЗаказНаДоставкуКлиенту.Широта КАК Широта,	
		|	ЗаказНаДоставкуКлиенту.Долгота КАК Долгота,		
		|	ЗаказНаДоставкуКлиенту.Ссылка КАК ЗаказНаДоставку,
		|	ЗаказНаДоставкуКлиенту.СуммаДокумента КАК Выручка,
		|	ЗаказНаДоставкуКлиенту.Партнер КАК Клиент,
		|	ЗаказНаДоставкуКлиенту.ТелефонКлиента КАК Телефон,
		|	ЗаказНаДоставкуКлиенту.ТелефонКлиентаНаВыгрузке КАК ТелефонНаВыгрузки,
		|	ЗаказНаДоставкуКлиенту.СтоимостьДоставки КАК ТранспортныеРасходы,
		|	ЗаказНаДоставкуКлиенту.Номер КАК Номер,
		|	ЗаказНаДоставкуКлиенту.Дата КАК Дата,
		|	ЗаказНаДоставкуКлиенту.Подразделение КАК Подразделение,
		|	ЗаказНаДоставкуКлиенту.ЭкспрессДоставка КАК ЭкспрессДоставка,
		|	ЗаказНаДоставкуКлиенту.ССайта КАК ССайта,
		|	ЗаказНаДоставкуКлиенту.Организация КАК Организация,
		|	ЗаказНаДоставкуКлиенту.ДоставкаСРазгрузкой КАК ДоставкаСРазгрузкой,
		|	ЗаказНаДоставкуКлиенту.СтоимостьДоставки КАК СтоимостьДоставки,
		|	ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС КАК СтоимостьДоставкиСНДС,
		|	ЗаказНаДоставкуКлиенту.ВидРазгрузки КАК ВидРазгрузки,
		|	ЗаказНаДоставкуКлиенту.МаксимальнаяДлина КАК МаксимальнаяДлина,
		|	ЗаказНаДоставкуКлиенту.ВидДоставки КАК ВидДоставки,
		|	ЗаказНаДоставкуКлиенту.НужнаИнкассация КАК НужнаИнкассация,
		|	ЗаказНаДоставкуКлиенту.НаправлениеДоставки КАК НаправлениеДоставки,
		|	ВЫБОР
		|		КОГДА ЗаказНаДоставкуКлиенту.Объем <> 0
		|			ТОГДА ЗаказНаДоставкуКлиенту.Вес / ЗаказНаДоставкуКлиенту.Объем
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ВесКОбъему,
		|	ЗаказНаДоставкуКлиенту.Инкассация КАК СуммаИнкассации,
		|	ЕСТЬNULL(ВТ_ОтметкаКассы.ОтметкаКассы, 0) КАК ОтметкаКассы,
		|	ВТ_ЗаказыКДоставке.ЗаказНаДоставку.Инкассация КАК Инкассация,
		|	ЕСТЬNULL(ВТ_РеализацииИЧеки.КоличествоДокументовПродажи, 0) КАК КоличествоДокументовПродажи,
		|	ВТ_ЗаказыКДоставке.ЗаказНаДоставку.ОплатаБанковскойКартой КАК ОплатаБанковскойКартой,
		|	ВТ_ОтметкаКассы.ПодНазначение КАК ПодНазначение,
		|	ЗаказНаДоставкуКлиенту.ЕстьЗаявкаЛесЕГАИС КАК ЕстьЗаявкаЛесЕГАИС,
		|	ЗаказНаДоставкуКлиенту.Тариф КАК Тариф,
		|	ЗаказНаДоставкуКлиенту.Тариф.ГрузоподъемностьВТоннах КАК ТарифГрузоподъемностьВТоннах,
		|	ЕСТЬNULL(ВТ_ЗаказыСОбращениемВОсновании.ЕстьОснование, ЛОЖЬ) КАК ОбменДовозПоОбращению
		|ИЗ
		|	ВТ_ЗаказыКДоставке КАК ВТ_ЗаказыКДоставке
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|		ПО ВТ_ЗаказыКДоставке.ЗаказНаДоставку = ЗаказНаДоставкуКлиенту.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОтметкаКассыОбъединение КАК ВТ_ОтметкаКассы
		|		ПО ВТ_ЗаказыКДоставке.ЗаказНаДоставку = ВТ_ОтметкаКассы.ЗаказНаДоставку
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РеализацииИЧеки КАК ВТ_РеализацииИЧеки
		|		ПО ВТ_ЗаказыКДоставке.ЗаказНаДоставку = ВТ_РеализацииИЧеки.ЗаказНаДоставку
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ЗаказыСОбращениемВОсновании КАК ВТ_ЗаказыСОбращениемВОсновании
		|		ПО (ВТ_ЗаказыКДоставке.ЗаказНаДоставку = ВТ_ЗаказыСОбращениемВОсновании.Ссылка)
		|ГДЕ
		|	ИСТИНА
		|	И ЗаказНаДоставкуКлиенту.Подразделение = &Подразделение
		|	И (ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку < &Период
		|			ИЛИ ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку = &Период
		|				И (ЗаказНаДоставкуКлиенту.ВремяДоставкиС >= &ДатаС
		|						И ЗаказНаДоставкуКлиенту.ВремяДоставкиПо <= &ДатаПо
		|					ИЛИ РАЗНОСТЬДАТ(&ДатаС, &ДатаПо, ЧАС) >= &ИнтервалПересеченияВЧасах
		|						И РАЗНОСТЬДАТ(ЗаказНаДоставкуКлиенту.ВремяДоставкиС, ЗаказНаДоставкуКлиенту.ВремяДоставкиПо, ЧАС) >= &ИнтервалПересеченияВЧасах
		|						И (РАЗНОСТЬДАТ(ЗаказНаДоставкуКлиенту.ВремяДоставкиС, &ДатаПо, ЧАС) >= &ИнтервалПересеченияВЧасах
		|								И ЗаказНаДоставкуКлиенту.ВремяДоставкиПо >= &ДатаПо
		|							ИЛИ РАЗНОСТЬДАТ(&ДатаС, ЗаказНаДоставкуКлиенту.ВремяДоставкиПо, ЧАС) >= &ИнтервалПересеченияВЧасах
		|								И &ДатаПо >= ЗаказНаДоставкуКлиенту.ВремяДоставкиПо)))
		|	И ЗаказНаДоставкуКлиенту.ВидДоставки В(&мВидДоставки)
		|	И ЗаказНаДоставкуКлиенту.Тариф В(&Тарифы)
		|	И &УсловиеПоТипуТС
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЭкспрессДоставка УБЫВ,
		|	ПрибытиеНаОтгрузку,
		|	ВремяДоставкиС";
	
	Если Не ЗначениеЗаполнено(Период) Тогда
		Период = ТекущаяДата();
	КонецЕсли;
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("ИнтервалПересеченияВЧасах", 2);
	
	Если ВремяДоставкиС > ВремяДоставкиПо И ЗначениеЗаполнено(ВремяДоставкиС) И ЗначениеЗаполнено(ВремяДоставкиПо) Тогда
		Запрос.УстановитьПараметр("ДатаС", Дата(1, 1, 1));
		Запрос.УстановитьПараметр("ДатаПо", Дата(1, 1, 1, 23, 59, 59));
		ОбщегоНазначения.СообщитьПользователю("Время доставки 'С' больше, чем время доставки 'По'! Будут выведены заказы за весь день");
	Иначе
		Запрос.УстановитьПараметр("ДатаС", ВремяДоставкиС);
		Если ЗначениеЗаполнено(ВремяДоставкиПо) Тогда
			Запрос.УстановитьПараметр("ДатаПо", ВремяДоставкиПо);
		Иначе
			Запрос.УстановитьПараметр("ДатаПо", Дата(1, 1, 1, 23, 59, 59));
		КонецЕсли;
	КонецЕсли;
	
	Если ИспользоватьОтборПоТарифам Тогда
		Запрос.УстановитьПараметр("Тарифы", Тарифы.Выгрузить().ВыгрузитьКолонку("Тариф"));
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ЗаказНаДоставкуКлиенту.Тариф В(&Тарифы)", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Филиал) Тогда
		Запрос.УстановитьПараметр("Подразделение", Филиал);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ЗаказНаДоставкуКлиенту.Подразделение = &Подразделение", "");
	КонецЕсли;
	                                                   
	Если ЗначениеЗаполнено(ВидДоставки) Тогда
		мВидДоставки = Новый Массив;
		мВидДоставки.Добавить(ВидДоставки);
		Если ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда
			мВидДоставки.Добавить(Перечисления.ВидыДоставокДоКлиента.Внутренняя);
		КонецЕсли;
		Запрос.УстановитьПараметр("мВидДоставки", мВидДоставки);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ЗаказНаДоставкуКлиенту.ВидДоставки В(&мВидДоставки)", "");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТипТС) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоТипуТС", "Вес <= &ВесMax И Объем <= &ОбъемMax И (ЗаказНаДоставкуКлиенту.ТипТС = Значение(Справочник.ТипыТранспортныхСредств.ПустаяСсылка) ИЛИ ЗаказНаДоставкуКлиенту.ТипТС.Приоритет <= &ПриоритетТС)");
		
		Запрос.УстановитьПараметр("ПриоритетТС", ТипТС.Приоритет); 	
		Запрос.УстановитьПараметр("ВесMax", ТипТС.ГрузоподъемностьВТоннах * 1000);
		Запрос.УстановитьПараметр("ОбъемMax", ТипТС.ВместимостьВКубическихМетрах);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоТипуТС", "Истина");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	ПулЗаказов.Загрузить(РезультатЗапроса.Выгрузить());
	
	Если ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда
		Выборка = Документы.ЗаказНаДоставкуКлиенту.ПолучитьКоличествоЗаказовНаДоставку(ТекущаяДата(), Филиал);
		сч = 1;
		Пока Выборка.Следующий() Цикл
			ИмяЭлемента = "Интервал" + сч;
			Если Элементы.Найти(ИмяЭлемента) = Неопределено Тогда
				Элементы.Добавить(ИмяЭлемента, Тип("ДекорацияФормы"), Элементы.ГруппаИнтервалы);
			КонецЕсли;
			Элементы[ИмяЭлемента].Заголовок = Выборка.Наименование + ": " + Выборка.КолЗаказов;
			сч = сч + 1;
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТипТС) Тогда
		мУдалитьСтроки = Новый Массив;
		
		мСкрытьЗаказы = УправлениеЛогистикойСервер.МассивНесовместимыхТиповТСДляРабочегоМестаМенеджераПоДоставке(
			ТипТС,
			ПулЗаказов.Выгрузить( , "ЗаказНаДоставку").ВыгрузитьКолонку(0));
			
		Если ЗначениеЗаполнено(мСкрытьЗаказы) Тогда
			Для Каждого Строка Из ПулЗаказов Цикл
				Если мСкрытьЗаказы.Найти(Строка.ЗаказНаДоставку) <> Неопределено Тогда                                              
					мУдалитьСтроки.Добавить(Строка);
				КонецЕсли;
			КонецЦикла;
			
			Для Каждого Строка Из мУдалитьСтроки Цикл
				ПулЗаказов.Удалить(Строка);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ФункцииОбработки

&НаКлиенте
Процедура ПулЗаказовВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка= Ложь;
	Док= Элементы.ПулЗаказов.ТекущиеДанные.ЗаказНаДоставку;
	Если Не Док.Пустая() Тогда 	
		ОткрытьФорму("Документ.ЗаказНаДоставкуКлиенту.ФормаОбъекта", Новый Структура("Ключ", Док));
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьМассивОснования(Ссылка)
	мОснований = Новый Массив;
	Для Каждого стрОснования Из Ссылка.Основания Цикл
		мОснований.Добавить(стрОснования.Документ);
	КонецЦикла;
	Возврат мОснований;
КонецФункции

&НаКлиенте
Процедура РасчитатьИтоги()
	Ном= 1;
	ВесИтог= 0;
	ОбъемИтог= 0;
	МаксимальнаяДлинна= 0;
	Расстояние= 0;
	ВремяВПути= 0;
	ВремяРазгрузки= 0;
	СтоимостьДоставки= 0;
	СтоимостьДоставкиСНДС= 0;
	Для Каждого стрДоставки Из ЗаказыВРейс Цикл
		стрДоставки.НомерСтроки= Ном;
		Ном= Ном+1;
		ВесИтог= ВесИтог+стрДоставки.Вес;
		ОбъемИтог= ОбъемИтог+стрДоставки.Объем;
		МаксимальнаяДлинна= Макс(МаксимальнаяДлинна, стрДоставки.МаксимальнаяДлина);
		Расстояние= Расстояние+стрДоставки.Расстояние;
		ВремяВПути= ВремяВПути+стрДоставки.ВремяВПути;
		ВремяРазгрузки= ВремяРазгрузки+стрДоставки.ВремяРазгрузки;
		СтоимостьДоставки= СтоимостьДоставки+стрДоставки.СтоимостьДоставки;
		СтоимостьДоставкиСНДС= СтоимостьДоставкиСНДС+стрДоставки.СтоимостьДоставкиСНДС;
	КонецЦикла;
	Элементы.ЗаказыВРейсыВес.ТекстПодвала= ВесИтог;
	Элементы.ЗаказыВРейсыОбъем.ТекстПодвала= ОбъемИтог;
	Элементы.ЗаказыВРейсыМаксимальнаяДлина.ТекстПодвала= МаксимальнаяДлинна;
	Элементы.ЗаказыВРейсыРасстояние.ТекстПодвала= Расстояние;
	Элементы.ЗаказыВРейсыВремяВПути.ТекстПодвала= ВремяВПути;
	Элементы.ЗаказыВРейсыВремяРазгрузки.ТекстПодвала= ВремяРазгрузки;
	Элементы.ЗаказыВРейсСтоимостьДоставки.ТекстПодвала= СтоимостьДоставки;
	Элементы.ЗаказыВРейсСтоимостьДоставкиСНДС.ТекстПодвала= СтоимостьДоставкиСНДС;
КонецПроцедуры

&НаСервере
Процедура СкрытьНесовместимыеЗаказы()  
	Если ЗначениеЗаполнено(ТипТС) Тогда
		мУдалитьСтроки = Новый Массив;
		
		// Несовместимость по критерям для типов ТС
		мСкрытьЗаказы = УправлениеЛогистикойСервер.СкрытьНесовместимыеЗаказы(
			ТипТС,
			ЗаказыВРейс.Выгрузить( , "ЗаказНаДоставку").ВыгрузитьКолонку(0),
			ПулЗаказов.Выгрузить( , "ЗаказНаДоставку").ВыгрузитьКолонку(0));			
		
		// Несовместимость по весу и по объему
		ВесMax = ТипТС.ГрузоподъемностьВТоннах * 1000 - ЗаказыВРейс.Итог("Вес");
		ОбъемMax = ТипТС.ВместимостьВКубическихМетрах - ЗаказыВРейс.Итог("Объем");
		
		Для Каждого Строка Из ПулЗаказов Цикл
			Если Строка.Вес > ВесMax ИЛИ Строка.Объем > ОбъемMax ИЛИ                // проверка по весу и объему 
				мСкрытьЗаказы.Найти(Строка.ЗаказНаДоставку) <> Неопределено ИЛИ    // проверка по критерям
				Строка.Отметка Тогда                                              // скрываем также отмеченные
				
				мУдалитьСтроки.Добавить(Строка);
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого Строка Из мУдалитьСтроки Цикл
			ПулЗаказов.Удалить(Строка);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьУдалитьЗаказВРейс()
	ТекущаяСтрока = Элементы.ПулЗаказов.ТекущиеДанные;	
	Если ТекущаяСтрока <> Неопределено Тогда
		Если ТекущаяСтрока.Отметка Тогда	
			НоваяСтрока = ЗаказыВРейс.Добавить();   
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекущаяСтрока);
			НоваяСтрока.НомерСтроки = ЗаказыВРейс.Количество();
		Иначе
			Строки = ЗаказыВРейс.НайтиСтроки(Новый Структура ("ЗаказНаДоставку", ТекущаяСтрока.ЗаказНаДоставку));
			Для Каждого Строка Из Строки Цикл
				ЗаказыВРейс.Удалить(ЗаказыВРейс.Индекс(Строка));
			КонецЦикла;	
		КонецЕсли;
		
		СкрытьНесовместимыеЗаказы();
		РасчитатьИтоги();
		ОбновитьТочкиНаКарте();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	Если ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная") Тогда
		Элементы.ДокументыДоставкиНаправлениеДоставки.Видимость= Ложь;
		Элементы.ГруппаИнтервалы.Видимость= Истина;
	Иначе 
		Элементы.ДокументыДоставкиНаправлениеДоставки.Видимость= Истина;
		Элементы.ГруппаИнтервалы.Видимость= Ложь;
	КонецЕсли;
	
	Если Карта Тогда 
		Элементы.ГруппаПраво.Видимость= Истина;
		Элементы.ЗаказыВРейсПостроитьМаршрутRoute.Видимость= Истина;
	Иначе
		Элементы.ГруппаПраво.Видимость= Ложь;
		Элементы.ЗаказыВРейсПостроитьМаршрутRoute.Видимость= Ложь;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОформитьДокументы

&НаКлиенте
Процедура СоздатьРейс(Команда)
	Если СуществуютДублиСкладов() Тогда
		Возврат;
	КонецЕсли;
	
	СоздатьРейсНаКлиенте();
	СброситьТС(); 
	ПриИзмененииДанныхДляДоставки();
	ДостуностьТаблицыЗаказов();
КонецПроцедуры 

