КонецФункции

&НаКлиенте
Процедура ДобавитьТочкуНаКарту(АдресДоставки, Широта = 0, Долгота = 0)
	КартаДокумент = Элементы.КартаЯндекс.Документ;
	Если КартаДокумент <> Неопределено Тогда
		Если Широта <>  0 Тогда 
			КартаДокумент.defaultView.addMarkerOnCoords(Широта, Долгота, АдресДоставки);
		Иначе
			КартаДокумент.defaultView.addMarkerOnAdress(АдресДоставки);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьРеализацию(Команда)
	ТекущаяСтрока=Элементы.ПулЗаказов.ТекущиеДанные;
	если ТекущаяСтрока<>Неопределено тогда
		если значениезаполнено(ТекущаяСтрока.ПодНазначение) тогда	
			СоздатьРеализациюСервер(ТекущаяСтрока.ПодНазначение);	
		иначе
			Сообщить("Документ основания не является обособленным. Создание реализации не требуется.");
		конецесли;
	конецесли;	
КонецПроцедуры

Процедура СоздатьРеализациюСервер(Назначение)
	УстановитьПривилегированныйРежим(истина);
	
	НачатьТранзакцию();
	
		ЗаказКлиента= Назначение.Заказ;
		
		Если Не ЗначениеЗаполнено(ЗаказКлиента.Кассир) Тогда
			Сообщить("На документ "+ЗаказКлиента+"не установлена отметка кассы.");
			возврат;
		КонецЕсли;
		
		ЗаказОбъект= ЗаказКлиента.ПолучитьОбъект();
		Для Каждого стрТовар Из ЗаказОбъект.Товары Цикл
			Если стрТовар.Отменено Тогда
				Продолжить;
			КонецЕсли;
			
			Если стрТовар.ВариантОбеспечения= Перечисления.ВариантыОбеспечения.УдалитьОтгрузитьОбособленно ИЛИ стрТовар.ВариантОбеспечения= Перечисления.ВариантыОбеспечения.НеТребуется Тогда
				Продолжить;
			КонецЕсли;
			
			Если стрТовар.ВариантОбеспечения= Перечисления.ВариантыОбеспечения.КОбеспечению Тогда
				стрТовар.ВариантОбеспечения= Перечисления.ВариантыОбеспечения.УдалитьОтгрузитьОбособленно;
			Иначе
				стрТовар.ВариантОбеспечения= Перечисления.ВариантыОбеспечения.Отгрузить;
			КонецЕсли;
		КонецЦикла;
		Отказ=ложь;
		Попытка
			ЗаказОбъект.ДополнительныеСвойства.Вставить("Регламент", Истина);
			
			ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
			АльтерраОбщегоНазначения.СообщитьПользователю(ЗаказОбъект.Ссылка, "Отгружен: "+ЗаказОбъект.Ссылка);
		Исключение
			Отказ= Истина;
			Текст= "Не удалось записать: "+ЗаказОбъект.Ссылка;
			АльтерраОбщегоНазначения.СообщитьПользователю(ЗаказОбъект.Ссылка, Текст);
		КонецПопытки;
		
		Если Не Отказ Тогда
			Док= Документы.РеализацияТоваровУслуг.СоздатьДокумент();
			
			ДанныеЗаполнения= Новый Структура;
			ДанныеЗаполнения.Вставить("ВариантОформленияПродажи", Перечисления.ВариантыОформленияПродажи);
			ДанныеЗаполнения.Вставить("ДокументОснование", ЗаказКлиента);
			ДанныеЗаполнения.Вставить("СкладОтгрузки", Неопределено);
			Док.Заполнить(ДанныеЗаполнения);
			
			Док.Склад= ЗаказКлиента.Склад;
			Док.Комментарий= "Создан автоматически по заказу с отметкой кассы";
			Док.Дата= ТекущаяДата();
			Док.Менеджер= ЗаказКлиента.Менеджер;
			Док.Магазин= ЗаказКлиента.Магазин;
			Если Док.Товары.Количество() > 0 Тогда 
				Попытка
					Док.СкидкиРассчитаны=истина;
					Док.Записать(РежимЗаписиДокумента.Проведение);
					АльтерраОбщегоНазначения.СообщитьПользователю(Док.Ссылка, "Создан: "+Док.Ссылка);
				Исключение
					Отказ= Истина;
					Текст= "Не удалось записать: "+Док.Ссылка;
					АльтерраОбщегоНазначения.СообщитьПользователю(Док.Ссылка, Текст);
				КонецПопытки;
				
				Если Не Отказ Тогда
					НужнаЗаявка= Документы.ЗаявкаВЕГАИСЛес.ПроверкаНаличияЗаявкиНаСоответствующийДокументПродажи(Док.Ссылка);
					
					Если НужнаЗаявка Тогда
						ДокЗаявка= Документы.ЗаявкаВЕГАИСЛес.СоздатьДокумент();
						ДокЗаявка.Дата= ТекущаяДата();
						ДокЗаявка.Заполнить(Док.Ссылка);
						Попытка
							ДокЗаявка.Записать(РежимЗаписиДокумента.Проведение);
							АльтерраОбщегоНазначения.СообщитьПользователю(ДокЗаявка.Ссылка, "Создан: "+ДокЗаявка.Ссылка);
						Исключение
							Отказ= Истина;
							Текст= "Не удалось записать: "+ДокЗаявка.Ссылка;
							АльтерраОбщегоНазначения.СообщитьПользователю(ДокЗаявка.Ссылка, Текст);
						КонецПопытки;
					КонецЕсли;
					
					Если Док.ИспользуетсяДоговор Тогда
						ДокЛистСогласования = Документы.ЛистСогласования.СоздатьДокумент();
						ДокЛистСогласования.Дата = ТекущаяДата();
						ДокЛистСогласования.Заполнить(Док.Ссылка);
						ДокЛистСогласования.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления;
						ДокЛистСогласования.Проблема = Справочники.Проблемы.НайтиПоКоду("000000016");//Реализация (отсутствие оригинала/некорректное оформление -ПАКЕТ ДОКУМЕНТОВ)
						
						Если Док.Партнер<>Справочники.Партнеры.ПустаяСсылка() и Док.Партнер.ОсновнойМенеджер<>Справочники.Пользователи.ПустаяСсылка() и СтрНайти(Док.Партнер.ОсновнойМенеджер.Наименование, "Сектор выписки")=0 Тогда
							ДокЛистСогласования.ОсновнойМенеджер = Док.Партнер.ОсновнойМенеджер;
						Иначе
							ДокЛистСогласования.ОсновнойМенеджер = Док.ЗаказКлиента.Менеджер;
						КонецЕсли;
						ДокЛистСогласования.Согласовано = Справочники.ПользователиДляСогласованияЛистов.НайтиПоКоду("000000035");//Тупицына Оксана Геннадьевна
						ДокЛистСогласования.Согласован = Истина;
						ДокЛистСогласования.Комментарий = "Создан автоматически по заказу с отметкой кассы";
						Попытка
							ДокЛистСогласования.Записать(РежимЗаписиДокумента.Проведение);
							АльтерраОбщегоНазначения.СообщитьПользователю(ДокЛистСогласования.Ссылка, "Создан: "+ДокЛистСогласования.Ссылка);
						Исключение
							Отказ = Истина;
							Текст = "Не удалось записать: " + ДокЛистСогласования.Ссылка;
							АльтерраОбщегоНазначения.СообщитьПользователю(ДокЛистСогласования.Ссылка, Текст);
						КонецПопытки;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	
	Если Отказ Тогда 
		ОтменитьТранзакцию();
		Текст= "Не удалось установить вариант обеспечение отгрузить: "+ЗаказКлиента;
		АльтерраОбщегоНазначения.СообщитьПользователю(ЗаказКлиента, Текст);
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти
#КонецОбласти