
&НаКлиенте
Процедура Обр__ПронумероватьДокументыПосле(Команда)
	ОчиститьСообщения();

	Массив = Новый Массив;
	Массив.Добавить(Тип("Число"));
	
	ПоказатьВводЗначения(
		Новый ОписаниеОповещения("ВводНомераДокументаЗавершение", ЭтотОбъект), 
		"", 
		НСтр("ru = 'Введите номер последнего документа'"),
		Новый ОписаниеТипов(Массив, , , Новый КвалификаторыЧисла(12,0)));
КонецПроцедуры 

&НаКлиенте
Процедура ВводНомераДокументаЗавершение(НомерДокумента,ОповещениеУспешногоВвода) Экспорт
	ВводНомераДокументаЗавершениеВводНомераСервер(НомерДокумента,ОповещениеУспешногоВвода);
КонецПроцедуры

&НаСервере
Процедура ВводНомераДокументаЗавершениеВводНомераСервер(НомерДокумента,ОповещениеУспешногоВвода)
	если НомерДокумента<>неопределено тогда
		для каждого стр из Объект.ДокументыКВыгрузке цикл
			если стр.Выгружать тогда
				если типзнч(стр.ссылка)=тип("Документссылка.СписаниеБезналичныхДенежныхСредств") тогда
					попытка
						Номердокумента=НомерДокумента+1;
						Док=стр.ссылка.ПолучитьОбъект();
						стр.НомерВходящегоДокумента=стрзаменить(строка(Номердокумента),символы.НПП,"");
						Док.НомерВходящегоДокумента=стрзаменить(строка(Номердокумента),символы.НПП,"");
						ОбновлениеИнформационнойБазы.ЗаписатьДанные(Док);
					исключение
						Сообщить("Не удалось записать номер документу: "+стр.ссылка);
					конецпопытки;
				конецесли;	
			конецесли;	
		конеццикла;	
	конецесли;
КонецПроцедуры
