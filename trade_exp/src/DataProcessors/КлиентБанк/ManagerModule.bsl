			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 7 Барнаул Альтерра");
		ИначеЕсли Найти(СтрНазначение, "2200+1023") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 1 Выбор Альтерра");
		ИначеЕсли Найти(СтрНазначение, "2200+3635") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 1 Майма Альтерра");
