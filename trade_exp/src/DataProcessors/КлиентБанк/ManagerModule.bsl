Функция МожноПолучитьКомиссиюИзНазаченияПлатежа(СтрокаНазначениеПлатежа) Экспорт
	ЕстьКомиссия = СтрНайти(СтрокаНазначениеПлатежа,"КОМИССИЯ");
	Если ЕстьКомиссия = 0 Тогда	
		Возврат 0;
	Иначе	
		ИщемСуммуВСтроке = Прав(СтрокаНазначениеПлатежа, СтрДлина(СтрокаНазначениеПлатежа)-ЕстьКомиссия+1);
		ПозицияПробела = СтрНайти(ИщемСуммуВСтроке," ");
		ПозицияТочки = СтрНайти(ИщемСуммуВСтроке,".");
		Если ПозицияТочки = 0 Тогда
			Возврат 0;
		Иначе	
			ИщемСуммуВСтроке = СокрЛП(Сред(ИщемСуммуВСтроке, ПозицияПробела, ПозицияТочки-ПозицияПробела+3));
			ИщемСуммуВСтроке = СтрЗаменить(ИщемСуммуВСтроке, ",", "");
			ИщемСуммуВСтроке = СтрЗаменить(ИщемСуммуВСтроке, " ", "");
			Попытка
				ИтоговаяСумма = Число(ИщемСуммуВСтроке)
			Исключение
				Возврат 0
			КонецПопытки;		
			Если ИтоговаяСумма = 0 Тогда 
				Возврат 0
			Иначе
				Возврат ИтоговаяСумма
			КонецЕсли;	  
		КонецЕсли;	
	КонецЕсли;
КонецФункции

&После ("ЗаполнитьЗначениеЭкспорта")
Процедура ОБР_ЗаполнитьЗначениеЭкспорта(СтрокаЭкспорта, ВыборкаДляЭкспорта)
	Если ПустаяСтрока(ВыборкаДляЭкспорта.НомерВходящегоДокумента) Тогда
		СтрокаЭкспорта.Номер = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ВыборкаДляЭкспорта.Номер, Истина, Истина);
	Иначе
		СтрокаЭкспорта.Номер = ВыборкаДляЭкспорта.НомерВходящегоДокумента;	
	КонецЕсли;
КонецПроцедуры

