			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 3 Майма Альтерра");
		ИначеЕсли Найти(СтрНазначение, "2200+2673") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 4 Альтерра ЦБ");
		ИначеЕсли Найти(СтрНазначение, "2200+5306") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 4 Бийск Альтерра");
		ИначеЕсли Найти(СтрНазначение, "2200+7460") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 5 Выбор Альтерра");
		ИначеЕсли Найти(СтрНазначение, "2200+4062") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 6 Барнаул Альтерра");
		ИначеЕсли Найти(СтрНазначение, "2200+9175") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса №1 Барнаул Альтерра");
		ИначеЕсли Найти(СтрНазначение, "7023580358") > 0 Тогда
			СтрокаДокумента.КассаОтправитель = Справочники.Кассы.НайтиПоНаименованию("Касса № 1 Бийск Альтерра");
