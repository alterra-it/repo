	ПоступлениеТоваровУслуг.СуммаДокумента КАК СуммаДокумента,
	ПоступлениеТоваровУслуг.Менеджер КАК Менеджер,
	ПоступлениеТоваровУслуг.Ссылка КАК Ссылка,
	ПоступлениеТоваровУслуг.Организация КАК Организация
ИЗ
	Документ.ПриобретениеТоваровУслуг КАК ПоступлениеТоваровУслуг
ГДЕ
	ПоступлениеТоваровУслуг.Ссылка В(&amp;Основания)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПеремещениеТоваров.Номер,
	ПеремещениеТоваров.Дата,
	NULL,
	ПеремещениеТоваров.СкладПолучатель,
	NULL,
	ПеремещениеТоваров.Ответственный,
	ПеремещениеТоваров.Ссылка,
	ПеремещениеТоваров.Организация
ИЗ
	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
ГДЕ
	ПеремещениеТоваров.Ссылка В(&amp;Основания)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗаказНаПеремещение.Номер,
	ЗаказНаПеремещение.Дата,
	NULL,
