    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ПоступлениеТоваровУслуг.Номер КАК Номер,
	ПоступлениеТоваровУслуг.Дата КАК Дата,
	ПоступлениеТоваровУслуг.Партнер КАК Партнер,
