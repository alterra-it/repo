
&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ЗаполнитьРеквизиты();
	ОбновитьВидимость();
КонецПроцедуры

&НаСервере
Процедура ОбновитьВидимость()
	Элементы.ГруппаФайлыПарнера.Видимость = ((ТипЗнч(ЭтотОбъект.Объект.ВладелецФайла) = Тип("СправочникСсылка.Партнеры")) Или (ТипЗнч(ЭтотОбъект.Объект.ВладелецФайла) = Тип("СправочникСсылка.ДоговорыКонтрагентов")));
	Элементы.ГрПарнеры.Видимость = (ТипЗнч(ЭтотОбъект.Объект.ВладелецФайла) = Тип("СправочникСсылка.Партнеры"));
	Элементы.ГрДоговоры.Видимость = (ТипЗнч(ЭтотОбъект.Объект.ВладелецФайла) = Тип("СправочникСсылка.ДоговорыКонтрагентов"));
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизиты()
	Если ТипЗнч(ЭтотОбъект.Объект.ВладелецФайла) = Тип("СправочникСсылка.Партнеры") Тогда
		ВидФайла = ЭтотОбъект.Объект.ВидФайла;
		Контрагент = ЭтотОбъект.Объект.Контрагент;
		
		Если Контрагент.Пустая() Тогда 
			Запрос = Новый Запрос;
			Запрос.Текст =
			"ВЫБРАТЬ
			|	Контрагенты.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.Контрагенты КАК Контрагенты
			|ГДЕ
			|	Контрагенты.Партнер = &ВыбПартнер
			|	И Контрагенты.ПометкаУдаления = ЛОЖЬ"
			;
			Запрос.УстановитьПараметр("ВыбПартнер",ЭтотОбъект.Объект.ВладелецФайла);
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Количество() = 1 Тогда
				Выборка.Следующий();
				Контрагент = Выборка.Ссылка;
			КонецЕсли;	
		КонецЕсли;	
	ИначеЕсли ТипЗнч(ЭтотОбъект.Объект.ВладелецФайла) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
		ВидФайла = ЭтотОбъект.Объект.ВидФайла;
		Если ВидФайла.Пустая() Тогда ВидФайла = Справочники.ВидыФайловПартнера.Договор КонецЕсли;
		ДнейОтсрочки = ЭтотОбъект.Объект.ДнейОтсрочки;
		ЛимитСезон = ЭтотОбъект.Объект.ЛимитСезон;
		ЛимитНеСезон = ЭтотОбъект.Объект.ЛимитНеСезон;
	КонецЕсли;	
КонецПроцедуры

