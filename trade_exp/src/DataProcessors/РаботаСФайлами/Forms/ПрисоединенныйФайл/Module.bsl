//Изменения - запись добавленных рекизитов файла
&Вместо("ЗаписатьФайл") 
Функция ЗаписатьФайлДоп(Знач ПараметрОбъект = Неопределено)
	
	Если ПараметрОбъект = Неопределено Тогда
		ЗаписываемыйОбъект = РеквизитФормыВЗначение("Объект");
	Иначе
		ЗаписываемыйОбъект = ПараметрОбъект;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеКопирования) Тогда
		НачатьТранзакцию();
		Попытка
			ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(ЗначениеКопирования);
			ТипХраненияФайла = РаботаСФайламиСлужебный.ТипХраненияФайла(ЗначениеКопирования.Размер, ЗначениеКопирования.Расширение);
			Если ТипХраненияФайла = Перечисления.ТипыХраненияФайлов.ВИнформационнойБазе Тогда
				СсылкаНового = Справочники[ИмяСправочника].ПолучитьСсылку();
				ЗаписываемыйОбъект.УстановитьСсылкуНового(СсылкаНового);
				РаботаСФайламиСлужебный.ЗаписатьФайлВИнформационнуюБазу(СсылкаНового, ДвоичныеДанные);
				ЗаписываемыйОбъект.ТипХраненияФайла = ТипХраненияФайла;
			Иначе
				// +Альтерра
				СведенияОФайле = РаботаСФайламиСлужебный.ДобавитьФайлВТом(ДвоичныеДанные, ЗаписываемыйОбъект.ДатаМодификацииУниверсальная,
				ЗаписываемыйОбъект.Наименование, ЗаписываемыйОбъект.Расширение); 
				ЗаписываемыйОбъект.Том              = СведенияОФайле.Том;
				ЗаписываемыйОбъект.ПутьКФайлу       = СведенияОФайле.ПутьКФайлу;
				ЗаписываемыйОбъект.ТипХраненияФайла = Перечисления.ТипыХраненияФайлов.ВТомахНаДиске;
				// -
				
				// -Альтерра
				//	ЗаписываемыйОбъект.Том = Неопределено;
				// 	ЗаписываемыйОбъект.ПутьКФайлу = Неопределено;
				//	ЗаписываемыйОбъект.ТипХраненияФайла = Неопределено;
				//   РаботаСФайламиВТомахСлужебный.ДобавитьФайл(ЗаписываемыйОбъект, ДвоичныеДанные);
				// -
			КонецЕсли;
			
			Если ДоступнаЭлектроннаяПодпись Тогда
				РаботаСФайламиСлужебный.ПеренестиРезультатыПроверкиПодписей(ЭлектронныеПодписи, ЗначениеКопирования);
			КонецЕсли;
			
			ЗаписываемыйОбъект.Записать();
			
			Если ДоступнаЭлектроннаяПодпись И ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.ЭлектроннаяПодпись") Тогда
				МодульЭлектроннаяПодпись = ОбщегоНазначения.ОбщийМодуль("ЭлектроннаяПодпись");
				
				СертификатыИсточника = МодульЭлектроннаяПодпись.СертификатыШифрования(ЗначениеКопирования);
				МодульЭлектроннаяПодпись.ЗаписатьСертификатыШифрования(ЗаписываемыйОбъект, СертификатыИсточника);
				
				УстановленныеПодписи = МодульЭлектроннаяПодпись.УстановленныеПодписи(ЗначениеКопирования);
				МодульЭлектроннаяПодпись.ДобавитьПодпись(ЗаписываемыйОбъект, УстановленныеПодписи);
			КонецЕсли;
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;
	Иначе
		НачатьТранзакцию();
		Попытка
			Если ДоступнаЭлектроннаяПодпись Тогда
				РаботаСФайламиСлужебный.ПеренестиРезультатыПроверкиПодписей(ЭлектронныеПодписи, ЗаписываемыйОбъект.Ссылка);
			КонецЕсли;
			
			// +Альтерра dr ExZ запись добавленных реквизитов
			Если ТипЗнч(ЗаписываемыйОбъект.ВладелецФайла) = Тип("СправочникСсылка.Партнеры") Тогда
				ЗаписываемыйОбъект.ВидФайла = ВидФайла; 
				ЗаписываемыйОбъект.Контрагент = Контрагент; 
			ИначеЕсли ТипЗнч(ЗаписываемыйОбъект.ВладелецФайла) = Тип("СправочникСсылка.ДоговорыКонтрагентов") Тогда
				ЗаписываемыйОбъект.ВидФайла = ВидФайла; 
				ЗаписываемыйОбъект.ДнейОтсрочки = ДнейОтсрочки;
				ЗаписываемыйОбъект.ЛимитСезон = ЛимитСезон;
				ЗаписываемыйОбъект.ЛимитНеСезон = ЛимитНеСезон;
			КонецЕсли;	
			// -
			
			ЗаписываемыйОбъект.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;
	КонецЕсли;
	
	Если ПараметрОбъект = Неопределено Тогда
		ЗначениеВРеквизитФормы(ЗаписываемыйОбъект, "Объект");
	КонецЕсли;
	
	ЗначениеКопирования = Справочники[ИмяСправочника].ПустаяСсылка();
	УстановитьДоступностьКнопок(ЭтотОбъект, Элементы);
	ОбновитьЗаголовок();
	
	Возврат Истина;
	
КонецФункции

//Отбор по партнеру
&НаКлиенте
Процедура Док_КонтрагентНачалоВыбораВместо(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОтбора = Новый Структура();
	ПараметрыОтбора.Вставить("Партнер",ПолучитьПартнера());
	
	ПараметрыФормы = Новый Структура("Отбор",ПараметрыОтбора);
	
	ОбработкаВыбораКонтрагента = Новый ОписаниеОповещения("ВыборЭлементаСправочникаКонтрагентыКонец",ЭтаФорма);
	
	ОткрытьФорму("Справочник.Контрагенты.ФормаВыбора",ПараметрыФормы,ЭтаФорма,,,,ОбработкаВыбораКонтрагента);
КонецПроцедуры

&НаСервере
Функция ПолучитьПартнера()
	Возврат ЭтаФорма.Объект.ВладелецФайла;
КонецФункции	

&НаКлиенте
Процедура ВыборЭлементаСправочникаКонтрагентыКонец(Значение,ДопПараметры) Экспорт
	Если Не Значение = Неопределено Тогда
		Контрагент = Значение;
	КонецЕсли;	
КонецПроцедуры	


&НаКлиенте
&Вместо("ОбработатьКомандуЗаписиФайла")
Функция Док_ОбработатьКомандуЗаписиФайла()        
	
	// +Альтерра
	Если ЭтотОбъект.ИмяСправочника = "ПартнерыПрисоединенныеФайлы" ИЛИ ЭтотОбъект.ИмяСправочника = "ДоговораКонтрагентовПрисоединенныеФайлы" Тогда
		Если Не ЗначениеЗаполнено(ЭтотОбъект.ВидФайла) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для продолжения укажите вид файла.'"), , "ВидФайла");
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	Если ЭтотОбъект.ИмяСправочника = "ПартнерыПрисоединенныеФайлы" Тогда
		Если Не ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для продолжения укажите контрагента.'"), , "Контрагент");
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;    
	// -
	
	Результат = ПродолжитьВызов();
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура Док_ПередЗакрытиемПеред(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Если ЗавершениеРаботы Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка= Ложь;
	
	Если ЭтотОбъект.ИмяСправочника = "ПартнерыПрисоединенныеФайлы" ИЛИ ЭтотОбъект.ИмяСправочника = "ДоговораКонтрагентовПрисоединенныеФайлы" Тогда
		Если Не ЗначениеЗаполнено(ЭтотОбъект.ВидФайла) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для продолжения укажите вид файла.'"), , "ВидФайла");
			Отказ= Истина;
		КонецЕсли;
	КонецЕсли;

	Если ЭтотОбъект.ИмяСправочника = "ПартнерыПрисоединенныеФайлы" Тогда
		Если Не ЗначениеЗаполнено(ЭтотОбъект.Контрагент) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для продолжения укажите контрагента.'"), , "Контрагент");
			Отказ= Истина;
		КонецЕсли;
	КонецЕсли;

	Если Модифицированность Тогда
		Оповещение= Новый ОписаниеОповещения("ЗаписатьЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, "Элемент изменен. Записать?", РежимДиалогаВопрос.ДаНет, 10, , "Записать");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьЗавершение(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработатьКомандуЗаписиФайла();
	КонецЕсли;
КонецПроцедуры
