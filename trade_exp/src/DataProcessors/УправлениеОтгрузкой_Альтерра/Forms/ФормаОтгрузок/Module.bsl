	Запрос.УстановитьПараметр("РабочиеУчастки", Секция);
	Запрос.УстановитьПараметр("МассивНоменклатура", Накладная.Товары.ВыгрузитьКолонку("Номенклатура"));
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Таблица.Свернуть("Распоряжение");	
	Если ТипЗнч(Таблица[0].Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") 
		ИЛИ (ТипЗнч(Таблица[0].Распоряжение) = Тип("ДокументСсылка.ЗаказНаПеремещение") И Таблица.Количество() = 1) Тогда
			ТоварыПоНакладной = Накладная.Товары.Выгрузить();
			ТоварыПоНакладной.Свернуть("Номенклатура", "Количество");
			Для Каждого Строка Из Результат Цикл
				Для Каждого СтрокаН Из ТоварыПоНакладной Цикл 
					Если Строка.Номенклатура = СтрокаН.Номенклатура И Строка.Количество > СтрокаН.Количество Тогда
						Строка.Количество = СтрокаН.Количество;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
	ИначеЕсли ТипЗнч(Таблица[0].Распоряжение) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
		Результат.Колонки.Добавить("Использовать");		
		ТоварыПоНакладной = Накладная.Товары.Выгрузить();
		ТоварыПоНакладной.Свернуть("Номенклатура, ЗаказНаПеремещение", "Количество");
		Для Каждого Строка Из Результат Цикл
			Для Каждого СтрокаН Из ТоварыПоНакладной Цикл 
				Если Строка.Номенклатура = СтрокаН.Номенклатура И Строка.Распоряжение = СтрокаН.ЗаказНаПеремещение Тогда 
					Если Строка.Количество > СтрокаН.Количество Тогда
						Строка.Количество = СтрокаН.Количество;
					КонецЕсли;
					Строка.Использовать = Истина;				
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		// Удаляем не нужные строки
		Индекс = 0;
		Пока Индекс < Результат.Количество() Цикл
			Если Результат[Индекс].Использовать = Неопределено Тогда
				Результат.Удалить(Индекс);
			Иначе 
				Индекс = Индекс + 1;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ТЗОрдераПоТекущемуРаспоряжениюВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ПоказатьЗначение(Неопределено, Элемент.ТекущиеДанные.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ПометитьОрдерНаУдаление(Команда)
	ТекущаяСтрока = Элементы.ТЗОрдераПоТекущемуРаспоряжению.ТекущиеДанные;
		
	Если ТекущаяСтрока<>Неопределено Тогда
		СсылкаНаДокумент = ТекущаяСтрока.Ссылка;
		ПометитьОрдерНаУдалениеСервер(СсылкаНаДокумент); 
		ЗаполнитьОрдераПоТекущемуРаспоряжению(ТекущаяНакладная);
	КонецЕсли;  
КонецПроцедуры  

&НаСервере
Процедура ПометитьОрдерНаУдалениеСервер(СсылкаНаДокумент)
	ОрдерОбъект = СсылкаНаДокумент.ПолучитьОбъект();  
	ОрдерОбъект.УстановитьПометкуУдаления(Истина);
	ОрдерОбъект.Записать();
КонецПроцедуры  
#КонецОбласти
	
