КонецФункции

&НаСервере
Функция ПолучитьРабочиеУчасткиПользователя()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СекцииКладовщиков.Ячейка КАК Ячейка
		|ИЗ
		|	РегистрСведений.СекцииКладовщиков КАК СекцииКладовщиков
		|ГДЕ
		|	СекцииКладовщиков.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	РезультатЗапросаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивЗначений = Новый Массив();
	
	Пока РезультатЗапросаДетальныеЗаписи.Следующий() Цикл
		МассивЗначений.Добавить(РезультатЗапросаДетальныеЗаписи.Ячейка);
	КонецЦикла;
	
	Возврат МассивЗначений;
КонецФункции

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле = Элементы.ТоварыЯчейка Тогда 
		
		ТекЯч = Элемент.ТекущиеДанные.Ячейка;
		 	
		РабочийУчасток = ПолучимРабУч(ТекЯч);
		ПараметрыОтбора =  Новый Структура;
		ЗначениеОтбора =  Новый Структура;
		ЗначениеОтбора.Вставить("Владелец", Склад);
		Если ЗначениеЗаполнено(РабочийУчасток) Тогда
			ЗначениеОтбора.Вставить("РабочийУчасток", РабочийУчасток);
		КонецЕсли;
		ЗначениеОтбора.Вставить("ПометкаУдаления", Ложь);
		ПараметрыОтбора.Вставить("Отбор", ЗначениеОтбора);
		ПараметрыОтбора.Вставить("МножественныйВыбор", Ложь);
		ОткрытьФорму("Справочник.СкладскиеЯчейки.ФормаВыбора",ПараметрыОтбора , Элемент);
		
	Иначе
		
		ПоказатьЗначение(Неопределено, Элемент.ТекущиеДанные.Номенклатура);
		
	КонецЕсли;

КонецПроцедуры

Функция ПолучимРабУч(ТекЯч)

	Возврат ТекЯч.РабочийУчасток;

КонецФункции

&НаКлиенте
Процедура ТоварыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	НоваяЯчейка(ВыбранноеЗначение, Склад, Элементы.Товары.ТекущиеДанные.Номенклатура);
		
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаОтгрузка" Тогда
		
		ТекущаяСтрока = Элементы.РаспоряженияНаОтгрузку.ТекущиеДанные;
		
		Если ТекущаяСтрока<>Неопределено Тогда
			СсылкаНаДокумент = ТекущаяСтрока.Распоряжение;
			ТекущийРабочийУчасток = ТекущаяСтрока.Секция;
			ЗаполнитьТовары(Ложь,СсылкаНаДокумент);
		КонецЕсли;
		
	Иначе
		
		ТекущаяСтрока = Элементы.ОрдераВРаботе.ТекущиеДанные;
		Если ТекущаяСтрока<>Неопределено Тогда
			СсылкаНаДокумент = ТекущаяСтрока.Ссылка;
			ЗаполнитьТовары(Истина,СсылкаНаДокумент);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры
	
&НаСервере
Процедура НоваяЯчейка(Ячейка, Склад, Номенклатура)
	Набор = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей();
	Набор.Отбор.Склад.Установить(Склад);
	Набор.Отбор.Номенклатура.Установить(Номенклатура);
	
	Набор.Прочитать();
	Если Набор.Количество() = 1 Тогда
		НоваяСтрока = Набор[0];	
    	НоваяСтрока.Ячейка = Ячейка;
		Попытка
			Набор.Записать(Истина);
		Исключение
			ЕстьОшибки = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить новую ячейку");
		КонецПопытки;
	ИначеЕсли Набор.Количество() = 0 Тогда
		
		 НоваяЗапись = Набор.Добавить(); 
		 НоваяЗапись.Номенклатура = Номенклатура;    
		 НоваяЗапись.Склад = Склад;  
         НоваяЗапись.Ячейка = Ячейка;
		 НоваяЗапись.ОсновнаяЯчейка = Истина;
        Попытка
			Набор.Записать(Истина);
		Исключение
			ЕстьОшибки = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить новую ячейку");
		КонецПопытки;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить новую ячейку");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДополнительныеТаблицы()
	
	Накладная = Ложь;
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаОтгрузка" Тогда
		ТекущаяСтрока = Элементы.РаспоряженияНаОтгрузку.ТекущиеДанные;
		//Распоряжение = Истина;
		Накладная = Истина;
	Иначе
		ТекущаяСтрока = Элементы.ОрдераВРаботе.ТекущиеДанные;
		//Распоряжение = Ложь;
		Накладная = Ложь;
	КонецЕсли;

	Если ТекущаяСтрока <> Неопределено Тогда
		
		//СсылкаНаДокумент = ?(Распоряжение,ТекущаяСтрока.Распоряжение,ТекущаяСтрока.Ссылка);
		 СсылкаНаДокумент = ?(Накладная, ТекущаяСтрока.Документ, ТекущаяСтрока.Ссылка);
		
		//Если Распоряжение Тогда
		Если Накладная Тогда
			ТекущийРабочийУчасток = ТекущаяСтрока.Секция; 
	    КонецЕсли;
	
		Если ОтображатьТовары Тогда
			//ЗаполнитьТовары(Не Распоряжение, СсылкаНаДокумент);
			ЗаполнитьТовары(Не Накладная, СсылкаНаДокумент);
		КонецЕсли;
		
		//Если ПоТекРаспоряжению И Распоряжение Тогда
		Если ПоТекРаспоряжению И Накладная Тогда
			 //ЗаполнитьТекОрдера(СсылкаНаДокумент);  
			  ЗаполнитьОрдераПоТекущемуРаспоряжению(ТекущаяНакладная);
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьОтборПоДатеДокументаПриИзменении(Элемент)
	Элементы.ДатаОтгрузки.Доступность = ?(ИспользоватьОтборПоДатеДокумента="1",Истина,Ложь);
	Элементы.ПериодПоДатеДокумента.Доступность = ?(ИспользоватьОтборПоДатеДокумента="0",Истина,Ложь);
	ДатаОтгрузкиПриИзмененииСервер();
	УстановитьОтборыВЗависимыхСписках(ТекущиеРаспоряжения());
	ЗаполнитьДополнительныеТаблицы();;
КонецПроцедуры

&НаКлиенте
Процедура ПериодПоДатеДокументаПриИзменении(Элемент)
	ДатаОтгрузкиПриИзмененииСервер();
	УстановитьОтборыВЗависимыхСписках(ТекущиеРаспоряжения());
	ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры

Функция ПолучитьОтгружаемыеТоварыПоСекции(ТоварыПоРаспоряжениям, Таблица, Склад, Секция, Накладная)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
	|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
	|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
	|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ВнешняяТаблицаНоменклатуры.Действие КАК Действие,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
	|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
	|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
	|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
	|ИЗ
	|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
	|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
	|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
	|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
	|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
	|	ВнешняяТаблицаНоменклатуры.Действие КАК Действие,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
	|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
	|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
	|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия,
	|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
	|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВнешняяТаблицаНоменклатуры.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И ВнешняяТаблицаНоменклатуры.Номенклатура В (&МассивНоменклатура)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ячейка";

	Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры", Таблица);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("РабочиеУчастки", Секция);
	Запрос.УстановитьПараметр("МассивНоменклатура", Накладная.Товары.ВыгрузитьКолонку("Номенклатура"));
	
	Результат = Запрос.Выполнить().Выгрузить();
	Если ТипЗнч(ТоварыПоРаспоряжениям[0].Распоряжение) = Тип("ДокументСсылка.ЗаказКлиента") ИЛИ ТипЗнч(ТоварыПоРаспоряжениям[0].Распоряжение) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
		ТоварыПоНакладной = Накладная.Товары.Выгрузить();
		ТоварыПоНакладной.Свернуть("Номенклатура", "КоличествоУпаковок, Количество");
		Для Каждого Строка Из Результат Цикл
			Для Каждого СтрокаН Из ТоварыПоНакладной Цикл 
				Если Строка.Номенклатура = СтрокаН.Номенклатура И Строка.Количество > СтрокаН.Количество Тогда
					Строка.Количество = СтрокаН.Количество;
					Строка.КоличествоУпаковок = СтрокаН.КоличествоУпаковок;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
			
	Возврат Результат;
	
КонецФункции

