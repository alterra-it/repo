&НаКлиенте
Процедура СоздатьОрдера(Команда)
	
	ОчиститьСообщения();
	Отказ = Ложь;
	
	ПроверитьСкладПомещение(Отказ);
	
	СоздатьОрдераСервер();
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ОбновитьДанныеСписка", ЭтаФорма);
	Если ТекущийДокумент <> Неопределено Тогда
		ОткрытьФорму("Документ.РасходныйОрдерНаТовары.ФормаОбъекта",Новый Структура("Ключ",ТекущийДокумент),,,,,ОповещениеОЗакрытии); 
	КонецЕсли;
	
КонецПроцедуры

