Процедура ЗаполнитьТовары(ЭтоОрдер,СсылкаНаДокумент)
	
	Если Не ОтображатьТовары Тогда
		Возврат;
	КонецЕсли;
	
	Если ЭтоОрдер Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
		|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество
		|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
		|ИЗ
		|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
		|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
		|ИЗ
		|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО ВнешняяТаблицаНоменклатуры.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|ГДЕ
		|	ВЫБОР
		|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
		|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
		
		Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры",СсылкаНаДокумент.ОтгружаемыеТовары.Выгрузить());
		Запрос.УстановитьПараметр("Склад",Склад);
		Запрос.УстановитьПараметр("РабочиеУчастки",СсылкаНаДокумент.РабочийУчасток);
		Товары.Загрузить(Запрос.Выполнить().Выгрузить());
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
|	ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура КАК Номенклатура,
|	ТоварыКОтгрузкеПоНакладнымОстатки.Характеристика КАК Характеристика,
|	ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток КАК Количество,
|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
|ИЗ
|	РегистрНакопления.ТоварыКОтгрузкеПоНакладным.Остатки КАК ТоварыКОтгрузкеПоНакладнымОстатки
|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
|		ПО ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
|			И ТоварыКОтгрузкеПоНакладнымОстатки.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
|ГДЕ
|	ВЫБОР
|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
|			ИНАЧЕ ИСТИНА
|		КОНЕЦ
|	И ТоварыКОтгрузкеПоНакладнымОстатки.Накладная = &Накладная";
		
		//"ВЫБРАТЬ
		//|	ТоварыКОтгрузке.Номенклатура КАК Номенклатура,
		//|	ТоварыКОтгрузке.Характеристика КАК Характеристика,
		//|	ВЫБОР
		//|		КОГДА ТоварыКОтгрузке.КОформлению > 0
		//|			ТОГДА ТоварыКОтгрузке.КОформлению
		//|		ИНАЧЕ ТоварыКОтгрузке.КОтгрузке
		//|	КОНЕЦ КАК Количество,
		//|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
		//|ИЗ
		//|	РегистрНакопления.ТоварыКОтгрузке КАК ТоварыКОтгрузке
		//|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		//|		ПО ТоварыКОтгрузке.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		//|			И ТоварыКОтгрузке.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		//|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		//|ГДЕ
		//|	ВЫБОР
		//|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
		//|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
		//|			ИНАЧЕ ИСТИНА
		//|		КОНЕЦ
		//|	И ТоварыКОтгрузке.Регистратор = &Накладная";
		
		Запрос.УстановитьПараметр("Накладная",СсылкаНаДокумент);
		Запрос.УстановитьПараметр("РабочиеУчастки",ТекущийРабочийУчасток);
        Товары.Загрузить(Запрос.Выполнить().Выгрузить());

	КонецЕсли;
КонецПроцедуры

