#Область ШтрихкодыИТорговоеОборудование

&НаСервере
Функция СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод)
	
	Менеджеры = Новый Массив();
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ОрдерНаПеремещениеТоваров.ПустаяСсылка"));
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ОтборРазмещениеТоваров.ПустаяСсылка"));
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.РасходныйОрдерНаТовары.ПустаяСсылка"));
	
	МассивСсылок = ШтрихкодированиеПечатныхФорм.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, Менеджеры);
	
	Если МассивСсылок.Количество() > 0 Тогда
		СсылкаДокумента = МассивСсылок[0];
		
		Если ТипЗнч(СсылкаДокумента) = Тип("ДокументСсылка.ОтборРазмещениеТоваров")
			И Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОтгрузка Тогда
			
			СсылкаРаспоряжения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаДокумента, "Распоряжение");
			Элементы.ОрдераВРаботе.ТекущаяСтрока = СсылкаРаспоряжения;
			
			Возврат СсылкаРаспоряжения;
			
		Иначе
			Если ТипЗнч(СсылкаДокумента) = Тип("ДокументСсылка.ОтборРазмещениеТоваров") Тогда
				Элементы.ЗаданияВРаботе.ТекущаяСтрока = СсылкаДокумента;
			ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаОтбор Тогда
				Элементы.РаспоряженияНаОтбор.ТекущаяСтрока = СсылкаДокумента;
			Иначе
				Элементы.ОрдераВРаботе.ТекущаяСтрока = СсылкаДокумента;
			КонецЕсли;
			
			Возврат СсылкаДокумента;
		КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкоды(Данные)
	
	СсылкаДокумента = СсылкаНаЭлементСпискаПоШтрихкоду(Данные.Штрихкод);
	
	Если СсылкаДокумента <> Неопределено Тогда
		ПоказатьЗначение(Неопределено, СсылкаДокумента);
	Иначе
		ШтрихкодированиеПечатныхФормКлиент.ОбъектНеНайден(Данные.Штрихкод);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Интерфейс

&НаКлиенте
Процедура ОсновнойСписокПриАктивацииСтрокиКлиент()
	
	Если ТекущееРаспоряжениеНаОтбор <> ТекущиеРаспоряжения.РаспоряжениеНаОтбор
	 ИЛИ ТекущееРаспоряжениеНаОтгрузку <> ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку Тогда
		
		// Кэшируем выделенные строки
		ВыделенныеСтрокиНаОтгрузку = Новый Массив;
		Для Каждого СтрокаТаблицы Из Элементы.РаспоряженияНаОтгрузку.ВыделенныеСтроки Цикл
			СтрокаТаблицы = РаспоряженияНаОтгрузку.НайтиПоИдентификатору(СтрокаТаблицы);
			Если СтрокаТаблицы <> Неопределено Тогда
				СтрокаТаблицы = СтрокаТаблицы.Распоряжение;
			КонецЕсли;
			ВыделенныеСтрокиНаОтгрузку.Добавить(СтрокаТаблицы);
		КонецЦикла;
		
		ВыделенныеСтрокиНаОтбор = Новый Массив;
		УстановитьОтборыВЗависимыхСписках(ТекущиеРаспоряжения);
		
		// Восстанавливаем выделенные строки
		СтрокиТаблицы = РаспоряженияНаОтгрузку.НайтиСтроки(Новый Структура("Распоряжение", ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку));
		Если СтрокиТаблицы.Количество() > 0 Тогда
			Элементы.РаспоряженияНаОтгрузку.ТекущаяСтрока = СтрокиТаблицы[0].ПолучитьИдентификатор();
		КонецЕсли;
		
		Элементы.РаспоряженияНаОтгрузку.ВыделенныеСтроки.Очистить();
		Для Каждого СтрокаТаблицы Из ВыделенныеСтрокиНаОтгрузку Цикл
			СтрокиТаблицы = РаспоряженияНаОтгрузку.НайтиСтроки(Новый Структура("Распоряжение", СтрокаТаблицы));
			Если СтрокиТаблицы.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			Элементы.РаспоряженияНаОтгрузку.ВыделенныеСтроки.Добавить(СтрокиТаблицы[0].ПолучитьИдентификатор());
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ТекущиеРаспоряжения()
	
	СтруктураВозврата = Новый Структура("РаспоряжениеНаОтбор, РаспоряжениеНаОтгрузку");
	
	Если Элементы.РаспоряженияНаОтгрузку.ТекущиеДанные <> Неопределено Тогда
		//СтруктураВозврата.РаспоряжениеНаОтгрузку = Элементы.РаспоряженияНаОтгрузку.ТекущиеДанные.Распоряжение;
		СтруктураВозврата.РаспоряжениеНаОтгрузку = Элементы.РаспоряженияНаОтгрузку.ТекущиеДанные.Документ;
	КонецЕсли;
	
	Возврат СтруктураВозврата;
	
КонецФункции

&НаСервере
Процедура СкладПомещениеПриИзмененииСервер()
		
	СтруктураУстанавливаемыхПараметров = Новый Структура;
	
	Если ЗначениеЗаполнено(Склад) Тогда
		СтруктураУстанавливаемыхПараметров.Вставить("Склад",Склад);
		СтруктураУстанавливаемыхПараметров.Вставить("Помещение",Помещение);
		ИспользоватьАдресноеХранение = СкладыСервер.ИспользоватьАдресноеХранение(Склад, Помещение);
	Иначе
		СтруктураУстанавливаемыхПараметров.Вставить("Склад",Неопределено);
		СтруктураУстанавливаемыхПараметров.Вставить("Помещение",Неопределено);
		ИспользоватьАдресноеХранение = Ложь;
	КонецЕсли;	
	
	УстановитьПараметрыФункциональныхОпцийФормы(СтруктураУстанавливаемыхПараметров);
	ИспользоватьСтатусыРасходныхОрдеров = ПолучитьФункциональнуюОпцию("ИспользоватьСтатусыРасходныхОрдеров",
																		Новый Структура("Склад", Склад));
	Если НЕ Параметры.Свойство("СвойОтбор") Тогда	
		РабочиеУчастки = Справочники.РабочиеУчастки.ПустаяСсылка();
	КонецЕсли;
	НазначитьЗонуОтгрузки = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьНеДоступноСозданиеРасходныхОрдеров()
	
	Если Не ДоступноСозданиеРасходныхОрдеров Тогда	
		
		Элементы.ГруппаРасходныеОрдера.ОтображатьЗаголовок = Ложь;
		Элементы.ГруппаРасходныеОрдера.Отображение = ОтображениеОбычнойГруппы.Нет;
		Элементы.ФильтрОрдеров.Видимость = Ложь;
		
		Элементы.ГруппаОтборКоманднаяПанельРаспоряженияНаОтгрузку.Видимость = Ложь;
		Элементы.ГруппаРаспоряженияНаОтгрузку.Видимость = Ложь;
		Элементы.ГруппаШапкаОтгрузкиРасходныеОрдера.Видимость = Истина;
		Элементы.АвтоматическоеФормированиеРасходныхОрдеров.Видимость = Истина;
		Элементы.ИзменитьФорму2.Видимость = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ГруппаСтраницыПриСменеСтраницыСервер(ТекущиеРаспоряжения, ИмяТекущейСтраницы);
	
	УстановитьОтборыВЗависимыхСписках(ТекущиеРаспоряжения);
	
КонецПроцедуры

&НаСервере
Процедура ДатаОтгрузкиПриИзмененииСервер()
	
	//УстановитьОтборыВОсновныхСписках();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗаголовкиКолонокВесОбъем()
	ЕдиницаИзмеренияОбъема 	= Строка(Константы.ЕдиницаИзмеренияОбъема.Получить());
	ЕдиницаИзмеренияВеса 	= Строка(Константы.ЕдиницаИзмеренияВеса.Получить());
	
	ЗаголовокЭлемента = НСтр("ru='Объем, %ЕдиницаИзмерения%'");
	ЗаголовокЭлемента = СтрЗаменить(ЗаголовокЭлемента, "%ЕдиницаИзмерения%", ЕдиницаИзмеренияОбъема); 
	
	ЗаголовокЭлемента = НСтр("ru='Вес (брутто), %ЕдиницаИзмерения%'");
	ЗаголовокЭлемента = СтрЗаменить(ЗаголовокЭлемента, "%ЕдиницаИзмерения%", ЕдиницаИзмеренияВеса); 
	Элементы.ЗаданияВРаботе.ПодчиненныеЭлементы.ПеремещенияВРаботеВесОтбор.Заголовок   = ЗаголовокЭлемента;
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборыВОсновныхСписках()
	ЗаполнитьРаспоряженияНаОтгрузку();
КонецПроцедуры

&НаСервере
Процедура УстановитьОтборыВЗависимыхСписках(ТекущиеРаспоряжения)
	
	ЗаполнитьРаспоряженияНаОтгрузку(Ложь);
	
	//ГруппаОрдера
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаОрдера" Тогда
		
		Если ТекущиеРаспоряжения = Неопределено Тогда
			ТекущееРаспоряжениеНаОтбор = Неопределено;
			ТекущееРаспоряжениеНаОтгрузку = Неопределено;
		Иначе
			ТекущееРаспоряжениеНаОтбор    = ТекущиеРаспоряжения.РаспоряжениеНаОтбор;
			ТекущееРаспоряжениеНаОтгрузку = ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку;
		КонецЕсли;
		
		//ОрдераВРаботе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Склад", Склад, ВидСравненияКомпоновкиДанных.Равно,,Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ПомещениеОтправитель", Помещение,
		ВидСравненияКомпоновкиДанных.Равно,,ЗначениеЗаполнено(Помещение));
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ДатаОтгрузки", КонецДня(ДатаОтгрузки.ДатаОкончания),
		ВидСравненияКомпоновкиДанных.МеньшеИЛИРавно,,Истина);
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ДатаОтгрузки", НачалоДня(ДатаОтгрузки.ДатаНачала),
		ВидСравненияКомпоновкиДанных.БольшеИлиРавно,,Истина);
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка.РабочийУчасток", РабочиеУчастки, ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
		
		// Сбросим отбор, установленный для скрытия ордеров в случае фильтра "ПоТекущемуРаспоряжению" при отсутствии распоряжений.
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка", Неопределено,,,Ложь);
		
		Если ФильтрОрдеров = "" Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Статус", Неопределено,,,Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Распоряжение", Неопределено,,,Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ЗаданиеНаПеревозку", Неопределено,,,Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Проведен", Истина,,,Ложь);
			
		ИначеЕсли ФильтрОрдеров = "ВсеНеотгруженные" Тогда
			СписокСтатусов = Новый СписокЗначений;
			СписокСтатусов.Добавить(Перечисления.СтатусыРасходныхОрдеров.Подготовлен);
			СписокСтатусов.Добавить(Перечисления.СтатусыРасходныхОрдеров.КОтбору);
			СписокСтатусов.Добавить(Перечисления.СтатусыРасходныхОрдеров.КПроверке);
			СписокСтатусов.Добавить(Перечисления.СтатусыРасходныхОрдеров.Проверен);
			СписокСтатусов.Добавить(Перечисления.СтатусыРасходныхОрдеров.КОтгрузке);
			СписокСтатусов.Добавить(Перечисления.СтатусыОрдеровНаПеремещение.КОтбору);
			СписокСтатусов.Добавить(Перечисления.СтатусыОрдеровНаПеремещение.КПроверке);
			СписокСтатусов.Добавить(Перечисления.СтатусыОрдеровНаПеремещение.КОтгрузке);
			
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Статус", СписокСтатусов, ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Распоряжение", Неопределено,,,Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ЗаданиеНаПеревозку", Неопределено,,,Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Проведен", Истина,,,Истина);
			
		ИначеЕсли ФильтрОрдеров = "ПоТекущемуРаспоряжению" Тогда
			Если Не ТекущиеРаспоряжения = Неопределено Тогда
				Если ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку = Неопределено Тогда
					// Текущего распоряжения нет, ордера не показываем
					ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка", Документы.РасходныйОрдерНаТовары.ПустаяСсылка(),,,Истина);
				Иначе
					ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Статус",   Неопределено,,,Ложь);
					ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Проведен", Истина,,,Ложь);
					Если ТипЗнч(ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку) = Тип("ДокументСсылка.ЗаданиеНаПеревозку") Тогда
						ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка", Неопределено,,,Ложь);
						ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ЗаданиеНаПеревозку", ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку,,,Истина);
					Иначе			
						Запрос = Новый Запрос;
						Запрос.Текст = 
						//"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
						//|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка КАК Ссылка
						//|ИЗ
						//|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
						//|ГДЕ
						//|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение = &Распоряжение";
						//Запрос.УстановитьПараметр("Распоряжение", ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку);
						"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
						|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
						|ИЗ
						|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
						|ГДЕ
						|	РасходныйОрдерНаТовары.Накладная = &Накладная";
						Запрос.УстановитьПараметр("Накладная", ТекущиеРаспоряжения.РаспоряжениеНаОтгрузку);
						РасходныеОрдера = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
						
						ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка", РасходныеОрдера, ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
						ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "ЗаданиеНаПеревозку", Неопределено,,,Ложь);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРаспоряженияНаОтгрузку(ПроверятьИзменениеПараметров = Ложь)
	
	Если Не ЗначениеЗаполнено(Склад) Или Не ЗначениеЗаполнено(РабочиеУчастки) Тогда
		РаспоряженияНаОтгрузку.Очистить();
		Возврат;
	КонецЕсли;
	
	Если Не Пользователи.ЭтоПолноправныйПользователь(Неопределено) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Склады.Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Ссылка = &Склад";
		
		Запрос.УстановитьПараметр("Склад", Склад);
		
		Если Запрос.Выполнить().Пустой() Тогда
			РаспоряженияНаОтгрузку.Очистить();
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Период", Склад.ДатаНачалаОрдернойСхемыПриОтгрузке);
	Запрос.УстановитьПараметр("ИспользоватьОтборПоДате", Ложь);
	Если ИспользоватьОтборПоДатеДокумента = "0" Тогда
		Запрос.УстановитьПараметр("Дата1", ?(ЗначениеЗаполнено(ПериодПоДатеДокумента.ДатаНачала), НачалоДня(ПериодПоДатеДокумента.ДатаНачала) - 1, ПериодПоДатеДокумента.ДатаНачала));
		Запрос.УстановитьПараметр("Дата2", ?(ЗначениеЗаполнено(ПериодПоДатеДокумента.ДатаОкончания), КонецДня(ПериодПоДатеДокумента.ДатаОкончания) + 1, ПериодПоДатеДокумента.ДатаОкончания));
	Иначе	
		Запрос.УстановитьПараметр("Дата1", ?(ЗначениеЗаполнено(ДатаОтгрузки.ДатаНачала), НачалоДня(ДатаОтгрузки.ДатаНачала) - 1, ДатаОтгрузки.ДатаНачала));
		Запрос.УстановитьПараметр("Дата2", ?(ЗначениеЗаполнено(ДатаОтгрузки.ДатаОкончания), КонецДня(ДатаОтгрузки.ДатаОкончания) + 1, ДатаОтгрузки.ДатаОкончания));
	КонецЕсли;
	Запрос.УстановитьПараметр("Номер", ПоискПоНомеру);
	
	Если ЗначениеЗаполнено(ДатаОтгрузки.ДатаНачала) ИЛИ ЗначениеЗаполнено(ПериодПоДатеДокумента.ДатаНачала) Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		ДатаНачалаДействияОтгрузкиПоНакладным = Константы.ДатаНачалаДействияОтгрузкиПоНакладным.Получить();
		УстановитьПривилегированныйРежим(Ложь);
	
		Если ДатаОтгрузки.ДатаНачала < ДатаНачалаДействияОтгрузкиПоНакладным 
			ИЛИ ПериодПоДатеДокумента.ДатаНачала < ДатаНачалаДействияОтгрузкиПоНакладным Тогда
			
			Запрос.Текст =	ПолучитьТекстЗапросаДоНачалаДействияОтгрузкиПоНакладным();	
		Иначе
			Запрос.Текст =	ПолучитьТекстЗапросаПослеНачалаДействияОтгрузкиПоНакладным();	
		КонецЕсли;  
		
	Иначе 
		Запрос.Текст =	ПолучитьТекстЗапросаПослеНачалаДействияОтгрузкиПоНакладным();	 
	КонецЕсли;
	
	Запрос.УстановитьПараметр("РабочиеУчастки",РабочиеУчастки.ВыгрузитьЗначения());
	
	ДобавитьСостоянияВТекстЗапроса(Запрос);
			
	// Запомним текущую строку таблицы распоряжений
	Если ЗначениеЗаполнено(Элементы.РаспоряженияНаОтгрузку.ТекущаяСтрока) Тогда
		ТекущаяСтрокаРаспоряженияНаОтгрузку = 
			РаспоряженияНаОтгрузку.НайтиПоИдентификатору(Элементы.РаспоряженияНаОтгрузку.ТекущаяСтрока);
		Если ТекущаяСтрокаРаспоряженияНаОтгрузку <> Неопределено Тогда
			ТекущаяНакладная = ТекущаяСтрокаРаспоряженияНаОтгрузку.Документ;
		КонецЕсли;		
	Иначе
		ТекущаяНакладная = Неопределено;
	КонецЕсли;
	
	РаспоряженияНаОтгрузку.Загрузить(Запрос.Выполнить().Выгрузить());
	
	// Восстановим текущую строку
	Если ЗначениеЗаполнено(ТекущаяНакладная) Тогда
		Строки = РаспоряженияНаОтгрузку.НайтиСтроки(Новый Структура("Документ", ТекущаяНакладная));
		Если Строки.Количество() > 0 Тогда
			Элементы.РаспоряженияНаОтгрузку.ТекущаяСтрока = Строки[0].ПолучитьИдентификатор();
		КонецЕсли;
	ИначеЕсли РаспоряженияНаОтгрузку.Количество() > 0 Тогда
		Элементы.РаспоряженияНаОтгрузку.ТекущаяСтрока = РаспоряженияНаОтгрузку[0].ПолучитьИдентификатор();
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Функция ПолучитьТекстЗапросаДоНачалаДействияОтгрузкиПоНакладным()
   	//СТАРАЯ ДАТА	
	Возврат "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			ТоварыКОтгрузке.Регистратор КАК Документ,
		|			ТоварыКОтгрузке.Получатель КАК Получатель,
		|			ТоварыКОтгрузке.ДокументОтгрузки КАК ДокументОтгрузки,
		|			ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток, ЗНАЧЕНИЕ(Справочник.РабочиеУчастки.ПустаяСсылка)) КАК Секция
		|		ПОМЕСТИТЬ Накладные
		|		ИЗ
		|			РегистрНакопления.ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|				ПО (ТоварыКОтгрузке.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура)
		|					И (ТоварыКОтгрузке.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад)
		|					И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ГДЕ
		|			ТоварыКОтгрузке.Склад = &Склад
		|			И РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В(&РабочиеУчастки)
		|			И ВЫБОР
		|					КОГДА &ИспользоватьОтборПоДате
		|						ТОГДА ТоварыКОтгрузке.Период >= &Период
		|					ИНАЧЕ ТоварыКОтгрузке.Период МЕЖДУ &Дата1 И &Дата2
		|				КОНЕЦ
		|			И НЕ(ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.ЗаказНаПеремещение
		|						ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.ЗаказКлиента
		|						ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.ЗаказНаВнутреннееПотребление
		|						ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.РасходныйОрдерНаТовары
		|						ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.ЗаказНаСборку
		|						ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.АктОРасхожденияхПослеПеремещения)
		//				ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.АктОРасхожденияхПослеПриемки
		//				ИЛИ ТоварыКОтгрузке.Регистратор ССЫЛКА Документ.АктОРасхожденияхПослеОтгрузки
		|			И ВЫБОР
		|					КОГДА НЕ &Номер = """"
		|						ТОГДА ТоварыКОтгрузке.Регистратор.Номер ПОДОБНО ""%"" + &Номер + ""%""
		|					ИНАЧЕ ИСТИНА
		|				КОНЕЦ
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ТоварыКОтгрузке.Регистратор,
		|			ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток, ЗНАЧЕНИЕ(Справочник.РабочиеУчастки.ПустаяСсылка)),
		|			ТоварыКОтгрузке.Получатель,
		|			ТоварыКОтгрузке.ДокументОтгрузки
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ
		|			ТоварыПоРаспоряжениям.Ссылка КАК Ордер,
		|			ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток, ЗНАЧЕНИЕ(Справочник.РабочиеУчастки.ПустаяСсылка)) КАК Секция
		|		ПОМЕСТИТЬ ОрдераПоСекциям
		|		ИЗ
		|			Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК ТоварыПоРаспоряжениям
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|				ПО ТоварыПоРаспоряжениям.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|					И ТоварыПоРаспоряжениям.Ссылка.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|					И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ГДЕ
		|			НЕ ТоварыПоРаспоряжениям.Ссылка.ПометкаУдаления
		|			И ТоварыПоРаспоряжениям.Ссылка.Накладная В
		|					(ВЫБРАТЬ
		|						Накладные.Документ
		|					ИЗ
		|						Накладные)
		|			И ТоварыПоРаспоряжениям.Ссылка.Проведен 
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ТоварыПоРаспоряжениям.Ссылка,
		|			РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			Накладные.Документ КАК Документ,
		|			Накладные.Получатель КАК Получатель,
		|			Накладные.Секция КАК Секция,
		|			Накладные.ДокументОтгрузки КАК ДокументОтгрузки,
		|			ВЫБОР
		|				КОГДА НЕ ОрдераПоСекциям.Ордер ЕСТЬ NULL 
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК ЕстьОрдер
		|		ПОМЕСТИТЬ НакладныеИОрдера
		|		ИЗ
		|			Накладные КАК Накладные
		|				ЛЕВОЕ СОЕДИНЕНИЕ ОрдераПоСекциям КАК ОрдераПоСекциям
		|				ПО Накладные.Документ = ОрдераПоСекциям.Ордер.Накладная
		|					И Накладные.Секция = ОрдераПоСекциям.Секция
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ
		|			ТоварыКОтгрузкеОстатки.ДокументОтгрузки КАК Документ,      //Вот тут меняем на ТоварыКОтгрузкеПоНакладным 
		|			РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
		|			СУММА(ТоварыКОтгрузкеОстатки.КОформлениюОстаток) КАК КОформлениюОстаток,
		|			СУММА(ТоварыКОтгрузкеОстатки.СобираетсяОстаток) КАК СобираетсяОстаток,
		|			СУММА(ТоварыКОтгрузкеОстатки.СобраноОстаток) КАК СобраноОстаток,
		|			СУММА(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток) КАК КОтгрузкеОстаток,
		|			СУММА(ТоварыКОтгрузкеОстатки.ВРезервеОстаток) КАК ВРезервеОстаток,
		|			СУММА(ТоварыКОтгрузкеОстатки.КСборкеОстаток) КАК КСборкеОстаток
		|		ПОМЕСТИТЬ Остатки
		|		ИЗ
		|			РегистрНакопления.ТоварыКОтгрузке.Остатки КАК ТоварыКОтгрузкеОстатки
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|				ПО ТоварыКОтгрузкеОстатки.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|					И ТоварыКОтгрузкеОстатки.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|					И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ГДЕ
		|			ТоварыКОтгрузкеОстатки.ДокументОтгрузки В
		|					(ВЫБРАТЬ
		|						Накладные.ДокументОтгрузки
		|					ИЗ
		|						Накладные)
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ТоварыКОтгрузкеОстатки.ДокументОтгрузки,
		|			РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			НакладныеИОрдера.Документ КАК Документ,
		|			НакладныеИОрдера.Получатель КАК Получатель,
		|			НакладныеИОрдера.Секция КАК Секция,
		|			НакладныеИОрдера.ЕстьОрдер КАК ЕстьОрдер,
		|			СУММА(ЕСТЬNULL(Остатки.КОформлениюОстаток, 0)) КАК КОформлению,
		|			СУММА(ЕСТЬNULL(Остатки.КСборкеОстаток, 0)) КАК КСборке,
		|			СУММА(ЕСТЬNULL(Остатки.СобираетсяОстаток, 0)) КАК Собирается,
		|			СУММА(ЕСТЬNULL(Остатки.СобраноОстаток, 0)) КАК Собрано,
		|			СУММА(ЕСТЬNULL(Остатки.КОтгрузкеОстаток, 0)) КАК КОтгрузке
		|		ПОМЕСТИТЬ РаспоряженияИСостояния
		|		ИЗ
		|			НакладныеИОрдера КАК НакладныеИОрдера
		|				ЛЕВОЕ СОЕДИНЕНИЕ Остатки КАК Остатки
		|				ПО (НакладныеИОрдера.ДокументОтгрузки = Остатки.Документ)
		|					И (НакладныеИОрдера.Секция = Остатки.Секция)
		|		
		|		СГРУППИРОВАТЬ ПО
		|			НакладныеИОрдера.Документ,
		|			НакладныеИОрдера.Получатель,
		|			НакладныеИОрдера.Секция,
		|			НакладныеИОрдера.ЕстьОрдер
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			ВложенныйЗапрос.Документ КАК Документ,
		|			ВложенныйЗапрос.Номенклатура КАК Номенклатура,
		|			ВложенныйЗапрос.Характеристика КАК Характеристика,
		|			СУММА(ВложенныйЗапрос.КоличествоВДокументе) КАК КоличествоВДокументе,
		|			ВложенныйЗапрос.Склад КАК Склад,
		|			ВложенныйЗапрос.Распоряжение КАК Распоряжение,
		|			СУММА(ВложенныйЗапрос.КоличествоВОрдере) КАК КоличествоВОрдере,
		|			ВЫБОР
		|				КОГДА СУММА(ВложенныйЗапрос.КоличествоВОрдере) > СУММА(ВложенныйЗапрос.КоличествоВДокументе)
		|					ТОГДА 1
		|				ИНАЧЕ 0
		|			КОНЕЦ КАК ЕстьПерепоставка,
		|			РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция
		|		ПОМЕСТИТЬ Перепоставка
		|		ИЗ
		|			(ВЫБРАТЬ
		|				ПеремещениеТоваровТовары.Ссылка КАК Документ,
