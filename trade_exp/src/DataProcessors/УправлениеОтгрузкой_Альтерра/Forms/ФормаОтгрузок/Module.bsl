 &НаСервере
 Процедура ЗаполнитьНарезку(РО)
	 //Заполнение по распоряжениям
	 ПредРаспоряжение = Документы.РеализацияТоваровУслуг.ПустаяСсылка();
	 ТоварыПоРаспоряжениям = РО.ТоварыПоРаспоряжениям; 
	 
	 Для каждого строка из ТоварыПоРаспоряжениям цикл 
		Распоряжение = Строка.Распоряжение; 
		
		Если ПредРаспоряжение = Распоряжение Тогда
			Прервать; 
		Иначе 
			ПредРаспоряжение = Распоряжение;
			РаспоряжениеОбъект = Распоряжение.ПолучитьОбъект();
			Если РаспоряжениеОбъект.Метаданные().ТабличныеЧасти.Найти("Нарезка")<>Неопределено
		    И  ЗначениеЗаполнено(Распоряжение.Нарезка) Тогда
			   
		    Для Каждого Строка Из Распоряжение.Нарезка Цикл
				  ЗаполнитьЗначенияСвойств(РО.Нарезка.Добавить(), Строка); 
		    КонецЦикла; 
			  
		   КонецЕсли;
	    КонецЕсли;
	КонецЦикла;
	
		
КонецПроцедуры

&НаСервере
Функция ПолучитьРаспоряжениеПоДокументу(Накладная)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузке.ДокументОтгрузки КАК Распоряжение
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|ГДЕ
		|	ТоварыКОтгрузке.Регистратор = &Накладная";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	Результат = Запрос.Выполнить().Выбрать();
	
	Пока Результат.Следующий() Цикл
		Возврат Результат.Распоряжение;
	КонецЦикла;
	
КонецФункции    

&НаСервере
Функция ПолучитьВСЕРаспоряженияПоДокументу(Накладная)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузке.ДокументОтгрузки КАК Распоряжение
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузке КАК ТоварыКОтгрузке
		|ГДЕ
		|	ТоварыКОтгрузке.Регистратор = &Накладная";
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	
	Результат = Запрос.Выполнить().Выбрать();
	Массив = Новый Массив; 
	
	Пока Результат.Следующий() Цикл
		Массив.Добавить(Результат.Распоряжение);
	КонецЦикла;
	Возврат Массив; 
КонецФункции


&НаСервере
Функция ПолучитьМассивРаспоряжений(МассивРаспоряжений)
	
	Распоряжение = Документы.ЗаказНаПеремещение.ПустаяСсылка();
	
	Если МассивРаспоряжений.Количество()=1 Тогда
		Если ТипЗнч(МассивРаспоряжений[0]) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			Распоряжение = МассивРаспоряжений[0];
		Иначе
			Возврат МассивРаспоряжений;
		КонецЕсли;
	Иначе
		Возврат МассивРаспоряжений;
	КонецЕсли;
	 
	Если Не Распоряжение.Пустая() Тогда
		  	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.ЗаказНаПеремещение КАК ЗаказНаПеремещение
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка = &Ссылка
		|	И ПеремещениеТоваровТовары.ЗаказНаПеремещение <> &ЗаказНаПеремещение
		|
		|СГРУППИРОВАТЬ ПО
		|	ПеремещениеТоваровТовары.ЗаказНаПеремещение";
	
	Запрос.УстановитьПараметр("Ссылка", ТекущаяНакладная);
	Запрос.УстановитьПараметр("ЗаказНаПеремещение", Распоряжение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивРаспоряжений.Добавить(ВыборкаДетальныеЗаписи.ЗаказНаПеремещение);
	КонецЦикла;
	
	Возврат МассивРаспоряжений;

	КонецЕсли;
	
КонецФункции
	
&НаСервере
Процедура ЗапуститьФормированиеОрдеров()
	
	СтруктураПараметровСозданияРасходныхОрдеров = СкладыСервер.ПараметрыПереоформленияРасходныхОрдеров();
	СтруктураПараметровСозданияРасходныхОрдеров.Склад = Склад;
	Получатели = ПолучателиПоКоторымНетФоновогоЗаданияПереоформленияОрдеров(Склад);
	ЕстьОшибка = Ложь;
	Для Каждого Получатель Из Получатели Цикл
		СтруктураПараметровСозданияРасходныхОрдеров.Получатель = Получатель;
		СтруктураВозврата = СкладыСервер.ПереоформитьРасходныеОрдера(СтруктураПараметровСозданияРасходныхОрдеров);
		ЕстьОшибка = СтруктураВозврата.ЕстьОшибка Или ЕстьОшибка;
	КонецЦикла;
	
	Если ЕстьОшибка Тогда
		
		Элементы.АвтоматическоеФормированиеРасходныхОрдеров.ТекущаяСтраница = 
		Элементы.СтраницаПроблема;
		
	Иначе
		Элементы.АвтоматическоеФормированиеРасходныхОрдеров.ТекущаяСтраница = 
		Элементы.СтраницаНетПроблем;	
	КонецЕсли;
	
	УстановитьОтборыВОсновныхСписках();
	
КонецПроцедуры

&НаСервере
Функция УстановитьЗоныОтгрузкиСервер(Знач МассивДокументов)

	МассивИзмененныхДокументов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	|ГДЕ
	|	РасходныйОрдерНаТовары.ЗонаОтгрузки <> &ЗонаОтгрузки
	|	И РасходныйОрдерНаТовары.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОрдерНаПеремещениеТоваров.Ссылка
	|ИЗ
	|	Документ.ОрдерНаПеремещениеТоваров КАК ОрдерНаПеремещениеТоваров
	|ГДЕ
	|	ОрдерНаПеремещениеТоваров.ЗонаОтгрузки <> &ЗонаОтгрузки
	|	И ОрдерНаПеремещениеТоваров.Ссылка В(&МассивДокументов)";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("ЗонаОтгрузки", ЗонаОтгрузки);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Попытка
			ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
			
			ДокументОбъект.Заблокировать();
			
			ДокументОбъект.ЗонаОтгрузки = ЗонаОтгрузки;
			
			ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
			МассивИзмененныхДокументов.Добавить(Выборка.Ссылка);
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;
	КонецЦикла;
	Элементы.ОрдераВРаботе.Обновить();
	
	Возврат МассивИзмененныхДокументов;
	
КонецФункции

&НаСервере
Функция НазначитьПриоритетОтгрузкиСервер(Знач МассивДокументов, Приоритет)
	
	МассивИзмененныхДокументов = Новый Массив;
	
    Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	|ГДЕ
	|	РасходныйОрдерНаТовары.Приоритет <> &Приоритет
	|	И РасходныйОрдерНаТовары.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОрдерНаПеремещениеТоваров.Ссылка
	|ИЗ
	|	Документ.ОрдерНаПеремещениеТоваров КАК ОрдерНаПеремещениеТоваров
	|ГДЕ
	|	ОрдерНаПеремещениеТоваров.Приоритет <> &Приоритет
	|	И ОрдерНаПеремещениеТоваров.Ссылка В(&МассивДокументов)";
	
