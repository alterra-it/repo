		|			ГДЕ
		|				ПеремещениеТоваровТовары.Ссылка В
		|						(ВЫБРАТЬ
		|							РаспоряженияИСостояния.Документ КАК Документ
		|						ИЗ
		|							РаспоряженияИСостояния КАК РаспоряженияИСостояния)
		|				И ПеремещениеТоваровТовары.Ссылка.Проведен
		|			
		|			СГРУППИРОВАТЬ ПО
		|				ПеремещениеТоваровТовары.Ссылка,
		|				ПеремещениеТоваровТовары.Номенклатура,
		|				ПеремещениеТоваровТовары.Характеристика,
		|				ПеремещениеТоваровТовары.Ссылка.СкладОтправитель,
		|				ВЫБОР
		|					КОГДА ПеремещениеТоваровТовары.ЗаказНаПеремещение = ЗНАЧЕНИЕ(Документ.ЗаказНаПеремещение.ПустаяСсылка)
		|						ТОГДА ПеремещениеТоваровТовары.Ссылка
		|					ИНАЧЕ ПеремещениеТоваровТовары.ЗаказНаПеремещение
		|				КОНЕЦ
		|			
		|			ОБЪЕДИНИТЬ ВСЕ
		|			
		|			ВЫБРАТЬ
		|				РеализацияТоваровУслугТовары.Ссылка,
		|				РеализацияТоваровУслугТовары.Номенклатура,
		|				РеализацияТоваровУслугТовары.Характеристика,
		|				СУММА(РеализацияТоваровУслугТовары.Количество),
		|				РеализацияТоваровУслугТовары.Склад,
		|				ВЫБОР
		|					КОГДА РеализацияТоваровУслугТовары.ЗаказКлиента = НЕОПРЕДЕЛЕНО
		|						ТОГДА РеализацияТоваровУслугТовары.Ссылка
		|					ИНАЧЕ РеализацияТоваровУслугТовары.ЗаказКлиента
		|				КОНЕЦ,
		|				0
		|			ИЗ
		|				Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|			ГДЕ
		|				РеализацияТоваровУслугТовары.Ссылка В
		|						(ВЫБРАТЬ
		|							РаспоряженияИСостояния.Документ КАК Документ
		|						ИЗ
		|							РаспоряженияИСостояния КАК РаспоряженияИСостояния)
		|				И РеализацияТоваровУслугТовары.Ссылка.Проведен
		|			
		|			СГРУППИРОВАТЬ ПО
		|				РеализацияТоваровУслугТовары.Ссылка,
		|				РеализацияТоваровУслугТовары.Номенклатура,
		|				РеализацияТоваровУслугТовары.Характеристика,
		|				РеализацияТоваровУслугТовары.Склад,
		|				ВЫБОР
		|					КОГДА РеализацияТоваровУслугТовары.ЗаказКлиента = НЕОПРЕДЕЛЕНО
		|						ТОГДА РеализацияТоваровУслугТовары.Ссылка
		|					ИНАЧЕ РеализацияТоваровУслугТовары.ЗаказКлиента
		|				КОНЕЦ
		|			
		|			ОБЪЕДИНИТЬ ВСЕ
		|			
		|			ВЫБРАТЬ
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Накладная,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика,
		|				0,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Склад,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение,
		|				СУММА(РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Количество)
		|			ИЗ
		|				Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|			ГДЕ
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Накладная В
		|						(ВЫБРАТЬ
		|							РаспоряженияИСостояния.Документ КАК Документ
		|						ИЗ
		|							РаспоряженияИСостояния КАК РаспоряженияИСостояния
		|						ГДЕ
		|							(ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) = ТИП(Документ.ЗаказКлиента)
		|								ИЛИ ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) = ТИП(Документ.РеализацияТоваровУслуг)
		|								ИЛИ ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) = ТИП(Документ.ПеремещениеТоваров)
		|								ИЛИ ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) = ТИП(Документ.ЗаказНаПеремещение)))
		|				И РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Проведен
		|			
		|			СГРУППИРОВАТЬ ПО
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Накладная,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Номенклатура,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Характеристика,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка.Склад,
		|				РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение) КАК ВложенныйЗапрос
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|				ПО ВложенныйЗапрос.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|					И ВложенныйЗапрос.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|					И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ВложенныйЗапрос.Документ,
		|			ВложенныйЗапрос.Номенклатура,
		|			ВложенныйЗапрос.Характеристика,
		|			ВложенныйЗапрос.Склад,
		|			ВложенныйЗапрос.Распоряжение,
		|			РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ
		|			Перепоставка.Документ КАК Документ,
		|			СУММА(Перепоставка.ЕстьПерепоставка) КАК ЕстьПерепоставка,
		|			Перепоставка.Секция КАК Секция,
		|			ВЫБОР
		|				КОГДА СУММА(Перепоставка.ЕстьПерепоставка) > 0
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК Перепоставка
		|		ПОМЕСТИТЬ ПерепоставкаИтоговый
		|		ИЗ
		|			Перепоставка КАК Перепоставка
		|		
		|		СГРУППИРОВАТЬ ПО
		|			Перепоставка.Документ,
		|			Перепоставка.Секция
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ
		|	РаспоряженияИСостояния.Документ КАК Реализация,
		|	ЗаказНаДоставкуОснования.Ссылка КАК ЗаказНаДоставку,
		|	ДополнительныеСведения.Значение КАК СведениеМаркетплейс
		|ПОМЕСТИТЬ ВТ_ПродажаДоставка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РаспоряженияИСостояния КАК РаспоряженияИСостояния
		|		ПО РеализацияТоваров.Ссылка = РаспоряженияИСостояния.Документ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
		|		ПО РеализацияТоваров.Ссылка = ЗаказНаДоставкуОснования.Документ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО РеализацияТоваров.Партнер = ДополнительныеСведения.Объект
		|			И (ДополнительныеСведения.Свойство.Наименование = ""Маркетплейс"")
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	РаспоряженияИСостояния.Документ,
		|	ЗаказНаДоставкуОснования.Ссылка,
		|	ДополнительныеСведения.Значение
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваров
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РаспоряженияИСостояния КАК РаспоряженияИСостояния
		|		ПО РеализацияТоваров.Ссылка = РаспоряженияИСостояния.Документ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
		|		ПО (РеализацияТоваров.ЗаказКлиента <> ЗНАЧЕНИЕ(Документ.ЗаказКлиента.ПустаяСсылка))
		|			И РеализацияТоваров.ЗаказКлиента = ЗаказНаДоставкуОснования.Документ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО РеализацияТоваров.Партнер = ДополнительныеСведения.Объект
		|			И (ДополнительныеСведения.Свойство.Наименование = ""Маркетплейс"")
		|;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ
		|			ВТ_ПродажаДоставка.Реализация КАК Реализация,
		|			ВТ_ПродажаДоставка.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|			ДокЗаказ.ОбъектДоставки КАК Объектдоставки,
		|			ОбъектыДоставки.Маркетплейс КАК Маркетплейс
		|		Поместить ПродажиМаркетплейс
		|		ИЗ
		|			Документ.ЗаказНаДоставкуКлиенту КАК ДокЗаказ
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПродажаДоставка КАК ВТ_ПродажаДоставка
		|				ПО ДокЗаказ.Ссылка = ВТ_ПродажаДоставка.ЗаказНаДоставку
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ОбъектыДоставки КАК ОбъектыДоставки
		|				ПО ДокЗаказ.ОбъектДоставки = ОбъектыДоставки.Ссылка
		|		ГДЕ
		|			ОбъектыДоставки.Маркетплейс <> """"
		|			И ВТ_ПродажаДоставка.СведениеМаркетплейс = ОбъектыДоставки.Маркетплейс
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		
		|		ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			РаспоряженияИСостояния.Документ КАК Документ,
		|			РаспоряженияИСостояния.Получатель КАК Получатель,
		|			ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) КАК ТипДокумента,
		|			0 КАК ИндексКартинки,
		|			РаспоряженияИСостояния.Секция КАК Секция,
		|			ВЫБОР
		|				КОГДА ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка ЕСТЬ NULL
		|					ТОГДА ЗаданиеНаПеревозкуРейсРасчетДоставки_Реализации.Ссылка
		|				ИНАЧЕ ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка
		|			КОНЕЦ КАК Рейс,
		|			ВЫБОР
		|				КОГДА ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) = ТИП(Документ.РеализацияТоваровУслуг)
		|					ТОГДА ВЫБОР
		|							КОГДА РаспоряженияИСостояния.Документ.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
		|								ТОГДА ЛОЖЬ
		|							ИНАЧЕ ИСТИНА
		|						КОНЕЦ
		|				ИНАЧЕ ВЫБОР
		|						КОГДА ТИПЗНАЧЕНИЯ(РаспоряженияИСостояния.Документ) = ТИП(Документ.ЧекККМ)
		|							ТОГДА ВЫБОР
		|									КОГДА РаспоряженияИСостояния.Документ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
		|										ТОГДА ИСТИНА
		|									ИНАЧЕ ЛОЖЬ
		|								КОНЕЦ
		|						ИНАЧЕ ИСТИНА
		|					КОНЕЦ
		|			КОНЕЦ КАК ОтметкаКассы,
		|			ВЫБОР
		|				КОГДА РаспоряженияИСостояния.КОтгрузке = 0
		|						И РаспоряженияИСостояния.ЕстьОрдер = ИСТИНА
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК Отгружен,
		|			ВЫБОР
		|				КОГДА РаспоряженияИСостояния.КОтгрузке > 0
		|		//				И РаспоряженияИСостояния.КСборке = 0
		|		//				И РаспоряженияИСостояния.Собрано = 0
		|		//				И РаспоряженияИСостояния.Собирается = 0
		|						И РаспоряженияИСостояния.ЕстьОрдер = ИСТИНА
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК ЧастичноОтгружен,
		|			ВЫБОР
		|				КОГДА РаспоряженияИСостояния.Собирается > 0
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК Набирается,
		|			ВЫБОР
		|				КОГДА РаспоряженияИСостояния.Собрано > 0
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК Набран,
		|			ВЫБОР
		|				КОГДА РаспоряженияИСостояния.ЕстьОрдер = ЛОЖЬ
		|						ИЛИ РаспоряженияИСостояния.ЕстьОрдер = ИСТИНА
		|							И РаспоряженияИСостояния.КСборке > 0
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК ОжидаетсяОтбор,
		|			ЕСТЬNULL(ПерепоставкаИтоговый.Перепоставка, ЛОЖЬ) КАК Перепоставка,
		|			ВЫБОР
		|				КОГДА не ПродажиМаркетплейс.Маркетплейс есть null
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ КАК ПродажаМаркетплейс
		|		ПОМЕСТИТЬ Итоговый
		|		ИЗ
		|			РаспоряженияИСостояния КАК РаспоряженияИСостояния
		|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
		|				ПО РаспоряженияИСостояния.Документ = ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи
		|					И (ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.Проведен = ИСТИНА)
		|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки_Реализации
		|				ПО РаспоряженияИСостояния.Документ.ЗаказКлиента = ЗаданиеНаПеревозкуРейсРасчетДоставки_Реализации.ДокументПродажи
		|					И (ЗаданиеНаПеревозкуРейсРасчетДоставки_Реализации.Ссылка.Проведен = ИСТИНА)
		|				ЛЕВОЕ СОЕДИНЕНИЕ ПерепоставкаИтоговый КАК ПерепоставкаИтоговый
		|				ПО РаспоряженияИСостояния.Документ = ПерепоставкаИтоговый.Документ
		|					И РаспоряженияИСостояния.Секция = ПерепоставкаИтоговый.Секция
		|				ЛЕВОЕ соединение ПродажиМаркетплейс как ПродажиМаркетплейс
		|				по РаспоряженияИСостояния.Документ = ПродажиМаркетплейс.Реализация
		|		;
		|		
		|		////////////////////////////////////////////////////////////////////////////////
		|		ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			Итоговый.Документ КАК Документ,
		|			Итоговый.Документ.Номер КАК Номер,
		|			Итоговый.Документ.Дата КАК Дата,
		|			Итоговый.Получатель КАК Получатель,
		|			Итоговый.ТипДокумента КАК ТипДокумента,
		|			Итоговый.ИндексКартинки КАК ИндексКартинки,
		|			Итоговый.Секция КАК Секция,
		|			Итоговый.Рейс КАК Рейс,
		|			Итоговый.ОтметкаКассы КАК ОтметкаКассы,
		|			Итоговый.Отгружен КАК Отгружен,
		|			Итоговый.ЧастичноОтгружен КАК ЧастичноОтгружен,
		|			Итоговый.Набирается КАК Набирается,
		|			Итоговый.Набран КАК Набран,
		|			Итоговый.ОжидаетсяОтбор КАК ОжидаетсяОтбор,
		|			Итоговый.Перепоставка КАК Перепоставка,
		|			Итоговый.ПродажаМаркетплейс как Маркетплейс
		|		ИЗ
		|			Итоговый КАК Итоговый 
		|		ГДЕ
		|			&Условие		
		|		УПОРЯДОЧИТЬ ПО
		|			Дата,
		|			Номер,
		|			ТипДокумента";

КонецФункции 

Функция ПолучитьТекстЗапросаПослеНачалаДействияОтгрузкиПоНакладным()  
	//НОВАЯ ДАТА	
	Возврат  "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТоварыКОтгрузкеПоНакладным.Регистратор КАК Документ,
		|	ТоварыКОтгрузкеПоНакладным.Получатель КАК Получатель,
		|	ТоварыКОтгрузкеПоНакладным.Накладная КАК ДокументОтгрузки,
		|	ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток, ЗНАЧЕНИЕ(Справочник.РабочиеУчастки.ПустаяСсылка)) КАК Секция
		|ПОМЕСТИТЬ Накладные
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузкеПоНакладным КАК ТоварыКОтгрузкеПоНакладным
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО ТоварыКОтгрузкеПоНакладным.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И ТоварыКОтгрузкеПоНакладным.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|ГДЕ
		|	ТоварыКОтгрузкеПоНакладным.Склад = &Склад
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В(&РабочиеУчастки)
		|	И ВЫБОР
		|			КОГДА &ИспользоватьОтборПоДате
		|				ТОГДА ТоварыКОтгрузкеПоНакладным.Период >= &Период
		|			ИНАЧЕ ТоварыКОтгрузкеПоНакладным.Период МЕЖДУ &Дата1 И &Дата2
		|		КОНЕЦ
		|	И НЕ(ТоварыКОтгрузкеПоНакладным.Регистратор ССЫЛКА Документ.РасходныйОрдерНаТовары
		|				ИЛИ ТоварыКОтгрузкеПоНакладным.Регистратор ССЫЛКА Документ.АктОРасхожденияхПослеПеремещения)
		|	И ВЫБОР
		|			КОГДА НЕ &Номер = """"
		|				ТОГДА ТоварыКОтгрузкеПоНакладным.Регистратор.Номер ПОДОБНО ""%"" + &Номер + ""%""
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКОтгрузкеПоНакладным.Регистратор,
		|	ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток, ЗНАЧЕНИЕ(Справочник.РабочиеУчастки.ПустаяСсылка)),
		|	ТоварыКОтгрузкеПоНакладным.Получатель,
		|	ТоварыКОтгрузкеПоНакладным.Накладная
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыПоРаспоряжениям.Ссылка КАК Ордер,
