#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&НаСервере
Функция ПолучитьСписокРабочихУчастковСотрудника(Сотрудник) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ 
					|	РабочиеУчасткиСотрудника.РабочийУчасток
					|ИЗ
					|	Справочник.Сотрудники.РабочиеУчастки КАК РабочиеУчасткиСотрудника
					|ГДЕ
					|	РабочиеУчасткиСотрудника.Ссылка = &Сотрудник
					|	И РабочиеУчасткиСотрудника.РабочийУчасток.ПометкаУдаления = Ложь";
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Выборка = Запрос.Выполнить().Выбрать();
	
	ДоступныеРабочиеУчастки = Новый Массив();
	
	Пока Выборка.Следующий() Цикл
		ДоступныеРабочиеУчастки.Добавить(Выборка.РабочийУчасток);	
	КонецЦикла;
	
	Возврат ДоступныеРабочиеУчастки;
	
КонецФункции

&НаСервере
Функция ДоступнаЯчейкаСотруднику(Сотрудник, Ячейка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ Ячейки.Ссылка
		|ИЗ 
		|	Справочник.Сотрудники.РабочиеУчастки КАК РабочиеУчасткиСотрудника
		|	СОЕДИНЕНИЕ 
		|		Справочник.СкладскиеЯчейки КАК Ячейки
		|	ПО РабочиеУчасткиСотрудника.РабочийУчасток = Ячейки.РабочийУчасток
		|ГДЕ 
		|	РабочиеУчасткиСотрудника.Ссылка = &Сотрудник
		|	И Ячейки.Ссылка = &Ячейка";	
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Ячейка", Ячейка);
	
	Если Запрос.Выполнить().Пустой() Тогда
		Возврат Ложь
	Иначе
		Возврат Истина
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПолучитьНоменклатуруИзЯчейки(Склад, Ячейка, ДатаОстатков) Экспорт
	Товары.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	РазмещениеПоЯчейкам.Номенклатура КАК Номенклатура,
		|	РазмещениеПоЯчейкам.Склад КАК Склад
		|ПОМЕСТИТЬ
		|	втНоменклатураВЯчейках
		|ИЗ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеПоЯчейкам
		|ГДЕ
		|	РазмещениеПоЯчейкам.Склад = &Склад
		|	И РазмещениеПоЯчейкам.Ячейка = &Ячейка
		|	И РазмещениеПоЯчейкам.ОсновнаяЯчейка = ИСТИНА
		|;
		|
		|ВЫБРАТЬ
		|	втНоменклатураВЯчейках.Номенклатура КАК Номенклатура
		|	ИЗ
		|	втНоменклатураВЯчейках
		|	СОЕДИНЕНИЕ
		|		РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОстатков, Склад = &Склад И Номенклатура В
		|			(ВЫБРАТЬ Номенклатура ИЗ втНоменклатураВЯчейках)) КАК ОстаткиНоменклатуры
		|		ПО
		|			втНоменклатураВЯчейках.Номенклатура = ОстаткиНоменклатуры.Номенклатура
		|			И втНоменклатураВЯчейках.Склад = ОстаткиНоменклатуры.Склад
		|СГРУППИРОВАТЬ ПО
		|	втНоменклатураВЯчейках.Номенклатура
		|ИМЕЮЩИЕ СУММА(ОстаткиНоменклатуры.ВНаличииОстаток) > 0	
		|УПОРЯДОЧИТЬ ПО втНоменклатураВЯчейках.Номенклатура.Наименование";		
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Ячейка", Ячейка);
	Запрос.УстановитьПараметр("ДатаОстатков", ДатаОстатков);
	
	СписокНоменклатуры = Запрос.Выполнить().Выгрузить();	
	
	Возврат СписокНоменклатуры;
	
КонецФункции

Функция ПолучитьЯчейкуНоменклатуры(Склад, Номенклатура, ОсновнаяЯчейка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ Ячейка
		|ИЗ 
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам
		|ГДЕ Склад = &Склад
		|И Номенклатура = &Номенклатура
		|И ОсновнаяЯчейка = &ОсновнаяЯчейка";	
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ОсновнаяЯчейка", ОсновнаяЯчейка);
	
	Выборка = Запрос.Выполнить().Выбрать();	
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ячейка
	Иначе
		Возврат Справочники.СкладскиеЯчейки.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции

Функция ПолучитьНоменклатуруПоШтрихкоду(Штрихкод, Склад, Ячейка, ЕстьОсновнаяЯчейка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ 
		|	Штрихкоды.Номенклатура, 
		|	ЕстьNULL(Ячейки.ОсновнаяЯчейка, Ложь) ЕстьОсновнаяЯчейка
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
		|ЛЕВОЕ СОЕДИНЕНИЕ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам Ячейки
		|	ПО Штрихкоды.Номенклатура = Ячейки.Номенклатура
		|	И Ячейки.ОсновнаяЯчейка = Истина
		|	И Ячейки.Склад = &Склад
		|	И Ячейки.Ячейка = &Ячейка
		|ГДЕ Штрихкоды.Штрихкод = &Штрихкод";	
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Ячейка", Ячейка);
	
	Результат = Справочники.Номенклатура.ПустаяСсылка();
	Выборка = Запрос.Выполнить().Выбрать();
	
	ЕстьОсновнаяЯчейка = Ложь;
	Если Выборка.Количество() > 0 Тогда
		Если Выборка.Следующий() Тогда
			Результат = Выборка.Номенклатура;
			ЕстьОсновнаяЯчейка = Выборка.ЕстьОсновнаяЯчейка; 
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция ЕстьОсновнаяЯчейкаУНоменклатуры(Номенклатура, Склад, Ячейка) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ 
		|	ЕстьNULL(ОсновнаяЯчейка, Ложь) ЕстьОсновнаяЯчейка
		|ИЗ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам 
		|ГДЕ Номенклатура = &Номенклатура
		|	И ОсновнаяЯчейка = Истина
		|	И Склад = &Склад
		|	И Ячейка = &Ячейка";	
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Ячейка", Ячейка);

	Выборка = Запрос.Выполнить().Выбрать();
	
	Результат = Ложь;
	Если Выборка.Количество() > 0 Тогда
		Если Выборка.Следующий() Тогда
			Результат = Выборка.ЕстьОсновнаяЯчейка; 
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция ПроверитьРазмещениеНоменклатурыВЯчейках(ТаблицаТовары)Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ТаблицаТовары.НомерСтроки,
		|	ТаблицаТовары.Номенклатура,
		|	ТаблицаТовары.ИсходнаяЯчейка,				
		|	ТаблицаТовары.ЦелеваяЯчейка	
		|ПОМЕСТИТЬ Товары
		|ИЗ
		|	&ТаблицаТовары КАК ТаблицаТовары
		|;
		|
		|ВЫБРАТЬ 
		|	Товары.НомерСтроки,
		|	Товары.Номенклатура,
		|	Товары.ИсходнаяЯчейка,
		|	Товары.ЦелеваяЯчейка,
		|	НомеклатураВЯчейках.Ячейка КАК ТекущаяЯчейка
		|ИЗ
		|	Товары
		|	ЛЕВОЕ СОЕДИНЕНИЕ 
		|		РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК НомеклатураВЯчейках
		|	ПО
		|		Товары.Номенклатура = НомеклатураВЯчейках.Номенклатура 
		|		И Товары.ИсходнаяЯчейка = НомеклатураВЯчейках.Ячейка
		|		И НомеклатураВЯчейках.ОсновнаяЯчейка = ИСТИНА
		|ГДЕ Товары.ИсходнаяЯчейка <> ЗНАЧЕНИЕ(Справочник.СкладскиеЯчейки.ПустаяССылка)
		|	И НомеклатураВЯчейках.Номенклатура ЕСТЬ NULL 	
		|	
		|ОБЪЕДИНИТЬ ВСЕ	
		|
		|ВЫБРАТЬ 
		|	Товары.НомерСтроки,
		|	Товары.Номенклатура,
		|	Товары.ИсходнаяЯчейка,
		|	Товары.ЦелеваяЯчейка,
		|	НомеклатураВЯчейках.Ячейка КАК ТекущаяЯчейка
		|ИЗ
		|	Товары
		|	ЛЕВОЕ СОЕДИНЕНИЕ 
		|		РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК НомеклатураВЯчейках
		|	ПО
		|		Товары.Номенклатура = НомеклатураВЯчейках.Номенклатура 
		|		И Товары.ЦелеваяЯчейка = НомеклатураВЯчейках.Ячейка
		|		И НомеклатураВЯчейках.ОсновнаяЯчейка = ИСТИНА
		|ГДЕ Товары.ИсходнаяЯчейка = ЗНАЧЕНИЕ(Справочник.СкладскиеЯчейки.ПустаяССылка)
		|	И НомеклатураВЯчейках.Номенклатура ЕСТЬ NOT NULL 		
		|	
		|УПОРЯДОЧИТЬ ПО 1";
	
	Запрос.УстановитьПараметр("ТаблицаТовары", ТаблицаТовары);
	СписокНоменклатуры = Запрос.Выполнить().Выгрузить();	
	
	Возврат СписокНоменклатуры;
КонецФункции

&НаСервере
Функция ЗаписатьРезультатыПроверкиАХ(ТекстСообщения, ПолеСообщения)Экспорт
	Результат = Ложь;	
	ТекстСообщения = "";
	ПолеСообщения = "";
	
	Если Не ЗначениеЗаполнено(Склад) Тогда
		ТекстСообщения = "Не выбран склад";
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ячейка) Тогда
		ТекстСообщения = "Не выбрана ячейка";
		Возврат Результат;
	КонецЕсли;	
	
	Если Товары.Количество() = 0 Тогда
		ТекстСообщения = "Отсутствуют товары";
		Возврат Результат;
	КонецЕсли;
	
	
	Для Каждого Строка Из Товары Цикл
		Если Не ЗначениеЗаполнено(Строка.Номенклатура) Тогда 
    		ТекстСообщения = "Отсутствует номенклатура в строке " + Строка(Строка.НомерСтроки);
    		ПолеСообщения = "Объект.Товары["+(Строка.НомерСтроки - 1)+"].Номенклатура";
			Возврат Результат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Строка.ЦелеваяЯчейка) Тогда 
    		ТекстСообщения = "Отсутствует фактическая ячейка в строке " + Строка(Строка.НомерСтроки);
    		ПолеСообщения = "Объект.Товары["+(Строка.НомерСтроки - 1)+"].ЦелеваяЯчейка";
			Возврат Результат;
		КонецЕсли;
	КонецЦикла;
	
	
	ТаблицаЗначенийТовары = Товары.Выгрузить();
	СписокОшибочныхСтрок = ПроверитьРазмещениеНоменклатурыВЯчейках(ТаблицаЗначенийТовары);

	Если СписокОшибочныхСтрок.Количество() > 0 Тогда
		Если Не ЗначениеЗаполнено(СписокОшибочныхСтрок[0].ТекущаяЯчейка) Тогда
    		ТекстСообщения = "Номенклатура """ + СписокОшибочныхСтрок[0].Номенклатура + """ не находится в ячейке " + СписокОшибочныхСтрок[0].ИсходнаяЯчейка;
    		ПолеСообщения = "Объект.Товары["+(СписокОшибочныхСтрок[0].НомерСтроки - 1)+"].Номенклатура";
		Иначе
    		ТекстСообщения = "Номенклатура """ + СписокОшибочныхСтрок[0].Номенклатура + """ уже находится в ячейке " + СписокОшибочныхСтрок[0].ИсходнаяЯчейка;
    		ПолеСообщения = "Объект.Товары["+(СписокОшибочныхСтрок[0].НомерСтроки - 1)+"].Номенклатура";
		КонецЕсли;
		
		Возврат Результат;
	КонецЕсли;	

	УстановитьПривилегированныйРежим(Истина);
	НачатьТранзакцию();
	
	Попытка
		ДатаПроверкиАХ = ТекущаяДата();
		ТекущаяЯчейка = Справочники.СкладскиеЯчейки.ПустаяСсылка();
		
		Для Каждого СтрокаТовара Из Товары Цикл 
			
			Если СтрокаТовара.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения.ПрисвоитьТекущуюЯчейку Тогда
				ТекущаяЯчейка = ПолучитьЯчейкуНоменклатуры(Склад, СтрокаТовара.Номенклатура, Истина);
			КонецЕсли;
			
			НаборЗаписей = РегистрыСведений.СобытияПроверкиАдресногоХранения.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Период.Установить(ДатаПроверкиАХ);
			НаборЗаписей.Отбор.Склад.Установить(Склад);
			НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТовара.Номенклатура);
			Если СтрокаТовара.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения.ПрисвоитьТекущуюЯчейку Тогда
				НаборЗаписей.Отбор.ИсходнаяЯчейка.Установить(ТекущаяЯчейка)
			Иначе
				НаборЗаписей.Отбор.ИсходнаяЯчейка.Установить(СтрокаТовара.ИсходнаяЯчейка); 
			КонецЕсли;
			НаборЗаписей.Отбор.ЦелеваяЯчейка.Установить(СтрокаТовара.ЦелеваяЯчейка);
						
			НоваяЗапись= НаборЗаписей.Добавить(); 
	      	НоваяЗапись.Период = ДатаПроверкиАХ; 
	   		НоваяЗапись.Номенклатура = СтрокаТовара.Номенклатура; 
			НоваяЗапись.Склад = Склад; 
			НоваяЗапись.Сотрудник = Сотрудник; 
			Если СтрокаТовара.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения.ПрисвоитьТекущуюЯчейку Тогда
				НоваяЗапись.ИсходнаяЯчейка = ТекущаяЯчейка
			Иначе
				НоваяЗапись.ИсходнаяЯчейка = СтрокаТовара.ИсходнаяЯчейка; 
			КонецЕсли;
			НоваяЗапись.ЦелеваяЯчейка = СтрокаТовара.ЦелеваяЯчейка; 
			НоваяЗапись.Проверено = СтрокаТовара.Проверено; 
			НоваяЗапись.Действие = СтрокаТовара.Действие; 
			НоваяЗапись.НетЭтикетки = СтрокаТовара.НетЭтикетки; 
			НаборЗаписей.Записать();
			
			Если СтрокаТовара.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения.ПереложитьВДругуюЯчейку Тогда
				НаборЗаписей = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Склад.Установить(Склад);				
				НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТовара.Номенклатура);
				НаборЗаписей.Отбор.Ячейка.Установить(Ячейка);				
				НаборЗаписей.Записать(); 
				
				МенеджерЗаписи = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Склад = Склад;
				МенеджерЗаписи.Ячейка = СтрокаТовара.ЦелеваяЯчейка;
				МенеджерЗаписи.Номенклатура = СтрокаТовара.Номенклатура;
				МенеджерЗаписи.ОсновнаяЯчейка = Истина;
				МенеджерЗаписи.Записать();	
				
			ИначеЕсли СтрокаТовара.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения.СделатьЯчейкуДополнительной Тогда
				
				ДополнительнаяЯчейка = ПолучитьЯчейкуНоменклатуры(Склад, СтрокаТовара.Номенклатура, Ложь);
				Пока ДополнительнаяЯчейка <> Справочники.СкладскиеЯчейки.ПустаяСсылка() Цикл
					НаборЗаписей = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей();
					НаборЗаписей.Отбор.Склад.Установить(Склад);				
					НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТовара.Номенклатура);
					НаборЗаписей.Отбор.Ячейка.Установить(ДополнительнаяЯчейка);				
					НаборЗаписей.Записать(); 
					ДополнительнаяЯчейка = ПолучитьЯчейкуНоменклатуры(Склад, СтрокаТовара.Номенклатура, Ложь);
				КонецЦикла;
				
				МенеджерЗаписи = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Склад = Склад;
				МенеджерЗаписи.Ячейка = СтрокаТовара.ЦелеваяЯчейка;
				МенеджерЗаписи.Номенклатура = СтрокаТовара.Номенклатура;
				МенеджерЗаписи.ОсновнаяЯчейка = Ложь;
				МенеджерЗаписи.Записать();				
				
			ИначеЕсли СтрокаТовара.Действие = Перечисления.ДействияПриПроверкеАдресногоХранения.ПрисвоитьТекущуюЯчейку Тогда
				НаборЗаписей = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Склад.Установить(Склад);				
				НаборЗаписей.Отбор.Номенклатура.Установить(СтрокаТовара.Номенклатура);
				НаборЗаписей.Отбор.Ячейка.Установить(ТекущаяЯчейка);				
				НаборЗаписей.Записать(); 
				
				МенеджерЗаписи = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьМенеджерЗаписи();
				МенеджерЗаписи.Склад = Склад;
				МенеджерЗаписи.Ячейка = СтрокаТовара.ЦелеваяЯчейка;
				МенеджерЗаписи.Номенклатура = СтрокаТовара.Номенклатура;
				МенеджерЗаписи.ОсновнаяЯчейка = Истина;
				МенеджерЗаписи.Записать();				
			КонецЕсли;
			
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		
		ТекстСообщения = "Данные о хранении номенклатуры в ячейках записаны";
		Результат = Истина;
		
	Исключение
		ОтменитьТранзакцию();	
		
		ТекстСообщения = "Ошибка при записи в регистры: " + ИнформацияОбОшибке().Описание;
		Результат = Ложь;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Результат;
	
КонецФункции

 #КонецЕсли   
