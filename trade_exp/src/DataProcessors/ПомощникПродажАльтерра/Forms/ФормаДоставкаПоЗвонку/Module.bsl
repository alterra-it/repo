
&НаКлиенте
Процедура ФормаОплатыПриИзменении(Элемент)
	Если ФормаОплаты = "Наличная" Тогда
		Элементы.СуммаСдачи.Видимость = Истина;
	Иначе
		Элементы.СуммаСдачи.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВПП(Команда)
	Если ФормаОплаты <> "" Тогда
		ПараметрыСФормы = Новый Структура("ФормаОплаты, СуммаСдачи", ФормаОплаты, СуммаСдачи);
		Закрыть(ПараметрыСФормы);
	Иначе
		Сообщить("Выберите форму оплаты");
	КонецЕсли;
КонецПроцедуры
