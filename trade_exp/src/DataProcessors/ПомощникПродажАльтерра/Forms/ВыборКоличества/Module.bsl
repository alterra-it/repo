&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ПараметрыТовара") Тогда
		ПараметрыТовара=Параметры.ПараметрыТовара;
		Номенклатура = Параметры.ПараметрыТовара.Номенклатура;
	иначеЕсли Параметры.Свойство("Номенклатура") Тогда
		Номенклатура = Параметры.Номенклатура;
	конецесли;	
		Попытка
			ПрисоединенныйФайл = ФайлКартинкиНоменклатуры(Номенклатура);
			АдресКартинки = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл, ЭтотОбъект.УникальныйИдентификатор).СсылкаНаДвоичныеДанныеФайла;
		Исключение
			Элементы.ГруппаКартинка.Видимость = Ложь;
			Элементы.ГруппаКартинкаОтсутствует.Видимость = Истина;
		КонецПопытки;
		

	Количество= 1;
КонецПроцедуры

&НаКлиенте
Процедура Ок(Команда)
	ПередатьДанные();
КонецПроцедуры

&НаКлиенте
Процедура КоличествоПриИзменении(Элемент)
	ПодключитьОбработчикОжидания("ПередатьДанные", 0.1, Истина)
//ПередатьДанные();
КонецПроцедуры

&НаКлиенте
Процедура ПередатьДанные()
	Если Не ТекущийЭлемент.Имя = "Замечание" Тогда
		Данные= Новый Структура;
		Данные.Вставить("Количество", Количество);
		если ПараметрыТовара<>неопределено тогда
			Данные.Вставить("ПараметрыТовара", ПараметрыТовара);
		конецесли;
		Закрыть(Данные);
	КонецЕсли; 
КонецПроцедуры


&НаКлиенте
Процедура АдресКартинкиНажатие(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ПросмотретьИзображение();

КонецПроцедуры

&НаКлиенте
Процедура ПросмотретьИзображение()
	
	ТекстСообщения = НСтр("ru='Отсутствует изображение для просмотра.'");
	
	Если Не ЗначениеЗаполнено(АдресКартинки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		
		ПрисоединенныйФайл = ФайлКартинкиНоменклатуры(Номенклатура);
		
		Если ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда
			РаботаСФайламиКлиент.ОткрытьФайл(
				РаботаСФайламиСлужебныйВызовСервера.ПолучитьДанныеФайла(ПрисоединенныйФайл, ЭтотОбъект.УникальныйИдентификатор));
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ФайлКартинкиНоменклатуры(Номенклатура)
	
	ФайлКартинки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ФайлКартинки");
	
	Возврат ФайлКартинки;
	
КонецФункции

&НаСервере
Процедура ОтправитьСообщениеОЗаменеКартинки(ТекстСообщения)
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		АвторЗамечания  = ПользователиКлиентСервер.ТекущийПользователь();
		ДопМодуль.ОтправитьСообщениеОЗаменеКартинки(ТекстСообщения, Номенклатура, Замечание, АвторЗамечания);	
	КонецЕсли; 

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщение(Команда)
	ОтправитьСообщениеОЗаменеКартинки("У номенклатуры отсутствует изображение - ");
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьСообщениеЗаменаИзображения(Команда)   
	Если Не ЗначениеЗаполнено(Замечание) Тогда     
		АльтерраОбщегоНазначения.СообщитьПользователю( , "Необходимо заполнить 'Текст замечания'!");
		Возврат;
	КонецЕсли;
	ОтправитьСообщениеОЗаменеКартинки("Замените изображение у номенклатуры - "); 
	
КонецПроцедуры
