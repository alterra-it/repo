&НаКлиенте
Процедура КомплектующиеХарактеристикаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	ТекСтрока = Элементы.Комплектующие.ТекущиеДанные;

	МассивХарактеристик = СписокХарактеристикКомплектующие(ТекСтрока.Номенклатура,Склад);
	СписокХарактеристик1 = Новый СписокЗначений;
	СписокХарактеристик1.ЗагрузитьЗначения(МассивХарактеристик);
	
	СтандартнаяОбработка = Ложь;    
    Форма = ПолучитьФорму("Справочник.ХарактеристикиНоменклатуры.ФормаВыбора",, Элемент);
    ЭлементОтбора = Форма.Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
