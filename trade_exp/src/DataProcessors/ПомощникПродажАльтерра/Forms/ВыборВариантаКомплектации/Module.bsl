    ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
    ЭлементОтбора.Использование = Истина;
    ЭлементОтбора.ПравоеЗначение = СписокХарактеристик1;  
    Форма.Открыть();
КонецПроцедуры

&НаСервере
Функция СписокХарактеристикКомплектующие(Номенклатура,Склад)
	УстановитьПривилегированныйРежим(Истина);
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ХарактеристикиНоменклатуры.Владелец КАК Номенклатура,
	|	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
	|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
	|	ХарактеристикиНоменклатуры.Владелец.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ХарактеристикиНоменклатуры.ПометкаУдаления КАК ПометкаУдаления,
	|	&Склад КАК Склад,
	|	ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток, 0) КАК Остаток,
	|	ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) - ЕСТЬNULL(ТоварыКОтгрузкеОстатки.ВРезервеОстаток, 0) КАК Доступно,
	|	ИСТИНА КАК ХарактеристикиИспользуются,
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка) КАК ВариантРасчетаЦеныНабора,
	|	ЛОЖЬ КАК СодержитТовары,
	|	ЛОЖЬ КАК СодержитУслуги
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
	|			ЗапасыИПотребностиОстатки.ВНаличииОстаток КАК ВНаличии
	|		ИЗ
	|			РегистрНакопления.ЗапасыИПотребности.Остатки(
	|					,
	|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки) КАК РаспределениеЗапасов
	|		ПО ХарактеристикиНоменклатуры.Владелец = РаспределениеЗапасов.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = РаспределениеЗапасов.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &Склад) КАК ТоварыКОтгрузкеОстатки
	|		ПО ХарактеристикиНоменклатуры.Владелец = ТоварыКОтгрузкеОстатки.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = ТоварыКОтгрузкеОстатки.Характеристика
	|ГДЕ
	|	ХарактеристикиНоменклатуры.Владелец = &Владелец
	|	И ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) - ЕСТЬNULL(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток, 0) > 0";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	РезультатЗапроса = Новый ТаблицаЗначений;
	ТЗ = Запрос.Выполнить().Выгрузить();
	УстановитьПривилегированныйРежим(Ложь);
	Возврат ТЗ.ВыгрузитьКолонку("Характеристика");
	
КонецФункции

&НаКлиенте
Процедура КомплектующиеХарактеристикаПриИзменении(Элемент)
	ТекСтрока = Элементы.Комплектующие.ТекущиеДанные;
	ТекущаяСтрока = Элементы.Комплект.ТекущиеДанные;
	ТекСтрока.Остаток = ПолучитьОстатокКомплектующие(ТекСтрока.Номенклатура,Склад,ТекСтрока.Характеристика);
	КратностьКомплектующей = ПолучитьКратностьКомплектующей(ТекСтрока.Характеристика);
	ТекСтрока.Кратность = КратностьКомплектующей;
    ТекСтрока.МожноСобрать = ТекСтрока.Остаток;
	ТекущаяСтрока.КоличествоВариант = ТекСтрока.Кратность;  
	ВариантыКомплектации[0].МожноСобрать = ТекСтрока.МожноСобрать;
	ХарактеристикаКомплектующейИзменена = Истина;
	ХарактеристикаКомплектующей = ТекСтрока.Характеристика;
	ОчиститьСообщения(); 
	Если ИспользоватьХарактеристики(Номенклатура) и Не ЗначениеЗаполнено(Комплект[0].Характеристика) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Выберете характеристику у номенклатуры комплекта!", , "Комплект[0].Характеристика",,Истина);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьОстатокКомплектующие(Номенклатура,Склад,Характеристика)
	УстановитьПривилегированныйРежим(Истина);
	Запрос= Новый Запрос;
	Запрос.Текст=
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА Остатки.ВНаличииОстаток - Остатки.РезервироватьНаСкладеОстаток - Остатки.РезервироватьПоМереПоступленияОстаток < 0
		|			ТОГДА 0
		|		ИНАЧЕ Остатки.ВНаличииОстаток - Остатки.РезервироватьНаСкладеОстаток - Остатки.РезервироватьПоМереПоступленияОстаток
		|	КОНЕЦ КАК Остаток
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(, Склад = &Склад и Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)) КАК Остатки
		|ГДЕ
		|	Остатки.Номенклатура = &Номенклатура
		|	И Остатки.Характеристика = &Характеристика
		|	И Остатки.Склад = &Склад";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Остаток;

КонецФункции

&НаСервере
Функция ПолучитьКратностьКомплектующей(Характеристика)
	МассивПодстрок = СтрРазделить(Характеристика, " ", Ложь);
	Для Каждого Подстрока Из МассивПодстрок Цикл
		ПодстрокаБезЗапятых = СтрЗаменить(Подстрока, ",", ".");
	    Попытка
			ДробноеЧисло = Число(ПодстрокаБезЗапятых);
	        Если ТипЗнч(ДробноеЧисло) = Тип("Число") Тогда
				Возврат ДробноеЧисло;
	        КонецЕсли;
		Исключение
	    КонецПопытки;
	КонецЦикла;
	Сообщить("Проверьте правильность написания характеристики!");
	Возврат 0;

КонецФункции

&НаКлиенте
Процедура Собрать(Команда)  
	
	ТЧ = Элементы.Комплект.ТекущиеДанные;	
	
	ВариантыКомплектации[0].Собрать = ТЧ.БудетСобрано;
 	Отношение = ВариантыКомплектации[0].Собрать /ВариантыКомплектации[0].КоличествоКомплект;
	Если Отношение < 1 Тогда
		ВариантыКомплектации[0].ЧислоКомплектов = 1;
	ИначеЕсли  Цел(Отношение)*ВариантыКомплектации[0].КоличествоКомплект  >= ВариантыКомплектации[0].Собрать Тогда
		ВариантыКомплектации[0].ЧислоКомплектов = Отношение; 
	Иначе 
		ВариантыКомплектации[0].ЧислоКомплектов = Цел(Отношение)+1;
	КонецЕсли; 

	ОчиститьСообщения(); 

	Если ИспользоватьХарактеристики(Номенклатура) и Не ЗначениеЗаполнено(ТЧ.Характеристика) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Выберете характеристику у номенклатуры комплекта!", , "Комплект[0].Характеристика",,Истина);
	ИначеЕсли Не ЗначениеЗаполнено(ТЧ.БудетСобрано) Тогда
		Сообщить("В поле ""Нужно собрать"" у комплекта не указано количество");
	Иначе
		ВариантыКомплектации[0].Собрать = ТЧ.БудетСобрано;
		СобратьНаСервере(ВариантыКомплектации[0].ВариантКомплектации, ТЧ.БудетСобрано);  
		ПодключитьОбработчикОжидания("ОбработкаОжидания", 2, Ложь);
	КонецЕсли;

	//ЕСЛИ НУЖНО ОТКРЫВАТЬ ФОРМУ
	//СсылкаНаДокумент = 	СобратьНаСервере(ВариантыКомплектации[0].ВариантКомплектации, ТЧ.БудетСобрано);
	//ОткрытьЗначение(СсылкаНаДокумент);
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОжидания()
	ОтключитьОбработчикОжидания("ОбработкаОжидания"); 
	Закрыть();		
КонецПроцедуры

&НаСервере
Процедура СобратьНаСервере(Ссылка, БудетСобрано) 
	
	КомплектацияСсылка = Ссылка; 
	СборкаТоваров = Документы.СборкаТоваров.СоздатьДокумент();
    	
    СборкаТоваров.Дата = ТекущаяДата();
	СборкаТоваров.ВариантКомплектации = Ссылка;
	СборкаТоваров.Организация = Организация; 
    СборкаТоваров.Склад = Склад;
    СборкаТоваров.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.СборкаТоваров; 
    СборкаТоваров.Номенклатура = Номенклатура;
    СборкаТоваров.Характеристика = Характеристика;
    СборкаТоваров.КоличествоУпаковок = БудетСобрано; 
    СборкаТоваров.Количество = СборкаТоваров.КоличествоУпаковок; 
    СборкаТоваров.Комментарий = "Создан из помощника продаж";
    СборкаТоваров.Заполнить(Новый Структура ("Организация",Организация));
 
    
    СборкаСсылка = СборкаТоваров.Ссылка;
    ЗаполнитьТоварыПоВариантуКомплектации(СборкаТоваров.ЭтотОбъект);
    РуководительСекции = ПолучитьРуководителяСекции();
    Попытка
    	СборкаТоваров.Записать(РежимЗаписиДокумента.Проведение);
    	ОбщегоНазначения.СообщитьПользователю("Создан документ Сборки/Разборки " + СборкаТоваров, СборкаТоваров);
    	Сборка = СборкаТоваров.Ссылка;
		Если ЗначениеЗаполнено(РуководительСекции) Тогда
			АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс("Создан документ Сборки/Разборки " + СборкаТоваров, РуководительСекции);
			Сборка = СборкаТоваров.Ссылка;
		КонецЕсли;	
	Исключение
    	Сообщить("Не удалось создать документ сборки");
    КонецПопытки; 
    
    Если Склад.ИспользоватьОрдернуюСхемуПриОтгрузке Или Склад.ИспользоватьОрдернуюСхемуПриПоступлении Тогда
    	Документы.СборкаТоваров.ОформитьОрдера(СборкаТоваров.Ссылка); 
    КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТоварыПоВариантуКомплектации(СборкаОбъект)
		
	СборкаОбъект.Товары.Загрузить(ПолучитьКомплектующиеНоменклатуры(СборкаОбъект.ВариантКомплектации, , СборкаОбъект.Количество));	
		
	СтруктураДействий = Новый Структура();
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(СборкаОбъект.Товары, СтруктураДействий, Неопределено);  
		
	ПараметрыУказанияСерий = НоменклатураСервер.ПараметрыУказанияСерий(СборкаОбъект, Документы.СборкаТоваров); 
		
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(СборкаОбъект,ПараметрыУказанияСерий.ТЧ);
		
	Если Не ХарактеристикаКомплектующейИзменена Тогда
		Справочники.ВариантыКомплектацииНоменклатуры.ОбновитьКоличествоКомплектующихПоКоличествуКомплектов(
		СборкаОбъект.Товары, СборкаОбъект.Количество, СборкаОбъект.ВариантКомплектации);
	КонецЕсли;
	
КонецПроцедуры
	
&НаСервере
Функция ПолучитьКомплектующиеНоменклатуры(ВариантКомплектации, Упаковка = Неопределено, Количество = 1)

	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА &ХарактеристикаКомплектующейИзменена
	|			ТОГДА &ХарактеристикаКомплектующей
	|		ИНАЧЕ Товары.Характеристика
	|	КОНЕЦ КАК Характеристика,
	|	Товары.Упаковка КАК Упаковка,
	|	&КоличествоКомплектов * Товары.КоличествоУпаковок / Товары.Ссылка.Количество КАК КоличествоУпаковок,
	|	&КоличествоКомплектов * Товары.Количество / Товары.Ссылка.Количество КАК Количество,
	|	Товары.ДоляСтоимости КАК ДоляСтоимости
	|ИЗ
	|	Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Товары.НомерСтроки";
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Ссылка", ВариантКомплектации);
	Запрос.УстановитьПараметр("КоличествоКомплектов", Количество);
	Запрос.УстановитьПараметр("ХарактеристикаКомплектующей", ХарактеристикаКомплектующей);
	Запрос.УстановитьПараметр("ХарактеристикаКомплектующейИзменена", ХарактеристикаКомплектующейИзменена);

	ТаблицаКомплектующих = Запрос.Выполнить().Выгрузить();
	
	Возврат ТаблицаКомплектующих;

КонецФункции

&НаСервере
Функция ПолучитьРуководителяСекции()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура КАК Номенклатура,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад КАК Склад,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК ЯчейкаРабочийУчасток,
		|	РабочиеУчастки.Руководитель КАК Руководитель
		|ИЗ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РабочиеУчастки КАК РабочиеУчастки
		|		ПО РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = РабочиеУчастки.Ссылка
		|ГДЕ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = &Номенклатура
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Руководитель;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

	
КонецФункции






