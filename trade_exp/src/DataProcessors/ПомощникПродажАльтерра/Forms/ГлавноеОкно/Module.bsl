#Область Фильтры
&НаСервере
Процедура ЗаполнитьФильтрыСервер()
  
  Если ПоказыватьФильтры Тогда
  	
  	  ДЗ = РеквизитФормыВЗначение("Фильтры");
	  ДЗ.Строки.Очистить();
	  ЗначениеВРеквизитФормы(ДЗ, "Фильтры");
	  	  
	  ТекущийСписокНоменклатуры = Новый Массив;
	  ТекущийСписокНоменклатуры = ПолучитьТекущийСписокНоменклатуры();

	  Запрос = Новый Запрос;
	  Запрос.Текст =  "ВЫБРАТЬ
	  |	НоменклатураДополнительныеРеквизиты.Свойство КАК Свойство,
	  | 0 КАК Флажок,
	  |	НоменклатураДополнительныеРеквизиты.Значение КАК Значение
	  |ИЗ
	  |	Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	  |	ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения КАК ДополнительныеРеквизитыИСведения
	  |	ПО (НоменклатураДополнительныеРеквизиты.Свойство = ДополнительныеРеквизитыИСведения.Ссылка)
	  |ГДЕ
	  |	НоменклатураДополнительныеРеквизиты.Ссылка В (&Номенклатура)
	  | И НЕ НоменклатураДополнительныеРеквизиты.Значение = НЕОПРЕДЕЛЕНО
	  |И ДополнительныеРеквизитыИСведения.ВключатьВФильтры
	  |СГРУППИРОВАТЬ ПО
	  |	НоменклатураДополнительныеРеквизиты.Свойство,
	  |	НоменклатураДополнительныеРеквизиты.Значение
	  |УПОРЯДОЧИТЬ ПО
	  |	НоменклатураДополнительныеРеквизиты.Свойство.Наименование
	  |ИТОГИ
	  |	Неопределено КАК Значение
	  |ПО
	  |	Свойство";
	  Запрос.УстановитьПараметр("Номенклатура", ТекущийСписокНоменклатуры);	
	  ДеревоФильтров = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	 
	  ЗначениеВРеквизитФормы(ДеревоФильтров, "Фильтры");
  КонецЕсли
   
КонецПроцедуры

&НаСервере
Функция ПолучитьТекущийСписокНоменклатуры()
	
  	  Схема	= Элементы.СписокНоменклатура.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	  Настройки = Элементы.СписокНоменклатура.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	  КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	  МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки, , ,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	  ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	  ПроцессорКомпоновки.Инициализировать(МакетКомпоновки); 
	  ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	  
	  Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);  
	  
	  Возврат Результат.ВыгрузитьКолонку("Номенклатура");
	  
КонецФункции	

&НаКлиенте
Процедура СделатьОтборПоФильтрам(Команда)
	
	СделатьОтборПоФильтрамНаСервере()
	
КонецПроцедуры

&НаСервере
Процедура СделатьОтборПоФильтрамНаСервере()
 
  	ДЗ = РеквизитФормыВЗначение("Фильтры");
 	Отбор = Новый Структура("Флажок", 1);
    МассивВыбранныхФильтров = ДЗ.Строки.НайтиСтроки(Отбор, Истина);
    
 	МассивТипов = Новый Массив;
 	МассивТипов.Добавить(Тип("Строка"));
 	ПараметрыСтроки = Новый КвалификаторыСтроки(250);
 	ПараметрыЧисла  = Новый КвалификаторыЧисла(12,2);
 	МассивТипов.Добавить(Тип("Число"));
 	МассивТипов.Добавить(Тип("СправочникСсылка.ЗначенияСвойствОбъектов"));
 	МассивТипов.Добавить(Тип("Булево"));
 	ТипДопЗначения = Новый ОписаниеТипов(МассивТипов, ПараметрыЧисла, ПараметрыСтроки);
 	ТипДопСвойства = Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.ДополнительныеРеквизитыИСведения");
  	МассивОтбора = Новый ТаблицаЗначений;
 	МассивОтбора.Колонки.Добавить("Свойство", ТипДопСвойства);
 	МассивОтбора.Колонки.Добавить("Значение", ТипДопЗначения);
  	КоличествоФильтров = МассивВыбранныхФильтров.Количество();
  	Если КоличествоФильтров > 0 Тогда
  		Для Каждого ТекущийЭлементМассива Из МассивВыбранныхФильтров Цикл 
  			НоваяСтрока = МассивОтбора.Добавить();
 			НоваяСтрока.Свойство = ТекущийЭлементМассива.Свойство;
   			НоваяСтрока.Значение = ТекущийЭлементМассива.Значение;
  		КонецЦикла;
  		ТЗСвойств = МассивОтбора.Скопировать();
  		ТЗСвойств.Свернуть("Свойство");
		НоменклатураПослеФильтрации = Новый СписокЗначений();
		ТЗНоменклатураПослеФильтрации = Новый ТаблицаЗначений;
		ТЗНоменклатураПослеФильтрации = ПолучитьТекущийСписокНоменклатуры();
		Для Каждого СтрокаСвойств Из ТЗСвойств Цикл
			ОтборПоСвойству = Новый Структура;
    		ОтборПоСвойству.Вставить("Свойство", СтрокаСвойств.Свойство);
    		ТЗТекущееСвойство = МассивОтбора.Скопировать(ОтборПоСвойству);
	  		Запрос = Новый Запрос;
	  		Запрос.Текст = "ВЫБРАТЬ 
	  		|	Номенклатура.Ссылка КАК Номенклатура
	   		|ИЗ
	  		|	Справочник.Номенклатура КАК Номенклатура
	  		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	  		|		ПО (НоменклатураДополнительныеРеквизиты.Ссылка = Номенклатура.Ссылка)
	  		|ГДЕ
	  		|	(НоменклатураДополнительныеРеквизиты.Свойство, НоменклатураДополнительныеРеквизиты.Значение) В (&ТабФильтр)
	  		| 	И Номенклатура.Ссылка В (&Номенклатура)
	  		|";
	  		
			Запрос.УстановитьПараметр("Номенклатура", ТЗНоменклатураПослеФильтрации);
	   		Запрос.УстановитьПараметр("ТабФильтр", ТЗТекущееСвойство);
		    		
	  		РезультатЗапроса = Запрос.Выполнить();
	   		ТЗНоменклатураПослеФильтрации = РезультатЗапроса.Выгрузить();
	  		ТЗНоменклатураПослеФильтрации.Свернуть("Номенклатура");
  		КонецЦикла;
	  	НоменклатураПослеФильтрации = ТЗНоменклатураПослеФильтрации.ВыгрузитьКолонку("Номенклатура");  			
   		Если НоменклатураПослеФильтрации.Количество() > 0 Тогда	
	  		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокНоменклатура,	"Номенклатура",	НоменклатураПослеФильтрации, Истина)
  		Иначе
  			ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокНоменклатура,	"Номенклатура",	Неопределено, Истина)
		КонецЕсли	
	КонецЕсли;
	ЗаполнитьФильтрыСервер()  	

КонецПроцедуры

&НаКлиенте
Процедура ФильтрыПриИзменении(Элемент)
	
	ИДТекущейСтроки = Элемент.ТекущаяСтрока;
	ЭлементКоллекции = ЭтаФорма.Фильтры.НайтиПоИдентификатору(ИДТекущейСтроки);
	Если ЭлементКоллекции.Флажок = 2 Тогда
		ЭлементКоллекции.Флажок = 0;
	КонецЕсли;
	УстановкаФлажков(ЭлементКоллекции, ЭлементКоллекции.Флажок);
	
	Родитель = ЭлементКоллекции.ПолучитьРодителя();
	Пока Родитель <> Неопределено Цикл 	
		Родитель.Флажок = ?(УстановленоДляВсех(ЭлементКоллекции), ЭлементКоллекции.Флажок, 2);
		ЭлементКоллекции = Родитель;
		Родитель = ЭлементКоллекции.ПолучитьРодителя();
	КонецЦикла	
	
КонецПроцедуры

&НаКлиенте
Процедура УстановкаФлажков(ЭлементКоллекции, Значение);
	
	ПодчинЭлементы = ЭлементКоллекции.ПолучитьЭлементы();
	Для Каждого ТекЭлем из  ПодчинЭлементы Цикл
		ТекЭлем.Флажок = Значение;
		УстановкаФлажков(ТекЭлем, ТекЭлем.Флажок);
	КонецЦикла	
	
КонецПроцедуры	

&НаКлиенте
Функция УстановленоДляВсех(ЭлементКоллекции)
	
	ЭлементыГруппы = ЭлементКоллекции.ПолучитьРодителя().ПолучитьЭлементы();
	Для Каждого ТекЭлем из ЭлементыГруппы Цикл
		Если ТекЭлем.Флажок <> ЭлементКоллекции.Флажок Тогда
			Возврат Ложь
		КонецЕсли	
	КонецЦикла;
	Возврат Истина
		
КонецФункции

&НаКлиенте
Процедура СброситьФильтр(Команда)
	СброситьФильтрНаСервере();
КонецПроцедуры

&НаСервере
Процедура СброситьФильтрНаСервере()
	Если ПоказыватьИерархию Тогда
		Если СтрДлина(Элементы.ИерархияНоменклатуры.ВыделенныеСтроки[0]) <> 0 Тогда 
			ИерархияНоменклатурыПриАктивизацииСтрокиСервер(Элементы.ИерархияНоменклатуры.ТекущаяСтрока)
		КонецЕсли; 
	Иначе
		ВыполнитьПоискНоменклатурыНаСервере(СтрокаПоискаНоменклатура);
	КонецЕсли	
КонецПроцедуры

&НаКлиенте
Процедура ОшибкаВКомплектующих(Команда)
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура",ТекущаяСтрокаНоменклатуры.Номенклатура);
	Если Элементы.КомплектующиеТовары.ТекущаяСтрока <> Неопределено Тогда
		ПараметрыФормы.Вставить("КомплектующийТовар", Элементы.КомплектующиеТовары.ТекущиеДанные.Номенклатура);
	КонецЕсли;
	
	ОткрытьФорму("Обработка.ПомощникПродажАльтерра.Форма.ОбработкаСообщенияОЗаменеКомплектующего",ПараметрыФормы,ЭтаФорма, , , , ,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьВсеНеоформленныеДокументы(Команда)
	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		ВходитВСегмент=ПартнерВходитВСегментыЗапретПродажи();
		Если ВходитВСегмент Тогда
			ИнформацияПоПартнеру= "Отгружать только по предоплате";
		Иначе
			ИнформацияПоПартнеру= "";
		КонецЕсли;
		КоличествоДокументов = НезакрытыеЗаказыЧеки.Количество();
		//Заполнение не закрытых заказов по партнеру
		ЗаполнитьНеЗакрытыеЗаказыПоПартнеру(Истина);
		
		Если НезакрытыеЗаказыЧеки.Количество()>0 Тогда
			Элементы.НезакрытыеЗаказыЧекиЗначение.Видимость = Истина;
			Если КоличествоДокументов <= НезакрытыеЗаказыЧеки.Количество() Тогда
				Сообщить("Дополнительных документов не найдено"); 
			КонецЕсли;
		Иначе
			Элементы.НезакрытыеЗаказыЧекиЗначение.Видимость = Ложь;
			Сообщить("У партнёра нет неоформленных документов");
		КонецЕсли;
	Иначе
		ИнформацияПоПартнеру= "";
	КонецЕсли; 
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ВызватьРаспределениеТранспортныхДистрибуция(Команда)
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		 СнятьРаспределениеТранспортныхДистрибуция();
	Иначе
		Если НЕ ЗначениеЗаполнено(Объект.Тариф) Тогда
		    Сообщить("Не определен тариф, транспортные распределены не будут. Выберите объект доставки");
		    Объект.РаспределитьТранспортныеДистрибуция = Ложь;
		    Возврат;
	    КонецЕсли;
		РаспределениеСтоимостиДоставкиДистрибуция(Истина);  
	КонецЕсли;
	Объект.РаспределитьТранспортныеДистрибуция = Не Объект.РаспределитьТранспортныеДистрибуция;
    ДобавитьУбратьВидТовараДляДоставки();	 
	УстановитьВидимостьПоРаспределитьТранспортные();
КонецПроцедуры

