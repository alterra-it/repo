#Область Нехватка
&НаКлиенте
Процедура ДобавитьНехваткуТовараПосле(Команда)
	ПараметрыФормы = Новый Структура;
	ДанныеСтроки=Элементы.СписокНоменклатура.ТекущиеДанные;
	ПараметрыФормы.Вставить("Номенклатура",ДанныеСтроки.Номенклатура );
	ПараметрыФормы.Вставить("Остаток", ДанныеСтроки.Доступно);
	ПараметрыФормы.Вставить("КлассТовара", НЕОПРЕДЕЛЕНО);
	ПараметрыФормы.Вставить("Ликвидность", НЕОПРЕДЕЛЕНО);
	
	ОписаниеОповещения=Новый ОписаниеОповещения("ПослеВыбораКоличестваНехватки", ЭтотОбъект);
	ОткрытьФорму("Обработка.ПодборТоваровВДокументПродажи.Форма.ЗапросКоличестваНехватки",ПараметрыФормы,,,,,ОписаниеОповещения);	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораКоличестваНехватки(Результат,ДопПараметры) Экспорт
	ПослеВыбораКоличестваНехваткиСервер(Результат);
КонецПроцедуры

&НаСервере
Процедура ПослеВыбораКоличестваНехваткиСервер(Результат)
	если Результат<>неопределено тогда
		СтрокаТаблицы=_НехваткаТовара.Добавить();
		заполнитьЗначенияСвойств(СтрокаТаблицы,Результат);
		СтрокаТаблицы.КлассТовара=РегистрыСведений.ABCКлассификацияНоменклатуры_Альтерра.ВернутьКлассТовара(СтрокаТаблицы.Номенклатура,Объект.Подразделение);
		СтрокаТаблицы.Ликвидность=РегистрыСведений.Неликвиды.ВернутьЛиквидностьТовара(СтрокаТаблицы.Номенклатура,Объект.Склад.Подразделение);
		СтрокаТаблицы.Склад=Объект.Склад;
		Элементы.ДекорацияНехваткаИнформация.Заголовок="Количество позиций в нехватке - "+_НехваткаТовара.Количество();
	конецесли;
КонецПроцедуры

&НаКлиенте
Процедура _СоздатьДокументНехватки(Команда)
	
	СоздатьДокументНехваткаНаСервере();
	
КонецПроцедуры
&НаСервере
Процедура СоздатьДокументНехваткаНаСервере()
	УстановитьПривилегированныйРежим(истина);
	если _НехваткаТовара.Количество()=0 тогда
		возврат;
	конецесли;
	НехваткаПоСкладам = РазбитьНехваткуПоСкладам(); 
	Попытка
		ВыборкаСклад = НехваткаПоСкладам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаСклад.Следующий() Цикл
			ДокументНехватки=Документы.НехваткаТовара.СоздатьДокумент();
			ДокументНехватки.Дата=ТекущаяДата();
			ДокументНехватки.Менеджер=Пользователи.ТекущийПользователь();
			ДокументНехватки.Клиент=Объект.Партнер;
			ДокументНехватки.Контрагент=Объект.Контрагент;
			ДокументНехватки.Склад = ВыборкаСклад.Склад;
			
			ВыборкаДетальныеЗаписи = ВыборкаСклад.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Если Строка(ВыборкаДетальныеЗаписи.СпособОбеспеченияПотребностей) <> "Ассортимент ТЗ" Тогда
					Строка = ДокументНехватки.Товары.Добавить();
					Строка.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура;
					Строка.БылоНужно = ВыборкаДетальныеЗаписи.БылоНужно;
					Строка.Остаток = ВыборкаДетальныеЗаписи.Остаток;
					Строка.Нехватка = ВыборкаДетальныеЗаписи.Нехватка;
					Строка.КлассТовара = ВыборкаДетальныеЗаписи.КлассТовара;
					Строка.Ликвидность = ВыборкаДетальныеЗаписи.Ликвидность;
				Иначе
					Сообщить("Номенклатура '"+ВыборкаДетальныеЗаписи.Номенклатура+"' по складу "+ВыборкаСклад.Склад+" не была добавлена в документ нехватки, т.к. способ обеспечения потребностей = 'Ассортимент ТЗ'");
				КонецЕсли;
			КонецЦикла;
			ДокументНехватки.Записать();
			Документы.НехваткаТовара.СоздатьСообщениеВБитрихПоДокументуНехватки(ДокументНехватки);
		КонецЦикла;
		
		_НехваткаТовара.Очистить();
		Элементы.ДекорацияНехваткаИнформация.Заголовок="Количество позиций в нехватке - "+_НехваткаТовара.Количество();
	исключение
		Информация = ИнформацияОбОшибке();
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = КраткоеПредставлениеОшибки(Информация);
		Сообщение.Сообщить();
		ТекстОшибки = ПодробноеПредставлениеОшибки(Информация);
	конецпопытки;	
	УстановитьПривилегированныйРежим(ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Перем ВыполняемаяОперация;
	Если ИсточникВыбора.ИмяФормы = "Обработка.ПодборМногооборотнойТары.Форма.Форма" Тогда
		
		ЗаполнитьМногооборотнуюТаруИзХранилищаСервер(ВыбранноеЗначение.АдресМногооборотнойТарыВХранилище);
		МногооборотнаяТараКлиент.ОповеститьПользователяОЗаполненииМногооборотнойТарой();
		
	конецесли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьМногооборотнуюТаруИзХранилищаСервер(АдресТарыВХранилище)
	
	КэшированныеЗначения    = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	ВариантОформленияДокументов=ПредопределенноеЗначение("Перечисление.ВариантыОформленияПродажи.РеализацияТоваровУслуг");
	
	ИменаПолей = ИменяПолейПодбораМногооборотнойТары(ВариантОформленияДокументов, Истина);
	СтруктураДействийИзмененныеСтроки = Новый Структура;
	СтруктураДействийДобавленныеСтроки = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(
	СтруктураДействийИзмененныеСтроки);
	
	МногооборотнаяТараСервер.ЗаполнитьМногооборотнуюТаруИзХранилища(Объект,
	АдресТарыВХранилище,
	"Товары",
	ИменаПолей,
	СтруктураДействийИзмененныеСтроки,
	СтруктураДействийДобавленныеСтроки,
	КэшированныеЗначения);
	Для Каждого стрТовара Из Объект.Товары Цикл
	//	если стрТовара.КоличествоУпаковок=0 тогда
			стрТовара.КоличествоУпаковок=стрТовара.Количество;
	//	конецесли;	
		ПересчитатьЦеныВСтрокеКорзиныНаСервере(стрТовара);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция РазбитьНехваткуПоСкладам()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаНехватка.Номенклатура КАК Номенклатура,
		|	ТаблицаНехватка.БылоНужно КАК БылоНужно,
		|	ТаблицаНехватка.Остаток КАК Остаток,
		|	ТаблицаНехватка.Нехватка КАК Нехватка,
		|	ТаблицаНехватка.КлассТовара КАК КлассТовара,
		|	ТаблицаНехватка.Ликвидность КАК Ликвидность,
		|	ТаблицаНехватка.Склад КАК Склад
		|ПОМЕСТИТЬ ВТТаблицаНехватка
		|ИЗ
		|	&ТаблицаНехватка КАК ТаблицаНехватка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТаблицаНехватка.Склад КАК Склад,
		|	ВТТаблицаНехватка.Номенклатура КАК Номенклатура,
		|	ВТТаблицаНехватка.БылоНужно КАК БылоНужно,
		|	ВТТаблицаНехватка.Остаток КАК Остаток,
		|	ВТТаблицаНехватка.Нехватка КАК Нехватка,
		|	ВТТаблицаНехватка.КлассТовара КАК КлассТовара,
		|	ВТТаблицаНехватка.Ликвидность КАК Ликвидность,
		|	ВариантыОбеспеченияТоварами.СпособОбеспеченияПотребностей КАК СпособОбеспеченияПотребностей
		|ИЗ
		|	ВТТаблицаНехватка КАК ВТТаблицаНехватка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВариантыОбеспеченияТоварами КАК ВариантыОбеспеченияТоварами
		|		ПО ВТТаблицаНехватка.Склад = ВариантыОбеспеченияТоварами.Склад
		|			И ВТТаблицаНехватка.Номенклатура = ВариантыОбеспеченияТоварами.Номенклатура
		|ИТОГИ ПО
		|	Склад";
	Запрос.УстановитьПараметр("ТаблицаНехватка", _НехваткаТовара.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;
	
КонецФункции 

