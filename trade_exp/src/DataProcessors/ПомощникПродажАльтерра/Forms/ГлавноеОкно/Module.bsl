  УстановитьТарифДистрибуция();
  РаспределениеСтоимостиДоставкиДистрибуция();
  
КонецПроцедуры
 
&НаКлиенте
Процедура ВыбратьОбъектДоставки(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыборОбъектаДоставкиДистрибуцияЗавершение", ЭтаФорма);
	ОткрытьФорму("Справочник.ОбъектыДоставки.Форма.Док_ФормаВыбораКарта", Новый Структура("Владелец",Объект.Партнер), ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ВыборОбъектаДоставкиДистрибуцияЗавершение(ОбъектДоставки, ДопПараметры) Экспорт 
	
	Если НЕ ОбъектДоставки = Неопределено Тогда
		Объект.ОбъектДоставки = ОбъектДоставки; 
		Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы");
		ОбъектДоставкиПриИзменении(Неопределено);
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере
Процедура УстановитьТарифДистрибуция()
	Результат = УправлениеЛогистикойСервер.ОпределитьТарифДистрибуция(Объект,,,Объект.ЗонаДоставкиДляВодителя);
	Объект.Тариф = Результат.Тариф;
	Объект.ТарифЗаКг = Результат.ТарифЗаКг;
КонецПроцедуры  

&НаКлиенте
Процедура УстановитьВидимостьРеквизитовДоставкиДистрибуция() 
	
	КлиентДистрибуцииИлиКоммерческого = АльтерраОбщегоНазначения.КлиентДистрибуцииИлиКоммерческого(Объект.Партнер); 
	
    Элементы.ВыбратьОбъектДоставки.Видимость                       = КлиентДистрибуцииИлиКоммерческого;
    Элементы.Тариф1.Видимость                                      = КлиентДистрибуцииИлиКоммерческого; 
	Элементы.ВызватьРаспределениеТранспортныхДистрибуция.Видимость = КлиентДистрибуцииИлиКоммерческого;   
	Элементы.ДистрибуцияГалочки.Видимость                          = КлиентДистрибуцииИлиКоммерческого;
	Элементы.ИспользуетсяДоговор1.Видимость                        = КлиентДистрибуцииИлиКоммерческого;
	
	Если Не КлиентДистрибуцииИлиКоммерческого Тогда
		Объект.РаспределитьТранспортныеДистрибуция = Ложь;
	КонецЕсли;  
	
	УстановитьВидимостьПоРаспределитьТранспортные();

КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПоРаспределитьТранспортные() 
	
	РаспределитьТранспортныеДистрибуция = Объект.РаспределитьТранспортныеДистрибуция;
	
	Элементы.ЛегкийПрайс.Видимость                  = РаспределитьТранспортныеДистрибуция;
	Элементы.ТоварыЦенаСДоставкойПечать.Видимость   = РаспределитьТранспортныеДистрибуция;
	Элементы.Корзина1ЦенаСДоставкойПечать.Видимость = РаспределитьТранспортныеДистрибуция; 
 	
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда 
		ЗаголовокКоманды  = "Снять распределение транспортных дистрибуция"; 
	Иначе  
		ЗаголовокКоманды  = "Распределить транспортные дистрибуция"; 
	Конецесли; 
	
	Элементы.ВызватьРаспределениеТранспортныхДистрибуция.Заголовок         = ЗаголовокКоманды; 
	Элементы.Корзина1ВызватьРаспределениеТранспортныхДистрибуция.Заголовок = ЗаголовокКоманды;
	
КонецПроцедуры

&НаКлиенте
Процедура РаспределениеСтоимостиДоставкиДистрибуция(ПоКнопке = Ложь)
	
	Если Объект.РаспределитьТранспортныеДистрибуция ИЛИ ПоКнопке Тогда
		ТолькоСтоимостьДоставки = Ложь;
	Иначе  
		ТолькоСтоимостьДоставки = Истина;
	КонецЕсли; 
	
	РаспределениеСтоимостиДоставкиДистрибуцияНаСервере(ТолькоСтоимостьДоставки);		
	ДобавлениеУслугиДоставки();  
	
КонецПроцедуры

&НаСервере 
Процедура РаспределениеСтоимостиДоставкиДистрибуцияНаСервере(ТолькоСтоимостьДоставки = Ложь)  
		
  Результат = УправлениеЛогистикойСервер.РаспределениеСтоимостиДоставкиДистрибуция(Объект,,ТолькоСтоимостьДоставки);
  Объект.СтоимостьДоставкиСНДС = Результат.СтоимостьДоставки;  
  
КонецПроцедуры

&НаКлиенте
Процедура ЛегкийПрайсПриИзменении(Элемент)
	Если ТекущаяСтрокаНоменклатуры.Номенклатура  <> Неопределено Тогда
	   ЗаполнитьСопутствующиеТовары(ТекущаяСтрокаНоменклатуры.Номенклатура, ТекущаяСтрокаНоменклатуры.ВидЦены);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДобавитьУбратьВидТовараДляДоставки() //Выводит или скрывает колонку ВидТовараДляДоставки динамического списка  
	
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда    
		
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(СписокНоменклатура.ТекстЗапроса);
		ПакетЗапросов = СхемаЗапроса.ПакетЗапросов[СхемаЗапроса.ПакетЗапросов.Количество()-1];
		Оператор = ПакетЗапросов.Операторы[0]; 
		
		ДопРеквизиты = Оператор.Источники.Добавить("Справочник.Номенклатура.ДополнительныеРеквизиты", "НоменклатураДополнительныеРеквизиты");
		ДопРеквизиты.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.ПравоеВнешнее;  
		ДопРеквизиты.Соединения[0].Условие = Новый ВыражениеСхемыЗапроса("НоменклатураДополнительныеРеквизиты.Ссылка = СправочникНоменклатура.Ссылка И НоменклатураДополнительныеРеквизиты.Свойство = &Свойство");		
		
		Оператор.ВыбираемыеПоля.Добавить("НоменклатураДополнительныеРеквизиты.Значение");   
		
		ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();	
		СписокНоменклатура.ТекстЗапроса = СтрЗаменить(ТекстЗапроса,"НоменклатураДополнительныеРеквизиты.Значение",
		"Выбор Когда ЕстьNull(НоменклатураДополнительныеРеквизиты.Значение,&Тяжелый) = &Тяжелый Тогда ""Тяжелый"" Иначе ""Легкий"" Конец");
	 
		
		СвойствоВидТовараДляДоставки = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ВидТовараДляДоставки");
	    ЗначениеТяжелый= Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Тяжелый",,,СвойствоВидТовараДляДоставки);
		
   		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Свойство", СвойствоВидТовараДляДоставки);
        СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Тяжелый", ЗначениеТяжелый);

		Если Элементы.Найти("СписокНоменклатураВидТовараДляДоставки") = Неопределено Тогда		
			КолонкаВидТовараДляДоставки = Элементы.Добавить("СписокНоменклатураВидТовараДляДоставки", Тип("ПолеФормы"), Элементы.СписокНоменклатура);
			КолонкаВидТовараДляДоставки.ПутьКДанным = "СписокНоменклатура.Значение";
			КолонкаВидТовараДляДоставки.Заголовок = "Вид товара для доставки";
			КолонкаВидТовараДляДоставки.Ширина = 10;
		КонецЕсли;	
	Иначе
		МодифицироватьЗапрос();
	КонецЕсли;
	
	Если Элементы.Найти("СписокНоменклатураВидТовараДляДоставки") <> Неопределено Тогда	
	   	Элементы.СписокНоменклатураВидТовараДляДоставки.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьПараметрыАвтоопределениеДистрибуция()
	 Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		 СнятьРаспределениеТранспортныхДистрибуция();  
		 
		 Объект.Тариф         = Неопределено;
		 Объект.ТарифЗаКг     =0;  
		 Объект.ВидДоставки   = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ПустаяСсылка");
		 Объект.НужнаДоставка = Ложь;
		 Объект.РаспределитьТранспортныеДистрибуция = Ложь;
		 
		 ДобавитьУбратьВидТовараДляДоставки();		
		 Объект.ОбъектДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ПустаяСсылка");
	 КонецЕсли;
	 УстановитьВидимостьРеквизитовДоставкиДистрибуция();
 КонецПроцедуры

&НаКлиенте
Процедура СнятьРаспределениеТранспортныхДистрибуция()
	Для Каждого Строка из Объект.Товары Цикл
			Строка.ПроцентРучнойСкидки = Строка.ПроцентРучнойСкидки - Строка.Компенсация;
			Строка.Компенсация = 0;
	КонецЦикла; 
    Объект.СтоимостьДоставкиСНДС = 0;
	ДобавлениеУслугиДоставки(); 	
КонецПроцедуры 

#КонецОбласти

