&НаСервере
Функция ЕстьМаркируемыеТовары() 
	
	Отбор = Новый Структура("СтатусПроверкиГосИС",4);
	МассивСтрокСМаркировкой = Объект.Товары.НайтиСтроки(Отбор); 
