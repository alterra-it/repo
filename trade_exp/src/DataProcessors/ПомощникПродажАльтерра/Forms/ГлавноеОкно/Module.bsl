#КонецОбласти

#Область ВыводСообщенийОСкидкахНаценках

&НаСервере
Процедура СкидкиНаценкиСервер_Рассчитать(ДокументОбъект)
	Попытка
		СтруктураПараметры = Новый Структура;
		СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
		СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
		СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Истина); 
		СтруктураПараметры.Вставить("УправляемыеСкидки",              УправляемыеСкидки);    

		Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(ДокументОбъект, "РеализацияПоЗаказам") Тогда
			СтруктураПараметры.Вставить("РеализацияСверхЗаказа", ДокументОбъект.РеализацияПоЗаказам)
		КонецЕсли;   
		
		СуммаБонусы = Объект.Товары.Итог("СуммаБонусныхБалловКСписанию");
		ПримененныеСкидки = СкидкиНаценкиСервер.Рассчитать(ДокументОбъект, СтруктураПараметры);
		ПересчитатьСуммыСУчетомБонусовВТЧ(ДокументОбъект);
		ДокументОбъект.СуммаДокумента = ДокументОбъект.Товары.Итог("СуммаСНДС");
		
		ДокументОбъект.СкидкиРассчитаны = Истина;
		
		Если  ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
			ДокументОбъект.ЭтапыГрафикаОплаты.Очистить();
			ВзаимоРасчетыСервер.ПроверитьЗаполнитьЭтапыГрафикаОплаты(ДокументОбъект);
		КонецЕсли;         

		СкидкиНаценки_Объект = "СкидкиНаценки_Объект_" + ДокументОбъект.Метаданные().Имя;
		ЗначениеВРеквизитФормы(ДокументОбъект, СкидкиНаценки_Объект);    
		//АвтоопределениеДистрибуция
		Если Объект.РаспределитьТранспортныеДистрибуция Тогда
			АльтерраОбщегоНазначения.ПересчитатьЦенуСДоставкойПечать(ДокументОбъект.Товары);
		КонецЕсли;
        //
	Исключение 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось применить скидки в документе!");
	КонецПопытки;
	

КонецПроцедуры

&НаКлиенте
Процедура ВыводСообщенийОСкидкахНаценках()
	
