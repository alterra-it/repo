	Истина);  
	ЗаполнитьФильтрыСервер();
	ПодборИНН();
	Если ПроверитьОбъектДоставки() Тогда
		РассчитатьИтоги();
		УстановитьВидимостьДоступностьДоставки();
	КонецЕсли;
	
	//158234
    СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.РучнойВвод");
