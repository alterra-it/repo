&НаСервере
Процедура СоздатьДокументЗаказКлиента(КоммерческоеПредложение = Ложь)
	Док = Документы.ЗаказКлиента.СоздатьДокумент();
	
	ЗаполнитьОбщиеРеквизиты(Док);
	
	Док.Согласован = Истина;
	Док.ДатаОтгрузки = Объект.ЖелаемаяДатаОтгрузки; 

	Док.КоммерческоеПредложение = КоммерческоеПредложение;
		
	Если КоммерческоеПредложение Тогда
		Док.Статус = Перечисления.СтатусыЗаказовКлиентов.НеСогласован;
		Док.СрокДействия = СрокДействия;
	ИНаче
		Док.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению;
	КонецЕсли;
	
	Док.ХозяйственнаяОперация= Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
	Док.НеОтгружатьЧастями = Истина;
	Док.Приоритет = Справочники.Приоритеты.НайтиПоНаименованию("Низкий");
	Док.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
	Док.Магазин = Объект.Магазин;
	СуммаБонусы = Объект.Товары.Итог("СуммаБонусныхБалловКСписанию");
	
	ПересчитатьБонусы = Ложь;
	
	Для Каждого стрТовар Из Объект.Товары Цикл
		Если стрТовар.ЕстьНехватка Тогда
			Если стрТовар.ВНаличии > 0 Тогда
				//Добавляем резерв
				ПересчитатьБонусы = Истина;
				Если КоммерческоеПредложение Тогда
					ДобавитьТоварВЗаказ(Док, стрТовар, стрТовар.ВНаличии, Перечисления.ВариантыОбеспечения.НеТребуется);
				Иначе	
					ДобавитьТоварВЗаказ(Док, стрТовар, стрТовар.ВНаличии, Перечисления.ВариантыОбеспечения.СоСклада);
				КонецЕсли;	
				ПересчитатьСуммыСУчетомБонусов(Док, стрТовар);
			КонецЕсли;
			//Добавляем обеспечение
			КОбеспечению = стрТовар.Количество-стрТовар.ВНаличии;
			Если КоммерческоеПредложение Тогда
				ДобавитьТоварВЗаказ(Док, стрТовар, КОбеспечению, Перечисления.ВариантыОбеспечения.НеТребуется);
			Иначе	
				ДобавитьТоварВЗаказ(Док, стрТовар, КОбеспечению, Перечисления.ВариантыОбеспечения.КОбеспечению);
			КонецЕсли;	
		Иначе
			Если КоммерческоеПредложение Тогда
				ДобавитьТоварВЗаказ(Док, стрТовар, стрТовар.Количество, Перечисления.ВариантыОбеспечения.НеТребуется);
			Иначе	
				ДобавитьТоварВЗаказ(Док, стрТовар, стрТовар.Количество, Перечисления.ВариантыОбеспечения.СоСклада);
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла; 
	
	ДобавитьНачислениеБонусныхБаллов(Док);
	
	Если ПересчитатьБонусы Тогда
		
		Для Каждого стрТовар Из Док.Товары Цикл
			
			стрТовар.СуммаБонусныхБалловКСписанию= 0;
			стрТовар.СуммаБонусныхБалловКСписаниюВВалюте= 0;
			стрТовар.СуммаНачисленныхБонусныхБалловВВалюте= 0;
			
			ПересчитатьСуммыСУчетомБонусов(Док, стрТовар);
		КонецЦикла;
		
		БонусыАльтерра.РаспределитьОплатуБаллами(СуммаБонусы,Док.Товары);
		
		Для Каждого стрТовар Из Док.Товары Цикл
			ПересчитатьСуммыСУчетомБонусов(Док, стрТовар);
		КонецЦикла;
		ПересчитатьСуммыСУчетомБонусовВТЧ(Док);
	КонецЕсли;
	
	СкидкиНаценкиСервер_Рассчитать(Док);
	
	ВзаимоРасчетыСервер.ПроверитьЗаполнитьЭтапыГрафикаОплаты(Док);
	Док.СуммаДокумента = Док.Товары.Итог("СуммаСНДС"); 
	
КонецПроцедуры       

&НаСервере
Процедура ДобавитьТоварВЗаказ(Док, стрТовар, Количество, ВариантОбеспечения)
	НоваяСтрока = Док.Товары.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, стрТовар);
	НоваяСтрока.Количество = Количество;
	НоваяСтрока.КоличествоУпаковок = Количество;
	НоваяСтрока.ДатаОтгрузки = Объект.ЖелаемаяДатаОтгрузки;
	НоваяСтрока.ВариантОбеспечения = ВариантОбеспечения;
	НоваяСтрока.Склад = Объект.Склад;
	
	ПересчитатьСуммыСУчетомБонусов(Док, НоваяСтрока);
КонецПроцедуры 

Процедура ДобавитьНачислениеБонусныхБаллов(Док)
	
	Для Каждого стрНачисление Из Объект.НачислениеБонусныхБаллов Цикл	
		НоваяСтрока = Док.НачислениеБонусныхБаллов.Добавить();
		НоваяСтрока.КлючСвязи = стрНачисление.КлючСвязи;
		НоваяСтрока.БонуснаяПрограммаЛояльности = стрНачисление.БонуснаяПрограммаЛояльности;
		НоваяСтрока.ДатаНачисления = стрНачисление.ДатаНачисления;
		НоваяСтрока.ДатаСписания = стрНачисление.ДатаСписания;
		НоваяСтрока.СуммаБонусныхБаллов = стрНачисление.СуммаБонусныхБаллов;
	КонецЦИкла;
	
КонецПроцедуры	 

#КонецОбласти

#Область Продажа
&НаСервере
Процедура ОформитьПродажу()	
	//Определяем Реализация или Чек
	
	ЕстьПроизвольныеЦены = АльтерраОбщегоНазначения.ЕстьПроизвольныеЦены(Объект);
	
	Если 
		ЕстьПроизвольныеЦены ИЛИ 
		ДоставкаПоЗвонку ИЛИ
		Объект.ИспользуетсяДоговор ИЛИ 
		(Объект.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания И НЕ Объект.Соглашение.ЧекККМ) ИЛИ
		Объект.Автор.Подразделение <> Объект.Склад.Подразделение
		ИЛИ (СкладОрдерный() И ЕстьМаркируемыеТовары() )
		ИЛИ Объект.РаспределитьТранспортныеДистрибуция Тогда
		
		СоздатьДокументРеализация();
	Иначе	
		СоздатьЧекККМ();
	КонецЕсли;
	
КонецПроцедуры
	
&НаСервере
Процедура ОформитьПродажу_Завершение(ДокСсылка)
	ДобавитьВДокументы(ДокСсылка);	
	
	НужнаЗаявка = Документы.ЗаявкаВЕГАИСЛес.ПроверкаНаличияЗаявкиНаСоответствующийДокументПродажи(ДокСсылка);
	Если НужнаЗаявка Тогда
		ДокЗаявка = Документы.ЗаявкаВЕГАИСЛес.СоздатьДокумент();
		ДокЗаявка.Дата = ТекущаяДата();
		ДокЗаявка.Заполнить(ДокСсылка);
		ДокЗаявка.Записать(РежимЗаписиДокумента.Проведение);
		АльтерраОбщегоНазначения.СообщитьПользователю(ДокЗаявка.Ссылка, "Создан: " + ДокЗаявка.Ссылка);
		ДобавитьВДокументы(ДокЗаявка.Ссылка);	
	КонецЕсли;	
	
	Если Объект.НужнаДоставка Тогда
		ОформитьЗаказНаДоставку(ДокСсылка);
	КонецЕсли;
	
	Если ДоставкаПоЗвонку Тогда
		ЛистСогласования = СоздатьЛистСогласования(ДокСсылка);
		ДобавитьВДокументы(ЛистСогласования);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументРеализация()
	Док = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
	
	ЗаполнитьОбщиеРеквизиты(Док);
	
	Док.Согласован = Истина;
	Док.Статус = Перечисления.СтатусыРеализацийТоваровУслуг.Отгружено;
	Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияКлиенту;
	Док.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
	Док.ВалютаВзаиморасчетов = Объект.Валюта;
	Док.БанковскийСчетОрганизации = Объект.БанковскийСчет;
	Док.ВариантОформленияПродажи = Перечисления.ВариантыОформленияПродажи.РеализацияТоваровУслуг;
	Док.Магазин = Объект.Магазин;
	
	Для Каждого стрТовар Из Объект.Товары Цикл
		НоваяСтрока = Док.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, стрТовар);
		//ПересчитатьЦеныВСтрокеКорзиныНаСервере(НоваяСтрока);
		НоваяСтрока.Склад = Объект.Склад;
	КонецЦикла;
	
	ДобавитьНачислениеБонусныхБаллов(Док);
	
	ВзаимоРасчетыСервер.ПроверитьЗаполнитьЭтапыГрафикаОплаты(Док);
	
	СкидкиНаценкиСервер_Рассчитать(Док);
	
	Док.СуммаДокумента = Док.Товары.Итог("СуммаСНДС");
	Док.СуммаВзаиморасчетов = Док.СуммаДокумента;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьЧекККМ()
	
	//Отмена заполнения реквизита "Контрагент" в Чеках ККМ
	Объект.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
	
	Док = Документы.ЧекККМ.СоздатьДокумент();
	
	ЗаполнитьОбщиеРеквизиты(Док);
	
	Док.Статус = Перечисления.СтатусыЧековККМ.ОтложенСРезервированием;
	Док.ОтложенДо = КонецДня(ТекущаяДата());
	если ДопМодуль.НовоеЦенообразование() тогда
		Док.ВидЦены = ВидЦены;
	иначе
		Док.ВидЦены = Объект.Соглашение.ВидЦен;
	КонецЕсли;   
	
	//Получение кассы по тек. раб. месту 
	ЯвляетсяКассиром = РольДоступна("Полныеправа") или РольДоступна("ОтметкаКассы");  
	КассаККМ = АльтерраОбщегоНазначения.ПолучитьКассуККМПоРабочемуМесту();
	Если КассаККМ <> Неопределено  и ЯвляетсяКассиром Тогда
		Док.КассаККМ = КассаККМ;
   	Иначе
		Док.КассаККМ = АльтерраОбщегоНазначения.КассаККМПоумолчанию(Объект.Подразделение);
	КонецЕсли; 
	
	//  
	Док.Магазин = Справочники.СтруктураПредприятия.ПустаяСсылка();
	СтруктураСостояниеКассовойСмены = РозничныеПродажи.ПолучитьСостояниеКассовойСмены(Док.КассаККМ);
	Если Док.Статус <> Перечисления.СтатусыЧековККМ.Пробит
		И Док.КассоваяСмена <> СтруктураСостояниеКассовойСмены.КассоваяСмена Тогда
		Док.КассоваяСмена = СтруктураСостояниеКассовойСмены.КассоваяСмена;
	КонецЕсли;
	  
	
	Для Каждого стрТовар Из Объект.Товары Цикл
		НоваяСтрока = Док.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, стрТовар);
		
		НоваяСтрока.Склад = Объект.Склад;
		Если значениезаполнено(Объект.Менеджер) Тогда
			НоваяСтрока.Продавец = Объект.Менеджер;
		Иначе
			НоваяСтрока.Продавец = пользователи.ТекущийПользователь();
		КонецЕсли;
	КонецЦикла;
	
	СкидкиНаценкиСервер_Рассчитать(Док);
	
	Док.СуммаДокумента = Док.Товары.Итог("СуммаСНДС");
	
КонецПроцедуры

#КонецОбласти

#Область ЗаказНаДоставку

&НаСервере
Процедура ОформитьЗаказНаДоставку(Основание)
	
	ЗаказНаДоставку = СоздатьЗаказНаДоставку(Основание);
	
	ДобавитьВДокументы(ЗаказНаДоставку);
	
КонецПроцедуры  

&НаСервере
Функция СоздатьЗаказНаДоставку(Основание)
	
	Док = Документы.ЗаказНаДоставкуКлиенту.СоздатьДокумент();
	
	ЗаполнитьЗначенияСвойств(Док, Объект);
	
	Док.ОплатаБанковскойКартой = Объект.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта; 
	Док.НаправлениеДоставки = Док.Партнер.БизнесРегион;
	Док.Статус = Перечисления.СтатусыЗаказовНаДоставку.Ожидает;
	Док.Комментарий = Объект.КомментарийПоДоставке;
	Док.Инкассация = Объект.Инкассация;
	Док.Сдача = Объект.Сдача;  
	Док.СтоимостьДоставкиПоДокументуПродажи = Объект.СтоимостьДоставкиСНДС;	  
	НоваяСтрока = Док.Основания.Добавить();
	НоваяСтрока.Документ = Основание;
	
	//Добавляем старые документы в основания
	Для Каждого Строка Из Объект.ОснованияДоставки Цикл
		НоваяСтрока = Док.Основания.Добавить();
	    НоваяСтрока.Документ = Строка.Документ;
	КонецЦикла;
	//
	
	Для Каждого Стр Из Объект.ВариантыРазгрузкиВРучную Цикл
		НоваяСтр = Док.ВариантыРазгрузкиВРучную.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтр, Стр);
	КонецЦикла;
	
	ЕСЛИ ДоставкаПоЗвонку = ИСТИНА ТОГДА
		Док.Комментарий = "забрать чек " + Объект.КомментарийПоДоставке;
	КонецЕсли;
	
	//Документы.ЗаказНаДоставкуКлиенту.ОбновитьИтогиПоОснованиям(Док); //еще раз вызывается при записи документа
	
	РежимЗаписи = РежимЗаписиДокумента.Проведение;  	
	Док.Записать(РежимЗаписи);
	Возврат Док.Ссылка; 	
КонецФункции   

#КонецОбласти

#Область Пропуск
&НаСервере
Процедура ОформитьПропуск()
	
	ТзОснование = Объект.Документы.Выгрузить();
	Для Каждого Строка Из ТзОснование Цикл 
		Если ТипЗнч(Строка.Документ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда				
			Док = Документы.Пропуск.СоздатьДокумент();
			Документы.Пропуск.ЗаполнитьДанныеПоОснованию(Строка.Документ, Док);
			ТекДата = ТекущаяДата();
			Док.Дата = ТекДата;
			Док.ДатаНачала = ТекДата;
			Док.ДатаОкончания = КонецДня(ТекДата);
			Док.Доступ = Объект.Склад.Подразделение.ЗонаДоступа;
			Док.ТипПрохода = Перечисления.ТипыПрохода.Въезд;
			Если Объект.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания Тогда
				Док.НаименованиеОрганизации = Объект.Партнер.НаименованиеПолное;
			Иначе 
				Док.ФИО = Объект.Партнер.НаименованиеПолное;
			КонецЕсли;
			Док.Записать(РежимЗаписиДокумента.Проведение);
			ДобавитьВДокументы(Док.Ссылка);	
		КонецЕсли;	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПропускНаОсновании()
	
	ФормаДок = ПолучитьФорму("Документ.Пропуск.ФормаОбъекта");
	ДанныеФормы = ФормаДок.Объект;	
	ЗаполнитьПропуск(ДанныеФормы);
	КопироватьДанныеФормы(ДанныеФормы, ФормаДок.Объект);
	ФормаДок.Открыть();	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПропуск(НовыйОбъект)
	
	ТзОснование = Объект.Документы.Выгрузить();
	Для Каждого Строка Из ТзОснование Цикл
		Если ТипЗнч(Строка.Документ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			Документы.Пропуск.ЗаполнитьДанныеПоОснованию(Строка.Документ, НовыйОбъект);	
			Док = ДанныеФормыВЗначение(НовыйОбъект, Тип("ДокументОбъект.Пропуск"));
			ТекДата = ТекущаяДата();
			Док.Дата = ТекДата;
			Док.ДатаНачала = ТекДата;
			Док.ДатаОкончания = КонецДня(ТекДата);
			Док.Доступ = Объект.Склад.Подразделение.ЗонаДоступа;
			Док.ТипПрохода = Перечисления.ТипыПрохода.Въезд;
			ЗначениеВДанныеФормы(Док,НовыйОбъект);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область Общие
&НаСервере
Процедура ЗаполнитьОбщиеРеквизиты(Док)
	ЗаполнитьЗначенияСвойств(Док, Объект);
	Док.Дата = ТекущаяДата();
	Док.Комментарий = "Создан из помощника продаж";
	
	//ТЧ
	Если Док.Метаданные().ТабличныеЧасти.Найти("СкидкиНаценки") <> Неопределено Тогда
		Док.СкидкиНаценки.Загрузить(Объект.СкидкиНаценки.Выгрузить());
	КонецЕсли;
	Если Док.Метаданные().ТабличныеЧасти.Найти("БонусныеБаллы") <> Неопределено Тогда
		Док.БонусныеБаллы.Загрузить(Объект.БонусныеБаллы.Выгрузить());
	КонецЕсли;
	Если Док.Метаданные().ТабличныеЧасти.Найти("Нарезка") <> Неопределено Тогда
		Док.Нарезка.Загрузить(Объект.Нарезка.Выгрузить());
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДобавитьВДокументы(Ссылка)
	НоваяСтрока = Объект.Документы.Добавить();
	НоваяСтрока.Документ = Ссылка;
КонецПроцедуры

&НаКлиенте
Процедура ДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ДокументСсылка= Элементы.Документы.ТекущиеДанные.Документ;
	ПараметрыФормы= Новый Структура("Ключ", ДокументСсылка);
	ИмяДокумента= АльтерраОбщегоНазначения.ИмяОбъекта(ТипЗнч(ДокументСсылка));
	
	Если ИмяДокумента = "ЧекККМ" Тогда
		СтатусЧека = ПолучитьСтатусЧека(ПараметрыФормы.Ключ);
		Если СтатусЧека <> ПредопределенноеЗначение("Перечисление.СтатусыЧековККМ.Пробит") Тогда
			ОткрытьФорму("Документ."+ИмяДокумента+".Форма.ФормаДокументаРМК",ПараметрыФормы,ЭтаФорма,,,,,РежимОткрытияОкнаФормы.Независимый);
		КонецЕсли;
	Иначе
		ОткрытьФорму("Документ."+ИмяДокумента+".ФормаОбъекта",ПараметрыФормы,ЭтаФорма,,,,,РежимОткрытияОкнаФормы.Независимый);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтатусЧека(СсылкаНаЧек)
	ЧекОбъект = СсылкаНаЧек.ПолучитьОбъект();
	Возврат ЧекОбъект.Статус;
	
КонецФункции	


&НаСервере
Процедура УдалитьДокументы()	
		
	Для Каждого ДокСсылка Из Объект.Документы Цикл
		УстановитьПривилегированныйРежим(Истина);
		Док= ДокСсылка.Документ.ПолучитьОбъект();
		Док.Удалить();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЦикла;
	
	Объект.Документы.Очистить();
	
	ЗапрещеноУдалятьДокументы= Ложь;
КонецПроцедуры

&НаКлиенте
Процедура ПеречитатьДокументы(Команда)
	ЗаполнитьСписокДокументовПоСделкеНаСервере();
	УстановитьВидимостьНовигации();
КонецПроцедуры
#КонецОбласти

#Область Печать
&НаКлиенте
Процедура НапечататьКомплектДокументов(Команда)
	СФП_МаркерыКлиент.МаркерНачало("ПП печать комплекта документов");
	
	ТабличныеДокументы= Новый СписокЗначений;
	ПараметрКоманды= Новый Массив;
	ПараметрКоманды.Добавить(Объект.Ссылка);
	ПараметрыПечати= Новый Структура;
	Для Каждого стрДокумент Из Объект.Документы Цикл
		Ссылка= стрДокумент.Документ;
		
		МассивОбъектов= Новый Массив;
		МассивОбъектов.Добавить(Ссылка);
		
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.КоммерческоеПредложениеКлиенту") Тогда
			ЕстьРаспределениеТранспортных= ЕстьРаспределениеТранспортных(Ссылка);
			
			Если ЕстьРаспределениеТранспортных Тогда
				ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "Коммерческое предложение (Альтерра)", "КоммерческоеПредложение", ПараметрыПечати);
			Иначе
				ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "2. Коммерческое предложение с распределенными услугами", "КоммерческоеПредложение", ПараметрыПечати);
			КонецЕсли;
			ТабличныйДокумент.Напечатать();
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Если Не Объект.НужнаДоставка Тогда
				ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "Печать по секциям", "ПечатьТНСекции", ПараметрыПечати);
				ТабличныйДокумент.Напечатать();
			КонецЕсли;
			
			//Нет счетфактуры 	
			
			ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "Печатные формы реализации", "ТоварныйЧек", ПараметрыПечати);
			ТабличныйДокумент.Напечатать();

			
//			//Если комиссионный товар 2 экземпляра чека 
//			Если Объект.НалогообложениеНДС = ПредопределенноеЗначение("Перечисление.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС") Тогда	
//				ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "Печатные формы реализации", "ТоварныйЧек", ПараметрыПечати);
//				ТабличныйДокумент.Напечатать();
//			КонецЕсли;
			
			Если АльтерраОбщегоНазначения.ЕстьУслуги(Объект) Тогда
				УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер(
				"Обработка.ПечатьАктОбОказанииУслуг",
				"Акт",
				ПараметрКоманды,
				ПараметрыПечати);
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
			
			ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "Печать чека", "ПечатьТоварногоЧека", ПараметрыПечати);
			ТабличныйДокумент.Напечатать();
			
			Если Не Объект.НужнаДоставка Тогда
				ТабличныйДокумент= СформироватьТНСекцию(МассивОбъектов);
				ТабличныйДокумент.Напечатать();				
			КонецЕсли;
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			УправлениеПечатьюКлиент.ВыполнитьКомандуПечатиНаПринтер(
			"Обработка.ПечатьСчетовНаОплату",
			"СчетНаОплату",
			МассивОбъектов,
			ПараметрыПечати);
			
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказНаДоставкуКлиенту") Тогда
			Если АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ссылка, "ВидДоставки") <> ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Внутренняя") Тогда
				НапечататьТабличныйДокумент(АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(
				МассивОбъектов, 
				"Заказ на доставку (Печатные формы)", 
				"ПФ_MXL_НарядЗаказНаДоставку_Лист2Диспетчер", 
				ПараметрыПечати));
			КонецЕсли;  
			Если Объект.ДоставкаСРазгрузкой Тогда 
				НапечататьТабличныйДокумент(АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(
				МассивОбъектов, 
				"Заказ на доставку (Печатные формы)", 
				"ПФ_MXL_ЗаданиеНаРазгрузкуДляКлиента", 
				ПараметрыПечати));	
			КонецЕсли;	
		КонецЕсли;
		
	КонецЦикла;  
КонецПроцедуры                     

&НаКлиенте
Функция НапечататьТабличныйДокумент(ТабличныйДокумент)
	Если ТабличныйДокумент <> Неопределено И ТабличныйДокумент.ВысотаТаблицы <> 0 И ТабличныйДокумент.ШиринаТаблицы <> 0 Тогда
		ТабличныйДокумент.Напечатать();
	КонецЕсли;
КонецФункции

&НаСервере
