&НаСервере
Процедура ИнтервалПриИзмененииСервер()
	ПоказыватьИнтервал = Истина;	
	Если ЗначениеЗаполнено(Объект.Интервал) Тогда
		Объект.ВремяДоставкиС= Объект.Интервал.ВремяС;
		Объект.ВремяДоставкиПо= Объект.Интервал.ВремяПО;
		НачальноеВремя = Объект.Интервал.ВремяС;
		
		Если Объект.Интервал.ЭкспрессДоставка Тогда
			Если НачалоДня(Объект.ПрибытиеНаОтгрузку) = НачалоДня(ТекущаяДата()) Тогда
				
				ТекущееВремя = ПолучитьВремяСПоправкойНаИнтервал();
				Если (ТекущееВремя >= Объект.Интервал.ВремяС) И (ТекущееВремя <= Объект.Интервал.ВремяПо) Тогда
					НачальноеВремя = ТекущееВремя;
					
				ИначеЕсли ТекущееВремя > Объект.Интервал.ВремяПо Тогда
					Сообщить("Время сегодня выходит за пределы интервала отгрузки");
					ПоказыватьИнтервал = Ложь;
				КонецЕсли;	
			КонецЕсли;
		Иначе
			ПоказыватьИнтервал = Ложь;
		КонецЕсли;
		
		Если ПоказыватьИнтервал Тогда
			Объект.ЭкспрессДоставка = Объект.Интервал.ЭкспрессДоставка;
			Элементы.ВремяДоставкиС.Доступность = Истина;
			Элементы.ВремяДоставкиПо.Доступность = Истина;
			Элементы.ВремяДоставкиС.АвтоВыборНезаполненного = Истина;
			Элементы.ВремяДоставкиПо.АвтоВыборНезаполненного = Истина;
			ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС, НачальноеВремя, Объект.Интервал.ВремяПо);
			ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо, НачальноеВремя, Объект.Интервал.ВремяПо);
		Иначе
			Объект.ЭкспрессДоставка = Ложь;
			Элементы.ВремяДоставкиС.Доступность = Ложь;
			Элементы.ВремяДоставкиПо.Доступность = Ложь;
		КонецЕсли;
		
		Если Объект.ЭкспрессДоставка Тогда
			Объект.ВремяДоставкиС = '00010101000000';
			Объект.ВремяДоставкиПо = '00010101000000';
		КонецЕсли;
		Модифицированность=Истина;
	Иначе
		Объект.ЭкспрессДоставка = Ложь;
		Элементы.ВремяДоставкиС.Доступность = Ложь;
		Элементы.ВремяДоставкиПо.Доступность = Ложь;
		Объект.ВремяДоставкиС = '00010101000000';
		Объект.ВремяДоставкиПо = '00010101000000';
	КонецЕсли;
	АвтоопределениеТарифа();
	
	Если ЗначениеЗаполнено(Объект.СтоимостьДоставкиСНДС)ИЛИ ЗначениеЗаполнено(Объект.СтоимостьДоставки) Тогда
		Если Объект.ДоставкаСРазгрузкой И ЗначениеЗаполнено(Объект.СтоимостьРазгрузкиДляКлиента) Тогда
			ДобавитьУслугуРазгрузки();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьВремяСПоправкойНаИнтервал()
	ТекущийЧас = Час(ТекущаяДата());
	НеКруглаяМинуты = Минута(ТекущаяДата()) - 1;
	ТекущиеМинуты = Цел(НеКруглаяМинуты/10)*10 + 10;
	
	Если ТекущиеМинуты = 60 Тогда
		ТекущиеМинуты = 0;
		ТекущийЧас = ТекущийЧас + 1;
	КонецЕсли;
	
	Если ТекущийЧас = 24 Тогда
		ТекущийЧас = 0;
	КонецЕсли;
	
	ТекущееВремя = Дата(0001,01,01, ТекущийЧас, ТекущиеМинуты, 0);
	
	Если Объект.ДоставкаСРазгрузкой Тогда
		ИнтервалЗакрытия = Объект.Интервал.ЗакрытиеИнтервалаПоРазгрузке*60;
	Иначе 
		ИнтервалЗакрытия = Объект.Интервал.ИнтервалЗакрытия*60;
	КонецЕсли;
	
	Если Объект.Интервал.ЗакрыватьСКонцаИнтервала Тогда
		НачальноеВремя = Дата(0001,01,01, ТекущийЧас, ТекущиеМинуты, 0) + ИнтервалЗакрытия;
	Иначе
		НачальноеВремя = Дата(0001,01,01, ТекущийЧас, ТекущиеМинуты, 0) - ИнтервалЗакрытия;
	КонецЕсли; 
	
	Возврат НачальноеВремя;
КонецФункции 

&НаКлиенте
Процедура ВремяДоставкиСПриИзменении(Элемент)
	Если Элементы.ВремяДоставкиС.СписокВыбора.Количество() > 0 Тогда
		
		НачальноеВремя = Элементы.ВремяДоставкиС.СписокВыбора[0].Значение;
		КонечноеВремя = Элементы.ВремяДоставкиС.СписокВыбора[Элементы.ВремяДоставкиС.СписокВыбора.Количество() - 1].Значение;
		
		Если Объект.ВремяДоставкиС < НачальноеВремя Тогда
			Объект.ВремяДоставкиС = НачальноеВремя;
			Сообщить("Время доставки не может быть меньше " + Формат(НачальноеВремя,"ДФ=ЧЧ:мм"))
		КонецЕсли;		
		
		Если Объект.ВремяДоставкиС > КонечноеВремя Тогда
			Объект.ВремяДоставкиС = КонечноеВремя;
			Сообщить("Время доставки не может быть больше " + Формат(КонечноеВремя,"ДФ=ЧЧ:мм"))
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ВремяДоставкиС) И ЗначениеЗаполнено(Объект.ВремяДоставкиПо) 
			И Объект.ВремяДоставкиС > Объект.ВремяДоставкиПо Тогда
			Сообщить("Начальное время " + Формат(Объект.ВремяДоставкиС, "ДФ=ЧЧ:мм") + " не может быть больше конечного времени " + Формат(Объект.ВремяДоставкиПо,"ДФ=ЧЧ:мм"));
			Объект.ВремяДоставкиС = Объект.ВремяДоставкиПо;
		КонецЕсли
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВремяДоставкиПоПриИзменении(Элемент)
	Если Элементы.ВремяДоставкиПо.СписокВыбора.Количество() > 0 Тогда
		
		НачальноеВремя = Элементы.ВремяДоставкиПо.СписокВыбора[0].Значение;
		КонечноеВремя = Элементы.ВремяДоставкиПо.СписокВыбора[Элементы.ВремяДоставкиПо.СписокВыбора.Количество() - 1].Значение;
		
		Если Объект.ВремяДоставкиПо < НачальноеВремя Тогда
			Объект.ВремяДоставкиПо = НачальноеВремя;
			Сообщить("Время доставки не может быть меньше " + Формат(НачальноеВремя,"ДФ=ЧЧ:мм"))
		КонецЕсли;		
		
		Если Объект.ВремяДоставкиПо > КонечноеВремя Тогда
			Объект.ВремяДоставкиПо = КонечноеВремя;
			Сообщить("Время доставки не может быть больше " + Формат(КонечноеВремя,"ДФ=ЧЧ:мм"))
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.ВремяДоставкиС) И ЗначениеЗаполнено(Объект.ВремяДоставкиПо)
			И Объект.ВремяДоставкиПо < Объект.ВремяДоставкиС Тогда
			Сообщить("Конечное время доставки " + Формат(Объект.ВремяДоставкиПо,"ДФ=ЧЧ:мм") + " не может быть меньше начального времени " + Формат(Объект.ВремяДоставкиС, "ДФ=ЧЧ:мм"));			
			Объект.ВремяДоставкиПо = Объект.ВремяДоставкиС;
		КонецЕсли
	КонецЕсли;
КонецПроцедуры


