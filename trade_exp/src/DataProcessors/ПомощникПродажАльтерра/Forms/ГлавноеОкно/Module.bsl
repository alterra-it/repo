&НаКлиенте
Процедура ИерархияНоменклатурыПриАктивизацииСтроки(Элемент)
	Если Элементы.ИерархияНоменклатуры.ТекущаяСтрока = ПредыдущаяСтрокаИерархии Тогда
		Возврат;
	КонецЕсли;
	ОтборПоИерархии();
	Если СтрДлина(Элемент.ВыделенныеСтроки[0]) <> 0 Тогда 
		ИерархияНоменклатурыПриАктивизацииСтрокиСервер(Элемент.ВыделенныеСтроки[0])
	КонецЕсли;   
	ПредыдущаяСтрокаИерархии = Элемент.ВыделенныеСтроки[0];
	
КонецПроцедуры

&НаСервере 
Процедура ИерархияНоменклатурыПриАктивизацииСтрокиСервер(ВидНоменклатуры)
	
	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Номенклатура
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ВидНоменклатуры = &ВидНоменклатуры"; 
	
	Запрос.УстановитьПараметр("ВидНоменклатуры",ВидНоменклатуры); 
	Выборка = Запрос.Выполнить().Выбрать(); 
	МассивОтбора = Новый СписокЗначений(); 
	Пока Выборка.Следующий() Цикл
		МассивОтбора.Добавить(Выборка.Номенклатура);
	КонецЦикла; 
	
	Если МассивОтбора.Количество() > 0 Тогда
		
			
		ВариантыЗапросов = ОпределитьВариантЗапроса();
		
		Если ВариантыЗапросов = "ЦеныПоСоглашению" Тогда
			СписокНоменклатура.ТекстЗапроса = ПолучитьТекстЗапросаСЦенамиПоСоглашению();
			ДобавитьТаблицыКЗапросу(СписокНоменклатура);
			
			УстановитьПараметрыПоУмолчанию();
			УстановитьПараметрыПоСоглашению();
		Иначе
			СписокНоменклатура.ТекстЗапроса = Обработки.ПомощникПродажАльтерра.ПолучитьТекстЗапросаСЦенамиПоВидуЦен();
			ДобавитьТаблицыКЗапросу(СписокНоменклатура);
			
			УстановитьПараметрыПоУмолчанию();
			УстановитьПараметрыПоВидуЦен();
		КонецЕсли; 
		
		
		
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		СписокНоменклатура,
		"Номенклатура",
		МассивОтбора,
		Истина);
		ЗаполнитьФильтрыСервер();
	КонецЕсли;	
КонецПроцедуры


