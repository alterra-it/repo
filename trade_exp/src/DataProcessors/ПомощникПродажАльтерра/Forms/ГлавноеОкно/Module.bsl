Процедура СнятьРаспределениеТранспортных(Команда)
	СнятьРаспределениеТранспортныхСервер();
КонецПроцедуры
&НаСервере
Процедура РаспределитьТранспортныеВТоварах(Знач ВыделенныеСтроки, Значение)
	Для Каждого Идентификатор Из ВыделенныеСтроки Цикл
		стрТовар= Объект.Товары.НайтиПоИдентификатору(Идентификатор);
		Если стрТовар.номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар Тогда
			стрТовар.Распределять= Значение;
		КонецЕсли;
	КонецЦикла;
	РаспределениеТранспортных();
КонецПроцедуры
&НаСервере
Процедура СнятьРаспределениеТранспортныхСервер()
	Для каждого стр из Объект.Товары цикл
		стр.СуммаСНДСРТ=0;
		стр.СуммаНДСРТ=0;
		стр.СуммаРТ=0;
		стр.Распределять=0;
	конеццикла;
	Объект.РаспределитьТранспортные= Объект.Товары.Итог("Распределять");
КонецПроцедуры

//Само распределение
Процедура РаспределениеТранспортных()
	Объект.РаспределитьТранспортные= Объект.Товары.Итог("Распределять");
	Если Не Объект.РаспределитьТранспортные Тогда
		СнятьРаспределениеТранспортныхСервер();
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура("СуммаТоваров,СуммаУслуг,Коэфф",0,0,0);
	ЗаполнитьПараметрыСтруктуры(СтруктураПараметров);
	
	Товары=Объект.Товары;
	ИТОГСуммаСНДСРТ=0;
	ИТОГСуммаНДСРТ=0;
	ИТОГСуммаРТ=0;
	Для каждого стр из Товары цикл
		
		стр.СуммаСНДСРТ=Стр.СуммаСНДС*СтруктураПараметров.Коэфф*стр.Распределять;
		стр.СуммаНДСРТ=Стр.СуммаНДС*СтруктураПараметров.Коэфф*стр.Распределять;
		стр.СуммаРТ=Стр.Сумма*СтруктураПараметров.Коэфф*стр.Распределять;
		если стр.Номенклатура.ТипНоменклатуры=перечисления.ТипыНоменклатуры.Услуга тогда
			ОтборУслуг=0;
		иначе
			ОтборУслуг=1;
		конецесли;	
		ИТОГСуммаСНДСРТ=ИТОГСуммаСНДСРТ+стр.СуммаСНДСРТ+отборУслуг*стр.СуммаСНДС;
		ИТОГСуммаНДСРТ=ИТОГСуммаНДСРТ+стр.СуммаНДСРТ+отборУслуг*стр.СуммаНДС;
		ИТОГСуммаРТ=ИТОГСуммаРТ+стр.СуммаРТ+отборУслуг*стр.Сумма;
	конеццикла;
	ТаблДокументаВР=Товары.Выгрузить();
	ТаблДокументаВР.Сортировать("Сумма Убыв");
	для каждого стр из ТаблДокументаВР цикл
		если стр.Номенклатура.ТипНоменклатуры=перечисления.ТипыНоменклатуры.Услуга тогда
			продолжить;
		иначе
			СтрокиДокумента=Товары.НайтиСтроки(Новый Структура("НомерСтроки", стр.номерстроки));
			строкаДокумента= СтрокиДокумента[0];
			строкаДокумента.СуммаСНДСРТ=стр.СуммаСНДСРТ+Товары.ИТОГ("СуммаСНДС")-ИТОГСуммаСНДСРТ;
			строкаДокумента.СуммаНДСРТ=стр.СуммаНДСРТ+Товары.ИТОГ("СуммаНДС")-ИТОГСуммаНДСРТ;
			строкаДокумента.СуммаРТ=стр.СуммаРТ+Товары.ИТОГ("Сумма")-ИТОГСуммаРТ;
			прервать;
		конецесли;	
	конеццикла;	
КонецПроцедуры
Процедура ЗаполнитьПараметрыСтруктуры(СтруктураПараметров)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Сумма,
	|	Товары.Номенклатура,
	|	Товары.Распределять
	|ПОМЕСТИТЬ ВР
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ВР.Сумма * ВР.Распределять) КАК СуммаТоваров,
	|	СУММА(ВЫБОР
	|			КОГДА СПР_Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|				ТОГДА ВР.Сумма
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаУслуг,
	|	ВЫБОР
	|		КОГДА СУММА(ВР.Сумма * ВР.Распределять) <> 0
	|			ТОГДА СУММА(ВЫБОР
	|						КОГДА СПР_Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|							ТОГДА ВР.Сумма
	|						ИНАЧЕ 0
	|					КОНЕЦ) / СУММА(ВР.Сумма * ВР.Распределять)
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Коэфф
	|ИЗ
	|	ВР КАК ВР
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СПР_Номенклатура
	|		ПО ВР.Номенклатура = СПР_Номенклатура.Ссылка";
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	если  Выборка.Следующий() тогда
		Заполнитьзначениясвойств(Структурапараметров, Выборка);
	конецесли;
	
КонецПроцедуры

