функция ПолучитьМаксимальнуюДлину(РасчетДоставкиПоНесколькимОснованиям = Ложь)
	
	Если РасчетДоставкиПоНесколькимОснованиям Тогда
	  ДлинаПоОбъекту = Документы.ЗаказНаДоставкуКлиенту.ПолучитьМаксимальнуюДлинуСУчетомНарезки(,Объект.Товары.Выгрузить(), Объект.Нарезка.Выгрузить());
	  ДлинаПоОснованиям = Документы.ЗаказНаДоставкуКлиенту.ПолучитьМаксимальнуюДлинуСУчетомНарезки(Объект.ОснованияДоставки.Выгрузить().ВыгрузитьКолонку("Документ"));
	  Возврат Макс(ДлинаПоОбъекту,ДлинаПоОснованиям);	
	КонецЕсли;
	
	Возврат Документы.ЗаказНаДоставкуКлиенту.ПолучитьМаксимальнуюДлинуСУчетомНарезки(,Объект.Товары.Выгрузить(), Объект.Нарезка.Выгрузить());
