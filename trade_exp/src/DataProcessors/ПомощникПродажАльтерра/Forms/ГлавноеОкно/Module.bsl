&НаКлиенте
Процедура КПодбору(Команда)
	Если ТекущаяСтраница <> "Подбор" Тогда
		ТекущаяСтраница= "Подбор";
		Если Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте") > 0 Тогда
			ОчиститьБонусыСервер();
			Сообщить ("Бонусные баллы были очищены");
		КонецЕсли;
		Элементы.СтраницаПодбор.Видимость= Истина;
		Элементы.СтраницаПараметры.Видимость= Ложь;
		Элементы.СтраницаОформление.Видимость= Ложь;
		УстановитьВидимостьНовигации();
		////АвтоопределениеДистрибуция
		//УстановитьВидимостьРеквизитовДоставкиДистрибуция();    
		////
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КПараметрам(Команда) 
	
	 //АвтоопределениеДистрибуция 
	 Элементы.СтоимостьДоставки.Видимость        =    Объект.РаспределитьТранспортныеДистрибуция;
	 Элементы.НаценкаДоставка.Видимость          = НЕ Объект.РаспределитьТранспортныеДистрибуция;
	 Элементы.ДобавитьДокументы.Видимость        = НЕ Объект.РаспределитьТранспортныеДистрибуция;
	 Элементы.ПараметрыРазгрузки.Видимость       = НЕ Объект.РаспределитьТранспортныеДистрибуция;
	 Элементы.ДоставкаСРазгрузкой.Видимость      = НЕ Объект.РаспределитьТранспортныеДистрибуция;
	 Элементы.РаспределятьТранспортные.Видимость = НЕ Объект.РаспределитьТранспортныеДистрибуция; 
     //
	 
	 НаценкаДоставка = Ложь;
	 
	 НаценкаОтсрочка = Ложь;
	 НаценкаКарта = Ложь;
	Если ТекущаяСтраница = "Оформление" Тогда	 
		
		СФП_МаркерыКлиент.МаркерНачало("ПП возврат К параметрам");
		
		ПроверитьВозможностьУдаленияДокументов();
		
		Если ЗапрещеноУдалятьДокументы Тогда
			ПоказатьПредупреждение(,"Запрещено удалять созданные документы", 10);
			Возврат;
		КонецЕсли;
		
		Если РазрешеноУдаленияДокументов() И Объект.Документы.Количество() > 0 Тогда
			ЗадатьВопроспроУдалениеДокументов();
		Иначе
			ПерейтиКПараметрам();	
		КонецЕсли;	
		
	Иначе     
		//Если СотрудникКонтакногоЦентра() Тогда
		//	Оповещение= Новый ОписаниеОповещения("ВыбранПравильныйСклад", ЭтотОбъект);
		//	ПоказатьВопрос(Оповещение, "Верно ли выбран склад: "+Строка(Объект.Склад)+"?", РежимДиалогаВопрос.ДаНет, 20, КодВозвратаДиалога.Нет);  
		//Иначе 
		//	ПереходКПараметрамПослеВопроса();
		//КонецЕсли;
		ПереходКПараметрамПослеВопроса();
	КонецЕсли;
	АктуализироватьСтатусГосИС();
	СохранитьСделкуНаСервере(Истина,Неопределено,Истина);
	Если Объект.НужнаДоставка Тогда
		АвтоопределениеТарифа();
	КонецЕсли;
	
КонецПроцедуры     

&НаСервере
Функция СотрудникКонтакногоЦентра()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА Пользователи.Подразделение.Наименование = ""Контактный центр""
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Проверка
	|ИЗ
	|	Справочник.Пользователи КАК Пользователи
	|ГДЕ
	|	Пользователи.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда         
		Возврат Выборка.Проверка;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции	

&НаКлиенте
Процедура ПереходКПараметрамПослеВопроса()
	СФП_МаркерыКлиент.МаркерНачало("ПП К параметрам");
	ПредложитьМногоОборотнуюТару(НЕОПРЕДЕЛЕНО);
	
	СохранитьСделкуНаСервере(Истина, ПредопределенноеЗначение("Перечисление.СтатусыСделок.ВРаботе")); 
	ПересчитатьЦеныУстановитьПараметрыДоступностьСервер();
	ПерейтиКПараметрам();
КонецПроцедуры

&НаКлиенте
Процедура ВыбранПравильныйСклад(Результат, ДопПараметры) Экспорт  
	Если Результат = КодВозвратаДиалога.Да Тогда 
		ПереходКПараметрамПослеВопроса();	
	КонецЕсли;	
КонецПроцедуры	

&НаКлиенте
Процедура ЗадатьВопроспроУдалениеДокументов()
	Оповещение= Новый ОписаниеОповещения("УдалитьДокументыЗавершение", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, "Будут удалены все созданные документы?", РежимДиалогаВопрос.ОКОтмена, 10, КодВозвратаДиалога.Отмена);
КонецПроцедуры

&НаКлиенте
Процедура ПерейтиКПараметрам()
	
	СтрокаПартнер = Строка(Объект.Партнер);
	Если (СтрокаПартнер = "РОЗНИЦА" ИЛИ СтрокаПартнер = "? розница для МД")
		И Объект.СуммаДокумента >= 3000
		Тогда 
		ОткрытьФормуСВыборомПартнера();
	КонецЕсли;
	
	
	ТекущаяСтраница = "Параметры";
	
	Элементы.СтраницаПодбор.Видимость = Ложь;
	Элементы.СтраницаПараметры.Видимость = Истина;
	Элементы.СтраницаОформление.Видимость = Ложь;
	
	УстановитьВидимостьНовигации();
	
	УстановитьВидимостьДоступностьДоставки();
	
	РассчитатьИтоги();
	
	ВывестиИнформацию();  
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьДокументыЗавершение(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.ОК Тогда
		УдалитьДокументы();
		
		СохранитьСделкуНаСервере(Истина, ПредопределенноеЗначение("Перечисление.СтатусыСделок.ВРаботе"));
		
		ПерейтиКПараметрам();
	КонецЕсли;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ИменяПолейПодбораМногооборотнойТары(ВариантОформленияДокументов, ИсключитьКоличество = Ложь)
	
	Если ИсключитьКоличество Тогда
		
		Если ВариантОформленияДокументов = ПредопределенноеЗначение("Перечисление.ВариантыОформленияДокументовПродажи.КоммерческоеПредложение") Тогда
			ИменаПолей = "Номенклатура,Характеристика";
		ИначеЕсли ВариантОформленияДокументов = ПредопределенноеЗначение("Перечисление.ВариантыОформленияДокументовПродажи.РеализацияТоваровУслуг")
			Тогда
			
			ИменаПолей = "Номенклатура,Характеристика,Склад";
			
		Иначе
			ИменаПолей = "Номенклатура,Характеристика,Склад,ДатаОтгрузки";
		КонецЕсли;
		
	Иначе
		
		Если ВариантОформленияДокументов = ПредопределенноеЗначение("Перечисление.ВариантыОформленияДокументовПродажи.КоммерческоеПредложение") Тогда
			ИменаПолей = "Номенклатура,Характеристика,Количество";
		ИначеЕсли ВариантОформленияДокументов = ПредопределенноеЗначение("Перечисление.ВариантыОформленияДокументовПродажи.РеализацияТоваровУслуг")
			Тогда
			
			ИменаПолей = "Номенклатура,Характеристика,Количество,Склад";
			
		Иначе
			ИменаПолей = "Номенклатура,Характеристика,Количество,Склад,ДатаОтгрузки";
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ИменаПолей;
	
КонецФункции

&НаКлиенте
Процедура ПредложитьМногоОборотнуюТару(Знач Оповещение)
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Оповещение", Оповещение);
	ВариантОформленияДокументов=ПредопределенноеЗначение("Перечисление.ВариантыОформленияПродажи.РеализацияТоваровУслуг");
	
	ИменаПолей         = ИменяПолейПодбораМногооборотнойТары(ВариантОформленияДокументов);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПредложитьПодобратьМногооборотнуюТаруЗавершение",
	ЭтотОбъект,
	ДополнительныеПараметры);
	
	МногооборотнаяТараКлиент.ПредложитьПодобратьМногооборотнуюТару(ЭтаФорма, "Товары", ИменаПолей,
	ОписаниеОповещения);
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПредложитьПодобратьМногооборотнуюТаруЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		ПересчитатьСтрокиКорзины()
	КонецЕсли;
	
	Возврат;
КонецПроцедуры


&НаКлиенте
Процедура КОформлению(Команда)
	СФП_МаркерыКлиент.МаркерНачало("ПП К оформлению");
	
	Отказ = Ложь;
	ПроверитьЗаполнениеПараметров(Отказ);
	
	Если ТекущаяСтраница = "Параметры" И Не Отказ Тогда
		ПредложитьМногоОборотнуюТару(НЕОПРЕДЕЛЕНО);  
		если Объект.СостояниеЗаполненияМногооборотнойТары=предопределенноезначение("Перечисление.СостоянияЗаполненияМногооборотнойТары.ПустаяСсылка") тогда
			возврат;
		конецесли;	
		Если ПроверкаУсловияДляУстановкиНаценкаКартаБезДоговора() или ПроверкаУсловияДляУстановкиНаценкаКарта() Тогда
			НаценкаКарта = Истина;
			АвтоматическаяУстановкаНаценкаКартаПриУсловии(НаценкаКарта);
		КонецЕсли;
		ПересчитатьДоступностьИНехватку();
		НачислитьБонусныеБаллы();
		РассчитатьИтоги();
		СкидкиНаценки_Объект = "";
		
		Попытка
			СохранитьСделкуНаСервере(Истина, ПредопределенноеЗначение("Перечисление.СтатусыСделок.Выиграна"));
			
			Если РежимОфрмления = "Коммерческое" Тогда
				
				СоздатьДокументЗаказКлиента(Истина);
				
				
			ИначеЕсли РежимОфрмления = "Заказ" Тогда
				
				СоздатьДокументЗаказКлиента(Ложь);
				
			ИначеЕсли РежимОфрмления = "Продажа" Тогда
				
				Нехватка = ПолучитьНехватку();
				Если Нехватка > 0 тогда
					Сообщить("Не хватает товара на остатках. Сформируйте заказ.");
					Возврат;
				КонецЕсли;
				
				ОформитьПродажу();
			КонецЕсли;
			
			ВыводСообщенийОСкидкахНаценках();
			
		Исключение
			Сообщить("Не удалось создать документы. Ошибка - " + ОписаниеОшибки());
		КонецПопытки;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура КОформлению_ЗавершениеНаКлиенте()
	
	Если КОформлению_ЗавершениеНаСервере() Тогда
		Если РежимОфрмления = "Заказ" И Объект.НуженПропуск Тогда
			Если КлиентРозница() Тогда
				СоздатьПропускНаОсновании();
				Сообщить("Укажите ФИО клиента для пропуска");
			Иначе 
				ОформитьПропуск();
			КонецЕсли;
		КонецЕсли;
		
		ПерейтиКОформлению();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере           
Функция КОформлению_ЗавершениеНаСервере()
	
	НачатьТранзакцию();
	Попытка
		Док = РеквизитФормыВЗначение(СкидкиНаценки_Объект); 	
		//АвтоопределениеДистрибуция
		Если Объект.РаспределитьТранспортныеДистрибуция Тогда
			АльтерраОбщегоНазначения.ПересчитатьЦенуСДоставкойПечать(Док.Товары);
		КонецЕсли;
        //
		Док.Записать(РежимЗаписиДокумента.Проведение);
		
		Если СтрНайти(СкидкиНаценки_Объект, "ЗаказКлиента") > 0 Тогда
			ОформитьЗаказ_Завершение(Док.Ссылка);
		Иначе
			ОформитьПродажу_Завершение(Док.Ссылка);
		КонецЕсли;
		ЗафиксироватьТранзакцию();
		
		Если ДоставкаПоЗвонку Тогда
            ОтправитьСообщениеОДоставке(Док);
        КонецЕсли;
		
		Возврат Истина;
	Исключение
		ОтменитьТранзакцию();
		ЗаполнитьСписокДокументовПоСделкеНаСервере();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать документ! " + ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
		
		
КонецФункции

&НаКлиенте
Процедура ПерейтиКОформлению()
	ТекущаяСтраница = "Оформление";
	
	Элементы.СтраницаПодбор.Видимость = Ложь;
	Элементы.СтраницаПараметры.Видимость = Ложь;
	Элементы.СтраницаОформление.Видимость = Истина;
	УстановитьВидимостьНовигации();
	
	НачислитьБонусныеБаллы();
	ПоказатьИнформациюПоБонусам();
	
	//Инструкции
	Для Каждого стрДокументы Из Объект.Документы Цикл
		Ссылка = стрДокументы.Документ;
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") ИЛИ ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			мФайлов = АльтерраОбщегоНазначения.ПолучитьВыборкуФайловИзТовара(Ссылка);
			Если мФайлов.Количество() > 0 Тогда
				Оповещение = Новый ОписаниеОповещения("НапечататьФайлыЗавершение", ЭтотОбъект, мФайлов);
				ПоказатьВопрос(Оповещение, "По преобретаемому товару есть инструкции." + Символы.ПС+"Напечатать инструкции?", РежимДиалогаВопрос.ДаНет, 10, КодВозвратаДиалога.Да, "Печать инструкций");
			КонецЕсли;
		КонецЕсли; 
		//Задача https://bitrix.tg-alterra.ru/company/personal/user/16834/tasks/task/view/242485/
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ПроверитьСостояниеЗакрыт(стрДокументы.Документ) 
		КонецЕсли;
		//
	КонецЦикла;
КонецПроцедуры
//Задача https://bitrix.tg-alterra.ru/company/personal/user/16834/tasks/task/view/242485/
&НаКлиенте
Процедура ПроверитьСостояниеЗакрыт(Документ)
	Форма = ПолучитьФорму("Документ.ЗаказКлиента.Форма.ФормаДокумента", Новый Структура("Ключ", Документ));
	
	Если Форма.Состояние = ПредопределенноеЗначение("Перечисление.СостоянияЗаказовКлиентов.Закрыт") Тогда
		Форма.Состояние = ПредопределенноеЗначение("Перечисление.СостоянияЗаказовКлиентов.ОжидаетсяСогласование");
	КонецЕсли;
КонецПроцедуры
//
&НаКлиенте
Процедура НапечататьФайлыЗавершение(Результат, мФайлов) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		РаботаСФайламиКлиент.НапечататьФайлы(мФайлов);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьНовигации()
	Если ТекущаяСтраница = "Подбор" Тогда
		Элементы.КПодбору.Доступность= Ложь;
		Элементы.КПараметрам.Доступность= Истина;
		Элементы.КОформлению.Доступность= Ложь;
	ИначеЕсли ТекущаяСтраница = "Параметры" Тогда
		Элементы.КПодбору.Доступность= Истина;
		Элементы.КПараметрам.Доступность= Ложь;
		Элементы.КОформлению.Доступность= Истина;
	ИначеЕсли ТекущаяСтраница = "Оформление" Тогда
		Элементы.КПодбору.Доступность= Ложь;
		Элементы.КПараметрам.Доступность= Истина;
		Элементы.КОформлению.Доступность= Ложь;
	КонецЕсли;
	
	Если ЗапрещеноУдалятьДокументы Тогда
		Элементы.КПараметрам.Доступность= Ложь;
		Элементы.КПодбору.Доступность= Ложь;
	КонецЕсли;   
	
	Если ЗначениеЗаполнено(ИнформацияПоПартнеру) Тогда 
		Элементы.ИнформацияПоПартнеру1.Видимость = Истина;
	Иначе     
		Элементы.ИнформацияПоПартнеру1.Видимость = Ложь;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ИнформацияПоБонусам) Тогда 
		Элементы.ИнформацияПоБонусам1.Видимость = Истина;
	Иначе  
		Элементы.ИнформацияПоБонусам1.Видимость = Ложь;
	КонецЕсли;	
	
КонецПроцедуры

