&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	
	Элементы.РасчитатьПараметрыНарезки.Доступность = НужнаНарезка;
	Элементы.ГрДоговор.Видимость                   = Объект.ИспользуетсяДоговор;
	//АвтоопределениеДистрибуция
	Элементы.Договор1.Видимость                    = Объект.ИспользуетсяДоговор;
	Элементы.Контрагент1.Видимость                 = Объект.ИспользуетсяДоговор;
	//
	Элементы.ПодборСписокЦен.Видимость             = ПоказыватьСписокЦен;  
	
	Если РежимОфрмления = "Заказ" ИЛИ РежимОфрмления = "Продажа" Тогда
		Элементы.ЖелаемаяДатаОтгрузки.Видимость= Истина;
		Элементы.ЖелаемаяДатаОтгрузки.ОтметкаНезаполненного= (РежимОфрмления = "Заказ");
		Элементы.БанковскийСчет.Видимость= Истина;
		Элементы.БанковскийСчетКонтрагента.Видимость= Истина;
		Элементы.ПараметрыКП.Видимость = Ложь;
		
	Иначе
		Элементы.ЖелаемаяДатаОтгрузки.Видимость= Ложь;
		Элементы.БанковскийСчет.Видимость= Ложь;
		Элементы.БанковскийСчетКонтрагента.Видимость= Ложь;
		Элементы.ПараметрыКП.Видимость = Истина;
	КонецЕсли;  
	
	Если РежимОфрмления = "Заказ" Тогда
		Элементы.ФлажкиАвтоподтоварки.Видимость = Истина;
	Иначе
		Элементы.ФлажкиАвтоподтоварки.Видимость = Ложь;		
	КонецЕсли;
	
	//Вид цены
	Элементы.Корзина1ВидЦены.ТолькоПросмотр= Элементы.ВидЦены.ТолькоПросмотр;
	
	Если РежимОфрмления = "Коммерческое" И ПроверкиАльтерраСервер.РазрешенПроизвольныйВидЦеныКоммерческоеПредложение() Тогда
		Элементы.Корзина1ВидЦены.ТолькоПросмотр = Ложь;
		Элементы.Корзина1ВидЦены.Доступность = Истина;
	КонецЕсли;
	Если РежимОфрмления <> "Коммерческое" Тогда
		Если Не ПроверкиАльтерраСервер.РазрешеноИзменятьВидЦены(Объект) Тогда
			Элементы.Корзина1ВидЦены.Доступность = Ложь;
		КонецЕсли;
	КонецЕсли;
	//Этапы строительства+
	ПараметрыОтображенияЭтаповСтроительства = ПолучитьПараметрыОтображенияЭтаповСтроительства(Объект.Партнер);
	
	Если ПараметрыОтображенияЭтаповСтроительства.ОтображатьЭтапыСтроительства Тогда
		Элементы.ПартнерАктивнаяФаза.Видимость = ПараметрыОтображенияЭтаповСтроительства.АктивнаяФазаЗаполнена ;
		Элементы.ПартнерДатаНачалаАктивнойФазы.Видимость = ПараметрыОтображенияЭтаповСтроительства.АктивнаяФазаЗаполнена ;
		
		Если ПараметрыОтображенияЭтаповСтроительства.ДатаНачалаАктивнойФазыУстарела Тогда
			Элементы.ПартнерДатаНачалаАктивнойФазы.ЦветТекста = WebЦвета.Красный;
		КонецЕсли;
		Элементы.НадписьДляДатыНачалаАктивнойФазы.Заголовок = ?(ПараметрыОтображенияЭтаповСтроительства.АктивнаяФазаЗаполнена , "", "нет активной фазы");
		Элементы.ГрФазаСтроительства.Видимость = Истина;
	Иначе
		Элементы.ГрФазаСтроительства.Видимость = Ложь;
	КонецЕсли;
	//+Этапы строительства
	
	Элементы.АдресДоставки.ТолькоПросмотр = Истина;
	
	Элементы.ГруппаСостояниеНомераТелефона.Видимость = АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Объект.Партнер) ИЛИ АльтерраОбщегоНазначения.ЭтоСотрудник(Объект.Партнер);
КонецПроцедуры

