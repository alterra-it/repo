&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	//// Обробатываем считанные штрихкоды
	////1. - начинается на 8888 - ставим менеджера
	////2. - начинается 21,22,23,24 - ставим карту лояльности
	////3. остальное подбор номенклатуры
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
						
			СтруктураДанных= МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
			Штрихкод= СокрЛП(СтруктураДанных.Штрихкод);
			Если Лев(Штрихкод, 4) = "8888" Тогда//1. Менеджер
				МенеджерСсылка = РСС_УправлениеОчередьюИСборкойЗаказов.ПоискПользователяПоШтрихкоду(Штрихкод);
				Если МенеджерСсылка <> Неопределено И МенеджерСсылка <> Объект.Менеджер Тогда
					Объект.Менеджер = МенеджерСсылка;	
					Модифицированность = Истина;
				КонецЕсли
			ИначеЕсли АльтерраОбщегоНазначенияКлиент.ЭтоШтрихкодКартыЛояльности(Штрихкод) Тогда //3. Карта лояльности
				КартыЛояльности = КартыЛояльностиВызовСервера.НайтиКартыЛояльностиПоШтрихкоду(Штрихкод);
				Если КартыЛояльности.ЗарегистрированныеКартыЛояльности.Количество() > 0 Тогда 
					КартаЛояльности= КартыЛояльности.ЗарегистрированныеКартыЛояльности[0];
					Если КартаЛояльности.Статус = АльтерраОбщегоНазначения.ПолучитьСтатусКартыЛояльностиДействует() Тогда
						Объект.КартаЛояльности= КартаЛояльности.Ссылка;
						КартаЛояльностиПриИзмененииНаСервере();
						СоглашениеПриИзменении(Неопределено);
						
						//158234
                        СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.КартаЛояльности");
                        Объект.СпособВводаКлиента = СпособВводаКлиента;
                        //158234
						
						Если Не ПустаяСтрока(ИнформацияПоПартнеру) Тогда 
							ПоказатьПредупреждение(, ИнформацияПоПартнеру, 5, "Внимание");
						КонецЕсли;
					Иначе
						ТекстСообщения = НСтр("ru = 'Карта со штрихкодом %1 аннулирована. Зарегистрируйте карту с помощью помощника регистрации карт лояльности'");
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Штрихкод), , "Объект.КартаЛояльности");
					конецесли;
				Иначе 
					ТекстСообщения = НСтр("ru = 'Карта со штрихкодом %1 не зарегистрирована. Карты регистрируются только с помощью помощника регистрации карт лояльности'");
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Штрихкод), , "Объект.КартаЛояльности");
				КонецЕсли;
			ИначеЕсли СтрДлина(Штрихкод) <= 30 Тогда //4. Номенклатура
				ОбработатьШтрихкоды(Штрихкод);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ИмяСобытия = "СчитанаКартаЛояльности"
		И Параметр.ФормаВладелец = УникальныйИдентификатор Тогда
		Объект.КартаЛояльности= Параметр.КартаЛояльности;
		КартаЛояльностиПриИзмененииНаСервере();
		СоглашениеПриИзменении(Неопределено);
		Если Не ПустаяСтрока(ИнформацияПоПартнеру) Тогда 
			ПоказатьПредупреждение(, ИнформацияПоПартнеру, 5, "Внимание");
		КонецЕсли;
		//158234
        СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.КартаЛояльности");
        Объект.СпособВводаКлиента = СпособВводаКлиента;
        //158234
	КонецЕсли;
	
	Если ИмяСобытия = "СчитанПартнер"	И Параметр.ФормаВладелец = УникальныйИдентификатор Тогда
		Объект.Партнер= Параметр.Партнер;
		ПартнерПриИзменении(Неопределено);				
		ИмяСобытия= "прервать";
		Если Не ПустаяСтрока(ИнформацияПоПартнеру) Тогда 
			ПоказатьПредупреждение(, ИнформацияПоПартнеру, 5, "Внимание");
		КонецЕсли;
		//158234
        СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.НомерТелефона");
        Объект.СпособВводаКлиента = СпособВводаКлиента;
        //158234
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПараметрыЗаполненияНалогообложенияНДСПродажи(Объект)
	ПараметрыЗаполнения = УчетНДСУПКлиентСервер.ПараметрыЗаполненияНалогообложенияНДСПродажи();
	
	ДанныеОбъекта = Объект;
//	ДанныеОбъекта = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект, "Организация,Договор,Склад,Дата,НаправлениеДеятельности,ХозяйственнаяОперация, Подразделение");
	
	ПараметрыЗаполнения.Организация = ДанныеОбъекта.Организация;
	ПараметрыЗаполнения.Дата = ДанныеОбъекта.Дата;
	ПараметрыЗаполнения.Склад = ДанныеОбъекта.Склад;
	ПараметрыЗаполнения.Договор = ДанныеОбъекта.Договор;
	ПараметрыЗаполнения.Подразделение = ДанныеОбъекта.Подразделение;
	
	ПараметрыЗаполнения.РеализацияТоваров = Истина;
	ПараметрыЗаполнения.РеализацияРаботУслуг = Истина;

	Возврат ПараметрыЗаполнения;
	
КонецФункции

&НаСервере
Процедура УстановитьНалогообложениеНДС()
	ПараметрыЗаполнения = ПараметрыЗаполненияНалогообложенияНДСПродажи(Объект);
	УчетНДСУП.ЗаполнитьНалогообложениеНДСПродажи(Объект.НалогообложениеНДС, ПараметрыЗаполнения, УчетНДСКэшированныеЗначенияПараметров);
КонецПроцедуры

#Область Штрихкоды
&НаСервере
Процедура КартаЛояльностиПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) Тогда
		Объект.Партнер= Объект.КартаЛояльности.Партнер;
		Объект.Контрагент= Объект.КартаЛояльности.Контрагент;
		Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
			Объект.Контрагент= АльтерраОбщегоНазначения.ПолучитьЕдинственногоКонтрагента(Объект.Партнер);
		КонецЕсли;
		Объект.Соглашение = АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
	КонецЕсли;
	
	ОчиститьБонусыСервер();
	//-пересчёт флажка СкидкиРассчитаны
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("РеализацияСверхЗаказа",            Истина);
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Ложь);
	СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры);
	//-
	ПоказатьИнформациюПоБонусам();
	ИнформацияПоПартнеру();
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкоды(Штрихкод)
	Если ЗначениеЗаполнено(Штрихкод) Тогда
		Количество=1;
		
		ДанныеТовара= ПолучитьНоменклатуруПоШК(Штрихкод);
		
		Если ЗначениеЗаполнено(ДанныеТовара) Тогда
			ПараметрыТовара = ПодборТоваровКлиентСервер.ПараметрыТовара(ДанныеТовара.Номенклатура);
			ЗаполнитьЗначенияСвойств(ПараметрыТовара, ДанныеТовара); 
			
			ПараметрыТовара.КоличествоУпаковок = Количество;
			ПараметрыТовара.Количество = Количество;
			ПараметрыТовара.ВидЦены = ВидЦены;
			если ЗапрашиватьКоличество тогда
				ВыбратьКоличество(ПараметрыТовара);
				
			иначе
				ДобавитьВКорзинуНаКлиенте(ПараметрыТовара, Истина);
			конецесли;
			
		Иначе
			Сообщить("Номенклатура по штрихкоду не найдена!");		
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНоменклатуруПоШК(Штрихкод)
	Рез= Новый Структура("Номенклатура,Характеристика");
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика КАК Характеристика,
	|	ШтрихкодыНоменклатуры.Упаковка КАК Упаковка
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод";
	
	если типзнч(Штрихкод)=тип("Структура") тогда
		Запрос.УстановитьПараметр("Штрихкод", Штрихкод.Штрихкод);
	иначе
		Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	конецесли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Выборка= РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, Выборка);
		Возврат Рез;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

&НаКлиенте
Процедура ПоискПоШтрихкодуВыполнить(Команда)
	
	ОчиститьСообщения();
	Оповещение = Новый ОписаниеОповещения("ПоискПоШтрихкодуЗавершение", ЭтотОбъект);
	ШтрихкодированиеНоменклатурыКлиент.ПоказатьВводШтрихкода(Оповещение);
	
