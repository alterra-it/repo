#Область Сделка
//Сохранить
&НаКлиенте
Процедура СохранитьСделку_Ожидание() Экспорт
	Если Объект.Товары.Количество() > 0 Тогда
		Сохранили = СохранитьСделкуНаСервере();
		
		Если Сохранили Тогда
			ПоказатьОповещениеПользователя(""+Объект.Сделка+" сохранена");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СохранитьСделку(Команда)
	СохранитьСделкуНаСервере(Истина);
КонецПроцедуры
&НаСервере
Функция СохранитьСделкуНаСервере(Принудительно = Ложь, Статус = Неопределено, ЗаполнятьДатуОкончания = Ложь)
	Если Не ЗначениеЗаполнено(Статус) Тогда
		Статус = Перечисления.СтатусыСделок.ВРаботе;
	КонецЕсли;
	
	Если Не Принудительно И Объект.Сделка.ПотенциальнаяСуммаПродажи = Объект.СуммаДокумента  Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Сделка) Тогда
		Сделка = Справочники.СделкиСКлиентами.СоздатьЭлемент();
		Сделка.ВалютаПервичногоСпроса = Объект.Валюта;
		Сделка.ВидСделки = Справочники.ВидыСделокСКлиентами.НайтиПоНаименованию("Продажа");
		Сделка.ДатаНачала = ТекущаяДата();
		Сделка.ВалютаПервичногоСпроса = Объект.Валюта;
		Сделка.Комментарий = "Создана из помощника продаж";
		Сделка.Ответственный =  Объект.Автор;
		Сделка.ПереведенаНаУправлениеВРучную = Истина;
		Сделка.ОбособленныйУчетТоваровПоСделке = Ложь;
	Иначе
		Сделка = Объект.Сделка.ПолучитьОбъект();
	КонецЕсли;
	
	Если ЗаполнятьДатуОкончания  Тогда
		Сделка.ДатаОкончания = ТекущаяДата();
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(Сделка, Объект);
	Сделка.СоглашениеСКлиентом = Объект.Соглашение;
	
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	Если не ЗначениеЗаполнено(Объект.Менеджер) Тогда 
		Объект.Менеджер = ТекущийПользователь;
	КонецЕсли;	
	
	Сделка.Менеджер = ТекущийПользователь;
	
	Сделка.Товары.Загрузить(Объект.Товары.Выгрузить());
	Сделка.СкидкиНаценки.Загрузить(Объект.СкидкиНаценки.Выгрузить());
	Сделка.БонусныеБаллы.Загрузить(Объект.БонусныеБаллы.Выгрузить());
	Сделка.Нарезка.Загрузить(Объект.Нарезка.Выгрузить());
	
	Сделка.ПотенциальнаяСуммаПродажи = Объект.СуммаДокумента;
	
	//Название сделки
	Сделка.Наименование = "";
	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		Сделка.Наименование = Сделка.Наименование + Объект.Партнер.Наименование + " ";
	КонецЕсли;
	Сделка.Наименование = Сделка.Наименование
	+ Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy")
	+ " на сумму: " + Сделка.ПотенциальнаяСуммаПродажи;
	
	Сделка.Статус = Статус;
	
	Сделка.Записать();
	
	Объект.Сделка = Сделка.Ссылка;
	
	Возврат Истина;
КонецФункции
//Загрузить
&НаКлиенте
Процедура СделкаПриИзменении(Элемент)
	Инициировать();
	ИнициироватьНаКлиенте();
	
	ЗаполнитьПоСделкеНаСервере();
	
	ПересчитатьСтрокиКорзины();
	
	РассчитатьИтоги();
	
	Если Объект.Документы.Количество() > 0 Тогда
		ПерейтиКОформлению();
	Иначе
		КПодбору(Неопределено);
	КонецЕсли;
	
	УстановитьВидимостьНовигации();
	ПодборИНН();
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьПоСделкеНаСервере()
	ЗаполнитьЗначенияСвойств(Объект, Объект.Сделка,,"Автор,Менеджер,Ссылка,Товары,СкидкиНаценки,БонусныеБаллы,Нарезка");
	
	Объект.Соглашение= Объект.Сделка.СоглашениеСКлиентом;
	Объект.Дата= Объект.Сделка.ДатаНачала;
	
	Объект.Товары.Загрузить(Объект.Сделка.Товары.Выгрузить());
	Объект.СкидкиНаценки.Загрузить(Объект.Сделка.СкидкиНаценки.Выгрузить());
	Объект.БонусныеБаллы.Загрузить(Объект.Сделка.БонусныеБаллы.Выгрузить());
	Объект.Нарезка.Загрузить(Объект.Сделка.Нарезка.Выгрузить());
	
	ВывестиИнформацию();
	
	ПроверитьВозможностьУдаленияДокументов();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокДокументовПоСделкеНаСервере()
	
	Объект.Документы.Очистить();
	
	Если Не ЗначениеЗаполнено(Объект.Сделка) Тогда
		Инициировать();
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыПоСделке.Ссылка КАК Ссылка
	|ИЗ
	|	КритерийОтбора.ДокументыПоСделке(&Сделка) КАК ДокументыПоСделке
	|ГДЕ
	|	ДокументыПоСделке.Ссылка.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументыПоСделке.Ссылка.Дата";
	
	Запрос.УстановитьПараметр("Сделка", Объект.Сделка);
	РезультатЗапроса = Запрос.Выполнить();
	
	СсылкиКУдалению = Новый Массив;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СсылкиКУдалению.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Для Каждого стрДокумента Из Объект.Документы Цикл
		СсылкиКУдалению.Добавить(стрДокумента.Документ);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Объект.Сделка) Тогда
		СсылкиКУдалению.Добавить(Объект.Сделка);
	КонецЕсли;
	
	УникальныеСсылки = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(УникальныеСсылки, СсылкиКУдалению, Истина);
	
	//СписокСсылок = НайтиПоСсылкам(УникальныеСсылки);
	//СписокСсылок.Свернуть("Данные, Метаданные");
	
	Для Каждого стрДокумента Из УникальныеСсылки Цикл
		Если Общегоназначения.ЭтоДокумент(стрДокумента.Метаданные()) Тогда
			ДобавитьВДокументы(стрДокумента);
		КонецЕсли;
	КонецЦикла;		
КонецПроцедуры

Процедура ПроверитьВозможностьУдаленияДокументов()
		
	ЗаполнитьСписокДокументовПоСделкеНаСервере();
	
