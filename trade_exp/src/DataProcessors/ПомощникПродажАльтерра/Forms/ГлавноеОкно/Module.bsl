&НаСервере
Процедура ПартнерПриИзмененииНаСервере()
	
	Объект.Контрагент = АльтерраОбщегоНазначения.ПолучитьЕдинственногоКонтрагента(Объект.Партнер);
	Если Объект.Партнер = Справочники.Партнеры.РозничныйПокупатель Тогда
		Объект.Контрагент = Справочники.Контрагенты.РозничныйПокупатель;
	КонецЕсли;
	Объект.БанковскийСчетКонтрагента = ЗначениеНастроекПовтИсп.ПолучитьБанковскийСчетКонтрагентаПоУмолчанию(Объект.Контрагент);
	Объект.КартаЛояльности = АльтерраОбщегоНазначения.ПолучитьКартуЛояльности(Объект.Партнер);
	Объект.Соглашение = АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		СведеньяОКлиенте = АльтерраОбщегоНазначения.ПолучитьСведеньяОПартнере(Объект.Партнер);
		Объект.ФИОКлиента =  Объект.Партнер.Наименование;
		Объект.АдресДоставки =  СведеньяОКлиенте.ФактическийАдрес;
		Объект.ТелефонКлиента =  СведеньяОКлиенте.ТелефонПартнера;
		Объект.СостояниеНомераТелефона = Объект.Партнер.СостояниеНомераТелефона;
		Объект.КартаДруга = Ложь;
	КонецЕсли;
	
	ОчиститьБонусыСервер();
	
	ПересчитатьЦеныУстановитьПараметрыДоступностьСервер();
	
	НачислитьБонусныеБаллы();
	ПоказатьИнформациюПоБонусам();
	
	ИнформацияПоПартнеру();
	
КонецПроцедуры

