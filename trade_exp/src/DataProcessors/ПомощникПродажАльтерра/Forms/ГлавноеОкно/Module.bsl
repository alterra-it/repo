&НаСервере
Функция ПроверитьОбъектДоставки()
	Если Объект.НужнаДоставка И ЗначениеЗаполнено(Объект.Партнер) Тогда   
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбъектыДоставки.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ОбъектыДоставки КАК ОбъектыДоставки
		|ГДЕ
		|	НЕ ОбъектыДоставки.ПометкаУдаления
		|	И ОбъектыДоставки.Владелец = &Владелец";
		Запрос.УстановитьПараметр("Владелец",Объект.Партнер);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() Тогда    
			Объект.ОбъектДоставки = Выборка.Ссылка;  
			ОбъектДоставкиПриИзмененииНаСервере();  
			Элементы.ОбъектДоставки.Доступность = Истина;
			Возврат Истина;
		Иначе
			Элементы.ОбъектДоставки.Доступность = Ложь;  
			Возврат Ложь;
		КонецЕсли;
	Иначе
		Возврат Ложь;
	КонецЕсли;	
КонецФункции


