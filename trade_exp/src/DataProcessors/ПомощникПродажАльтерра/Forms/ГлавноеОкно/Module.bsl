&НаКлиенте
Процедура СоздатьПКО(Команда)
	ИмяДокумента= АльтерраОбщегоНазначения.ИмяОбъекта(ТипЗнч(Элементы.Документы.ТекущиеДанные.Документ));
	
	Если ИмяДокумента <> "ЧекККМ" Тогда
		ДокОснование = Новый Структура;  
		ДокОснование.Вставить("Основание", Элементы.Документы.ТекущиеДанные.Документ);
		ОткрытьФорму("Документ.ПриходныйКассовыйОрдер.ФормаОбъекта", ДокОснование); 
	Иначе
		Сообщить("На основании чека ККМ нельзя создавать ПКО")
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьЭО(Команда)
	ИмяДокумента= АльтерраОбщегоНазначения.ИмяОбъекта(ТипЗнч(Элементы.Документы.ТекущиеДанные.Документ));
	
	Если ИмяДокумента <> "ЧекККМ" Тогда
		Если ПроверитьОткрытиеСмены() Тогда	
			ДокОснование = Новый Структура;
			ДокОснование.Вставить("Основание", Элементы.Документы.ТекущиеДанные.Документ);
			ОткрытьФорму("Документ.ОперацияПоПлатежнойКарте.ФормаОбъекта", ДокОснование);
		КонецЕсли; 
	Иначе
		Сообщить("На основании чека ККМ нельзя создавать ЭО")  
	КонецЕсли;
КонецПроцедуры  

