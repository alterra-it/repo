&НаСервере
Процедура ОбновитьДанныеПоСтроке();
	
	Строка = Объект.Товары.НайтиПоИдентификатору(Элементы.Корзина1.ТекущаяСтрока);
	
	Если БонусыАльтерраРезерв.ЗапрещеноИспользоватьБонусы(Строка)
		ИЛИ Строка.СуммаБонусныхБалловКСписанию > Строка.Сумма
	Тогда
		Строка.СуммаБонусныхБалловКСписанию = 0;
		Строка.СуммаБонусныхБалловКСписаниюВВалюте = 0;
	КонецЕсли;
	
	Строка.СуммаНачисленныхБонусныхБалловВВалюте = 0;
	
	БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, Строка);
	
	Объект.КОплатеБаллами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
КонецПроцедуры

