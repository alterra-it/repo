//Этапы строительства+
&НаСервере
Функция  ПолучитьПараметрыОтображенияЭтаповСтроительства(Партнер) 
	ПараметрыОтображения = Новый Структура;
	ПараметрыОтображения.Вставить("ОтображатьЭтапыСтроительства", АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Партнер));
	ПараметрыОтображения.Вставить("АктивнаяФазаЗаполнена", ЗначениеЗаполнено(Партнер.АктивнаяФаза));
	ПараметрыОтображения.Вставить("ДатаНачалаАктивнойФазыУстарела", ДобавитьМесяц(Партнер.ДатаНачалаАктивнойФазы, 3) <= НачалоДня(ТекущаяДата())); 	
	Возврат ПараметрыОтображения;
КонецФункции
