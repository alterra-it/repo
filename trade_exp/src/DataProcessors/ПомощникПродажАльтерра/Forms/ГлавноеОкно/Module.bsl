&НаСервере
Процедура ОбъектДоставкиПриИзмененииНаСервере()		
	
	Если ЗначениеЗаполнено(Объект.ОбъектДоставки) Тогда
		ОбъектДоставки = Объект.ОбъектДоставки;
		ЗаполнитьЗначенияСвойств(Объект,ОбъектДоставки, , "Ссылка, Автор");
		Объект.АдресДоставки = ОбъектДоставки.Адрес; 
		
		Если ЗначениеЗаполнено(ОбъектДоставки.ТелефонНаВыгрузке) Тогда
			Объект.ТелефонКлиентаНаВыгрузке = ОбъектДоставки.ТелефонНаВыгрузке;
		КонецЕсли;  
		
		Если Не Объект.ТарифВРучную Тогда
			УстановитьТарифСервер();
		КонецЕсли;
		
		УстановитьСтоимостиДляКлиента(); 
		
		//Добавляем услугу
		УдалитьУслугиДоставки();
		Если НЕ ЗначениеЗаполнено(Объект.Акция) Тогда
			НоваяСтрокаИд = ДобавитьУслугуДоставки();
			ПересчитатьЦеныВСтрокеКорзиныНаСервере(Объект.Товары.НайтиПоИдентификатору(НоваяСтрокаИд));
		КонецЕсли;
		НачислитьБонусныеБаллы(); 
		
	КонецЕсли;   
	
КонецПроцедуры

