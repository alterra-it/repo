&НаКлиенте
Процедура ДобавитьКлассВЗапросПриИзменении(Элемент)
	
	Если ДобавитьКлассВЗапрос Тогда
		ДобавитьКлассВЗапросПриИзмененииНаСервере();
	Иначе
