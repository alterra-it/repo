КонецПроцедуры

&НаСервере
Процедура ДобавитьСрокиОтПоставщикаПриИзмененииНаСервере()
	
	Если ДобавитьСрокиОтПоставщика Тогда
		СхемаЗапросаСрокиПоставки = Новый СхемаЗапроса;
		СхемаЗапросаСрокиПоставки.УстановитьТекстЗапроса(СписокНоменклатура.ТекстЗапроса);
		ПакетЗапросовСрокиПоставки = СхемаЗапросаСрокиПоставки.ПакетЗапросов[СхемаЗапросаСрокиПоставки.ПакетЗапросов.Количество()-1];
		ОператорСрокиПоставки = ПакетЗапросовСрокиПоставки.Операторы[0];
		РегистрСрокиПоставщика = ОператорСрокиПоставки.Источники.Добавить("РегистрСведений.СрокиПоставкиТовараОтПоставщика.СрезПоследних", "СрокиПоставкиТовараОтПоставщикаСрезПоследних");
		РегистрСрокиПоставщика.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.ПравоеВнешнее;
		РегистрСрокиПоставщика.Источник.Параметры[1].Выражение = Новый ВыражениеСхемыЗапроса("Подразделение = &Подразделение");
		ОператорСрокиПоставки.ВыбираемыеПоля.Добавить("СрокиПоставкиТовараОтПоставщикаСрезПоследних.МинимальныйСрокПоставки");
		ТекстЗапросаСрокиПоставки = СхемаЗапросаСрокиПоставки.ПолучитьТекстЗапроса();	
		СписокНоменклатура.ТекстЗапроса = СтрЗаменить(ТекстЗапросаСрокиПоставки, "СрокиПоставкиТовараОтПоставщикаСрезПоследних.МинимальныйСрокПоставки КАК МинимальныйСрокПоставки",
			"ВЫБОР КОГДА (СрокиПоставкиТовараОтПоставщикаСрезПоследних.МинимальныйСрокПоставки > 0
			|И СрокиПоставкиТовараОтПоставщикаСрезПоследних.МаксимальныйСрокПоставки > 0)
			|ТОГДА СТРОКА(СрокиПоставкиТовараОтПоставщикаСрезПоследних.МинимальныйСрокПоставки) + "" - "" + СТРОКА(СрокиПоставкиТовараОтПоставщикаСрезПоследних.МаксимальныйСрокПоставки)
			|ИНАЧЕ """" КОНЕЦ КАК ОтПоставщика");
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Подразделение", Объект.Склад.Подразделение);
	
		Если Элементы.Найти("СписокНоменклатураОтПоставщика") = Неопределено Тогда
			
			КолонкаОтПоставщика = Элементы.Добавить("СписокНоменклатураОтПоставщика", Тип("ПолеФормы"), Элементы.СписокНоменклатура);
			КолонкаОтПоставщика.ПутьКДанным = "СписокНоменклатура.ОтПоставщика";
			КолонкаОтПоставщика.Заголовок = "От поставщика";
			КолонкаОтПоставщика.Ширина = 10;
		КонецЕсли;	
	Иначе
		МодифицироватьЗапрос();
	КонецЕсли;
	Элементы.СписокНоменклатураОтПоставщика.Видимость = ДобавитьСрокиОтПоставщика;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьПеремещениеСФилиалаПриИзмененииНаСервере()

	Элементы.ДатаПеремещения.Заголовок = "  ";
	Если ПеремещениеСФилиала <> Справочники.СтруктураПредприятия.ПустаяСсылка() И Объект.Склад <> Справочники.СтруктураПредприятия.ПустаяСсылка() Тогда
		НастройкиМатрицыПеремещений = ПолучитьНастройкиМатрицыПеремещений();
		Если НастройкиМатрицыПеремещений <> Ложь Тогда
			ОтборПоМатрице = Новый Структура ("ПодразделениеОткуда, ПодразделениеКуда", ПеремещениеСФилиала, Объект.Склад.Подразделение);
			МассивСтрок =  НастройкиМатрицыПеремещений.НайтиСтроки(ОтборПоМатрице);
			Если ЗначениеЗаполнено(МассивСтрок) Тогда
				СегодяняшнееЧисло = ТекущаяДата();
				НазваниеДняНедели = Формат(СегодяняшнееЧисло, "ДФ = дддд");
			    КоличествоДнейДоставки = МассивСтрок[0][НазваниеДняНедели];
			    Если КоличествоДнейДоставки > 0 Тогда
			    	Элементы.ДатаПеремещения.Заголовок = Формат((СегодяняшнееЧисло + КоличествоДнейДоставки*24*3600), "ДФ=dd.MM.yyyy");
				КонецЕсли
			КонецЕсли;	 
		КонецЕсли
	КонецЕсли	

КонецПроцедуры

&НаСервере
Функция ПолучитьНастройкиМатрицыПеремещений()
		
	ХранилищеСсылка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Матрица доставки настройки");
	НастройкиХранилища = ХранилищеСсылка.ХранилищеНастроек.Получить(); 
	    	
	Если НастройкиХранилища	<> Неопределено Тогда      	
		Возврат  НастройкиХранилища.НастройкиМатрицыДоставки;
	Иначе
		Сообщить("Не удалось получить матрицу доставки. Обратитесь в ИТ отдел.");	
		Возврат Ложь;
	КонецЕсли	 
		
КонецФункции 

