
&НаКлиенте
Процедура СделкаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ПараметрыОткрытия = Новый Структура("ОтборПоДате", Истина); 	
	Если Не ПартнерПустаяСсылка() Тогда
		Если НЕ Строка(Объект.Партнер) = "РОЗНИЦА" Тогда
			СвойМассивЗначений = Объект.Партнер;
			ПараметрыОтбора = Новый Структура("Партнер", СвойМассивЗначений);
			ПараметрыОткрытия.Вставить("Отбор", ПараметрыОтбора); 
		КонецЕсли;
	КонецЕсли;

	Форма = ПолучитьФорму("Справочник.СделкиСКлиентами.Форма.ФормаВыбора", ПараметрыОткрытия,Элемент, ЭтаФорма);
	Отбор = Форма.Список.КомпоновщикНастроек.Настройки.Отбор.Элементы;

	Форма.Список.КомпоновщикНастроек.ЗагрузитьНастройки(Форма.Список.КомпоновщикНастроек.Настройки);
	
	ЭлементыПользовательскихНастроек = Форма.Список.КомпоновщикНастроек.ПользовательскиеНастройки.Элементы;
	
	Для Каждого НастройкаСписка Из ЭлементыПользовательскихНастроек Цикл

        Если ТипЗнч(НастройкаСписка) = ТипЗнч(Форма.Список.КомпоновщикНастроек.Настройки.Порядок) Тогда
			НастройкаСписка.Элементы.Очистить();
			
            СортировкаПоДате 					= НастройкаСписка.Элементы.Добавить(Тип("ЭлементПорядкаКомпоновкиДанных"));
            СортировкаПоДате.Поле 				= Новый ПолеКомпоновкиДанных("ДатаНачала");
            СортировкаПоДате.ТипУпорядочивания 	= НаправлениеСортировкиКомпоновкиДанных.Убыв;
            СортировкаПоДате.Использование 		= Истина;
        КонецЕсли;
	КонецЦикла;

	Форма.Открыть();
КонецПроцедуры

&НаСервере 
Функция ПартнерПустаяСсылка()
	Возврат Объект.Партнер = Справочники.Партнеры.ПустаяСсылка();
КонецФункции


&НаКлиенте
Процедура ДобавитьДокументы(Команда)
	ДобавитьДокументыЗавершение = Новый ОписаниеОповещения("ДобавитьДокументыЗавершение", ЭтаФорма);		
	ПараметрыФормы = Новый Структура("ОснованияДоставки", Объект.ОснованияДоставки);
	ОткрытьФорму("Обработка.ПомощникПродажАльтерра.Форма.ОснованияДоставки",ПараметрыФормы,ЭтаФорма,,,,ДобавитьДокументыЗавершение);	
КонецПроцедуры  

&НаКлиенте
Процедура ДобавитьДокументыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	ДобавитьДокументыЗавершениеНаСервере(Результат);
	РассчитатьИтоги();
	АвтоопределениеТарифа(); 
	Если Объект.ДоставкаСРазгрузкой И (ЗначениеЗаполнено(Объект.СтоимостьДоставкиСНДС)ИЛИ ЗначениеЗаполнено(Объект.СтоимостьДоставки))Тогда 
		  Объект.ВариантРазгрузки = ПредопределенноеЗначение("Справочник.ВариантыРазгрузкиКлиента.ПустаяСсылка");
		Если Объект.ОснованияДоставки.Количество() = 0 Тогда
			Объект.СтоимостьРазгрузкиДляКлиента = 0;
	        Объект.СтоимостьРазгрузкиДляВодителя = 0;
			   ДобавитьУслугуРазгрузки();
		КонецЕсли;
	       ОткрытьФорму("Обработка.КартографическийИнтерфейсДоставка.Форма.НастройкаПараметровРазгрузки",Новый Структура("ПараметрыРазгрузкиАдресВХранилище",ПолучитьАдресПараметровРазгрузки()),ЭтаФорма,,,,Новый ОписаниеОповещения("ЗакрытиеФормыНастройкиПараметровЗагрузки",ЭтотОбъект));
	       Сообщить("Товары могли измениться, проверьте параметры разгрузки");	    
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Корзина1ВидЦеныОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	ПроверкаРоли = ПроверкиАльтерраСервер.РазрешенПроизвольныйВидЦеныКоммерческоеПредложение();
	ТекущаяСтрока = Элементы.Корзина1.ТекущиеДанные;
	Если НЕ ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Если НЕ ПроверкаРоли Тогда
			Сообщить("Недостаточно прав для установки произвольных цен");
			Возврат
		КонецЕсли;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Если НЕ РежимОфрмления = "Коммерческое" Тогда
			Сообщить("Произвольные цены разрешины только для создания коммерческого предложения");
			Возврат
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СдачаПриИзменении(Элемент)
	Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
КонецПроцедуры

&НаСервере
Процедура ДобавитьДокументыЗавершениеНаСервере(Результат) 
	Если Результат <> Неопределено Тогда
		Объект.ОснованияДоставки.Загрузить(Результат.ОснованияДоставки.Выгрузить());
	КонецЕсли;
	
	Если Объект.ОснованияДоставки.Количество() > 0 Тогда
		Объект.ТоварыДляДоставки.Загрузить(ПолучитьТоварыДляДоставки());	
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьЗапросКлиента(Команда)
	Если ПустаяСтрока(ЗапросКлиента) Тогда
		ПоказатьПредупреждение(Неопределено,Нстр("ru = 'Не заполнен Запрос клиента'"))
	Иначе
		ОтправитьЗапросКлиентаНаСервере();
		ЗапросКлиента = "";
	КонецЕсли;
КонецПроцедуры
&НаСервере
Процедура ОтправитьЗапросКлиентаНаСервере()
	Автор = Пользователи.ТекущийПользователь();
	Подраздаление = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Автор, Неопределено);
	Сотрудник = АльтерраОбщегоНазначения.ПолучитьСотрудника(Автор);
	МенеджерЗаписи = РегистрыСведений.ЗапросыКлиентов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Пользователь = Автор;
	МенеджерЗаписи.Запрос = ЗапросКлиента;
	МенеджерЗаписи.Период = ТекущаяДата();
	МенеджерЗаписи.Отдел = Сотрудник.Отдел;
	МенеджерЗаписи.Подразделение = Подраздаление;
	МенеджерЗаписи.Записать();
КонецПроцедуры

#Область СобытияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	
	Инициировать();
	
	Если Параметры.Свойство("Сделка") Тогда
		Если ЗначениеЗаполнено(Параметры.Сделка) Тогда
			Объект.Сделка = Параметры.Сделка;
			ЗаполнитьПоСделкеНаСервере();
		КонецЕсли;
	КонецЕсли;
	
	Если РольДоступна("ВидетьВсеЦены") ИЛИ РольДоступна("ПолныеПрава")  Тогда
		Элементы.СписокНоменклатураКонтекстноеМенюПосмотретьВсеЦены.Видимость = Истина;
	Иначе
		Элементы.СписокНоменклатураКонтекстноеМенюПосмотретьВсеЦены.Видимость = Ложь;
	КонецЕсли;
	
	ДоступностьЦены = Истина;
	Если РольДоступна("ЗапретИзменениеВидаЦеныВДокументе") Тогда
		Если Не Объект.Склад.ЭтоГруппа	тогда
			ДоступностьЦены = Не Объект.Склад.неРазрешеноРедактированиеЦены;
		КонецЕсли;
	конецесли;	
	Элементы.Корзина1ВидЦены.Доступность = ДоступностьЦены ;
	
	Если НЕ ЗначениеЗаполнено(Объект.Партнер) ИЛИ Строка(Объект.Партнер) = "РОЗНИЦА" Тогда
		Элементы.НезакрытыеЗаказыЧекиЗначение.Видимость = Ложь;		
	КонецЕсли;
	Элементы.ДоставкаРазгрузка.Доступность = УправлениеЛогистикойСервер.РасчетРазгрузкиДействуетНаДату(ТекущаяДата());
	ЕстьБлокировкаУслуги=АльтерраОбщегоНазначения.ЕстьБлокировкаУслуги(ТекущаяДата());
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДобавитьУслугуДоставки", "Видимость", НЕ ЕстьБлокировкаУслуги);
	
	ПодборИНН();
	
	НовыйПорядокНачисленияБонусов = БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Объект);
	УстановитьУсловноеОформлениеПолей();
	КолонкаИнтерфейса = Элементы.Корзина1СтатусПроверкиГосИС;
	КолонкаИнтерфейса.Вид = ВидПоляФормы.ПолеКартинки;
	КолонкаИнтерфейса.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	КолонкаИнтерфейса.КартинкаЗначений = БиблиотекаКартинок.МаркируемаяПродукцияТЧ;
	КолонкаИнтерфейса.КартинкаШапки = БиблиотекаКартинок.МаркируемаяПродукцияШапка;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	
	Если  ЗначениеЗаполнено(Объект.Сделка) Тогда
		РассчитатьИтоги();
		
		УстановитьВидимостьНовигации();
		ПерейтиКОформлению();
	Иначе
		ИнициироватьНаКлиенте();
	КонецЕсли; 
	ПодключитьОбработчикОжидания("СохранитьСделку_Ожидание", 60, Ложь); 
	//АвтоопределениеДистрибуция
	УстановитьВидимостьРеквизитовДоставкиДистрибуция();
	//
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПолей()
	
	ИменаПолей = Новый Массив;
	ИменаПолей.Добавить("Корзина1СуммаБонусныхБалловКСписанию");
	ИменаПолей.Добавить("Корзина1СуммаНачисленныхБонусныхБалловВВалюте");
	
	Для каждого ИмяПоля Из ИменаПолей Цикл
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли; 
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.СуммаРучнойСкидки");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
		ОтборЭлемента.ПравоеЗначение = 0;
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.ВидЦены");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ОтборЭлемента.ПравоеЗначение = Справочники.ВидыЦен.ПустаяСсылка();
		
		Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоРозовый);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)   
	Если ЗавершениеРаботы Тогда 
		Отказ= Истина;
	ИначеЕсли Не ЗакрытьОбработку Тогда
		Отказ= Истина;
		СтандартнаяОбработка= Ложь;
		ОбработатьОтветОЗакрытии= Новый ОписаниеОповещения("ОбработатьОтветОЗакрытии", ЭтаФорма);
		ПоказатьВопрос(ОбработатьОтветОЗакрытии, "Вы уверены, что хотите закрыть 'Помощник продаж'?", РежимДиалогаВопрос.ДаНет, 10, КодВозвратаДиалога.Нет, "Закрыть Помощник продаж?", КодВозвратаДиалога.Нет);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОтветОЗакрытии(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗакрытьОбработку= Истина;
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтотОбъект);	
КонецПроцедуры

&НаСервере
Процедура Инициировать()
	УстановитьНачальныеЗначения();
	
	НоваяПродажаНаСервере();
КонецПроцедуры

&НаСервере
Процедура УстановитьНачальныеЗначения()
	
	//Служебные
	Автор = Пользователи.ТекущийПользователь();
	
	ОтображатьОстатки = Истина;
	ИспользоватьРасширеннуюФормуПодбораКоличестваИВариантовОбеспечения = Ложь;
	РежимПодбораБезСуммовыхПараметров = Ложь;
	ВариантПоискаТоваров = "ПоУмолчанию";
	ТекущаяСтраница = "Подбор";
	ИспользоватьСтандартныйПоискПриПодбореТоваров = Истина;
	ПоказыватьИерархию = Ложь;
	Элементы.ПодборИерархия.Видимость = ПоказыватьИерархию;
	ПоказыватьСекцию2 = Ложь;
	Элементы.ПодборСекция2.Видимость = ПоказыватьСекцию2;
	ПоказыватьАналоги = Истина;
	ПоказыватьФильтры = Ложь;
	Элементы.Фильтры.Видимость = Ложь;
	Элементы.ДействияФильтров.Видимость = Ложь;
	ПоказыватьСопутку = Истина;
	ПоказыватьСписокЦен = ?(РольДоступна("ВидетьВсеЦены") или РольДоступна("ПолныеПрава"), Истина, Ложь);
	ТолькоВНаличии = Ложь;
	Объект.Валюта = Константы.ВалютаРегламентированногоУчета.Получить();
	Валюта = Объект.Валюта;
	Объект.Автор = Автор;
	Объект.ЦенаВключаетНДС = Истина;
	Объект.ВернутьМногооборотнуюТару = Ложь;
	СегментНоменклатуры = Справочники.СегментыНоменклатуры.НайтиПоНаименованию("ТЗ подбор ОБЩИЙ", Истина);	
	Объект.Ссылка = Документы.ЗаказКлиента.ПустаяСсылка();
	РежимОфрмления = "Продажа";
	Элементы.ВидЦены.Доступность = Ложь;
	Объект.Магазин = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Автор, Неопределено);
	
	Элементы.ТипДанныхПоиска.ТолькоПросмотр = Ложь;
	Элементы.ТипДанныхПоиска.СписокВыбора.Очистить();
	Элементы.ТипДанныхПоиска.РежимВыбораИзСписка = Истина;
	Элементы.ТипДанныхПоиска.СписокВыбора.Добавить("Наименование");
	Элементы.ТипДанныхПоиска.СписокВыбора.Добавить("Артикул");
	Элементы.ТипДанныхПоиска.СписокВыбора.Добавить("Код");
	ТипДанныхПоиска = "Наименование";
	
	НачальноеВремя = ПолучитьВремяСПоправкойНаИнтервал(); 
	ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС, НачальноеВремя, Объект.Интервал.ВремяПо);
	ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо, НачальноеВремя, Объект.Интервал.ВремяПо);
	
	//Настройки запроса
	//ВариантыЗапросов = "ЦеныПоВидуЦен";
	ДобавитьКлассВЗапрос = Истина;
	Элементы.СписокНоменклатураКласс.Видимость = ДобавитьКлассВЗапрос;
	Если Элементы.Найти("СписокНоменклатураОтПоставщика") = Неопределено Тогда
		ДобавитьСрокиОтПоставщика = Ложь;
	Иначе
		Элементы.СписокНоменклатураОтПоставщика.Видимость = ДобавитьСрокиОтПоставщика;	
	КонецЕсли;
	
	//АвтоопределениеДистрибуция
	Если НЕ Элементы.Найти("СписокВидТовараДляДоставки") = Неопределено Тогда
	    Элементы.СписокВидТовараДляДоставки.Видимость = Объект.РаспределитьТранспортныеДистрибуция;	
    КонецЕсли;
	//
	
	ПереключательСопутствующиеКомплектующие = 1;  
	ПереключательАналогиФильтры				= 1;
	
	ЗаполнитьРеквизитыПродажи();
	ОрганизацияПриИзмененииНаСервере();  
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыПродажи()
	Объект.Подразделение = Объект.Автор.Подразделение;
	
	АльтерраОбщегоНазначения.ЗаполнитьРеквизитыПродажи(Объект);
	Объект.Грузоотправитель = Объект.Склад.Грузоотправитель;
	
	//Заполнение партнера по умолчанию
	ПартнерПоУмолчанию = Объект.Подразделение.ПартнерПоУмолчанию;
	Если ЗначениеЗаполнено(ПартнерПоУмолчанию) И Не Объект.Партнер = ПартнерПоУмолчанию Тогда
		Объект.Партнер = ПартнерПоУмолчанию;
		Объект.Контрагент = АльтерраОбщегоНазначения.ПолучитьЕдинственногоКонтрагента(Объект.Партнер);
		Объект.Соглашение = АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
	КонецЕсли;
	
	ОрганизацияПриИзмененииНаСервере();
	ВидЦены = Объект.Подразделение.ЦенаПоКарте;
	
	ЗаполнитьЗначенияСвойств(Объект, Объект.Соглашение, "ГрафикОплаты,ПорядокРасчетов");
КонецПроцедуры

&НаСервере
Процедура НоваяПродажаНаСервере()
	//Автоопеделение
	Если Объект.НужнаДоставка Тогда
		Объект.ЗонаДоставкиДляВодителя = Справочники.ЗоныДоставкиДоКлиента.ПустаяСсылка();
		Объект.Тариф = Справочники.ТарифыПеревозчиков.ПустаяСсылка();
		Объект.СтоимостьДоставки = 0;
		Объект.СтоимостьДоставкиСНДС = 0;
		//АвтоопределениеДистрибуция
		Если Объект.РаспределитьТранспортныеДистрибуция Тогда	
			Объект.РаспределитьТранспортныеДистрибуция = Ложь;
			ДобавитьУбратьВидТовараДляДоставки();
		КонецЕсли;
		//
	КонецЕсли;
	
	ЗаполнитьРеквизитыПродажи();                                              
	Объект.СостояниеЗаполненияМногооборотнойТары = Перечисления.СостоянияЗаполненияМногооборотнойТары.ПредлагатьЗаполнить;
	
	ЗаполнитьСклады();                                        
	ЗаполнитьВидыЦен();
	ПоказатьИнформациюПоБонусам();
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
	СписокНоменклатура,
	"Номенклатура",
	Неопределено,
	Истина);
	ЗаполнитьФильтрыСервер();
		
	Объект.Акция = Справочники.МаркетинговыеМероприятия.ПустаяСсылка();
	
	УстановитьСвязьПараметровВыбораДляАкции();
	
	
	СопутствующиеТовары.Очистить();  
	КомплектующиеТовары.Очистить();
	УправляемыеСкидки.Очистить();
	Объект.ОснованияДоставки.Очистить();
КонецПроцедуры

