&НаКлиенте
Процедура ПараметрыРазгрузки(Команда)
	
	ОткрытьФорму("Обработка.КартографическийИнтерфейсДоставка.Форма.НастройкаПараметровРазгрузки",Новый Структура("ПараметрыРазгрузкиАдресВХранилище",ПолучитьАдресПараметровРазгрузки()),ЭтаФорма,,,,Новый ОписаниеОповещения("ЗакрытиеФормыНастройкиПараметровЗагрузки",ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытиеФормыНастройкиПараметровЗагрузки(Результат, Параметры) Экспорт
	
	Если Результат <> Неопределено Тогда
		Если Результат.ДоставкаСРазгрузкой И Результат.ДоставкаСРазгрузкой <> Объект.ДоставкаСРазгрузкой Тогда 
			Объект.Интервал = Неопределено; 
			Объект.Тариф = Неопределено;
			ИнтервалПриИзмененииСервер(); 
		КонецЕсли; 
		ЗаполнитьЗначенияСвойств(Объект, Результат);
		Если Результат.РучнаяКорректировкаВариантовРазгрузки И ЗначениеЗаполнено(Результат.ВариантыРазгрузкиВРучнуюАдресВХранилище) Тогда
			ЗаполнитьВариантыРазгрузкиВРучную(Результат.ВариантыРазгрузкиВРучнуюАдресВХранилище);
		Иначе
			Объект.ВариантыРазгрузкиВРучную.Очистить();
		КонецЕсли;
	КонецЕсли; 
	
	 Если ЗначениеЗаполнено(Объект.СтоимостьДоставкиСНДС)ИЛИ ЗначениеЗаполнено(Объект.СтоимостьДоставки)Тогда
			ДобавитьУслугуРазгрузки();
	 КонецЕсли;	
КонецПроцедуры  

&НаСервере
Процедура ЗаполнитьВариантыРазгрузкиВРучную(ВариантыРазгрузкиВРучнуюАдресВХранилище) 
	
	Объект.ВариантыРазгрузкиВРучную.Загрузить(ПолучитьИзВременногоХранилища(ВариантыРазгрузкиВРучнуюАдресВХранилище));
	
КонецПроцедуры

&НаСервере
Функция ПолучитьАдресПараметровРазгрузки()
	
	ПараметрыРазгрузки = УправлениеЛогистикойСервер.ПолучитьСтруктуруПараметровРазгрузки();
	ЗаполнитьЗначенияСвойств(ПараметрыРазгрузки, Объект, "Этаж, НомерКвартиры, ВариантРазгрузки, НаличиеПандуса, РучнаяКорректировкаВариантовРазгрузки");
	
	ТоварыКРазгрузке = УправлениеЛогистикойСервер.ПолучитьТаблицуРазгрузкиТовара(Объект);
	
	ПараметрыРазгрузки.ТЗТоварыКРазгрузке = ТоварыКРазгрузке;
	ПараметрыРазгрузки.Зона = УправлениеЛогистикойСервер.ПолучитьГлобальнуюЗону(Объект.ЗонаДоставкиДляВодителя, Объект.Подразделение);
	ПараметрыРазгрузки.СНДС = Объект.СтоимостьДоставкиСНДС > 0;
	
	ПараметрыРазгрузкиАдресВХранилище = ПоместитьВоВременноеХранилище(ПараметрыРазгрузки, ЭтотОбъект.УникальныйИдентификатор);
	
	Возврат ПараметрыРазгрузкиАдресВХранилище;
	
КонецФункции

&НаСервере
Процедура ДобавитьУслугуРазгрузки()
	
	//Ложь - вместо услуг доставки удаляем услуги разгрузки
	УдалитьУслугиДоставки(Ложь);
	
	Если Объект.ДоставкаСРазгрузкой Тогда
		НоваяСтрокаИд = ДобавитьРазгрузку();
		ПересчитатьЦеныВСтрокеКорзиныНаСервере(Объект.Товары.НайтиПоИдентификатору(НоваяСтрокаИд));	
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Функция ДобавитьРазгрузку()
	
	НДС = ОпределитьНДС();
	
	НоваяСтрока = Объект.Товары.Добавить(); 
	НоваяСтрока.Номенклатура = ?(НДС, АльтерраОбщегоНазначения.УслугаРазгрузкиСНДС(), АльтерраОбщегоНазначения.УслугаРазгрузкиБезНДС());
	Если НДС Тогда
		СтавкаНДСПоУмолчанию = УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,ТекущаяДата());
		СтавкаНДСЧислом = ЦенообразованиеКлиентСервер.ПолучитьСтавкуНДСЧислом(СтавкаНДСПоУмолчанию)/100+1;
		НоваяСтрока.Количество = Объект.СтоимостьРазгрузкиДляКлиента;///СтавкаНДСЧислом; ////////////////////////////////////////
		НоваяСтрока.СтавкаНДС = СтавкаНДСПоУмолчанию;
	Иначе
		НоваяСтрока.Количество = Объект.СтоимостьРазгрузкиДляКлиента; 
		НоваяСтрока.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
	Конецесли;
	НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
	НоваяСтрока.ВидЦены = Объект.Соглашение.ВидЦен;
	НоваяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
	НоваяСтрока.Упаковка = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
	
	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;
	
	Возврат НоваяСтрока.ПолучитьИдентификатор();
КонецФункции

#КонецОбласти

&НаСервере 
Процедура ПодборИНН()
	Если Объект.Контрагент.ИНН <> Неопределено Тогда 
		Этаформа.ИНН = Объект.Контрагент.ИНН; 
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция КонтрагентИННПриИзмененииНаСервере()
	Контрагент = АльтерраОбщегоНазначения.ПолучитьКонтрагентаПоИНН(ЭтаФорма.ИНН);
	Если Контрагент <> неопределено Тогда 
		Объект.Контрагент = Контрагент; 
		Объект.Партнер= Контрагент.Партнер; 
		Возврат Истина; 
	Иначе
		Возврат Ложь; 
	КонецЕсли; 
	
КонецФункции

&НаКлиенте
Процедура КонтрагентИННПриИзменении(Элемент)
	Если КонтрагентИННПриИзмененииНаСервере() Тогда
		
		ПартнерПриИзмененииНаСервере();
		РассчитатьИтоги();
		
		Если Не ПустаяСтрока(ИнформацияПоПартнеру) Тогда 
			ПоказатьПредупреждение(, ИнформацияПоПартнеру, 5, "Внимание");
		КонецЕсли;
		
		УстановитьВидимостьДоступность();
		АльтерраОбщегоНазначения.ПолучитьДополнительнуюИнформациюПоПартнеру(Объект.Партнер);
		
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		СписокНоменклатура,
		"Номенклатура",
		Неопределено,
		Истина);
		ЗаполнитьФильтрыСервер();
		ПодборИНН(); 
		
		ИнформацияПоПартнеру(); 
	Иначе 
		Сообщить("По данному ИНН не обнаружено партнера"); 
	КонецЕсли; 
	
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьУслугуДоставкиБезНДС(Команда)
	ДобавитьУслугуБезНДСНаСервере();
КонецПроцедуры
&НаСервере
Процедура ДобавитьУслугуБезНДСНаСервере()
	НоваяСтрока= Объект.Товары.Добавить();
	НоваяСтрока.Номенклатура = АльтерраОбщегоНазначения.УслугаДоставкиБезНДС();
	НоваяСтрока.Количество= Константы.СтоимостьУслугиДоставкиБезНДС.Получить(); 
	НоваяСтрока.КоличествоУпаковок= НоваяСтрока.Количество;
	НоваяСтрока.ВидЦены= Объект.Соглашение.ВидЦен;
	НоваяСтрока.СтавкаНДС= НоваяСтрока.Номенклатура.СтавкаНДС;
	НоваяСтрока.Цена = 1;
	НоваяСтрока.Сумма = НоваяСтрока.Цена * НоваяСтрока.Количество; 

	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьУслугуДоставкиСНДС(Команда)
	ДобавитьУслугуДоставкиСНДСНаСервере();
КонецПроцедуры

&НаСервере
Процедура ДобавитьУслугуДоставкиСНДСНаСервере()
	НоваяСтрока= Объект.Товары.Добавить();
	НоваяСтрока.Номенклатура = Справочники.Номенклатура.НайтиПоКоду("0А-00002683");
	НоваяСтрока.Количество= Константы.СтоимостьУслугиДоставкиБезНДС.Получить(); 
	НоваяСтрока.КоличествоУпаковок= НоваяСтрока.Количество;
	НоваяСтрока.ВидЦены= Объект.Соглашение.ВидЦен;
	НоваяСтрока.СтавкаНДС= НоваяСтрока.Номенклатура.СтавкаНДС;
	НоваяСтрока.Цена = 1;
	НоваяСтрока.Сумма = НоваяСтрока.Цена * НоваяСтрока.Количество; 

	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКритерии()	             
	ТЗ = Объект.Товары.Выгрузить( , "Номенклатура, КоличествоУпаковок");
	Если ЗначениеЗаполнено(ТЗ) Тогда
		Возврат УправлениеЛогистикойСервер.ПодборКритериевДляТиповТС(ТЗ);						   
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции
&НаСервере
Функция ПолучитьТипТС()	             
	Критерии = ПолучитьКритерии();
	Если ЗначениеЗаполнено(Критерии) Тогда
		Возврат УправлениеЛогистикойСервер.ОпределениеТипаТСДляЗаказаНаДоставку(Критерии);
	КонецЕсли;						   
	
	Возврат Неопределено;
КонецФункции
&НаКлиенте
Процедура ТарифНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.СборнаяОРК") Тогда 
		ПараметрыФормы = Новый Структура("ВидДоставки", Объект.ВидДоставки);
	Иначе
		ПараметрыФормы = Новый Структура("ВидДоставки, ТипТС", Объект.ВидДоставки, ПолучитьТипТС());
	КонецЕсли;
	ВыборТарифаЗавершение = Новый ОписаниеОповещения("ВыборТарифаЗавершение", ЭтаФорма);
	ОткрытьФорму("Справочник.ТарифыПеревозчиков.ФормаВыбора", ПараметрыФормы, ЭтаФорма,,,, ВыборТарифаЗавершение);																					  
КонецПроцедуры
&НаКлиенте
Процедура ВыборТарифаЗавершение(Результат, ДопПараметры) Экспорт 
	Если ЗначениеЗаполнено(Результат) Тогда
		Объект.Тариф = Результат;
		ТарифПриИзмененииНаСервере();
		ЭтаФорма.Модифицированность = Истина;
		ДобавлениеУслугиДоставки()
	КонецЕсли;
КонецПроцедуры
&НаСервере
Процедура ПроверкаТарифаПоКритериямДляТС()
	ТарифПеревозчика = Объект.Тариф;
	ТарифТипТС = ТарифПеревозчика.ТипТС;
	
	Если Не ЗначениеЗаполнено(ТарифПеревозчика) Тогда
		Элементы.ДекорацияТариф.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТарифТипТС) И 
		((ЗначениеЗаполнено(ТарифТипТС.ГрузоподъемностьВТоннах) И ТарифТипТС.ГрузоподъемностьВТоннах * 1000 < Объект.Товары.Итог("Вес")) ИЛИ 
		(ЗначениеЗаполнено(ТарифТипТС.ВместимостьВКубическихМетрах) И ТарифТипТС.ВместимостьВКубическихМетрах < Объект.Товары.Итог("Объем"))) Тогда
		
		Элементы.ДекорацияТариф.Видимость = Истина;
		Возврат;
	КонецЕсли;
	
	Критерии = ПолучитьКритерии();
	Если Не ЗначениеЗаполнено(Критерии) Тогда
		Элементы.ДекорацияТариф.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	МассивНесовместимыхТиповТС = УправлениеЛогистикойСервер.МассивНесовместимыхТиповТС(Критерии);
	Если Не ЗначениеЗаполнено(МассивНесовместимыхТиповТС) Тогда
		Элементы.ДекорацияТариф.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.ДекорацияТариф.Видимость = МассивНесовместимыхТиповТС.Найти(ТарифТипТС) <> Неопределено; 
КонецПроцедуры

&НаСервере
Функция ОпределитьНДС()
	НДС = ?(Объект.СтоимостьДоставки > 0,Ложь, Истина); 
	// подмена услуги доставки (временно)
	Если ЕстьБлокировкаУслуги ИЛИ Объект.РаспределитьТранспортныеДистрибуция Тогда
		НДС=Истина;
	КонецЕсли;

	Возврат НДС;
КонецФункции

