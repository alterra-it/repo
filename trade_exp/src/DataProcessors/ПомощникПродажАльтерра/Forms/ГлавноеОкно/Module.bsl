&НаКлиенте
Процедура ДоставкаПоЗвонкуПриИзменении(Элемент)
	Объект.НужнаИнкассация = ДоставкаПоЗвонку;
	Элементы.Инкассация.Видимость = ДоставкаПоЗвонку;
	Элементы.Сдача.Видимость = ДоставкаПоЗвонку и Объект.ФормаОплаты = ПредопределенноеЗначение("Перечисление.ФормыОплаты.Наличная");
	Если ДоставкаПоЗвонку Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ВводФормыОплатыЗавершение", ЭтаФорма);
		ОчиститьСообщения();
		ОткрытьФорму("Обработка.ПомощникПродажАльтерра.Форма.ФормаДоставкаПоЗвонку",,,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВводФормыОплатыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если Результат.ФормаОплаты = "Безналичная" Тогда
		Объект.ФормаОплаты = ПредопределенноеЗначение("Перечисление.ФормыОплаты.ПлатежнаяКарта");
		ОплатаБанковскойКартой = Истина;
		Объект.Сдача = 0;
	Иначе 
		Объект.ФормаОплаты = ПредопределенноеЗначение("Перечисление.ФормыОплаты.Наличная");
		ОплатаБанковскойКартой = Ложь;
		Объект.Сдача = Результат.СуммаСдачи;
	КонецЕсли;
	Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	Элементы.Сдача.Видимость = ДоставкаПоЗвонку и Объект.ФормаОплаты = ПредопределенноеЗначение("Перечисление.ФормыОплаты.Наличная");
КонецПроцедуры

&НаСервере
Функция СоздатьЛистСогласования(Основание)
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	Док = Документы.ЛистСогласования.СоздатьДокумент();
	Документы.ЛистСогласования.ЗаполнитьДанныеПоОснованию(Основание, Док, Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления);
	Док.Проблема = Справочники.Проблемы.НайтиПоКоду("000000001");
	Док.Основание = Основание;
	Док.Автор = ТекущийПользователь;
	Док.Контрагент = Объект.Контрагент;
	Док.ОплатаДо = Объект.ЖелаемаяДатаОтгрузки;
	Док.ДатаДоставки = Объект.ЖелаемаяДатаОтгрузки;
	Док.ФормаОплаты = Объект.ФормаОплаты;
	Док.ДатаДоставки = Объект.ПрибытиеНаОтгрузку;
	Док.ОсновнойМенеджер = ТекущийПользователь;
	
	Если Объект.Товары.Итог("Сумма")>50000 ИЛИ Объект.ЗонаДоставкиДляВодителя.ГлобальнаяЗона = Перечисления.ЗоныДоставкиКлиента.ПустаяСсылка() Тогда
		Руководитель = ПолучитьРуководителяТекущегоПользователя(ТекущийПользователь);
		Док.Согласовано = ОпределитьЛицоСПравомСогласования(Руководитель.Пользователь);
		Если Руководитель.Пользователь = ТекущийПользователь Тогда
			Док.Согласован = Истина;
			Док.Согласователь = ТекущийПользователь;
		КонецЕсли;
	Иначе
		Док.Согласован = Истина;
		Док.Согласовано = ОпределитьЛицоСПравомСогласования(ТекущийПользователь);
		Док.Согласователь = ТекущийПользователь;
	КонецЕсли;
	Док.Записать(РежимЗаписиДокумента.Проведение);
	
	Если ДоставкаПоЗвонку Тогда
			ОтправитьСообщениеОДоставке(Док);
	КонецЕсли;
	
	Возврат Док.Ссылка;
КонецФункции

&НаСервере
Функция ПолучитьРуководителяТекущегоПользователя(ТекущийПользователь)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Сотрудники.Отдел.Руководитель КАК ОтделРуководитель
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
		|		ПО Сотрудники.Пользователь = Пользователи.Ссылка
		|ГДЕ
		|	Пользователи.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ТекущийПользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ОтделРуководитель;
	КонецЕсли;

КонецФункции

&НаСервере
Функция ОпределитьЛицоСПравомСогласования(Пользователь)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПользователиДляСогласованияЛистов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПользователиДляСогласованияЛистов КАК ПользователиДляСогласованияЛистов
		|ГДЕ
		|	ПользователиДляСогласованияЛистов.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;

	Возврат Пользователи.ТекущийПользователь();
КонецФункции

&НаСервере
Процедура ОтправитьСообщениеОДоставке(Документ)
	Если ТипЗНЧ(Документ) = Тип("ДокументОбъект.РеализацияТоваровУслуг") ИЛИ ТипЗНЧ(Документ) = Тип("ДокументОбъект.ЛистСогласования") Тогда
		ТекущийПользователь = Пользователи.ТекущийПользователь();
		ИДЧата = ПолучитьИДЧата(Объект.Склад.Подразделение);
		ТекстСообщения = "Пользователь "+Строка(ТекущийПользователь)+" оформил доставку по звонку"+Символы.ПС;
		ТекстСообщения = ТекстСообщения+Символы.Таб+"-"+Строка(Документ)+Символы.ПС+Строка(ПолучитьНавигационнуюСсылку(Документ))+Символы.ПС;
		ТекстСообщения = ТекстСообщения+"Необходимо установить отметку кассы";
		Руководитель = ПолучитьРуководителяТекущегоПользователя(ТекущийПользователь);
		Если (Объект.Товары.Итог("Сумма")>50000 ИЛИ Объект.ЗонаДоставкиДляВодителя.ГлобальнаяЗона = Перечисления.ЗоныДоставкиКлиента.ПустаяСсылка())
			И НЕ Руководитель.Пользователь = ТекущийПользователь Тогда
			ТекстСообщения = ТекстСообщения+" после согласования руководителя";
		КонецЕсли;
		Если найти(СтрокаСоединенияИнформационнойБазы(),"""trade""")<>0 Тогда
			//АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения, ТекущийПользователь);
			АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитриксПоИДЧата(ТекстСообщения, ИДЧата);
			//ИДЧата = "chat176331";
			//АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитриксПоИДЧата(ТекстСообщения, ИДЧата);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьИДЧата(Филиал)
	Если Филиал = Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000001") Тогда
		Возврат "chat92049";//ЦБ
	ИначеЕсли Филиал = Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000002") Тогда
		Возврат "chat91858";//Барнаул
	ИначеЕсли Филиал = Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000003") Тогда
		Возврат "chat92162";//Выбор
	ИначеЕсли Филиал = Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000004") Тогда
		Возврат "chat42465";//Бийск
	ИначеЕсли Филиал = Справочники.СтруктураПредприятия.НайтиПоКоду("01-000002") Тогда
		Возврат "chat91773";//Майма
	КонецЕсли;
КонецФункции

#КонецОбласти

&НаСервере
Процедура ОпределитьОбъемСУчетомСкрутокПоликарбоната(РасчетДоставкиПоНесколькимОснованиям =Ложь)
	ОбъемСучетомСкрутокПоликарбоната = 0;  
	ТаблицаТовары = ?(РасчетДоставкиПоНесколькимОснованиям,Объект.ТоварыДляДоставки.Выгрузить(),Объект.Товары.Выгрузить());
	Если ТаблицаТовары.Количество() = 0 Тогда 
		Возврат;
	КонецЕсли;
	ОбъемСучетомСкрутокПоликарбоната = УправлениеЛогистикойСервер.ПолучитьОбъемСУчетомСкрутокПоликарбоната(ТаблицаТовары); 
	Объект.Объем = ?(ОбъемСучетомСкрутокПоликарбоната=0,Объект.Объем,ОбъемСучетомСкрутокПоликарбоната); 
КонецПроцедуры

