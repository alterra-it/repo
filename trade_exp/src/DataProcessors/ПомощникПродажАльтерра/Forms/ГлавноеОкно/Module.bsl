#Область Нарезка

&НаКлиенте
Процедура РасчитатьПараметрыНарезки(Команда)
	ПараметрыОткрытия= Новый Структура;
	ПараметрыОткрытия.Вставить("АдресВХранилище", ПередатьВХранилищеТЧПоНарезке()); 
	
	ОповещениеЗаполнитьНарезку= Новый ОписаниеОповещения("ЗаполнитьНарезкуНаКлиенте", ЭтотОбъект);
	
	ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаНарезка", ПараметрыОткрытия, ЭтаФорма, Истина,,, ОповещениеЗаполнитьНарезку, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаСервере
Функция ПередатьВХранилищеТЧПоНарезке()
	Данные= Новый Структура;
	Данные.Вставить("Товары", Объект.Товары.Выгрузить());
	Данные.Вставить("Нарезка", Объект.Нарезка.Выгрузить());
	АдресВХранилище= ПоместитьВоВременноеХранилище(Данные);
	
	Возврат АдресВХранилище;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьНарезкуНаКлиенте(АдресВХранилище, ДопПараметры) Экспорт   	
	ЗаполнитьНарезку(АдресВХранилище, ДопПараметры);
	ПересчитатьЦеныВКорзине();
	
	РассчитатьИтоги(); 
	//изменяется максимальная длина, нужно переопределить тариф
   Если Объект.НужнаДоставка Тогда
     АвтоопределениеТарифа();
 КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНарезку(АдресВХранилище, ДопПараметры)
	Если АдресВХранилище <> Неопределено Тогда
		Нарезка= ПолучитьИзВременногоХранилища(АдресВХранилище);
		Объект.Нарезка.Загрузить(Нарезка);
		
		//Удаляем
		Для Каждого стрНарезка ИЗ Объект.Нарезка Цикл
			УслугаРезки= стрНарезка.Номенклатура.УслугаРезки;
			
			Отбор= Новый Структура("Номенклатура", УслугаРезки);
			НайденыеСтроки= Объект.Товары.НайтиСтроки(Отбор);
			
			Для Каждого стрУслугРезки Из НайденыеСтроки Цикл
				Объект.Товары.Удалить(стрУслугРезки);
			КонецЦикла;
		КонецЦикла;
		
		Для Каждого стрНарезка ИЗ Объект.Нарезка Цикл
			
			Если стрНарезка.НарезкаОтПоставщика Тогда
				Продолжить;
			КонецЕсли;
			
			УслугаРезки= стрНарезка.Номенклатура.УслугаРезки;
			КоличествоОтрезков= АльтерраОбщегоНазначения.ПолучитьКоличествоОтрезков(стрНарезка);
			
			Отбор= Новый Структура("Номенклатура", УслугаРезки);
			НайденыеСтроки= Объект.Товары.НайтиСтроки(Отбор);
			
			Если НайденыеСтроки.Количество() = 1 Тогда
				НоваяСтрока= НайденыеСтроки[0];
			Иначе
				НоваяСтрока= Объект.Товары.Добавить();
				НоваяСтрока.Номенклатура= УслугаРезки;
			КонецЕсли;
			
			НоваяСтрока.ВидЦены= ВидЦены;
			НоваяСтрока.СтавкаНДС= УслугаРезки.СтавкаНДС; 
			НоваяСтрока.Количество= НоваяСтрока.Количество + стрНарезка.Количество*(КоличествоОтрезков-1);			
			НоваяСтрока.КоличествоУпаковок= НоваяСтрока.Количество;
			
		КонецЦикла;
	КонецЕсли;
	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область Информация
&НаСервере
Процедура ВывестиИнформацию()
	
	ИнформацияПоСкладу();
	ИнформацияПоОрганизации();
	ИнформацияПоСоглашению();
	ИнформацияПоДоговору();
	ИнформацияПоПартнеру();
	
	Объект.НужнаЗаявкаЛесЕГАИС = НужнаЗаявкаЕГАИС();
	Если Объект.НужнаЗаявкаЛесЕГАИС И Объект.Контрагент.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда
		НуженНомерДекларацииЕГАИС = Истина;
	Иначе 
		НуженНомерДекларацииЕГАИС = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ИнформацияПоСкладу()
	СтрокиНехватки= Объект.Товары.НайтиСтроки(Новый Структура("ЕстьНехватка", Истина));
	Если СтрокиНехватки.Количество() > 0 Тогда
		Элементы.ИнформацияПоСкладу.Заголовок= "Остатков недостаточно по "+СтрокиНехватки.Количество()+" позициям";
		Элементы.ИнформацияПоСкладу.ЦветТекста= ЦветаСтиля.ЦветОтрицательногоЧисла;
		Элементы.ТоварыИтогНехватает.Видимость= Истина;
	Иначе
		Элементы.ИнформацияПоСкладу.Заголовок= "Остатков достаточно";
		Элементы.ИнформацияПоСкладу.ЦветТекста= ЦветаСтиля.ЦветТекстаУспех;
		Элементы.ТоварыИтогНехватает.Видимость= Ложь;
	КонецЕсли;
КонецПроцедуры
&НаСервере
Процедура ИнформацияПоОрганизации()
	Если Объект.Подразделение.Организация <> Объект.Организация  И Объект.Подразделение.Код = "0А-000013" Тогда
		Элементы.ИнформацияПоОрганизации.Заголовок= "Продажа по "+Объект.Организация+" запрещена!";
		Элементы.ИнформацияПоСкладу.ЦветТекста= ЦветаСтиля.ЦветОтрицательногоЧисла;
	КонецЕсли;
КонецПроцедуры
&НаСервере
Процедура ИнформацияПоСоглашению()
	
КонецПроцедуры
&НаСервере
Процедура ИнформацияПоДоговору()
	ТекстОстатокДопустимогоКредита= "";
	
	ПродажиСервер.ОбновитьОграничениеЗадолженности(
	Объект.Договор,
	ТекущаяДата(),
	ТекстОстатокДопустимогоКредита,
	Элементы.ИнформацияПоДоговору.Видимость,
	Элементы.ИнформацияПоДоговору.ЦветТекста,
	Элементы.КартинкаОтгрузкаЗапрещена.Видимость);
	
	Элементы.ИнформацияПоДоговору.Видимость= Истина;
	Элементы.ИнформацияПоДоговору.Заголовок= ТекстОстатокДопустимогоКредита;
КонецПроцедуры
&НаСервере
Процедура ИнформацияПоПартнеру()
	Если ЗначениеЗаполнено(Объект.Партнер) Тогда
		ВходитВСегмент=ПартнерВходитВСегментыЗапретПродажи();
		Если ВходитВСегмент Тогда
			ИнформацияПоПартнеру= "Отгружать только по предоплате";
		Иначе
			ИнформацияПоПартнеру= "";
		КонецЕсли;
		//Заполнение не закрытых заказов по партнеру
		ЗаполнитьНеЗакрытыеЗаказыПоПартнеру();
		
		Если НезакрытыеЗаказыЧеки.Количество()>0 Тогда
			Элементы.НезакрытыеЗаказыЧекиЗначение.Видимость = Истина;
		Иначе
			Элементы.НезакрытыеЗаказыЧекиЗначение.Видимость = Ложь;
		КонецЕсли;
	Иначе
		ИнформацияПоПартнеру= "";
	КонецЕсли;    
КонецПроцедуры

&НаСервере
Функция НужнаЗаявкаЕГАИС()
	
	Товары = Объект.Товары.Выгрузить( , "Номенклатура");
	
	ТоварыН = Новый ТаблицаЗначений();
	ТоварыН.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТоварыН.Колонки.Добавить("ВидНоменклатуры", Новый ОписаниеТипов("СправочникСсылка.ВидыНоменклатуры"));
	Для Каждого Стр Из Товары Цикл
		Номенклатура = Стр.Номенклатура.ПолучитьОбъект();
		НоваяСтрока = ТоварыН.Добавить();
		НоваяСтрока.Номенклатура = Номенклатура.Ссылка;
		НоваяСтрока.ВидНоменклатуры = Номенклатура.ВидНоменклатуры;
	КонецЦикла;                            
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа = ИСТИНА
	|	И Номенклатура.ЕГАИСЛес = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура, 
	|	Товары.ВидНоменклатуры КАК ВидНоменклатуры
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Ссылка
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ГДЕ
	|	ВТ_Товары.ВидНоменклатуры В ИЕРАРХИИ
	|		(ВЫБРАТЬ
	|			Номенклатура.Ссылка КАК Ссылка
	|		ИЗ
	|			ВТ_ГруппыЕГАИС КАК Номенклатура)";
	
	Запрос.УстановитьПараметр("Товары", ТоварыН);
	Результат = Запрос.Выполнить();
	
	Если НЕ Результат.Пустой() Тогда 
		Возврат Истина
	Иначе 
		Возврат Ложь
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьНеЗакрытыеЗаказыПоПартнеру(ПолныйПериод = Ложь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Распоряжения.Распоряжение КАК Документ
	|ИЗ
	|	РегистрНакопления.РаспоряженияНаОтгрузку.Обороты(&ДатаНачало, , , ) КАК Распоряжения
	|ГДЕ
	|	Распоряжения.Распоряжение.Партнер = &Партнер
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка
	|ИЗ
	|	Документ.ЧекККМ КАК ЧекККМ
	|ГДЕ
	|	ЧекККМ.Проведен = ИСТИНА
	|	И НЕ ЧекККМ.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И ЧекККМ.Партнер = &Партнер
	|	И ЧекККМ.Дата > &ДатаОтбора
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|ГДЕ
	|	ЗаказКлиента.Партнер = &Партнер
	|	И ЗаказКлиента.Дата >= &ДатаНачало
	|	И ЗаказКлиента.Проведен
	|	И ЗаказКлиента.КоммерческоеПредложение";
	Запрос.УстановитьПараметр("ДатаНачало", НачалоДня(ТекущаяДата() - ?(ПолныйПериод, 365,31)*24*60*60));
	Запрос.УстановитьПараметр("ДатаОтбора", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	
	МассивДокументов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Документ");
	
	НезакрытыеЗаказыЧеки.ЗагрузитьЗначения(МассивДокументов);
	
КонецПроцедуры

&НаСервере
Функция ПартнерВходитВСегментыЗапретПродажи()
	Запрос= Новый Запрос;
	Запрос.Текст= "ВЫБРАТЬ
	|	ПартнерыСегмента.Сегмент КАК Сегмент,
	|	ПартнерыСегмента.Партнер КАК Партнер
	|ИЗ
	|	РегистрСведений.ПартнерыСегмента КАК ПартнерыСегмента
	|ГДЕ
	|	ПартнерыСегмента.Сегмент.ЗапретОтгрузки
	|	И ПартнерыСегмента.Партнер = &Партнер";
	
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	
	РезультатЗапроса= Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
КонецФункции

Функция ПолучитьНехватку()
	СтрокиНехватки= Объект.Товары.НайтиСтроки(Новый Структура("ЕстьНехватка", Истина));
	Возврат СтрокиНехватки.Количество();
КонецФункции

#КонецОбласти

#Область Бонусы
&НаСервере
Процедура НачислитьБонусныеБаллы()
	БонусыАльтерраРезерв.НачислитьБонусныеБаллы(Объект);
КонецПроцедуры

&НаСервере
Процедура ПоказатьИнформациюПоБонусам()
	
	Если БонусыАльтерра.УчаствуетПартнерВБонуснойПрограмме(Объект.Партнер) Тогда
		Элементы.Информация.Видимость = Истина;
		Элементы.грБонусы.Заголовок = "Информация по бонусам";
		Элементы.грБонусы.Показать();
		Элементы.грБонусы1.Заголовок = "Информация по бонусам";
		Элементы.грБонусы1.Показать();
		
		ИнфоПоБонусам = БонусыАльтерраРезерв.ПолучитьИнформациюПоБаллам(Объект.Дата, Объект.Партнер);
		ДоступноБаллов = ИнфоПоБонусам.ДоступныеБаллы;
		
		Если ИнфоПоБонусам.ЭтоБригадир Тогда
			Элементы.Информация.Видимость= Ложь;
			Элементы.грБонусы.Заголовок= "Клиент является бригадиром";
			Элементы.грБонусы.Скрыть();
			Элементы.грБонусы1.Заголовок= "Клиент является бригадиром";
			Элементы.грБонусы1.Скрыть();
			Если Объект.Партнер.БонуснаяПрограммаАктивна Тогда
				Элементы.грБонусы.ЦветТекстаЗаголовка = Новый Цвет(0, 128, 0);
				Элементы.грБонусы1.ЦветТекстаЗаголовка = Новый Цвет(0, 128, 0);
			Иначе
				Элементы.грБонусы.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
				Элементы.грБонусы1.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
			КонецЕсли;			
		Иначе		
			Если Не ЗначениеЗаполнено(Объект.СтатусПартнераВПрограммеЛояльности) Тогда
				Объект.СтатусПартнераВПрограммеЛояльности = ИнфоПоБонусам.Статус;
			КонецЕсли;
			ДоступноБаллов = ИнфоПоБонусам.ДоступныеБаллы;
			ПроцентУчастникаБонуснойПрограммы = Объект.СтатусПартнераВПрограммеЛояльности.Коэффициент*100;
			Если Объект.Партнер.БонуснаяПрограммаАктивна Тогда
				Элементы.грБонусы.ЦветТекстаЗаголовка = Новый Цвет(0, 128, 0);
				Элементы.грБонусы1.ЦветТекстаЗаголовка = Новый Цвет(0, 128, 0);
			Иначе
				Элементы.грБонусы.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
				Элементы.грБонусы1.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
			КонецЕсли;			
		КонецЕсли;
	Иначе
		ДоступноБаллов = 0;
		Элементы.грБонусы.Заголовок = "Не участвует в бонусной программе";
		Элементы.грБонусы.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
		Элементы.грБонусы.Скрыть();
		Элементы.грБонусы1.Заголовок = "Не участвует в бонусной программе";
		Элементы.грБонусы1.ЦветТекстаЗаголовка= Новый Цвет(255, 0, 0);
		Элементы.грБонусы1.Скрыть();
		Элементы.Информация.Видимость = Ложь;
		
		Объект.СтатусПартнераВПрограммеЛояльности = Неопределено;
		Объект.ПроцентЗаКрупнуюПокупку = 0;	
	КонецЕсли;	
КонецПроцедуры
&НаКлиенте
Процедура ОплатитьБонуснымиБаллами(Команда)
	Если ПроверитьВозможностьОплаты() Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуОплатыБаламиФрагмент();
КонецПроцедуры
&НаКлиенте
Процедура ОбновитьРасчетБаллов(Команда)
	НачислитьБонусныеБаллы();
	ПоказатьИнформациюПоБонусам();
КонецПроцедуры
&НаСервере
Функция ПроверитьВозможностьОплаты()
	
	Если НовыйПорядокНачисленияБонусов Тогда
		ЗапретОплаты = БонусыАльтерраРезерв.ПроверитьЗапретОплатыБонусов(Объект);
	Иначе
		ЗапретОплаты = БонусыАльтерра.ПроверитьЗапретОплатыБонусов(Объект);
	КонецЕсли;
	
	Возврат ЗапретОплаты;
КонецФункции
&НаКлиенте
Процедура ОткрытьФормуОплатыБаламиФрагмент()
	
	//ОчиститьБонусыСервер();
	
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Партнер",                   Объект.Партнер);
	ПараметрыОткрытияФормы.Вставить("КартаЛояльности",           Объект.КартаЛояльности);
	ПараметрыОткрытияФормы.Вставить("АдресТабличнойЧастиТовары", АдресТабличнойЧастиТовары());
	ПараметрыОткрытияФормы.Вставить("Валюта",                    Объект.Валюта);
	ПараметрыОткрытияФормы.Вставить("ТолькоИнформация", Ложь);
	
	ОткрытьФорму(
	"Справочник.БонусныеПрограммыЛояльности.Форма.ОплатаБонуснымиБаллами",
	ПараметрыОткрытияФормы,
	ЭтотОбъект,,,,
	Новый ОписаниеОповещения("ОповещениеОбОплатеБонусовМенеджеромЗавершить", ЭтотОбъект));
	
КонецПроцедуры
