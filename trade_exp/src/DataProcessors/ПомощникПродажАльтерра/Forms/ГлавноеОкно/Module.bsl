#Область СозданиеСборкиРазборки

&НаКлиенте
Процедура Пополнить(Команда)
	
	ХарактеристикиИспользуются = Истина;
	
	ТекДанные = Элементы.СписокНоменклатура.ТекущиеДанные; 
		
		Если ТекДанные = Неопределено Тогда
			ТекДанные = Элементы.Характеристики.ТекущиеДанные;
			Характеристика = ТекДанные.Характеристика;
		Иначе 
			Характеристика = Неопределено;
			ХарактеристикиИспользуются = Ложь;
		КонецЕсли; 
		
		ХарактеристикаВарианта = ХарактеристикаИзВариантаКомплектации(ТекДанные.Номенклатура); 
		Если Характеристика<>ХарактеристикаВарианта Тогда
			 Характеристика = ХарактеристикаВарианта;
		КонецЕсли;

		Если ХарактеристикиИспользуются И ТекДанные.Доступно > 0 Тогда
			Сообщить("Для данной характеристики уже есть остаток");
		Иначе
			ПополнитьНаСервере(ТекДанные.Номенклатура, Характеристика, ТекДанные.Доступно, ХарактеристикиИспользуются); 
			ЗапретНарезки = Ложь;	
			Если Найти(ТекДанные.Номенклатура, "м/прокат") > 0 И ПроверкаДоступностиРоли() Тогда
				Для каждого ВариантКомплектации Из Объект.ВариантыКомплектации Цикл
					Если ЭтоВыводимыйТовар(ВариантКомплектации.ВариантКомплектации,Объект.Подразделение) 
						или ЭтоВыводимыйТовар(ТекДанные.Номенклатура,Объект.Подразделение) Тогда
						ЗапретНарезки = Истина;
					КонецЕсли;
				КонецЦикла; 
			КонецЕсли;
			Если Объект.ВариантыКомплектации.Количество()> 0 Тогда
				Если ЗапретНарезки Тогда
					Сообщить("Запрещено проводить сборку!");
				Иначе
					Параметрыформы = Новый Структура("Номенклатура, Характеристика, Остаток, ВариантыКомплектации, Склад, Организация",
					ТекДанные.Номенклатура, Характеристика, ТекДанные.Доступно, Объект.ВариантыКомплектации, Объект.Склад, Объект.Организация);
					ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершениеВыбораКомплектации", ЭтотОбъект);
					ОткрытьФорму("Обработка.ПомощникПродажАльтерра.Форма.ВыборВариантаКомплектации",ПараметрыФормы,,,,,ОписаниеОповещения);
				КонецЕсли;
			Иначе
				Сообщить("Нет доступного остатка для пополнения"); 
			КонецЕсли;
		КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция ХарактеристикаИзВариантаКомплектации(Номенклатура)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВариантыКомплектацииНоменклатуры.Характеристика КАК Характеристика
	|ИЗ
	|	Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	|ГДЕ
	|	НЕ ВариантыКомплектацииНоменклатуры.ПометкаУдаления
	|	И ВариантыКомплектацииНоменклатуры.Владелец = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Характеристика;	
КонецФункции

&НаСервере
Функция ПроверкаДоступностиРоли()
	Возврат Не РольДоступна("Оператор1С");
КонецФункции

&НаСервере
Функция ЭтоВыводимыйТовар(Номенклатура,Склад)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс КАК Класс
		|ИЗ
		|	РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
		|ГДЕ
		|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура = &Номенклатура
		|	И ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Подразделение", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Если Выборка.Класс = Перечисления.ABCКлассификация_Альтерра.ВыводимыйТовар Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

&НаКлиенте
Процедура ЗавершениеВыбораКомплектации(Результат, ДополнительныеПараметры) экспорт
	Если ТипЗнч(Результат) = ТИП("Структура") и ЗначениеЗаполнено(Результат.Сборка) Тогда
		ЗаписатьИнформациюОСборке(Результат.Сборка);
	КонецЕсли;
КонецПроцедуры

&НаСервере 
Процедура ЗаписатьИнформациюОСборке(Сборка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	""Комплект"" КАК Заголовок,
		|	СборкаТоваров.Ссылка КАК Ссылка,
		|	СборкаТоваров.Номенклатура КАК Номенклатура,
		|	СборкаТоваров.КоличествоУпаковок КАК Количество,
		|	СборкаТоваров.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
		|ИЗ
		|	Документ.СборкаТоваров КАК СборкаТоваров
		|ГДЕ
		|	СборкаТоваров.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	""Комплектующие"",
		|	СборкаТоваровТовары.Ссылка,
		|	СборкаТоваровТовары.Номенклатура,
		|	СборкаТоваровТовары.КоличествоУпаковок,
		|	СборкаТоваровТовары.Номенклатура.ЕдиницаИзмерения
		|ИЗ
		|	Документ.СборкаТоваров.Товары КАК СборкаТоваровТовары
		|ГДЕ
		|	СборкаТоваровТовары.Ссылка = &Ссылка
		|ИТОГИ
		|ПО
		|	Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Сборка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСсылка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		ТекстКомментария = Строка(ВыборкаСсылка.Ссылка) + Символы.ПС;
		
		Выборка = ВыборкаСсылка.Выбрать();
		Пока Выборка.Следующий() Цикл
			ТекстКомментария = ТекстКомментария + Выборка.Заголовок + " " +	Строка(Выборка.Номенклатура) + " " 
							+ Строка(Выборка.Количество) + " " + Строка(Выборка.ЕдиницаИзмерения) + Символы.ПС;
		КонецЦикла;
	КонецЦикла;

	Объект.КомментарийДляСклада = Объект.КомментарийДляСклада + " " + ТекстКомментария;
КонецПроцедуры	
     

&НаСервере 
Процедура ПополнитьНаСервере(Номенклатура, Характеристика, Остаток, ХарактеристикиИспользуются)
	
Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВариантыКомплектацииНоменклатурыТовары.Номенклатура КАК Номенклатура,
		|	ВариантыКомплектацииНоменклатурыТовары.Характеристика КАК Характеристика,
		|	ВариантыКомплектацииНоменклатурыТовары.Количество КАК Количество,
		|	ВариантыКомплектацииНоменклатурыТовары.Ссылка.Ссылка КАК Ссылка,
		|	ВариантыКомплектацииНоменклатурыТовары.Ссылка.Количество КАК КоличествоКомплект,
		|	ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец КАК НоменклатураКомплект,
		|	1 КАК ЧислоКомплектующих
		|ПОМЕСТИТЬ Комплектация
		|ИЗ
		|	Справочник.ВариантыКомплектацииНоменклатуры.Товары КАК ВариантыКомплектацииНоменклатурыТовары
		|ГДЕ
		|	НЕ ВариантыКомплектацииНоменклатурыТовары.Ссылка.ПометкаУдаления
		|	И ВариантыКомплектацииНоменклатурыТовары.Ссылка.Владелец = &Номенклатура
		|	И ВариантыКомплектацииНоменклатурыТовары.Ссылка.Характеристика = &Характеристика
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоступныеОстатки.Характеристика КАК Характеристика,
		|	ДоступныеОстатки.Номенклатура КАК Номенклатура,
		|	ДоступныеОстатки.Свободно КАК Свободно
		|ПОМЕСТИТЬ Остатки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
		|		ВЫБОР
		|			КОГДА ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток < 0
		|				ТОГДА 0
		|			ИНАЧЕ ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток
		|		КОНЕЦ КАК Свободно,
		|		ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика
		|	ИЗ
		|		РегистрНакопления.ЗапасыИПотребности.Остатки(
		|				,
		|				Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|					И Склад = &Склад
		|					И Номенклатура В
		|						(ВЫБРАТЬ
		|							Комплектация.Номенклатура
		|						ИЗ
		|							Комплектация)) КАК ЗапасыИПотребностиОстатки) КАК ДоступныеОстатки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	Комплектация.Номенклатура КАК Номенклатура,
		|	Комплектация.Количество КАК Количество,
		|	Комплектация.Ссылка КАК Ссылка,
		|	Комплектация.КоличествоКомплект КАК КоличествоКомплект,
		|	Остатки.Свободно КАК Свободно,
		|	ВЫРАЗИТЬ(Остатки.Свободно / Комплектация.Количество КАК ЧИСЛО(10, 0)) КАК МаксЧислоКомплектов
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
		|	Комплектация КАК Комплектация
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Остатки КАК Остатки
		|		ПО Комплектация.Номенклатура = Остатки.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Комплектация.Ссылка КАК Ссылка,
		|	СУММА(Комплектация.ЧислоКомплектующих) КАК ЧислоКомплектующих
		|ПОМЕСТИТЬ ЧислоКомплектующихТаб
		|ИЗ
		|	Комплектация КАК Комплектация
		|
		|СГРУППИРОВАТЬ ПО
		|	Комплектация.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.Ссылка КАК Ссылка,
		|	МИНИМУМ(ВременнаяТаблица.МаксЧислоКомплектов) КАК МаксЧислоКомплектов,
		|	СУММА(1) КАК ЧислоКомплектующихИтог
		|ПОМЕСТИТЬ ТабМаксимальноеКоличество
		|ИЗ
		|	ВременнаяТаблица КАК ВременнаяТаблица
		|
		|СГРУППИРОВАТЬ ПО
		|	ВременнаяТаблица.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.Ссылка КАК Ссылка,
		|	МАКСИМУМ(ВременнаяТаблица.КоличествоКомплект) КАК КоличествоКомплект,
		|	МАКСИМУМ(ТабМаксимальноеКоличество.МаксЧислоКомплектов) КАК МаксЧислоКомплектов,
		|	МАКСИМУМ(ТабМаксимальноеКоличество.МаксЧислоКомплектов * ВременнаяТаблица.КоличествоКомплект) КАК МаксимальноеКоличество
		|ИЗ
		|	ВременнаяТаблица КАК ВременнаяТаблица
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЧислоКомплектующихТаб КАК ЧислоКомплектующихТаб
		|		ПО ВременнаяТаблица.Ссылка = ЧислоКомплектующихТаб.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТабМаксимальноеКоличество КАК ТабМаксимальноеКоличество
		|		ПО ВременнаяТаблица.Ссылка = ТабМаксимальноеКоличество.Ссылка
		|ГДЕ
		|	ЧислоКомплектующихТаб.ЧислоКомплектующих = ТабМаксимальноеКоличество.ЧислоКомплектующихИтог
		|
		|СГРУППИРОВАТЬ ПО
		|	ВременнаяТаблица.Ссылка";

	Если Характеристика = Неопределено Тогда
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
	КонецЕсли; 
	Запрос.УстановитьПараметр("Номенклатура",Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",Характеристика); 
	Запрос.УстановитьПараметр("Склад",Объект.Склад);   
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Объект.ВариантыКомплектации.Очистить();
	Пока Выборка.Следующий() Цикл	
		НС = Объект.ВариантыКомплектации.Добавить();
		НС.ВариантКомплектации = Выборка.ссылка;
		Если ХарактеристикиИспользуются Тогда  
			НС.МожноСобрать = Выборка.КоличествоКомплект;
			НС.МаксЧислоКомплектов = 1; 
		
		Иначе
			НС.МожноСобрать = Выборка.МаксимальноеКоличество;
			НС.МаксЧислоКомплектов = Выборка.МаксЧислоКомплектов;
		КонецЕсли;
		Нс.КоличествоКомплект = Выборка.КоличествоКомплект;
	КонецЦикла; 
	 
	
КонецПроцедуры

&НаСервере	
Функция ЕстьВариантыКомплектации(Номенклатура,Характеристика) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВариантыКомплектацииНоменклатуры.Владелец КАК Владелец
	|ИЗ
	|	Справочник.ВариантыКомплектацииНоменклатуры КАК ВариантыКомплектацииНоменклатуры
	|ГДЕ
	|	ВариантыКомплектацииНоменклатуры.Владелец = &Владелец
	|	И ВариантыКомплектацииНоменклатуры.Характеристика = &Характеристика
	|	И НЕ ВариантыКомплектацииНоменклатуры.ПометкаУдаления";  
	
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика",?(Характеристика = Неопределено,Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка(),Характеристика));
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

