			ОписаниеОповещения = Новый ОписаниеОповещения("ОбновитьЭлементы", ЭтотОбъект);

			ПараметрыФормы = Новый Структура("ТолькоОтправкаКода, НовыйПартнер, Владелец, ИзменениеТелефона, Действие", 
				Истина, Ложь, Объект.Партнер, Истина, "1c_verify_phone");
			ОткрытьФорму("Справочник.БонусныеПрограммыЛояльности.Форма.Спр_СМСИдентификация", ПараметрыФормы, Неопределено,,,,ОписаниеОповещения);		
	КонецЕсли;
	
