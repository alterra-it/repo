&НаКлиенте
Процедура ПартнерПриИзменении(Элемент)
	
	//АвтоопределениеДистрибуция 
	ОчиститьПараметрыАвтоопределениеДистрибуция();
	//
	ПартнерПриИзмененииНаСервере();
