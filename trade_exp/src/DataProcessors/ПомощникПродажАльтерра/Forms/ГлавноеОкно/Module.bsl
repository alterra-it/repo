&НаКлиенте
Процедура ДобавитьФотоНоменклатурыПриИзменении(Элемент)
	ФотоНоменклатурыПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура ФотоНоменклатурыПриИзмененииНаСервере()
	
	КолонкаНаименование = Элементы.Найти("СписокНоменклатураНаименование");

	Если ДобавитьФотоНоменклатуры Тогда
			
		ЗапросФото();
		Если Элементы.Найти("СписокНоменклатураФото") = Неопределено Тогда
			ИскомаяКолонка = Элементы.Найти("СписокНоменклатураВидЦены");
			КолонкаФото = Элементы.Вставить("СписокНоменклатураФото", Тип("ПолеФормы"), Элементы.СписокНоменклатура, ИскомаяКолонка);
		    КолонкаФото.Вид = ВидПоляФормы.ПолеКартинки;
			КолонкаФото.Высота = 4;
			КолонкаФото.Ширина = 10;
			КолонкаФото.РазмерКартинки = РазмерКартинки.РеальныйРазмер;
			КолонкаФото.ПутьКДанным = "СписокНоменклатура.ФайлКартинки";
			КолонкаФото.Заголовок = "Фото";
			КолонкаНаименование.АвтоВысотаЯчейки = Истина;
		КонецЕсли;
	Иначе
		МодифицироватьЗапрос();
		КолонкаНаименование.АвтоВысотаЯчейки = Ложь;
	КонецЕсли;

    Если НЕ (Элементы.Найти("СписокНоменклатураФото") = Неопределено) Тогда			
      	Элементы.СписокНоменклатураФото.Видимость = ДобавитьФотоНоменклатуры;
    КонецЕсли;	
    	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СписокНоменклатураПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
  
	КоличествоСтрокВыборки = Строки.Количество();  
	Если КоличествоСтрокВыборки > 0 Тогда
		Для Каждого Строка ИЗ Строки Цикл
		 	ПерваяСтрока = Строка; 
		 	Прервать
		КонецЦикла;	
		Если ПерваяСтрока.Значение.Данные.Свойство("ФайлКартинки") Тогда
			  Запрос = Новый Запрос;
			  Запрос.Текст = "ВЫБРАТЬ 
			   |СправочникНоменклатура.Ссылка КАК Ссылка,
			   |СправочникНоменклатура.ФайлКартинки КАК ФайлКартинки
			   |ИЗ Справочник.Номенклатура КАК СправочникНоменклатура
			   |ГДЕ СправочникНоменклатура.Ссылка В (&Номенклатура)
			   |И НЕ СправочникНоменклатура.ФайлКартинки.ПометкаУдаления";
			   Запрос.УстановитьПараметр("Номенклатура", Строки.ПолучитьКлючи());
			   Выборка = Запрос.Выполнить().Выбрать();
			   Пока Выборка.Следующий() Цикл
			   	СтрокаСписка = Строки[Выборка.Ссылка];
				   	Если Выборка.ФайлКартинки <> Справочники.НоменклатураПрисоединенныеФайлы.ПустаяСсылка() ТОгда
				   		Попытка
				   	   		СтрокаСписка.Данные["ФайлКартинки"] = АдресФото(Выборка.ФайлКартинки);
				   	   	Исключение
				   			СтрокаСписка.Данные["ФайлКартинки"] = "";
				   		КонецПопытки;
			    	Иначе
			        	СтрокаСписка.Данные["ФайлКартинки"] = "";
				   	КонецЕсли
			   КонецЦикла;
		КонецЕсли;
	КонецЕсли	
		 
КонецПроцедуры

Процедура ЗапросФото()
	Если ДобавитьФотоНоменклатуры Тогда
		ТекстЗапросаСписка = СписокНоменклатура.ТекстЗапроса;
		Если СтрНайти(ТекстЗапросаСписка, "ФайлКартинки") = 0 Тогда  
			СписокНоменклатура.ТекстЗапроса = СтрЗаменить(ТекстЗапросаСписка, "СправочникНоменклатура.Ссылка КАК Ссылка,",
				"СправочникНоменклатура.Ссылка КАК Ссылка, ВЫРАЗИТЬ("""" КАК Строка (250)) КАК ФайлКартинки,")
		КонецЕсли;	
	КонецЕсли
КонецПроцедуры		

&НаСервереБезКонтекста
Функция АдресФото(Номенклатура)     
	ФайлКартинки = Номенклатура;
	Попытка
		АдресКартинки = РаботаСФайлами.ДвоичныеДанныеФайла(ФайлКартинки);
	Исключение
		Возврат "";
	КонецПопытки;
	Картинка = Новый Картинка(АдресКартинки, Истина);
	Обработка = Новый ОбрабатываемаяКартинка(Картинка);
	Обработка.УстановитьРазмер(60, 60);
	Картинка = Обработка.ПолучитьКартинку();        
	Возврат ПоместитьВоВременноеХранилище(Картинка, Новый УникальныйИдентификатор);    
КонецФункции

