	ДобавитьАВСКлассификацию(СписокНоменклатура);
КонецПроцедуры

#КонецОбласти

#Область СобытияПодбора

&НаКлиенте
Процедура СписокНоменклатураПриАктивизацииСтроки(Элемент)
	Если НавигацияПоХарактеристикам Тогда
		Возврат;
	КонецЕсли;           
	
	Если Не (Элемент.ТекущаяСтрока = Неопределено) И Не (ПредыдущаяСтрокаНоменклатуры = Неопределено) И (Элемент.ТекущаяСтрока = ПредыдущаяСтрокаНоменклатуры) Тогда
		Возврат
	КонецЕсли;
	
	СтрокаТаблицыНоменклатуры = Элемент.ТекущиеДанные;
	ТекущаяСтрокаНоменклатуры = СтруктураСтрокиНоменклатуры();
	
	Если СтрокаТаблицыНоменклатуры = Неопределено Тогда
		ПодборТоваровКлиентСервер.ОчиститьТаблицуОстатков(ЭтаФорма);
	Иначе
		ЗаполнитьЗначенияСвойств(ТекущаяСтрокаНоменклатуры, СтрокаТаблицыНоменклатуры);
		
		Если ЗначениеЗаполнено(СтрокаТаблицыНоменклатуры.Номенклатура) Тогда
			ПодключитьОбработчикОжидания("ЗаполнитьДополнительныеТаблицы_ОбработчикОжидания", 0.1, Истина);
		КонецЕсли;   
		
		//СкрытиеКоманды Пополнить, если используются характеристики  или нет вариантов комплектации
		Элементы.СписокНоменклатураКонтекстноеМенюПополнить.Видимость = НЕ СтрокаТаблицыНоменклатуры.ХарактеристикиИспользуются И
		ЕстьВариантыКомплектации(СтрокаТаблицыНоменклатуры.Номенклатура,Неопределено);
		//
	КонецЕсли;               
	
	ПредыдущаяСтрокаНоменклатуры = Элемент.ТекущаяСтрока;   
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДополнительныеТаблицы_ОбработчикОжидания() 
	
	Если ПоказыватьИерархию И Не Элементы.ПодборИерархия.Скрыта() Тогда
		УстановитьТекущуюСтрокуИерархииНоменклатуры();
	КонецЕсли;
	
	Если ПоказыватьСекцию2 И Не Элементы.ПодборСекция2.Скрыта() Тогда        
		
		Если ОтображатьОстатки И ЗначениеЗаполнено(Объект.Склад) И Не Элементы.ПодборОстатки.Скрыта() Тогда
			ПараметрыФормы= Новый Структура("ОтображатьОстатки,ОстаткиТоваров,ТекущаяДатаСеанса,ИспользоватьРасширеннуюФормуПодбораКоличестваИВариантовОбеспечения,РежимПодбораБезСуммовыхПараметров,ОтображатьОстатки,ТекущаяСтрокаНоменклатуры,НавигацияПоХарактеристикам,Валюта,Соглашение,Склады,ВидыЦен");
			ЗаполнитьЗначенияСвойств(ПараметрыФормы, ЭтаФорма);  
			если ДопМодуль.НовоеЦенообразование() тогда
				ПараметрыФормы.Вставить("Подразделение",Объект.Подразделение);
			конецесли;	
			ТекущаяДатаСеанса = ТекущаяДата();
			ПодборТоваровКлиент.ПолучитьИнформациюОТовареПриПродаже(ПараметрыФормы);
		КонецЕсли;
		
		ЗаполнитьДополнительныеТаблицыНаСервере();
		
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДополнительныеТаблицыНаСервере()
	
	Если ПоказыватьАналоги И Не Элементы.ПодборАналоги.Скрыта()  Тогда
		ЗаполнитьАналогиСервер(ТекущаяСтрокаНоменклатуры.Номенклатура, ТекущаяСтрокаНоменклатуры.ВидЦены);
	КонецЕсли;
	
	Если ПоказыватьСопутку И ЗначениеЗаполнено(Объект.Склад) И Не Элементы.ПодборСопутствующие.Скрыта() Тогда
		ЗаполнитьСопутствующиеТовары(ТекущаяСтрокаНоменклатуры.Номенклатура, ТекущаяСтрокаНоменклатуры.ВидЦены);
	КонецЕсли;
	
	Если ПоказыватьСписокЦен И Не Элементы.ПодборСписокЦен.Скрыта() Тогда 
		ЗаполнитьСписокЦен(ТекущаяСтрокаНоменклатуры.Номенклатура);
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ПереключательСопутствующиеКомплектующиеПриИзменении(Элемент)
	ПоказатьСопутствующие = ?(ПереключательСопутствующиеКомплектующие = 1, Истина, Ложь);
	Элементы.СопутствующиеТовары.Видимость = ПоказатьСопутствующие;
	Элементы.КомплектующиеТовары.Видимость = Не ПоказатьСопутствующие;
	Если Элементы.КомплектующиеТоварыНоменклатура.Ширина <> Элементы.СопутствующиеТоварыНоменклатура.Ширина Тогда
		Элементы.КомплектующиеТоварыНоменклатура.Ширина = Элементы.СопутствующиеТоварыНоменклатура.Ширина;
	КонецЕсли
КонецПроцедуры      

&НаКлиенте
Процедура ПереключательАналогиФильтрыПриИзменении(Элемент)
	
	ПоказатьАналогиФильтры = ?(ПереключательАналогиФильтры = 1, Ложь, Истина);
	Элементы._Аналоги.Видимость = Не ПоказатьАналогиФильтры;
	ПоказыватьАналоги = Не ПоказатьАналогиФильтры;
	ПоказыватьФильтры = ПоказатьАналогиФильтры;
	Элементы.Фильтры.Видимость = ПоказатьАналогиФильтры;
	Элементы.ДействияФильтров.Видимость = ПоказатьАналогиФильтры;
	ЗаполнитьФильтрыСервер();
	
КонецПроцедуры


&НаКлиенте
Процедура СписокНоменклатураВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Элементы.ПодборНазадКНоменклатуре.Видимость= Истина;
	
	СтрокаТаблицыНоменклатуры = Элементы.СписокНоменклатура.ТекущиеДанные;
	// блокировка услуги (временно) 
	Если ЕстьБлокировкаУслуги Тогда
		Если СтрокаТаблицыНоменклатуры.Номенклатура = АльтерраОбщегоНазначения.УслугаДоставкиБезНДС()
			Или СтрокаТаблицыНоменклатуры.Номенклатура = АльтерраОбщегоНазначения.УслугаРазгрузкиБезНДС() Тогда
			ПоказатьПредупреждение( , "Эта услуга временно не используется при продажах!");
				Возврат;
		КонецЕсли;
	КонецЕсли;
	
	//Маркировка
	Если НЕ СкладОрдерный() Тогда
	  Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(СтрокаТаблицыНоменклатуры.Номенклатура) Тогда
		ПоказатьПредупреждение( , "Вы пытаетесь добавить маркированный товар, его можно приобрести только на кассе!");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ТекущаяСтрокаНоменклатуры = СтруктураСтрокиНоменклатуры();
	ЗаполнитьЗначенияСвойств(ТекущаяСтрокаНоменклатуры, СтрокаТаблицыНоменклатуры);
	
	Если СтрокаТаблицыНоменклатуры.ХарактеристикиИспользуются Тогда
		ПоказатьТоварИлиХарактеристики("Хар");
		ЗаполнитьХарактеристики(СтрокаТаблицыНоменклатуры.Номенклатура, СтрокаТаблицыНоменклатуры.ВидЦены);
	Иначе
		ВыбратьКоличество();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьКоличество(ПараметрыТовара=НЕОПРЕДЕЛЕНО)
	Оповещение= Новый ОписаниеОповещения("ВыборКоличестваЗавершение", ЭтотОбъект);
	если ПараметрыТовара=НЕОПРЕДЕЛЕНО тогда
		ПараметрыФормы = Новый Структура("Номенклатура",ТекущаяСтрокаНоменклатуры.Номенклатура);
	иначе
		ПараметрыФормы= Новый Структура("ПараметрыТовара", ПараметрыТовара);
	конецесли;
	
	ОткрытьФорму("Обработка.ПомощникПродажАльтерра.Форма.ВыборКоличества",ПараметрыФормы,ЭтаФорма,,,,Оповещение,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ВыборКоличестваЗавершение(Результат, ДопПараметры) Экспорт 
	Если ЗначениеЗаполнено(Результат) Тогда
		Количество= Результат.Количество;
		
		если Результат.Свойство("ПараметрыТовара") тогда
			ПараметрыТовара =Результат.ПараметрыТовара;
		иначе
			ПараметрыТовара = ПодборТоваровКлиентСервер.ПараметрыТовара(ТекущаяСтрокаНоменклатуры.Номенклатура);
			ЗаполнитьЗначенияСвойств(ПараметрыТовара, ТекущаяСтрокаНоменклатуры);
		конецесли;
		ПараметрыТовара.Склад = Объект.Склад;
		ПараметрыТовара.КоличествоУпаковок = Количество;
		Если ПараметрыТовара.ЭтоТовар Тогда
			Нехватает= ПараметрыТовара.Доступно-Количество;
			Если Нехватает < 0 Тогда
				ПараметрыТовара.Вставить("Нехватает", -Нехватает);
				ПараметрыТовара.Вставить("ЕстьНехватка", Истина);
			КонецЕсли;
		КонецЕсли;
		
		ДобавитьВКорзинуНаКлиенте(ПараметрыТовара, Истина);
		//АвтоопределениеДистрибуция
		Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы") Тогда
			РаспределениеСтоимостиДоставкиДистрибуция();
		КонецЕсли;
		//
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Функция СтруктураСтрокиНоменклатуры() Экспорт
	СтруктураСтроки = Новый Структура();
	СтруктураСтроки.Вставить("Ссылка");
	СтруктураСтроки.Вставить("Родитель");
	СтруктураСтроки.Вставить("ВидНоменклатуры");
	СтруктураСтроки.Вставить("ТипНоменклатуры");
	СтруктураСтроки.Вставить("Упаковка");
	СтруктураСтроки.Вставить("ЕдиницаИзмерения");
	СтруктураСтроки.Вставить("Артикул");
	СтруктураСтроки.Вставить("Номенклатура");
	СтруктураСтроки.Вставить("ЦеноваяГруппа");
	СтруктураСтроки.Вставить("ЭтоТовар",Ложь);
	СтруктураСтроки.Вставить("ЭтоУслуга", Ложь);
	СтруктураСтроки.Вставить("ПометкаУдаления", Ложь);
	СтруктураСтроки.Вставить("ХарактеристикиИспользуются", Ложь);
	СтруктураСтроки.Вставить("ЭтоГруппа", Ложь);
	СтруктураСтроки.Вставить("ИспользованиеХарактеристик", Ложь);
	СтруктураСтроки.Вставить("Цена", 0);
	СтруктураСтроки.Вставить("ВНаличииОстаток", 0);
	СтруктураСтроки.Вставить("Доступно", 0);
	СтруктураСтроки.Вставить("ВладелецХарактеристик");
	СтруктураСтроки.Вставить("ВидЦены");
	
	Возврат СтруктураСтроки;
КонецФункции

#КонецОбласти

#Область Поиск
&НаКлиенте
Процедура Поиск(Команда)
	
	ОчиститьСообщения();
	Если Не ПоискПроизведен Тогда
		ВыполнитьПоискНоменклатурыНаСервере(СтрокаПоискаНоменклатура);
		ПодключитьОбработчикОжидания("ВернутьАктивностьВСтрокуПоиска", 0.5, Истина);
	КонецЕсли;
	ПоискПроизведен = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура СтрокаПоискаНоменклатураПриИзменении(Элемент)

	ОчиститьСообщения();
	ВыполнитьПоискНоменклатурыНаСервере(СтрокаПоискаНоменклатура);
	ПодключитьОбработчикОжидания("ВернутьАктивностьВСтрокуПоиска", 0.5, Истина);
	ПоискПроизведен = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ВернутьАктивностьВСтрокуПоиска()
	ЭтаФорма.ТекущийЭлемент= Элементы.СтрокаПоискаНоменклатура;
КонецПроцедуры

&НаСервере
Процедура ВыполнитьПоискНоменклатурыНаСервере(Текст) 
	
	ШаблонПоиска = СокрЛП(Текст);
	
	Если ЗначениеЗаполнено(ШаблонПоиска) Тогда
		
		МассивОтбора = Новый СписокЗначений();	
		МассивСлов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ШаблонПоиска," ", Истина, Истина);
		МассивСлов = ПеревестиВРег(МассивСлов);
		КоличествоСлов = МассивСлов.Количество();
		
		Если КоличествоСлов > 0 Тогда
			ТекстЗапроса = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СпрНоменклатура.Ссылка КАК Номенклатура,
			|	СпрНоменклатура.Наименование КАК Наименование,
			|	СпрНоменклатура.Артикул КАК Артикул,
			|	СпрНоменклатура.Код КАК Код
			|ИЗ
			|	Справочник.Номенклатура КАК СпрНоменклатура
			|ГДЕ
			|	НЕ СпрНоменклатура.ЭтоГруппа
			|	И НЕ СпрНоменклатура.ПометкаУдаления";	
			
			ДлиннаСтроки = 0;
			
			Если ТипДанныхПоиска = "Наименование" Тогда
				ДлиннаСтроки = "200";
			ИначеЕсли ТипДанныхПоиска = "Артикул" Тогда
				ДлиннаСтроки = "30";
			Иначе
				ДлиннаСтроки = "15";
			КонецЕсли;
			
			НомерПараметра = 1;
			Для Каждого ПодстрокаПоиска Из МассивСлов Цикл
				ТекстЗапроса = ТекстЗапроса + "
				|И ВЫРАЗИТЬ(СпрНоменклатура." + ТипДанныхПоиска + " КАК СТРОКА(" + ДлиннаСтроки + ")) ПОДОБНО &Парам" + Строка(НомерПараметра);
				НомерПараметра = НомерПараметра + 1;
			КонецЦикла;
			
			Запрос = Новый Запрос();
			Запрос.Текст = ТекстЗапроса;
			
			НомерПараметра = 1;
			Для Каждого ПодстрокаПоиска Из МассивСлов Цикл
				Парам = "Парам" + Строка(НомерПараметра); 
				Запрос.УстановитьПараметр(Парам, "%"+СокрЛП(ПодстрокаПоиска)+"%");
				НомерПараметра = НомерПараметра + 1;
			КонецЦикла;
			
			Результат = Запрос.Выполнить();
			
			МассивОтбора.ЗагрузитьЗначения(Результат.Выгрузить().ВыгрузитьКолонку("Номенклатура"));
		КонецЕсли;	
		
		Если МассивОтбора.Количество() > 0 Тогда
			
			МодифицироватьЗапрос();
			
			//Оптимизация
			ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
			СписокНоменклатура,
			"Номенклатура",
			МассивОтбора,
			Истина);
		Иначе 
			Сообщить("По запросу ничего не найдено, скорректируйте строку запроса.");
		КонецЕсли;
	Иначе
		//Оптимизация
		ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		СписокНоменклатура,
		"Номенклатура",
		Неопределено,
		Истина);
	КонецЕсли;    
	ЗаполнитьФильтрыСервер();
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПеревестиВРег(МассивСлов)
	
	НовыйМассив = Новый Массив; 
	
	Для Каждого Стр Из МассивСлов Цикл
		НовыйМассив.Добавить(ВРег(СокрЛП(Стр)));
	КонецЦикла;
	
	Возврат НовыйМассив; 
	
КонецФункции

#КонецОбласти

#Область Иерархия

&НаКлиенте
Процедура ОтборПоИерархии()
	Если ИспользоватьФильтры Тогда
		Если ТекущаяИерархияНоменклатуры = Элементы.ИерархияНоменклатуры.ТекущаяСтрока Тогда
			Возврат;
		КонецЕсли;
		ТекущаяИерархияНоменклатуры = Элементы.ИерархияНоменклатуры.ТекущаяСтрока;
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(СписокНоменклатура,
		"ВидНоменклатуры",
		ТекущаяИерархияНоменклатуры,
		ВидСравненияКомпоновкиДанных.Равно,
		"ВидНоменклатуры",
		ИспользоватьФильтры);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановитьТекущуюСтрокуИерархииНоменклатуры() 
	
	ТекущаяСтрока = Элементы.СписокНоменклатура.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ТекущаяСтрока) = Тип("СтрокаГруппировкиДинамическогоСписка") Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.СписокНоменклатура.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	
	Если Элементы.ИерархияНоменклатуры.ТекущаяСтрока = ТекущиеДанные.ВидНоменклатуры Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ИерархияНоменклатуры.ТекущаяСтрока = ТекущиеДанные.ВидНоменклатуры;
	ТекущаяИерархияНоменклатуры                 = ТекущиеДанные.ВидНоменклатуры;
	ПредыдущаяСтрокаИерархии 					= ТекущиеДанные.ВидНоменклатуры;   
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказыватьИерархиюПриИзменении(Элемент)
	Элементы.ПодборИерархия.Видимость= ПоказыватьИерархию;
	ПредыдущаяСтрокаИерархии = Неопределено;
	Если ПоказыватьИерархию Тогда
		Элементы.ДобавитьФотоНоменклатуры.Доступность = Истина;
	Иначе
		Элементы.ДобавитьФотоНоменклатуры.Доступность = Ложь;
		ДобавитьФотоНоменклатуры = Ложь;
		Если Не Элементы.Найти("СписокНоменклатураФото") = Неопределено Тогда
			Элементы.СписокНоменклатураФото.Видимость = Ложь;	
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ПоказатьРезервы

&НаКлиенте
Процедура ПоказатьРезервы(Команда)
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", Элементы.СписокНоменклатура.ТекущаяСтрока);
	ПараметрыФормы.Вставить("Склад", Объект.Склад);
	ОткрытьФорму("ОбщаяФорма.ФормаРезервыПоСкладам", ПараметрыФормы, ЭтаФорма);
КонецПроцедуры

#КонецОбласти

#Область Остатки   

&НаСервере
Функция ВидЦеныПоСоглашению(Соглашение,ВидЦен,Номенклатура=НЕОПРЕДЕЛЕНО)
	
	если не ДопМодуль.НовоеЦенообразование() тогда
		возврат Соглашение.ВидЦен;
	конецесли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ВидыЦен.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
	|		ПО СоглашенияСКлиентами.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
	|			И (ВидыЦен.ФорматПодразделения = &ФорматПодразделения)
	|			И (ВидыЦен.РегионПрисутствия = &РегионПрисутствия)
	|ГДЕ
	|	СоглашенияСКлиентами.Ссылка = &Соглашение
	|	И НЕ ВидыЦен.Ссылка ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("РегионПрисутствия", Объект.Подразделение.РегионПрисутствия);
	Запрос.УстановитьПараметр("Соглашение", Соглашение);
	Запрос.УстановитьПараметр("ФорматПодразделения", Объект.Подразделение.ФорматПодразделения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		возврат ВыборкаДетальныеЗаписи.ссылка;  
	иначе
		возврат ВидЦен;
	Конецесли;
	
	
КонецФункции 

&НаСервере
Процедура ЗаполнитьВидыЦен()
	ВидыЦен.Очистить();
	
	Если ЗначениеЗаполнено(Объект.Соглашение) Тогда
		ВидЦены= ВидЦеныПоСоглашению(Объект.Соглашение,ВидЦены);
		мВидыЦен= ВидыЦенПоСоглашениюСКлиентом(Объект.Соглашение);
	Иначе
		ВидыЦен.Добавить(ВидЦены);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(мВидыЦен) Тогда
		Для Каждого тВидЦены Из мВидыЦен Цикл
			ВидыЦен.Добавить(тВидЦены);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВидыЦенПоСоглашениюСКлиентом(СоглашениеСКлиентом)
	Запрос = Новый Запрос();
	если ДопМодуль.НовоеЦенообразование() тогда
		Возврат ПодбортоваровСервер.ВидыЦенПоСоглашениюСКлиентом_НЦ(СоглашениеСКлиентом,Объект.Подразделение);
	иначе
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	СоглашениеШапка.ВидЦен КАК ВидЦен
		|ИЗ
		|	Справочник.СоглашенияСКлиентами КАК СоглашениеШапка
		|ГДЕ
		|	СоглашениеШапка.Ссылка = &Соглашение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Товары.ВидЦены
		|ИЗ
		|	Справочник.СоглашенияСКлиентами.Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &Соглашение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЦеновыеГруппы.ВидЦен
		|ИЗ
		|	Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК ЦеновыеГруппы
		|ГДЕ
		|	ЦеновыеГруппы.Ссылка = &Соглашение";
	конецесли;
	Запрос.УстановитьПараметр("Соглашение", СоглашениеСКлиентом);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВидЦен");
КонецФункции

&НаСервере
Процедура ЗаполнитьСклады()
	Склады.Очистить();
	
	Если ЗначениеЗаполнено(Объект.Склад) Тогда
		ВидыЦен.Добавить(Склады);
	КонецЕсли;
	// Устинов	
	//ОбновитьПараметрыЦены();
	Объект.Подразделение=объект.склад.Подразделение;
	
КонецПроцедуры
#КонецОбласти

#Область Характеристики

&НаСервере
Процедура ЗаполнитьХарактеристики(Номенклатура, ВидЦены)
	УстановитьПривилегированныйРежим(Истина);
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ХарактеристикиНоменклатуры.Владелец КАК Номенклатура,
	|	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
	|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
	|	ХарактеристикиНоменклатуры.Владелец.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ХарактеристикиНоменклатуры.ПометкаУдаления КАК ПометкаУдаления,
	|	&ВидЦены КАК ВидЦены,
	|	&Склад КАК Склад,
	|	ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток, 0) КАК Остаток,
	|	ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) - ЕСТЬNULL(ТоварыКОтгрузкеОстатки.ВРезервеОстаток, 0) КАК Доступно,
	|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК Цена,
	|	ИСТИНА КАК ХарактеристикиИспользуются,
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка) КАК ВариантРасчетаЦеныНабора,
	|	ЛОЖЬ КАК СодержитТовары,
	|	ЛОЖЬ КАК СодержитУслуги
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ТекущаяДата, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ХарактеристикиНоменклатуры.Владелец = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = ЦеныНоменклатурыСрезПоследних.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ (
	|		ВЫБРАТЬ
	|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
	|			ЗапасыИПотребностиОстатки.ВНаличииОстаток КАК ВНаличии
	|		ИЗ
	|			РегистрНакопления.ЗапасыИПотребности.Остатки(
	|					,
	|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки) КАК РаспределениеЗапасов
	|		ПО ХарактеристикиНоменклатуры.Владелец = РаспределениеЗапасов.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = РаспределениеЗапасов.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &Склад) КАК ТоварыКОтгрузкеОстатки
	|		ПО ХарактеристикиНоменклатуры.Владелец = ТоварыКОтгрузкеОстатки.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = ТоварыКОтгрузкеОстатки.Характеристика
	|ГДЕ
	|	ХарактеристикиНоменклатуры.Владелец = &Владелец";
	
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Характеристики.Загрузить(ТЗ);
КонецПроцедуры	

&НаКлиенте
Процедура ХарактеристикиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекущиеДанные= Элементы.Характеристики.ТекущиеДанные;
	ТекущаяСтрокаНоменклатуры = ПодборТоваровКлиентСервер.СтруктураСтрокиХарактеристик();
	ЗаполнитьЗначенияСвойств(ТекущаяСтрокаНоменклатуры, ТекущиеДанные);
	ВыбратьКоличество();
КонецПроцедуры

&НаКлиенте
Процедура ПодборНазадКНоменклатуре(Команда)
	ПоказатьТоварИлиХарактеристики("Товар");
КонецПроцедуры
#КонецОбласти

#Область Аналоги
&НаСервере
Процедура ЗаполнитьАналогиСервер(Номенклатура, ВидЦены)
	Если Номенклатура = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	УстановитьПривилегированныйРежим(Истина);
	Аналоги.Загрузить(РегистрыСведений.АналогиНоменклатуры.ПолучитьАналогиНоменклатуры(Номенклатура, ВидЦены, Объект.Склад));
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура _АналогиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	ТекущаяСтрокаАналога= Элементы._Аналоги.ТекущиеДанные;
	Если ТекущаяСтрокаАналога.ХарактеристикиИспользуются Тогда //Пока нет характеристик
		Элементы.СтраницыАналогов.ТекущаяСтраница = Элементы.СтраницаАналогиХарактеристик;
	Иначе
		ТекущаяСтрокаНоменклатуры = ПодборТоваровКлиентСервер.СтруктураСтрокиНоменклатуры();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрокаНоменклатуры, Элемент.ТекущиеДанные);
		ВыбратьКоличество();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СопутствующиеТовары

&НаСервере
Процедура ЗаполнитьСопутствующиеТовары(Номенклатура, ВидЦены)
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;	
	Запрос.Текст = 	
	"ВЫБРАТЬ
	|	ИСТИНА КАК ЭтоСопутсвующийТовар,
	|	СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ
	|	Справочник.СопутствующиеВидыНоменклатуры.СопутствующаяНоменклатура КАК СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура
	|ГДЕ
	|	СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Ссылка.Владелец = &ВидНоменклатуры
	|	И НЕ СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Номенклатура.ПометкаУдаления
	|	И НЕ СопутствующиеВидыНоменклатурыСопутствующаяНоменклатура.Ссылка.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЛОЖЬ,
	|	Комплектующие.Комплектующее
	|ИЗ
	|	РегистрСведений.Комплектующие КАК Комплектующие
	|ГДЕ
	|	Комплектующие.Номенклатура = &Номенклатура
	|	И НЕ Комплектующие.Комплектующее.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток, 0)) КАК Остаток,
	|	СУММА(ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) - ЕСТЬNULL(ТоварыКОтгрузкеОстатки.ВРезервеОстаток, 0)) КАК Доступно,
	|	МАКСИМУМ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0)) КАК Цена,
	|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс КАК Класс,
	|	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
	|	ВТ_Номенклатура.ЭтоСопутсвующийТовар КАК ЭтоСопутсвующийТовар
	|ПОМЕСТИТЬ ВТ_ДанныеПоНоменклатуре
	|ИЗ
	|	ВТ_Номенклатура КАК ВТ_Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ВТ_Номенклатура.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних(, Подразделение = &Подразделение) КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
	|		ПО ВТ_Номенклатура.Номенклатура = ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (
	|		ВЫБРАТЬ
	|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыИПотребностиОстатки.ВНаличииОстаток КАК ВНаличии 
	|		ИЗ
	|			РегистрНакопления.ЗапасыИПотребности.Остатки(
	|					,
	|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки) КАК РаспределениеЗапасов
	|		ПО ВТ_Номенклатура.Номенклатура = РаспределениеЗапасов.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &Склад) КАК ТоварыКОтгрузкеОстатки
	|		ПО ВТ_Номенклатура.Номенклатура = ТоварыКОтгрузкеОстатки.Номенклатура
	|ГДЕ
	|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс <> &КлассВыводимыйТовар
	|
	|СГРУППИРОВАТЬ ПО
	|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс,
	|	ВТ_Номенклатура.Номенклатура,
	|	ВТ_Номенклатура.ЭтоСопутсвующийТовар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДанныеПоНоменклатуре.Остаток КАК Остаток,
	|	ВТ_ДанныеПоНоменклатуре.Доступно КАК Доступно,
	|	ВТ_ДанныеПоНоменклатуре.Цена КАК Цена,
	|	ВТ_ДанныеПоНоменклатуре.Класс КАК Класс,
	|	&Склад КАК Склад,
	|	&ВидЦены КАК ВидЦены,
	|	ИСТИНА КАК ЭтоТовар,
	|	ЛОЖЬ КАК ЭтоУслуга,
	|	ЛОЖЬ КАК ЭтоГруппа,
	|	ВТ_ДанныеПоНоменклатуре.Номенклатура КАК Номенклатура,
	|	ВТ_ДанныеПоНоменклатуре.ЭтоСопутсвующийТовар КАК ЭтоСопутсвующийТовар
	|ИЗ
	|	ВТ_ДанныеПоНоменклатуре КАК ВТ_ДанныеПоНоменклатуре
	|ГДЕ
	|	НЕ(ВТ_ДанныеПоНоменклатуре.Класс = &КлассРазоваяПоставка
	|				И ВТ_ДанныеПоНоменклатуре.Остаток = 0)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ_ДанныеПоНоменклатуре.Номенклатура.Наименование";
	
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Запрос.УстановитьПараметр("ВидНоменклатуры", Номенклатура.ВидНоменклатуры);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Подразделение", Объект.Склад.Подразделение);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("КлассВыводимыйТовар", Перечисления.ABCКлассификация_Альтерра.ВыводимыйТовар);
	Запрос.УстановитьПараметр("КлассРазоваяПоставка", Перечисления.ABCКлассификация_Альтерра.РазоваяПоставка);
	
	//АвтоопределениеДистрибуция
	Если ЛегкийПрайс Тогда
		
		ЗаменяемыйТекст = "ИЗ
      	|	ВТ_ДанныеПоНоменклатуре КАК ВТ_ДанныеПоНоменклатуре
     	|ГДЕ
	    |	НЕ(ВТ_ДанныеПоНоменклатуре.Класс = &КлассРазоваяПоставка
	    |				И ВТ_ДанныеПоНоменклатуре.Остаток = 0)
		|
		|УПОРЯДОЧИТЬ ПО
	    |	ВТ_ДанныеПоНоменклатуре.Номенклатура.Наименование";
	     
		Запрос.Текст = СтрЗаменить(Запрос.Текст, ЗаменяемыйТекст, 
		 "ИЗ
	     |	ВТ_ДанныеПоНоменклатуре КАК ВТ_ДанныеПоНоменклатуре
	     |	ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК ДопРеквизиты
         |		ПО ВТ_ДанныеПоНоменклатуре.Номенклатура = ДопРеквизиты.Ссылка
         |			И (ДопРеквизиты.Свойство = &Свойство)
	     |ГДЕ
	     |  ДопРеквизиты.Значение = &Легкий
	     |  И НЕ(ВТ_ДанныеПоНоменклатуре.Класс = &КлассРазоваяПоставка
	     |				И ВТ_ДанныеПоНоменклатуре.Остаток = 0)
		 |
		 |УПОРЯДОЧИТЬ ПО
	     |	ВТ_ДанныеПоНоменклатуре.Цена /&ТекстЗапросаВесНоменклатуры УБЫВ");
		
		Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаВесНоменклатуры",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
		"Номенклатура.ЕдиницаИзмерения",
		"Номенклатура")); 
		
	     
		СвойствоВидТовараДляДоставки = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ВидТовараДляДоставки");
	    ЗначениеЛегкий = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Легкий",,,СвойствоВидТовараДляДоставки); 
	    Запрос.УстановитьПараметр("Свойство", СвойствоВидТовараДляДоставки);
	    Запрос.УстановитьПараметр("Легкий", ЗначениеЛегкий);
		
	КонецЕсли;
	//
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	СопутствующиеТовары.Загрузить(ТЗ.Скопировать(Новый Структура("ЭтоСопутсвующийТовар", Истина)));
	СопутствующиеТовары.Сортировать("Цена");
	
	НовыйЗаголовок = "Сопутствующие (" + Строка(СопутствующиеТовары.Количество()) + ")";
	Если НовыйЗаголовок <> Элементы.ПереключательСопутствующиеКомплектующие.СписокВыбора[0].Представление Тогда
		Элементы.ПереключательСопутствующиеКомплектующие.СписокВыбора[0].Представление = НовыйЗаголовок;
	КонецЕсли;
	
	КомплектующиеТовары.Загрузить(ТЗ.Скопировать(Новый Структура("ЭтоСопутсвующийТовар", Ложь)));     
	КомплектующиеТовары.Сортировать("Цена");                                                  
	НовыйЗаголовок = "Комплектующие (" + Строка(КомплектующиеТовары.Количество()) + ")";
	Если НовыйЗаголовок <> Элементы.ПереключательСопутствующиеКомплектующие.СписокВыбора[1].Представление Тогда
		Элементы.ПереключательСопутствующиеКомплектующие.СписокВыбора[1].Представление = "Комплектующие (" + Строка(КомплектующиеТовары.Количество()) + ")";
	КонецЕсли;
КонецПроцедуры	

&НаКлиенте
Процедура СопутствующиеТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТоварыВыбор(Элементы.СопутствующиеТовары.ТекущиеДанные)
КонецПроцедуры   

&НаКлиенте
Процедура КомплектующиеТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ТоварыВыбор(Элементы.КомплектующиеТовары.ТекущиеДанные)
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(ТекущаяСтрока)
	ТекущаяСтрокаНоменклатуры = ПодборТоваровКлиентСервер.СтруктураСтрокиНоменклатуры();
	ЗаполнитьЗначенияСвойств(ТекущаяСтрокаНоменклатуры, ТекущаяСтрока);
	
	ВыбратьКоличество();
КонецПроцедуры 

#КонецОбласти

#Область СписокЦен

&НаСервере
Процедура ЗаполнитьСписокЦен(Номенклатура)
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос; 
	если ДопМодуль.НовоеЦенообразование() тогда  
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.ВидЦены КАК ВидЦены,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			,
		|			Номенклатура = &Номенклатура
		|				И ВидЦены.ИспользоватьПриПродаже
		|				И ВидЦены.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДействияВидовЦен.Действует)) КАК ЦеныНоменклатурыСрезПоследних
		|ГДЕ
		|	ЦеныНоменклатурыСрезПоследних.Цена > 0
		|	И ЦеныНоменклатурыСрезПоследних.ВидЦены.ФорматПодразделения = &ФорматПодразделения
		|	И ЦеныНоменклатурыСрезПоследних.ВидЦены.РегионПрисутствия = &РегионПрисутствия
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЦеныНоменклатурыСрезПоследних.ВидЦены.Наименование";
		
		Запрос.УстановитьПараметр("ФорматПодразделения", Объект.Подразделение.ФорматПодразделения);
		Запрос.УстановитьПараметр("РегионПрисутствия",   Объект.Подразделение.РегионПрисутствия);
		
		
	иначе	
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.ВидЦены КАК ВидЦены,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			,
		|			Номенклатура = &Номенклатура
		|				И ВидЦены.ИспользоватьПриПродаже
		|				И ВидЦены.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыДействияВидовЦен.Действует)) КАК ЦеныНоменклатурыСрезПоследних
		|ГДЕ
		|	ЦеныНоменклатурыСрезПоследних.Цена > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЦеныНоменклатурыСрезПоследних.ВидЦены.Наименование";
	конецесли;
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	РезультатЗапроса = Запрос.Выполнить();
	СписокЦен.Загрузить(РезультатЗапроса.Выгрузить());
	
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ПосмотретьВсеЦены(Команда)
	ПараметрыОткрытияФормыЦен = Новый Структура;
	ПараметрыОткрытияФормыЦен.Вставить("Дата", ТекущаяДата());
	ПараметрыОткрытияФормыЦен.Вставить("Номенклатура", Элементы.СписокНоменклатура.ТекущиеДанные.Номенклатура);
	
	ОткрытьФорму("Обработка.ПомощникПродажАльтерра.Форма.ЦеныНоменклатуры", ПараметрыОткрытияФормыЦен, ЭтаФорма, Истина,,,, РежимОткрытияОкнаФормы.Независимый)
КонецПроцедуры

#КонецОбласти

#Область Корзина
&НаКлиенте
Процедура ДобавитьВКорзинуНаКлиенте(ПараметрыТовара, ПересчитатьОстатки=Ложь)
	Отбор = Новый Структура("Номенклатура, Характеристика");
	
	ЗаполнитьЗначенияСвойств(Отбор, ПараметрыТовара);
	
	РезультатПоиска = Объект.Товары.НайтиСтроки(Отбор);
	Если РезультатПоиска.Количество() = 0 Тогда
		ТекущаяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, ПараметрыТовара);
	Иначе
		ТекущаяСтрока = РезультатПоиска[0];
		ТекущаяСтрока.КоличествоУпаковок = ТекущаяСтрока.КоличествоУпаковок + ПараметрыТовара.КоличествоУпаковок;
	КонецЕсли;
	
	ПересчитатьЦеныВСтрокеКорзиныНаКлиенте(ТекущаяСтрока);
	
	Если ПересчитатьОстатки Тогда
		ПересчитатьДоступностьИНехваткуВСтрокеКорзины(ТекущаяСтрока)
	КонецЕсли;
	
	//Сообщение
	ТекстОповещения = Символы.ПС + НСтр("ru = 'Товар ""[Товар]"" стоимостью [Цена] [Валюта] в количестве [КоличествоУпаковок] [ЕдиницаИзмерения] добавлен в корзину'");
	ВставляемыеЗначения = Новый Структура("Товар, Цена, Валюта, КоличествоУпаковок, ЕдиницаИзмерения");
	ВставляемыеЗначения.Товар              = Строка(ТекущаяСтрока.Номенклатура) + ?(ЗначениеЗаполнено(ТекущаяСтрока.Характеристика)," (" + ТекущаяСтрока.Характеристика + ")","");
	ВставляемыеЗначения.Цена               = Формат(ТекущаяСтрока.Цена, "ЧДЦ=2; ЧН=");
	ВставляемыеЗначения.Валюта             = Объект.Валюта;
	ВставляемыеЗначения.ЕдиницаИзмерения   = ?(ЗначениеЗаполнено(ТекущаяСтрока.Упаковка), ТекущаяСтрока.Упаковка, НСтр("ru = 'ед.'"));
	ВставляемыеЗначения.КоличествоУпаковок = ПараметрыТовара.КоличествоУпаковок;
	
	ТекстОповещения = СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(ТекстОповещения, ВставляемыеЗначения);
	ПоказатьОповещениеПользователя(НСтр("ru = 'Товар добавлен в корзину'"), , ТекстОповещения);
	
	Если ЗначениеЗаполнено(СтрокаПоискаНоменклатура) Тогда
		ТекущийЭлемент = Элементы.СтрокаПоискаНоменклатура;
	КонецЕсли;  
	МногооборотнаяТараКлиент.ОбновитьСостояниеЗаполненияМногооборотнойТары(Объект.СостояниеЗаполненияМногооборотнойТары);
	РассчитатьИтоги();
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьИтоги(РассчитатьСкидки = Истина)
	
Если Объект.НужнаДоставка и Объект.ТоварыДляДоставки.Количество()>0 Тогда
	Объект.Вес = Объект.ТоварыДляДоставки.Итог("Вес");
	Объект.Объем = Объект.ТоварыДляДоставки.Итог("Объем");
	РасчетДоставкиПоНесколькимОснованиям = Истина;
Иначе
	Объект.Вес = Объект.Товары.Итог("Вес");
	Объект.Объем = Объект.Товары.Итог("Объем");
	РасчетДоставкиПоНесколькимОснованиям = Ложь;
КонецЕсли;	

	//Автоопределение 
	Объект.МаксимальнаяДлина = ПолучитьМаксимальнуюДлину(РасчетДоставкиПоНесколькимОснованиям); 

	//Поликарбонат  нужен объем поликарбонат 
	ОпределитьОбъемСУчетомСкрутокПоликарбоната(РасчетДоставкиПоНесколькимОснованиям);
	Элементы.ОбъемСучетомСкрутокПоликарбоната.Видимость = ОбъемСучетомСкрутокПоликарбоната >0;
	
	КоличествоТоваровВКорзине = Объект.Товары.Количество();
	Объект.СуммаДокумента = Объект.Товары.Итог("Сумма");
	Если КоличествоТоваровВКорзине > 0 И РассчитатьСкидки Тогда
		РассчитатьСкидкиНаценки();
	КонецЕсли;
	
	СуммаСкидки = Объект.Товары.Итог("СуммаАвтоматическойСкидки")+Объект.Товары.Итог("СуммаРучнойСкидки");
	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьЦеныВКорзине()
	ЗаполнитьЦены();
КонецПроцедуры 

&НаКлиенте
Процедура ПересчитатьЦеныВСтрокеКорзиныНаКлиенте(ТекущаяСтрока)
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.ВидЦены) Тогда
		Если НЕ РежимОфрмления = "Коммерческое" Тогда 
			Если ВариантыЗапросов = "ЦеныПоВидуЦен" Тогда
				ТекущаяСтрока.ВидЦены = ВидЦены;
			КонецЕсли;
		КонецЕсли;
	Иначе 
		Если ВариантыЗапросов = "ЦеныПоВидуЦен" Тогда
			ТекущаяСтрока.ВидЦены = ВидЦены;
		КонецЕсли;
	КонецЕсли;
	
	СтруктураДействий = ПолучитьСтруктуруДействийДляПересчета();    
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, Неопределено);	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьЦеныВСтрокеКорзиныНаСервере(ТекущаяСтрока)
	
	Если ВариантыЗапросов = "ЦеныПоВидуЦен" Тогда
		ТекущаяСтрока.ВидЦены = ВидЦены;
	КонецЕсли;
	
	СтруктураДействий = ПолучитьСтруктуруДействийДляПересчета();   
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, Неопределено);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруДействийДляПересчета()
	
	СтруктураПересчетаСуммыИЦены = Новый Структура;
	СтруктураПересчетаСуммыИЦены.Вставить("Дата",   ТекущаяДата());
	СтруктураПересчетаСуммыИЦены.Вставить("Валюта", Объект.Валюта);
	СтруктураПересчетаСуммыИЦены.Вставить("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьЦенуПродажи", СтруктураПересчетаСуммыИЦены);
	СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", Новый Структура("НалогообложениеНДС, Дата, Организация, ПоДатеОтгрузки", Объект.НалогообложениеНДС, Объект.Дата, Объект.Организация, Истина));
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммыИЦены);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммыИЦены);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки");
	СтруктураДействий.Вставить("ПересчитатьСуммуАвтоматическойСкидки");
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Ложь));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами");
	
	Возврат СтруктураДействий;
	
КонецФункции


&НаСервере
Процедура ЗаполнитьЦены()
	
	Если ВариантыЗапросов = "ЦеныПоСоглашению" И ЗначениеЗаполнено(Объект.Соглашение) Тогда
		АльтерраОбщегоНазначения.ЗаполнитьЦеныПоСоглашению(Объект);
	Иначе
		//!!Почему то в типовом заполнении цен теряется ставка НДС если указан вид цены
		Для Каждого стрТовара Из Объект.Товары Цикл
			ПересчитатьЦеныВСтрокеКорзиныНаСервере(стрТовара);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммыСУчетомБонусов(Объект, ТекущаяСтрока)  Экспорт
	
	СтруктураДействий = ПолучитьСтруктуруПересчетаСуммыСУчетомБонусов();
    
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
КонецПроцедуры

&НаСервере
Процедура ПересчитатьСуммыСУчетомБонусовВТЧ(Объект)  Экспорт
	
	СтруктураДействий = ПолучитьСтруктуруПересчетаСуммыСУчетомБонусов();
    
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий, КэшированныеЗначения);
КонецПроцедуры


&НаСервере
Функция ПолучитьСтруктуруПересчетаСуммыСУчетомБонусов()
	
	СтруктураДействий = Новый Структура;
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами"); 
	
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Ложь));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
	
	Возврат СтруктураДействий;
	
КонецФункции

&НаКлиенте
Процедура ПересчитатьСтрокиКорзины()
	Для Каждого стрТовара Из Объект.Товары Цикл
		ПересчитатьЦеныВСтрокеКорзиныНаКлиенте(стрТовара);
		ПересчитатьДоступностьИНехваткуВСтрокеКорзины(стрТовара);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьДоступностьИНехватку()
	Для Каждого стрТовара Из Объект.Товары Цикл
		ПересчитатьДоступностьИНехваткуВСтрокеКорзины(стрТовара);
	КонецЦикла;
КонецПроцедуры 
&НаКлиенте
Процедура ПересчитатьДоступностьИНехваткуВСтрокеКорзины(ТекущаяСтрока)
	ТипНоменклатуры = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущаяСтрока.Номенклатура, "ТипНоменклатуры");
	
	Если ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар") Тогда
		
		ВНаличии = ПолучитьОстаткиНоменклатуры(ТекущаяСтрока.Номенклатура, ТекущаяСтрока.Характеристика, Объект.Склад);
		ТекущаяСтрока.ВНаличии = ВНаличии;
		
		ВесОбъем = ПолучитьВесОбъем(ТекущаяСтрока.Номенклатура);
		ТекущаяСтрока.Вес = ТекущаяСтрока.Количество*ВесОбъем.Вес;
		ТекущаяСтрока.Объем = ТекущаяСтрока.Количество*ВесОбъем.Объем;
		
		Нехватает = ТекущаяСтрока.ВНаличии - ТекущаяСтрока.Количество;
		Если Нехватает < 0 Тогда
			ТекущаяСтрока.Нехватает = -Нехватает;
			ТекущаяСтрока.ЕстьНехватка = Истина;
		Иначе
			ТекущаяСтрока.Нехватает = 0;
			ТекущаяСтрока.ЕстьНехватка = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьОстаткиНоменклатуры(Номенклатура, Характеристика, Склад)
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос; 
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|	ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток КАК ВНаличииОстаток
	|ИЗ
	|	РегистрНакопления.ЗапасыИПотребности.Остатки(
	|			,
	|			Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|				И Номенклатура = &Номенклатура
	|				И Склад = &Склад
	|				И Характеристика = &Характеристика) КАК ЗапасыИПотребностиОстатки
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗапасыИПотребностиОстатки.Номенклатура,
	|	ЗапасыИПотребностиОстатки.ВНаличииОстаток,
	|	ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток,
	|	ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток
	|";

	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ВНаличииОстаток;
	КонецЕсли;
	
	Возврат 0;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьВесОбъем(Номенклатура)
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(ВТ_Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК ВТ_Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	1 * &ТекстЗапросаВесНоменклатуры КАК Вес,
	|	1 * &ТекстЗапросаОбъемНоменклатуры КАК Объем
	|ИЗ
	|	ВТ_Товары КАК Товары";
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товары.Номенклатура.ЕдиницаИзмерения",
	"Товары.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товары.Номенклатура.ЕдиницаИзмерения",
	"Товары.Номенклатура"));
	
	
	ТЗ= Новый ТаблицаЗначений;
	Тип= Новый Массив;
	Тип.Добавить(Тип("СправочникСсылка.Номенклатура"));
	ТЗ.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов(Тип));
	НоваяСтрока= ТЗ.Добавить();
	НоваяСтрока.Номенклатура= Номенклатура;
	
	Запрос.УстановитьПараметр("Товары", ТЗ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Рез= Новый Структура("Вес, Объем", 0,0);
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, ВыборкаДетальныеЗаписи);
		Возврат Рез;
	КонецЕсли;
	
	Возврат Рез;
КонецФункции

#КонецОбласти

#Область Управление
&НаКлиенте
Процедура СкладПриИзменении(Элемент)
	
    //Автоопределение Дистрибуция 
    ОчиститьПараметрыАвтоопределениеДистрибуция();	
	//
	Если ТекущаяСтраница = "Подбор" Тогда
		ВыполнитьПоискНоменклатурыНаСервере(СтрокаПоискаНоменклатура);
		ПодключитьОбработчикОжидания("ВернутьАктивностьВСтрокуПоиска", 0.5, Истина);
	КонецЕсли;	
	
	ПересчитатьДоступностьИНехватку();
	
	ПересчитатьЦеныУстановитьПараметрыДоступностьСервер();
	
	Объект.Грузоотправитель = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Грузоотправитель");
	
	УстановитьВидимостьДоступность();
	
	УстановитьСвязьПараметровВыбораДляАкции(); 
	
	Если Объект.НужнаДоставка Тогда 
		АвтоопределениеТарифа();
	КонецЕсли;	//	ОбновитьПараметрыЦены();
	
	ДобавитьПеремещениеСФилиалаПриИзмененииНаСервере();
	
	РассчитатьИтоги();
   
КонецПроцедуры

&НаСервере
Процедура ОбновитьПараметрыЦены()
	// Устинов
	если значениезаполнено(Объект.Склад.Подразделение)  
		и ДопМодуль.НовоеЦенообразование() тогда
		Объект.Подразделение=Объект.Склад.Подразделение;   
		// Устинов
		//	Объект.Товары.Очистить();
		Если ПоказыватьСписокЦен И Не Элементы.ПодборСписокЦен.Скрыта() Тогда 
