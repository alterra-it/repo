#Область Доставка
Процедура ЗаполнитьСписокВыбораПоляВремени(ПолеВводаФормы, НачальноеВремя, КонечноеВремя, Интервал = 3600) Экспорт
	Если ЗначениеЗаполнено(Объект.Интервал) И Объект.Интервал.ЭкспрессДоставка Тогда
		
		ПолеВводаФормы.СписокВыбора.Очистить();
		ПолеВводаФормы.СписокВыбора.Добавить(НачальноеВремя, Формат(НачальноеВремя,"ДФ=ЧЧ:мм"));
		
		ТекущееВремя = КонецЧаса(НачальноеВремя) + 1;
		Пока ТекущееВремя <= КонечноеВремя Цикл
			ПолеВводаФормы.СписокВыбора.Добавить(ТекущееВремя, Формат(ТекущееВремя,"ДФ=ЧЧ:мм"));
			ТекущееВремя = ТекущееВремя + Интервал;
		КонецЦикла;
		
		Если (ТекущееВремя > КонечноеВремя) И (КонечноеВремя <> НачалоЧаса(КонечноеВремя)) Тогда
			ПолеВводаФормы.СписокВыбора.Добавить(КонечноеВремя, Формат(КонечноеВремя,"ДФ=ЧЧ:мм"));
		КонецЕсли;
	КонецЕсли 	
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьДоступностьДоставки()
	
	Элементы.ЗаполнитьПараметрыДоставки.Видимость = Объект.НужнаДоставка;
	
	ВидДоставкиРозничная = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная");
	ВидДоставкиСборная = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.СборнаяОРК");
	
	Элементы.ВидРазгрузки.Видимость = (Объект.ВидДоставки = ВидДоставкиСборная);
	Элементы.ЭкспрессДоставка.Видимость = (Объект.ВидДоставки = ВидДоставкиРозничная);
	Элементы.СтоимостьДляКлиента.Видимость = (Объект.ВидДоставки = ВидДоставкиРозничная) И Объект.НужнаДоставка;
	Элементы.Тариф.ТолькоПросмотр = Не Объект.ТарифВРучную;
	
	Элементы.Инкассация.Видимость = Объект.НужнаИнкассация;
	Элементы.Сдача.Видимость = (Объект.ФормаОплаты = ПредопределенноеЗначение("Перечисление.ФормыОплаты.Наличная") И Объект.НужнаИнкассация);
	
	Элементы.Акция.Доступность = (Объект.ВидДоставки = ВидДоставкиРозничная) И Объект.НужнаДоставка;
	Элементы.ВремяДоставкиС.Доступность = Объект.ЭкспрессДоставка;
	Элементы.ВремяДоставкиПо.Доступность = Объект.ЭкспрессДоставка;
	//Элементы.Интервал.Доступность = Не Объект.ЭкспрессДоставка;
	
	ЭтоРозница = Объект.Партнер = ПредопределенноеЗначение("Справочник.Партнеры.РозничныйПокупатель");
	Элементы.ГруппаОбъектДоставки.Видимость = Не ЭтоРозница;
	
	Элементы.ЗаполнитьПараметрыДоставки.Показать(); 
	
	//АвтоопределениеДистрибуция
	Элементы.СтоимостьДоставки.Видимость = Не Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы");
    //
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСтоимостьДоставки(Команда)
	
	Если ОбъектДоставкиЕстьУПартнера(,,Объект.Партнер) И Не ЗначениеЗаполнено(Объект.ОбъектДоставки) Тогда
		
		ОписаниеОповещения= Новый ОписаниеОповещения("ВыборОбъектаДоставкиЗавершение", ЭтаФорма);
		ОткрытьФорму("Справочник.ОбъектыДоставки.Форма.Док_ФормаВыбораКарта", Новый Структура("Владелец",Объект.Партнер), ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		
		ОткрытьКартографическийИнтерфейсДоставка();        
		
	КонецЕсли;
	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьКартографическийИнтерфейсДоставка()
	Элементы.АдресДоставки.РедактированиеТекста = Ложь;
	
	ПараметрыФормы= Новый Структура;
	ПараметрыФормы.Вставить("ОткрытИзДокумента", Истина);
	ПараметрыФормы.Вставить("Партнер", Объект.Партнер);
	ПараметрыФормы.Вставить("Филиал", Объект.Подразделение);
	ПараметрыФормы.Вставить("ВидДоставки", Объект.ВидДоставки);
	ПараметрыФормы.Вставить("Тариф", Объект.Тариф);
	ПараметрыФормы.Вставить("Адрес", Объект.АдресДоставкиКарта);		
	ПараметрыФормы.Вставить("НомерДома", Объект.НомерДома);
	ПараметрыФормы.Вставить("НомерКвартиры", Объект.НомерКвартиры);
	ПараметрыФормы.Вставить("ЭтоЧастныйДом", Объект.НомерКвартиры=0 И Объект.НомерОфиса=0);  
	ПараметрыФормы.Вставить("НомерКорпуса", Объект.НомерКорпуса);
	ПараметрыФормы.Вставить("НомерОфиса", Объект.НомерОфиса);
	ПараметрыФормы.Вставить("ДополнениеКАдресу", Объект.ДополнениеКАдресу);	
	ПараметрыФормы.Вставить("Широта", Объект.Широта);
	ПараметрыФормы.Вставить("Долгота", Объект.Долгота);
	ПараметрыФормы.Вставить("ТарифВРучную", Объект.ТарифВРучную);
	ПараметрыФормы.Вставить("БезСтоимостиФилиалов", Истина);
	
	ПараметрыФормы.Вставить("ПараметрыРазгрузкиАдресВХранилище",ПолучитьАдресПараметровРазгрузки());
	
	ОписаниеОповещения= Новый ОписаниеОповещения("РассчитатьСтоимостьДоставкиЗавершение", ЭтаФорма);
	ОткрытьФорму("Обработка.КартографическийИнтерфейсДоставка.Форма.Карта", ПараметрыФормы, ЭтаФорма,,,,ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборОбъектаДоставкиЗавершение(ОбъектДоставки, ДопПараметры) Экспорт 
	
	Если ОбъектДоставки = Неопределено Тогда
		ОткрытьКартографическийИнтерфейсДоставка();	
	Иначе
		Объект.ОбъектДоставки = ОбъектДоставки;
		ОбъектДоставкиПриИзменении(Неопределено);	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСтоимостьДоставкиЗавершение(ДанныеКарты, ДопПараметры) Экспорт 
	Если Не ЗначениеЗаполнено(ДанныеКарты) Тогда
		Возврат;
	КонецЕсли;
	
	РассчитатьСтоимостьДоставкиЗавершениеНаСевере(ДанныеКарты, ДопПараметры);
	РассчитатьИтоги();
    //АвтоопределениеДистрибуция
	Если  Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы") Тогда
		АвтоопределениеТарифаДистрибуция();
	КонецЕсли; 
	//
	УстановитьВидимостьДоступностьДоставки();
	
	ИмяРеквизитаАдресаДоставки = "АдресДоставки";
	АдресЗначенияПолей = Объект[ИмяРеквизитаАдресаДоставки + "ЗначенияПолей"];
	ОбщегоНазначенияУТВызовСервера.ЗаполнитьЗначенияПолейКИПоПредставлению(Объект.АдресДоставки, АдресЗначенияПолей);
КонецПроцедуры
&НаСервере
Процедура РассчитатьСтоимостьДоставкиЗавершениеНаСевере(ДанныеКарты, ДопПараметры) 
	
	Объект.АдресДоставкиКарта = ДанныеКарты.Адрес;
	Объект.АдресДоставки= Объект.АдресДоставкиКарта;
	
	ЗаполнитьЗначенияСвойств(Объект,ДанныеКарты,"НомерДома,НомерКвартиры,НомерКорпуса,НомерОфиса,ДополнениеКАдресу");
	
	//адрес детально
	Если Прав(Объект.АдресДоставки, СтрДлина(Объект.НомерДома)) = Объект.НомерДома Тогда
		Объект.АдресДоставки = Лев(Объект.АдресДоставки, СтрДлина(Объект.АдресДоставки) - СтрДлина(Объект.НомерДома))	+ "дом " + Объект.НомерДома
	Иначе
		Объект.АдресДоставки = Объект.АдресДоставки + ", дом " + Объект.НомерДома;
	КонецЕсли;
	
	Если Объект.НомерКорпуса<>0 Тогда
		Объект.АдресДоставки = Объект.АдресДоставки + ", корп. " + Объект.НомерКорпуса;
	КонецЕсли;
	
	Если Объект.НомерКвартиры<>0 Тогда
		Объект.АдресДоставки = Объект.АдресДоставки + ", кв. " + Объект.НомерКвартиры;
	КонецЕсли;
	
	Если Объект.НомерОфиса<>0 Тогда
		Объект.АдресДоставки = Объект.АдресДоставки + ", оф. " + Объект.НомерОфиса;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Объект.ДополнениеКАдресу) Тогда
		Объект.АдресДоставки = Объект.АдресДоставки + ", " + Объект.ДополнениеКАдресу;
	КонецЕсли;  
	
	
	Если Объект.ВидДоставки <> ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы") Тогда
	    Объект.ВидДоставки = ДанныеКарты.ВидДоставки; 
	КонецЕсли; 
	
	Объект.РасчетПоРасстоянию = ДанныеКарты.РасчетПоРасстоянию;
	Объект.СтоимостьПоРасстоянию = ДанныеКарты.СтоимостьПоРасстоянию;
	Объект.Широта = ДанныеКарты.Широта;
	Объект.Долгота = ДанныеКарты.Долгота;
	
	
	//Получаем зону доставки
	Если Не ПустаяСтрока(ДанныеКарты.Зона) Тогда
		ЗонаВРучную = Ложь;
		Элементы.ЗонаДоставкиДляВодителя.ТолькоПросмотр = Истина;
		Объект.ЗонаДоставкиДляВодителя = ПолучитьЗонуДоставки(ДанныеКарты.Зона);
		Если Не Объект.ЗонаДоставкиДляВодителя.Пустая() Тогда 
			Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда
				ИнформацияПоДоставке= Обработки.КартографическийИнтерфейсДоставка.ПроверитьИПредложитьДругойФилиал(Объект);
			КонецЕсли;
		Иначе			
			Сообщить("Не обнаружена в справочнике Зона доставки " + ДанныеКарты.Зона, СтатусСообщения.ОченьВажное);
		КонецЕсли;
	Иначе
		Объект.ЗонаДоставкиДляВодителя = ПредопределенноеЗначение("Справочник.ЗоныДоставки.ПустаяСсылка");
	КонецЕсли;	
		                     
	Если НЕ Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда	
	Если ДанныеКарты.НДС = "БезНДС" Тогда
		Если Объект.РасчетПоРасстоянию Тогда
			Объект.СтоимостьДоставки = ДанныеКарты.СтоимостьПоРасстоянию;
		Иначе
			Объект.СтоимостьДоставки = ДанныеКарты.СтоимостьДоставки;
		КонецЕсли;
	Иначе//НДС
		Если Объект.РасчетПоРасстоянию Тогда
			Объект.СтоимостьДоставкиСНДС = ДанныеКарты.СтоимостьПоРасстоянию;
		Иначе
			Объект.СтоимостьДоставкиСНДС= ДанныеКарты.СтоимостьДоставки;	
		КонецЕсли;
	КонецЕсли;
КонецЕсли;  

Если ДанныеКарты.ДоставкаСРазгрузкой И ДанныеКарты.ДоставкаСРазгрузкой <> Объект.ДоставкаСРазгрузкой Тогда 
	Объект.Интервал = Неопределено;
	Объект.Тариф = Неопределено;
	ИнтервалПриИзмененииСервер();
КонецЕсли;
	
	Объект.ТарифВРучную = ДанныеКарты.ТарифВРучную;
	Если Объект.ТарифВРучную Тогда
		Объект.Тариф = ДанныеКарты.Тариф;
		ДобавлениеУслугиДоставки();
	ИначеЕсли Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда
		АвтоопределениеТарифа(); 
	Иначе
		Документы.ЗаказНаДоставкуКлиенту.УстановитьТариф(Объект, УправлениеЛогистикойСервер.МассивНесовместимыхТиповТС(ПолучитьКритерии()));
		ДобавлениеУслугиДоставки();
	КонецЕсли; 
	
   
	//Заполняем разгрузку
	РасчетРазгрузки = УправлениеЛогистикойСервер.РасчетРазгрузкиДействуетНаДату(ТекущаяДата());
	
	Если РасчетРазгрузки Тогда 
		ЗаполнитьЗначенияСвойств(Объект, ДанныеКарты, "ДоставкаСРазгрузкой, Этаж, ВариантРазгрузки, НомерКвартиры, СтоимостьРазгрузкиДляКлиента, СтоимостьРазгрузкиДляВодителя, РучнаяКорректировкаВариантовРазгрузки");
		
		Если ДанныеКарты.РучнаяКорректировкаВариантовРазгрузки И ЗначениеЗаполнено(ДанныеКарты.ВариантыРазгрузкиВРучнуюАдресВХранилище) Тогда
			ЗаполнитьВариантыРазгрузкиВРучную(ДанныеКарты.ВариантыРазгрузкиВРучнуюАдресВХранилище);
		Иначе
			Объект.ВариантыРазгрузкиВРучную.Очистить();
		КонецЕсли;
		
	КонецЕсли;

	
	//Добавляем услугу разгрузки
	ДобавитьУслугуРазгрузки();
	НачислитьБонусныеБаллы();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьЗонуДоставки(Зона)
	Возврат Обработки.КартографическийИнтерфейсДоставка.ПолучитьЗонуДоставкиПоНаименованию(Зона);
КонецФункции

&НаСервере
Функция ДобавитьУслугуДоставки()
	НДС = ОпределитьНДС();
	НоваяСтрока = Объект.Товары.Добавить();
	НоваяСтрока.Номенклатура = ?(НДС, АльтерраОбщегоНазначения.УслугаДоставкиСНДС(), АльтерраОбщегоНазначения.УслугаДоставкиБезНДС());
	//АвтоопределениеДистрибуция
	Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы")  Тогда  
	  НоваяСтрока.Количество = Объект.СтоимостьДоставкиСНДС;	
	Иначе
	  НоваяСтрока.Количество = Объект.СтоимостьДоставки; 
    КонецЕсли;
    //
	НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
	НоваяСтрока.ВидЦены = ?(ЗначениеЗаполнено(Объект.Соглашение.ВидЦен), Объект.Соглашение.ВидЦен, ВидЦены);
	НоваяСтрока.СтавкаНДС = ?(НДС, УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,ТекущаяДата()), Перечисления.СтавкиНДС.БезНДС);
	НоваяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
	НоваяСтрока.Упаковка = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
	Если ДоставкаПоЗвонку Тогда
		Объект.Инкассация = Объект.Товары.Итог("Сумма")+Объект.Сдача;
	КонецЕсли;  
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		НоваяСтрока.ЦенаСДоставкойПечать =  1;
	КонецЕсли;
	//
	Возврат НоваяСтрока.ПолучитьИдентификатор();
КонецФункции

&НаСервере
Процедура УдалитьУслугиДоставки(Доставка = Истина, НДС = Неопределено)
	
	МассивУслуг = Новый Массив;
	
	Если НДС = Неопределено ИЛИ НДС Тогда
		Услуга = ?(Доставка, АльтерраОбщегоНазначения.УслугаДоставкиСНДС(), АльтерраОбщегоНазначения.УслугаРазгрузкиСНДС());
		МассивУслуг.Добавить(Услуга);
	КонецЕсли;
	
	Если НДС = Неопределено ИЛИ Не НДС Тогда
		Услуга = ?(Доставка, АльтерраОбщегоНазначения.УслугаДоставкиБезНДС(), АльтерраОбщегоНазначения.УслугаРазгрузкиБезНДС());
		МассивУслуг.Добавить(Услуга);
	КонецЕсли;
	
	Для Каждого стрУслуга из МассивУслуг Цикл
		СтрокиТовара = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", стрУслуга));
		Для Каждого стрТовар Из СтрокиТовара Цикл
			Объект.Товары.Удалить(стрТовар);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВидДоставкиПриИзменении(Элемент)
	УстановитьВидимостьДоступностьДоставки();
	
	Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.СборнаяОРК") Тогда
		ОбновитьТелефонКлиентаНаВыгрузке(Неопределено);
	Иначе
		Объект.ТелефонКлиентаНаВыгрузке= "";
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура ОбновитьТелефонКлиентаНаВыгрузке(Команда)
	СведеньяОКлиенте= АльтерраОбщегоНазначения.ПолучитьСведеньяОПартнере(Объект.Партнер);
	Объект.ТелефонКлиентаНаВыгрузке=  СведеньяОКлиенте.Телефон3+" - "+СведеньяОКлиенте.Примечание3;
КонецПроцедуры

&НаКлиенте
Процедура ПрибытиеНаОтгрузкуПриИзменении(Элемент)
	Объект.Интервал= Неопределено;
КонецПроцедуры

&НаКлиенте
Процедура ИнтервалНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка= Ложь;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Подразделение", Объект.Подразделение);
	ПараметрыОткрытия.Вставить("ВидДоставки", Объект.ВидДоставки);
	ПараметрыОткрытия.Вставить("ДатаОтгрузки", Объект.ПрибытиеНаОтгрузку);
	ПараметрыОткрытия.Вставить("ДоставкаСРазгрузкой", Объект.ДоставкаСРазгрузкой);
	ПараметрыОткрытия.Вставить("НетНомераДекларацииЕГАИСуЮрЛица", НуженНомерДекларацииЕГАИС);
	
	ОбработкаВыбораИнтервала= Новый ОписаниеОповещения("ОбработкаВыбораИнтервала", ЭтаФорма);
	
	ОткрытьФорму("Справочник.ИнтервалыДоставки.Форма.ФормаВыбораВРейсе", ПараметрыОткрытия, ЭтаФорма,,,, ОбработкаВыбораИнтервала, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
