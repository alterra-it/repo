		ИЛИ (Объект.Партнер = Справочники.Партнеры.НайтиПоНаименованию("РОЗНИЦА"))
		И Объект.СуммаДокумента >= 3000) Тогда
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
