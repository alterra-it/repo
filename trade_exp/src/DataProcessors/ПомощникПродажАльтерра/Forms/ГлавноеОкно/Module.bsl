	|							КОГДА СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|								ТОГДА 0
	|							ИНАЧЕ 2
	|						КОНЕЦ
	|				ИНАЧЕ -1 + ВЫБОР
	|						КОГДА СправочникНоменклатура.ПометкаУдаления
	|							ТОГДА 1
	|						ИНАЧЕ 0
	|					КОНЕЦ + ВЫБОР
	|						КОГДА СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|							ТОГДА 1
	|						ИНАЧЕ 3
	|					КОНЕЦ
	|			КОНЕЦ
	|	КОНЕЦ КАК ИндексКартинки,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА СоглашениеТовары.Упаковка
	|		ИНАЧЕ ЕСТЬNULL(ЦеныНоменклатуры.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))
	|	КОНЕЦ КАК Упаковка,
	|	ВЫРАЗИТЬ((ЕСТЬNULL(ДоступныеОстатки.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузке.КОтгрузкеОстаток, 0)) / ВЫБОР
	|			КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|				ТОГДА ЕСТЬNULL(&ТекстЗапросаПоСоглашениям, 1)
	|			ИНАЧЕ ЕСТЬNULL(&ТекстЗапросаПоЦенамНоменклатуры, 1)
	|		КОНЕЦ КАК ЧИСЛО(15, 3)) КАК ВНаличииОстаток,
	|	ЕСТЬNULL(ДоступныеОстатки.ВНаличии, 0) КАК ВНаличииВБазовыхЕдиницах,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ДоступныеОстатки.Свободно, 0) / ВЫБОР
	|			КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|				ТОГДА ЕСТЬNULL(&ТекстЗапросаПоСоглашениям, 1)
	|			ИНАЧЕ ЕСТЬNULL(&ТекстЗапросаПоЦенамНоменклатуры, 1)
	|		КОНЕЦ КАК ЧИСЛО(15, 3)) КАК Доступно,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.ВидЦены, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ТОГДА СоглашениеТовары.ВидЦены
	|		КОГДА ЕСТЬNULL(СоглашениеЦеновыеГруппы.ВидЦен, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|			ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
	|		ИНАЧЕ ЕСТЬNULL(СоглашениеШапка.ВидЦен, &ВидЦены)
	|	КОНЕЦ КАК ВидЦены,
	|	ВЫРАЗИТЬ(ВЫБОР
	|			КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
	|				ТОГДА СоглашениеТовары.Цена
	|			КОГДА ВЫБОР
	|						КОГДА ЕСТЬNULL(СоглашениеЦеновыеГруппы.ВидЦен, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|							ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
	|						ИНАЧЕ ЕСТЬNULL(СоглашениеШапка.ВидЦен, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка))
	|					КОНЕЦ <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|					И ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) > 0
	|				ТОГДА ЦеныНоменклатуры.Цена
	|			ИНАЧЕ ЦеныНоменклатурыПоВиду.Цена
	|		КОНЕЦ КАК ЧИСЛО(31, 2)) КАК Цена,
	|	ЦеныНоменклатурыПоВиду.Цена КАК ЦенаПоВиду
	|ИЗ
	|	Справочник.Номенклатура КАК СправочникНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашениеШапка
	|		ПО (СоглашениеШапка.Ссылка = &Соглашение)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашениеТовары
	|		ПО (СоглашениеТовары.Ссылка = &Соглашение)
	|			И СправочникНоменклатура.Ссылка = СоглашениеТовары.Номенклатура
	|			И (СоглашениеТовары.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглашениеЦеновыеГруппы
	|		ПО (СоглашениеЦеновыеГруппы.Ссылка = &Соглашение)
	|			И СправочникНоменклатура.ЦеноваяГруппа = СоглашениеЦеновыеГруппы.ЦеноваяГруппа
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&ТекущаяДата,
	|				ВидЦены В (&ВидыЦен)
	|					И Номенклатура В (&Номенклатура)
	|					И Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) {(Номенклатура).* КАК Номенклатура}) КАК ЦеныНоменклатуры
	|		ПО (ЦеныНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка)
	|			И (ЦеныНоменклатуры.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка))
	|			И (ЦеныНоменклатуры.ВидЦены = ВЫБОР
	|				КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
	|					ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|				КОГДА ЕСТЬNULL(СоглашениеТовары.ВидЦены, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|					ТОГДА СоглашениеТовары.ВидЦены
	|				КОГДА ЕСТЬNULL(СоглашениеЦеновыеГруппы.ВидЦен, ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.ВидыЦен.ПустаяСсылка)
	|					ТОГДА СоглашениеЦеновыеГруппы.ВидЦен
	|				ИНАЧЕ ЕСТЬNULL(СоглашениеШапка.ВидЦен, &ВидЦены)
	|			КОНЕЦ)
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДоступностьТоваров.Номенклатура КАК Номенклатура,
	|			СУММА(ДоступностьТоваров.ВНаличии) КАК ВНаличии,
	|			СУММА(ДоступностьТоваров.Свободно) КАК Свободно
	|		ИЗ
	|			РегистрСведений.РаспределениеЗапасов КАК ДоступностьТоваров
	|		ГДЕ
	|			ДоступностьТоваров.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе)
	|			И ДоступностьТоваров.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|			И ДоступностьТоваров.Склад = &Склад
	|			И ДоступностьТоваров.Номенклатура В(&Номенклатура)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ДоступностьТоваров.Номенклатура) КАК ДоступныеОстатки
	|		ПО СправочникНоменклатура.Ссылка = ДоступныеОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(
	|				,
	|				Склад = &Склад
	|					И Номенклатура В (&Номенклатура)) КАК ТоварыКОтгрузке
	|		ПО СправочникНоменклатура.Ссылка = ТоварыКОтгрузке.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&ТекущаяДата,
	|				ВидЦены = &ВидЦены
	|					И Номенклатура В (&Номенклатура)
	|					И Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка)) КАК ЦеныНоменклатурыПоВиду
	|		ПО (ЦеныНоменклатурыПоВиду.Номенклатура = СправочникНоменклатура.Ссылка)
	|			И (ЦеныНоменклатурыПоВиду.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка))
	|ГДЕ
	|	НЕ СправочникНоменклатура.ЭтоГруппа
	|	И СправочникНоменклатура.Ссылка В(&Номенклатура)" ;
	
	ТекстЗапроса = СтрЗаменить(
	ТекстЗапроса, 
	"&ТекстЗапросаПоСоглашениям", 
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки("СоглашениеТовары.Упаковка", "СоглашениеТовары.Номенклатура"));
	
	ТекстЗапроса = СтрЗаменить(
	ТекстЗапроса, 
	"&ТекстЗапросаПоЦенамНоменклатуры", 
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки("ЦеныНоменклатуры.Упаковка", "ЦеныНоменклатуры.Номенклатура"));
	
	Возврат ТекстЗапроса;
КонецФункции

&НаСервере
Функция ПолучитьТекстЗапросаСЦенамиПоСоглашениюНЦ()
	//желательно оптимизировать
	ТекстЗапроса=  
	"ВЫБРАТЬ
	|	ДоступностьТоваров.Номенклатура КАК Номенклатура,
	|	СУММА(ДоступностьТоваров.ВНаличии) КАК ВНаличии,
	|	0 КАК Свободно
	|Поместить ВТ_остатки
	|ИЗ
	|	РегистрСведений.РаспределениеЗапасов КАК ДоступностьТоваров
	|ГДЕ
	|	ДоступностьТоваров.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе)
	|	И ДоступностьТоваров.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|	И ДоступностьТоваров.Склад = &Склад
	|	И ДоступностьТоваров.Номенклатура В (&Номенклатура)
	|СГРУППИРОВАТЬ ПО
	|	ДоступностьТоваров.Номенклатура
	|
	|ОБЪЕДИНИТЬ все
	|
	|ВЫБРАТЬ
	|	ЗапасыИПотребностиОстатки.Номенклатура,
	|	0,
	|	СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток -
	|		ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток)
	|ИЗ
	|	РегистрНакопления.ЗапасыИПотребности.Остатки(, Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|	И Номенклатура В (&Номенклатура)
	|	И Склад В (&Склад)) КАК ЗапасыИПотребностиОстатки
	|СГРУППИРОВАТЬ ПО
	|	ЗапасыИПотребностиОстатки.Номенклатура
	|;
	|///////////////////////////////////////////////
	|ВЫБРАТЬ
	|	"""" КАК Класс,
	|	СправочникНоменклатура.Ссылка КАК Ссылка,
	|	СправочникНоменклатура.Артикул КАК Артикул,
	|	СправочникНоменклатура.Код КАК Код,
	|	СправочникНоменклатура.Наименование КАК Наименование,
	|	СправочникНоменклатура.ПометкаУдаления КАК ПометкаУдаления,
	|	СправочникНоменклатура.Родитель КАК Родитель,
	|	СправочникНоменклатура.ЭтоГруппа КАК ЭтоГруппа,
	|	СправочникНоменклатура.Ссылка КАК Номенклатура,
	|	СправочникНоменклатура.Ссылка КАК ЭлементСписка,
	|	СправочникНоменклатура.ВидНоменклатуры КАК ВидНоменклатуры,
	|	СправочникНоменклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор)
	|			ТОГДА ЕСТЬNULL(ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка),
	|				ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка))
	|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка)
	|	КОНЕЦ КАК ВариантРасчетаЦеныНабора,
	|	ЛОЖЬ КАК СодержитТовары,
	|	ЛОЖЬ КАК СодержитУслуги,
	|	СправочникНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	СправочникНоменклатура.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	СправочникНоменклатура.Качество КАК Качество,
	|	СправочникНоменклатура.ИспользованиеХарактеристик КАК ИспользованиеХарактеристик,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар),
	|			ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
	|			ТОГДА ИСТИНА
	|		КОГДА СправочникНоменклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор))
	|		И ЕСТЬNULL(ЛОЖЬ, ЛОЖЬ)
	|		И НЕ ЕСТЬNULL(ЛОЖЬ, ЛОЖЬ)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоТовар,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга),
	|			ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Работа))
	|			ТОГДА ИСТИНА
	|		КОГДА СправочникНоменклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Набор))
	|		И ЕСТЬNULL(ЛОЖЬ, ЛОЖЬ)
	|		И НЕ ЕСТЬNULL(ЛОЖЬ, ЛОЖЬ)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ЭтоУслуга,
	|	ВЫБОР
	|		КОГДА
	|			СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеДляВидаНоменклатуры)
	|			ТОГДА СправочникНоменклатура.ВидНоменклатуры
	|		КОГДА
	|			СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ИндивидуальныеДляНоменклатуры)
	|			ТОГДА СправочникНоменклатура.Ссылка
	|		КОГДА
	|			СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.ОбщиеСДругимВидомНоменклатуры)
	|			ТОГДА СправочникНоменклатура.ВладелецХарактеристик
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК ВладелецХарактеристик,
	|	ВЫБОР
	|		КОГДА
	|			СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ХарактеристикиИспользуются,
	|	ВЫБОР
	|		КОГДА СправочникНоменклатура.ЭтоГруппа
	|			ТОГДА ВЫБОР
	|				КОГДА СправочникНоменклатура.ПометкаУдаления
	|					ТОГДА 13
	|				ИНАЧЕ 12
	|			КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|			КОГДА СправочникНоменклатура.ЕстьТоварыДругогоКачества
	|				ТОГДА 4 + ВЫБОР
	|					КОГДА СправочникНоменклатура.ПометкаУдаления
	|						ТОГДА 1
	|					ИНАЧЕ 0
	|				КОНЕЦ + ВЫБОР
	|					КОГДА
	|						СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|						ТОГДА 0
	|					ИНАЧЕ 2
	|				КОНЕЦ
	|			ИНАЧЕ -1 + ВЫБОР
	|				КОГДА СправочникНоменклатура.ПометкаУдаления
	|					ТОГДА 1
	|				ИНАЧЕ 0
	|			КОНЕЦ + ВЫБОР
	|				КОГДА
	|					СправочникНоменклатура.ИспользованиеХарактеристик = ЗНАЧЕНИЕ(Перечисление.ВариантыИспользованияХарактеристикНоменклатуры.НеИспользовать)
	|					ТОГДА 1
	|				ИНАЧЕ 3
	|			КОНЕЦ
	|		КОНЕЦ
	|	КОНЕЦ КАК ИндексКартинки,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка,
	|			ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА СоглашениеТовары.Упаковка
	|		ИНАЧЕ ЕСТЬNULL(ЦеныНоменклатуры.Упаковка, ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка))
	|	КОНЕЦ КАК Упаковка,
	|	ВЫРАЗИТЬ((ЕСТЬNULL(ДоступныеОстатки.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузке.КОтгрузкеОстаток, 0)) / ВЫБОР
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка,
	|			ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(&ТекстЗапросаПоСоглашениям, 1)
	|		ИНАЧЕ ЕСТЬNULL(&ТекстЗапросаПоЦенамНоменклатуры, 1)
	|	КОНЕЦ КАК ЧИСЛО(15, 3)) КАК ВНаличииОстаток,
	|	ЕСТЬNULL(ДоступныеОстатки.ВНаличии, 0) КАК ВНаличииВБазовыхЕдиницах,
	|	ВЫРАЗИТЬ(ЕСТЬNULL(ДоступныеОстатки.Свободно, 0) / ВЫБОР
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.Упаковка,
	|			ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)) <> ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ЕСТЬNULL(&ТекстЗапросаПоСоглашениям, 1)
	|		ИНАЧЕ ЕСТЬNULL(&ТекстЗапросаПоЦенамНоменклатуры, 1)
	|	КОНЕЦ КАК ЧИСЛО(15, 3)) КАК Доступно,
	|	&ПолеВидаЦен КАК ВидЦены,
	|	ВЫРАЗИТЬ(ВЫБОР
	|		КОГДА ЕСТЬNULL(СоглашениеТовары.Цена, 0) > 0
	|			ТОГДА СоглашениеТовары.Цена
	|		ИНАЧЕ ЦеныНоменклатуры.Цена
	|	КОНЕЦ КАК ЧИСЛО(31, 2)) КАК Цена
	|ИЗ
	|	Справочник.Номенклатура КАК СправочникНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами КАК СоглашениеШапка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
	|			ПО СоглашениеШапка.ГруппаВидовЦен = ВидыЦен.ГруппаВидовЦен
	|			И (ВидыЦен.РегионПрисутствия = &РегионПрисутствия)
	|			И (ВидыЦен.ФорматПодразделения = &ФорматПодразделения)
	|		ПО (СоглашениеШапка.Ссылка = &Соглашение)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.Товары КАК СоглашениеТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦенТовары
	|			ПО СоглашениеТовары.ГруппаВидовЦен = ВидыЦенТовары.ГруппаВидовЦен
	|			И (ВидыЦенТовары.РегионПрисутствия = &РегионПрисутствия)
	|			И (ВидыЦенТовары.ФорматПодразделения = &ФорматПодразделения)
	|		ПО (СоглашениеТовары.Ссылка = &Соглашение)
	|		И СправочникНоменклатура.Ссылка = СоглашениеТовары.Номенклатура
	|		И (СоглашениеТовары.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СоглашенияСКлиентами.ЦеновыеГруппы КАК СоглашениеЦеновыеГруппы
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦенЦеновыеГруппы
	|			ПО СоглашениеЦеновыеГруппы.ГруппаВидовЦен = ВидыЦенЦеновыеГруппы.ГруппаВидовЦен
	|			И (ВидыЦенЦеновыеГруппы.ФорматПодразделения = &ФорматПодразделения)
	|			И (ВидыЦенЦеновыеГруппы.РегионПрисутствия = &РегионПрисутствия)
	|		ПО (СоглашениеЦеновыеГруппы.Ссылка = &Соглашение)
	|		И СправочникНоменклатура.ЦеноваяГруппа = СоглашениеЦеновыеГруппы.ЦеноваяГруппа
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ТекущаяДата, ВидЦены В (&ВидыЦен)
	|		И Номенклатура В (&Номенклатура)
	|		И Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка) {(Номенклатура).* КАК
	|			Номенклатура}) КАК ЦеныНоменклатуры
	|		ПО (ЦеныНоменклатуры.Номенклатура = СправочникНоменклатура.Ссылка)
	|		И (ЦеныНоменклатуры.Характеристика = ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка))
	|		И (ЦеныНоменклатуры.ВидЦены = &ПолеВидаЦен)
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ДоступностьТоваров.Номенклатура,
	|			Сумма(ДоступностьТоваров.ВНаличии),
	|			Сумма(ДоступностьТоваров.Свободно)
	|		ИЗ
	|			ВТ_Остатки КАК ДоступностьТоваров
	|		СГРУППИРОВАТЬ ПО
	|		ДоступностьТоваров.Номенклатура) КАК ДоступныеОстатки
	|		ПО СправочникНоменклатура.Ссылка = ДоступныеОстатки.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &Склад
	|		И Номенклатура В (&Номенклатура)) КАК ТоварыКОтгрузке
	|		ПО СправочникНоменклатура.Ссылка = ТоварыКОтгрузке.Номенклатура
	|ГДЕ
	|	НЕ СправочникНоменклатура.ЭтоГруппа
	|	И СправочникНоменклатура.Ссылка В (&Номенклатура)";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
	"&ПолеВидаЦен",
	ЦеныПредприятияЗаполнениеСервер.ПолеВидаЦены());
	
	ТекстЗапроса = СтрЗаменить(
	ТекстЗапроса, 
	"&ТекстЗапросаПоСоглашениям", 
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки("СоглашениеТовары.Упаковка", "СоглашениеТовары.Номенклатура"));
	
	ТекстЗапроса = СтрЗаменить(
	ТекстЗапроса, 
	"&ТекстЗапросаПоЦенамНоменклатуры", 
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки("ЦеныНоменклатуры.Упаковка", "ЦеныНоменклатуры.Номенклатура"));
	
	Возврат ТекстЗапроса;
КонецФункции

&НаСервере
Процедура МодифицироватьЗапрос()
	Если ПустаяСтрока(СтрокаПоискаНоменклатура) Тогда //Оптимизация
		Возврат;
	КонецЕсли;
	
		
	ВариантыЗапросов = ОпределитьВариантЗапроса();
	
	Если ВариантыЗапросов = "ЦеныПоСоглашению" Тогда                      
		если ДопМодуль.НовоеЦенообразование() тогда
			СписокНоменклатура.ТекстЗапроса = ПолучитьТекстЗапросаСЦенамиПоСоглашениюНЦ();
		иначе
			СписокНоменклатура.ТекстЗапроса = ПолучитьТекстЗапросаСЦенамиПоСоглашению();
		конецесли;
		ДобавитьТаблицыКЗапросу(СписокНоменклатура);
		
		УстановитьПараметрыПоУмолчанию();
		УстановитьПараметрыПоСоглашению();
	Иначе
		СписокНоменклатура.ТекстЗапроса = Обработки.ПомощникПродажАльтерра.ПолучитьТекстЗапросаСЦенамиПоВидуЦен();
		ДобавитьТаблицыКЗапросу(СписокНоменклатура);
		
		УстановитьПараметрыПоУмолчанию();
		УстановитьПараметрыПоВидуЦен();
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция ОпределитьВариантЗапроса()
	
	Если Объект.Соглашение = Справочники.СоглашенияСКлиентами.ПустаяСсылка() Тогда
		ВариантЗапроса = "ЦеныПоВидуЦен";
	Иначе
		ТаблицаЦеновыеГруппы = Объект.Соглашение.ЦеновыеГруппы.Выгрузить();
		ТаблицаТовары = Объект.Соглашение.Товары.Выгрузить();
		
		Если ТаблицаЦеновыеГруппы.Количество()= 0 И ТаблицаТовары.Количество()= 0 Тогда
			ВариантЗапроса = "ЦеныПоВидуЦен";
		Иначе
			ВариантЗапроса = "ЦеныПоСоглашению";
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВариантЗапроса;
	
КонецФункции

&НаСервере
Процедура УстановитьПараметрыПоСоглашению()                                   
	//Устинов
	Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "&ВидыЦен") > 1 Тогда
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("ВидыЦен", ВидыЦен); 
	КонецЕсли;
	Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "&ФорматПодразделения") > 1 Тогда
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("ФорматПодразделения", Объект.Подразделение.ФорматПодразделения);
	КонецЕсли;
	Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "&РегионПрисутствия") > 1 Тогда
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("РегионПрисутствия", Объект.Подразделение.РегионПрисутствия);
	КонецЕсли;
	// Устинов
	Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "&Соглашение") > 1 Тогда
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Соглашение", Объект.Соглашение); 
	КонецЕсли; 
	Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "&ВидЦены") > 1 Тогда
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("ВидЦены", ВидЦены); 
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыПоВидуЦен()
КонецПроцедуры

&НаСервере
Процедура УстановитьПараметрыПоУмолчанию()
	СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Склад", Объект.Склад); 
	Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "&ВидЦены") > 1 Тогда
		СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("ВидЦены", ВидЦены);
	конецесли;
	СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСеанса());
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(СписокНоменклатура.Отбор,"ВНаличииОстаток", 0, ВидСравненияКомпоновкиДанных.Больше,,ТолькоВНаличии);
КонецПроцедуры

&НаСервере
Процедура ДобавитьТаблицыКЗапросу(СписокНоменклатура)
	Если ДобавитьКлассВЗапрос Тогда
		ДобавитьАВСКлассификацию(СписокНоменклатура);
	КонецЕсли;
	Если ДобавитьСрокиОтПоставщика Тогда
	  	ДобавитьСрокиОтПоставщикаПриИзмененииНаСервере();
	КонецЕсли; 
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		ДобавитьУбратьВидТовараДляДоставки()
	КонецЕсли;
	//
	ДобавитьОтборПоСегменту(СписокНоменклатура);
	Если ДобавитьФотоНоменклатуры Тогда
	  	ЗапросФото();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДобавитьОтборПоСегменту(СписокНоменклатура)
	СтрокаУсловия= "
	|1 В
	|(ВЫБРАТЬ ПЕРВЫЕ 1
	|	1
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК Сегменты
	|ГДЕ
	|	Сегменты.Номенклатура = СправочникНоменклатура.Ссылка
	|	И Сегменты.Сегмент = &СегментНоменклатуры)";
	
	СхемаЗапроса= Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(СписокНоменклатура.ТекстЗапроса);
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[1];
	ОператорВыбора = ЗапросВыбора.Операторы[0];
	Если ЗначениеЗаполнено(СегментНоменклатуры) Тогда	
		ОператорВыбора.Отбор.Добавить(СтрокаУсловия);
		
		СписокНоменклатура.ТекстЗапроса= СхемаЗапроса.ПолучитьТекстЗапроса();			
		ПодборТоваровКлиентСервер.УстановитьПараметрДинамическогоСписка(СписокНоменклатура, "СегментНоменклатуры", СегментНоменклатуры, ЗначениеЗаполнено(СегментНоменклатуры));
	Иначе
		Условие= ОператорВыбора.Отбор.Найти(СтрокаУсловия);	
		Если Условие <> Неопределено Тогда
			Индекс= ОператорВыбора.Отбор.Индекс(Условие);
			ОператорВыбора.Отбор.Удалить(Индекс);
			СписокНоменклатура.ТекстЗапроса= СхемаЗапроса.ПолучитьТекстЗапроса();			
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ДобавитьАВСКлассификацию(СписокНоменклатура)
	СхемаЗапроса= Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(СписокНоменклатура.ТекстЗапроса);
	ПакетЗапросов= СхемаЗапроса.ПакетЗапросов[1];
	Оператор= ПакетЗапросов.Операторы[0];
	ИсточникАВС= Оператор.Источники.Добавить("РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних", "ABCКлассификацияНоменклатуры_АльтерраСрезПоследних");
	ИсточникАВС.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.ПравоеВнешнее;
	ИсточникАВС.Источник.Параметры[1].Выражение= Новый ВыражениеСхемыЗапроса("Подразделение = &Подразделение");
	
	Оператор.ВыбираемыеПоля[0]= Новый ВыражениеСхемыЗапроса("ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс");
	
	СписокНоменклатура.ТекстЗапроса= СхемаЗапроса.ПолучитьТекстЗапроса();			
	СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Подразделение", Объект.Склад.Подразделение);
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьНастроекЗапроса()
	
КонецПроцедуры

