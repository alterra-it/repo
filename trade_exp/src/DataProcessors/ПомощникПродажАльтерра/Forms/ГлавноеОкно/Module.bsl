КонецПроцедуры
&НаКлиенте
Процедура НаценкаОтсрочкаПриИзменении(Элемент)
	Объект.СкидкиРассчитаны = Ложь;
	ДобавитьУправляемуюСкидкуНаСервере(НаценкаОтсрочка,"+1% (наценка на отсрочку)");
	РассчитатьИтоги(Ложь);
КонецПроцедуры
&НаКлиенте
Процедура НаценкаКартаПриИзменении(Элемент)
	Объект.СкидкиРассчитаны = Ложь;
	ДобавитьУправляемуюСкидкуНаСервере(НаценкаКарта,"Наценка на оплату картой");
	РассчитатьИтоги(Ложь);
КонецПроцедуры

&НаСервере
Процедура ДобавитьУправляемуюСкидкуНаСервере(Добавить, ИмяСкидки)	
	Скидка = Справочники.СкидкиНаценки.НайтиПоНаименованию(ИмяСкидки);
	Если Добавить Тогда 
		УправляемыеСкидки.Добавить(Скидка, Истина);
	Иначе 
		УправляемыеСкидки.Удалить(УправляемыеСкидки.НайтиПоЗначению(Скидка));
	КонецЕсли;
	
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("РеализацияСверхЗаказа",            Истина);
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Ложь);
	СтруктураПараметры.Вставить("УправляемыеСкидки", УправляемыеСкидки);
	
	СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры);   
	
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда  
		АльтерраОбщегоНазначения.ПересчитатьЦенуСДоставкойПечать(Объект.Товары); 
	КонецЕсли; 
	//
	
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСкидкиНаценки()
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("РеализацияСверхЗаказа",            Истина);
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Ложь);
	
	СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры);	
КонецПроцедуры

&НаСервере
Функция РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры, ВзятьИзВременногоХранилища = Ложь)
	
	Если Не ЗначениеЗаполнено(Объект.Соглашение) Тогда 
		Объект.СкидкиРассчитаны = Ложь;	
		Возврат Ложь;
	КонецЕсли;
	
	Если ВзятьИзВременногоХранилища Тогда
		ПримененныеСкидки = ПолучитьИзВременногоХранилища(АдресПримененныхСкидокВоВременномХранилище);
		СкидкиНаценкиСервер.ПрименитьРезультатРасчета(Объект, ПримененныеСкидки);
	Иначе
		ПримененныеСкидки = СкидкиНаценкиСервер.Рассчитать(Объект, СтруктураПараметры);
	КонецЕсли;
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, ПолучитьСтруктуруДействийДляПересчета(), ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения()); 
	
	Объект.СкидкиРассчитаны = Истина;
	
	Возврат Объект.СкидкиРассчитаны;
КонецФункции
#КонецОбласти

#Область ПараметрыУправление
&НаКлиенте
Процедура РежимОфрмленияПриИзменении(Элемент)
	УстановитьВидимостьДоступность();
	Для Каждого стрТовара Из Объект.Товары Цикл
		ПересчитатьЦеныВСтрокеКорзиныНаКлиенте(стрТовара);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура НужнаНарезкаПриИзменении(Элемент)
	Элементы.РасчитатьПараметрыНарезки.Доступность= НужнаНарезка;
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеПараметров(Отказ)
	Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
		Сообщить("Заполните организацию");
		Отказ= Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Магазин) Тогда
		Сообщить("Заполните Магазин");
		Отказ= Истина;
	КонецЕсли;    
	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда
		Сообщить("Заполните Склад");
		Отказ= Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Подразделение) Тогда
		Сообщить("Заполните Подразделение");
		Отказ= Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Партнер) Тогда
		Сообщить("Заполните Партнера");
		Отказ= Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Сообщить("Заполните Контрагента");
		Отказ= Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.ФормаОплаты) Тогда
		Сообщить("Заполните Форму оплаты");
		Отказ= Истина;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Соглашение) Тогда
		Сообщить("Заполните Соглашение");
		Отказ= Истина;
	КонецЕсли;
	Если Объект.Дата > Дата(2021, 8, 4)и НЕ Объект.Склад.Транзит 
		и НЕ Объект.ТоварПодЗаказ и НЕ ЗначениеЗаполнено(Объект.ПричинаОтклоненияОтЦеновыхУсловий) Тогда	
		ДопМодуль.ПроверкаНаОтклонениеОтЦеновыхУсловий(Объект, Отказ);
	КонецЕсли;
	
	//ЗАКАЗ
	Если РежимОфрмления = "Заказ" Тогда
		Если Не ЗначениеЗаполнено(Объект.ЖелаемаяДатаОтгрузки) Тогда	
			Сообщить("Заполните Желаемую дату отгрузки");
			Отказ= Истина;
		КонецЕсли;
	КонецЕсли;
	
	//Доставка
	Если Объект.НужнаДоставка Тогда
		
		Если Не ЗначениеЗаполнено(Объект.АдресДоставки) Тогда
			Сообщить("Заполните адрес доставки");
			Отказ= Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.Тариф) Тогда
			Сообщить("Укажите тариф доставки");
			Отказ= Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.ЗонаДоставкиДляВодителя) Тогда
			Сообщить("Заполните зону доставки");
			Отказ= Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.ТелефонКлиентаНаВыгрузке) Тогда
			Сообщить("Укажите телефон клиента на выгрузке");
			Отказ= Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.ПрибытиеНаОтгрузку) Тогда
			Сообщить("Укажите дату доставки");
			Отказ= Истина;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(Объект.ВремяДоставкиС) ИЛИ Не ЗначениеЗаполнено(Объект.ВремяДоставкиПо) Тогда
			Сообщить("Укажите интервал доставки");
			Отказ= Истина;
		КонецЕсли;
		Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная И (Объект.Широта = 0 ИЛИ Объект.Долгота = 0) Тогда
			Сообщить("Не заданы координаты! Выберите точку доставки на карте.");
			Отказ= Истина;
		КонецЕсли;
		Если Объект.Организация.Префикс = "АК" или Объект.Организация.Префикс = "ЛЛ" Тогда // АСК-Р или ОПТ-Рубцовск
			Организация1СК = Справочники.Организации.НайтиПоРеквизиту("ИНН", "2208056528");
			НаименованиеОрганизации = Объект.Организация.Наименование;
			ТЧТовары = Объект.Товары;
			Для каждого СтрокаТЧ из ТЧТовары Цикл
				Товар = СтрокаТЧ.Номенклатура;
				Если Товар.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга 
					и Товар.Принципал = Организация1СК Тогда
					АльтерраОбщегоНазначения.СообщитьПользователю(, "По организации " + НаименованиеОрганизации + " нельзя использовать услуги по «1СК».");
					Отказ = Истина;
					Прервать;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	//Проверка на 0 количество товара или услуги
		ТЧТовары = Объект.Товары;
		Для каждого СтрокаТЧ из ТЧТовары Цикл
			Если СтрокаТЧ.Количество = 0 Тогда
				АльтерраОбщегоНазначения.СообщитьПользователю(, "Для номенклатуры """ + СтрокаТЧ.Номенклатура + """ не задано количество.");
				Отказ = Истина;
				Прервать;
			КонецЕсли;	
			Если СтрокаТЧ.Цена = 0 и РежимОфрмления = "Продажа" Тогда
				АльтерраОбщегоНазначения.СообщитьПользователю(, "Для номенклатуры """ + СтрокаТЧ.Номенклатура + """ не задана цена.");
				Отказ = Истина;
				Прервать;
			КонецЕсли;		
		КонецЦикла;
КонецПроцедуры
