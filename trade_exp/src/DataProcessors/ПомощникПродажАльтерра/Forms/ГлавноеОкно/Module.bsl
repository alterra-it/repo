&НаСервере
Процедура ОформитьЗаказ_Завершение(Заказ)
	
	ДобавитьВДокументы(Заказ);   
	
	//Переопределяем документ, если это заказ под заказ. 
	Если ЗаказНаСклад Тогда 
		ЗаказОбъект = Заказ.ПолучитьОбъект(); 
		Для каждого Строка из ЗаказОбъект.Товары Цикл 
			Строка.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению; 
			Строка.Обособленно = Истина;
			Строка.Склад = СкладДляЗаказа; 
		КонецЦикла; 
		ЗаказОбъект.Склад = СкладДляЗаказа; 
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение); 
		ЗаказНаПеремещение = СоздатьЗаказНаПеремещение(Заказ); 
		ДобавитьВДокументы(ЗаказНаПеремещение); 
	КонецЕсли; 

	
	Если Объект.НужнаДоставка Тогда
		СохранитьАдресДоставкиВОбъектДоставки();
		ОформитьЗаказНаДоставку(Заказ)
	КонецЕсли;
	
	
	
КонецПроцедуры


