	     Сообщить("Для выбора тарифа не заполнены необходимые параметры");	
	     Возврат;
	ИначеЕсли  Не Объект.ТарифВРучную Тогда
		АвтоопределениеТарифа();	
	КонецЕсли;	
КонецЕсли;
