#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

////////////////////////////////////////////////////////////////////////////////
// Возвращает сведения о внешней обработке.
Функция СведенияОВнешнейОбработке() Экспорт
	НаименованиеОтчета= "Помощник продаж Альтерра";
	Идентификатор= "ПомощникПродажАльтерра"; 
	
	ВерсияБСП= СтандартныеПодсистемыСервер.ВерсияБиблиотеки();	
	ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке(ВерсияБСП);
	//ПараметрыРегистрации = ДополнительныеОтчетыИОбработки.СведенияОВнешнейОбработке("2.2.3.44");
	
	ПараметрыРегистрации.Вид = ДополнительныеОтчетыИОбработкиКлиентСервер.ВидОбработкиДополнительнаяОбработка();
	ПараметрыРегистрации.Версия = "2.02";
	ПараметрыРегистрации.БезопасныйРежим = Ложь;
	ПараметрыРегистрации.Информация = НаименованиеОтчета;
	
	НоваяКоманда = ПараметрыРегистрации.Команды.Добавить();
	стрНаименованиеОтчета= СтрЗаменить("ru = '&НаименованиеОтчета'", "&НаименованиеОтчета", НаименованиеОтчета);
	НоваяКоманда.Представление = НСтр(стрНаименованиеОтчета);
	НоваяКоманда.Идентификатор = Идентификатор;
	НоваяКоманда.Использование = ДополнительныеОтчетыИОбработкиКлиентСервер.ТипКомандыОткрытиеФормы();
	НоваяКоманда.ПоказыватьОповещение = Ложь;
	НоваяКоманда.Модификатор = Идентификатор;
	
	Возврат ПараметрыРегистрации;
	
КонецФункции

#КонецЕсли
