Function ArrayFromString(Val Str, Separator=",") Export
	
	Array      = New Array;
	RightPart = SeparateBySeparator(Str, Separator);
	
	While Not IsBlankString(Str) Do
		Array.Add(TrimAll(Str));
		Str       = RightPart;
		RightPart = SeparateBySeparator(Str, Separator);
	EndDo; 
	
	Return(Array);
	
EndFunction 

Function SeparateBySeparator(Str, Val Separator, Mode=0)
	
	RightPart       = "";
	SeparatorPos    = Find(Str, Separator);
	SeparatorLength	= StrLen(Separator);
	If SeparatorPos > 0 Then
		RightPart	= Mid(Str, SeparatorPos + ?(Mode=2, 0, SeparatorLength));
		Str         = TrimAll(Left(Str, SeparatorPos - ?(Mode=1, -SeparatorLength + 1, 1)));
	EndIf;
	
	Return(RightPart);
	
EndFunction 

