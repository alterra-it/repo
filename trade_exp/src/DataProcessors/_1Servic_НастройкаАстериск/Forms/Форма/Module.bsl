//&НаКлиенте
Перем Соединение;
//&НаКлиенте
Перем Cookie;		

//Время жизни Cookie и Date в примере указано явно, чтобы не заниматься парсингом.
//Эти вещи правильнее получать из строки заголовка ответа. Пример ответа, "...Max-Age=60.."
//&НаКлиенте
Перем CookieTTL;
//&НаКлиенте
Перем CookieDate;

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	_1Servic_РС_НастройкаАстериск.Настройка КАК Настройка,
	|	_1Servic_РС_НастройкаАстериск.Значение КАК Значение
	|ИЗ
	|	РегистрСведений._1Servic_РС_НастройкаАстериск КАК _1Servic_РС_НастройкаАстериск";
	
	РезультатЗапроса = Запрос.Выполнить();	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если ВыборкаДетальныеЗаписи.Настройка="IP" Тогда
			IP=ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка="Port" Тогда
			Port=ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка="User" Тогда
			User=ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка="Password" Тогда
			Password=ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка="Контекст" Тогда
			Контекст=ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка="ОсновнойКанал" Тогда
			ОсновнойКанал=ВыборкаДетальныеЗаписи.Значение;
		ИначеЕсли ВыборкаДетальныеЗаписи.Настройка="ДлинаКанала" Тогда
			ДлинаКанала=ВыборкаДетальныеЗаписи.Значение;
		КонецЕсли;	
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция Подключиться()
	
	Если ЗначениеЗаполнено(IP)=Ложь Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Port)=Ложь Тогда
		Port=8088;
	КонецЕсли; 
	
	Соединение=Новый HTTPСоединение(IP,Port,,,,30,);
	
	Возврат ?(Соединение=Неопределено,Ложь,Истина);
	
КонецФункции

&НаСервере
Процедура Login(параметр_1)
	Если Подключиться() Тогда
		ТекстКоманды="/asterisk/rawman?action=login&username="+СокрЛП(User)+"&secret="+СокрЛП(Password);
		Запрос= Новый HTTPЗапрос();
		Запрос.АдресРесурса=ТекстКоманды;
		Ответ=Соединение.Получить(Запрос);
		Если Ответ.КодСостояния=200 Тогда
			Cookie=Ответ.Заголовки.Получить("Set-Cookie");
			CookieDate=ТекущаяДата();
		КонецЕсли; 
		Сообщить(Ответ.ПолучитьТелоКакСтроку());
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ListCommands(Элемент)
	ТекстКоманды="/asterisk/manager?action=ListCommands";
	ВыполнитьЗапрос(ТекстКоманды,1);
КонецПроцедуры

&НаКлиенте
Процедура SipPeers(Элемент)
	ТекстКоманды="/asterisk/manager?action=sippeers";
	ВыполнитьЗапрос(ТекстКоманды,2);
КонецПроцедуры

&НаСервере
Функция ВыполнитьЗапрос(ТекстКоманды,_ТипКоманды)
	
	// проверка срока годности cookie
	Если ТекущаяДата()-CookieDate>CookieTTL Тогда
		// придется снова авторизоваться
		Login("");
	КонецЕсли; 
	
	Если Подключиться() Тогда
		Запрос= Новый HTTPЗапрос();
		Запрос.АдресРесурса=ТекстКоманды;
		Заголовки=Новый Соответствие;
		Заголовки.Вставить("Cookie",Cookie);
		Заголовки.Вставить("Accept","*/*");
		Запрос.Заголовки=Заголовки;
		
		Ответ=Соединение.Получить(Запрос);
		Если Ответ.КодСостояния=200 Тогда
			Cookie=Ответ.Заголовки.Получить("Set-Cookie");
			CookieDate=ТекущаяДата();
		КонецЕсли; 
		
		_тело_как_строка=Ответ.ПолучитьТелоКакСтроку();
		
		Сообщить(_тело_как_строка);
		
	КонецЕсли; 
	
КонецФункции

&НаКлиенте
Процедура СохранитьИЗакрыть(Команда)
	СохранитьИЗакрытьНаСервере();
	Закрыть();
КонецПроцедуры

&НаСервере
Процедура СохранитьИЗакрытьНаСервере()
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="IP";
	_менеджерЗаписи.Значение =IP;
	_менеджерЗаписи.Записать(Истина);
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="Port";
	_менеджерЗаписи.Значение =?(ЗначениеЗаполнено(Port),Port,8088);
	_менеджерЗаписи.Записать(Истина);
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="User";
	_менеджерЗаписи.Значение =User;
	_менеджерЗаписи.Записать(Истина);
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="Password";
	_менеджерЗаписи.Значение =Password;
	_менеджерЗаписи.Записать(Истина);
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="Контекст";
	_менеджерЗаписи.Значение =?(ЗначениеЗаполнено(Контекст),Контекст,"from-internal");
	_менеджерЗаписи.Записать(Истина);
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="ОсновнойКанал";
	_менеджерЗаписи.Значение =ОсновнойКанал;
	_менеджерЗаписи.Записать(Истина);
	
	_менеджерЗаписи=РегистрыСведений._1Servic_РС_НастройкаАстериск.СоздатьМенеджерЗаписи();
	_менеджерЗаписи.Настройка="ДлинаКанала";
	_менеджерЗаписи.Значение = ?(ЗначениеЗаполнено(ДлинаКанала),ДлинаКанала,19);
	_менеджерЗаписи.Записать(Истина);
	
КонецПроцедуры

