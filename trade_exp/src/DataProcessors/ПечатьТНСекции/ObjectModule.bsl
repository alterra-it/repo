	Запрос.УстановитьПараметр("ГруппаУслугДоставки", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую());
	
	СкладБарнаул = Справочники.Склады.НайтиПоНаименованию("Склад (Барнаул)");
	СекцияД = Справочники.РабочиеУчастки.НайтиПоНаименованию("Секция Д", ,, СкладБарнаул);
	Запрос.УстановитьПараметр("СекцияД", СекцияД );
            
	Возврат Запрос.ВыполнитьПакет();
КонецФункции

