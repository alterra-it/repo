#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбщиеМодули
Функция ПараметрыМассыПрописью(Масса, КоэффициентПересчетаВТонны)
	
	МассаТонны = Масса * КоэффициентПересчетаВТонны;
	Если МассаТонны > 1 Тогда
		Коэффициент = 1;
		СтрокаФормат = "т, т, т, ж, кг, кг, кг, м, " + ?(Окр(МассаТонны) = МассаТонны, "0", "3");
	ИначеЕсли МассаТонны * 1000 > 1 Тогда
		Коэффициент = 1000;
		СтрокаФормат = "кг, кг, кг, м, г, г, г, м, " + ?(Окр(МассаТонны * Коэффициент) = МассаТонны * Коэффициент, "0", "3");
	Иначе
		Коэффициент = 1000000;
		СтрокаФормат = "г, г, г, м, г, г, г, м, 0";
	КонецЕсли;
	
	Возврат Новый Структура("Формат, Коэффициент", СтрокаФормат, Коэффициент*КоэффициентПересчетаВТонны);
	
КонецФункции
Процедура ПроставитьПрочеркиВПустыеПоляСтроки(ОбластьМакета)
	
	Для Сч = 0 По ОбластьМакета.Параметры.Количество() - 1 Цикл
		
		ТекПараметр = ОбластьМакета.Параметры.Получить(Сч);
		
		Если НЕ ЗначениеЗаполнено(ТекПараметр) Тогда
			ОбластьМакета.Параметры.Установить(Сч, "--");
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры
Процедура ОкруглитьДоЦелого(ОкругляемоеЧисло)
	Если ЗначениеЗаполнено(ОкругляемоеЧисло) Тогда
		Если ОкругляемоеЧисло <> Цел(ОкругляемоеЧисло) Тогда
			ОкругляемоеЧисло = Цел(ОкругляемоеЧисло) + 1;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти

#Область ТНСекции    
Процедура ПолучитьРеализациюПоЗаказу(Заказ)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента КАК Заказ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
		|ГДЕ
		|	Заказ.Ссылка = &Заказ
		|	И РеализацияТоваровУслуг.Проведен";
				
	Запрос.УстановитьПараметр("Заказ", Заказ);	 
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() И ЗначениеЗаполнено(Результат.Ссылка) Тогда
		Заказ = Результат.Ссылка;
	КонецЕсли;
КонецПроцедуры

Функция СформироватьПечатнуюФормуПечатьТНСекции(МассивОбъектов, ОбъектыПечати=Неопределено, ПараметрыПечати=Неопределено) Экспорт
	Если ПараметрыПечати <> Неопределено И ПараметрыПечати.Свойство("ИзРейсаДляПечатиТНСекции") Тогда
		Возврат СформироватьПечатнуюФормуСгруппированоПоСекциям(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
	Иначе
		Возврат СформироватьПечатнуюФорму(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
	КонецЕсли;
КонецФункции

Функция СформироватьПечатнуюФорму(МассивОбъектов, ОбъектыПечати=Неопределено, ПараметрыПечати=Неопределено)
	Макет = ПолучитьМакет("ПФ_MXL_ПечатьТНСекции");
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	ОграничениеДоступностиОстатков = АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков();
	ЕстьПравоПросмотраОстатков = ?(ОграничениеДоступностиОстатков, АльтерраОбщегоНазначения.ЕстьПравоПросмотраОстатков(Пользователи.ТекущийПользователь()), Истина);
	//ЕстьПравоПросмотраОстатков = Ложь;
	
	ОбластьИтого  = Макет.ПолучитьОбласть("Итого");	
	ОбластьПодписи = Макет.ПолучитьОбласть("Подписи");  
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
	ПервыйДокумент= Истина;               
	
	ЕстьУслугаРезки = Ложь;
	ЕстьОбращение = Ложь;
	Печатать2Экземпляра = Новый Массив;
	Для Каждого Ссылка Из МассивОбъектов Цикл
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			ЕстьОбращение = Истина;
			Если ТипЗнч(Ссылка.ИсточникЗаполненияТоваровДляДовоза) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
				Печатать2Экземпляра.Добавить(Ссылка);
			КонецЕсли;                               
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
   
			Печатать2Экземпляра.Добавить(Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Ссылка Из Печатать2Экземпляра Цикл	
		МассивОбъектов.Добавить(Ссылка);
	КонецЦикла;
	
	Для Каждого Ссылка Из МассивОбъектов Цикл
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент= Ложь;
		
		Если Документы.ЗаявкаВЕГАИСЛес.ПроверкаНаличияЗаявкиНаСоответствующийДокументПродажи(Ссылка) Тогда
			Возврат ТабличныйДокумент;
		КонецЕсли;
		
		ПакетРезультат = ПолучитьДанныеДляПечатиТНСекции(Ссылка);
		Результат = ПакетРезультат[5];
		РезультатДопЯчейки = ПакетРезультат[6];
		РезультатВозвраты = ПакетРезультат[7];
		ОпасностьПерегрузки = ПакетРезультат[8].Выбрать();
		ВесБольше2500 = ПакетРезультат[9].Выбрать();	
		РезультатНарезка = ПакетРезультат[10];
		РезультатШтрихкоды = ПакетРезультат[11]; 
		
		ВыборкаПоДопЯчейкам = РезультатДопЯчейки.Выбрать();
		
		ВыборкаВозвраты = РезультатВозвраты.Выбрать();
		стрВозвраты = "";
		Пока  ВыборкаВозвраты.Следующий() Цикл 
			стрВозвраты=  стрВозвраты+ВыборкаВозвраты.Номер+"  ";
		КонецЦикла;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		Вес = Ложь;
		Если ВесБольше2500.Количество() > 0  Тогда 
			Вес = Истина;
		КонецЕсли;
		
		ВыборкаШтрихкодов = РезультатШтрихкоды.Выбрать();
				
		ВыборкаПоСекциям= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Секция");
		Пока ВыборкаПоСекциям.Следующий() Цикл
			ХарактеристикаИКомплект = ?(ВыборкаПоСекциям.ХарактеристикаКомплект = "Пусто", "", "Характеристика");
			
			ВыборкаНазначений= ВыборкаПоСекциям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Назначение");
			Пока ВыборкаНазначений.Следующий() Цикл
				
				Остатки = "";
				ВыводитьОстатки = Истина;
				
				//Если ОграничениеДоступностиОстатков И Не ВыборкаПоСекциям.Секция = NULL И ВыборкаПоСекциям.Секция.СкрытьКоличествоПоУчету Тогда
				//	Остатки = ?(ЕстьПравоПросмотраОстатков,"","БезОстатков");
				//	ВыводитьОстатки = ?(ЕстьПравоПросмотраОстатков,Истина,Ложь); 
				//КонецЕсли;
				
				ЭтоДубликат = Ложь;
				
				Если РегистрыСведений.СобытияДокументовАльтерра.БылоСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьТНСекции) Тогда
					ЭтоДубликат = Истина;
				КонецЕсли;
				
				Если ЭтоДубликат Тогда
					ОбластьПовторнаяПечать= Макет.ПолучитьОбласть("ПовторнаяПечать");
					ТабличныйДокумент.Вывести(ОбластьПовторнаяПечать);
				КонецЕсли;
				
				ВыборкаТовары = ВыборкаНазначений.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
				ЕстьМаркировка = ""; 
				Пока ВыборкаТовары.Следующий() Цикл
					Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(ВыборкаТовары.Номенклатура) Тогда
					 ЕстьМаркировка = "Маркировка";
				    КонецЕсли;
				КонецЦикла;	
				ВыборкаТовары.Сбросить();
				
				
				ОбластьСтрока = Макет.ПолучитьОбласть("Строка"+ХарактеристикаИКомплект+Остатки+ЕстьМаркировка);
				ОбластьИтого  = Макет.ПолучитьОбласть("Итого"+ХарактеристикаИКомплект+Остатки);
				
				ВывестиШапку(Ссылка, Макет, ВыборкаНазначений, ТабличныйДокумент, стрВозвраты, Вес, ЕстьОбращение, ВыводитьОстатки, ХарактеристикаИКомплект, ЕстьМаркировка);
			
				ОбластьНазначение= Макет.ПолучитьОбласть("Назначение");
				ОбластьНазначение.Параметры.Заполнить(ВыборкаНазначений);
				Если ЗначениеЗаполнено(ОбластьНазначение.Параметры.Назначение) Тогда
					ТабличныйДокумент.Вывести(ОбластьНазначение);
				КонецЕсли;
				
				СчетСтрок=1;
				НомерСтроки= 0;
				СуммаИтог=0;
				ИтогНДС= 0;
				
				//ВыборкаТовары = ВыборкаНазначений.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
				Пока ВыборкаТовары.Следующий() Цикл
					
					СтрТовара = ВыборкаТовары.Номенклатура;
					Если СтрТовара.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
						И Найти(СтрТовара.Наименование, "резк") > 0 Тогда
						ЕстьУслугаРезки = Истина;
					КонецЕсли;
					
					СчетСтрок = СчетСтрок + 1;
					НомерСтроки = НомерСтроки + 1;
				
					Если ЕстьМаркировка = "Маркировка" Тогда
						ЭлементНоменклатура = ОбластьСтрока.Области.Найти(ХарактеристикаИКомплект + Остатки + ЕстьМаркировка);
						Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(СтрТовара) Тогда 
							ЭлементНоменклатура.Картинка = БиблиотекаКартинок.МаркируемаяПродукцияЧБ;
						Иначе
							ЭлементНоменклатура.Картинка = Неопределено;
						КонецЕсли;	
					КонецЕсли;
					ОбластьСтрока.Параметры.НомерСтроки = НомерСтроки;
					ОбластьСтрока.Параметры.Заполнить(ВыборкаТовары);
					
						
					//Если ВыводитьОстатки Тогда
					//	ОбластьСтрока.Параметры.Цена = Строка(ВыборкаТовары.ВНаличииОстаток);
					//КонецЕсли;
					Если ОграничениеДоступностиОстатков И Не ВыборкаПоСекциям.Секция = NULL И ВыборкаПоСекциям.Секция.СкрытьКоличествоПоУчету Тогда
						Если ВыборкаТовары.ХарактеристикаКомплект = "Характеристика" ИЛИ ВыборкаТовары.ХарактеристикаКомплект = "Характеристика/Комплект" Тогда
							ОбластьСтрока.Параметры.Цена = Строка(ВыборкаТовары.ВНаличииОстаток);
						Иначе
							ОбластьСтрока.Параметры.Цена = "";
						КонецЕсли;
					Иначе
						ОбластьСтрока.Параметры.Цена = Строка(ВыборкаТовары.ВНаличииОстаток);
					КонецЕсли;
					
					СуммаИтог = СуммаИтог+ ВыборкаТовары.Сумма;
					ИтогНДС = ИтогНДС+ ВыборкаТовары.СуммаНДС;
					
					стрШтрихкоды= "";
					ВыборкаШтрихкодов.Сбросить();
					СтуктураПоиска = Новый Структура("Номенклатура,Характеристика", ВыборкаТовары.Номенклатура, ВыборкаТовары.Характеристика);
					Пока ВыборкаШтрихкодов.НайтиСледующий(СтуктураПоиска) Цикл
						стрШтрихкоды= ?(ПустаяСтрока(стрШтрихкоды), стрШтрихкоды, стрШтрихкоды+Символы.ПС) + ВыборкаШтрихкодов.Штрихкод;
					КонецЦикла;
					ОбластьСтрока.Параметры.Штрихкод= стрШтрихкоды;
					
					
					ТабличныйДокумент.Вывести(ОбластьСтрока);	
				КонецЦикла;
			
			ОбластьИтого.Параметры.Заполнить(ВыборкаНазначений);
			
			ВерсияПеремещения = ПолучитьВерсиюДокумента(Ссылка);
			Если ВерсияПеремещения > 0 Тогда
				ОбластьИтого.Параметры.НомерВерсии = "Версия: " + Строка(ВерсияПеремещения);
			Иначе
				ОбластьИтого.Параметры.НомерВерсии = "";
			КонецЕсли;
			
			ТабличныйДокумент.Вывести(ОбластьИтого);
			
			ТекстИтоговойСтроки = НСтр("ru = 'Всего наименований %ВсегоНаименований%'");
			ТекстИтоговойСтроки = СтрЗаменить(ТекстИтоговойСтроки,"%ВсегоНаименований%", СчетСтрок-1);
			
			СуммаНДСРуб=" , в т.ч. НДС - "+ФормированиеПечатныхФорм.ФорматСумм(итогНДС, Константы.ВалютаРегламентированногоУчета.Получить());
			ОбластьПодписи.Параметры.ИтоговаяСтрока = ТекстИтоговойСтроки+", на сумму "+ФормированиеПечатныхФорм.ФорматСумм(СуммаИтог, Константы.ВалютаРегламентированногоУчета.Получить())+суммаНДСруб;
			
			ОбластьПодписи.параметры.ВремяПечати=""+ТекущаяДата()+" "+Пользователи.ТекущийПользователь();
			ОбластьПодписи.Параметры.СуммаПрописью  = "Сумма: "+РаботаСКурсамиВалют.СформироватьСуммуПрописью(СуммаИтог,Константы.ВалютаРегламентированногоУчета.Получить());

			Если ВесБольше2500.Количество() > 0  Тогда 
				ОбластьПодписи.Параметры.ДопТекст = ", погрузку товара в транспортное средство произвел самостоятельно";
			КонецЕсли;
			Если ОпасностьПерегрузки.Количество() > 0 Тогда
				ОбластьПодписи.Параметры.ОпастностьПерегрузки = "Подлежит проверке";
			КонецЕсли;
						
			ТабличныйДокумент.Вывести(ОбластьПодписи);
			
			Если ЭтоДубликат Тогда
					ОбластьПовторнаяПечатьЧасть2= Макет.ПолучитьОбласть("ПовторнаяПечатьЧасть2");
					ТабличныйДокумент.Вывести(ОбластьПовторнаяПечатьЧасть2);
			КонецЕсли;

			Попытка
				ОбластьКомментарий = Макет.ПолучитьОбласть("Комментарий");
					ОбластьКомментарий.Параметры.Комментарий= СокрЛП(Ссылка.КомментарийДляСклада);
					ТабличныйДокумент.Вывести(ОбластьКомментарий);
			Исключение
				Если Ссылка.Метаданные().Реквизиты.Найти("Комментарий") <> Неопределено И Не ПустаяСтрока(Ссылка.Комментарий) Тогда
					ОбластьКомментарий = Макет.ПолучитьОбласть("Комментарий");
					ОбластьКомментарий.Параметры.Комментарий = СокрЛП(Ссылка.Комментарий);
					ТабличныйДокумент.Вывести(ОбластьКомментарий);
				КонецЕсли;
			КонецПопытки;
			
			//Если ЕстьУслугаРезки Тогда
				СекцииНарезки = РезультатНарезка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Секция");
				Пока СекцииНарезки.Следующий() Цикл
					Если СекцииНарезки.Секция = ВыборкаПоСекциям.Секция Тогда
						
						НарезкаШапка = Макет.ПолучитьОбласть("НарезкаШапка");
						НарезкаСтрока = Макет.ПолучитьОбласть("НарезкаСтрока");
						
						ТабличныйДокумент.Вывести(НарезкаШапка);
						
						ВыборкаНарезка = СекцииНарезки.Выбрать();
						Пока ВыборкаНарезка.Следующий() Цикл
							НарезкаСтрока.Параметры.Заполнить(ВыборкаНарезка);
							ТабличныйДокумент.Вывести(НарезкаСтрока);
						КонецЦикла;
						
					КонецЕсли;
				КонецЦикла;
			//КонецЕсли;
			
			Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
				ОбластьЗаголовокДубльОбменДовоз = Макет.ПолучитьОбласть("ЗаголовокДубльОбменДовоз");
				ПредставлениеДокумента = "Обмен/довоз по обращению ";
				СсылкаВоз = Ссылка.ИсточникЗаполненияТоваровДляДовоза; 
				Если ТипЗнч(СсылкаВоз) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
					ОбластьЗаголовокДубльОбменДовоз.Параметры.ПредставлениеДокумента = "Возврат товаров "+СсылкаВоз.Номер+" от "+Формат(СсылкаВоз.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
				ИначеЕсли ТипЗнч(СсылкаВоз) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
					ОбластьЗаголовокДубльОбменДовоз.Параметры.ПредставлениеДокумента = "Перемещение товаров "+СсылкаВоз.Номер+" от "+Формат(СсылкаВоз.Дата,"ДФ=""дд ММММ гггг 'г.' """);
				Иначе
					ОбластьЗаголовокДубльОбменДовоз.Параметры.ПредставлениеДокумента = ПредставлениеДокумента+СсылкаВоз.Номер+" от "+Формат(СсылкаВоз.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
				КонецЕсли;
				ТабличныйДокумент.Вывести(ОбластьЗаголовокДубльОбменДовоз);
			КонецЕсли;
			
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();		
			КонецЦикла;
		КонецЦикла;
		
		Если Не РегистрыСведений.СобытияДокументовАльтерра.БылоСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьТНСекции) Тогда
			РегистрыСведений.СобытияДокументовАльтерра.ЗаписатьСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьТНСекции);
		КонецЕсли;
	КонецЦикла;
	
	Если ОбъектыПечати=Неопределено Тогда
		ОбъектыПечати = Новый СписокЗначений;
	КонецЕсли;
		
	ТабличныйДокумент.АвтоМасштаб = Истина;
	УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, Ссылка);
	
	Возврат ТабличныйДокумент;	
КонецФункции

Функция СформироватьПечатнуюФормуСгруппированоПоСекциям(МассивОбъектов, ОбъектыПечати=Неопределено, ПараметрыПечати=Неопределено)
	
	ОграничениеДоступностиОстатков = АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков();
	ЕстьПравоПросмотраОстатков = ?(ОграничениеДоступностиОстатков, АльтерраОбщегоНазначения.ЕстьПравоПросмотраОстатков(Пользователи.ТекущийПользователь()), Истина);
	
	ЕстьОбращение = Ложь;
	Печатать2Экземпляра = Новый Массив;
	Для Каждого Ссылка Из МассивОбъектов Цикл
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			ЕстьОбращение = Истина;
			Если ТипЗнч(Ссылка.ИсточникЗаполненияТоваровДляДовоза) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
				Печатать2Экземпляра.Добавить(Ссылка);
			КонецЕсли;                               
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
   
			Печатать2Экземпляра.Добавить(Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого Ссылка Из Печатать2Экземпляра Цикл	
		МассивОбъектов.Добавить(Ссылка);
	КонецЦикла;
	
	НомерСтрокиНачало = 0;
	
	Результат = ПолучитьДанныеДляПечатиТНСекцииСгруппированоПоСекциямНачало(МассивОбъектов);	
	ВыборкаПоСекциям= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Секция");

	МассивСекция = Новый Массив();
	
	Если ПараметрыПечати.Свойство("Секции") И ПараметрыПечати.Секции <> Неопределено Тогда
		Пока ВыборкаПоСекциям.Следующий() Цикл
			Если  ПараметрыПечати.Секции.Найти(ВыборкаПоСекциям.Секция) <> Неопределено Тогда
				МассивСекция.Добавить(СформироватьТабличыйДокументСекция(ВыборкаПоСекциям, ЕстьОбращение, ОграничениеДоступностиОстатков, ЕстьПравоПросмотраОстатков, ОбъектыПечати));
			КонецЕсли;	
		КонецЦикла;
	Иначе
		Пока ВыборкаПоСекциям.Следующий() Цикл
			МассивСекция.Добавить(СформироватьТабличыйДокументСекция(ВыборкаПоСекциям, ЕстьОбращение, ОграничениеДоступностиОстатков, ЕстьПравоПросмотраОстатков, ОбъектыПечати));
		КонецЦикла;
	КонецЕсли;
	
	
	МассивТабличныхДокументов = Новый Массив();
	Для каждого ТабличныйДокументСекция из МассивСекция Цикл
		МассивТабличныхДокументов.Добавить(ТабличныйДокументСекция);
	КонецЦикла;
	
	Для каждого Ссылка Из МассивОбъектов Цикл
		Если Не РегистрыСведений.СобытияДокументовАльтерра.БылоСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьТНСекции) Тогда
			РегистрыСведений.СобытияДокументовАльтерра.ЗаписатьСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьТНСекции);
		КонецЕсли;	
	КонецЦикла;
	
	Если ОбъектыПечати=Неопределено Тогда
		ОбъектыПечати = Новый СписокЗначений;
	КонецЕсли;
	
	Возврат МассивТабличныхДокументов;	
КонецФункции

Функция ПолучитьТаблицуТовары()
	ТаблицаТовары = Новый ТаблицаЗначений();
	ТаблицаТовары.Колонки.Добавить("ЯчейкаОсновная", Новый ОписаниеТипов("СправочникСсылка.СкладскиеЯчейки"));
	ТаблицаТовары.Колонки.Добавить("Секция",  Новый ОписаниеТипов("СправочникСсылка.РабочиеУчастки"));
	
	МассивТипов = Новый Массив();
	МассивТипов.Добавить(Тип("ДокументСсылка.РеализацияТоваровУслуг"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ВозвратТоваровОтКлиента"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ЗаказКлиента"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ПеремещениеТоваров"));
	МассивТипов.Добавить(Тип("ДокументСсылка.ЧекККМ"));
	
	ТаблицаТовары.Колонки.Добавить("Документ", Новый ОписаниеТипов(МассивТипов));
	ТаблицаТовары.Колонки.Добавить("Контрагент", Новый ОписаниеТипов("СправочникСсылка.Партнеры"));
	ТаблицаТовары.Колонки.Добавить("ПрибытиеНаОтгрузку", Новый ОписаниеТипов("Дата"));
	ТаблицаТовары.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТаблицаТовары.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТаблицаТовары.Колонки.Добавить("ЕдиницаЦены", Новый ОписаниеТипов("СправочникСсылка.УпаковкиЕдиницыИзмерения"));
	ТаблицаТовары.Колонки.Добавить("Цена", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("СУММА", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("СуммаНДС", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("Дата", Новый ОписаниеТипов("Дата"));
	ТаблицаТовары.Колонки.Добавить("СуммаСкидки", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("Код", Новый ОписаниеТипов("Строка"));
	ТаблицаТовары.Колонки.Добавить("КОЛИЧЕСТВО", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТаблицаТовары.Колонки.Добавить("Вес", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("Объем", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("Возврат", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("КВыдаче", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("ВНаличииОстаток", Новый ОписаниеТипов("Число"));
	ТаблицаТовары.Колонки.Добавить("Назначение", Новый ОписаниеТипов("СправочникСсылка.Назначения"));
	ТаблицаТовары.Колонки.Добавить("ХарактеристикаКомплект", Новый ОписаниеТипов("Строка"));
	
	Возврат ТаблицаТовары;
КонецФункции

Функция СформироватьТабличыйДокументСекция(ВыборкаПоСекциям, ЕстьОбращение,  ОграничениеДоступностиОстатков, ЕстьПравоПросмотраОстатков, ОбъектыПечати)
	Макет = ПолучитьМакет("ПФ_MXL_ОтгрузочныйЛистДляСклада");
	
	ЭтоПервый = Истина;
	
	НомерСтрокиНачало = 0;
	
	ОбластьИтого  = Макет.ПолучитьОбласть("Итого");	
	ОбластьПодписи = Макет.ПолучитьОбласть("Подписи");  
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");              
	
	ЕстьУслугаРезки = Ложь;

	
	ТабличныйДокументСекция = Новый ТабличныйДокумент();
	ТабличныйДокументСекция.ЭкземпляровНаСтранице = 0;

	ТабличныйДокументПрисоединение = Новый ТабличныйДокумент();
	
	ТабличныйДокументСекция.НижнийКолонтитул.Выводить = Истина;
	
	ТабличныйДокументСекция.АвтоМасштаб = Истина;

	
	Страница = 0;
	КоличествоСтраниц = 0;
	
	ТаблицаТовары = ПолучитьТаблицуТовары();
	
	ХарактеристикаИКомплект = ?(ВыборкаПоСекциям.ХарактеристикаКомплект = "Пусто", "", "Характеристика");	
	ВыборкаДокументов = ВыборкаПоСекциям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Документ");
	
	КоличествоСтраниц = ВыборкаДокументов.Количество();
	
	Пока ВыборкаДокументов.Следующий() Цикл
		ВыборкаОбособленноеОбеспечение = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ОбособленноеОбеспечение");

		КоличествоСтраниц = КоличествоСтраниц - 1 + ВыборкаОбособленноеОбеспечение.Количество();	
	КонецЦикла;
	ВыборкаДокументов.Сбросить();
	
	Пока ВыборкаДокументов.Следующий() Цикл
		Ссылка = ВыборкаДокументов.Документ;
		Если Документы.ЗаявкаВЕГАИСЛес.ПроверкаНаличияЗаявкиНаСоответствующийДокументПродажи(Ссылка) Тогда
			Возврат ТабличныйДокументПрисоединение;
		КонецЕсли;
		
		ВыборкаОбособленноеОбеспечение = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ОбособленноеОбеспечение");
		
		Пока ВыборкаОбособленноеОбеспечение.Следующий() Цикл
				ТабличныйДокументПрисоединение = Новый ТабличныйДокумент();
				
				ТаблицаТовары.Очистить();
				ВыборкаТовары = ВыборкаОбособленноеОбеспечение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
				Пока ВыборкаТовары.Следующий() Цикл
					НоваяСтрока = ТаблицаТовары.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаТовары);
				КонецЦикла;
				ВыборкаТовары.Сбросить();
				
				Страница = Страница + 1;
				
				ПакетРезультат = ПолучитьДанныеДляПечатиТНСекцииСгруппированоПоСекциямОкончание(ТаблицаТовары);
				РезультатДопЯчейки = ПакетРезультат[1];
				РезультатВозвраты = ПакетРезультат[2];
				ОпасностьПерегрузки = ПакетРезультат[3].Выбрать();
				ВесБольше2500 = ПакетРезультат[4].Выбрать();	
				РезультатНарезка = ПакетРезультат[5];
				РезультатШтрихкоды = ПакетРезультат[6];
				
				ВыборкаПоДопЯчейкам = РезультатДопЯчейки.Выбрать();
				
				ВыборкаВозвраты = РезультатВозвраты.Выбрать();
				стрВозвраты = "";
				Пока  ВыборкаВозвраты.Следующий() Цикл 
					стрВозвраты=  стрВозвраты+ВыборкаВозвраты.Номер+"  ";
				КонецЦикла;
				
				НомерСтрокиНачало = ТабличныйДокументПрисоединение.ВысотаТаблицы + 1;
				
				Вес = Ложь;
				Если ВесБольше2500.Количество() > 0  Тогда 
					Вес = Истина;
				КонецЕсли;
				
				ВыборкаШтрихкодов = РезультатШтрихкоды.Выбрать();
				
				Остатки = "";
				ВыводитьОстатки = Истина;
				
				ЭтоДубликат = Ложь;
				Если РегистрыСведений.СобытияДокументовАльтерра.БылоСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьТНСекции) Тогда
					ОбластьПовторнаяПечать= Макет.ПолучитьОбласть("ПовторнаяПечать");
					ТабличныйДокументПрисоединение.Вывести(ОбластьПовторнаяПечать);
					ЭтоДубликат = Истина;
				КонецЕсли;
					
				ЕстьМаркировка = "";
				Для каждого Товар из ТаблицаТовары Цикл
					Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(Товар.Номенклатура) Тогда
						ЕстьМаркировка = "Маркировка";
				    КонецЕсли;
				КонецЦикла;
				
				ОбластьСтрока = Макет.ПолучитьОбласть("Строка"+ХарактеристикаИКомплект+Остатки+ЕстьМаркировка);
				ОбластьИтого  = Макет.ПолучитьОбласть("Итого"+ХарактеристикаИКомплект+Остатки);
							
				ОбластьНазначение= Макет.ПолучитьОбласть("Назначение");
				
				СчетСтрок=1;
				НомерСтроки= 0;
				СуммаИтог=0;
				ИтогНДС= 0;
				
				ВыборкаНазначений= ВыборкаОбособленноеОбеспечение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Назначение");		
				ВыборкаНазначений.Следующий();
				ВывестиШапкуОтгрузочныйЛист(Ссылка, Макет, ВыборкаНазначений, ТабличныйДокументПрисоединение, стрВозвраты, Вес, ЕстьОбращение, ВыводитьОстатки, ХарактеристикаИКомплект, ЕстьМаркировка);
				ВыборкаНазначений.Сбросить();
				
				Пока ВыборкаНазначений.Следующий() Цикл
					
					ОбластьНазначение.Параметры.Заполнить(ВыборкаНазначений);
					Если ЗначениеЗаполнено(ОбластьНазначение.Параметры.Назначение) Тогда
						ТабличныйДокументПрисоединение.Вывести(ОбластьНазначение);
					КонецЕсли;
					
					ВыборкаТовары = ВыборкаНазначений.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
					Пока ВыборкаТовары.Следующий() Цикл														
						СтрТовара = Товар.Номенклатура;
						Если СтрТовара.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
							И Найти(СтрТовара.Наименование, "резк") > 0 Тогда
							ЕстьУслугаРезки = Истина;
						КонецЕсли;
						
						СчетСтрок = СчетСтрок + 1;
						НомерСтроки = НомерСтроки + 1;
					
						Если ЕстьМаркировка = "Маркировка" Тогда
							ЭлементНоменклатура = ОбластьСтрока.Области.Найти(ХарактеристикаИКомплект + Остатки + ЕстьМаркировка);
							Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(СтрТовара) Тогда 
								ЭлементНоменклатура.Картинка = БиблиотекаКартинок.МаркируемаяПродукцияЧБ;
							Иначе
								ЭлементНоменклатура.Картинка = Неопределено;
							КонецЕсли;	
						КонецЕсли;
						ОбластьСтрока.Параметры.НомерСтроки = НомерСтроки;
						ОбластьСтрока.Параметры.Заполнить(ВыборкаТовары);
						
						Если ОграничениеДоступностиОстатков И Не ВыборкаПоСекциям.Секция = NULL И ВыборкаПоСекциям.Секция.СкрытьКоличествоПоУчету Тогда
							Если ВыборкаТовары.ХарактеристикаКомплект = "Характеристика" ИЛИ ВыборкаТовары.ХарактеристикаКомплект = "Характеристика/Комплект" Тогда
								ОбластьСтрока.Параметры.Цена = Строка(ВыборкаТовары.ВНаличииОстаток);
							Иначе
								ОбластьСтрока.Параметры.Цена = "";
							КонецЕсли;
						Иначе
							ОбластьСтрока.Параметры.Цена = Строка(ВыборкаТовары.ВНаличииОстаток);
						КонецЕсли;
						
						СуммаИтог = СуммаИтог+ ВыборкаТовары.Сумма;
						ИтогНДС = ИтогНДС+ ВыборкаТовары.СуммаНДС;
						
						стрШтрихкоды= "";
						ВыборкаШтрихкодов.Сбросить();
						СтуктураПоиска = Новый Структура("Номенклатура,Характеристика", ВыборкаТовары.Номенклатура, ВыборкаТовары.Характеристика);
						Пока ВыборкаШтрихкодов.НайтиСледующий(СтуктураПоиска) Цикл
							стрШтрихкоды= ?(ПустаяСтрока(стрШтрихкоды), стрШтрихкоды, стрШтрихкоды+Символы.ПС) + ВыборкаШтрихкодов.Штрихкод;
						КонецЦикла;
						ОбластьСтрока.Параметры.Штрихкод= стрШтрихкоды;
						
						
						ТабличныйДокументПрисоединение.Вывести(ОбластьСтрока);
					КонецЦикла;
				КонецЦикла;
				ОбластьИтого.Параметры.Заполнить(ВыборкаОбособленноеОбеспечение);
				ВерсияПеремещения = ПолучитьВерсиюДокумента(Ссылка);
				Если ВерсияПеремещения > 0 Тогда
					ОбластьИтого.Параметры.НомерВерсии = "Версия: " + Строка(ВерсияПеремещения);
				Иначе
					ОбластьИтого.Параметры.НомерВерсии = "";
				КонецЕсли;
				
				ТабличныйДокументПрисоединение.Вывести(ОбластьИтого);

				ТекстИтоговойСтроки = НСтр("ru = 'Всего наименований %ВсегоНаименований%'");
				ТекстИтоговойСтроки = СтрЗаменить(ТекстИтоговойСтроки,"%ВсегоНаименований%", СчетСтрок-1);
				
				СуммаНДСРуб=" , в т.ч. НДС - "+ФормированиеПечатныхФорм.ФорматСумм(итогНДС, Константы.ВалютаРегламентированногоУчета.Получить());
				ОбластьПодписи.Параметры.ИтоговаяСтрока = ТекстИтоговойСтроки+", на сумму "+ФормированиеПечатныхФорм.ФорматСумм(СуммаИтог, Константы.ВалютаРегламентированногоУчета.Получить())+суммаНДСруб;
				
				//ОбластьПодписи.параметры.ВремяПечати=""+ТекущаяДата()+" "+Пользователи.ТекущийПользователь();
				//ОбластьПодписи.Параметры.СуммаПрописью  = "Сумма: "+РаботаСКурсамиВалют.СформироватьСуммуПрописью(СуммаИтог,Константы.ВалютаРегламентированногоУчета.Получить());

				Если ВесБольше2500.Количество() > 0  Тогда 
					ОбластьПодписи.Параметры.ДопТекст = ", погрузку товара в транспортное средство произвел самостоятельно";
				КонецЕсли;
				Если ОпасностьПерегрузки.Количество() > 0 Тогда
					ОбластьПодписи.Параметры.ОпастностьПерегрузки = "Подлежит проверке";
				КонецЕсли;
							
				ТабличныйДокументПрисоединение.Вывести(ОбластьПодписи);
				
				//Если ЭтоДубликат Тогда
				//		ОбластьПовторнаяПечатьЧасть2= Макет.ПолучитьОбласть("ПовторнаяПечатьЧасть2");
				//		ТабличныйДокументПрисоединение.Вывести(ОбластьПовторнаяПечатьЧасть2);
				//КонецЕсли;

				Попытка
					ОбластьКомментарий = Макет.ПолучитьОбласть("Комментарий");
						ОбластьКомментарий.Параметры.Комментарий= СокрЛП(Ссылка.КомментарийДляСклада);
						ТабличныйДокументПрисоединение.Вывести(ОбластьКомментарий);
				Исключение
					Если Ссылка.Метаданные().Реквизиты.Найти("Комментарий") <> Неопределено И Не ПустаяСтрока(Ссылка.Комментарий) Тогда
						ОбластьКомментарий = Макет.ПолучитьОбласть("Комментарий");
						ОбластьКомментарий.Параметры.Комментарий = СокрЛП(Ссылка.Комментарий);
						ТабличныйДокументПрисоединение.Вывести(ОбластьКомментарий);
					КонецЕсли;
				КонецПопытки;
				
				//Если ЕстьУслугаРезки Тогда
					СекцииНарезки = РезультатНарезка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Секция");
					Пока СекцииНарезки.Следующий() Цикл
						Если СекцииНарезки.Секция = ВыборкаПоСекциям.Секция Тогда
							
							НарезкаШапка = Макет.ПолучитьОбласть("НарезкаШапка");
							НарезкаСтрока = Макет.ПолучитьОбласть("НарезкаСтрока");
							
							ТабличныйДокументПрисоединение.Вывести(НарезкаШапка);
							
							ВыборкаНарезка = СекцииНарезки.Выбрать();
							Пока ВыборкаНарезка.Следующий() Цикл
								НарезкаСтрока.Параметры.Заполнить(ВыборкаНарезка);
								ТабличныйДокументПрисоединение.Вывести(НарезкаСтрока);
							КонецЦикла;
							
						КонецЕсли;
					КонецЦикла;
				//КонецЕсли;
				
				Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
					ОбластьЗаголовокДубльОбменДовоз = Макет.ПолучитьОбласть("ЗаголовокДубльОбменДовоз");
					ПредставлениеДокумента = "Обмен/довоз по обращению ";
					СсылкаВоз = Ссылка.ИсточникЗаполненияТоваровДляДовоза; 
					Если ТипЗнч(СсылкаВоз) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
						ОбластьЗаголовокДубльОбменДовоз.Параметры.ПредставлениеДокумента = "Возврат товаров "+СсылкаВоз.Номер+" от "+Формат(СсылкаВоз.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
					ИначеЕсли ТипЗнч(СсылкаВоз) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
						ОбластьЗаголовокДубльОбменДовоз.Параметры.ПредставлениеДокумента = "Перемещение товаров "+СсылкаВоз.Номер+" от "+Формат(СсылкаВоз.Дата,"ДФ=""дд ММММ гггг 'г.' """);
					Иначе
						ОбластьЗаголовокДубльОбменДовоз.Параметры.ПредставлениеДокумента = ПредставлениеДокумента+СсылкаВоз.Номер+" от "+Формат(СсылкаВоз.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
					КонецЕсли;
					ТабличныйДокументПрисоединение.Вывести(ОбластьЗаголовокДубльОбменДовоз);
				КонецЕсли;
				
				ОбластьНумерацияСтраниц = Макет.ПолучитьОбласть("НумерацияСтраниц");
				ОбластьНумерацияСтраниц.Параметры.Нумерация = "Документ " + Страница + "/" + КоличествоСтраниц;	
				ОбластьНумерацияСтраниц.параметры.ВремяПечати=""+ТекущаяДата()+" "+Пользователи.ТекущийПользователь();
				
				ТабличныйДокументПрисоединение.Вывести(ОбластьНумерацияСтраниц);
				ТабличныйДокументПрисоединение.АвтоМасштаб = Истина;
				
				Если ПроверитьВывод(ТабличныйДокументСекция, ТабличныйДокументПрисоединение) Тогда
					ТабличныйДокументСекция.Вывести(ТабличныйДокументПрисоединение);
				ИначеЕсли ЭтоПервый Тогда
					ТабличныйДокументСекция.Вывести(ТабличныйДокументПрисоединение);
				Иначе
					Область = ТабличныйДокументСекция.Область(ТабличныйДокументСекция.ВысотаТаблицы, , ТабличныйДокументСекция.ВысотаТаблицы);
					ТабличныйДокументСекция.УдалитьОбласть(Область, ТипСмещенияТабличногоДокумента.ПоВертикали);
					ТабличныйДокументСекция.ВывестиГоризонтальныйРазделительСтраниц();
					ТабличныйДокументСекция.Вывести(ТабличныйДокументПрисоединение);
				КонецЕсли;
				ЭтоПервый = Ложь;
		КонецЦикла; //обособленное обеспечение
	КонецЦикла; //документы
	
	ТабличныйДокументСекция.НижнийКолонтитул.Выводить = Истина;
	ТабличныйДокументСекция.НижнийКолонтитул.ТекстВЦентре = "[&НомерСтраницы]/[&СтраницВсего]";
	ТабличныйДокументСекция.НижнийКолонтитул.НачальнаяСтраница = 1;
	ТабличныйДокументСекция.ИспользуемоеИмяФайла = ВыборкаПоСекциям.Секция;
	УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокументСекция, НомерСтрокиНачало, ОбъектыПечати, Ссылка);
	Возврат ТабличныйДокументСекция;
	
КонецФункции

Функция ПроверитьВывод(ТабличныйДокумент, Вывод)
	КоличествоСтраницДо = ТабличныйДокумент.КоличествоСтраниц();
	Область = ТабличныйДокумент.Вывести(Вывод);
	КоличествоСтраницПосле = ТабличныйДокумент.КоличествоСтраниц();
	ТабличныйДокумент.УдалитьОбласть(Область, ТипСмещенияТабличногоДокумента.ПоВертикали);
	Возврат КоличествоСтраницПосле = КоличествоСтраницДо;
КонецФункции

Процедура ВывестиШапку(ДокСсылка, Макет, ВыборкаПоСекциям, ТабличныйДокумент,  стрВозвраты="", Вес, ЕстьОбращение, ВыводитьОстатки, ХарактеристикаИКомплект = "", ЕстьМаркировка = "") Экспорт
	
	Остатки = "";//?(ВыводитьОстатки,"","БезОстатков");
	
	ОбластьПолоса =	Макет.ПолучитьОбласть("Полоса");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапки = Макет.ПолучитьОбласть("ШапкаТаблицы"+ХарактеристикаИКомплект+Остатки+ЕстьМаркировка);
	
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда // в обращении от клиента не выводим "Водитель"
		ОбластьДоставки = Макет.ПолучитьОбласть("ОбластьДоставкиБезВодителя");
	Иначе
		ОбластьДоставки = Макет.ПолучитьОбласть("ОбластьДоставки"); 
	КонецЕсли;
	
	ОбластьДопШапка = Макет.ПолучитьОбласть("ДополнительноШапка");
	ЕстьДоставка = Ложь; 	
	ЗаказНаДоставку = Документы.ЗаказНаДоставкуКлиенту.ПолучитьЗаказНаДоставкуПоОснованию(ДокСсылка);
	
	ВыводQRкода = НеобходимостьQRкода(ДокСсылка);
	Если ВыборкаПоСекциям.Маркетплейс Тогда
		ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкодаМаркетплейс");
		ИмяШтрихкода = "КартинкаШтрихкодаМаркетплейс";
	Иначе
		Если ВыводQRкода.ДокументПродажи Тогда 
			Если ВыводQRкода.ОтметкаКассы Тогда 
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкодаСОтметкойКассы");
				//Андронов 
				ИмяШтрихкода = "КартинкаШтрихкодаОтметка"; 
				СтруктураДанных = ПолучитьQR(ДокСсылка);
				Если СтруктураДанных <> Неопределено Тогда 
					ДанныеQRКода = ГенерацияШтрихкода.Док_ДанныеQRКода(СтруктураДанных.QrКод, 1, 400, 90);
		  			КартинкаQRКода = Новый Картинка(ДанныеQRКода);
		 			ОбластьШтрихкода.Рисунки.QRКод.Картинка = КартинкаQRКода;
					ОбластьШтрихкода.Параметры.ЗащитныйКод = СтруктураДанных.ЗащитныйКод; 
				КонецЕсли; 	  
				ОбластьШтрихкода.Область("СекцияСОтметкой").Текст = ?(ВыборкаПоСекциям.Секция = Null, "", ВыборкаПоСекциям.Секция); 
			Иначе	
				ИмяШтрихкода = "КартинкаШтрихкодаБезОтметки";
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкодаБезОтметкиКассы");   
				ОбластьШтрихкода.Область("СекцияБезОтметки").Текст = ?(ВыборкаПоСекциям.Секция = Null, "", ВыборкаПоСекциям.Секция); 
			КонецЕсли;
		Иначе  
			Если Макет.Области.Найти("ОбластьШтрихкода1") <> Неопределено Тогда
				ИмяШтрихкода = "КартинкаШтрихкода1";
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкода1"); 
			Иначе
				ИмяШтрихкода = "КартинкаШтрихкода";
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкода"); 
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли;
	Если Не ПустаяСтрока(стрВозвраты) Тогда
		ОбластьШтрихкода.Параметры.ЕстьВозвраты = "Обратите внимание по документу есть возвраты: "+стрВозвраты;
	КонецЕсли;
		
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
		Ссылка = ДокСсылка.ИсточникЗаполненияТоваровДляДовоза; 
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ПолучитьРеализациюПоЗаказу(Ссылка);	
		КонецЕсли;																							  
	Иначе
		Ссылка = ДокСсылка;   
	КонецЕсли;          
	
	Если ЕстьОбращение Тогда
		ПредставлениеДокумента = "Обмен/довоз по обращению ";
	Иначе                                                 
		ПредставлениеДокумента = "Расходная накладная ";
	КонецЕсли; 

	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		Автор = Ссылка.Менеджер;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Автор = Ссылка.Менеджер;
		Очередь = Ссылка.Очередь;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Автор = Ссылка.Ответственный;
		Очередь = Перечисления.Очередь.Очередь1;
		Если ТипЗнч(ДокСсылка) <> Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			ОбластьДоставки.Параметры.Водитель = Ссылка.Водитель;
		КонецЕсли;
		ЕстьДоставка = Истина;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		Автор = Ссылка.Менеджер;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Автор = Ссылка.Кассир;
		Очередь = Ссылка.Очередь;
	Иначе
		Автор = "";
		Очередь = "";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыборкаПоСекциям.Секция) Тогда
		СекцияНадпись = ВыборкаПоСекциям.Секция;
	Иначе
		СекцияНадпись = "";
	КонецЕсли;
	
	ОбластьШтрихкода.Параметры.Автор = Автор;
	ТелефонАвтора = ПолучитьТелефонАвтора(Автор);
	Если ЗначениеЗаполнено(ТелефонАвтора) Тогда
		ОбластьШтрихкода.Параметры.Телефон = ", телефон: " + ТелефонАвтора;
	КонецЕсли;
	
	//Если ВыводитьОстатки Тогда
		ОбластьШапки.Область("О"+ХарактеристикаИКомплект+ЕстьМаркировка).Текст = "О";
	//КонецЕсли;
	
	Если ТипЗнч(Ссылка) <> Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда // в возврате товаров от клиента не выводим, что это доставка
		
		Если ЗначениеЗаполнено(ЗаказНаДоставку) Тогда
			
			ОбластьДоставка = Макет.ПолучитьОбласть("Доставка");
			ОбластьДоставка.Область("Озон").Текст = ?(ВыборкаПоСекциям.Маркетплейс, "! ОЗОН-ПРЕДНАБОРКА-ОЗОН-ПРЕДНАБОРКА-ОЗОН !", "");
			ТабличныйДокумент.Вывести(ОбластьДоставка);
								
			ОбластьДоставки.Параметры.ВидДоставки = ЗаказНаДоставку.ВидДоставки; 
			ЕстьДоставка = Истина; 
			Если ЗаказНаДоставку.ЭкспрессДоставка Тогда
				ОбластьДоставки.Параметры.ЭкспресДоставка = "Экспрес-доставка";
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Если Не ЗначениеЗаполнено(ЗаказНаДоставку) Тогда // если не заполнили из заказа, то заполняем вручную
				ОбластьДоставка = Макет.ПолучитьОбласть("Доставка");
				ТабличныйДокумент.Вывести(ОбластьДоставка);
				ОбластьДоставки.Параметры.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя;
			КонецЕсли;
			ТабличныйДокумент.Вывести(ОбластьДоставки); // если перемещение, то эту область попросили выводить в любом случае, даже если заказ не  заполнен
		Иначе
			Если ЗначениеЗаполнено(ЗаказНаДоставку) Тогда
				ТабличныйДокумент.Вывести(ОбластьДоставки); // в остальных случаях область выводится только если заказ заполнен
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыборкаПоСекциям.Назначение) Тогда
		 ОбластьШтрихкода.Параметры.ОбособленноеОбеспечение = "Обособленное обеспечение";
	КонецЕсли;
	
	ОбластьЗаголовок.Параметры.НомерОчереди = ""+Очередь+Прав(СокрЛП(Ссылка.Номер), 3);
	Если Найти(СТРОКА(ВыборкаПоСекциям.Склад),"Торг")>0 Тогда
		ТабличныйДокумент.Вывести(ОбластьПолоса);
	КонецЕсли;	
	
	Если Ссылка.Метаданные().Реквизиты.Найти("Организация") <> Неопределено И 
		ЗначениеЗаполнено(Ссылка.Организация) И 
		Строка(Ссылка.Организация.Наименование) <> "АСК и ИП" Тогда
		
		ОбластьЗаголовок.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата), "ПолноеНаименование");
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(Ссылка.СкладОтправитель, "Адрес", Ссылка.Дата);
	Иначе
		ОбластьЗаголовок.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(Ссылка.Склад, "Адрес", Ссылка.Дата);
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ПодразделениеОтправитель = Ссылка.СкладОтправитель.Подразделение;
		АдресПодразделения = ПодразделениеОтправитель.Адрес;
		ОрганизацияПодразделения = ПодразделениеОтправитель.Организация;
		Если НЕ ОрганизацияПодразделения.Пустая() Тогда
			ОбластьЗаголовок.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ОрганизацияПодразделения, Ссылка.Дата), "ПолноеНаименование");
		Иначе	
			ОбластьЗаголовок.Параметры.ПредставлениеПоставщика = "ООО Альтерра";
		КонецЕсли;	
		Если АдресПодразделения <> "" Тогда
			ОбластьЗаголовок.Параметры.ПредставлениеАдреса = АдресПодразделения;
		Иначе
			ОбластьЗаголовок.Параметры.ПредставлениеАдреса = "658083, Алтайский край, Новоалтайск г, Дорожная ул, дом № 42/1";
		КонецЕсли;	
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = "Возврат товаров "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = Символы.ПС + "Получатель: " + Ссылка.Склад;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = "Перемещение товаров "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = Символы.ПС + "Получатель: " + Ссылка.СкладПолучатель;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = ПредставлениеДокумента+"(к Реализации товаров и услуг)"+Символы.ПС+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: "+ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Контрагент, Ссылка.Дата), "ПолноеНаименование,ФактическийАдрес");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = ПредставлениеДокумента+"(к Чеку ККМ) "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: "+Ссылка.Партнер;
	Иначе 			
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: ___________________________";
	КонецЕсли;
	
	ОбластьЗаголовок.Параметры.Секция = СекцияНадпись;
	ОбластьЗаголовок.Параметры.Склад = ВыборкаПоСекциям.Склад;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьШтрихкода, Ссылка);
	КонецЕсли;
	
	ПараметрыПоиска = Новый Структура();
	ПараметрыПоиска.Вставить("Документ",Ссылка);
	ПараметрыПоиска.Вставить("Секция",?(ВыборкаПоСекциям.Секция= Null, "", ВыборкаПоСекциям.Секция));
	ПараметрыПоиска.Вставить("Назначение",ВыборкаПоСекциям.Назначение);
	
	ВывестиШтрихкодПоСекциям(ТабличныйДокумент, Макет, ОбластьШтрихкода, ПараметрыПоиска, ИмяШтрихкода);
	
	Если Вес = Истина Тогда 
		ТабличныйДокумент.Вывести(ОбластьДопШапка);
	КонецЕсли;
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	
	ТабличныйДокумент.Вывести(ОбластьШапки);
	
КонецПроцедуры
Процедура ВывестиШтрихкодПоСекциям(ТабличныйДокумент, Макет, Знач ОбластьМакета, ПараметрыПоиска, ИмяШтрихкода)
	Эталон = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("Эталон");
	КоличествоМиллиметровВПикселе = Эталон.Рисунки.Квадрат100Пикселей.Высота / 100;
	
	// поиск ШК по секции документа реализации
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ШтрихкодыПоСекциямДокумента.Штрихкод КАК Штрихкод
	|ИЗ
	|	РегистрСведений.ШтрихкодыПоСекциямДокумента КАК ШтрихкодыПоСекциямДокумента
	|ГДЕ
	|	ШтрихкодыПоСекциямДокумента.Документ = &Документ
	|	И ШтрихкодыПоСекциямДокумента.Секция = &Секция
	|	И ШтрихкодыПоСекциямДокумента.Назначение = &Назначение";
	
	Запрос.УстановитьПараметр("Документ", ПараметрыПоиска.Документ);
	Запрос.УстановитьПараметр("Секция", ПараметрыПоиска.Секция);
	Запрос.УстановитьПараметр("Назначение", ПараметрыПоиска.Назначение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Штрихкод = Выборка.Штрихкод;
		ПараметрыШтрихкода = Новый Структура;
				ПараметрыШтрихкода.Вставить("Штрихкод",        Штрихкод);
		ПараметрыШтрихкода.Вставить("ТипКода",         4); // Code128
		ПараметрыШтрихкода.Вставить("ОтображатьТекст", Ложь);
		ПараметрыШтрихкода.Вставить("РазмерШрифта",    6);
		УстановитьПривилегированныйРежим(истина);
		Если ИмяШтрихкода = "КартинкаШтрихкода1" Тогда 
			ПараметрыШтрихкода.Вставить("Ширина",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкода.Ширина / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Высота",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкода.Высота / КоличествоМиллиметровВПикселе));
			ОбластьМакета.Рисунки.КартинкаШтрихкода1.Картинка = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода).Картинка;
		ИначеЕсли ИмяШтрихкода = "КартинкаШтрихкода" Тогда 
			ПараметрыШтрихкода.Вставить("Ширина",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкода.Ширина / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Высота",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкода.Высота / КоличествоМиллиметровВПикселе));
			ОбластьМакета.Рисунки.КартинкаШтрихкода.Картинка = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода).Картинка;
		ИначеЕсли ИмяШтрихкода = "КартинкаШтрихкодаОтметка" Тогда 
			ПараметрыШтрихкода.Вставить("Ширина",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкодаОтметка.Ширина / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Высота",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкодаОтметка.Высота / КоличествоМиллиметровВПикселе));
			ОбластьМакета.Рисунки.КартинкаШтрихкодаОтметка.Картинка = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода).Картинка;
		ИначеЕсли ИмяШтрихкода = "КартинкаШтрихкодаБезОтметки" Тогда
			ПараметрыШтрихкода.Вставить("Ширина",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкодаБезОтметки.Ширина / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Высота",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкодаБезОтметки.Высота / КоличествоМиллиметровВПикселе));
			ОбластьМакета.Рисунки.КартинкаШтрихкодаБезОтметки.Картинка = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода).Картинка;
		ИначеЕсли ИмяШтрихкода = "КартинкаШтрихкодаМаркетплейс" Тогда
			ПараметрыШтрихкода.Вставить("Ширина",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкодаМаркетплейс.Ширина / КоличествоМиллиметровВПикселе));
			ПараметрыШтрихкода.Вставить("Высота",          Окр(ОбластьМакета.Рисунки.КартинкаШтрихкодаМаркетплейс.Высота / КоличествоМиллиметровВПикселе));
			ОбластьМакета.Рисунки.КартинкаШтрихкодаМаркетплейс.Картинка = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода).Картинка;
		КонецЕсли; 
		УстановитьПривилегированныйРежим(ложь);
	КонецЕсли;
	ТабличныйДокумент.Вывести(ОбластьМакета);	
	
КонецПроцедуры

Процедура ВывестиШапкуОтгрузочныйЛист(ДокСсылка, Макет, ВыборкаПоСекциям, ТабличныйДокумент,  стрВозвраты="", Вес, ЕстьОбращение, ВыводитьОстатки, ХарактеристикаИКомплект = "", ЕстьМаркировка = "") Экспорт
	
	Остатки = "";
	
	ОбластьПолоса =	Макет.ПолучитьОбласть("Полоса");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапки = Макет.ПолучитьОбласть("ШапкаТаблицы"+ХарактеристикаИКомплект+Остатки+ЕстьМаркировка);
		
	ОбластьДопШапка = Макет.ПолучитьОбласть("ДополнительноШапка");
	ЕстьДоставка = Ложь; 	
	ЗаказНаДоставку = Документы.ЗаказНаДоставкуКлиенту.ПолучитьЗаказНаДоставкуПоОснованию(ДокСсылка);
	
	ВыводQRкода = НеобходимостьQRкода(ДокСсылка);
	Если ВыборкаПоСекциям.Маркетплейс Тогда
		ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкодаМаркетплейс");
		ИмяШтрихкода = "КартинкаШтрихкодаМаркетплейс";
	Иначе
		Если ВыводQRкода.ДокументПродажи Тогда 
			Если ВыводQRкода.ОтметкаКассы Тогда 
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкодаСОтметкойКассы");
				//Андронов 
				ИмяШтрихкода = "КартинкаШтрихкодаОтметка"; 
				СтруктураДанных = ПолучитьQR(ДокСсылка);
				Если СтруктураДанных <> Неопределено Тогда 
					ДанныеQRКода = ГенерацияШтрихкода.Док_ДанныеQRКода(СтруктураДанных.QrКод, 1, 400, 90);
		  			КартинкаQRКода = Новый Картинка(ДанныеQRКода);
		 			ОбластьШтрихкода.Рисунки.QRКод.Картинка = КартинкаQRКода;
					ОбластьШтрихкода.Параметры.ЗащитныйКод = СтруктураДанных.ЗащитныйКод; 
				КонецЕсли; 	  
				ОбластьШтрихкода.Область("СекцияСОтметкой").Текст = ?(ВыборкаПоСекциям.Секция = Null, "", ВыборкаПоСекциям.Секция); 
			Иначе	
				ИмяШтрихкода = "КартинкаШтрихкодаБезОтметки";
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкодаБезОтметкиКассы");   
				ОбластьШтрихкода.Область("СекцияБезОтметки").Текст = ?(ВыборкаПоСекциям.Секция = Null, "", ВыборкаПоСекциям.Секция); 
			КонецЕсли;
		Иначе  
			Если Макет.Области.Найти("ОбластьШтрихкода1") <> Неопределено Тогда
				ИмяШтрихкода = "КартинкаШтрихкода1";
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкода1"); 
			Иначе
				ИмяШтрихкода = "КартинкаШтрихкода";
				ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкода"); 
			КонецЕсли;
		КонецЕсли; 
	КонецЕсли;
	Если Не ПустаяСтрока(стрВозвраты) Тогда
		ОбластьШтрихкода.Параметры.ЕстьВозвраты = "Обратите внимание по документу есть возвраты: "+стрВозвраты;
	КонецЕсли;
		
	Если ТипЗнч(ДокСсылка) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
		Ссылка = ДокСсылка.ИсточникЗаполненияТоваровДляДовоза; 
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			ПолучитьРеализациюПоЗаказу(Ссылка);	
		КонецЕсли;																							  
	Иначе
		Ссылка = ДокСсылка;   
	КонецЕсли;          
	
	Если ЕстьОбращение Тогда
		ПредставлениеДокумента = "Обмен/довоз по обращению ";
	Иначе                                                 
		ПредставлениеДокумента = "Расходная накладная ";
	КонецЕсли; 

	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		Автор = Ссылка.Менеджер;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Автор = Ссылка.Менеджер;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Автор = Ссылка.Ответственный;
		Если ТипЗнч(ДокСсылка) <> Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			ОбластьШтрихкода.Параметры.Водитель = Ссылка.Водитель;
		Иначе
			ОбластьШтрихкода.Параметры.Водитель = "Не заполняется";
		КонецЕсли;
		ЕстьДоставка = Истина;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		Автор = Ссылка.Менеджер;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Автор = Ссылка.Кассир;
	Иначе
		Автор = "";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыборкаПоСекциям.Секция) Тогда
		СекцияНадпись = ВыборкаПоСекциям.Секция;
	Иначе
		СекцияНадпись = "";
	КонецЕсли;
	
	ОбластьШтрихкода.Параметры.Автор = Автор;
	ТелефонАвтора = ПолучитьТелефонАвтора(Автор);
	Если ЗначениеЗаполнено(ТелефонАвтора) Тогда
		ОбластьШтрихкода.Параметры.Телефон = ", телефон: " + ТелефонАвтора;
	КонецЕсли;
	
	//Если ВыводитьОстатки Тогда
		ОбластьШапки.Область("О"+ХарактеристикаИКомплект+ЕстьМаркировка).Текст = "О";
	//КонецЕсли;
	
	Если ТипЗнч(Ссылка) <> Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда // в возврате товаров от клиента не выводим, что это доставка
		
		Если ЗначениеЗаполнено(ЗаказНаДоставку) Тогда
			
			ОбластьДоставка = Макет.ПолучитьОбласть("Доставка");
			ОбластьДоставка.Область("Озон").Текст = ?(ВыборкаПоСекциям.Маркетплейс, "! ОЗОН-ПРЕДНАБОРКА-ОЗОН-ПРЕДНАБОРКА-ОЗОН !", "");
			ТабличныйДокумент.Вывести(ОбластьДоставка);
			
			ОбластьШтрихкода.Параметры.ВидДоставки = ЗаказНаДоставку.ВидДоставки; 
			ЕстьДоставка = Истина; 
			Если ЗаказНаДоставку.ЭкспрессДоставка Тогда
				ОбластьШтрихкода.Параметры.ЭкспресДоставка = ", Экспрес-доставка";
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Если Не ЗначениеЗаполнено(ЗаказНаДоставку) Тогда // если не заполнили из заказа, то заполняем вручную
				ОбластьШтрихкода.Параметры.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;

	Если ЗначениеЗаполнено(ВыборкаПоСекциям.Назначение) ИЛИ ВыборкаПоСекциям.ОбособленноеОбеспечение Тогда
		 ОбластьЗаголовок.Параметры.ОбособленноеОбеспечение = "Обособленное обеспечение";
	КонецЕсли;

	Если Найти(СТРОКА(ВыборкаПоСекциям.Склад),"Торг")>0 Тогда
		ТабличныйДокумент.Вывести(ОбластьПолоса);
	КонецЕсли;	
	
	Если Ссылка.Метаданные().Реквизиты.Найти("Организация") <> Неопределено И 
		ЗначениеЗаполнено(Ссылка.Организация) И 
		Строка(Ссылка.Организация.Наименование) <> "АСК и ИП" Тогда
		
		ОбластьШтрихкода.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата), "ПолноеНаименование");
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ОбластьШтрихкода.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(Ссылка.СкладОтправитель, "Адрес", Ссылка.Дата);
		ПодразделениеОтправитель = Ссылка.СкладОтправитель.Подразделение;
		АдресПодразделения = ПодразделениеОтправитель.Адрес;
		ОрганизацияПодразделения = ПодразделениеОтправитель.Организация;
		Если НЕ ОрганизацияПодразделения.Пустая() Тогда
			ОбластьШтрихкода.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ОрганизацияПодразделения, Ссылка.Дата), "ПолноеНаименование");
		Иначе	
			ОбластьШтрихкода.Параметры.ПредставлениеПоставщика = "ООО Альтерра";
		КонецЕсли;	
		Если АдресПодразделения <> "" Тогда
			ОбластьШтрихкода.Параметры.ПредставлениеАдреса = АдресПодразделения;
		Иначе
			ОбластьШтрихкода.Параметры.ПредставлениеАдреса = "658083, Алтайский край, Новоалтайск г, Дорожная ул, дом № 42/1";
		КонецЕсли;
	Иначе
		ОбластьШтрихкода.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ПолучитьАдресИзКонтактнойИнформации(Ссылка.Склад, "Адрес", Ссылка.Дата);
	КонецЕсли;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = "Возврат товаров "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Получатель: " + Ссылка.Склад;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = "Перемещение товаров "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Получатель: " + Ссылка.СкладПолучатель;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = ПредставлениеДокумента+"(к Реализации товаров и услуг)"+Символы.ПС+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: "+ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Контрагент, Ссылка.Дата), "ПолноеНаименование,ФактическийАдрес");
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента = ПредставлениеДокумента+"(к Чеку ККМ) "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: "+Ссылка.Партнер;
	Иначе 			
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: ___________________________";
	КонецЕсли;
	
	ОбластьЗаголовок.Параметры.Секция = СекцияНадпись;
	ОбластьЗаголовок.Параметры.Склад = ВыборкаПоСекциям.Склад;
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьШтрихкода, Ссылка);
	КонецЕсли;
	
	ПараметрыПоиска = Новый Структура();
	ПараметрыПоиска.Вставить("Документ",Ссылка);
	ПараметрыПоиска.Вставить("Секция",?(ВыборкаПоСекциям.Секция= Null, "", ВыборкаПоСекциям.Секция));
	ПараметрыПоиска.Вставить("Назначение",ВыборкаПоСекциям.Назначение);
	
	ВывестиШтрихкодПоСекциям(ТабличныйДокумент, Макет, ОбластьШтрихкода, ПараметрыПоиска, ИмяШтрихкода);
	
	Если Вес = Истина Тогда 
		ТабличныйДокумент.Вывести(ОбластьДопШапка);
	КонецЕсли;
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	
	ТабличныйДокумент.Вывести(ОбластьШапки);
	
КонецПроцедуры
Функция ПолучитьДанныеДляПечатиТНСекции(Ссылка) Экспорт
	//Выводим товар в приложение 1
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза КАК Ссылка,
		|	ТоварыДляДовоза.Контрагент КАК Контрагент,
		|	ТоварыДляДовоза.Номенклатура КАК Номенклатура,
		|	ТоварыДляДовоза.Количество КАК Количество,
		|	ТоварыДляДовоза.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ТоварыДляДовоза.Цена КАК Цена,
		|	ТоварыДляДовоза.СуммаСНДС КАК Сумма,
		|	ТоварыДляДовоза.СуммаНДС КАК СуммаНДС,
		|	ТоварыДляДовоза.Склад КАК Склад,
		|	ТоварыДляДовоза.Характеристика КАК Характеристика,
		|	ТоварыДляДовоза.Назначение КАК Назначение,
		|	МИНИМУМ(ВЫБОР
		|		КОГДА ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза ССЫЛКА Документ.ВозвратТоваровОтКлиента
		|			ТОГДА ВозвратТоваровОтКлиентаТовары.НомерСтроки
		|		КОГДА ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза ССЫЛКА Документ.ЗаказКлиента
		|			ТОГДА ЗаказКлиентаТовары.НомерСтроки
		|		КОГДА ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза ССЫЛКА Документ.РеализацияТоваровУслуг
		|			ТОГДА РеализацияТоваровУслугТовары.НомерСтроки
		|		КОГДА ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза ССЫЛКА Документ.ПеремещениеТоваров
		|			ТОГДА ПеремещениеТоваровТовары.НомерСтроки
		|		КОГДА ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза ССЫЛКА Документ.ЧекККМ
		|			ТОГДА ЧекККМТовары.НомерСтроки
		|		ИНАЧЕ -1
		|	КОНЕЦ) КАК НомерСтроки
		|ПОМЕСТИТЬ ВТОбращенияКлиентов
		|ИЗ
		|	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ТоварыДляДовоза
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
		|		ПО ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза = ВозвратТоваровОтКлиентаТовары.Ссылка
		|		И ТоварыДляДовоза.Номенклатура = ВозвратТоваровОтКлиентаТовары.Номенклатура
		|		И ТоварыДляДовоза.Характеристика = ВозвратТоваровОтКлиентаТовары.Характеристика
		|		И ТоварыДляДовоза.Назначение = ВозвратТоваровОтКлиентаТовары.Назначение
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|		ПО ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза = ЗаказКлиентаТовары.Ссылка
		|		И ТоварыДляДовоза.Номенклатура = ЗаказКлиентаТовары.Номенклатура
		|		И ТоварыДляДовоза.Характеристика = ЗаказКлиентаТовары.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|		ПО ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза = РеализацияТоваровУслугТовары.Ссылка
		|		И ТоварыДляДовоза.Номенклатура = РеализацияТоваровУслугТовары.Номенклатура
		|		И ТоварыДляДовоза.Характеристика = РеализацияТоваровУслугТовары.Характеристика
		|		И ТоварыДляДовоза.Назначение = РеализацияТоваровУслугТовары.Назначение
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|		ПО ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза = ПеремещениеТоваровТовары.Ссылка
		|		И ТоварыДляДовоза.Номенклатура = ПеремещениеТоваровТовары.Номенклатура
		|		И ТоварыДляДовоза.Характеристика = ПеремещениеТоваровТовары.Характеристика
		|		И ТоварыДляДовоза.Назначение = ПеремещениеТоваровТовары.Назначение
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ЧекККМТовары
		|		ПО ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза = ЧекККМТовары.Ссылка
		|		И ТоварыДляДовоза.Номенклатура = ЧекККМТовары.Номенклатура
		|		И ТоварыДляДовоза.Характеристика = ЧекККМТовары.Характеристика
		|ГДЕ
		|	ТоварыДляДовоза.Ссылка В (&МассивДокументов)
		|	И ТоварыДляДовоза.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		|СГРУППИРОВАТЬ ПО
		|	ТоварыДляДовоза.Ссылка.ИсточникЗаполненияТоваровДляДовоза,
		|	ТоварыДляДовоза.Контрагент,
		|	ТоварыДляДовоза.Номенклатура,
		|	ТоварыДляДовоза.Количество,
		|	ТоварыДляДовоза.ЕдиницаИзмерения,
		|	ТоварыДляДовоза.Цена,
		|	ТоварыДляДовоза.СуммаСНДС,
		|	ТоварыДляДовоза.СуммаНДС,
		|	ТоварыДляДовоза.Склад,
		|	ТоварыДляДовоза.Характеристика,
		|	ТоварыДляДовоза.Назначение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОбращенияКлиентов.Ссылка КАК Документ,
		|	ОбращенияКлиентов.Контрагент КАК Контрагент,
		|	ВЫБОР
		|		КОГДА НЕ ОбращенияКлиентов.Ссылка ССЫЛКА Документ.ВозвратТоваровОтКлиента
		|			ТОГДА ОбращенияКлиентов.Ссылка.ПрибытиеНаОтгрузку
		|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)
		|	КОНЕЦ КАК ПрибытиеНаОтгрузку,
		|	ОбращенияКлиентов.Номенклатура КАК Номенклатура,
		|	ОбращенияКлиентов.Количество КАК Количество,
		|	ОбращенияКлиентов.ЕдиницаИзмерения КАК ЕдИзм,
		|	ОбращенияКлиентов.Цена КАК Цена,
		|	ОбращенияКлиентов.Сумма КАК Сумма,
		|	ОбращенияКлиентов.СуммаНДС КАК СуммаНДС,
		|	ОбращенияКлиентов.Ссылка.Дата КАК Дата,
		|	ВЫБОР
		|		КОГДА ОбращенияКлиентов.Ссылка ССЫЛКА Документ.ЗаказКлиента
		|			ТОГДА ВЫБОР
		|				КОГДА ЗаказКлиентаТовары.КоличествоУпаковок <> 0
		|					ТОГДА ВЫРАЗИТЬ((ЗаказКлиентаТовары.СуммаРучнойСкидки + ЗаказКлиентаТовары.СуммаАвтоматическойСкидки) *
		|						ОбращенияКлиентов.Количество / ЗаказКлиентаТовары.КоличествоУпаковок КАК ЧИСЛО(15, 2))
		|				ИНАЧЕ 0
		|			КОНЕЦ
		|		КОГДА ОбращенияКлиентов.Ссылка ССЫЛКА Документ.РеализацияТоваровУслуг
		|			ТОГДА ВЫБОР
		|				КОГДА РеализацияТоваровУслугТовары.КоличествоУпаковок <> 0
		|					ТОГДА ВЫРАЗИТЬ((РеализацияТоваровУслугТовары.СуммаРучнойСкидки +
		|						РеализацияТоваровУслугТовары.СуммаАвтоматическойСкидки) * ОбращенияКлиентов.Количество /
		|						РеализацияТоваровУслугТовары.КоличествоУпаковок КАК ЧИСЛО(15, 2))
		|				ИНАЧЕ 0
		|			КОНЕЦ
		|		КОГДА ОбращенияКлиентов.Ссылка ССЫЛКА Документ.ЧекККМ
		|			ТОГДА ВЫБОР
		|				КОГДА ЧекККМТовары.КоличествоУпаковок <> 0
		|					ТОГДА ВЫРАЗИТЬ((ЧекККМТовары.СуммаРучнойСкидки + ЧекККМТовары.СуммаАвтоматическойСкидки) *
		|						ОбращенияКлиентов.Количество / ЧекККМТовары.КоличествоУпаковок КАК ЧИСЛО(15, 2))
		|				ИНАЧЕ 0
		|			КОНЕЦ
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК СуммаСкидки,
		|	ОбращенияКлиентов.Номенклатура.Код КАК Код,
		|	ОбращенияКлиентов.Склад КАК Склад,
		|	ОбращенияКлиентов.Характеристика КАК Характеристика,
		|	ОбращенияКлиентов.Назначение КАК Назначение
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	ВТОбращенияКлиентов КАК ОбращенияКлиентов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
		|		ПО ОбращенияКлиентов.Ссылка = ВозвратТоваровОтКлиентаТовары.Ссылка
		|		И ОбращенияКлиентов.НомерСтроки = ВозвратТоваровОтКлиентаТовары.НомерСтроки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|		ПО ОбращенияКлиентов.Ссылка = ЗаказКлиентаТовары.Ссылка
