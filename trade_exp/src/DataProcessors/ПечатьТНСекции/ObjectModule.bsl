Функция ПолучитьТелефонАвтора(Автор)
	Если ЗначениеЗаполнено(Автор) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПользователиКонтактнаяИнформация.Представление КАК НомерТелефона
			|ИЗ
			|	Справочник.Пользователи.КонтактнаяИнформация КАК ПользователиКонтактнаяИнформация
			|ГДЕ
			|	ПользователиКонтактнаяИнформация.Ссылка = &Автор
			|	И ПользователиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПользователя)";
		
		Запрос.УстановитьПараметр("Автор", Автор);
		
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() И ЗначениеЗаполнено(Результат.НомерТелефона) Тогда
			Возврат Результат.НомерТелефона;
		КонецЕсли;
	КонецЕсли;
	
	Возврат "";
КонецФункции

Функция ПолучитьQR(ссылка)
	Запрос = Новый Запрос; 
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") или ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Запрос.Текст ="ВЫБРАТЬ
		              |	СТРЗАМЕНИТЬ(СТРЗАМЕНИТЬ(СТРЗАМЕНИТЬ(СТРЗАМЕНИТЬ(РеализацияТоваровУслуг.Номер + СТРОКА(РеализацияТоваровУслуг.Дата) + СТРОКА(РеализацияТоваровУслуг.ДатаОтметкиКасса), "":"", """"), ""."", """"), "" "", """"), ""-"", """") КАК ЗащитныйКод,
		              |	ШтрихкодыПоСекциямДокумента.QRкод КАК QRкод
		              |ИЗ
		              |	РегистрСведений.ШтрихкодыПоСекциямДокумента КАК ШтрихкодыПоСекциямДокумента
		              |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		              |		ПО ШтрихкодыПоСекциямДокумента.Документ = РеализацияТоваровУслуг.Ссылка
		              |ГДЕ
		              |	РеализацияТоваровУслуг.Ссылка = &Ссылка
		              |
		              |ОБЪЕДИНИТЬ ВСЕ
		              |
		              |ВЫБРАТЬ
		              |	СТРЗАМЕНИТЬ(СТРЗАМЕНИТЬ(СТРЗАМЕНИТЬ(СТРЗАМЕНИТЬ(ЧекККМ.Номер + СТРОКА(ЧекККМ.Дата) + СТРОКА(ЧекККМ.ДатаСоздания), "":"", """"), ""."", """"), "" "", """"), ""-"", """"),
		              |	ШтрихкодыПоСекциямДокумента.QRкод
		              |ИЗ
		              |	РегистрСведений.ШтрихкодыПоСекциямДокумента КАК ШтрихкодыПоСекциямДокумента
		              |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
		              |		ПО ШтрихкодыПоСекциямДокумента.Документ = ЧекККМ.Ссылка
		              |ГДЕ
		              |	ЧекККМ.Ссылка = &Ссылка";
	Иначе
		Возврат Неопределено; 
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка); 
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 
		Структура = Новый Структура; 
		Структура.Вставить("ЗащитныйКод", прав(Выборка.ЗащитныйКод, СтрДлина(Выборка.ЗащитныйКод) - 4)); 
		Структура.Вставить("QRкод", Выборка.QRкод);
		Возврат Структура;   
	КонецЕсли; 
	Возврат Неопределено; 
	
КонецФункции
&НаСервере
Функция НеобходимостьQRкода(Ссылка) 
	Структура = Новый Структура; 
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Структура.Вставить("ДокументПродажи", Истина);
		Если Ссылка.ДатаОтметкиКасса > Дата("00010101000000") и не Ссылка.Кассир.Пустая() Тогда 
			Структура.Вставить("ОтметкаКассы", Истина); 
		Иначе
			Структура.Вставить("ОтметкаКассы", Ложь); 
		КонецЕсли; 
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда  
		Структура.Вставить("ДокументПродажи", Истина);
		Если Ссылка.Статус = Перечисления.СтатусыЧековККМ.Пробит Тогда 
			Структура.Вставить("ОтметкаКассы", Истина); 
		Иначе
			Структура.Вставить("ОтметкаКассы", Ложь);  
		КонецЕсли;
	Иначе
		Структура.Вставить("ДокументПродажи", Ложь);
	    Структура.Вставить("ОтметкаКассы", Ложь);
	КонецЕсли; 
	Возврат Структура; 
КонецФункции

