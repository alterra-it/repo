
&НаСервере
Процедура ПроверитьНаСервере() 
	Проверка.Очистить();
	Если ПервыйВал = 0 Тогда
		Сообщить("Первый вал должен быть больше 0!"); 
		Возврат;
	КонецЕсли;	
	Если Патерностер = 0 Тогда
		Сообщить("Патерностер должен быть больше 0!"); 
		Возврат;
	КонецЕсли;	
	Если Не ЗначениеЗаполнено(Склад) Тогда
		Сообщить("Выберите склад!");
		Возврат;
	КонецЕсли;	
	
	Запрос = Новый Запрос;  
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Патерностеры.Ссылка КАК Патерностер,
		|	Патерностеры.Вал КАК Вал,
		|	Патерностеры.ДопустимаяНагрузкаНаСтанок КАК ДопустимаяНагрузкаНаСтанок,
		|	Патерностеры.ДопустимаяНагрузкаНаВал КАК ДопустимаяНагрузкаНаВал,
		|	Патерностеры.ДисбалансПоСторонам КАК ДисбалансПоСторонам,
		|	РегистрПатерностеры.Характеристика КАК Характеристика,
		|	РегистрПатерностеры.Номенклатура КАК Номенклатура,
		|	Патерностеры.Склад КАК Склад,
		|	&Вес КАК Вес
		|ПОМЕСТИТЬ ВТ_Патерностер
		|ИЗ
		|	Справочник.Патерностеры КАК Патерностеры
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Патерностеры КАК РегистрПатерностеры
		|		ПО (РегистрПатерностеры.Патерностер = Патерностеры.Ссылка)
		|ГДЕ
		|	Патерностеры.Склад = &Склад
		|	И Патерностеры.Патерностер = &Патерностер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Патерностер.Патерностер КАК Патерностер,
		|	ВТ_Патерностер.Вал КАК Вал,
		|	ВТ_Патерностер.ДопустимаяНагрузкаНаСтанок КАК ДопустимаяНагрузкаНаСтанок,
		|	ВТ_Патерностер.ДопустимаяНагрузкаНаВал КАК ДопустимаяНагрузкаНаВал,
		|	ВТ_Патерностер.ДисбалансПоСторонам КАК ДисбалансПоСторонам,
		|	ВТ_Патерностер.Характеристика КАК Характеристика,
		|	ВТ_Патерностер.Номенклатура КАК Номенклатура,
		|	ВТ_Патерностер.Склад КАК Склад,
		|	СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК Остаток,
		|	ВТ_Патерностер.Вес * СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК Вес
		|ИЗ
		|	ВТ_Патерностер КАК ВТ_Патерностер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыИПотребности.Остатки(, ) КАК ЗапасыИПотребностиОстатки
		|		ПО (ЗапасыИПотребностиОстатки.Номенклатура = ВТ_Патерностер.Номенклатура)
		|			И (ЗапасыИПотребностиОстатки.Характеристика = ВТ_Патерностер.Характеристика)
		|			И (ЗапасыИПотребностиОстатки.Склад = ВТ_Патерностер.Склад)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Патерностер.Патерностер,
		|	ВТ_Патерностер.Вал,
		|	ВТ_Патерностер.ДопустимаяНагрузкаНаСтанок,
		|	ВТ_Патерностер.ДопустимаяНагрузкаНаВал,
		|	ВТ_Патерностер.ДисбалансПоСторонам,
		|	ВТ_Патерностер.Характеристика,
		|	ВТ_Патерностер.Номенклатура,
		|	ВТ_Патерностер.Склад,
		|	ВТ_Патерностер.Вес
		|
		|УПОРЯДОЧИТЬ ПО
		|	Вал
		|ИТОГИ
		|	КОЛИЧЕСТВО(Вал)
		|ПО
		|	ОБЩИЕ";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Вес", Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки("РегистрПатерностеры.Номенклатура.ЕдиницаИзмерения", "РегистрПатерностеры.Номенклатура", Ложь));
	
	Запрос.УстановитьПараметр("Дата", ТекущаяДата());
	Запрос.УстановитьПараметр("Патерностер", Патерностер);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
	ТаблицаПроверки = Новый ТаблицаЗначений;
	ТаблицаПроверки.Колонки.Добавить("Патерностер");
	ТаблицаПроверки.Колонки.Добавить("Вал",Новый ОписаниеТипов("Число"));  
	ТаблицаПроверки.Колонки.Добавить("Остаток",Новый ОписаниеТипов("Число"));
	ТаблицаПроверки.Колонки.Добавить("Вес",Новый ОписаниеТипов("Число"));
	ТаблицаПроверки.Колонки.Добавить("ДопустимаяНагрузкаНаСтанок",Новый ОписаниеТипов("Число")); 
	ТаблицаПроверки.Колонки.Добавить("ДопустимаяНагрузкаНаВал",Новый ОписаниеТипов("Число"));
	ТаблицаПроверки.Колонки.Добавить("ДисбалансПоСторонам",Новый ОписаниеТипов("Число"));
	ТаблицаПроверки.Колонки.Добавить("Номенклатура");   
	ТаблицаПроверки.Колонки.Добавить("Характеристика"); 
	
	ВыборкаОбщие = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"Общие");
	
	Если ВыборкаОбщие.Следующий() Тогда   
		ВсегоВалов = ВыборкаОбщие.Вал;
		Выборка = ВыборкаОбщие.Выбрать();
		Пока Выборка.Следующий() Цикл        
			СтрокаПоверки = ТаблицаПроверки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаПоверки,Выборка);  
		КонецЦикла;
	КонецЕсли;
	
	// Вывести отчет
	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("Макет");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");   
	ОбластьДисбаланс = Макет.ПолучитьОбласть("Дисбаланс");
	
	ВывестиШапку = 0; 
	
	//ПоловинаВалов = Цел(ВсегоВалов/2);
	ПоловинаВалов = ?(Цел(ВсегоВалов/2) = ВсегоВалов/2, ВсегоВалов/2, Цел(ВсегоВалов/2) + 1);
	ВсегоВес1 = 0; 
	ВсегоВес2 = 0;
	Для Н=0 По  ПоловинаВалов-1  Цикл
		Если ВывестиШапку = 0 Тогда  
			ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,ТаблицаПроверки[0]);  
			Проверка.Вывести(ОбластьШапка);
			ВывестиШапку = 1;	
		КонецЕсли;
		
		Н1=Н+ПервыйВал;  
		Если Н1>ВсегоВалов Тогда
			Н1=Н1-ВсегоВалов;
		КонецЕсли;	
		
		Н2=Н1+ПоловинаВалов;
		Если Н2>ВсегоВалов Тогда
			Н2=Н2-ВсегоВалов;
		КонецЕсли;	
		
		ОбластьСтрока.Параметры.НомерВала1 = ТаблицаПроверки[Н1-1].Вал; 
		ОбластьСтрока.Параметры.Номенклатура1 = СтрШаблон("%1 %2",ТаблицаПроверки[Н1-1].Номенклатура, ТаблицаПроверки[Н1-1].Характеристика);
		ОбластьСтрока.Параметры.Остаток1 = ТаблицаПроверки[Н1-1].Остаток;
		ОбластьСтрока.Параметры.Вес1 = ТаблицаПроверки[Н1-1].Вес;   
		ВсегоВес1 = ВсегоВес1 + ТаблицаПроверки[Н1-1].Вес; 
		ОбластьСтрока.Параметры.РасшифровкаНоменклатура1 = Новый Структура("Номенклатура, Характеристика", ТаблицаПроверки[Н1-1].Номенклатура, ТаблицаПроверки[Н1-1].Характеристика);
		
		Если Н < ПоловинаВалов-1 или ПоловинаВалов=Цел(ВсегоВалов/2) Тогда
		ОбластьСтрока.Параметры.НомерВала2 = ТаблицаПроверки[Н2-1].Вал; 
		ОбластьСтрока.Параметры.Номенклатура2 = СтрШаблон("%1 %2",ТаблицаПроверки[Н2-1].Номенклатура, ТаблицаПроверки[Н2-1].Характеристика);
		ОбластьСтрока.Параметры.Остаток2 = ТаблицаПроверки[Н2-1].Остаток;
		ОбластьСтрока.Параметры.Вес2 = ТаблицаПроверки[Н2-1].Вес; 
		ВсегоВес2 = ВсегоВес2 + ТаблицаПроверки[Н2-1].Вес;     
		ОбластьСтрока.Параметры.РасшифровкаНоменклатура2 = Новый Структура("Номенклатура, Характеристика", ТаблицаПроверки[Н2-1].Номенклатура, ТаблицаПроверки[Н2-1].Характеристика);
		Иначе
		ОбластьСтрока.Параметры.НомерВала2 = ""; 
		ОбластьСтрока.Параметры.Номенклатура2 = "";
		ОбластьСтрока.Параметры.Остаток2 = "";
		ОбластьСтрока.Параметры.Вес2 = ""; 
		ОбластьСтрока.Параметры.РасшифровкаНоменклатура2 = "";
		КонецЕсли;
	
		Если ТаблицаПроверки[Н1-1].Вес > ТаблицаПроверки[Н1-1].ДопустимаяНагрузкаНаВал Тогда   
			Сообщить(СтрШаблон("Превышение веса на %1 валу на %2 кг.",Н1,ТаблицаПроверки[Н1-1].Вес - ТаблицаПроверки[Н1-1].ДопустимаяНагрузкаНаВал));
		КонецЕсли;	     
		
		Если Н < ПоловинаВалов-1 или ПоловинаВалов=Цел(ВсегоВалов/2) Тогда
		Если ТаблицаПроверки[Н2-1].Вес > ТаблицаПроверки[Н2-1].ДопустимаяНагрузкаНаВал Тогда   
			Сообщить(СтрШаблон("Превышение веса на %1 валу на %2 кг.",Н2,ТаблицаПроверки[Н2-1].Вес - ТаблицаПроверки[Н2-1].ДопустимаяНагрузкаНаВал));
		КонецЕсли;
		КонецЕсли;
		
		Проверка.Вывести(ОбластьСтрока);
	КонецЦикла;           
	ОбластьПодвал.Параметры.ВсегоВес1 = ВсегоВес1;  
	ОбластьПодвал.Параметры.ВсегоВес2 = ВсегоВес2; 
	Проверка.Вывести(ОбластьПодвал);       
	
	Если Макс(ВсегоВес1 - ВсегоВес2,ВсегоВес2 - ВсегоВес1) > ТаблицаПроверки[0].ДисбалансПоСторонам Тогда   
		Сообщить(СтрШаблон("Дисбаланс по сторонам на %1 кг.", Макс(ВсегоВес1 - ВсегоВес2,ВсегоВес2 - ВсегоВес1)));
	КонецЕсли;
	Если ВсегоВес1 + ВсегоВес2 > ТаблицаПроверки[0].ДопустимаяНагрузкаНаСтанок Тогда   
		Сообщить(СтрШаблон("Превышение общего веса на %1 кг.", ВсегоВес1 + ВсегоВес2 - ТаблицаПроверки[0].ДопустимаяНагрузкаНаСтанок));
	КонецЕсли; 
	//--
	
	// Проверить дисбаланс по всем вариантам размещения валов   
	ВалыДисбаланс = "";
	
	Для Сч=1 По ВсегоВалов Цикл
	ПервыйВалПроверка = Сч;
		ВсегоВес1 = 0; 
		ВсегоВес2 = 0;     
		
		Для Н=0 По  ПоловинаВалов-1  Цикл
			
			Н1=Н+ПервыйВалПроверка;  
			Если Н1>ВсегоВалов Тогда
				Н1=Н1-ВсегоВалов;
			КонецЕсли;	
			
			Н2=Н1+ПоловинаВалов;
			Если Н2>ВсегоВалов Тогда
				Н2=Н2-ВсегоВалов;
			КонецЕсли;	
			
			ВсегоВес1 = ВсегоВес1 + ТаблицаПроверки[Н1-1].Вес;
			
			Если Н < ПоловинаВалов-1 или ПоловинаВалов=Цел(ВсегоВалов/2) Тогда
            ВсегоВес2 = ВсегоВес2 + ТаблицаПроверки[Н2-1].Вес;
			КонецЕсли;
		
		КонецЦикла;           
		
		Если Макс(ВсегоВес1 - ВсегоВес2,ВсегоВес2 - ВсегоВес1) > ТаблицаПроверки[0].ДисбалансПоСторонам Тогда   
			Если ВалыДисбаланс = "" Тогда 
				ВалыДисбаланс = Строка(Сч);
			Иначе
				ВалыДисбаланс = СтрШаблон("%1, %2",ВалыДисбаланс,Строка(Сч));
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;
	Если ВалыДисбаланс <> "" Тогда
		ОбластьДисбаланс.Параметры.ВалыДисбаланс = ВалыДисбаланс; 
		Проверка.Вывести(ОбластьДисбаланс);       
	КонецЕсли;	
	//--
	Иначе
		Сообщить("Не найдена информация по патерностерам");
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура Проверить(Команда) 
	ОчиститьСообщения();
	ПроверитьНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Склад") Тогда
		Склад = Параметры.Склад;  
	КонецЕсли;
	Если Параметры.Свойство("Патерностер") Тогда
		Патерностер = Параметры.Патерностер;  
	КонецЕсли;
	ПервыйВал = 1;
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОбработкаРасшифровки(Элемент, Расшифровка, СтандартнаяОбработка, ДополнительныеПараметры)
	СтандартнаяОбработка = Ложь;     
	ЗначениеОтбора = Новый Структура("Склад, Номенклатура, Характеристика", Склад, Расшифровка.Номенклатура, Расшифровка.Характеристика);
	ПараметрыВыбора = Новый Структура("Отбор", ЗначениеОтбора);
	ФормаРегистра = ПолучитьФорму("РегистрСведений.Патерностеры.ФормаСписка",ПараметрыВыбора);
	ФормаРегистра.Открыть();
КонецПроцедуры
