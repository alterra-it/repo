  <attributes>
    <name>Список</name>
    <title>
      <key>ru</key>
      <value>Список</value>
    </title>
    <id>1</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	СтатусыВодителей.Водитель КАК Водитель,
	ВЫБОР
		КОГДА СтатусыВодителей.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.Готов)
			ТОГДА 1
		ИНАЧЕ ВЫБОР
				КОГДА СтатусыВодителей.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.ВРейсе)
					ТОГДА 2
				ИНАЧЕ ВЫБОР
						КОГДА СтатусыВодителей.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.НеГотов)
							ТОГДА 3
						ИНАЧЕ 10
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК Порядок,
	СвязьВодителейТСПартнеров.Автомобиль КАК Автомобиль,
	СвязьВодителейТСПартнеров.Автомобиль.Тип КАК ТипТС,
	СвязьВодителейТСПартнеров.Автомобиль.Тип.Приоритет КАК ПриоритетТипаТС,
	СвязьВодителейТСПартнеров.Автомобиль.ГрузоподъемностьВТоннах КАК ГрузоподъемностьВТоннах,
	СвязьВодителейТСПартнеров.Автомобиль.ВместимостьВКубическихМетрах КАК ВместимостьВКубическихМетрах,
	СвязьВодителейТСПартнеров.Автомобиль.МаксимальнаяДлинаГруза КАК МаксимальнаяДлинаГруза,
	Сотрудники.Подразделение КАК Подразделение,
	СтатусыВодителей.Статус КАК Статус,
	СтатусыВодителей.Рейс КАК Рейс,
	СтатусыВодителей.Дата КАК ДатаГотов
ПОМЕСТИТЬ ВТ_ВыходыВодителейФакт
ИЗ
	РегистрСведений.СтатусыВодителей КАК СтатусыВодителей
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		ПО СтатусыВодителей.Водитель = Сотрудники.ФизическоеЛицо
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязьВодителейТСПартнеров КАК СвязьВодителейТСПартнеров
		ПО СтатусыВодителей.Водитель = СвязьВодителейТСПартнеров.Водитель
ГДЕ
	Сотрудники.Уволен = ЛОЖЬ
	И Сотрудники.ПометкаУдаления = ЛОЖЬ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ГрафикВыходаВодителейОбороты.Период КАК Период,
	ГрафикВыходаВодителейОбороты.Водитель КАК Водитель,
	ГрафикВыходаВодителейОбороты.ПлановыйВыходОборот КАК ПлановыйВыход,
	ГрафикВыходаВодителейОбороты.ВнеплановыйВыходОборот КАК ВнеплановыйВыход,
	ГрафикВыходаВодителейОбороты.ВыходнойОборот КАК Выходной,
	ГрафикВыходаВодителейОбороты.НеВыходОборот КАК НеВыход,
	ВЫБОР
		КОГДА ГрафикВыходаВодителейОбороты.ПлановыйВыходОборот = 1
			ТОГДА &quot;1&quot;
		ИНАЧЕ ВЫБОР
				КОГДА ГрафикВыходаВодителейОбороты.ВнеплановыйВыходОборот = 1
					ТОГДА &quot;в1&quot;
				ИНАЧЕ ВЫБОР
						КОГДА ГрафикВыходаВодителейОбороты.ВыходнойОборот = 1
							ТОГДА &quot;в&quot;
						ИНАЧЕ ВЫБОР
								КОГДА ГрафикВыходаВодителейОбороты.НеВыходОборот = 1
									ТОГДА &quot;н&quot;
							КОНЕЦ
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК ГрафикВыхода
ПОМЕСТИТЬ ВТ_ПланВыходов
ИЗ
	РегистрНакопления.ГрафикВыходаВодителей.Обороты(&amp;Дата1, &amp;Дата2, День, ПланФакт = &amp;ПланФакт) КАК ГрафикВыходаВодителейОбороты
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_ВыходыВодителейФакт.Водитель КАК Водитель,
	ВТ_ВыходыВодителейФакт.Порядок КАК Порядок,
	ЕСТЬNULL(ВТ_ПланВыходов.ПлановыйВыход, 0) КАК ПлановыйВыход,
	ЕСТЬNULL(ВТ_ПланВыходов.ВнеплановыйВыход, 0) КАК ВнеплановыйВыход,
	ЕСТЬNULL(ВТ_ПланВыходов.Выходной, 0) КАК Выходной,
	ЕСТЬNULL(ВТ_ПланВыходов.НеВыход, 0) КАК НеВыход,
	ЕСТЬNULL(ВТ_ПланВыходов.ГрафикВыхода, &quot;&quot;) КАК ПоПлану,
	ВТ_ВыходыВодителейФакт.Автомобиль КАК Автомобиль,
	ВТ_ВыходыВодителейФакт.ТипТС КАК ТипТС,
	ВТ_ВыходыВодителейФакт.ПриоритетТипаТС КАК ПриоритетТипаТС,
	ВТ_ВыходыВодителейФакт.ГрузоподъемностьВТоннах КАК Грузоподъемность,
	ВТ_ВыходыВодителейФакт.ВместимостьВКубическихМетрах КАК Вместимость,
	ВТ_ВыходыВодителейФакт.МаксимальнаяДлинаГруза КАК МаксимальнаяДлинаГруза,
	ВТ_ВыходыВодителейФакт.Подразделение КАК Подразделение,
	ВТ_ВыходыВодителейФакт.Статус КАК Статус,
	ВТ_ВыходыВодителейФакт.Рейс КАК Рейс,
	ВТ_ВыходыВодителейФакт.ДатаГотов КАК ДатаГотов
ИЗ
	ВТ_ВыходыВодителейФакт КАК ВТ_ВыходыВодителейФакт
		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПланВыходов КАК ВТ_ПланВыходов
		ПО ВТ_ВыходыВодителейФакт.Водитель = ВТ_ПланВыходов.Водитель

УПОРЯДОЧИТЬ ПО
	ВнеплановыйВыход УБЫВ,
	Порядок,
	ДатаГотов</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
