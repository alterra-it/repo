  <attributes>
    <name>СтатусыВодителей</name>
    <title>
      <key>ru</key>
      <value>Статусы водителей</value>
    </title>
    <id>4</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	СтатусыВодителейСрезПоследних.Водитель КАК Водитель,
	СтатусыВодителейСрезПоследних.Статус КАК Статус,
	ВЫБОР
		КОГДА СтатусыВодителейСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.Готов)
			ТОГДА 1
		ИНАЧЕ ВЫБОР
				КОГДА СтатусыВодителейСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.Возвращается)
					ТОГДА 2
				ИНАЧЕ ВЫБОР
						КОГДА СтатусыВодителейСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.ВРейсе)
							ТОГДА 3
						ИНАЧЕ ВЫБОР
								КОГДА СтатусыВодителейСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.НеГотов)
									ТОГДА 4
								ИНАЧЕ 10
							КОНЕЦ
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК Порядок,
	Сотрудники.Подразделение КАК Подразделение,
	СтатусыВодителейСрезПоследних.Рейс КАК Рейс,
	СтатусыВодителейСрезПоследних.Рейс.НужнаИнкассация КАК НужнаИнкассация,
	СтатусыВодителейСрезПоследних.Рейс.ОплатаБанковскойКартой КАК ОплатаБанковскойКартой,
	СтатусыВодителейСрезПоследних.Рейс.БанковскийТерминал КАК БанковскийТерминал,
	СтатусыВодителейСрезПоследних.Дата КАК Дата,
	ВЫБОР
		КОГДА СтатусыВодителейСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыВодителей.Возвращается)
			ТОГДА ВЫБОР
					КОГДА РАЗНОСТЬДАТ(&amp;ТекущаяДата, СтатусыВодителейСрезПоследних.ДатаПрибытия, МИНУТА) > 0
							И РАЗНОСТЬДАТ(&amp;ТекущаяДата, СтатусыВодителейСрезПоследних.ДатаПрибытия, МИНУТА) &lt; 3601
						ТОГДА РАЗНОСТЬДАТ(&amp;ТекущаяДата, СтатусыВодителейСрезПоследних.ДатаПрибытия, МИНУТА)
					ИНАЧЕ ВЫБОР
							КОГДА РАЗНОСТЬДАТ(&amp;ТекущаяДата, СтатусыВодителейСрезПоследних.ДатаПрибытия, МИНУТА) > 9909
								ТОГДА &quot;более часа&quot;
							ИНАЧЕ &quot;опаздывает&quot;
						КОНЕЦ
				КОНЕЦ
	КОНЕЦ КАК НаБазеЧерез,
	ВЫРАЗИТЬ(&quot;&quot; КАК СТРОКА(100)) КАК СписокЗаказов
ИЗ
	РегистрСведений.СтатусыВодителей КАК СтатусыВодителейСрезПоследних
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		ПО СтатусыВодителейСрезПоследних.Водитель = Сотрудники.ФизическоеЛицо
			И (ЛОЖЬ = Сотрудники.Уволен)
			И (ЛОЖЬ = Сотрудники.ПометкаУдаления)</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
