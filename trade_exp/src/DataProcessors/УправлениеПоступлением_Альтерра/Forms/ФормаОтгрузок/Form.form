    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ЖурналДокументовСкладскиеОрдера.Ссылка КАК Ссылка,
	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение КАК Распоряжение
ИЗ
	ЖурналДокументов.СкладскиеОрдера КАК ЖурналДокументовСкладскиеОрдера
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		ПО ЖурналДокументовСкладскиеОрдера.Ссылка = РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Ссылка</dataPath>
        <field>Ссылка</field>
      </fields>
      <fields xsi:type="schema:DataCompositionSchemaDataSetField">
        <dataPath>Распоряжение</dataPath>
        <field>Распоряжение</field>
      </fields>
    </extInfo>
  </attributes>
