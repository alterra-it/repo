Процедура ЗаполнитьОрдераПоТекРаспоряжению(РаспоряжениеНаПоступление)
ПриходныеОрдера = ПриходныеОрдераПоРаспоряжению(РаспоряжениеНаПоступление);
ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераПоТекущемуРаспоряжению, "Ссылка", ПриходныеОрдера, ВидСравненияКомпоновкиДанных.ВСписке,,Истина);									
КонецПроцедуры

&НаКлиенте
Процедура РабочиеУчасткиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь; 
	
	РабочиеУчастки.Очистить();
	
	ПараметрыОтбора =  Новый Структура;
	ЗначениеОтбора =  Новый Структура;
	ЗначениеОтбора.Вставить("Владелец", Склад);
	ЗначениеОтбора.Вставить("ПометкаУдаления", Ложь);
	ПараметрыОтбора.Вставить("Отбор", ЗначениеОтбора);
	ПараметрыОтбора.Вставить("МножественныйВыбор", Истина);
	Форма = ОткрытьФорму("Справочник.РабочиеУчастки.ФормаВыбора",ПараметрыОтбора , Элемент);
	
	Если ЕстьРабочиеУчасткиПользователя() Тогда
		
		ОтборВладелец = Форма.Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
		ОтборВладелец.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; 
		ОтборВладелец.Использование = Истина; 
		ОтборВладелец.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка"); 
		ОтборВладелец.ПравоеЗначение = ПолучитьРабочиеУчасткиПользователя();    
		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ЕстьРабочиеУчасткиПользователя()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СекцииКладовщиков.Ячейка КАК Ячейка
		|ИЗ
		|	РегистрСведений.СекцииКладовщиков КАК СекцииКладовщиков
		|ГДЕ
		|	СекцииКладовщиков.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
КонецФункции

&НаСервере
Функция ПолучитьРабочиеУчасткиПользователя()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СекцииКладовщиков.Ячейка КАК Ячейка
		|ИЗ
		|	РегистрСведений.СекцииКладовщиков КАК СекцииКладовщиков
		|ГДЕ
		|	СекцииКладовщиков.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	РезультатЗапросаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивЗначений = Новый Массив();
	
	Пока РезультатЗапросаДетальныеЗаписи.Следующий() Цикл
		МассивЗначений.Добавить(РезультатЗапросаДетальныеЗаписи.Ячейка);
	КонецЦикла;
	
	Возврат МассивЗначений;
КонецФункции

&НаКлиенте
Процедура РабочиеУчасткиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Для Каждого Элем из ВыбранноеЗначение цикл
	 РабочиеУчастки.Добавить(Элем);
	Конеццикла; 
	УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
	ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДополнительныеТаблицы()
		
	Распоряжение = Ложь;
	
	Если Элементы.Группа1.ТекущаяСтраница.Имя = "Группа2" Тогда
		ТекущаяСтрока = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
		Распоряжение = Истина;
	Иначе
		ТекущаяСтрока = Элементы.ОрдераВРаботе.ТекущиеДанные;
		Распоряжение = Ложь;
	КонецЕсли;

	Если ТекущаяСтрока<>Неопределено Тогда
		
		СсылкаНаДокумент = ?(Распоряжение,ТекущаяСтрока.Распоряжение,ТекущаяСтрока.Ссылка);
		
		Если Распоряжение Тогда
		ТекущийРабочийУчасток =ТекущаяСтрока.РабочийУчасток; 
	    КонецЕсли;
	
		Если ОтображатьТовары Тогда
			ЗаполнитьТовары(Не Распоряжение,СсылкаНаДокумент);
		КонецЕсли;
		
		Если ОтображатьОрдераПоТекущемуРаспоряжению И Распоряжение Тогда
			 ЗаполнитьОрдераПоТекРаспоряжению(РаспоряжениеНаПоступление());
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСписки(Команда)
	УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
	ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле = Элементы.ТоварыЯчейка Тогда 
		
		ТекЯч = Элемент.ТекущиеДанные.Ячейка;
		
		ПараметрыОтбора =  Новый Структура;
		ЗначениеОтбора =  Новый Структура;
		ЗначениеОтбора.Вставить("Владелец", Склад);
		
		ЗначениеОтбора.Вставить("ПометкаУдаления", Ложь);
		ПараметрыОтбора.Вставить("Отбор", ЗначениеОтбора);
		ПараметрыОтбора.Вставить("МножественныйВыбор", Ложь);
		ОткрытьФорму("Справочник.СкладскиеЯчейки.ФормаВыбора",ПараметрыОтбора , Элемент);
		
	Иначе
		
		ПоказатьЗначение(Неопределено, Элемент.ТекущиеДанные.Номенклатура);
		
	КонецЕсли;

КонецПроцедуры

Функция ПолучимРабУч(ТекЯч)

	Возврат ТекЯч.РабочийУчасток;

КонецФункции

&НаКлиенте
Процедура ТоварыОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
    НоваяЯчейка(ВыбранноеЗначение, Склад, Элементы.Товары.ТекущиеДанные.Номенклатура);
    ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры
	
&НаСервере
Процедура НоваяЯчейка(Ячейка, Склад, Номенклатура)
	Набор = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей();
	Набор.Отбор.Склад.Установить(Склад);
	Набор.Отбор.Номенклатура.Установить(Номенклатура);
	
	Набор.Прочитать();
	Если Набор.Количество() = 1 Тогда
		НоваяСтрока = Набор[0];	
    	НоваяСтрока.Ячейка = Ячейка;
		Попытка
			Набор.Записать(Истина);
		Исключение
			ЕстьОшибки = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить новую ячейку");
		КонецПопытки;
	ИначеЕсли Набор.Количество() = 0 Тогда
		
		 НоваяЗапись = Набор.Добавить(); 
		 НоваяЗапись.Номенклатура = Номенклатура;    
		 НоваяЗапись.Склад = Склад;  
         НоваяЗапись.Ячейка = Ячейка;
		 НоваяЗапись.ОсновнаяЯчейка = Истина;
        Попытка
			Набор.Записать(Истина);
		Исключение
			ЕстьОшибки = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить новую ячейку");
		КонецПопытки;
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось установить новую ячейку");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ПоискПоНомеруПриИзменении(Элемент)
	УстановитьОтборыВОсновныхСписках();
	ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры

&НаКлиенте
Процедура ИспользоватьОтборПоДатеДокументаПриИзменении(Элемент)
	Элементы.ДатаПоступления.Доступность = ?(ИспользоватьОтборПоДатеДокумента="1",Истина,Ложь);
	Элементы.ПериодПоДатеДокумента.Доступность = ?(ИспользоватьОтборПоДатеДокумента="0",Истина,Ложь);
	УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
	ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры

&НаКлиенте
Процедура ПериодПоДатеДокументаПриИзменении(Элемент)
		УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
		ЗаполнитьДополнительныеТаблицы();
КонецПроцедуры
