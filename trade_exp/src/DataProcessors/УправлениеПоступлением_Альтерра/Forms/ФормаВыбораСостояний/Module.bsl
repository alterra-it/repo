
&НаКлиенте
Процедура ВыбратьВсе(Команда)
	Для Каждого Стр Из ТаблицаСостояний Цикл 
		Стр.Пометка = Стр.Представление <> "Все";
	КонецЦикла;
КонецПроцедуры   
 
 &НаКлиенте
Процедура ОтменитьВыбор(Команда)
	Для Каждого Стр Из ТаблицаСостояний Цикл
		Стр.Пометка = Ложь;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)    
	Состояние = Новый СписокЗначений;
	Для Каждого Стр Из ТаблицаСостояний Цикл
		Если Стр.Пометка Тогда
			Состояние.Добавить(Стр.Значение, Стр.Представление);
		КонецЕсли;
	КонецЦикла;
	
	Закрыть(Состояние);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("СостояниеСписок") И ЗначениеЗаполнено(Параметры.СостояниеСписок) И ТипЗнч(Параметры.СостояниеСписок) = Тип("СписокЗначений") Тогда 
		Для Каждого Элемент Из Параметры.СостояниеСписок Цикл
			НоваяСтрока               = ТаблицаСостояний.Добавить();
			НоваяСтрока.Пометка       = Элемент.Пометка;
			НоваяСтрока.Представление = Элемент.Представление;
			НоваяСтрока.Значение      = Элемент.Значение;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПометкаПриИзменении(Элемент)  
	ТекущиеДанные = Элементы.ТаблицаСостояний.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено И ТекущиеДанные.Пометка Тогда
		Если ТекущиеДанные.Представление = "Все" Тогда
			Для Каждого Стр Из ТаблицаСостояний Цикл
				Если Стр.Представление <> "Все" Тогда 
					Стр.Пометка = Ложь;         
				КонецЕсли;
			КонецЦикла;
		Иначе
			Для Каждого Стр Из ТаблицаСостояний Цикл
				Если Стр.Представление = "Все" Тогда 
					Стр.Пометка = Ложь;         
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;  
	КонецЕсли;
КонецПроцедуры
