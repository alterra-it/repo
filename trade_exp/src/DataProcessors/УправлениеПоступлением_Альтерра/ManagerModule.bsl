
#Область РаботаСОтборомПоСостоянию

&НаСервере
Процедура ДобавитьСостоянияВТекстЗапроса(Запрос, МассивСостояний) Экспорт        
	
	Условие = "";
	Условие_ОтметкаКассы = "";
	Если МассивСостояний.Найти("Все") = Неопределено Тогда 
		Для Каждого Строка Из МассивСостояний Цикл
			Если СтрНайти(Строка, "ОтметкаКассы") = 0 Тогда
				Условие = ?(ЗначениеЗаполнено(Условие), Условие + " ИЛИ ", "") + Строка;
			Иначе
				Условие_ОтметкаКассы = Строка;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;    
	
	Если ЗначениеЗаполнено(Условие) И ЗначениеЗаполнено(Условие_ОтметкаКассы) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие", Условие_ОтметкаКассы + " И (" + Условие + ")");
	ИначеЕсли НЕ ЗначениеЗаполнено(Условие) И НЕ ЗначениеЗаполнено(Условие_ОтметкаКассы) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие", "ИСТИНА");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Условие", ?(ЗначениеЗаполнено(Условие), Условие, Условие_ОтметкаКассы));	
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

