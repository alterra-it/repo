&НаКлиенте
Процедура Группа1ПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если Элементы.Группа1.ТекущаяСтраница.Имя = "Группа2" Тогда
		ТекущаяСтрока = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
		Если ТекущаяСтрока<>Неопределено Тогда
			СсылкаНаДокумент = ТекущаяСтрока.Распоряжение;
			ЗаполнитьТовары(Ложь,СсылкаНаДокумент);
		КонецЕсли;	
	Иначе
		ТекущаяСтрока = Элементы.ОрдераВРаботе.ТекущиеДанные;
		Если ТекущаяСтрока<>Неопределено Тогда
			СсылкаНаДокумент = ТекущаяСтрока.Ссылка;
			ЗаполнитьТовары(Истина,СсылкаНаДокумент);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтображатьОрдераПоТекущемуРаспоряжениюПриИзменении(Элемент)
	Элементы.Группа6.Видимость=ОтображатьОрдераПоТекущемуРаспоряжению;
КонецПроцедуры

Процедура ЗаполнитьОрдераПоТекРаспоряжению(РаспоряжениеНаПоступление)
ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераПоТекущемуРаспоряжению, "Ссылка.Основание", РаспоряжениеНаПоступление, ВидСравненияКомпоновкиДанных.Равно,,Истина);									
КонецПроцедуры

&НаСервере
Процедура УтвердитьОрдерНаСервере(СсылкаНаДокумент)
	 Ордер = СсылкаНаДокумент.ПолучитьОбъект();
     Ордер.ПодтвержденСкладом = Истина;
	 Ордер.Записать(РежимЗаписиДокумента.Проведение);
КонецПроцедуры

&НаКлиенте
Процедура УтвердитьОрдер(Команда)
	
	ТекущаяСтраница = Неопределено;
	
	Если Элементы.Группа1.ТекущаяСтраница.Имя = "Группа2" Тогда
		 ТекущаяСтрока = Элементы.ОрдераПоТекущемуРаспоряжению.ТекущиеДанные;
	 ИначеЕсли Элементы.Группа1.ТекущаяСтраница.Имя = "Группа3" Тогда
		 ТекущаяСтрока = Элементы.ОрдераВРаботе.ТекущиеДанные;
	КонецЕсли;
	
	Если ТекущаяСтрока<>Неопределено Тогда
	СсылкаНаДокумент = ТекущаяСтрока.Ссылка;
	УтвердитьОрдерНаСервере(СсылкаНаДокумент);
    КонецЕсли;

	ТекущаяСтрокаР = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
	
	Если ТекущаяСтрокаР<>Неопределено Тогда
		
		СсылкаНаДокумент = ТекущаяСтрокаР.Распоряжение;
		ЗаполнитьОрдераПоТекРаспоряжению(СсылкаНаДокумент);
			
	КонецЕсли;

	Элементы.ОрдераВРаботе.Обновить();
КонецПроцедуры

&НаКлиенте
Процедура РабочиеУчасткиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь; 
	
	РабочиеУчастки.Очистить();
	ПараметрыОтбора =  Новый Структура;
	ЗначениеОтбора =  Новый Структура;
	ЗначениеОтбора.Вставить("Владелец", Склад);
	ЗначениеОтбора.Вставить("ПометкаУдаления", Ложь);
	ПараметрыОтбора.Вставить("Отбор", ЗначениеОтбора);
	ПараметрыОтбора.Вставить("МножественныйВыбор", Истина);
	Форма = ОткрытьФорму("Справочник.РабочиеУчастки.ФормаВыбора",ПараметрыОтбора , Элемент);

	Если ЕстьРабочиеУчасткиПользователя() Тогда
		
		ОтборВладелец =Форма.Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
		ОтборВладелец.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; 
		ОтборВладелец.Использование = Истина; 
		ОтборВладелец.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Ссылка"); 
		ОтборВладелец.ПравоеЗначение = ПолучитьРабочиеУчасткиПользователя();    
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЕстьРабочиеУчасткиПользователя()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СекцииКладовщиков.Ячейка КАК Ячейка
		|ИЗ
		|	РегистрСведений.СекцииКладовщиков КАК СекцииКладовщиков
		|ГДЕ
		|	СекцииКладовщиков.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
КонецФункции

&НаСервере
Функция ПолучитьРабочиеУчасткиПользователя()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СекцииКладовщиков.Ячейка КАК Ячейка
		|ИЗ
		|	РегистрСведений.СекцииКладовщиков КАК СекцииКладовщиков
		|ГДЕ
		|	СекцииКладовщиков.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	РезультатЗапросаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивЗначений = Новый Массив();
	
	Пока РезультатЗапросаДетальныеЗаписи.Следующий() Цикл
		МассивЗначений.Добавить(РезультатЗапросаДетальныеЗаписи.Ячейка);
	КонецЦикла;
	
	Возврат МассивЗначений;
КонецФункции

&НаКлиенте
Процедура РабочиеУчасткиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Для Каждого Элем из ВыбранноеЗначение цикл
	 РабочиеУчастки.Добавить(Элем);
     Конеццикла;
    РабочиеУчастки.Добавить(ПустойУчасток());
	УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
КонецПроцедуры

&НаКлиенте
Процедура Обновить(Команда)
	УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
КонецПроцедуры

Функция ПустойУчасток()
	Возврат Справочники.РабочиеУчастки.ПустаяСсылка();
КонецФункции

Функция РольДоступнаПодтверждениеСкладом()
	Возврат АльтерраОбщегоНазначения._РольДоступна("ПодтверждениеСкладом") ИЛИ АльтерраОбщегоНазначения._РольДоступна("ПолныеПрава");
КонецФункции
