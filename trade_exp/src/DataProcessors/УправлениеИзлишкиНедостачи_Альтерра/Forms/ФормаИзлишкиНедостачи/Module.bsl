&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;
	
	ЗаполнитьСкладПоУмолчанию();
	
	ФильтрОрдеров = "НеПодтвержденные";
	Элементы.УтвердитьОрдер1.Доступность = РольДоступнаПодтверждениеСкладом();		
	СкладПомещениеПриИзмененииСервер();
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	СписокТипов = ОрдераВРаботе.КомпоновщикНастроек.Настройки.Выбор.ДоступныеПоляВыбора.НайтиПоле(Новый ПолеКомпоновкиДанных("Ссылка")).Тип;
	ПараметрыРазмещения = ПодключаемыеКоманды.ПараметрыРазмещения();
	ПараметрыРазмещения.Источники = СписокТипов;
	ПараметрыРазмещения.КоманднаяПанель = Элементы.ОрдераВРаботеГруппаКоманднаяПанель;
	ПараметрыРазмещения.ПрефиксГрупп = "ОрдераВРаботе";
	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект, ПараметрыРазмещения);
	
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");

	УстановитьОтборыВоВсехСписках(РаспоряжениеНаПоступление());
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр));
		КонецЕсли;
	КонецЕсли;
	// Конец ПодключаемоеОборудование
		
КонецПроцедуры

#Область ОбработчикиСобытийЭлементовТаблицыФормыРаспоряженияНаПоступление

&НаКлиенте
Процедура РаспоряженияНаПоступлениеПриАктивизацииСтроки(Элемент)
	
	ТекущаяСтрока = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
	
	Если ТекущаяСтрока<>Неопределено Тогда
		
		СсылкаНаДокумент = ТекущаяСтрока.Распоряжение;
		ТекущийРабочийУчасток =ТекущаяСтрока.РабочийУчасток; 
		
		Если ОтображатьТовары Тогда
			ЗаполнитьТовары(Ложь,СсылкаНаДокумент);
		КонецЕсли;
		
		Если ОтображатьОрдераПоТекущемуРаспоряжению Тогда
			 ЗаполнитьОрдераПоТекРаспоряжению(СсылкаНаДокумент);
		КонецЕсли;
		
		Элементы.РаспоряженияНаПоступлениеСоздатьОрдер.Видимость = ТекущаяСтрока.ОрдерНеСоздан;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

&НаКлиенте
Функция РаспоряжениеНаПоступление()
	
	Если Элементы.РаспоряженияНаПоступление.ТекущиеДанные <> Неопределено Тогда
		Возврат Элементы.РаспоряженияНаПоступление.ТекущиеДанные.Распоряжение;
	КонецЕсли;
	
	Возврат ПредопределенноеЗначение("Документ.ОприходованиеИзлишковТоваров.ПустаяСсылка");
	
КонецФункции

&НаСервере
Процедура УстановитьОтборыВЗависимыхСписках()
	
		
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Склад", Склад, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка.РабочийУчасток", РабочиеУчастки, ВидСравненияКомпоновкиДанных.ВСписке,,Истина);
		
	Если ФильтрОрдеров = "" Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка.ПодтвержденСкладом", Истина, ВидСравненияКомпоновкиДанных.Равно,,Ложь);
	ИначеЕсли ФильтрОрдеров = "Подтвержденные" Тогда	
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка.ПодтвержденСкладом", Истина, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	ИначеЕсли ФильтрОрдеров = "НеПодтвержденные" Тогда	
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОрдераВРаботе, "Ссылка.ПодтвержденСкладом", Ложь, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПриходныеОрдераПоРаспоряжению(Распоряжение)

	Запрос = Новый Запрос;
	Запрос.Текст = 		
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СкладскиеОрдераНаИзлишкиНедостачиПорчи.Ссылка КАК Ссылка
	|ИЗ
	|	ЖурналДокументов.СкладскиеОрдераНаИзлишкиНедостачиПорчи КАК СкладскиеОрдераНаИзлишкиНедостачиПорчи
	|ГДЕ
	|	СкладскиеОрдераНаИзлишкиНедостачиПорчи.Ссылка.Основание = &Распоряжения";
	
	Запрос.УстановитьПараметр("Распоряжение", Распоряжение);	
	ПриходныеОрдера = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
	Возврат ПриходныеОрдера;
	
КонецФункции

Процедура ЗаполнитьСкладПоУмолчанию()
	
	СтруктураЗаполнения = Новый Структура("Склад");
	ОбщегоНазначенияУТ.ОбработкаЗаполнения(СтруктураЗаполнения, Неопределено, Неопределено);
	Склад = СтруктураЗаполнения.Склад;
	
	Если НЕ ЗначениеЗаполнено(Склад) Тогда
		Склад = ЗначениеНастроекПовтИсп.ПолучитьСкладПоУмолчанию(Склад);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СкладПомещениеПриИзмененииСервер()
	
	СтруктураУстанавливаемыхПараметров = Новый Структура;
	Если ЗначениеЗаполнено(Склад) Тогда
		СтруктураУстанавливаемыхПараметров.Вставить("Склад",Склад);			
	Иначе
		СтруктураУстанавливаемыхПараметров.Вставить("Склад",Неопределено);
	КонецЕсли;
	
	РабочиеУчастки.Очистить();
		
	УстановитьОтборыВОсновныхСписках();
	
КонецПроцедуры

Процедура УстановитьОтборыВОсновныхСписках()
	//ЗаполнитьРаспоряженияНаПоступление();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРаспоряженияНаПоступление()
	
	Если Не ЗначениеЗаполнено(Склад) Тогда
		РаспоряженияНаПоступление.Очистить();
		Возврат;
	КонецЕсли;
	
	Если Не Пользователи.ЭтоПолноправныйПользователь(Неопределено) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Склады.Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Ссылка = &Склад";
		
		Запрос.УстановитьПараметр("Склад", Склад);
		
		Если Запрос.Выполнить().Пустой() Тогда
			РаспоряженияНаПоступление.Очистить();
			Возврат;
		КонецЕсли;
		
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОприходованиеИзлишковТоваров)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.СписаниеНедостачТоваров)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ПересортицаТоваров)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ПорчаТоваров)
	|			ТОГДА ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор
	|		ИНАЧЕ ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор.Основание
	|	КОНЕЦ КАК Распоряжение,
	|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Характеристика КАК Характеристика,
	|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Склад КАК Склад,
	|	СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовПриход) КАК КОформлениюАктовПриход,
	|	СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовРасход) КАК КОформлениюАктовРасход,
	|	-1 * (СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовПриход) - СУММА(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.КОформлениюАктовРасход)) КАК КОформлениюОрдеров,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция
	|ПОМЕСТИТЬ ВременнаяТаблица
	|ИЗ
	|	РегистрНакопления.ТоварыКОформлениюИзлишковНедостач.ОстаткиИОбороты(&ДатаНачала, &ДатаОкончания, Регистратор, , Склад = &Склад) КАК ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Склад)
	|ГДЕ
	|	(ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОприходованиеИзлишковТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.СписаниеНедостачТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ПересортицаТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ПорчаТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОрдерНаОтражениеИзлишковТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОрдерНаОтражениеНедостачТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОрдерНаОтражениеПересортицыТоваров)
	|			ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОрдерНаОтражениеПорчиТоваров))
	|	И ВЫБОР
	|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток В (&РабочиеУчастки)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Номенклатура,
	|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Характеристика,
	|	ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Склад,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ОприходованиеИзлишковТоваров)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.СписаниеНедостачТоваров)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ПересортицаТоваров)
	|				ИЛИ ТИПЗНАЧЕНИЯ(ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор) = ТИП(Документ.ПорчаТоваров)
	|			ТОГДА ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор
	|		ИНАЧЕ ТоварыКОформлениюИзлишковНедостачОстаткиИОбороты.Регистратор.Основание
	|	КОНЕЦ,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременнаяТаблица.Распоряжение.Дата КАК Дата,
	|	ВременнаяТаблица.Распоряжение.Номер КАК Номер,
	|	ТИПЗНАЧЕНИЯ(ВременнаяТаблица.Распоряжение) КАК ТипДокумента,
	|	ВременнаяТаблица.Распоряжение КАК Распоряжение,
	|	ВременнаяТаблица.Секция КАК РабочийУчасток,
	|	ВременнаяТаблица.Склад КАК Склад,
	|	ВЫБОР
	|		КОГДА СУММА(ВременнаяТаблица.КОформлениюОрдеров) > 0
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ОрдерНеСоздан
	|ИЗ
	|	ВременнаяТаблица КАК ВременнаяТаблица
	|
	|СГРУППИРОВАТЬ ПО
	|	ВременнаяТаблица.Распоряжение,
	|	ВременнаяТаблица.Секция,
	|	ВременнаяТаблица.Склад,
	|	ВременнаяТаблица.Распоряжение.Дата,
	|	ВременнаяТаблица.Распоряжение.Номер,
	|	ТИПЗНАЧЕНИЯ(ВременнаяТаблица.Распоряжение)";
	
	
	Запрос.УстановитьПараметр("РабочиеУчастки", РабочиеУчастки.ВыгрузитьЗначения());
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Если ЗначениеЗаполнено(ДатаПоступления) Тогда
		Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ДатаПоступления.ДатаОкончания)); 
		Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ДатаПоступления.ДатаНачала)); 
	Иначе
		Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ТекущаяДата())); 
	    Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ТекущаяДата())); 
	КонецЕсли;
			
	РаспоряженияНаПоступление.Загрузить(Запрос.Выполнить().Выгрузить());
		
КонецПроцедуры

#Область ШтрихкодыИТорговоеОборудование

&НаКлиенте
Функция СсылкаНаЭлементСпискаПоШтрихкоду(Штрихкод)
	
	Менеджеры = Новый Массив();
	Менеджеры.Добавить(ПредопределенноеЗначение("Документ.ОтборРазмещениеТоваров.ПустаяСсылка"));
	Возврат ШтрихкодированиеПечатныхФормКлиент.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, Менеджеры);
	
КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкоды(Данные)
	
	МассивСсылок = СсылкаНаЭлементСпискаПоШтрихкоду(Данные.Штрихкод);
	Если МассивСсылок.Количество() > 0 Тогда
		Ссылка = МассивСсылок[0];
		Элементы.ЗаданияВРаботе.ТекущаяСтрока = Ссылка;
		Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.ГруппаСтраницы.ПодчиненныеЭлементы.СтраницаРазмещение;
		ПоказатьЗначение(Неопределено, Ссылка);
	Иначе
		ШтрихкодированиеПечатныхФормКлиент.ОбъектНеНайден(Данные.Штрихкод);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

