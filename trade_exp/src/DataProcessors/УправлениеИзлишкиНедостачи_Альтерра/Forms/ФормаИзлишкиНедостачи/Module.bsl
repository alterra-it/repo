	УстановитьОтборыВЗависимыхСписках();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьОрдер(Команда)
	
	ОчиститьСообщения();
	ТекущиеДанные = Элементы.РаспоряженияНаПоступление.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено Тогда

		ЗаполнитьТовары(Ложь,ТекущиеДанные.Распоряжение);

		Основание = Новый Структура;
		Основание.Вставить("Основание",               ТекущиеДанные.Распоряжение);
		Основание.Вставить("Склад",               Склад);
		Основание.Вставить("РабочийУчасток",      ТекущиеДанные.РабочийУчасток);
		Основание.Вставить("Товары", Товары);
		
		Если ТекущиеДанные.ТипДокумента = "Оприходование излишков товаров" Тогда
			ОткрытьФорму("Документ.ОрдерНаОтражениеИзлишковТоваров.Форма.ФормаДокумента",
			Новый Структура("Основание",Основание));
		КонецЕсли;
		
		Если ТекущиеДанные.ТипДокумента = "Списание недостач товаров" Тогда
			ОткрытьФорму("Документ.ОрдерНаОтражениеНедостачТоваров.Форма.ФормаДокумента",
			Новый Структура("Основание",Основание));
		КонецЕсли;
		
		Если ТекущиеДанные.ТипДокумента = "Пересортица товаров" Тогда
			ОткрытьФорму("Документ.ОрдерНаОтражениеПересортицыТоваров.Форма.ФормаДокумента",
			Новый Структура("Основание",Основание));
		КонецЕсли;
		
		Если ТекущиеДанные.ТипДокумента = "Порча товаров" Тогда
			ОткрытьФорму("Документ.ОрдерНаОтражениеПорчиТоваров.Форма.ФормаДокумента",
			Новый Структура("Основание",Основание));
		КонецЕсли;
	Иначе
			
		ТекстПредупреждения = НСтр("ru = 'Выберите распоряжение на оформление ордера'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПредупреждения);
		
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьТовары()
	Возврат Товары.Выгрузить();
Конецфункции

&НаКлиенте
Процедура ОрдераВРаботеПриАктивизацииСтроки(Элемент)
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	ТекущаяСтрока = Элементы.ОрдераВРаботе.ТекущиеДанные;
	Если ТекущаяСтрока<>Неопределено Тогда
	СсылкаНаДокумент = ТекущаяСтрока.Ссылка;
	ЗаполнитьТовары(Истина,СсылкаНаДокумент);
	КонецЕсли;

КонецПроцедуры

Процедура ЗаполнитьТовары(ЭтоОрдер,СсылкаНаДокумент)
	Товары.Очистить();
	Если ЭтоОрдер Тогда
		Если СсылкаНаДокумент.Проведен Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОприходованиеИзлишковТоваровТовары.Номенклатура КАК Номенклатура,
		|	ОприходованиеИзлишковТоваровТовары.Характеристика КАК Характеристика,
		|	ОприходованиеИзлишковТоваровТовары.Ссылка.Склад КАК Склад,
		|	ОприходованиеИзлишковТоваровТовары.Количество КАК КоличествоУпаковок,
		|	NULL КАК НоменклатураОприходование,
		|	NULL КАК ХарактеристикаОприходование
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	Документ.ОрдерНаОтражениеИзлишковТоваров.Товары КАК ОприходованиеИзлишковТоваровТовары
		|ГДЕ
		|	ОприходованиеИзлишковТоваровТовары.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СписаниеНедостачТоваровТовары.Номенклатура,
		|	СписаниеНедостачТоваровТовары.Характеристика,
		|	СписаниеНедостачТоваровТовары.Ссылка.Склад,
		|	СписаниеНедостачТоваровТовары.Количество,
		|	NULL,
		|	NULL
		|ИЗ
		|	Документ.ОрдерНаОтражениеНедостачТоваров.Товары КАК СписаниеНедостачТоваровТовары
		|ГДЕ
		|	СписаниеНедостачТоваровТовары.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПересортицаТоваровТовары.Номенклатура,
		|	ПересортицаТоваровТовары.Характеристика,
		|	ПересортицаТоваровТовары.Ссылка.Склад,
		|	ПересортицаТоваровТовары.Количество,
		|	ПересортицаТоваровТовары.НоменклатураОприходование,
		|	ПересортицаТоваровТовары.ХарактеристикаОприходование
		|ИЗ
		|	Документ.ОрдерНаОтражениеПересортицыТоваров.Товары КАК ПересортицаТоваровТовары
		|ГДЕ
		|	ПересортицаТоваровТовары.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПорчаТоваровТовары.Номенклатура,
		|	ПорчаТоваровТовары.Характеристика,
		|	ПорчаТоваровТовары.Ссылка.Склад,
		|	ПорчаТоваровТовары.Количество,
		|	ПорчаТоваровТовары.НоменклатураОприходование,
		|	ПорчаТоваровТовары.ХарактеристикаОприходование
		|ИЗ
		|	Документ.ОрдерНаОтражениеПорчиТоваров.Товары КАК ПорчаТоваровТовары
		|ГДЕ
		|	ПорчаТоваровТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Товары.Номенклатура КАК Номенклатура,
		|	ВТ_Товары.Характеристика КАК Характеристика,
		|	ВТ_Товары.Склад КАК Склад,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	ВТ_Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВТ_Товары.НоменклатураОприходование КАК НоменклатураОприходование,
		|	ВТ_Товары.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.Ячейка КАК ЯчейкаОприходование
		|ИЗ
		|	ВТ_Товары КАК ВТ_Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование
		|		ПО ВТ_Товары.НоменклатураОприходование = РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.Номенклатура
		|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.Склад
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.ОсновнаяЯчейка = ИСТИНА)";
		
		Запрос.УстановитьПараметр("Ссылка",СсылкаНаДокумент);
		Товары.Загрузить(Запрос.Выполнить().Выгрузить());
		КонецЕсли;
	Иначе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОприходованиеИзлишковТоваровТовары.Номенклатура КАК Номенклатура,
		|	ОприходованиеИзлишковТоваровТовары.Характеристика КАК Характеристика,
		|	ОприходованиеИзлишковТоваровТовары.Ссылка.Склад КАК Склад,
		|	ОприходованиеИзлишковТоваровТовары.Количество КАК КоличествоУпаковок,
		|	NULL КАК НоменклатураОприходование,
		|	NULL КАК ХарактеристикаОприходование
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	Документ.ОприходованиеИзлишковТоваров.Товары КАК ОприходованиеИзлишковТоваровТовары
		|ГДЕ
		|	ОприходованиеИзлишковТоваровТовары.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СписаниеНедостачТоваровТовары.Номенклатура,
		|	СписаниеНедостачТоваровТовары.Характеристика,
		|	СписаниеНедостачТоваровТовары.Ссылка.Склад,
		|	СписаниеНедостачТоваровТовары.Количество,
		|	NULL,
		|	NULL
		|ИЗ
		|	Документ.СписаниеНедостачТоваров.Товары КАК СписаниеНедостачТоваровТовары
		|ГДЕ
		|	СписаниеНедостачТоваровТовары.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПересортицаТоваровТовары.Номенклатура,
		|	ПересортицаТоваровТовары.Характеристика,
		|	ПересортицаТоваровТовары.Ссылка.Склад,
		|	ПересортицаТоваровТовары.Количество,
		|	ПересортицаТоваровТовары.НоменклатураОприходование,
		|	ПересортицаТоваровТовары.ХарактеристикаОприходование
		|ИЗ
		|	Документ.ПересортицаТоваров.Товары КАК ПересортицаТоваровТовары
		|ГДЕ
		|	ПересортицаТоваровТовары.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПорчаТоваровТовары.Номенклатура,
		|	ПорчаТоваровТовары.Характеристика,
		|	ПорчаТоваровТовары.Ссылка.Склад,
		|	ПорчаТоваровТовары.Количество,
		|	ПорчаТоваровТовары.НоменклатураОприходование,
		|	ПорчаТоваровТовары.ХарактеристикаОприходование
		|ИЗ
		|	Документ.ПорчаТоваров.Товары КАК ПорчаТоваровТовары
		|ГДЕ
		|	ПорчаТоваровТовары.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Товары.Номенклатура КАК Номенклатура,
		|	ВТ_Товары.Характеристика КАК Характеристика,
		|	ВТ_Товары.Склад КАК Склад,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	ВТ_Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВТ_Товары.НоменклатураОприходование КАК НоменклатураОприходование,
		|	ВТ_Товары.ХарактеристикаОприходование КАК ХарактеристикаОприходование,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.Ячейка КАК ЯчейкаОприходование
		|ИЗ
		|	ВТ_Товары КАК ВТ_Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование
		|		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.Номенклатура
		|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.Склад
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкамОприходование.ОсновнаяЯчейка = ИСТИНА)
		|ГДЕ
		|	ВЫБОР
		|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
		|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочиеУчастки
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
		
		Запрос.УстановитьПараметр("Ссылка",СсылкаНаДокумент);
		Запрос.УстановитьПараметр("РабочиеУчастки",ТекущийРабочийУчасток);
		Товары.Загрузить(Запрос.Выполнить().Выгрузить());
	КонецЕсли;
	
	Элементы.ТоварыГруппаОприходвание.Видимость = ?(ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПересортицаТоваров") ИЛИ
		ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ПорчаТоваров") ИЛИ 
		ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ОрдерНаОтражениеПересортицыТоваров")  
		ИЛИ ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.ОрдерНаОтражениеПорчиТоваров"),Истина,Ложь);
		
	КонецПроцедуры

&НаКлиенте
Процедура ОтображатьТоварыПриИзменении(Элемент)
	Элементы.Группа4.Видимость = ОтображатьТовары;
КонецПроцедуры

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	Список = Элементы.ОрдераВРаботе;

	ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Список);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат)
	Список = Элементы.ОрдераВРаботе;
	
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Список, Результат);
КонецПроцедуры

