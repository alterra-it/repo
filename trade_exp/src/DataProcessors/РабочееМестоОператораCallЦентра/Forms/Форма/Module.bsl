Процедура МестоОплатыМинимальнаяСуммаПриИзменении(Элемент)
	Примечание = "Фильтр: "+Строка(МестоОплаты)+ " Сумма больше "+ Строка(МинимальнаяСумма);
КонецПроцедуры

&НаСервере
Процедура СформироватьСписокКачестваРаботыКЦНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
		|ПОМЕСТИТЬ ВТЧерныйСписок
		|ИЗ
		|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеЗвонков.Контрагент КАК Клиент
		|ПОМЕСТИТЬ ВТ_Исключения
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|ГДЕ
		|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
		|	И ДанныеЗвонков.ДатаСобытия > &ДатаСобытия
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ОбращениеКлиента.Клиент
		|ИЗ
		|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|ГДЕ
		|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
		|	И ОбращениеКлиента.Дата > &ДатаСобытия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Максимум(ДанныеЗвонков.ДатаСобытия) КАК ДатаСобытия,
		|	ДанныеЗвонков.Контрагент КАК Контрагент
		|Поместить ВТ_Клиенты
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК СпрПартнеры
		|		ПО (ДанныеЗвонков.Контрагент = СпрПартнеры.Ссылка)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|		ПО (ДанныеЗвонков.Контрагент = ПартнерыДополнительныеРеквизиты.Ссылка)
		|ГДЕ
		|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Входящее)
		|	И ДанныеЗвонков.ДатаСобытия > &ДатаСобытия
		|	И ДанныеЗвонков.НомерКому = &НомерКому
		|	И ДанныеЗвонков.ДлительностьРазговора МЕЖДУ 30 И 180
		|	И СпрПартнеры.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.КомпанияЧастноеЛицо.ЧастноеЛицо)
		|	И ВЫБОР
		|			КОГДА ПартнерыДополнительныеРеквизиты.Свойство.Наименование ПОДОБНО ""%Группы партнеров%""
		|				ТОГДА НЕ ПартнерыДополнительныеРеквизиты.Значение.Наименование ПОДОБНО ""%Сотрудники%""
		|		КОНЕЦ
		|	И НЕ ДанныеЗвонков.Контрагент В
		|				(ВЫБРАТЬ
		|					ВТ_Исключения.Клиент КАК Клиент
		|				ИЗ
		|					ВТ_Исключения)
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеЗвонков.Контрагент 
		|;
		|////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Клиенты.ДатаСобытия КАК ДатаСобытия,
		|	ВТ_Клиенты.Контрагент КАК ФИОКлиента,
		|	ДанныеЗвонков.НомерОтКого КАК НомерТелефона
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Клиенты КАК ВТ_Клиенты
		|		ПО (ВТ_Клиенты.ДатаСобытия = ДанныеЗвонков.ДатаСобытия)
		|			И (ВТ_Клиенты.Контрагент = ДанныеЗвонков.Контрагент) 
		|ГДЕ 
		|	НЕ ДанныеЗвонков.НомерОтКого В
		|						(ВЫБРАТЬ
		|							ВТЧерныйСписок.Номер КАК Номер
		|						ИЗ
		|							ВТЧерныйСписок)";
	
	Запрос.УстановитьПараметр("ДатаСобытия", ДобавитьМесяц(ТекущаяДата(), -3));
	Запрос.УстановитьПараметр("НомерКому", НомераКЦ);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой()Тогда
		Получить5СлучайныхЗаписей(РезультатЗапроса, ОбзвонКачестваРаботыКЦ);
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура СформироватьСписокОбзвонаРаботыКорзинки(Команда)
	СформироватьСписокОбзвонаРаботыКорзинкиНаСервере();
КонецПроцедуры

&НаСервере
Процедура СформироватьСписокОбзвонаРаботыКорзинкиНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
		|ПОМЕСТИТЬ ВТЧерныйСписок
		|ИЗ
		|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеЗвонков.Контрагент КАК Клиент
		|ПОМЕСТИТЬ ВТ_Исключения
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|ГДЕ
		|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
		|	И ДанныеЗвонков.ДатаСобытия > &Дата
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ОбращениеКлиента.Клиент
		|ИЗ
		|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|ГДЕ
		|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
		|	И ОбращениеКлиента.Дата > &Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЧекККМ.Ссылка) КАК Чек,
		|	СпрПартнеры.Ссылка КАК ФИОКлиента,
		|	МАКСИМУМ(ПартнерыКонтактнаяИнформация.НомерТелефона) КАК НомерТелефона
		|		
		|ИЗ
		|	Справочник.Партнеры КАК СпрПартнеры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
		|		ПО СпрПартнеры.Ссылка = ЧекККМ.Партнер
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|		ПО СпрПартнеры.Ссылка = ПартнерыКонтактнаяИнформация.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|		ПО СпрПартнеры.Ссылка = ПартнерыДополнительныеРеквизиты.Ссылка
		|ГДЕ
		|	ЧекККМ.Дата > &Дата
		|	и ЧекККМ.Проведен = Истина
		|	И СпрПартнеры.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.КомпанияЧастноеЛицо.ЧастноеЛицо)
		|	И ВЫБОР
		|			КОГДА ПартнерыДополнительныеРеквизиты.Свойство.Наименование ПОДОБНО ""%Группы партнеров%""
		|				ТОГДА НЕ ПартнерыДополнительныеРеквизиты.Значение.Наименование ПОДОБНО ""%Сотрудники%""
		|		КОНЕЦ
		|	И ПартнерыКонтактнаяИнформация.НомерТелефона <> """"
		|	И (ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 11
		|				И ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""89%""
		|			ИЛИ ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10
		|				И ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%"")
		|	И ЧекККМ.МестоОплаты В(&МестаОплаты)
		|	И ЧекККМ.СуммаДокумента > &МинСумма
		|	И НЕ СпрПартнеры.Ссылка В
		|				(ВЫБРАТЬ
		|					ВТ_Исключения.Клиент КАК Клиент
		|				ИЗ
		|					ВТ_Исключения)
		|	И НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
		|				(ВЫБРАТЬ
		|					ВТЧерныйСписок.Номер КАК Номер
		|				ИЗ
		|					ВТЧерныйСписок)
		|
		|СГРУППИРОВАТЬ ПО
		|	СпрПартнеры.Ссылка";

	Запрос.УстановитьПараметр("Дата",ДобавитьМесяц(ТекущаяДата(), -1)); 
	Запрос.УстановитьПараметр("МестаОплаты", МестоОплаты);
	Запрос.УстановитьПараметр("МинСумма", МинимальнаяСумма);

	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой()Тогда
		Получить5СлучайныхЗаписей(РезультатЗапроса, ОбзвонРаботыКорзинки);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ВидыОбзвоновПриИзменении(Элемент)
	ПолучитьДанныеИзХранилища(ВидыОбзвонов);
КонецПроцедуры 

&НаСервере
Функция ПолучитьДанныеИзХранилища(ВидыОбзвонов)
	//Подключаемся к хранилищу настроек
	ХранилищеСсылка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Настройки хранилища");
	Хранилище = ХранилищеСсылка.ХранилищеНастроек.Получить();
	//Скрипт - реквезит на форме, тип "Строка"
	Если ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонКачестваДоставки Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонКачестваРаботы
	ИначеЕсли ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонКачестваКрупныхПокупок
	ИначеЕсли ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонКачестваРаботыКорзинки
	ИначеЕсли ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонКачестваРаботыОператораКЦПоЗвонку
	ИначеЕсли ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонКачестваРаботыОсновногоМенеджера
	ИначеЕсли ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонПричинВозвратаТовара Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонПричинВозвратаТовара
	ИначеЕсли ВидыОбзвонов = Перечисления.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ Тогда
		Скрипт = Хранилище.ШаблонСкриптовРабочееМестоОператораCallЦентра.ОбзвонУдобстваРаботыВИМ
	КонецЕсли
			
КонецФункции

&НаСервере
Функция ПроверитьРольУправленияОценкой()
	Возврат РольДоступна("УправлениеОценкойКонтактныйЦентр") ИЛИ РольДоступна("ПолныеПрава");
КонецФункции

&НаКлиенте
Процедура ОценкаКлиентаАст(Команда)
	Если ПроверитьРольУправленияОценкой() Тогда
		ИзминениеОценки = ИзминитьОценку();
	Иначе 
		Сообщить("Не достаточно прав для управления оценкой");
		Возврат;
	КонецЕсли; 
	Если ИзминениеОценки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ИзминениеОценки = 1 Тогда
		Элементы.Декорация5.Заголовок = "Оценка включена";
	ИначеЕсли ИзминениеОценки = 0 Тогда
		Элементы.Декорация5.Заголовок = "Оценка выключена";
	КонецЕсли;
КонецПроцедуры

Функция ИзминитьОценку()
	УстановитьПривилегированныйРежим(Истина);
	
	Оценка = Константы.ОценкаКонтактногоЦентраАстериск.Получить();
	
	Включить = ?(Оценка, Ложь, Истина);
	Если НСтр(СтрокаСоединенияИнформационнойБазы(), "Ref") = "trade" Тогда
		Адрес = "192.168.8.9";
	Иначе
		Адрес = "192.168.8.250";
	КонецЕсли;	
	Порт = 8081;
	АдресРесурса = "/api/toggle-operator-mark";
	
	ЗначениеОценки = ?(Включить,"true","false");
		
	ПараметрыЗапроса = НСтр("ru = '{""enabled"": "+ ЗначениеОценки + "}'"); 
	
	Запрос = Новый HTTPЗапрос(АдресРесурса);
	Запрос.УстановитьТелоИзСтроки(ПараметрыЗапроса, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	
	HTTPСоединение = Новый HTTPСоединение(Адрес, Порт);
	Ответ = HTTPСоединение.ОтправитьДляОбработки(Запрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		JSONОтвет = Ответ.ПолучитьТелоКакСтроку(); 
		ЧтениеJSON = Новый ЧтениеJSON;
		ЧтениеJSON.УстановитьСтроку(JSONОтвет);
		Результат = ПрочитатьJSON(ЧтениеJSON); 
		Статус = Результат["status"]; 
		ЗначениеMark = Результат["enabled"];
		Если ЗначениеMark Тогда
			Сообщить("Оценка включена");
			Константы.ОценкаКонтактногоЦентраАстериск.Установить(Истина);
		Иначе
			Сообщить("Оценка выключена");
			Константы.ОценкаКонтактногоЦентраАстериск.Установить(Ложь);
		КонецЕсли;
	Иначе
		Сообщить("Ошибка HTTP: " + Ответ.КодСостояния + " - " + Ответ.ПолучитьТелоКакСтроку());
		УстановитьПривилегированныйРежим(Ложь);
		Возврат Неопределено;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	Возврат ЗначениеMark;
КонецФункции



