&НаСервере
Процедура ОчиститьОчередь(ПараметрыЗапроса)
	
	УстановитьПривилегированныйРежим(Истина);	
	
	Набор = РегистрыСведений.ОчередьЗапросовНаОбратныйЗвонок.СоздатьНаборЗаписей();
	
	Набор.Отбор.ДатаЗвонка.Установить(ПараметрыЗапроса.ДатаЗвонка);
	Набор.Отбор.НомерТелефона.Установить(ПараметрыЗапроса.НомерТелефона);
	Набор.Прочитать();
	Если Набор.Количество()>0 Тогда
		Запись = Набор[0];
		Запись.Выполнен = Истина;
		Запись.ДатаВыполнения = ТекущаяДата();
		Запись.Оператор = ТекущийСотрудник;
		Набор.Записать();
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры  

&НаКлиенте
Процедура СписокПартнеровВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущаяСтрока = Элементы.СписокПартнеров.ТекущиеДанные; 
	Если ТекущаяСтрока <> Неопределено Тогда
		ЗаполнитьПоПартнеру(ТекущаяСтрока.Партнер);   
	КонецЕсли;  
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоПартнеру(Партнер)
		
	Если ЗначениеЗаполнено(Партнер) Тогда
		
		Если БонусыАльтерра.УчаствуетПартнерВБонуснойПрограмме(Партнер) Тогда
			Баллы = БонусыАльтерра.ПолучитьИнформациюПоБаллам(ТекущаяДата(),Партнер); 
			Статус = ПолучитьСтатусПартнера(Партнер);
			ИнформацияПоБонуснойПрограмме = "Доступно баллов: " + Строка(Баллы.ДоступныеБаллы) + Символы.ПС + "Статус участника по бонусной программе: " + Статус; 
		КонецЕсли;
		
		ДокументыПродажи.Отбор.Элементы.Очистить();
		ИсторияЗвонков.Отбор.Элементы.Очистить();
		ОбращенияКлиентов.Отбор.Элементы.Очистить();
		
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДокументыПродажи, "Клиент", Партнер, ВидСравненияКомпоновкиДанных.Равно,,Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ИсторияЗвонков, "АбонентКонтакт", Партнер, ВидСравненияКомпоновкиДанных.Равно,,Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ОбращенияКлиентов, "Клиент", Партнер, ВидСравненияКомпоновкиДанных.Равно,,Истина);
				
	КонецЕсли;  
	
	УстановитьВидимостьЭлементовПоТипуПартнера(Партнер);
	УстановитьВидимостьГруппРабочейОбластиФормы(,Истина); 
		
КонецПроцедуры

