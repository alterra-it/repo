&НаКлиенте
Процедура ВидыОбзвоновОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	НомерТелефонаИсходящий = ""; 
	Партнер = ПредопределенноеЗначение("Справочник.Партнеры.ПустаяСсылка");
	Элементы.ОценкаПоЗвонку.Видимость = Истина;
	Элементы.НачислитьББЗаИдею.Видимость = Ложь;
	ОценкаПоЗвонку = "";
	Если ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваДоставки") Тогда
		УстановитьВидимостьОбзвонов(Истина);
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок") Тогда
		УстановитьВидимостьОбзвонов(,Истина);
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ") Тогда
		УстановитьВидимостьОбзвонов(,,Истина);
		ЗагрузитьДанныеДляОбзвонаУдобстваРаботыВИМ();
		Элементы.НачислитьББЗаИдею.Видимость = Истина;
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонПричинВозвратаТовара") Тогда
		УстановитьВидимостьОбзвонов(,,,Истина);
		Элементы.ОценкаПоЗвонку.Видимость = Ложь;
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку") Тогда    //обзвон качества работы КЦ
		УстановитьВидимостьОбзвонов(,,,,Истина);
		Элементы.НомераКЦ.СписокВыбора.ЗагрузитьЗначения(ПолучитьВнутренниеНомера());
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки") Тогда
		УстановитьВидимостьОбзвонов(,,,,,Истина);
		//Элементы.МестоОплаты.СписокВыбора.ЗагрузитьЗначения(ПолучитьМестаОплаты());
	ИначеЕсли ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера") Тогда	
		УстановитьВидимостьОбзвонов(,,,,,,Истина);
		ЗагрузитьДанныеДляОбзвонаОценкиКачестваРаботыОсновногоМенеджера();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьОбзвонов(Гр0=Ложь,Гр1=Ложь,Гр2=Ложь,Гр3=Ложь,Гр4=Ложь,Гр5=Ложь,Гр6=Ложь)
		
	Элементы.ОбластьИсходящие.Видимость = Гр0;
	Элементы.ОбластьКачестваКрупныхПокупок.Видимость = Гр1;
	Элементы.ОбластьОбзвонКачестваРаботыВИМ.Видимость = Гр2;
	Элементы.ОбластьПричиныВозвратаТовара.Видимость = Гр3;
	Элементы.ОбластьОбзвонКачестваРаботыКЦ.Видимость = Гр4;
	Элементы.ОбластьОбзвонРаботыКорзинки.Видимость = Гр5;
	Элементы.ОбластьОбзвонКачестваРаботыОсновногоМенеджера.Видимость = Гр6;

КонецПроцедуры

&НаСервере
Функция Получить5СлучайныхЗаписей(РезультатЗапроса, ТаблицаЗначений)

	ВыборкаТЗ = РезультатЗапроса.Выгрузить();
	ТаблицаЗначений.Очистить();
	КоличествоЗаписей = ВыборкаТЗ.Количество();
	Генератор = Новый ГенераторСлучайныхЧисел();
	
	МассивЗначений = Новый Массив;
	
	Если ВыборкаТЗ.Количество()>5 Тогда 
		Пока МассивЗначений.Количество()<5 Цикл
			Инд = Генератор.СлучайноеЧисло(0, КоличествоЗаписей - 1);
			Если МассивЗначений.Найти(Инд) = Неопределено Тогда
				МассивЗначений.Добавить(Инд);
				СтрокаТЗ = ТаблицаЗначений.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТЗ, ВыборкаТЗ[инд]);
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ТаблицаЗначений.Загрузить(ВыборкаТЗ);
	КонецЕсли;

КонецФункции 

&НаСервере
Процедура ЗагрузитьДанныеДляОбзвонаКачестваКрупныхПокупок()
	
	ОбзвонКачестваКрупныхПокупок.Очистить();
	ВидЖалобы = Новый Массив;
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000003"));
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000002"));
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000001"));
	
	Доставка = Новый Массив;
	Доставка.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Услуги доставки", Истина));
	Доставка.Добавить(Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Услуги 1СК", Истина));

	Если СпособПолучения = "Самовывоз" Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
			|ПОМЕСТИТЬ ВТЧерныйСписок
			|ИЗ
			|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ДанныеЗвонков.Контрагент КАК Клиент
			|ПОМЕСТИТЬ ВТ_Исключения
			|ИЗ
			|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
			|ГДЕ
			|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
			|	И ДанныеЗвонков.ДатаСобытия > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
			|
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ
			|	ОбращениеКлиента.Клиент
			|ИЗ
			|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
			|ГДЕ
			|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
			|	И ОбращениеКлиента.ВидЖалобы В(&ВидЖалобы)
			|	И ОбращениеКлиента.Дата > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	РеализацияТоваровУслугТовары.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТДокументыСДоставкой
			|ИЗ
			|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
			|		ПО (ВидыНоменклатуры.Ссылка = РеализацияТоваровУслугТовары.Номенклатура.ВидНоменклатуры)
			|ГДЕ
			|	ВидыНоменклатуры.Ссылка В(&Доставка)
			|	И РеализацияТоваровУслугТовары.Ссылка.Дата >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -30)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ЧекККМТовары.Ссылка
			|ИЗ
			|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
			|		ПО ЧекККМТовары.Номенклатура.ВидНоменклатуры = ВидыНоменклатуры.Ссылка
			|ГДЕ
