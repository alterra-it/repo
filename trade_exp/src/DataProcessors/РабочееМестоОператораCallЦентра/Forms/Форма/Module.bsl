#Область ОбработчикиСобытийФормы   

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Если Параметры.Свойство("ДанныеЗвонка") Тогда 
		ДатаНачалаЗвонка = ТекущаяДата(); 
		ИдентификаторЗвонкаВАТС = Параметры.ДанныеЗвонка.ИдентификаторЗвонкаВАТС; 
		НомерТелефонаВходящий = Параметры.ДанныеЗвонка.НомерТелефонаАбонента;
		ЗаполнитьГруппуВходящие(НомерТелефонаВходящий);	
	Иначе
		УстановитьВидимостьГруппРабочейОбластиФормы(Истина);
	КонецЕсли;
	
	ТекущийСотрудник = Пользователи.ТекущийПользователь();
	Элементы.НачислитьББЗаИдею.Видимость = Ложь;
		
	ВнутреннийНомер = ТелефонияСервер.ВнутреннийНомерПользователя();
	
	ПриИзмененииОтбораМоиЗаказы();

	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Заказы, "Состояние",Перечисления.СостоянияЗаказовКлиентов.Закрыт,Истина);
    ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ДокументыПродажи,"Номер",Номер,Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Партнеры, "ТелефонПартнера",Справочники.ВидыКонтактнойИнформации.ТелефонПартнера,Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Партнеры, "ПочтаПартнера",Справочники.ВидыКонтактнойИнформации.EmailПартнера,Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДокументыПродажи, "ТипДокумента","1",ВидСравненияКомпоновкиДанных.Равно,Истина);

	УстановитьВидимостьКомандФормы();
 
	ЗаполнитьНастройкиХранилища();
		
КонецПроцедуры

