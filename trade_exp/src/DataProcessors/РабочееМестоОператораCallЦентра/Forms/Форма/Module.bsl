			|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ЧекККМТовары
			|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
			|				ПО (ВидыНоменклатуры.Ссылка = ЧекККМТовары.Номенклатура.ВидНоменклатуры)
			|			ПО (ЧекККМТовары.Ссылка = ЧекККМ.Ссылка)
			|				И (ЧекККМ.Магазин.ФорматПодразделения В (&ФорматПодразделения))
			|				И (ЧекККМ.СуммаДокумента >= &СуммаДокумента)
			|				И (ЧекККМ.Дата >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -30))
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
			|			ПО (ДанныеОбзвонов.ОбъектОбзвона = ЧекККМ.Ссылка)
			|				И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)
			|		ПО Партнеры.Ссылка = ЧекККМ.Партнер
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
			|		ПО (ПартнерыДополнительныеРеквизиты.Ссылка = Партнеры.Ссылка)
			|			И (ВЫБОР
			|				КОГДА ПартнерыДополнительныеРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
			|					ТОГДА ПартнерыДополнительныеРеквизиты.Значение.Наименование = ""Частные лица""
			|			КОНЕЦ)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|		ПО (ПартнерыКонтактнаяИнформация.Ссылка = Партнеры.Ссылка)
			|			И (Партнеры.ЮрФизЛицо = &ЮрФизЛицо)
			|			И (ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%"")
			|			И (ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10)
			|ГДЕ
			|	НЕ Партнеры.Ссылка В
			|				(ВЫБРАТЬ
			|					ВТ_Исключения.Клиент КАК Клиент
			|				ИЗ
			|					ВТ_Исключения)
			|	И ВидыНоменклатуры.Ссылка В(&Доставка)
			|	И НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
			|				(ВЫБРАТЬ
			|					ВТЧерныйСписок.Номер КАК Номер
			|				ИЗ
			|					ВТЧерныйСписок)
			|
			|СГРУППИРОВАТЬ ПО
			|	Партнеры.Ссылка,
			|	ДанныеОбзвонов.Оценка,
			|	ДанныеОбзвонов.Комментарий
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	Партнеры.Ссылка,
			|	МАКСИМУМ(ПартнерыКонтактнаяИнформация.НомерТелефона),
			|	МАКСИМУМ(РеализацияТоваровУслуг.Ссылка),
			|	ДанныеОбзвонов.Оценка,
			|	ДанныеОбзвонов.Комментарий
			|ИЗ
			|	Справочник.Партнеры КАК Партнеры
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
			|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
			|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыНоменклатуры КАК ВидыНоменклатуры
			|				ПО (ВидыНоменклатуры.Ссылка = РеализацияТоваровУслугТовары.Номенклатура.ВидНоменклатуры)
			|			ПО (РеализацияТоваровУслугТовары.Ссылка = РеализацияТоваровУслуг.Ссылка
			|				И РеализацияТоваровУслуг.Магазин.ФорматПодразделения В(&ФорматПодразделения)
			|				И РеализацияТоваровУслуг.СуммаДокумента >= &СуммаДокумента
			|				И РеализацияТоваровУслуг.Дата >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -30))
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
			|			ПО (ДанныеОбзвонов.ОбъектОбзвона = РеализацияТоваровУслуг.Ссылка)
			|				И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)
			|		ПО Партнеры.Ссылка = РеализацияТоваровУслуг.Партнер
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
			|		ПО (ПартнерыДополнительныеРеквизиты.Ссылка = Партнеры.Ссылка
			|			И ВЫБОР
			|					КОГДА ПартнерыДополнительныеРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
			|						ТОГДА ПартнерыДополнительныеРеквизиты.Значение.Наименование = ""Частные лица""
			|				КОНЕЦ)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|		ПО (ПартнерыКонтактнаяИнформация.Ссылка = Партнеры.Ссылка
			|			И Партнеры.ЮрФизЛицо = &ЮрФизЛицо   
			|			И ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%""
			|			И ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10)
			|ГДЕ
			|	НЕ Партнеры.Ссылка В
			|				(ВЫБРАТЬ
			|					ВТ_Исключения.Клиент КАК Клиент
			|				ИЗ
			|					ВТ_Исключения)
			|	И ВидыНоменклатуры.Ссылка В(&Доставка)
			|	И НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
			|				(ВЫБРАТЬ
			|					ВТЧерныйСписок.Номер КАК Номер
			|				ИЗ
			|					ВТЧерныйСписок) 
			|
			|СГРУППИРОВАТЬ ПО
			|	Партнеры.Ссылка,
			|	ДанныеОбзвонов.Оценка,
			|	ДанныеОбзвонов.Комментарий";
		
		Запрос.УстановитьПараметр("ВидЖалобы", ВидЖалобы);
		Запрос.УстановитьПараметр("Доставка", Доставка);
		Запрос.УстановитьПараметр("СуммаДокумента", СуммаДокумента);
		Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДата()));
		Запрос.УстановитьПараметр("ФорматПодразделения", ФорматПодразделения);
		Запрос.УстановитьПараметр("ЮрФизЛицо", Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо);
		Запрос.УстановитьПараметр("ВидОбзвона", Перечисления.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок);
		
		РезультатЗапроса = Запрос.Выполнить();

	КонецЕсли;

	Если Не РезультатЗапроса.Пустой() Тогда
		Получить5СлучайныхЗаписей(РезультатЗапроса, ОбзвонКачестваКрупныхПокупок);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗагрузитьДанныеДляОбзвонаПричинВозврата()

	ОбзвонПричинВозвратаТовара.Очистить();
	ВидЖалобы = Новый Массив;
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000003"));
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000002"));
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000001"));
	
	ПричинаВозврата = Новый Массив;
	ПричинаВозврата.Добавить(Справочники.ПричиныВозвратаТоваровДляОрганизации.НайтиПоКоду("000000027"));
	ПричинаВозврата.Добавить(Справочники.ПричиныВозвратаТоваровДляОрганизации.НайтиПоКоду("000000028"));
	ПричинаВозврата.Добавить(Справочники.ПричиныВозвратаТоваровДляОрганизации.НайтиПоКоду("000000035"));
	ПричинаВозврата.Добавить(Справочники.ПричиныВозвратаТоваровДляОрганизации.НайтиПоКоду("000000012"));
	ПричинаВозврата.Добавить(Справочники.ПричиныВозвратаТоваровДляОрганизации.НайтиПоКоду("000000032"));
	ПричинаВозврата.Добавить(Справочники.ПричиныВозвратаТоваровДляОрганизации.НайтиПоКоду("000000033"));
	
	Если ВидКлиентаВозвратТоваров = "Частное лицо" Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
			|ПОМЕСТИТЬ ВТЧерныйСписок
			|ИЗ
			|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ДанныеЗвонков.Контрагент КАК Клиент
			|ПОМЕСТИТЬ ВТ_Исключения
			|ИЗ
			|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
			|ГДЕ
			|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
			|	И ДанныеЗвонков.ДатаСобытия > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ
			|	ОбращениеКлиента.Клиент
			|ИЗ
			|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
			|ГДЕ
			|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
			|	И ОбращениеКлиента.ВидЖалобы В(&ВидЖалобы)
			|	И ОбращениеКлиента.Дата > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Партнеры.Ссылка КАК ФИОКлиента,
			|	ПартнерыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона,
			|	ВозвратТоваровОтКлиента.Ссылка КАК ДокументВозврата,
			|	ДанныеОбзвонов.Оценка КАК ОценкаПоЗвонку,
			|	ДанныеОбзвонов.Комментарий КАК Комментарий
			|ИЗ
			|	Справочник.Партнеры КАК Партнеры
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
			|		ПО (ПартнерыДополнительныеРеквизиты.Ссылка = Партнеры.Ссылка
			|			И ВЫБОР
			|					КОГДА ПартнерыДополнительныеРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
			|						ТОГДА ПартнерыДополнительныеРеквизиты.Значение.Наименование = ""Частные лица""
			|				КОНЕЦ)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|		ПО (ПартнерыКонтактнаяИнформация.Ссылка = Партнеры.Ссылка                                          
			|			И Партнеры.Ссылка.ЮрФизЛицо = &ЮрФизЛицо
			|			И НЕ ПартнерыКонтактнаяИнформация.НомерТелефона = """"
			|			И ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%""
			|			И ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваровОтКлиента
			|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
			|				ПО (ДанныеОбзвонов.ОбъектОбзвона = ВозвратТоваровОтКлиента.Ссылка)
			|					И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)
			|		ПО (ВозвратТоваровОтКлиента.Партнер = Партнеры.Ссылка 
			|			И ВозвратТоваровОтКлиента.Дата >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -30)
			|			И ВозвратТоваровОтКлиента.ПричинаДляОрганизацииСпр В(&ПричинаВозврата))
			|ГДЕ
			|	НЕ Партнеры.Ссылка В
			|				(ВЫБРАТЬ
			|					ВТ_Исключения.Клиент КАК Клиент
			|				ИЗ
			|					ВТ_Исключения)
			|	И НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
			|				(ВЫБРАТЬ
			|					ВТЧерныйСписок.Номер КАК Номер
			|				ИЗ
			|					ВТЧерныйСписок)";
		
		Запрос.УстановитьПараметр("ВидЖалобы", ВидЖалобы);
		Запрос.УстановитьПараметр("ПричинаВозврата", ПричинаВозврата);
		Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДата()));
		Запрос.УстановитьПараметр("ЮрФизЛицо", Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо);
		Запрос.УстановитьПараметр("ВидОбзвона", Перечисления.ВидыОбзвонов.ОбзвонПричинВозвратаТовара);

		РезультатЗапроса = Запрос.Выполнить();
	Иначе

		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
			|ПОМЕСТИТЬ ВТЧерныйСписок
			|ИЗ
			|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ДанныеЗвонков.Контрагент КАК Клиент
			|ПОМЕСТИТЬ ВТ_Исключения
			|ИЗ
			|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
			|ГДЕ
			|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
			|	И ДанныеЗвонков.ДатаСобытия > &ТекущаяДата
			|
			|ОБЪЕДИНИТЬ
			|
			|ВЫБРАТЬ
			|	ОбращениеКлиента.Клиент
			|ИЗ
			|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
			|ГДЕ
			|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
			|	И ОбращениеКлиента.ВидЖалобы В (&ВидЖалобы)
			|	И ОбращениеКлиента.Дата > &ТекущаяДата
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	пользователи.Ссылка КАК Пользователь
			|ПОМЕСТИТЬ ВТПользователи
			|ИЗ
			|	Справочник.Пользователи КАК пользователи
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
			|		ПО (ДополнительныеСведения.Объект = пользователи.Ссылка
			|			И &УсловияДляОтделов)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Партнеры.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТПартнеры
			|ИЗ
			|	Справочник.Партнеры КАК Партнеры
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты КАК ВыручкаИСебестоимостьПродажОбороты
			|		ПО Партнеры.Ссылка = ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаПоПартнерам.Партнер
			|			И &Выручка
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПользователи КАК ВТПользователи
			|		ПО (ВТПользователи.Пользователь = Партнеры.ОсновнойМенеджер)
			|ГДЕ
			|	НЕ Партнеры.Ссылка В
			|				(ВЫБРАТЬ
			|					ВТ_Исключения.Клиент КАК Клиент
			|				ИЗ
			|					ВТ_Исключения)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Партнеры.Ссылка КАК ФИОКлиента,
			|	МАКСИМУМ(ПартнерыКонтактнаяИнформация.НомерТелефона) КАК НомерТелефона,
			|	МАКСИМУМ(ВозвратТоваровОтКлиента.Ссылка) КАК ДокументВозврата,
			|	ДанныеОбзвонов.Оценка КАК ОценкаПоЗвонку,
			|	ДанныеОбзвонов.Комментарий КАК Комментарий
			|ИЗ
			|	ВТПартнеры КАК Партнеры
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|		ПО (ПартнерыКонтактнаяИнформация.Ссылка = Партнеры.Ссылка)
			|			И (НЕ ПартнерыКонтактнаяИнформация.НомерТелефона = """")
			|			И (ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%"")
			|			И (ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10)
			|			И (НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
			|						(ВЫБРАТЬ
			|							ВТЧерныйСписок.Номер КАК Номер
			|						ИЗ
			|							ВТЧерныйСписок))
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваровОтКлиента
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
			|			ПО (ДанныеОбзвонов.ОбъектОбзвона = ВозвратТоваровОтКлиента.Ссылка)
			|				И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)
			|		ПО (ВозвратТоваровОтКлиента.Партнер = Партнеры.Ссылка)
			|			И (ВозвратТоваровОтКлиента.Дата >= &ТекущаяДата)
			|			И (ВозвратТоваровОтКлиента.ПричинаДляОрганизацииСпр В (&ПричинаВозврата))
			|
			|СГРУППИРОВАТЬ ПО
			|	Партнеры.Ссылка,
			|	ДанныеОбзвонов.Оценка,
			|	ДанныеОбзвонов.Комментарий
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	Партнеры.Ссылка,
			|	МАКСИМУМ(ПартнерыКонтактнаяИнформация.НомерТелефона),
			|	МАКСИМУМ(КорректировкаРеализации.Ссылка),
			|	ДанныеОбзвонов.Оценка,
			|	ДанныеОбзвонов.Комментарий
			|ИЗ
			|	ВТПартнеры КАК Партнеры
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
			|		ПО (ПартнерыКонтактнаяИнформация.Ссылка = Партнеры.Ссылка)
			|			И (НЕ ПартнерыКонтактнаяИнформация.НомерТелефона = """")
			|			И (ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%"")
			|			И (ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10)
			|			И (НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
			|						(ВЫБРАТЬ
			|							ВТЧерныйСписок.Номер КАК Номер
			|						ИЗ
			|							ВТЧерныйСписок))
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КорректировкаРеализации КАК КорректировкаРеализации
			|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
			|			ПО (ДанныеОбзвонов.ОбъектОбзвона = КорректировкаРеализации.Ссылка)
			|				И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)
			|		ПО (КорректировкаРеализации.Партнер = Партнеры.Ссылка)
			|			И (КорректировкаРеализации.Дата >= &ТекущаяДата)
			|
			|СГРУППИРОВАТЬ ПО
			|	Партнеры.Ссылка,
			|	ДанныеОбзвонов.Оценка,
			|	ДанныеОбзвонов.Комментарий";

		Если ВидКлиентаВозвратТоваров = "КО" Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловияДляОтделов", "ДополнительныеСведения.Значение.Наименование = ""Коммерческий отдел""");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Выручка", "ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот >= 150000
													 |			 И ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот <= 1000000");
			
		ИначеЕсли ВидКлиентаВозвратТоваров = "ОД" ТОгда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловияДляОтделов", "ДополнительныеСведения.Значение.Наименование = ""Отдел дистрибуции""");
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Выручка", "ИСТИНА");
		КонецЕсли;
		
		Запрос.УстановитьПараметр("ВидЖалобы", ВидЖалобы);
		Запрос.УстановитьПараметр("ПричинаВозврата", ПричинаВозврата);
		Запрос.УстановитьПараметр("ТекущаяДата", ДобавитьМесяц(ТекущаяДата(), -1));
		Запрос.УстановитьПараметр("ВидОбзвона", Перечисления.ВидыОбзвонов.ОбзвонПричинВозвратаТовара);
		
		РезультатЗапроса = Запрос.Выполнить();
	КонецЕсли;
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Получить5СлучайныхЗаписей(РезультатЗапроса, ОбзвонПричинВозвратаТовара);	
	КонецЕсли;
КонецПроцедуры 

&НаСервере
Процедура ЗагрузитьДанныеДляОбзвонаУдобстваРаботыВИМ()

	ОбзвонУдобстваРаботыВИМ.Очистить();
	ВидЖалобы = Новый Массив;
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000003"));
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000002"));
	ВидЖалобы.Добавить(Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000001"));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
		|ПОМЕСТИТЬ ВТЧерныйСписок
		|ИЗ
		|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеЗвонков.Контрагент КАК Клиент
		|ПОМЕСТИТЬ ВТ_Исключения
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|ГДЕ
		|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
		|	И ДанныеЗвонков.ДатаСобытия > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ОбращениеКлиента.Клиент
		|ИЗ
		|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|ГДЕ
		|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
		|	И ОбращениеКлиента.ВидЖалобы В(&ВидЖалобы)
		|	И ОбращениеКлиента.Дата > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаказКлиента.Партнер КАК ФИОКлиента,
		|	МАКСИМУМ(ПартнерыКонтактнаяИнформация.НомерТелефона) КАК НомерТелефона,
		|	МАКСИМУМ(ЗаказКлиента.Ссылка) КАК ЗаказКлиента,
		|	ДанныеОбзвонов.Оценка КАК ОценкаПоЗвонку,
		|	ДанныеОбзвонов.Комментарий КАК Комментарий
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|			ПО (ПартнерыДополнительныеРеквизиты.Ссылка = ПартнерыКонтактнаяИнформация.Ссылка)
		|				И (НЕ(ПартнерыДополнительныеРеквизиты.Свойство.Имя = ""ГруппыПартнеров""
		|						И ПартнерыДополнительныеРеквизиты.Значение.Наименование = ""Сотрудники""))
		|				И (НЕ ПартнерыДополнительныеРеквизиты.Ссылка.ПометкаУдаления)
		|		ПО ЗаказКлиента.Партнер = ПартнерыКонтактнаяИнформация.Ссылка
		|			И (НЕ ПартнерыКонтактнаяИнформация.НомерТелефона = """")
		|			И (ПартнерыКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%"")
		|			И (ДЛИНАСТРОКИ(ПартнерыКонтактнаяИнформация.НомерТелефона) = 10)
		|			И (ЗаказКлиента.ССайта)
		|			И (ЗаказКлиента.Дата >= ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -30))
		|			И (ЗаказКлиента.Партнер.ЮрФизЛицо = &ЮрФизЛицо)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
		|		ПО (ДанныеОбзвонов.ОбъектОбзвона = ЗаказКлиента.Ссылка)
		|			И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)
		|ГДЕ
		|	НЕ ЗаказКлиента.Партнер В
		|				(ВЫБРАТЬ
		|					ВТ_Исключения.Клиент КАК Клиент
		|				ИЗ
		|					ВТ_Исключения)
		|	И НЕ ПартнерыКонтактнаяИнформация.НомерТелефона В
		|				(ВЫБРАТЬ
		|					ВТЧерныйСписок.Номер КАК Номер
		|				ИЗ
		|					ВТЧерныйСписок)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказКлиента.Партнер,
		|	ДанныеОбзвонов.Оценка,
		|	ДанныеОбзвонов.Комментарий";
	
	Запрос.УстановитьПараметр("ВидЖалобы", ВидЖалобы);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ЮрФизЛицо", Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо);
	Запрос.УстановитьПараметр("ВидОбзвона", Перечисления.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Получить5СлучайныхЗаписей(РезультатЗапроса, ОбзвонУдобстваРаботыВИМ);
	КонецЕсли;

КонецПроцедуры 

