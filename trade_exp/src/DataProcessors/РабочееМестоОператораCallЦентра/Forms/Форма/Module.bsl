	КомОтделСписок.Добавить(Справочники.Пользователи.НайтиПоНаименованию("Коммерческий отдел Майма", Истина));
	КомОтделСписок.Добавить(Справочники.Пользователи.НайтиПоНаименованию("Коммерческий отдел ЦБ", Истина));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧерныйСписокКонтактов.КонтактныеДанные КАК Номер
		|ПОМЕСТИТЬ ВТЧерныйСписок
		|ИЗ
		|	РегистрСведений.ЧерныйСписокКонтактов КАК ЧерныйСписокКонтактов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеЗвонков.Контрагент КАК Клиент
		|ПОМЕСТИТЬ ВТ_Исключения
		|ИЗ
		|	РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
		|ГДЕ
		|	ДанныеЗвонков.ВходящееИсходящее = ЗНАЧЕНИЕ(Перечисление.ВходящееИсходящееСобытие.Исходящее)
		|	И ДанныеЗвонков.ДатаСобытия > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	ОбращениеКлиента.Клиент
		|ИЗ
		|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|ГДЕ
		|	ОбращениеКлиента.ВидОбращения = ЗНАЧЕНИЕ(Перечисление.ВидыОбращений.Жалоба)
		|	И ОбращениеКлиента.ВидЖалобы В(&ВидЖалобы)
		|	И ОбращениеКлиента.Дата > ДОБАВИТЬКДАТЕ(&ТекущаяДата, ДЕНЬ, -90)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КонтактныеЛицаПартнеров.Ссылка КАК Ссылка,
		|	Партнеры.Ссылка КАК Партнер,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &РольМенеджерСнабженец
		|				ТОГДА КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК МенеджерСнабженец,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &РольДиректор
		|				ТОГДА КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК Директор,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА НЕ(КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &РольМенеджерСнабженец
		|							ИЛИ КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &РольДиректор)
		|					ИЛИ КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица ЕСТЬ NULL
		|				ТОГДА КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона
		|			ИНАЧЕ """"
		|		КОНЕЦ) КАК Прочие
		|ПОМЕСТИТЬ ВТВыборПоРолям
		|ИЗ
		|	Справочник.КонтактныеЛицаПартнеров.КонтактнаяИнформация КАК КонтактныеЛицаПартнеровКонтактнаяИнформация
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|				ПО (ДополнительныеСведения.Объект = Партнеры.ОсновнойМенеджер)
		|				ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеЗвонков КАК ДанныеЗвонков
