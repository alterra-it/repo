Процедура ЗакрытьНаСервере()
	
	УстановитьПривилегированныйРежим(Истина);
	Если ТипЗвонка = "" Тогда 
		Сообщить("Тип обращения не выбран! Звонок не закрыт.");
		Возврат;
	Иначе 
	ТелефонияСервер.СоздатьСобытиеПоДаннымЗвонка(НомерТелефонаВходящий,Партнер,ДатаНачалаЗвонка,ИдентификаторЗвонкаВАТС, 
	Перечисления.ВходящееИсходящееСобытие.Входящее, Перечисления.ТипыОбращенийВCallЦентр[ТипЗвонка], Комментарий, ЗапросНаПерезвон); 
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
		
	НомерТелефонаВходящий = "";
	Партнер = Неопределено;
	ИнформацияПоБонуснойПрограмме = ""; 
	Комментарий = "";
	ТипЗвонка = "";
	ДокументыПродажи.Отбор.Элементы.Очистить();
	ИсторияЗвонков.Отбор.Элементы.Очистить();
	ОбращенияКлиентов.Отбор.Элементы.Очистить(); 
	
КонецПроцедуры

