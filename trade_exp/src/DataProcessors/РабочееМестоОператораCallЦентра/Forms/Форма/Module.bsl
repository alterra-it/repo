&НаКлиенте
Процедура Сохранить(Команда)



	ТекСтрока = Неопределено;
	ОпределитьВидЗвонков(ТекСтрока);

	ОценкаКачестваДоставки = ТекСтрока.ОценкаКачестваДоставки;
	ПартнерОбзвона = ТекСтрока.ФИОКлиента;
	СоздатьЗаписьВРегистр(ОценкаКачестваДоставки, ПартнерОбзвона);
	ОценкаПоЗвонку = "";
	
КонецПроцедуры

&НаКлиенте
Функция ОпределитьВидЗвонков(ТекСтрока)
	
	Если ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваДоставки") Тогда
		ТекСтрока = Элементы.Реквизит1.ТекущиеДанные
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок") Тогда
		ТекСтрока = Элементы.ОбзвонКачестваКрупныхПокупок.ТекущиеДанные
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ") Тогда
		ТекСтрока = Элементы.ОбзвонУдобстваРаботыВИМ.ТекущиеДанные
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонПричинВозвратаТовара") Тогда
		ТекСтрока = Элементы.ОбзвонПричинВозвратаТовара.ТекущиеДанные
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку") Тогда
		ТекСтрока = Элементы.ОбзвонКачестваРаботыКЦ.ТекущиеДанные
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки") Тогда
		ТекСтрока = Элементы.ОбзвонРаботыКорзинки.ТекущиеДанные
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера")  Тогда
		ТекСтрока = Элементы.ОбзвонКачестваРаботыОсновногоМенеджера.ТекущиеДанные
	КонецЕсли;
	
	Возврат ТекСтрока

КонецФункции
	
	
	
	
&НаСервере
Процедура СоздатьЗаписьВРегистр(ОценкаКачестваДоставки, ПартнерОбзвона, Недозвон = Ложь)
	
	ДанныеОбзвонов = РегистрыСведений.ДанныеОбзвонов;
	НаборЗапись = ДанныеОбзвонов.СоздатьНаборЗаписей();
	
	НаборЗапись.Отбор.ОбъектОбзвона.Установить(ОбъектОбзвона); 
	НаборЗапись.Отбор.ВидОбзвона.Установить(ВидыОбзвонов);
	НаборЗапись.Прочитать();
	
	Если НаборЗапись.Количество() = 0 Тогда
	    Запись = НаборЗапись.Добавить();
	    Запись.ОбъектОбзвона = ОбъектОбзвона;
	    Запись.ВидОбзвона = ВидыОбзвонов; 
	Иначе
		Запись = НаборЗапись[0];
	КонецЕсли;
	Запись.Период = ТекущаяДата();
    Запись.НомерТелефона = НомерТелефонаИсходящий; 
	Запись.Комментарий = Комментарий;
	Если ОценкаПоЗвонку <> Неопределено Тогда
		Запись.Оценка = ОценкаПоЗвонку;
	Иначе
		Запись.Оценка = Перечисления.ОценкиКлиентов.НетОценки
	КонецЕсли;
	Если Недозвон Тогда
		Запись.Комментарий = "Недозвон"
	КонецЕсли;
	Если ОценкаКачестваДоставки <> Неопределено Тогда
		Запись.ОценкаКачестваДоставки = ОценкаКачестваДоставки;
	КонецЕсли;
	Запись.Примечание = Примечание;
	Запись.Пользователь = Пользователи.ТекущийПользователь();
	Запись.Партнер = Партнер;
	НаборЗапись.Записать(); 

КонецПроцедуры


