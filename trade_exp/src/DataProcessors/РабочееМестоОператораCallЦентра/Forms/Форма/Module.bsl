&НаКлиенте
Процедура ОценкаПоЗвонкуПриИзменении(Элемент)
	Если ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваДоставки") Тогда
		ТекСтрока = Элементы.Реквизит1.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок") Тогда
		ТекСтрока = Элементы.ОбзвонКачестваКрупныхПокупок.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ") Тогда
		ТекСтрока = Элементы.ОбзвонУдобстваРаботыВИМ.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонПричинВозвратаТовара") Тогда
		ТекСтрока = Элементы.ОбзвонПричинВозвратаТовара.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку") Тогда    //обзвон качества работы КЦ
		ТекСтрока = Элементы.ОбзвонКачестваРаботыКЦ.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки") Тогда
		ТекСтрока = Элементы.ОбзвонРаботыКорзинки.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера") Тогда
		ТекСтрока = Элементы.ОбзвонКачестваРаботыОсновногоМенеджера.ТекущиеДанные;
	Иначе
		ТекСтрока = Неопределено;
	КонецЕсли;
	Если Не ТекСтрока = Неопределено Тогда
		Если ОценкаПоЗвонку <> Неопределено Тогда;
			ТекСтрока.ОценкаПоЗвонку = ОценкаПоЗвонку;
		Иначе
			ТекСтрока.ОценкаПоЗвонку = ПредопределенноеЗначение("Перечиление.ОценкиКлиентов.НетОценки");
		КонецЕсли;
	Иначе
		Сообщить("Выберите строку из обзвона");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура КомПоДоставкеОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	Если ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваДоставки") Тогда
		ТекСтрока = Элементы.Реквизит1.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок") Тогда
		ТекСтрока = Элементы.ОбзвонКачестваКрупныхПокупок.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ") Тогда
		ТекСтрока = Элементы.ОбзвонУдобстваРаботыВИМ.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонПричинВозвратаТовара") Тогда
		ТекСтрока = Элементы.ОбзвонПричинВозвратаТовара.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку") Тогда    //обзвон качества работы КЦ
		ТекСтрока = Элементы.ОбзвонКачестваРаботыКЦ.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки") Тогда
		ТекСтрока = Элементы.ОбзвонРаботыКорзинки.ТекущиеДанные;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера") Тогда
		ТекСтрока = Элементы.ОбзвонКачестваРаботыОсновногоМенеджера.ТекущиеДанные;
	Иначе
		ТекСтрока = Неопределено;
	КонецЕсли;
	Если НЕ ТекСтрока = Неопределено Тогда
		ТекСтрока.Комментарий = Текст;
	Иначе
		Сообщить("Выберите строку из обзвона");
	КонецЕсли;
	Комментарий = Текст;
КонецПроцедуры

&НаСервере
Функция ПолучитьВнутренниеНомера()
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиПользователейТелефонии.ВнутреннийНомер КАК ВнутреннийНомер
		|ИЗ
		|	РегистрСведений.НастройкиПользователейТелефонии КАК НастройкиПользователейТелефонии
		|ГДЕ
		|	НастройкиПользователейТелефонии.Пользователь <> &Пользователь"; 
	
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	ВнутренниеНомера = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ВнутреннийНомер");
	УстановитьПривилегированныйРежим(Ложь);
	Возврат ВнутренниеНомера
	
КонецФункции

