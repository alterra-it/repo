	Если ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваДоставки") Тогда
		ТаблицаЗначений = ОценкаДоставки;
		Фильтр = ОтборПоФилиалу;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок") Тогда
		ТаблицаЗначений = ОбзвонКачестваКрупныхПокупок;
		Фильтр = СпособПолучения;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ") Тогда
		ТаблицаЗначений = ОбзвонУдобстваРаботыВИМ;
		Фильтр = "";
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонПричинВозвратаТовара") Тогда
		ТаблицаЗначений = ОбзвонПричинВозвратаТовара;
		Фильтр = ВидКлиентаВозвратТоваров;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку") Тогда    
		ТаблицаЗначений = ОбзвонКачестваРаботыКЦ;
		Фильтр = Строка(НомераКЦ);
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки") Тогда
		ТаблицаЗначений = ОбзвонРаботыКорзинки;
		Фильтр = Строка(МестоОплаты) + " Сумма больше " + Строка(МинимальнаяСумма);
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера") Тогда
