&НаКлиенте
Процедура НомерТелефонаВБуферОбмена()
	
	Телефон_ = НомерТелефонаВходящий;
	АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(Телефон_);
	HTML = Новый COMОбъект("htmlfile");
	HTML.parentWindow.clipboardData.setData("Text",Телефон_);  
	
КонецПроцедуры

&НаСервере
Процедура НайтиПартнераНаСервере(ТекстПоиска)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Партнеры.Ссылка КАК Партнер
		|ИЗ
		|	Справочник.Партнеры КАК Партнеры
		|ГДЕ
		|	Партнеры.Наименование ПОДОБНО ""%"" + &Наименование + ""%""
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Партнеры.Ссылка
		|ИЗ
		|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры КАК Партнеры
		|		ПО ПартнерыКонтактнаяИнформация.Ссылка = Партнеры.Ссылка
		|ГДЕ
		|	ПартнерыКонтактнаяИнформация.Представление ПОДОБНО ""%"" + &Наименование + ""%""";
	
	Запрос.УстановитьПараметр("Наименование", ТекстПоиска);
	
	Если Не ПустаяСтрока(ТекстПоиска) Тогда
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		СписокПартнеров.Загрузить(РезультатЗапроса);
		
		Элементы.СписокПартнеров.Видимость = Истина;

	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементовПоТипуПартнера(Партнер)
	
	Если ЗначениеЗаполнено(Партнер) Тогда
		Если Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо Тогда
			ВидимостьГруппыФЛ=Истина;
			ВидимостьГруппыЮЛ=Ложь;
			ВидимостьНовый=Ложь;
		Иначе
			ВидимостьГруппыФЛ=Ложь;
			ВидимостьГруппыЮЛ=Истина;
			ВидимостьНовый=Ложь;
		КонецЕсли;
	Иначе
		ВидимостьГруппыФЛ=Ложь;
		ВидимостьГруппыЮЛ=Ложь;
		ВидимостьНовый=Истина;
	КонецЕсли;
	
	Элементы.ГруппаФЛ.Видимость=ВидимостьГруппыФЛ;
	Элементы.ГруппаЮЛ.Видимость=ВидимостьГруппыЮЛ;
	Элементы.ГруппаНовый.Видимость=ВидимостьНовый;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПодразделение()
	
	МассивПодразделений = Новый Массив();
	
	Если ОтборПоФилиалу = "" Тогда
		ОтборПоФилиалу = "Барнаул";
	КонецЕсли;
	
	Если ОтборПоФилиалу = "ЦБ" ИЛИ ОтборПоФилиалу = "Все" Тогда
		МассивПодразделений.Добавить(Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000001"));
	КонецЕсли;
	
	Если ОтборПоФилиалу = "Барнаул" ИЛИ ОтборПоФилиалу = "Все" Тогда
		МассивПодразделений.Добавить(Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000002"));
	КонецЕсли; 
	
	Если  ОтборПоФилиалу = "Выбор" ИЛИ ОтборПоФилиалу = "Все" Тогда
		МассивПодразделений.Добавить(Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000003"));
	КонецЕсли;	
	
	Если  ОтборПоФилиалу = "Бийск" ИЛИ ОтборПоФилиалу = "Все" Тогда
		МассивПодразделений.Добавить(Справочники.СтруктураПредприятия.НайтиПоКоду("0А-000004"));
	КонецЕсли;
	
	Если  ОтборПоФилиалу = "Майма" ИЛИ ОтборПоФилиалу = "Все" Тогда
		МассивПодразделений.Добавить(Справочники.СтруктураПредприятия.НайтиПоКоду("01-000002"));
	КонецЕсли;
	
	Примечание = "Фильтр: "+Строка(ОтборПоФилиалу);

	Возврат МассивПодразделений;
	
КонецФункции

&НаСервере
Процедура УстановитьЗапросЗаказыНаДоставку(Подразделения)
	
	ОценкаДоставки.Очистить();
	
	Для каждого Подразделение из Подразделения Цикл
				
		ОценкаДоставкиПоЗапросу = Обработки.РабочееМестоОператораCallЦентра.ПолучитьВыборкуЗаказовНаДоставкуДляОценки(ПериодОбзвона.ДатаНачала,ПериодОбзвона.ДатаОкончания,Подразделение); 	
		
		Для каждого Строка из ОценкаДоставкиПоЗапросу Цикл
			
			НоваяСтрока = ОценкаДоставки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
			
		КонецЦикла;   
		
	КонецЦикла;
		
КонецПроцедуры

