&НаСервере
Функция ПолучитьТекущийЗвонок(ТекущийСотрудник)
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ТекущиеВходящиеЗвонки.АбонентОтКого КАК АбонентОтКого,
		|	ТекущиеВходящиеЗвонки.НомерТелефонаАбонента КАК НомерТелефонаАбонента,
		|	ТекущиеВходящиеЗвонки.ИдентификаторЗвонкаВАТС КАК ИдентификаторЗвонкаВАТС
		|ИЗ
		|	РегистрСведений.ТекущиеВходящиеЗвонки КАК ТекущиеВходящиеЗвонки
		|ГДЕ
		|	ТекущиеВходящиеЗвонки.ПользовательКому = &ПользовательКому
		|   И Не ТекущиеВходящиеЗвонки.Завершен";
	
	Запрос.УстановитьПараметр("ПользовательКому", ТекущийСотрудник);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ДатаНачалаЗвонка = ТекущаяДата(); 
		ИдентификаторЗвонкаВАТС = ВыборкаДетальныеЗаписи.ИдентификаторЗвонкаВАТС; 
		НомерТелефонаВходящий = ВыборкаДетальныеЗаписи.НомерТелефонаАбонента;
		ЗаполнитьГруппуВходящие(НомерТелефонаВходящий);	
		
		Набор = РегистрыСведений.ТекущиеВходящиеЗвонки.СоздатьНаборЗаписей();
	    Набор.Отбор.ПользовательКому.Установить(ТекущийСотрудник);
	    Набор.Записать();

		Возврат Истина;
		
	КонецЦикла;

	Возврат Ложь;
	
КонецФункции

&НаСервере
Функция ЗавершитьТекущийЗвонок(ТекущийСотрудник)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Истина
		|ИЗ
		|	РегистрСведений.ТекущиеВходящиеЗвонки КАК ТекущиеВходящиеЗвонки
		|ГДЕ
		|	ТекущиеВходящиеЗвонки.ПользовательКому = &ПользовательКому
		|   И ТекущиеВходящиеЗвонки.Завершен";
	
	Запрос.УстановитьПараметр("ПользовательКому", ТекущийСотрудник);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
			
		Набор = РегистрыСведений.ТекущиеВходящиеЗвонки.СоздатьНаборЗаписей();
	    Набор.Отбор.ПользовательКому.Установить(ТекущийСотрудник);
	    Набор.Записать();

		Возврат Истина;
		
	КонецЕсли;

	Возврат Ложь;
	
КонецФункции

