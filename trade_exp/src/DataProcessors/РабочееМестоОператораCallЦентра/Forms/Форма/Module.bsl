&НаКлиенте
Процедура Позвонить(Команда)

	ЗапросНаПерезвон = Истина;
	ТекущаяСтрока = Элементы.ОчередьЗапросовНаЗвонок.ТекущиеДанные;
	
	ТелефонияКлиент.ПозвонитьПоНомеру(НомерТелефонаИсходящий, Партнер, , "");	
	ЗаполнитьГруппуВходящие(НомерТелефонаИсходящий);

	Если Не ТекущаяСтрока = Неопределено Тогда  
		ОчиститьОчередь(Новый Структура("ДатаЗвонка,НомерТелефона",ТекущаяСтрока.ДатаЗвонка,ТекущаяСтрока.НомерТелефона)); 
	КонецЕсли; 
	
	ЗаполнитьОчередьЗапросовНаЗвонок();

КонецПроцедуры

&НаКлиенте
Процедура Исходящие(Команда)
	
	УстановитьВидимостьГруппРабочейОбластиФормы(,,,,Истина);
	Если Не ЗначениеЗаполнено(ВидыОбзвонов) Тогда
		УстановитьВидимостьОбзвонов();
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваДоставки") Тогда
		УстановитьВидимостьОбзвонов(Истина);
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваКрупныхПокупок") Тогда
		УстановитьВидимостьОбзвонов(,Истина);
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонУдобстваРаботыВИМ") Тогда
		УстановитьВидимостьОбзвонов(,,Истина);
		Элементы.НачислитьББЗаИдею.Видимость = Истина;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонПричинВозвратаТовара") Тогда
		УстановитьВидимостьОбзвонов(,,,Истина);
		Элементы.ОценкаПоЗвонку.Видимость = Ложь;
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОператораКЦПоЗвонку") Тогда    //обзвон качества работы КЦ
		УстановитьВидимостьОбзвонов(,,,,Истина);
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыКорзинки") Тогда
		УстановитьВидимостьОбзвонов(,,,,,Истина);
	ИначеЕсли ВидыОбзвонов = ПредопределенноеЗначение("Перечисление.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера") Тогда	
		УстановитьВидимостьОбзвонов(,,,,,,Истина);
	КонецЕсли;  
	
КонецПроцедуры

