&НаКлиенте
Процедура НачислитьББЗаИдею(Команда)
	Форма = ПолучитьФорму("Документ.НачислениеИСписаниеБонусныхБаллов.ФормаОбъекта");
    ДанныеФормы = Форма.Объект;    
	ТекущаяСтрока = Элементы.ОбзвонУдобстваРаботыВИМ.ТекущиеДанные;
    НачислитьББЗаИдеюНаСервере(ДанныеФормы, ТекущаяСтрока.ФИОКлиента); 
	
	КопироватьДанныеФормы(ДанныеФормы, Форма.Объект);
    Форма.Открыть();
КонецПроцедуры

&НаСервере
Процедура НачислитьББЗаИдеюНаСервере(ДанныеФормы, Партнер)
	Док = ДанныеФормыВЗначение(ДанныеФормы, Тип("ДокументОбъект.НачислениеИСписаниеБонусныхБаллов"));
	Док.Комментарий = "Начисление 100 ББ за идею по улучшению работы ИМ";
	Док.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоКоду("000000007");
	Стр = Док.Начисление.Добавить();
	Стр.Партнер = Партнер;
	Стр.Баллы = 100;
	ЗначениеВДанныеФормы(Док, ДанныеФормы);
КонецПроцедуры

