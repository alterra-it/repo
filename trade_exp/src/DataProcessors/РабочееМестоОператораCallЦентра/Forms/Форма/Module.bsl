		|			ПО (КонтактныеЛицаПартнеров.Владелец = Партнеры.Ссылка)
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.РолиКонтактногоЛица КАК КонтактныеЛицаПартнеровРолиКонтактногоЛица
		|			ПО (КонтактныеЛицаПартнеровРолиКонтактногоЛица.Ссылка = КонтактныеЛицаПартнеров.Ссылка)
		|		ПО (КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка = КонтактныеЛицаПартнеров.Ссылка)
		|			И (НЕ КонтактныеЛицаПартнеров.ПометкаУдаления)
		|			И (НЕ КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона = """")
		|			И (КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона ПОДОБНО ""9%"")
		|			И (ДЛИНАСТРОКИ(КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона) = 10)
		|ГДЕ
		|	(ДополнительныеСведения.Значение.Наименование = ""Отдел дистрибуции""
		|			ИЛИ ДополнительныеСведения.Значение.Наименование = ""Коммерческий отдел"")
		|	И НЕ КонтактныеЛицаПартнеров.Владелец В
		|				(ВЫБРАТЬ
		|					ВТ_Исключения.Клиент КАК Клиент
		|				ИЗ
		|					ВТ_Исключения)
		|	И НЕ КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона В
		|				(ВЫБРАТЬ
		|					ВТЧерныйСписок.Номер КАК Номер
		|				ИЗ
		|					ВТЧерныйСписок)
		|	И НЕ Партнеры.ОсновнойМенеджер В (&КомОтдел)
		|
		|СГРУППИРОВАТЬ ПО
		|	КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица,
		|	КонтактныеЛицаПартнеров.Ссылка,
		|	Партнеры.Ссылка,
		|	ВЫБОР
		|		КОГДА НЕ(КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &РольМенеджерСнабженец
		|					ИЛИ КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица = &РольДиректор
		|					ИЛИ КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица ЕСТЬ NULL)
		|			ТОГДА КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона
		|		ИНАЧЕ """"
		|	КОНЕЦ,
		|	КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВыборПоРолям.Партнер КАК Партнер,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ВТВыборПоРолям.МенеджерСнабженец <> """"
		|				ТОГДА ВТВыборПоРолям.МенеджерСнабженец
		|			ИНАЧЕ ВЫБОР
		|					КОГДА ВТВыборПоРолям.Директор <> """"
		|						ТОГДА ВТВыборПоРолям.Директор
		|					ИНАЧЕ ВТВыборПоРолям.Прочие
		|				КОНЕЦ
		|		КОНЕЦ) КАК НомерТелефона
		|ПОМЕСТИТЬ ВТПартнерыСНомерами
		|ИЗ
		|	ВТВыборПоРолям КАК ВТВыборПоРолям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТВыборПоРолям.Партнер
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТПартнерыСНомерами.Партнер КАК Партнер,
		|	КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка КАК ФИОКлиента,
		|	ВТПартнерыСНомерами.НомерТелефона КАК НомерТелефона,
		|	КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица КАК Должность,
		|	ВТПартнерыСНомерами.Партнер.ОсновнойМенеджер КАК Менеджер,
		|	ДанныеОбзвонов.Оценка КАК ОценкаПоЗвонку,
		|	ДанныеОбзвонов.Комментарий КАК Комментарий
		|ИЗ
		|	ВТПартнерыСНомерами КАК ВТПартнерыСНомерами
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.КонтактнаяИнформация КАК КонтактныеЛицаПартнеровКонтактнаяИнформация
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
		|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.РолиКонтактногоЛица КАК КонтактныеЛицаПартнеровРолиКонтактногоЛица
		|				ПО (КонтактныеЛицаПартнеровРолиКонтактногоЛица.Ссылка = КонтактныеЛицаПартнеров.Ссылка)
		|			ПО (КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка = КонтактныеЛицаПартнеров.Ссылка)
		|		ПО (КонтактныеЛицаПартнеровКонтактнаяИнформация.НомерТелефона = ВТПартнерыСНомерами.НомерТелефона)
		|			И (КонтактныеЛицаПартнеровКонтактнаяИнформация.Ссылка.Владелец = ВТПартнерыСНомерами.Партнер)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеОбзвонов КАК ДанныеОбзвонов
		|		ПО (ДанныеОбзвонов.ОбъектОбзвона = ВТПартнерыСНомерами.Партнер.ОсновнойМенеджер)
		|			И (ДанныеОбзвонов.ВидОбзвона = &ВидОбзвона)";
	
	Запрос.УстановитьПараметр("ВидЖалобы", ВидЖалобы);
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("РольДиректор", Справочники.РолиКонтактныхЛицПартнеров.НайтиПоНаименованию("Директор", Истина));
	Запрос.УстановитьПараметр("РольМенеджерСнабженец", Справочники.РолиКонтактныхЛицПартнеров.НайтиПоНаименованию("Менеджер/снабженец", Истина));
	Запрос.УстановитьПараметр("КомОтдел", КомОтделСписок);
	Запрос.УстановитьПараметр("ВидОбзвона", Перечисления.ВидыОбзвонов.ОбзвонКачестваРаботыОсновногоМенеджера);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Получить5СлучайныхЗаписей(РезультатЗапроса, ОбзвонКачестваРаботыОсновногоМенеджера);
	КонецЕсли;

КонецПроцедуры 

&НаКлиенте
Процедура ОбзвоныПриАктивизацииСтроки(Элемент)
	ТекущаяСтрока = Элемент.ТекущиеДанные;
	Если Не ТекущаяСтрока = Неопределено Тогда  
		НомерТелефонаИсходящий = ТекущаяСтрока.НомерТелефона; 
		Партнер = ТекущаяСтрока.ФИОКлиента;
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефонаИсходящий);  
	
		Если Элемент.Имя = "Реквизит1" Тогда
			ОбъектОбзвона = ТекущаяСтрока.ЗаказНаДоставку;
		ИначеЕсли Элемент.Имя = "ОбзвонКачестваКрупныхПокупок" Тогда
			ОбъектОбзвона = ТекущаяСтрока.ДокументПокупки;
		ИначеЕсли Элемент.Имя = "ОбзвонПричинВозвратаТовара" Тогда
			ОбъектОбзвона = ТекущаяСтрока.ДокументВозврата;
		ИначеЕсли Элемент.Имя = "ОбзвонУдобстваРаботыВИМ" Тогда
			ОбъектОбзвона = ТекущаяСтрока.ЗаказКлиента;
		ИначеЕсли Элемент.Имя = "ОбзвонКачестваРаботыОсновногоМенеджера" Тогда
			ОбъектОбзвона = ТекущаяСтрока.Менеджер;
		ИначеЕсли Элемент.Имя = "ОбзвонКачестваРаботыКЦ" Тогда 		
			ОбъектОбзвона = ТекущаяСтрока.ФИОКлиента;
		ИначеЕсли Элемент.Имя = "ОбзвонРаботыКорзинки" Тогда 		
			ОбъектОбзвона = ТекущаяСтрока.Чек;
		Иначе
			ОбъектОбзвона = "";
		КонецЕсли;
	КонецЕсли; 
КонецПроцедуры

