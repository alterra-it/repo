  <attributes>
    <name>ДокументыПродажи</name>
    <title>
      <key>ru</key>
      <value>Документы продажи</value>
    </title>
    <id>12</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЗаказКлиента.Ссылка КАК Ссылка,
	ЗаказКлиента.Номер КАК Номер,
	ЗаказКлиента.Дата КАК Дата,
	ЗаказКлиента.Партнер КАК Партнер,
	ЗаказКлиента.Склад КАК Склад,
	ЗаказКлиента.СуммаДокумента КАК СуммаДокумента,
	&quot;1&quot; КАК ТипДокумента
ИЗ
	Документ.ЗаказКлиента КАК ЗаказКлиента
ГДЕ
	ВЫБОР
			КОГДА НЕ &amp;Номер = &quot;&quot;&quot;&quot;
				ТОГДА ЗаказКлиента.Номер ПОДОБНО &quot;%&quot; + &amp;Номер + &quot;%&quot;
			ИНАЧЕ ИСТИНА
		КОНЕЦ

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	РеализацияТоваровУслуг.Ссылка,
	РеализацияТоваровУслуг.Номер,
	РеализацияТоваровУслуг.Дата,
	РеализацияТоваровУслуг.Партнер,
	РеализацияТоваровУслуг.Склад,
	РеализацияТоваровУслуг.СуммаДокумента,
	&quot;2&quot;
ИЗ
	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
ГДЕ
	ВЫБОР
			КОГДА НЕ &amp;Номер = &quot;&quot;&quot;&quot;
				ТОГДА РеализацияТоваровУслуг.Номер ПОДОБНО &quot;%&quot; + &amp;Номер + &quot;%&quot;
			ИНАЧЕ ИСТИНА
		КОНЕЦ

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЧекККМ.Ссылка,
	ЧекККМ.Номер,
	ЧекККМ.Дата,
	ЧекККМ.Партнер,
	ЧекККМ.Склад,
	ЧекККМ.СуммаДокумента,
	&quot;3&quot;
ИЗ
	Документ.ЧекККМ КАК ЧекККМ
ГДЕ
	ВЫБОР
			КОГДА НЕ &amp;Номер = &quot;&quot;&quot;&quot;
				ТОГДА ЧекККМ.Номер ПОДОБНО &quot;%&quot; + &amp;Номер + &quot;%&quot;
			ИНАЧЕ ИСТИНА
		КОНЕЦ</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
