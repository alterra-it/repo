
&НаКлиенте
Процедура ОК(Команда)
	Результат = Новый Структура("БылоНужно",Количество);
	Результат.Вставить("Номенклатура",Номенклатура);
	Результат.Вставить("Остаток",Остаток);
	Результат.Вставить("Нехватка",Количество-Остаток);
	Результат.Вставить("КлассТовара",КлассТовара);
	Результат.Вставить("Ликвидность",Ликвидность);
	если Остаток>=Количество тогда
		Сообщить("Данное количество есть на остатке!");
	иначе
		если Количество<>0 тогда  	
			Закрыть(Результат);
		иначе
			Закрыть(Неопределено);
		конецесли;
	конецесли;	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть(Неопределено);
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	Номенклатура=Параметры.номенклатура;
	если Параметры.остаток<0 тогда
		Остаток=0;
	иначе	
	Остаток=Параметры.остаток;
	конецесли;
	КлассТовара=Параметры.КлассТовара;
	Ликвидность=Параметры.Ликвидность;
КонецПроцедуры
