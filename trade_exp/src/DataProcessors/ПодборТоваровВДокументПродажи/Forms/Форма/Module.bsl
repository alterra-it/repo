
&НаСервере
Процедура Обр_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	МодифицироватьЗапрос();
	Элементы.КорзинаВидЦены.ТолькоПросмотр = Не ПроверкиАльтерраСервер.ИмеетПолныеПрава();
	Если Параметры.Свойство("СтруктураКлиента") Тогда
		_СтруктураКлиента = Параметры.СтруктураКлиента;
	КонецЕсли;	
	
	Элементы.ОстаткиТоваров.Видимость = Истина;
	Элементы.ОтображатьОстаткиНадпись.Видимость = Истина;

КонецПроцедуры

&НаСервере
Процедура МодифицироватьЗапрос()
	
	Если Не ПустаяСтрока(СписокНоменклатура.ТекстЗапроса) Тогда
		Если СтрНайти(СписокНоменклатура.ТекстЗапроса, "ABCКлассификацияНоменклатуры_Альтерра") = 0 Тогда 
			СхемаЗапроса = Новый СхемаЗапроса;
			СхемаЗапроса.УстановитьТекстЗапроса(СписокНоменклатура.ТекстЗапроса);  
			
			
			ПакетЗапроса = СхемаЗапроса.ПакетЗапросов.Количество()-1;
			ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[ПакетЗапроса];
			ОператорВыбора = ЗапросВыбора.Операторы[0];
			
			НовыйИсточник = ОператорВыбора.Источники.Добавить("РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних","ABCКлассификацияНоменклатуры_АльтерраСрезПоследних");
			
			НовыйИсточник.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.ПравоеВнешнее;
			Условие = Новый ВыражениеСхемыЗапроса("СправочникНоменклатура.Ссылка = ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура");
			НовыйИсточник.Соединения[0].Условие = Условие;
			
			НовыйИсточник.Источник.Параметры[1].Выражение = Новый ВыражениеСхемыЗапроса("Подразделение=&Подразделение") ;
			
			ОператорВыбора.ВыбираемыеПоля.Добавить("ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс");
			 
			Если найти(СписокНоменклатура.ТекстЗапроса,"&Склад") > 0 тогда
				НовыйИсточник = ОператорВыбора.Источники.Добавить("РегистрНакопления.ТоварыКОтгрузке.Остатки","ТоварыКОтгрузке");
				Условие = Новый ВыражениеСхемыЗапроса("СправочникНоменклатура.Ссылка = ТоварыКОтгрузке.Номенклатура");
				НовыйИсточник.Соединения[0].Условие = Условие;
				НовыйИсточник.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.ПравоеВнешнее;
				НовыйИсточник.Источник.Параметры[1].Выражение = Новый ВыражениеСхемыЗапроса("Склад в (&Склад)") ;
				
				стрпоиска = "ВЫРАЗИТЬ(ЕСТЬNULL(ВсеОстатки.ВНаличии, 0) /";
				стрзамены = "ВЫРАЗИТЬ((ЕСТЬNULL(ВсеОстатки.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузке.КОтгрузкеОстаток, 0)) /";
				
				СписокНоменклатура.ТекстЗапроса = стрзаменить(СхемаЗапроса.ПолучитьТекстЗапроса(), стрпоиска, стрзамены);
			Иначе
				СписокНоменклатура.ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
			КонецЕсли;
			СписокНоменклатура.Параметры.УстановитьЗначениеПараметра("Подразделение", Склад.Подразделение);
		КонецЕсли;  
		
		//новое ценообразование
		Если ДопМодуль.НовоеЦенообразование() Тогда     
			Если ЭтаФорма.ВидыЦен.Количество() = 0 Тогда
				ВидыЦенПараметр = Справочники.ВидыЦен.ПустаяСсылка();
			ИначеЕсли ЭтаФорма.ВидыЦен.Количество() = 1 Тогда
				ВидыЦенПараметр = ЭтаФорма.ВидыЦен[0].Значение;
			Иначе
				ВидыЦенПараметр = ЭтаФорма.ВидыЦен.ВыгрузитьЗначения();
			КонецЕсли;

				ПодборТоваровКлиентСервер.УстановитьПараметрДинамическогоСписка(СписокНоменклатура, "ВидыЦен", ВидыЦенПараметр);
				ПодборТоваровКлиентСервер.УстановитьПараметрДинамическогоСписка(СписокНоменклатура, "ФорматПодразделения", Подразделение.ФорматПодразделения);
				ПодборТоваровКлиентСервер.УстановитьПараметрДинамическогоСписка(СписокНоменклатура, "РегионПрисутствия", Подразделение.РегионПрисутствия);
		КонецЕсли;	
		
		ДобавитьОтборПоСегменту();
	КонецЕсли; 
	
КонецПроцедуры

#Область ИзменениеПодбора

&НаСервере
Процедура ПоискПоПодстрокеНаКлиенте()
	
	Использование = ЗначениеЗаполнено(СтрокаПоискаНоменклатура);
	
	Если Использование Тогда
		ШаблонПоиска = СокрЛП(СтрокаПоискаНоменклатура);
		
		МассивОтбора = Новый СписокЗначений();	
		МассивСлов = мРазложитьСтрокуВМассивПодстрок(ШаблонПоиска," ");
		МассивСлов = ПеревестиВРег(МассивСлов);
		КоличествоСлов = МассивСлов.Количество();
		
		Если КоличествоСлов > 0 Тогда
			ТекстЗапроса = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	Номенклатура.Ссылка КАК Номенклатура,
			|	Номенклатура.Наименование,
			|	Номенклатура.Артикул,
			|	Номенклатура.Код
			|ИЗ
			|	Справочник.Номенклатура КАК Номенклатура
			|ГДЕ
			|	(Номенклатура.Наименование ПОДОБНО &ШаблонПоиска
			|			ИЛИ Номенклатура.Артикул ПОДОБНО &ШаблонПоиска
			|			ИЛИ Номенклатура.Код ПОДОБНО &ШаблонПоиска)
			|	И Номенклатура.ЭтоГруппа = ЛОЖЬ";	
			
			//Попытка найти по первому слову но его может и не быть.
			ПодстрокаПоиска = СокрЛП(МассивСлов[0]);
			
			Запрос = Новый Запрос();
			Запрос.Текст = ТекстЗапроса;							
			Запрос.УстановитьПараметр("ШаблонПоиска","%"+ПодстрокаПоиска+"%");
			ТаблицаТоваров = Запрос.Выполнить().Выгрузить();
			
			//Попытка найти по второму слову
			Попытка
				Если ТаблицаТоваров.Количество() = 0 Тогда
					ПодстрокаПоиска = СокрЛП(МассивСлов[1]);
					
					Запрос = Новый Запрос();
					Запрос.Текст = ТекстЗапроса;							
					Запрос.УстановитьПараметр("ШаблонПоиска","%"+ПодстрокаПоиска+"%");
					ТаблицаТоваров = Запрос.Выполнить().Выгрузить();
				КонецЕсли;
			Исключение
			КонецПопытки;
			
			Если ТаблицаТоваров.Количество() > 0 Тогда
				Для Каждого СтрЭлемент Из ТаблицаТоваров Цикл
					НаименованиеНоменклатуры = ВРег(СокрЛП(СтрЭлемент.Наименование));
					Артикул = ВРег(СокрЛП(СтрЭлемент.Артикул));
					Код = Врег(СокрЛП(СтрЭлемент.Код));
					КоличествоСовпаденийСлов = 0;
					Для Каждого ПодстрокаПоиска Из МассивСлов Цикл				
						НомерСовпадения = Найти(НаименованиеНоменклатуры, ПодстрокаПоиска);
						Если НомерСовпадения = 0 Тогда
							НомерСовпадения = Найти(Артикул, ПодстрокаПоиска);
						КонецЕсли;
						Если НомерСовпадения = 0 Тогда
							НомерСовпадения = Найти(Код, ПодстрокаПоиска);
						КонецЕсли;
						Если НомерСовпадения > 0 Тогда						
							КоличествоСовпаденийСлов = КоличествоСовпаденийСлов + 1;
							Если КоличествоСовпаденийСлов = КоличествоСлов Тогда
								МассивОтбора.Добавить(СтрЭлемент.Номенклатура);
							КонецЕсли;					
						КонецЕсли;
					КонецЦикла;			
				КонецЦикла;	
			КонецЕсли;
		КонецЕсли;	
		
		Если МассивОтбора.Количество() > 0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
			СписокНоменклатура.Отбор,
			"Ссылка",
			МассивОтбора,
			ВидСравненияКомпоновкиДанных.ВСписке,,Использование);
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		СписокНоменклатура.Отбор,
		"Ссылка",
		Неопределено,
		ВидСравненияКомпоновкиДанных.ВСписке,,Ложь);
	КонецЕсли;
	СпискиВыбораКлиентСервер.ОбновитьСписокВыбора(Элементы.СтрокаПоискаНоменклатура.СписокВыбора, СтрокаПоискаНоменклатура);

КонецПроцедуры

