КонецПроцедуры

&НаСервере
Процедура ДобавитьОтборПоСегменту()
	
	СтрокаУсловия = "
	|1 В
	|(ВЫБРАТЬ ПЕРВЫЕ 1
	|	1
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК Сегменты
	|ГДЕ
	|	Сегменты.Номенклатура = СправочникНоменклатура.Ссылка
	|	И Сегменты.Сегмент = &СегментНоменклатуры)";
	
	СхемаЗапроса= Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(СписокНоменклатура.ТекстЗапроса);
//	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[0]; 
	ПакетЗапроса = СхемаЗапроса.ПакетЗапросов.Количество()-1;
	ЗапросВыбора = СхемаЗапроса.ПакетЗапросов[ПакетЗапроса];
	ОператорВыбора = ЗапросВыбора.Операторы[0];
	Если ЗначениеЗаполнено(СегментНоменклатуры) Тогда	
		ОператорВыбора.Отбор.Добавить(СтрокаУсловия);
		
		СписокНоменклатура.ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();			
		ПодборТоваровКлиентСервер.УстановитьПараметрДинамическогоСписка(СписокНоменклатура, "СегментНоменклатуры", СегментНоменклатуры, ЗначениеЗаполнено(СегментНоменклатуры));
	Иначе
		Условие = ОператорВыбора.Отбор.Найти(СтрокаУсловия);	
		Если Условие <> Неопределено Тогда
			Индекс = ОператорВыбора.Отбор.Индекс(Условие);
			ОператорВыбора.Отбор.Удалить(Индекс);
			СписокНоменклатура.ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#Область СохранениеСегмента

&НаСервере
Процедура Обр_ПриОткрытииПослеНаСервере()
	
	СтруктураНастроек = Новый Структура;
	СтруктураНастроек = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("ПодборТоваровВДокументПродажи_Форма","Настройки",СтруктураНастроек);
	ЗаполнитьЗначенияСвойств(ЭтаФорма, СтруктураНастроек); 
	
КонецПроцедуры

&НаКлиенте
Процедура Обр_ПриОткрытииПосле(Отказ)
	
	Обр_ПриОткрытииПослеНаСервере();
	Если ЗначениеЗаполнено(СегментНоменклатуры) Тогда
		ДобавитьОтборПоСегменту();
	КонецЕсли;    
	
КонецПроцедуры

&НаСервере
Процедура Обр_ПередЗакрытиемПослеНаСервере()
	
	СтруктураНастроек = Новый Структура;
	СтруктураНастроек.Вставить("СегментНоменклатуры", СегментНоменклатуры);
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("ПодборТоваровВДокументПродажи_Форма","Настройки",СтруктураНастроек);
	Если значениезаполнено(_СтруктураКлиента) Тогда
		Если _НехваткаТовара.Количество() > 0 Тогда
			УстановитьПривилегированныйРежим(Истина);
			Попытка 
				ДокументНехватки = Документы.НехваткаТовара.СоздатьДокумент();
				ДокументНехватки.Дата = ТекущаяДата();
				ДокументНехватки.Менеджер = Пользователи.ТекущийПользователь();
				ДокументНехватки.Склад = Объект.Склад;
				ДокументНехватки.Клиент = _СтруктураКлиента.Партнер;
				ДокументНехватки.Контрагент = _СтруктураКлиента.Контрагент;
				ДокументНехватки.Товары.Загрузить(_НехваткаТовара.Выгрузить());
				ДокументНехватки.Записать();
				_НехваткаТовара.Очистить();
				Документы.НехваткаТовара.СоздатьСообщениеВБитрихПоДокументуНехватки(ДокументНехватки);
			Исключение
				_НехваткаТовара.Очистить();
				Информация = ИнформацияОбОшибке();
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = КраткоеПредставлениеОшибки(Информация);
				Сообщение.Сообщить();
				ТекстОшибки = ПодробноеПредставлениеОшибки(Информация);
			КонецПопытки;	
			УстановитьПривилегированныйРежим(Ложь);
			
		КонецЕсли;	
	КонецЕсли;  
	
КонецПроцедуры

&НаКлиенте
Процедура Обр_ПередЗакрытиемПосле(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Обр_ПередЗакрытиемПослеНаСервере();
КонецПроцедуры
#КонецОбласти

#Область Аналоги

&НаКлиенте
Процедура Обр_СписокСтандартныйПоискНоменклатураПриАктивизацииСтрокиПосле(Элемент)
	
	Если _ПоказыватьАналоги И Элементы.СписокСтандартныйПоискНоменклатура.ТекущиеДанные <> Неопределено Тогда
		ЗаполнитьАналогиСервер(Элементы.СписокСтандартныйПоискНоменклатура.ТекущиеДанные.Номенклатура);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАналогиСервер(Номенклатура)
	
	_Аналоги.Очистить();
	
	Если Номенклатура = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Если ВидыЦен.Количество() > 0 Тогда
		ВидЦеныП = ВидыЦен[0].Значение;
	Иначе
		ВидЦеныП = ВидЦены;
	КонецЕсли;
	
	_Аналоги.Загрузить(РегистрыСведений.АналогиНоменклатуры.ПолучитьАналогиНоменклатуры(Номенклатура,ВидЦеныП,Склад));
	
КонецПроцедуры

&НаКлиенте
Процедура Обр_СписокРасширенныйПоискНоменклатураПриАктивизацииСтрокиПосле(Элемент)
	
	Если _ПоказыватьАналоги И Элементы.СписокРасширенныйПоискНоменклатура.ТекущиеДанные <> Неопределено Тогда
		ЗаполнитьАналогиСервер(Элементы.СписокРасширенныйПоискНоменклатура.ТекущиеДанные.Номенклатура);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Обр__АналогиВыборПосле(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)	
	
	СтандартнаяОбработка = Ложь;
	
	СтараяТекСтрока = ТекущаяСтрокаНоменклатуры;
	
	Если ТекущаяСтрокаНоменклатуры.ХарактеристикиИспользуются Тогда
		Обр__ПерейтиКХарактеристикамНоменклатурыПослеНаСервере(Элементы._Аналоги.ТекущиеДанные.Номенклатура);
		Элементы.СтраницыАналогов.ТекущаяСтраница = Элементы.СтраницаАналогиХарактеристик;
	Иначе
		ТекущаяСтрокаНоменклатуры = ПодборТоваровКлиентСервер.СтруктураСтрокиНоменклатуры();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрокаНоменклатуры, Элемент.ТекущиеДанные);
		
		ПодборТаблицаНоменклатураВыбор(Элемент, ВыбраннаяСтрока, Неопределено, СтандартнаяОбработка);
		ТекущаяСтрокаНоменклатуры = СтараяТекСтрока;
	КонецЕсли;  
	
КонецПроцедуры

&НаСервере
Процедура Обр__ПерейтиКХарактеристикамНоменклатурыПослеНаСервере(Номенклатура)	

	Запрос = Новый Запрос;   
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХарактеристикиНоменклатуры.Владелец КАК Номенклатура,
	|	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
	|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
	|	ХарактеристикиНоменклатуры.Владелец.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ХарактеристикиНоменклатуры.ПометкаУдаления КАК ПометкаУдаления,
	|	&ВидЦены КАК ВидЦены,
	|	&Склад КАК Склад,
	|	ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) + ЕСТЬNULL(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток, 0) КАК Остаток,
	|	ЕСТЬNULL(РаспределениеЗапасов.ВНаличии, 0) - ЕСТЬNULL(ТоварыКОтгрузкеОстатки.ВРезервеОстаток, 0) КАК Доступно,
	|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК Цена,
	|	НЕОПРЕДЕЛЕНО КАК ВладелецХарактеристик,
	|	ИСТИНА КАК ХарактеристикиИспользуются,
	|	ЗНАЧЕНИЕ(Перечисление.ВариантыРасчетаЦенНаборов.ПустаяСсылка) КАК ВариантРасчетаЦеныНабора,
	|	ЛОЖЬ КАК СодержитТовары,
	|	ЛОЖЬ КАК СодержитУслуги
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ХарактеристикиНоменклатуры.Владелец = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = ЦеныНоменклатурыСрезПоследних.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|			ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
	|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК ВНаличии,
	|			СУММА(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Резерв
	|		ИЗ
	|			РегистрНакопления.ЗапасыИПотребности.Остатки(
	|					,
	|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗапасыИПотребностиОстатки.Номенклатура,
	|			ЗапасыИПотребностиОстатки.Характеристика) КАК РаспределениеЗапасов
	|		ПО ХарактеристикиНоменклатуры.Владелец = РаспределениеЗапасов.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = РаспределениеЗапасов.Характеристика
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКОтгрузке.Остатки(, Склад = &Склад) КАК ТоварыКОтгрузкеОстатки
	|		ПО ХарактеристикиНоменклатуры.Владелец = ТоварыКОтгрузкеОстатки.Номенклатура
	|			И ХарактеристикиНоменклатуры.Ссылка = ТоварыКОтгрузкеОстатки.Характеристика
	|ГДЕ
	|	ХарактеристикиНоменклатуры.Владелец = &Владелец";
	
	Если ВидыЦен.Количество() > 0 Тогда
		ВидЦеныП = ВидыЦен[0].Значение;
	Иначе
		ВидЦеныП = ВидЦены;
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВидЦены", ВидЦеныП);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Владелец", Номенклатура);
	
	Рез = Запрос.Выполнить().Выгрузить();
	
	_АналогиХарактеристики.Загрузить(Рез);
	
КонецПроцедуры

&НаКлиенте
Процедура Обр__ПерейтиКСпискуАналогиПосле(Команда)
	Элементы.СтраницыАналогов.ТекущаяСтраница = Элементы.СтраницаАналогиНоменклатуры;
КонецПроцедуры

&НаКлиенте
Процедура Обр__АналогиХарактеристикиВыборПосле(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	СтараяТекСтрокаХарактеристика = ТекущаяСтрокаХарактеристик;
	
	ТекущаяСтрокаХарактеристик = ПодборТоваровКлиентСервер.СтруктураСтрокиХарактеристик();
	ЗаполнитьЗначенияСвойств(ТекущаяСтрокаХарактеристик, Элемент.ТекущиеДанные);
	
	ПодборТаблицаХарактеристикиВыбор(Элемент, ВыбраннаяСтрока, Неопределено, СтандартнаяОбработка);
	ТекущаяСтрокаХарактеристик = СтараяТекСтрокаХарактеристика;	        
	
КонецПроцедуры

&НаКлиенте
Процедура Обр__ОткрытьКарточкуПосле(Команда)

	ТекущаяСтрока = ЭтаФорма.Элементы._Аналоги.ТекущиеДанные;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура("Ключ", ТекущаяСтрока.Номенклатура);
	ОткрытьФорму("Справочник.Номенклатура.Форма.ФормаЭлемента", ПараметрыФормы);  
	
КонецПроцедуры

&НаКлиенте
Процедура Обр__ПоказыватьАналогиПриИзмененииПосле(Элемент)
	Элементы.СтраницыАналогов.Видимость = _ПоказыватьАналоги; 
КонецПроцедуры

#КонецОбласти


#Область ПоказатьРезервы
&НаКлиенте
Процедура Ном_ПоказатьРезервы(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", Элементы[ПодборТоваровКлиентСервер.ИмяСпискаНоменклатурыПоВариантуПоиска(ЭтаФорма)].ТекущаяСтрока);
	ПараметрыФормы.Вставить("Склад",Объект.Склад);
