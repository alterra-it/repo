		ОбластьШапки.Параметры.ТранспортноеСредство=СтрокаАвто;
		ОбластьШапки.Параметры.Водитель =""+ВыборкаСсылка.Водитель+Телефон(ВыборкаСсылка.Водитель);
		ОбластьШапки.Параметры.Склад =ВыборкаСсылка.Склад;
		ТабличныйДокумент.Вывести(ОбластьШапки);	
