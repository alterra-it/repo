	МассивРезультатов         = Запрос.ВыполнитьПакет();
	РезультатПоШапке          = МассивРезультатов[1];
	РезультатПоТабличнойЧасти = МассивРезультатов[3];
	
	СтруктураДанныхДляПечати 	= Новый Структура("РезультатПоШапке, РезультатПоТабличнойЧасти",
	РезультатПоШапке, РезультатПоТабличнойЧасти);
	
	Возврат СтруктураДанныхДляПечати;
	
КонецФункции

#КонецОбласти

#Область НарядЗаказНаДоставку
Функция СформироватьПечатнуюФормуНарядЗаказНаДоставку(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	Макет = Обработки.ПечатьФормДополнительно.ПолучитьМакет("ПФ_MXL_НарядЗаказНаДоставку");
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб= Истина;
	
	Если  МассивОбъектов.Количество() > 0 Тогда
		Ссылка= МассивОбъектов[0];		
	Иначе
		Возврат ТабДок;
	КонецЕсли;
	
	//Выводим наряд заказ
	ОбластьШтрихкода= Макет.ПолучитьОбласть("ОбластьШтрихкода");
	ОбластьШапка= Макет.ПолучитьОбласть("Шапка");
	ОбластьУсловия= Макет.ПолучитьОбласть("Условия");
	
	ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабДок, Макет, ОбластьШтрихкода, Ссылка);
	ТабДок.Вывести(ОбластьШтрихкода);
	
	ОбластьШапка.Параметры.Номер= Ссылка.Номер;
	ОбластьШапка.Параметры.Дата= Формат(Ссылка.Дата,"ДФ=dd.MM.yyyy") ;
	ОбластьШапка.Параметры.Время= Формат(Ссылка.Дата, "ДЛФ=T");
	
	СведеньяОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата);
	СведеньяОКлиента = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Контрагент, Ссылка.Дата);
	СведеньяОПеревозчике = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Перевозчик, Ссылка.Дата);
	
	//информация об Агенте:
	ОбластьШапка.Параметры.ОрганизацияНаименование= СведеньяОбОрганизации.ПолноеНаименование;
	ОбластьШапка.Параметры.ОрганизацияИНН= СведеньяОбОрганизации.ИНН;
	ОбластьШапка.Параметры.ОрганизацияЮридическийАдрес= СведеньяОбОрганизации.ЮридическийАдрес;
	ОбластьШапка.Параметры.ОрганизацияФизическийАдрес= СведеньяОбОрганизации.ФактическийАдрес;
	ОбластьШапка.Параметры.Менеджер= Ссылка.Автор;
	ОбластьШапка.Параметры.ТелефонДиспетчера= АльтерраОбщегоНазначения.ПолучитьТелефонПоВиду(Ссылка.Организация, "Телефон диспетчера по доставке");
	//информация о Клиенте: 
	ОбластьШапка.Параметры.ФИОКлиента= Ссылка.ФИОКлиента;
	ОбластьШапка.Параметры.КлиентЮридическийАдрес= СведеньяОКлиента.ЮридическийАдрес;
	ОбластьШапка.Параметры.КлиентФактическийАдрес= СведеньяОКлиента.ФактическийАдрес;
	ОбластьШапка.Параметры.КлиентТелефон= Ссылка.ТелефонКлиента;
	ОбластьШапка.Параметры.ТелефонНаВыгрузке= Ссылка.ТелефонКлиентаНаВыгрузке;
	//информация о доставке:
	ОбластьШапка.Параметры.ДатаДоставки=Формат(Ссылка.ПрибытиеНаОтгрузку, "ДЛФ=DD");
	ОбластьШапка.Параметры.АдресДоставки= Ссылка.АдресДоставки;
	ОбластьШапка.Параметры.ВремяДоставкиС= Лев(Формат(Ссылка.ВремяДоставкиС, "ДЛФ=T"), 5) ;
	ОбластьШапка.Параметры.ВремяДоставкиПо= Лев(Формат(Ссылка.ВремяДоставкиПо, "ДЛФ=T"), 5);
	ОбластьШапка.Параметры.СуммаДоставки= ПолучитьУслугуДоставки(Ссылка);
	
	//информация об Исполнителе:
	ОбластьШапка.Параметры.Перевозчик= СведеньяОПеревозчике.ПолноеНаименование;
	Если ЗначениеЗаполнено(Ссылка.Автомобиль) Тогда
