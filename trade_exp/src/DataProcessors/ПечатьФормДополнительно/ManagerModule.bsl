			ВыборкаПомещение = ВыборкаСклад.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаПомещение.Следующий() Цикл
				СуммаИтог=0; Веситог=0;
				
				СекцияДляШК = "";
				Если ЗначениеЗаполнено(ВыборкаПомещение.Помещение) Тогда
					СекцияДляШК = ВыборкаПомещение.Помещение;
				КонецЕсли;
				
				Если ВыдачаВОкно И ВыборкаПомещение.Помещение = Секция7 Тогда
					Секция= "ОКНО";
				Иначе 
					Секция=ВыборкаПомещение.Помещение;
					если не ЗначениеЗаполнено(ВыборкаПомещение.Помещение) тогда
						Секция="";
					конецесли;	
				КонецЕсли;
				Если Не ПервыйДокумент Тогда
					ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				КонецЕсли;
				
				ПервыйДокумент    = Ложь;
				НомерСтроки=0;
				если Найти(СТРОКА(ВыборкаСклад.Склад),"Торг")>0 тогда
					ТабличныйДокумент.Вывести(ОбластьПолоса);
				конецесли;	
				
				Если Строка(ВыборкаДокумент.Ссылка.Организация) <> "АСК и ИП" Тогда
					
					ОбластьЗаголовок.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаДокумент.Ссылка.Организация, ВыборкаДокумент.Ссылка.Дата), "ПолноеНаименование");
					
				КонецЕсли;
				
				ОбластьЗаголовок.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаДокумент.Ссылка.Организация, ВыборкаДокумент.Ссылка.Дата), "ФактическийАдрес");
				ОбластьЗаголовок.Параметры.ПредставлениеДокумента ="Расходная накладная "+ВыборкаДокумент.Ссылка.Номер+" от "+Формат(ВыборкаДокумент.Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
				Если СчетФактура.ТекстСчетФактура<>"Оформить счет-фактуру" Тогда
					ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: "+ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаДокумент.Ссылка.Контрагент, ВыборкаДокумент.Ссылка.Дата), "ПолноеНаименование,ФактическийАдрес");
				иначе
					ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: ___________________________";
				конецесли;
				ОбластьЗаголовок.Параметры.Секция = Секция;
				ВывестиШтрихкодПоСекциям(ТабличныйДокумент, Макет, ОбластьШтрихкода, ВыборкаДокумент.Ссылка, СекцияДляШК);
				ТабличныйДокумент.Вывести(ОбластьЗаголовок);
				
				ТабличныйДокумент.Вывести(ОбластьШапки);
				ВыборкаТовары = ВыборкаПомещение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Сумма=0;СчетСтрок=1;
				ИтогНДС=0;
				КоличествоИтог= 0;
				
				Пока ВыборкаТовары.Следующий() Цикл
					ВыборкаДетали=ВыборкаТовары.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					ВыборкаДетали.Следующий();
					СчетСтрок = СчетСтрок + 1;
					НомерСтроки = НомерСтроки + 1;
					если ВыборкаДетали.ВМинус="" тогда
						ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
					иначе
						ОбластьСтрока = Макет.ПолучитьОбласть("СтрокаМинус");
					конецесли;
					ОбластьСтрока.Параметры.НомерСтроки = НомерСтроки;
					ОбластьСтрока.Параметры.Заполнить(ВыборкаДетали);
					ОбластьСтрока.Параметры.Товар = СОКРЛП(ВыборкаДетали.Номенклатура);
					ОбластьСтрока.Параметры.Характеристика = СОКРЛП(ВыборкаДетали.Характеристика);
					ОбластьСтрока.Параметры.Цена = ?(ВыборкаДетали.Количество,ВыборкаДетали.Сумма/ВыборкаДетали.Количество,0);
					ОбластьСтрока.Параметры.Количество = ВыборкаДетали.Количество;
					ОбластьСтрока.Параметры.Сумма = ВыборкаДетали.Сумма;
					ОбластьСтрока.Параметры.ЕдиницаЦены = ВыборкаДетали.ЕдиницаЦены;
					ВесИтог = ВесИтог + ЧИСЛО(ВыборкаДетали.Вес);
					СуммаИтог = СуммаИтог+ ВыборкаДетали.Сумма;
					ИтогНДС=ИтогНДС+ВыборкаДетали.СуммаНДС;
					КоличествоИтог= КоличествоИтог+ВыборкаДетали.Количество;
					ДопЯчейки    = "";
					ВыборкаДетали.Сбросить();
					Пока ВыборкаДетали.Следующий() Цикл
						ДопЯчейки = ДопЯчейки + ВыборкаДетали.ЯчейкаДополнительная + Символы.ПС;
					КонецЦикла;
					ОбластьСтрока.Параметры.ДопЯчейки=ДопЯчейки;
					
					ТабличныйДокумент.Вывести(ОбластьСтрока);	
				КонецЦикла;
				Областьподвал.Параметры.Сумма=Суммаитог;
				Областьподвал.Параметры.Вес=Веситог;
				Областьподвал.Параметры.Количество=КоличествоИтог;
				ТабличныйДокумент.Вывести(ОбластьПодвал);
				
				ТекстИтоговойСтроки = НСтр("ru = 'Всего наименований %ВсегоНаименований%'");
				ТекстИтоговойСтроки = СтрЗаменить(ТекстИтоговойСтроки,"%ВсегоНаименований%", СчетСтрок-1);
				
				СуммаНДСРуб=" , в т.ч. НДС - "+ФормированиеПечатныхФорм.ФорматСумм(итогНДС, Константы.ВалютаРегламентированногоУчета.Получить());
				ОбластьПодписи.Параметры.ИтоговаяСтрока = ТекстИтоговойСтроки+", на сумму "+ФормированиеПечатныхФорм.ФорматСумм(СуммаИтог, Константы.ВалютаРегламентированногоУчета.Получить())+суммаНДСруб;
				
				ОбластьПодписи.параметры.ВремяПечати=ТекущаяДата();
				ОбластьПодписи.Параметры.СуммаПрописью  = "Сумма: "+РаботаСКурсамиВалют.СформироватьСуммуПрописью(СуммаИтог,Константы.ВалютаРегламентированногоУчета.Получить());
				ТабличныйДокумент.Вывести(ОбластьПодписи);
				
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат ТабличныйДокумент;
	
КонецФункции
Функция ПроверитьУсловиявыдачиВОкно(Знач Ссылка, Знач Результат, Секция7)//замена названия секции
	Рез= Истина;
	СекцияТоргзал = Справочники.РабочиеУчастки.НайтиПоНаименованию("Торговый зал (ЦО)");
	СегментОкно= Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Окно ТЗ ЦО");
	
	ТЗТовара= Ссылка.Товары.Выгрузить();
	ТЗТовара.Свернуть("Номенклатура");
	
	//Условия
	//1. Номенклатура 7 секции не в сегменте. 
	//2. В Реализации только одна 7я секция (рабочий участок). 
	//3. Общий вес документа по 7ой секции <= 20 кг. 
	
	//1.
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	Товар.Номенклатура
	|ПОМЕСТИТЬ ВТ_Товар
	|ИЗ
	|	&ТЗТовара КАК Товар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НоменклатураСегмента.Сегмент,
	|	НоменклатураСегмента.Номенклатура,
	|	НоменклатураСегмента.Характеристика
	|ИЗ
	|	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	|ГДЕ
	|	НоменклатураСегмента.Номенклатура В
	|			(ВЫБРАТЬ
	|				ВТ_Товар.Номенклатура
	|			ИЗ
	|				ВТ_Товар)
	|	И НоменклатураСегмента.Сегмент = &Сегмент";
	Запрос.УстановитьПараметр("Сегмент", СегментОкно);
	Запрос.УстановитьПараметр("ТЗТовара", ТЗТовара);
	ВыборкаСекции= Запрос.Выполнить().Выбрать();
	Если ВыборкаСекции.Следующий() Тогда
		Возврат Ложь
	Иначе
		Рез= Рез И Истина;
	КонецЕсли;
	
	//2. 3.
	ВесИтог= 0;
	КолПозиций= 0;
	мСекций= Новый Массив;
	//2.
	ВыборкаПомещение= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Помещение");
	Пока ВыборкаПомещение.Следующий() Цикл
		мСекций.Добавить(ВыборкаПомещение.Помещение);
		ВыборкаДетали= ВыборкаПомещение.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Если ВыборкаПомещение.Помещение = Секция7 Тогда
			Пока ВыборкаДетали.Следующий() Цикл
				ВесИтог = ВесИтог + ЧИСЛО(ВыборкаДетали.Вес);
				КолПозиций= КолПозиций+1;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	ВыборкаДетали.Сбросить();
	ВыборкаПомещение.Сбросить();
	
	Если ВесИтог <= 20 Тогда
		Рез= Рез И Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	//3.
	Если мСекций.Количество() = 1 Тогда
		Если мСекций[0] = Секция7 Тогда
			Рез= Рез И Истина;	
		Иначе
			Возврат Ложь;
		КонецЕсли;
	ИначеЕсли мСекций.Количество() = 2 Тогда 
		Если мСекций.Найти(Секция7) <> Неопределено И мСекций.Найти(СекцияТоргзал) <> Неопределено Тогда
			Рез= Рез И Истина;	
		Иначе
			Возврат Ложь;
		КонецЕсли;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	
	Возврат Рез;
КонецФункции

// Функция формирует печатную форму Расходная Накладная документа.
Функция СформироватьПечатнуюФормуТоварногоЧека(МассивОбъектов, ОбъектыПечати,ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Ссылка= МассивОбъектов[0];
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_РеализацияТоваровУслуг_РасходнаяНакладная";
	
	КолонкаКодов = ФормированиеПечатныхФорм.ИмяДополнительнойКолонки();
	ВыводитьКоды = ЗначениеЗаполнено(КолонкаКодов);
	
	ИспользоватьРучныеСкидки         = ПолучитьФункциональнуюОпцию("ИспользоватьРучныеСкидкиВПродажах");
	ИспользоватьАвтоматическиеСкидки = ПолучитьФункциональнуюОпцию("ИспользоватьАвтоматическиеСкидкиВПродажах");
	ИспользоватьУпаковки             = ПолучитьФункциональнуюОпцию("ИспользоватьУпаковкиНоменклатуры");
	
	ЗапросПоСкладам = Новый Запрос;
	ЭтоРеализация = ТипЗнч(МассивОбъектов[0]) = Тип("ДокументСсылка.РеализацияТоваровУслуг");
		ЗапросПоСкладам.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		                        |	РеализацияТоваровУслугТовары.Ссылка КАК Ссылка,
		                        |	РеализацияТоваровУслугТовары.Склад КАК Склад,
		                        |	РеализацияТоваровУслугТовары.Склад.ИспользоватьСерииНоменклатуры КАК ИспользоватьСерииНоменклатуры
		                        |ИЗ
		                        |	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		                        |ГДЕ
		                        |	РеализацияТоваровУслугТовары.Ссылка В(&МассивОбъектов)
		                        |	И РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		                        |
		                        |ОБЪЕДИНИТЬ ВСЕ
		                        |
		                        |ВЫБРАТЬ РАЗЛИЧНЫЕ
		                        |	ЧекККМТовары.Ссылка,
		                        |	ЧекККМТовары.Ссылка.Склад,
		                        |	ЧекККМТовары.Ссылка.Склад.ИспользоватьСерииНоменклатуры
		                        |ИЗ
		                        |	Документ.ЧекККМ.Товары КАК ЧекККМТовары
		                        |ГДЕ
		                        |	ЧекККМТовары.Ссылка В(&МассивОбъектов)
		                        |	И ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
		                        |
		                        |УПОРЯДОЧИТЬ ПО
		                        |	Ссылка
		                        |ИТОГИ ПО
		                        |	ИспользоватьСерииНоменклатуры";
	ЗапросПоСкладам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	
	// Создание массива для проверки: какие из докуметов не попали в выборку
	МассивПроверки = Новый Массив;
	Для Каждого Ссылка Из МассивОбъектов Цикл
		МассивПроверки.Добавить(Ссылка);
	КонецЦикла;
	
	ДеревоОбъектов = ЗапросПоСкладам.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Для Каждого ИспользованиеСерий Из ДеревоОбъектов.Строки Цикл
		
				//-
				ТекстЗапросаПоТоварам = 
				"ВЫБРАТЬ
				|	Товары.Ссылка КАК Ссылка,
				|	Товары.Ссылка.Организация КАК Организация,
				|	Товары.Ссылка.Контрагент КАК Контрагент,
				|	Товары.Ссылка.Номер КАК Номер,
				|	Товары.Ссылка.Дата КАК Дата,
				|	Товары.Ссылка.Организация.Префикс КАК Префикс,
				|	Товары.Склад КАК Склад,
				|	ВЫБОР
				|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
				|			ТОГДА ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаИзмерения)
				|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(Товары.Упаковка.ЕдиницаИзмерения)
				|	КОНЕЦ КАК ПредставлениеЕдининицыИзмеренияУпаковки,
				|	ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаИзмерения) КАК ПредставлениеБазовойЕдиницыИзмерения,
				|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
				|	Товары.Количество КАК Количество,
				|	Товары.Номенклатура.Код КАК Код,
				|	Товары.Номенклатура.Артикул КАК Артикул,
				|	Товары.Номенклатура.НаименованиеПолное КАК Номенклатура,
				|	Товары.Характеристика.НаименованиеПолное КАК Характеристика,
				|	ВЫБОР
				|		КОГДА ЕСТЬNULL(Товары.Упаковка.Коэффициент, 1) = 1
				|			ТОГДА НЕОПРЕДЕЛЕНО
				|		ИНАЧЕ Товары.Упаковка.Наименование
				|	КОНЕЦ КАК Упаковка,
				|	"""" КАК Серия,
				|	Товары.СуммаСНДС + Товары.СуммаСНДС * Товары.Распределять * ВЫБОР
				|		КОГДА РаспределениеУслуг.СуммаТоваров <> 0
				|			ТОГДА РаспределениеУслуг.СуммаУслуг / РаспределениеУслуг.СуммаТоваров
				|		ИНАЧЕ 0
				|	КОНЕЦ КАК Сумма,
				|	Товары.СуммаНДС + Товары.СуммаНДС * Товары.Распределять * ВЫБОР
				|		КОГДА РаспределениеУслуг.СуммаТоваров <> 0
				|			ТОГДА РаспределениеУслуг.СуммаУслуг / РаспределениеУслуг.СуммаТоваров
				|		ИНАЧЕ 0
				|	КОНЕЦ КАК СуммаНДС,
				|	Товары.СуммаАвтоматическойСкидки + Товары.СуммаРучнойСкидки КАК СуммаСкидки
				|ИЗ
				|	Документ.РеализацияТоваровУслуг.Товары КАК Товары
				|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				|			СУММА(ВЫБОР
				|					КОГДА РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
				|						ТОГДА РеализацияТоваровУслугТовары.Сумма
				|					ИНАЧЕ 0
				|				КОНЕЦ) КАК СуммаУслуг,
				|			СУММА(ВЫБОР
				|					КОГДА РеализацияТоваровУслугТовары.Распределять = 1
				|						ТОГДА РеализацияТоваровУслугТовары.Сумма
				|					ИНАЧЕ 0
				|				КОНЕЦ) КАК СуммаТоваров,
				|			РеализацияТоваровУслугТовары.Ссылка КАК Ссылка
				|		ИЗ
				|			Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
				|		
				|		СГРУППИРОВАТЬ ПО
				|			РеализацияТоваровУслугТовары.Ссылка) КАК РаспределениеУслуг
				|		ПО Товары.Ссылка = РаспределениеУслуг.Ссылка
				|ГДЕ
				|	Товары.Ссылка В(&МассивОбъектов)
				|	И Товары.Склад В(&МассивСкладов)
				|	И ВЫБОР
				|			КОГДА РаспределениеУслуг.СуммаТоваров <> 0
				|				ТОГДА Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
				|			ИНАЧЕ ИСТИНА
				|		КОНЕЦ
				|
				|ОБЪЕДИНИТЬ ВСЕ
				|
				|ВЫБРАТЬ
				|	Товары.Ссылка,
				|	Товары.Ссылка.Организация,
				|	Товары.Ссылка.Партнер,
				|	Товары.Ссылка.Номер,
				|	Товары.Ссылка.Дата,
				|	Товары.Ссылка.Организация.Префикс,
				|	Товары.Ссылка.Склад,
				|	ВЫБОР
				|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
				|			ТОГДА ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаИзмерения)
				|		ИНАЧЕ ПРЕДСТАВЛЕНИЕ(Товары.Упаковка.ЕдиницаИзмерения)
				|	КОНЕЦ,
				|	ПРЕДСТАВЛЕНИЕ(Товары.Номенклатура.ЕдиницаИзмерения),
				|	Товары.КоличествоУпаковок,
				|	Товары.Количество,
				|	Товары.Номенклатура.Код,
				|	Товары.Номенклатура.Артикул,
				|	Товары.Номенклатура.НаименованиеПолное,
				|	Товары.Характеристика.НаименованиеПолное,
				|	ВЫБОР
				|		КОГДА ЕСТЬNULL(Товары.Упаковка.Коэффициент, 1) = 1
				|			ТОГДА НЕОПРЕДЕЛЕНО
				|		ИНАЧЕ Товары.Упаковка.Наименование
				|	КОНЕЦ,
				|	"""",
				|	Товары.Сумма + Товары.Сумма * Товары.Распределять * ВЫБОР
				|		КОГДА РаспределениеУслуг.СуммаТоваров <> 0
				|			ТОГДА РаспределениеУслуг.СуммаУслуг / РаспределениеУслуг.СуммаТоваров
				|		ИНАЧЕ 0
				|	КОНЕЦ,
				|	Товары.СуммаНДС + Товары.СуммаНДС * Товары.Распределять * ВЫБОР
				|		КОГДА РаспределениеУслуг.СуммаТоваров <> 0
				|			ТОГДА РаспределениеУслуг.СуммаУслуг / РаспределениеУслуг.СуммаТоваров
				|		ИНАЧЕ 0
				|	КОНЕЦ,
				|	Товары.СуммаАвтоматическойСкидки + Товары.СуммаРучнойСкидки
				|ИЗ
				|	Документ.ЧекККМ.Товары КАК Товары
				|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
				|			СУММА(ВЫБОР
				|					КОГДА ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
				|						ТОГДА ЧекККМТовары.Сумма
				|					ИНАЧЕ 0
				|				КОНЕЦ) КАК СуммаУслуг,
				|			СУММА(ВЫБОР
				|					КОГДА ЧекККМТовары.Распределять = 1
				|						ТОГДА ЧекККМТовары.Сумма
				|					ИНАЧЕ 0
				|				КОНЕЦ) КАК СуммаТоваров,
				|			ЧекККМТовары.Ссылка КАК Ссылка
				|		ИЗ
				|			Документ.ЧекККМ.Товары КАК ЧекККМТовары
				|		
				|		СГРУППИРОВАТЬ ПО
				|			ЧекККМТовары.Ссылка) КАК РаспределениеУслуг
				|		ПО Товары.Ссылка = РаспределениеУслуг.Ссылка
				|ГДЕ
				|	Товары.Ссылка В(&МассивОбъектов)
				|	И ВЫБОР
				|			КОГДА РаспределениеУслуг.СуммаТоваров <> 0
				|				ТОГДА Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
				|			ИНАЧЕ ИСТИНА
				|		КОНЕЦ
				|
				|УПОРЯДОЧИТЬ ПО
				|	Ссылка,
				|	Склад
				|ИТОГИ ПО
				|	Ссылка";
		
		ЗапросПоТоварам = Новый Запрос;
		ЗапросПоТоварам.Текст = ТекстЗапросаПоТоварам;
		ЗапросПоТоварам.УстановитьПараметр("МассивОбъектов", ИспользованиеСерий.Строки.ВыгрузитьКолонку("Ссылка"));
		ЗапросПоТоварам.УстановитьПараметр("МассивСкладов",  ИспользованиеСерий.Строки.ВыгрузитьКолонку("Склад"));
		
		ПервыйДокумент = Истина;
		
		Макет = ПолучитьМакет("ПФ_MXL_ТоварныйЧек");
		
		
		РеквизитыДокумента = Новый Структура("Номер, Дата, Префикс, Представление");
		
		ДанныеПечати = ЗапросПоТоварам.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ДанныеПечати.Следующий() Цикл
			
			МассивПроверки.Удалить(МассивПроверки.Найти(ДанныеПечати.Ссылка));
			
			НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
			
			ЗаполнитьЗначенияСвойств(РеквизитыДокумента, ДанныеПечати);
			
			Если Не ПервыйДокумент Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			
			ПервыйДокумент = Ложь;
			
			ТелефонСклада="";
			Если ЭтоРеализация Тогда
				если  значениезаполнено(ДанныеПечати.Ссылка.Склад) тогда
					складДокумента=ДанныеПечати.Ссылка.Склад;
					если не складДокумента.ЭтоГруппа тогда 
						для каждого стр из складДокумента.КонтактнаяИнформация цикл
							если значениезаполнено(стр.НомерТелефона) тогда
								телефонСклада=стр.НомерТелефона;
								прервать;
							конецесли;
						конеццикла;	
					конецесли;
				конецесли;
			конецесли;

			Область = Макет.ПолучитьОбласть("Поставщик");
			Область.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Организация, ДанныеПечати.Дата), "ПолноеНаименование")+?(не пустаяСтрока(ТелефонСклада)," ,тел."+ТелефонСклада,"");
			Область.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Организация, ДанныеПечати.Дата), "ФактическийАдрес");
			
			Область.Параметры.ПредставлениеДокумента="к накладной "+РеквизитыДокумента.Номер+" от "+Формат(РеквизитыДокумента.Дата,"ДФ=""дд ММММ гггг 'г.' """);
			БезНалогаТекст=?(ДанныеПечати.Ссылка.НалогообложениеНДС=Перечисления.ТипыНалогообложенияНДС.ПродажаНеОблагаетсяНДС,"Без налога НДС","");
			Область.Параметры.Безналога=БезНалогаТекст;
			
			ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, Область, ДанныеПечати.Ссылка);
			Область.Параметры.НомерОчереди = ""+Ссылка.Очередь+Прав(СокрЛП(ДанныеПечати.Ссылка.Номер),3);
			ТабличныйДокумент.Вывести(Область);
			
			Область = Макет.ПолучитьОбласть("ШапкаТаблицы");
			ТабличныйДокумент.Вывести(Область);
			СчетСтрок = 1;
			ВыборкаПоТоварам = ДанныеПечати.Выбрать();
			КоличествоСтрок = ВыборкаПоТоварам.Количество();
			Сумма=0;
			ИтогНДС=0;
			СуммаСкидки=0;
			СуммаБезСкидки=0;
			Область = Макет.ПолучитьОбласть("СтрокаТаблицы");
			Пока ВыборкаПоТоварам.Следующий() Цикл
				Область.Параметры.НомерСтроки = СчетСтрок;
				РаспределитьТранспортные = Ложь;
				Если ЭтоРеализация Тогда
					РаспределитьТранспортные = ДанныеПечати.Ссылка.РаспределитьТранспортные
				КонецЕсли;
				Если  КоличествоСтрок = СчетСтрок И РаспределитьТранспортные Тогда
					ПоследняяСумма=ДанныеПечати.Ссылка.Товары.ИТОГ("Сумма")-Сумма;
					Область.Параметры.Сумма=ПоследняяСумма;
					ИтогНДС=ДанныеПечати.Ссылка.Товары.ИТОГ("СуммаНДС");
					Сумма=ДанныеПечати.Ссылка.Товары.ИТОГ("Сумма");
					Область.Параметры.Цена = ?(ВыборкаПоТоварам.Количество,ПоследняяСумма/ВыборкаПоТоварам.Количество,0);
					
				иначе	
					Область.Параметры.Сумма = ВыборкаПоТоварам.Сумма;
					Сумма          = Сумма          + ВыборкаПоТоварам.Сумма;
					ИтогНДС          = ИтогНДС          + ВыборкаПоТоварам.СуммаНДС;
					Область.Параметры.Цена = ?(ВыборкаПоТоварам.Количество,ВыборкаПоТоварам.Сумма/ВыборкаПоТоварам.Количество,0);
				конецесли;
				СчетСтрок = СчетСтрок + 1;
				СуммаСкидки          = СуммаСкидки          + ВыборкаПоТоварам.СуммаСкидки;
				
				стрТовар= СокрЛП(ВыборкаПоТоварам.Номенклатура);
				Если ЗначениеЗаполнено(ВыборкаПоТоварам.Характеристика) Тогда
					стрТовар= стрТовар+", "+ СокрЛП(ВыборкаПоТоварам.Характеристика);
				КонецЕсли;
				
				Область.Параметры.Товар = стрТовар;
				
				Область.Параметры.Количество = ВыборкаПоТоварам.КоличествоУпаковок;
				Область.Параметры.ЕдиницаЦены = ВыборкаПоТоварам.ПредставлениеЕдининицыИзмеренияУпаковки;
				
				ТабличныйДокумент.Вывести(Область);	
				
			КонецЦикла;
			
			Область = Макет.ПолучитьОбласть("Линия");
			ТабличныйДокумент.Вывести(Область);	

			// Бонусные баллы
			Если Ссылка.ОплатаБаллами Тогда
				Область = Макет.ПолучитьОбласть("ПодвалБонусы");	
				Область.Параметры.СуммаОплатыБаллами= Ссылка.СуммаОплатыБаллами; 
				Область.Параметры.СуммаСкидки = СуммаСкидки;
				СуммаБезСкидки= Сумма+СуммаСкидки;
				Область.Параметры.СуммаБезСкидки = СуммаБезСкидки;
				ТабличныйДокумент.Вывести(Область);
			КонецЕсли;
			
			//Подвал Итого
			Область = Макет.ПолучитьОбласть("ПодвалТаблицы");
			Область.Параметры.Всего = Сумма;
			ТабличныйДокумент.Вывести(Область);
			ВыводитьСкидки = ?(ПараметрыПечати.Свойство("ВыводитьСкидки"), ПараметрыПечати.ВыводитьСкидки, Ложь);
			если ВыводитьСкидки И Не Ссылка.ОплатаБаллами тогда
				если СуммаСкидки<>0 тогда
					Область = Макет.ПолучитьОбласть("ПодвалСкидки");	
					Область.Параметры.СуммаСкидки = СуммаСкидки;
					ТабличныйДокумент.Вывести(Область);
				конецесли;
			конецесли;
			
			СуммаКПрописи = Сумма;
			Область = Макет.ПолучитьОбласть("СуммаПрописью");
			ТекстИтоговойСтроки = НСтр("ru = 'Всего наименований %ВсегоНаименований%'");
			ТекстИтоговойСтроки = СтрЗаменить(ТекстИтоговойСтроки,"%ВсегоНаименований%", СчетСтрок-1);
			Область.Параметры.ИтоговаяСтрока = ТекстИтоговойСтроки;
			
			если ИтогНДС=0 тогда
				СуммаНДСРуб="";
			иначе
				СуммаНДСРуб=" , в т.ч. НДС - "+ФормированиеПечатныхФорм.ФорматСумм(итогНДС, Константы.ВалютаРегламентированногоУчета.Получить());
			конецесли;
			Область.Параметры.СуммаПрописью  = РаботаСКурсамиВалют.СформироватьСуммуПрописью(СуммаКПрописи,Константы.ВалютаРегламентированногоУчета.Получить())+СуммаНДСРуб;
			ТабличныйДокумент.Вывести(Область);
			
			Область = Макет.ПолучитьОбласть("Подписи");
			ТабличныйДокумент.Вывести(Область);
			
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ДанныеПечати.Ссылка);
		КонецЦикла;
	КонецЦикла;
	
	Для Каждого Ссылка Из МассивПроверки Цикл
		Текст = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'В документе %1 отсутствуют товары. Печать расходной накладной не требуется.'"),
		Ссылка
		);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
		Текст,
		Ссылка
		);
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Если ПараметрыПечати.Свойство("ИмяПринтера") Тогда
		ТабличныйДокумент.ИмяПринтера= ПараметрыПечати.ИмяПринтера;
	КонецЕсли;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ПечатьВнутреннееПотреблениеТоваровСумма(МассивОбъектов, ОбъектыПечати)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка КАК Ссылка,
	|	ВнутреннееПотреблениеТоваровТовары.Номенклатура КАК Номенклатура,
	|	ВнутреннееПотреблениеТоваровТовары.Характеристика КАК Характеристика,
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка.Дата,
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка.Номер,
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка.Склад,
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка.Организация,
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка.Подразделение,
	|	ВнутреннееПотреблениеТоваровТовары.НомерСтроки КАК НомерСтроки,
	|	ВнутреннееПотреблениеТоваровТовары.Количество КАК Количество,
	|	ВЫБОР
	|		КОГДА ВнутреннееПотреблениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(ВнутреннееПотреблениеТоваровТовары.Номенклатура.ЕдиницаИзмерения)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ВнутреннееПотреблениеТоваровТовары.Упаковка)
	|	КОНЕЦ КАК Упаковка,
	|	ВЫБОР
	|		КОГДА СебестоимостьТоваровОбороты.КоличествоРасход <> 0
	|			ТОГДА ВнутреннееПотреблениеТоваровТовары.КоличествоУпаковок * (СебестоимостьТоваровОбороты.СуммаДопРасходовПриход + СебестоимостьТоваровОбороты.СтоимостьРасход) / СебестоимостьТоваровОбороты.КоличествоРасход
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК Сумма,
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка.Комментарий
	|ИЗ
	|	РегистрНакопления.СебестоимостьТоваров.Обороты(, , Регистратор, ) КАК СебестоимостьТоваровОбороты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВнутреннееПотреблениеТоваров.Товары КАК ВнутреннееПотреблениеТоваровТовары
	|		ПО СебестоимостьТоваровОбороты.Регистратор = ВнутреннееПотреблениеТоваровТовары.Ссылка
	|			И СебестоимостьТоваровОбороты.АналитикаУчетаНоменклатуры.Номенклатура = ВнутреннееПотреблениеТоваровТовары.Номенклатура
	|ГДЕ
	|	ВнутреннееПотреблениеТоваровТовары.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки
	|ИТОГИ ПО
	|	Ссылка,
	|	Номенклатура";
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ВнутреннееПотреблениеТоваров";
	
	Результат = Запрос.Выполнить();
	
	Макет = ПолучитьМакет("ПФ_MXL_ВнутреннееПотреблениеТоваровСумма");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьПодписи   = Макет.ПолучитьОбласть("Подписи");
	
	ОбластьСтрока       = Макет.ПолучитьОбласть("Строка");
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
	
	РеквизитыДокумента = Новый Структура("Номер, Дата, Префикс");
	СинонимДокумента = Метаданные.Документы.ВнутреннееПотреблениеТоваров.Синоним;
	
	ПервыйДокумент = Истина;
	
	ВыборкаДокументы = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокументы.Следующий() Цикл
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		ЗаполнитьЗначенияСвойств(РеквизитыДокумента, ВыборкаДокументы);
		ОбластьЗаголовок.Параметры.ТекстЗаголовка = ОбщегоНазначенияУТКлиентСервер.СформироватьЗаголовокДокумента(РеквизитыДокумента, СинонимДокумента);
		ОбластьЗаголовок.Параметры.Заполнить(ВыборкаДокументы);
		ТабДокумент.Вывести(ОбластьЗаголовок);
		ТабДокумент.Вывести(ОбластьШапкаТаблицы);
		
		ВыборкаНоменклатура = ВыборкаДокументы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ИтогоСумма=0;
		Пока ВыборкаНоменклатура.Следующий() Цикл
			ВыборкаСтроки = ВыборкаНоменклатура.Выбрать();
			
			Пока ВыборкаСтроки.Следующий() Цикл
				ОбластьСтрока.Параметры.Заполнить(ВыборкаСтроки);
				ИтогоСумма=ИтогоСумма+ВыборкаСтроки.Сумма;
				ОбластьСтрока.Параметры.Номенклатура = НоменклатураКлиентСервер.ПредставлениеНоменклатурыДляПечати(
				ВыборкаСтроки.Номенклатура,
				ВыборкаСтроки.Характеристика
				);
				
				ТабДокумент.Вывести(ОбластьСтрока);
				
			КонецЦикла;
		КонецЦикла;  
		
		// Вывод подвала.
		ОбластьИтогоСумма       = Макет.ПолучитьОбласть("ИтогоСумма");
		ОбластьИтогоСумма.Параметры.ИтогоСумма=ИтогоСумма;
		ТабДокумент.Вывести(ОбластьИтогоСумма);
		
		ТабДокумент.Вывести(ОбластьПодписи);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, ВыборкаДокументы.Ссылка);
	КонецЦикла;
	
	Возврат ТабДокумент;
КонецФункции

