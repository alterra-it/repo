	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Характеристика,
	|	Товары.ЕдИзм КАК ЕдиницаЦены,
	|	Товары.Цена КАК Цена,
	|	Товары.Сумма КАК Сумма,
	|	Товары.СуммаНДС КАК СуммаНДС,
	|	Товары.Дата,
	|	Товары.СуммаСкидки КАК СуммаСкидки,
	|	Товары.Код,
	|	Товары.Количество КАК Количество,
	|	Товары.Склад КАК Склад,
	|	Товары.Количество * &ТекстЗапросаВесНоменклатуры КАК Вес,
	|	Товары.Количество * &ТекстЗапросаОбъемНоменклатуры КАК Объем
	|ИЗ
	|	ВТ_Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|			И (ИСТИНА = РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Код,
	|	Номенклатура,
	|	Склад
	|ИТОГИ
	|	СУММА(Цена),
	|	СУММА(Сумма),
	|	СУММА(СуммаНДС),
	|	СУММА(СуммаСкидки),
	|	СУММА(Количество),
	|	МАКСИМУМ(Склад),
	|	СУММА(Вес),
	|	СУММА(Объем)
	|ПО
	|	Секция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК ЯчейкаДополнительная
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|			И (ЛОЖЬ = РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура";
	
		Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаВесНоменклатуры",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
			"Товары.Номенклатура.ЕдиницаИзмерения",
			"Товары.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаОбъемНоменклатуры",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
			"Товары.Номенклатура.ЕдиницаИзмерения",
			"Товары.Номенклатура"));
	
	Запрос.УстановитьПараметр("МассивДокументов", Ссылка);
	Результат = Запрос.ВыполнитьПакет();
	
	Возврат Результат;
КонецФункции
#КонецОбласти

#Область ЗаданиеНаРазмещение
Функция ЗапросЗаданиеНаРазмещение(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ЗаказПоставщикуТовары.КоличествоУпаковок) КАК КоличествоУпаковок,
