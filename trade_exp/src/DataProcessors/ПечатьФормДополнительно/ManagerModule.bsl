	|	ТаблицаТовары.Серия.Наименование КАК СерияПредставление,
	|	ТаблицаТовары.Количество,
	|	ТаблицаТовары.Количество * ВЫБОР
	|		КОГДА НЕ ЦеныНоменклатуры.Упаковка.Коэффициент ЕСТЬ NULL 
	|				И ЦеныНоменклатуры.Упаковка.Коэффициент <> 0
	|			ТОГДА ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) / ЦеныНоменклатуры.Упаковка.Коэффициент
	|		ИНАЧЕ ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0)
	|	КОНЕЦ КАК Стоимость,
	|	ТаблицаТовары.Операция,
	|	ТаблицаТовары.СвязаннаяНоменклатура,
	|	ТаблицаТовары.СвязаннаяХарактеристика,
	|	ТаблицаТовары.СвязаннаяСерия,
	|	ТаблицаТовары.Номенклатура.НаименованиеПолное КАК ТоварНаименование,
	|	ТаблицаТовары.Номенклатура.ЕдиницаИзмерения.Код КАК ЕдиницаИзмеренияКод,
	|	ТаблицаТовары.Номенклатура.ЕдиницаИзмерения.Наименование КАК ЕдиницаИзмеренияНаименование,
	|	ТаблицаТовары.Номенклатура.Код КАК ТоварКод,
	|	ЛОЖЬ КАК ЭтоВозвратнаяТара
	|ИЗ
	|	ТаблицаТовары КАК ТаблицаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ЦеныНоменклатуры КАК ЦеныНоменклатуры
	|		ПО ТаблицаТовары.Номенклатура = ЦеныНоменклатуры.Номенклатура
	|			И ТаблицаТовары.Характеристика = ЦеныНоменклатуры.Характеристика
	|
	|УПОРЯДОЧИТЬ ПО
	|	ТоварНаименование,
	|	ХарактеристикаПредставление,
	|	СерияПредставление,
	|	ТаблицаТовары.Операция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	КурсыВалютСрезПоследних.КурсЧислитель / КурсыВалютСрезПоследних.КурсЗнаменатель КАК КоэффициентПересчета
	|ИЗ
	|	РегистрСведений.ОтносительныеКурсыВалют.СрезПоследних(
	|			&ДатаОстатков,
	|			Валюта В
	|				(ВЫБРАТЬ ПЕРВЫЕ 1
	|					ВЫРАЗИТЬ(Таблица.ВидЦен КАК Справочник.ВидыЦен).ВалютаЦены
	|				ИЗ
	|					ТаблицаТовары КАК Таблица)
	|				И БазоваяВалюта = &БазоваяВалюта) КАК КурсыВалютСрезПоследних";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Номенклатура.Код", "Номенклатура." + КолонкаКодов);
	
	Запрос.Текст = ТекстЗапроса;
	
	Результаты = Запрос.ВыполнитьПакет();
	РезультатПоШапке = Результаты[3];
	РезультатПоТабличнойЧасти = Результаты[4];
	РезультатКурсВалюты = Результаты[5];
	РезультатСвязанныеТовары = Неопределено;
	
	
	СтруктураВозврата = Новый Структура;
	СтруктураВозврата.Вставить("РезультатПоШапке",			РезультатПоШапке);
	СтруктураВозврата.Вставить("РезультатПоТабличнойЧасти", РезультатПоТабличнойЧасти);
	СтруктураВозврата.Вставить("РезультатКурсВалюты", 		РезультатКурсВалюты);
	СтруктураВозврата.Вставить("РезультатСвязанныеТовары",  РезультатСвязанныеТовары);
	
	Возврат СтруктураВозврата
	
КонецФункции

// Анкеты покупателей
Функция ПечатьАнкеты(МассивОбъектов,ОбъектыПечати,ПараметрыПечати)
	Объект=МассивОбъектов[0];
	Макет = Обработки.ПечатьФормДополнительно.ПолучитьМакет("ПФ_MXL_АнкетаПолученияКарты");
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_АнкетаПолучениеКарты";	
	Область = Макет.ПолучитьОбласть("Заголовок");
	Область.Параметры.Заполнить(Объект);
	Область.Параметры.Заполнить(Объект.Партнер);
	Фамилия = "";
	Имя = "";
	Отчество = "";
	РазобратьФИО(Объект.Партнер, Фамилия, Имя, Отчество);
	Область.Параметры.Фамилия = Фамилия;
	Область.Параметры.Имя = Имя;
	Область.Параметры.Отчество = Отчество;
	Область.Параметры.Телефон = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Объект.Партнер, Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	Область.Параметры.Адрес = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Объект.Партнер, Справочники.ВидыКонтактнойИнформации.АдресПартнера);
	Область.Параметры.ТекущаяДата = ТекущаяДата();
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДок.Вывести(Область);	
	Возврат ТабДок;
КонецФункции

Функция ПечатьАнкетыПостоянногоПокупателя(МассивОбъектов,ОбъектыПечати,ПараметрыПечати)
	ТабДок= Новый ТабличныйДокумент;
	Макет = Обработки.ПечатьФормДополнительно.ПолучитьМакет("MXL_АнкетаПостоянногоПокупателя");
	Область= Макет.ПолучитьОбласть("Анкета");
	
	Для Каждого Ссылка Из МассивОбъектов Цикл
		Если ТипЗнч(Ссылка) = Тип("СправочникСсылка.КартыЛояльности") Тогда
			Клиент= Ссылка.Партнер;
			НомерКарты= Ссылка.Штрихкод;
		ИначеЕсли ТипЗнч(Ссылка) = Тип("СправочникСсылка.Партнеры") Тогда					
			Клиент= Ссылка;
			НомерКарты= "";
		ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ  ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда					
			Клиент= Ссылка.Партнер;
			НомерКарты= Ссылка.КартаЛояльности.Штрихкод;
		КонецЕсли;
		
		Выборка= ПолучитьДанныеДляАнкеты(Клиент);
		Если Выборка.Следующий() Тогда
			Область.Параметры.Заполнить(Выборка);
			Область.Параметры.НомерКарты= НомерКарты;
			Область.Параметры.Дата= ТекущаяДата();
		КонецЕсли;
		
		ТабДок.Вывести(Область);
		
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла;
	
	ТабДок.АвтоМасштаб= Истина;
	
	Возврат ТабДок;
КонецФункции

