	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	Запрос.УстановитьПараметр("ВидЦены", 		   ДокументОснование.ВидЦены);
	Запрос.УстановитьПараметр("ДатаНачалаИнвентаризации", ДокументОснование.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончанияИнвентаризации", ДокументОснование.ДатаОкончания);    
