Функция ПолучитьДанныеДляАнкеты(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Партнеры.Ссылка,
	|	Партнеры.ЮрФизЛицо,
	|	Партнеры.Пол,
	|	Партнеры.ДатаРождения,
	|	Партнеры.Представление КАК ФИО,
	|	ПартнерыКонтактнаяИнформацияПочта.Представление КАК Почта,
	|	ПартнерыКонтактнаяИнформацияТелефон.Представление КАК Телефон
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияТелефон
	|		ПО Партнеры.Ссылка = ПартнерыКонтактнаяИнформацияТелефон.Ссылка
	|			И (&ВидТелефон = ПартнерыКонтактнаяИнформацияТелефон.Вид)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияПочта
	|		ПО Партнеры.Ссылка = ПартнерыКонтактнаяИнформацияПочта.Ссылка
	|			И (&ВидПочта = ПартнерыКонтактнаяИнформацияПочта.Вид)
	|ГДЕ
	|	Партнеры.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("ВидПочта", Справочники.ВидыКонтактнойИнформации.EmailПартнера);
	Запрос.УстановитьПараметр("ВидТелефон", Справочники.ВидыКонтактнойИнформации.ТелефонПартнера);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
КонецФункции

Функция СформироватьДоговорКуплиПродажи(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	ТабДок= Новый ТабличныйДокумент;
	Для Каждого Ссылка Из МассивОбъектов Цикл
		   ЗаполнитьДоговорКуплиРодажи(Ссылка, ТабДок);
	КонецЦикла;
	
	Возврат ТабДок;
КонецФункции

Процедура ЗаполнитьДоговорКуплиРодажи(Ссылка, ТабДок)
	Макет= ПолучитьМакет("ПФ_MXL_ДоговорКуплиПродажи");
	Шапка= Макет.ПолучитьОбласть("Шапка");
	
	ТаблицаСчФактур= Документы.СчетФактураВыданный.СчетаФактурыПоОснованию(Ссылка);
	Если ТаблицаСчФактур.Количество() > 0 Тогда
		Счф= ТаблицаСчФактур[0];
		Шапка.Параметры.Номер= Счф.Номер;
		Шапка.Параметры.Дата= Формат(Счф.Дата,"ДЛФ=DD") ;
	Иначе
		Сообщить("Нет счет-фактуры!");
		Возврат;
	КонецЕсли;
	
	СведеньяОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата,, Ссылка.БанковскийСчетОрганизации);
	СведеньяОКлиента = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Контрагент, Ссылка.Дата, Истина, Ссылка.БанковскийСчетКонтрагента);
	
	Список = "ИНН,ЮридическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет";
	ОписаниеОрганизации= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведеньяОбОрганизации, Список, Ложь);
	ОписаниеКлиента= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведеньяОКлиента, Список, Ложь);
	
	Шапка.Параметры.НаименованиеОрганизации= СведеньяОбОрганизации.ПолноеНаименование;
	Шапка.Параметры.НаименованиеКлиента= СведеньяОКлиента.ПолноеНаименование;
	
	Шапка.Параметры.ОписаниеОрганизации= ОписаниеОрганизации;
	Шапка.Параметры.ОписаниеКлиента= ОписаниеКлиента;
	
	Шапка.Параметры.СуммаДокумента= Ссылка.СуммаДокумента;
	Шапка.Параметры.СуммаДокументаПрописью= РаботаСКурсамиВалют.СформироватьСуммуПрописью(Ссылка.СуммаДокумента, Константы.ВалютаРегламентированногоУчета.Получить());
	
	ТабДок.АвтоМасштаб= Истина;
	ТабДок.Защита= Ложь;
	ТабДок.ТолькоПросмотр= Ложь;
	
	ТабДок.Вывести(Шапка);
КонецПроцедуры

#КонецЕсли