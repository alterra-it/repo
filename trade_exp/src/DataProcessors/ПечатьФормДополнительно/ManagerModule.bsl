	ОбластьЗаголовок.Параметры.НомерОчереди= ""+Очередь+Прав(СокрЛП(Ссылка.Номер), 3);
	ОбластьЗаголовок.Параметры.РасходнаяНакладная= Ссылка;
	ОбластьЗаголовок.Параметры.ДатаОтгрузки= Ссылка.ПрибытиеНаОтгрузку;
	ТабДок.Вывести(ОбластьЗаголовок);
	
	Запрос = Новый Запрос;
