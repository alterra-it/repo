	|			ТОГДА ЗаказПоставщикуТовары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ ЗаказПоставщикуТовары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ КАК ЕдИзм,
	|	СУММА(ЗаказПоставщикуТовары.Цена) КАК Цена,
	|	СУММА(ЗаказПоставщикуТовары.СуммаСНДС) КАК Сумма,
	|	СУММА(ВЫБОР
	|			КОГДА ЗаказПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|				ТОГДА &ТекстЗапросаВесНоменклатурыЗ * ЗаказПоставщикуТовары.КоличествоУпаковок
	|			ИНАЧЕ ЗаказПоставщикуТовары.КоличествоУпаковок * ЗаказПоставщикуТовары.Упаковка.Вес
	|		КОНЕЦ) КАК Вес,
	|	СУММА(ЗаказПоставщикуТовары.СуммаНДС) КАК СуммаНДС,
	|	СУММА(ВЫБОР
	|			КОГДА ЗаказПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|				ТОГДА &ТекстЗапросаОбъемНоменклатурыЗ * ЗаказПоставщикуТовары.КоличествоУпаковок
	|			ИНАЧЕ ЗаказПоставщикуТовары.КоличествоУпаковок * ЗаказПоставщикуТовары.Упаковка.Объем
	|		КОНЕЦ) КАК Объем,
	|	ЗаказПоставщикуТовары.Номенклатура.Код КАК Код,
	|	ЗаказПоставщикуТовары.Ссылка.Склад КАК Склад
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ЗаказПоставщикуТовары.Номенклатура,
	|	ЗаказПоставщикуТовары.Номенклатура.Код,
	|	ЗаказПоставщикуТовары.Ссылка.Склад,
	|	ВЫБОР
	|		КОГДА ЗаказПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ЗаказПоставщикуТовары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ ЗаказПоставщикуТовары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	СУММА(ПеремещениеТоваровТовары.КоличествоУпаковок),
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	СУММА(0),
	|	СУММА(0),
	|	СУММА(ВЫБОР
	|			КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|				ТОГДА &ТекстЗапросаВесНоменклатурыП * ПеремещениеТоваровТовары.КоличествоУпаковок
	|			ИНАЧЕ ПеремещениеТоваровТовары.КоличествоУпаковок * ПеремещениеТоваровТовары.Упаковка.Вес
	|		КОНЕЦ),
	|	СУММА(0),
	|	СУММА(ВЫБОР
	|			КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|				ТОГДА &ТекстЗапросаОбъемНоменклатурыП * ПеремещениеТоваровТовары.КоличествоУпаковок
	|			ИНАЧЕ ПеремещениеТоваровТовары.КоличествоУпаковок * ПеремещениеТоваровТовары.Упаковка.Объем
	|		КОНЕЦ),
	|	ПеремещениеТоваровТовары.Номенклатура.Код,
	|	ПеремещениеТоваровТовары.Ссылка.СкладПолучатель
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.Номенклатура.Код,
	|	ПеремещениеТоваровТовары.Ссылка.СкладПолучатель,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК ОснЯчейка,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК Секция,
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	ВТ_Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВТ_Товары.ЕдИзм КАК ЕдИзм,
	|	ВТ_Товары.Цена КАК Цена,
	|	ВТ_Товары.Сумма КАК Сумма,
	|	ВТ_Товары.Вес КАК Вес,
	|	ВТ_Товары.СуммаНДС КАК СуммаНДС,
	|	ВТ_Товары.Объем КАК Объем,
	|	ВТ_Товары.Код КАК Код,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкамДоп.Ячейка КАК ДопЯчейка
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|			И (ИСТИНА = РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкамДоп
	|		ПО ВТ_Товары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкамДоп.Номенклатура
	|			И ВТ_Товары.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкамДоп.Склад
	|			И (ЛОЖЬ = РазмещениеНоменклатурыПоСкладскимЯчейкамДоп.ОсновнаяЯчейка)
	|ИТОГИ
	|	МАКСИМУМ(ОснЯчейка),
	|	СУММА(КоличествоУпаковок),
	|	МАКСИМУМ(ЕдИзм),
	|	СУММА(Цена),
	|	СУММА(Сумма),
	|	СУММА(Вес),
	|	СУММА(СуммаНДС),
	|	СУММА(Объем),
	|	МАКСИМУМ(Код),
	|	МАКСИМУМ(ДопЯчейка)
	|ПО
	|	Секция,
	|	Номенклатура";
	
	Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаВесНоменклатурыЗ",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
			"ЗаказПоставщикуТовары.Номенклатура.ЕдиницаИзмерения",
			"ЗаказПоставщикуТовары.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаОбъемНоменклатурыЗ",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
			"ЗаказПоставщикуТовары.Номенклатура.ЕдиницаИзмерения",
			"ЗаказПоставщикуТовары.Номенклатура"));
		
		Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаВесНоменклатурыП",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
			"ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения",
			"ПеремещениеТоваровТовары.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
		Запрос.Текст, 
		"&ТекстЗапросаОбъемНоменклатурыП",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
			"ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения",
			"ПеремещениеТоваровТовары.Номенклатура"));

	Запрос.УстановитьПараметр("Ссылка", Документы.ЗаказПоставщику.ПустаяСсылка());
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Иначе
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Запрос.УстановитьПараметр("Ссылка", Ссылка);
		Иначе	
			Если Ссылка.Основание <> Неопределено Тогда
				Если ТипЗнч(Ссылка.Основание) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
					Запрос.УстановитьПараметр("Ссылка", Ссылка.Основание);
				Иначе
					Если ТипЗнч(Ссылка.Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
						Запрос.УстановитьПараметр("Ссылка", Ссылка.Основание);
					Иначе
						Если Ссылка.Основание <> Неопределено Тогда
							Если ТипЗнч(Ссылка.Основание.Основание) = Тип("ДокументСсылка.ЗаказПоставщику")  Тогда
								Запрос.УстановитьПараметр("Ссылка", Ссылка.Основание.Основание);
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
КонецФункции

Функция СформироватьПечатнуюФормуЗаданиеНаРазмещение(МассивОбъектов, ОбъектыПечати, ПараметрыПечати) Экспорт
	
	Макет = Обработки.ПечатьФормДополнительно.ПолучитьМакет("ПФ_MXL_ЗаданиеНаРазмещение");
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб= Истина;
	
	Если  МассивОбъектов.Количество() > 0 Тогда
		Ссылка= МассивОбъектов[0];		
	КонецЕсли;
	
	ОбластьШтрихкода= Макет.ПолучитьОбласть("ОбластьШтрихкода");
	ОбластьЗаголовок= Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапка= Макет.ПолучитьОбласть("Шапка");
	ОбластьСекция= Макет.ПолучитьОбласть("Секция");
	ОбластьСтрока= Макет.ПолучитьОбласть("Строка");
	ОбластьПодвал= Макет.ПолучитьОбласть("Подвал");
	ОбластьОтрыва= Макет.ПолучитьОбласть("ЛистОтрыва");
	ОбластьПоставка = Макет.ПолучитьОбласть("ОбластьСекция");
	
	ОбластьПодвал.Параметры.Комментарий= Ссылка.Комментарий;	
	
	СведеньяОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата);
	ОбластьЗаголовок.Параметры.Организация= СведеньяОбОрганизации.ПолноеНаименование;
	ОбластьЗаголовок.Параметры.Поставщик= Ссылка.Контрагент;
	ОбластьЗаголовок.Параметры.Склад= Ссылка.Склад;
	Если ЗначениеЗаполнено(Ссылка.Основание) Тогда
		ОбластьЗаголовок.Параметры.НомерЗаказа= Ссылка.Основание.Номер;
		ОбластьЗаголовок.Параметры.ДатаЗаказа= Ссылка.Основание.Дата;
	КонецЕсли;
	ОбластьЗаголовок.Параметры.ТекущаяДата= Формат(ТекущаяДата(), "");
		
	ОбластьОтрыва.Параметры.Организация= ОбластьЗаголовок.Параметры.Организация;
	ОбластьОтрыва.Параметры.Поставщик= ОбластьЗаголовок.Параметры.Поставщик;
	ОбластьОтрыва.Параметры.Склад= ОбластьЗаголовок.Параметры.Склад;
	ОбластьОтрыва.Параметры.НомерЗаказа= ОбластьЗаголовок.Параметры.НомерЗаказа;
	ОбластьОтрыва.Параметры.ДатаЗаказа= ОбластьЗаголовок.Параметры.ДатаЗаказа;
	ОбластьОтрыва.Параметры.ТекущаяДата= Формат(ТекущаяДата(), "");
	
	Результат= ЗапросЗаданиеНаРазмещение(Ссылка);

	СчетСтраниц=1;
	ОбластьШапка.Параметры.СчетСтраниц= СчетСтраниц;	
	
	Ном= 0;
	ВыборкаСекция = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Секция");
	
	КоличествоСекций = ВыборкаСекция.Количество();
	ТекущийНомерСекции = 0;
	
	Если КоличествоСекций = 0 Тогда
		 ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабДок, Макет, ОбластьОтрыва, Ссылка);
		 ТабДок.Вывести(ОбластьОтрыва);
	КонецЕсли;
	
	Пока	ВыборкаСекция.Следующий() Цикл 

	ТекущийНомерСекции = ТекущийНомерСекции +1;
	
	ОбластьПоставка.Параметры.Заполнить(ВыборкаСекция);
    ТабДок.Вывести(ОбластьПоставка);

	ТабДок.Вывести(ОбластьЗаголовок);

    ТабДок.Вывести(ОбластьШапка);

	ВыборкаНоменклатура = ВыборкаСекция.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Номенклатура");
	Пока	ВыборкаНоменклатура.Следующий() Цикл 
		// В цикле получаем строку доп. ячеек
		ВыборкаДетальныеЗаписи = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
		ДопЯчейки= "";
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДопЯчейки= ДопЯчейки+ ВыборкаДетальныеЗаписи.ДопЯчейка+";";
		КонецЦикла;
		
		ДопЯчейки= Лев(ДопЯчейки, СтрДлина(ДопЯчейки)-1);
		Ном= Ном+1;
		
		ОбластьСтрока.Параметры.Заполнить(ВыборкаНоменклатура);
		
		ОбластьСтрока.Параметры.Ном= Ном;
		ОбластьСтрока.Параметры.ДопЯчейки= ДопЯчейки;
		
		//Проверка вывода 
		мОблостей= Новый Массив;
		мОблостей.Добавить(ОбластьСтрока);
		мОблостей.Добавить(ОбластьПодвал);
		Если ТекущийНомерСекции = КоличествоСекций Тогда
		мОблостей.Добавить(ОбластьОтрыва);
		КонецЕсли;
		Если ТабДок.ПроверитьВывод(мОблостей) Тогда
			ТабДок.Вывести(ОбластьСтрока);
		Иначе
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
			СчетСтраниц= СчетСтраниц+1;
			ОбластьШапка.Параметры.СчетСтраниц= СчетСтраниц;
			ТабДок.Вывести(ОбластьШапка);
			ТабДок.Вывести(ОбластьСтрока);
		КонецЕсли;
		
	КонецЦикла;
	
	ТабДок.Вывести(ОбластьПодвал);
	
	Если ТекущийНомерСекции = КоличествоСекций Тогда
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабДок, Макет, ОбластьОтрыва, Ссылка);
		ТабДок.Вывести(ОбластьОтрыва);
	Иначе
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЕсли;
    
КонецЦикла;

	Возврат ТабДок;
КонецФункции

#КонецОбласти

Функция СформироватьПечатнуюФормуИНВ19(ДокументОснование, ОбъектыПечати, ПараметрыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ИНВ19";
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеДляПечати = ПолучитьДанныеДляПечатнойФормыИНВ19(ДокументОснование);
	
	Если НЕ ЗначениеЗаполнено(ДанныеДляПечати) Тогда
		Возврат ТабличныйДокумент;
	КонецЕсли;
	
	ЗаполнитьТабличныйДокументИНВ19(ТабличныйДокумент, ДанныеДляПечати, ОбъектыПечати);
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Процедура ЗаполнитьТабличныйДокументИНВ19(ТабличныйДокумент, ДанныеДляПечати, ОбъектыПечати)
	
	ТабличныйДокумент.ПолеСверху = 10;
	ТабличныйДокумент.ПолеСлева = 10;
	ТабличныйДокумент.ПолеСнизу = 10;
	ТабличныйДокумент.ПолеСправа = 10;
	ТабличныйДокумент.РазмерКолонтитулаСверху = 0;
	ТабличныйДокумент.РазмерКолонтитулаСнизу = 0;
	ТабличныйДокумент.АвтоМасштаб = Ложь;
	ТабличныйДокумент.МасштабПечати = 89;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	
	Шапка = ДанныеДляПечати.РезультатПоШапке.Выбрать();
	Шапка.Следующий();
	ТаблицаТоваров = ДанныеДляПечати.РезультатПоТабличнойЧасти.Выгрузить();
	
	Если ДанныеДляПечати.РезультатКурсВалюты <> Неопределено И ДанныеДляПечати.РезультатСвязанныеТовары = Неопределено Тогда
		ПечатьПоВидуЦен = Истина;
		КурсВалюты = ДанныеДляПечати.РезультатКурсВалюты.Выбрать();
		Если КурсВалюты.Следующий() Тогда
			КоэффициентПересчета = КурсВалюты.КоэффициентПересчета;
		Иначе
			КоэффициентПересчета = 1;
		КонецЕсли;
	ИначеЕсли ДанныеДляПечати.РезультатКурсВалюты = Неопределено И ДанныеДляПечати.РезультатСвязанныеТовары <> Неопределено Тогда
		ПечатьПоВидуЦен = Ложь;
		КоэффициентПересчета = 1;
	Иначе       		
		ТекстСообщения = НСтр("ru='Неверные данные для печати.'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;		
	КонецЕсли;
	
	Если ТаблицаТоваров.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='В рамках периода документа ""%Опись%"" не были оформлены складские акты. Нет данных для формирования печатной формы ""ИНВ-19""'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Опись%", Шапка.Ссылка);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Обработка.ПечатьИНВ19.ПФ_MXL_ИНВ19");
	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапки = Макет.ПолучитьОбласть("ШапкаТаблицы");     
	ОбластьСтроки = Макет.ПолучитьОбласть("Строка");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ОбластьШапки_Лист2 = Макет.ПолучитьОбласть("ШапкаТаблицы_Лист2");     
	МассивСтрок_Лист2 = Новый ТабличныйДокумент;
	ОбластьСтроки_Лист2 = Макет.ПолучитьОбласть("Строка_Лист2");
	ОбластьПодвал_Лист2 = Макет.ПолучитьОбласть("Подвал_Лист2");
	
	ОбластьЗаголовок.Параметры.Заполнить(Шапка);
	ОбластьЗаголовок.Параметры.ДолжностьМОЛ1  = Шапка.ДолжностьКладовщика;
	ОбластьЗаголовок.Параметры.ФИОМОЛ1        = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(Шапка.Кладовщик);
	ОбластьЗаголовок.Параметры.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.ПолучитьНомерНаПечать(Шапка.НомерДокумента);
	ОбластьЗаголовок.Параметры.ОснованиеНомер = ПрефиксацияОбъектовКлиентСервер.ПолучитьНомерНаПечать(Шапка.ОснованиеНомер);
	
	ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьЗаголовок, Шапка.Ссылка);
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
	
	ИтоговыеСуммы = Новый Структура;
	
	ИтоговыеСуммы.Вставить("ИтогоРезультатИзлишекКолво",0);
	ИтоговыеСуммы.Вставить("ИтогоРезультатИзлишекСумма",0);
	ИтоговыеСуммы.Вставить("ИтогоРезультатНедостачаКолво",0);
	ИтоговыеСуммы.Вставить("ИтогоРезультатНедостачаСумма",0);
	
	ИтоговыеСуммы.Вставить("ИтогоПересортИзлишкиКолво",0);
	ИтоговыеСуммы.Вставить("ИтогоПересортИзлишкиСумма",0);
	ИтоговыеСуммы.Вставить("ИтогоПересортНедостачиКолво",0);
	ИтоговыеСуммы.Вставить("ИтогоПересортНедостачиСумма",0);
	
	ИтоговыеСуммы.Вставить("ИтогоПриходИзлишковКолво",0);
	ИтоговыеСуммы.Вставить("ИтогоПриходИзлишковСумма",0);
	ИтоговыеСуммы.Вставить("ИтогоСписаниеНедостачКолонкаКолво",0);
	ИтоговыеСуммы.Вставить("ИтогоСписаниеНедостачКолонкаСумма",0);
	
	НомерСтроки = 0;
	НомерСтраницы = 1;
	ПервыйНомерСтроки = 1;
	
	КоличествоСтрок = ТаблицаТоваров.Количество();
	
	ТаблицаТоваровРезультат = Новый ТаблицаЗначений;
	ТаблицаТоваровРезультат.Колонки.Добавить("НомерСтроки");
	ТаблицаТоваровРезультат.Колонки.Добавить("НомерСвязаннойСтроки");
	ТаблицаТоваровРезультат.Колонки.Добавить("Номенклатура");
	ТаблицаТоваровРезультат.Колонки.Добавить("Характеристика");
	ТаблицаТоваровРезультат.Колонки.Добавить("Серия");
	ТаблицаТоваровРезультат.Колонки.Добавить("ТоварНаименование");
	ТаблицаТоваровРезультат.Колонки.Добавить("ТоварКод");
	ТаблицаТоваровРезультат.Колонки.Добавить("ЕдиницаИзмеренияКод");
	ТаблицаТоваровРезультат.Колонки.Добавить("ЕдиницаИзмеренияНаименование");
	ТаблицаТоваровРезультат.Колонки.Добавить("КоличествоИзлишков");
	ТаблицаТоваровРезультат.Колонки.Добавить("СуммаИзлишков");
	ТаблицаТоваровРезультат.Колонки.Добавить("КоличествоНедостачи");
	ТаблицаТоваровРезультат.Колонки.Добавить("СуммаНедостачи");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПересортИзлишкиКолво");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПересортИзлишкиСумма");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПересортИзлишкиНомер");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПересортНедостачиКолво");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПересортНедостачиСумма");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПересортНедостачиНомер");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПриходИзлишковКолво");
	ТаблицаТоваровРезультат.Колонки.Добавить("ПриходИзлишковСумма");
	ТаблицаТоваровРезультат.Колонки.Добавить("СписаниеНедостачКолонкаКолво");
	ТаблицаТоваровРезультат.Колонки.Добавить("СписаниеНедостачКолонкаСумма");
	
	Если Не ПечатьПоВидуЦен Тогда
		ТаблицаСвязанныхТоваров = ДанныеДляПечати.РезультатСвязанныеТовары.Выгрузить();
	КонецЕсли;	
	
	//Организовываем таблицу значений с товарами, организуя при этом связанные строки
	Для каждого СтрокаТоваров Из ТаблицаТоваров Цикл
		
		Если СтрокаТоваров.Операция = "1_Списание" Тогда
			НоваяСтрока = НоваяСтрокаТаблицыРезультатов(ТаблицаТоваровРезультат, СтрокаТоваров, НомерСтроки);
			
			НоваяСтрока.КоличествоИзлишков = 0;	
			НоваяСтрока.СуммаИзлишков = 0;	
			
			НоваяСтрока.КоличествоНедостачи = СтрокаТоваров.Количество;	
			НоваяСтрока.СуммаНедостачи = СтрокаТоваров.Стоимость * КоэффициентПересчета;	
			
			НоваяСтрока.ПересортИзлишкиКолво = 0;	
			НоваяСтрока.ПересортИзлишкиСумма = 0;	
			НоваяСтрока.ПересортИзлишкиНомер = 0;	
			
			НоваяСтрока.ПересортНедостачиКолво = 0;	
			НоваяСтрока.ПересортНедостачиСумма = 0;	
			НоваяСтрока.ПересортНедостачиНомер = 0;	
			
			НоваяСтрока.ПриходИзлишковКолво = 0;	
			НоваяСтрока.ПриходИзлишковСумма = 0;	
			
			НоваяСтрока.СписаниеНедостачКолонкаКолво = СтрокаТоваров.Количество;	
			НоваяСтрока.СписаниеНедостачКолонкаСумма = СтрокаТоваров.Стоимость * КоэффициентПересчета;	
			
			ИтоговыеСуммы.ИтогоРезультатНедостачаКолво = 
			ИтоговыеСуммы.ИтогоРезультатНедостачаКолво + СтрокаТоваров.Количество;
			
			ИтоговыеСуммы.ИтогоРезультатНедостачаСумма = 
			ИтоговыеСуммы.ИтогоРезультатНедостачаСумма + СтрокаТоваров.Стоимость * КоэффициентПересчета;
			
			ИтоговыеСуммы.ИтогоСписаниеНедостачКолонкаКолво = 
			ИтоговыеСуммы.ИтогоСписаниеНедостачКолонкаКолво + СтрокаТоваров.Количество;
			
			ИтоговыеСуммы.ИтогоСписаниеНедостачКолонкаСумма = 
			ИтоговыеСуммы.ИтогоСписаниеНедостачКолонкаСумма + СтрокаТоваров.Стоимость * КоэффициентПересчета;
			
		ИначеЕсли СтрокаТоваров.Операция = "2_Оприходование" Тогда
			НоваяСтрока = НоваяСтрокаТаблицыРезультатов(ТаблицаТоваровРезультат, СтрокаТоваров, НомерСтроки);
			
			НоваяСтрока.КоличествоИзлишков = СтрокаТоваров.Количество;	
			НоваяСтрока.СуммаИзлишков = СтрокаТоваров.Стоимость;	
			
			НоваяСтрока.КоличествоНедостачи = 0;	
			НоваяСтрока.СуммаНедостачи = 0;	
			
			НоваяСтрока.ПересортИзлишкиКолво = 0;	
			НоваяСтрока.ПересортИзлишкиСумма = 0;	
			НоваяСтрока.ПересортИзлишкиНомер = 0;	
			
			НоваяСтрока.ПересортНедостачиКолво = 0;	
			НоваяСтрока.ПересортНедостачиСумма = 0;	
			НоваяСтрока.ПересортНедостачиНомер = 0;	
			
			НоваяСтрока.ПриходИзлишковКолво = СтрокаТоваров.Количество;	
			НоваяСтрока.ПриходИзлишковСумма = СтрокаТоваров.Стоимость * КоэффициентПересчета;	
			
			НоваяСтрока.СписаниеНедостачКолонкаКолво = 0;	
			НоваяСтрока.СписаниеНедостачКолонкаСумма = 0;
			
			ИтоговыеСуммы.ИтогоРезультатИзлишекКолво = 
			ИтоговыеСуммы.ИтогоРезультатИзлишекКолво + СтрокаТоваров.Количество;
			
			ИтоговыеСуммы.ИтогоРезультатИзлишекСумма = 
			ИтоговыеСуммы.ИтогоРезультатИзлишекСумма + СтрокаТоваров.Стоимость * КоэффициентПересчета;
			
			ИтоговыеСуммы.ИтогоПриходИзлишковКолво = 
			ИтоговыеСуммы.ИтогоПриходИзлишковКолво + СтрокаТоваров.Количество;
			
			ИтоговыеСуммы.ИтогоПриходИзлишковСумма = 
			ИтоговыеСуммы.ИтогоПриходИзлишковСумма + СтрокаТоваров.Стоимость * КоэффициентПересчета;
			
		ИначеЕсли СтрокаТоваров.Операция = "3_ПересортицаСписание" Тогда
			Если ПечатьПоВидуЦен Тогда
				НоваяСтрока = НоваяСтрокаТаблицыРезультатов(ТаблицаТоваровРезультат, СтрокаТоваров, НомерСтроки);
				
				НоваяСтрока.КоличествоИзлишков = 0;	
				НоваяСтрока.СуммаИзлишков = 0;	
				
