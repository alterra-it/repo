		ТекстСообщения = НСтр("ru = 'Печать %Документ% не выполнена: в указанный инвентаризационный период не найдены складские документы товаров.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Документ%", Строка(ДокументОснование));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ДокументОснование);
		Возврат Неопределено
	КонецЕсли;
	
	ДатаНачала 						  = НачалоДня(ПредварительныеДанныеРезультат.Дата);
	ДатаОкончания 					  = КонецДня(ПредварительныеДанныеРезультат.Дата);
