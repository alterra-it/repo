#КонецОбласти

#Область ТНСекции
Функция СформироватьПечатнуюФормуПечатьТНСекцииРеализацияНов(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	Макет = ПолучитьМакет("ПФ_MXL_ПечатьТНСекции");
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	Если  МассивОбъектов.Количество() > 0 Тогда
		Ссылка= МассивОбъектов[0];		
	Иначе
		Возврат ТабличныйДокумент;
	КонецЕсли;
	
	Если ТипЗнч(Ссылка)  = Тип("ДокументСсылка.ЗаявкиНаДоставку") Тогда
		Ссылка= Ссылка.Основание;
	КонецЕсли;
	
	
	ОбластьИтого  = Макет.ПолучитьОбласть("Итого");
	ОбластьПодписи = Макет.ПолучитьОбласть("Подписи");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
	
	
	ПакетРезультат= ПолучитьДанныеДляПечатиТНСекции(Ссылка);
	Результат= ПакетРезультат[1];
	РезультатДопЯчейки= ПакетРезультат[2];
	ВыборкаПоДопЯчейкам= РезультатДопЯчейки.Выбрать();
	
	ВыборкаПоСекциям= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Секция");
	Пока ВыборкаПоСекциям.Следующий() Цикл
		
		ВывестиШапку(Ссылка, Макет, ВыборкаПоСекциям, ТабличныйДокумент);
		
		СчетСтрок=1;
		НомерСтроки= 0;
		СуммаИтог=0;
		ИтогНДС= 0;
		
		ВыборкаТовары = ВыборкаПоСекциям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");
		Пока ВыборкаТовары.Следующий() Цикл
			СчетСтрок = СчетСтрок + 1;
			НомерСтроки = НомерСтроки + 1;
			ОбластьСтрока.Параметры.НомерСтроки = НомерСтроки;
			ОбластьСтрока.Параметры.Заполнить(ВыборкаТовары);
			ОбластьСтрока.Параметры.Цена = ?(ВыборкаТовары.Количество, ВыборкаТовары.Сумма/ВыборкаТовары.Количество,0);
			
			СуммаИтог = СуммаИтог+ ВыборкаТовары.Сумма;
			ИтогНДС = ИтогНДС+ ВыборкаТовары.СуммаНДС;
			
			стрДопЯчейки= "";
			СтуктураПоиска = Новый Структура("Номенклатура", ВыборкаТовары.Номенклатура);
			Пока ВыборкаПоДопЯчейкам.НайтиСледующий(СтуктураПоиска) Цикл
				стрДопЯчейки= стрДопЯчейки+ВыборкаПоДопЯчейкам.ЯчейкаДополнительная+Символы.ПС;
			КонецЦикла;
			ОбластьСтрока.Параметры.ДопЯчейки= стрДопЯчейки;
			
			ТабличныйДокумент.Вывести(ОбластьСтрока);	
		КонецЦикла;
		
		ОбластьИтого.Параметры.Заполнить(ВыборкаПоСекциям);		
		ТабличныйДокумент.Вывести(ОбластьИтого);
		
		ТекстИтоговойСтроки = НСтр("ru = 'Всего наименований %ВсегоНаименований%'");
		ТекстИтоговойСтроки = СтрЗаменить(ТекстИтоговойСтроки,"%ВсегоНаименований%", СчетСтрок-1);
		
		СуммаНДСРуб=" , в т.ч. НДС - "+ФормированиеПечатныхФорм.ФорматСумм(итогНДС, Константы.ВалютаРегламентированногоУчета.Получить());
		ОбластьПодписи.Параметры.ИтоговаяСтрока = ТекстИтоговойСтроки+", на сумму "+ФормированиеПечатныхФорм.ФорматСумм(СуммаИтог, Константы.ВалютаРегламентированногоУчета.Получить())+суммаНДСруб;
		
		ОбластьПодписи.параметры.ВремяПечати=ТекущаяДата();
		ОбластьПодписи.Параметры.СуммаПрописью  = "Сумма: "+РаботаСКурсамиВалют.СформироватьСуммуПрописью(СуммаИтог,Константы.ВалютаРегламентированногоУчета.Получить());
		ТабличныйДокумент.Вывести(ОбластьПодписи);
		
		ОбластьШтрихкодДокумента= Макет.ПолучитьОбласть("ОбластьШтрихкодДокумента");
		АльтерраОбщегоНазначения.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьШтрихкодДокумента, "КартинкаШтрихкодаДокумента", Ссылка);

		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
КонецФункции

Процедура ВывестиШапку(Ссылка, Макет, ВыборкаПоСекциям, ТабличныйДокумент)
	ОбластьПолоса=		Макет.ПолучитьОбласть("Полоса");
	ОбластьЗаголовок =  Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапки  = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьШтрихкода= Макет.ПолучитьОбласть("ОбластьШтрихкода");
	
	//Шапка заголовок
	СчетФактура=ПродажиСервер.ПредставлениеСчетаФактурыВДокументеПродажи(Ссылка, Ссылка.организация);
	
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОбластьШтрихкода.Параметры.Автор= Ссылка.Менеджер;
		Очередь= Ссылка.Очередь;
		Если ЗначениеЗаполнено(ВыборкаПоСекциям.Секция) Тогда
				СекцияНадпись=  ВыборкаПоСекциям.Секция;
		Иначе
			СекцияНадпись= "";
		КонецЕсли;
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ОбластьШтрихкода.Параметры.Автор= Ссылка.Ответственный;
		Очередь= Перечисления.Очередь.Очередь1;
		СекцияНадпись=  ВыборкаПоСекциям.Секция;
		
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ВозвратТоваровПоставщику") Тогда
		ОбластьШтрихкода.Параметры.Автор= Ссылка.Менеджер;
		СекцияНадпись=  ВыборкаПоСекциям.Секция;
	ИначеЕсли ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЧекККМ") Тогда
		ОбластьШтрихкода.Параметры.Автор= Ссылка.Кассир;
		СекцияНадпись=  ВыборкаПоСекциям.Секция;
	КонецЕсли;
	
	ОбластьЗаголовок.Параметры.НомерОчереди= ""+Очередь+Прав(СокрЛП(Ссылка.Номер), 3);
	Если Найти(СТРОКА(ВыборкаПоСекциям.Склад),"Торг")>0 Тогда
		ТабличныйДокумент.Вывести(ОбластьПолоса);
	КонецЕсли;	
	
	Если Строка(Ссылка.Организация.Наименование) <> "АСК и ИП" Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата), "ПолноеНаименование");
	КонецЕсли;
	ОбластьЗаголовок.Параметры.ПредставлениеАдреса = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Организация, Ссылка.Дата), "ФактическийАдрес");
	Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		если ссылка.перемещениенафилиал тогда
		ОбластьЗаголовок.Параметры.ПредставлениеПоставщика = "ООО Альтерра";
		ОбластьЗаголовок.Параметры.ПредставлениеАдреса = "658083, Алтайский край, Новоалтайск г, Дорожная ул, дом № 42/1";
		конецесли;	
	КонецЕсли;

	Попытка
		ЦентральныйСклад = Справочники.Склады.НайтиПоНаименованию("Центральный склад", Истина);
		ТорговыйЗал = Справочники.Склады.НайтиПоНаименованию("Торговый зал", Истина);
		Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") И ((Ссылка.СкладОтправитель = ЦентральныйСклад И Ссылка.СкладПолучатель = ТорговыйЗал) Или (Ссылка.СкладПолучатель = ЦентральныйСклад И Ссылка.СкладОтправитель = ТорговыйЗал)) Тогда
			ОбластьЗаголовок.Параметры.ПредставлениеДокумента ="Перемещение товаров "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
			ОбластьЗаголовок.Параметры.Отправитель = "Отправитель: ";
			ОбластьЗаголовок.Параметры.Получатель = Символы.ПС + "Получатель: " + Ссылка.СкладПолучатель;
		Иначе
			ОбластьЗаголовок.Параметры.ПредставлениеДокумента ="Расходная накладная "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
		КонецЕсли;
	Исключение
		ОбластьЗаголовок.Параметры.ПредставлениеДокумента ="Расходная накладная "+Ссылка.Номер+" от "+Формат(Ссылка.Дата,"ДФ=""дд ММММ гггг 'г.' """); 
	КонецПопытки;

	Если СчетФактура<>"" И ТипЗнч(Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: "+ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Ссылка.Контрагент, Ссылка.Дата), "ПолноеНаименование,ФактическийАдрес");
	Иначе 
		ОбластьЗаголовок.Параметры.ПредставлениеПокупателя = "Покупатель: ___________________________";
	КонецЕсли;

	ОбластьЗаголовок.Параметры.Секция = СекцияНадпись;
	ОбластьЗаголовок.Параметры.Склад = ВыборкаПоСекциям.Склад;
	
	ВывестиШтрихкодПоСекциям(ТабличныйДокумент, Макет, ОбластьШтрихкода, Ссылка, ?(ВыборкаПоСекциям.Секция= Null, "", ВыборкаПоСекциям.Секция));
	
	ТабличныйДокумент.Вывести(ОбластьЗаголовок);
	
	ТабличныйДокумент.Вывести(ОбластьШапки);
	
КонецПроцедуры

