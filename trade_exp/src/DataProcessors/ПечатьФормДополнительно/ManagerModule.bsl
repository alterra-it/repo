	|	ВЫБОР
	|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ КАК ЕдИзм,
	|	Товары.Цена,
	|	СУММА(Товары.СуммаСНДС + Товары.СуммаСНДС * Товары.Распределять * ВЫБОР
	|			КОГДА РаспределениеУслуг.СуммаТоваров <> 0
	|				ТОГДА РаспределениеУслуг.СуммаУслуг / РаспределениеУслуг.СуммаТоваров
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Сумма,
	|	Товары.Ссылка.Партнер,
	|	СУММА(ВЫБОР
	|			КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|				ТОГДА Товары.Номенклатура.Вес * Товары.КоличествоУпаковок
	|			ИНАЧЕ Товары.КоличествоУпаковок * Товары.Упаковка.Вес
	|		КОНЕЦ) КАК Вес,
	|	СУММА(Товары.СуммаНДС + Товары.СуммаНДС * Товары.Распределять * ВЫБОР
	|			КОГДА РаспределениеУслуг.СуммаТоваров <> 0
	|				ТОГДА РаспределениеУслуг.СуммаУслуг / РаспределениеУслуг.СуммаТоваров
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК СуммаНДС,
	|	Товары.Ссылка.Дата КАК Дата,
	|	Товары.Ссылка.АдресДоставки,
	|	Товары.Ссылка.Водитель КАК Перевозчик,
	|	Товары.СуммаРучнойСкидки + Товары.СуммаАвтоматическойСкидки КАК СуммаСкидки
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СУММА(ВЫБОР
	|					КОГДА РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|						ТОГДА РеализацияТоваровУслугТовары.Сумма
	|					ИНАЧЕ 0
	|				КОНЕЦ) КАК СуммаУслуг,
	|			СУММА(ВЫБОР
	|					КОГДА РеализацияТоваровУслугТовары.Распределять = 1
	|						ТОГДА РеализацияТоваровУслугТовары.Сумма
	|					ИНАЧЕ 0
	|				КОНЕЦ) КАК СуммаТоваров,
	|			РеализацияТоваровУслугТовары.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РеализацияТоваровУслугТовары.Ссылка) КАК РаспределениеУслуг
	|		ПО Товары.Ссылка = РаспределениеУслуг.Ссылка
	|ГДЕ
	|	Товары.Ссылка В(&МассивДокументов)
	|	И ВЫБОР
	|			КОГДА РаспределениеУслуг.СуммаТоваров <> 0
	|				ТОГДА Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Ссылка,
	|	Товары.Ссылка.Контрагент,
	|	Товары.НомерСтроки,
	|	Товары.Номенклатура,
	|	Товары.КоличествоУпаковок,
	|	Товары.Цена,
	|	Товары.Ссылка.Партнер,
	|	Товары.Ссылка.Дата,
	|	Товары.Ссылка.АдресДоставки,
	|	Товары.Ссылка.ТелефонКлиента,
	|	Товары.Ссылка.ПрибытиеНаОтгрузку,
	|	ВЫБОР
	|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	Товары.Ссылка.Водитель,
	|	Товары.СуммаРучнойСкидки + Товары.СуммаАвтоматическойСкидки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Документ КАК Документ,
	|	ВТ_Товары.Контрагент,
	|	ВТ_Товары.ТелефонКлиента,
	|	ВТ_Товары.ПрибытиеНаОтгрузку,
	|	ВТ_Товары.НомерСтроки,
	|	ВТ_Товары.Номенклатура,
	|	ВТ_Товары.КоличествоУпаковок,
	|	ВТ_Товары.ЕдИзм,
	|	ВТ_Товары.Цена,
	|	ВТ_Товары.Сумма КАК Сумма,
	|	ВТ_Товары.Партнер,
	|	ВТ_Товары.Вес КАК Вес,
	|	ВТ_Товары.СуммаНДС КАК СуммаНДС,
	|	ВТ_Товары.Дата,
	|	ВТ_Товары.АдресДоставки,
	|	ВТ_Товары.Перевозчик,
	|	0 КАК ДоляУслуг,
	|	ВТ_Товары.СуммаСкидки
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ИТОГИ
	|	СУММА(Сумма),
	|	СУММА(Вес),
	|	СУММА(СуммаНДС)
	|ПО
	|	ОБЩИЕ,
	|	Документ";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	
	Результат = Запрос.Выполнить();
	
	ОбластьОбщийИтог = Макет.ПолучитьОбласть("Подвал");
	ОбластьСсылка = Макет.ПолучитьОбласть("Заголовок");
	ОбластьДетальныхЗаписей = Макет.ПолучитьОбласть("Детали");
	
	ТабДок.Очистить();
	
	ТабДок.НачатьАвтогруппировкуСтрок();
	
	ВыборкаОбщийИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ВыборкаОбщийИтог.Следующий();	
	ОбластьОбщийИтог.Параметры.Заполнить(ВыборкаОбщийИтог);
	ПервыйДокумент = Истина;
	
	ВыборкаСсылка = ВыборкаОбщийИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		Если Не ПервыйДокумент Тогда
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		ОбластьСсылка.Параметры.Заполнить(ВыборкаСсылка);
		
		Ссылка= ВыборкаСсылка.Документ;
		ОбластьСсылка.Параметры.Контрагент= Ссылка.ФИОКлиента;
		ОбластьСсылка.Параметры.АдресДоставки= Ссылка.АдресДоставки;
		ОбластьСсылка.Параметры.Перевозчик= Ссылка.Перевозчик;
		ОбластьСсылка.Параметры.ПрибытиеНаОтгрузку= Ссылка.ПрибытиеНаОтгрузку;
		ОбластьСсылка.Параметры.ТелефонКлиента= Ссылка.ТелефонКлиента;
		
		ТабДок.Вывести(ОбластьСсылка, ВыборкаСсылка.Уровень());
		
		ВыборкаДетальныеЗаписи = ВыборкаСсылка.Выбрать();
		СчетСтрок=1;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			СчетСтрок=СчетСтрок+1;
			ОбластьДетальныхЗаписей.Параметры.Заполнить(ВыборкаДетальныеЗаписи);
			ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
		КонецЦикла;
		
		ТекстИтоговойСтроки = НСтр("ru = 'Всего наименований %ВсегоНаименований%'");
		ТекстИтоговойСтроки = СтрЗаменить(ТекстИтоговойСтроки,"%ВсегоНаименований%", СчетСтрок-1);
		ОбластьОбщийИтог.Параметры.ИтоговаяСтрока = ТекстИтоговойСтроки;
		
		если ВыборкаСсылка.СуммаНДС=0 тогда
			СуммаНДСРуб="";
		иначе
			СуммаНДСРуб=" , в т.ч. НДС - "+ФормированиеПечатныхФорм.ФорматСумм(ВыборкаСсылка.СуммаНДС, Константы.ВалютаРегламентированногоУчета.Получить());
		конецесли;
		ОбластьОбщийИтог.Параметры.СуммаПрописью  = РаботаСКурсамиВалют.СформироватьСуммуПрописью(ВыборкаСсылка.Сумма,Константы.ВалютаРегламентированногоУчета.Получить())+СуммаНДСРуб;
		ОбластьОбщийИтог.Параметры.ВремяДоставки=ТекущаяДата();
		ТабДок.Вывести(ОбластьОбщийИтог, ВыборкаОбщийИтог.Уровень());
		
		
		
	КонецЦикла;
	
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	возврат ТабДок;
КонецФункции

Функция ПервичныйИнтерес(Партнер, ТолькоПартнер = Ложь)
	
	Интерес = Новый Структура("ИсточникПервичногоИнтереса, Сделка");
	Интерес.Вставить(
	"КаналПервичногоИнтереса",
	ПланыВидовХарактеристик.КаналыРекламныхВоздействий.ПустаяСсылка()
	);
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИсточникиПервичногоИнтереса.КаналПервичногоИнтереса,
	|	ИсточникиПервичногоИнтереса.ИсточникПервичногоИнтереса,
	|	ИсточникиПервичногоИнтереса.Сделка
	|ИЗ
	|	РегистрСведений.ИсточникиПервичногоИнтереса КАК ИсточникиПервичногоИнтереса
	|ГДЕ
	|	ИсточникиПервичногоИнтереса.Партнер = &Партнер";
	
	Если ТолькоПартнер Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|	И ИсточникиПервичногоИнтереса.Сделка = ЗНАЧЕНИЕ(Справочник.СделкиСКлиентами.ПустаяСсылка)";
	КонецЕсли;	
	
	ТекстЗапроса = ТекстЗапроса + "
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИсточникиПервичногоИнтереса.Сделка.ДатаНачала";
	
	Запрос.Текст = ТекстЗапроса;
	
	Запрос.УстановитьПараметр("Партнер", Партнер.Ссылка);
	
	УстановитьПривилегированныйРежим(Истина);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Интерес.КаналПервичногоИнтереса		= Выборка.КаналПервичногоИнтереса;
		Интерес.ИсточникПервичногоИнтереса	= Выборка.ИсточникПервичногоИнтереса;
		Интерес.Сделка						= Выборка.Сделка;
	КонецЕсли;
	
	Возврат Интерес;
	
КонецФункции

Функция ПечатьЛистаСогласования(МассивОбъектов,ОбъектыПечати)
	Макет = Обработки.ПечатьФормДополнительно.ПолучитьМакет("ПФ_MXL_ЛистСогласования");
	ТабДок = Новый ТабличныйДокумент;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Дата,
	|	РеализацияТоваровУслуг.Партнер,
	|	РеализацияТоваровУслуг.Менеджер,
	|	РеализацияТоваровУслуг.Контрагент,
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.Договор
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка В(&МассивДокументов)
	|ИТОГИ ПО
	|	ОБЩИЕ";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	
	Результат = Запрос.Выполнить();
	
	ОбластьСсылка = Макет.ПолучитьОбласть("Заголовок");
	
	ТабДок.Очистить();
	ТабДок.НачатьАвтогруппировкуСтрок();
	ВыборкаОбщийИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаОбщийИтог.Следующий();		
	ПервыйДокумент = Истина;
	
	ВыборкаСсылка = ВыборкаОбщийИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСсылка.Следующий() Цикл
		Если Не ПервыйДокумент Тогда
			ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		ОбластьСсылка.Параметры.Покупатель = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаСсылка.Контрагент, ВыборкаСсылка.Дата), "ПолноеНаименование,ИНН");
		ОбластьСсылка.Параметры.Заголовок="Лист согласования на отпуск товара покупателю № ___________ от "+ФОРМАТ(ВыборкаСсылка.Дата,"ДЛФ=D");
		СчетФактура=ПродажиСервер.ПараметрыПредставленияСчетаФактуры(ВыборкаСсылка.Ссылка,);
		Если СчетФактура.ТекстСчетФактура<>"Создать счет-фактуру" Тогда
			ОбластьСсылка.Параметры.ТекстСчетФактуры=СчетФактура.ТекстСчетФактура;
		конецесли;
		ОбластьСсылка.Параметры.ТекстАвтора="Автор документа: "+ВыборкаСсылка.Менеджер;
		
		ОбластьСсылка.Параметры.Задолженность=Задолженность(ВыборкаСсылка.Договор,ВыборкаСсылка.Ссылка);
		ОбластьСсылка.Параметры.СуммаДокумента=ВыборкаСсылка.Ссылка.СуммаДокумента;
		
		ТабДок.Вывести(ОбластьСсылка, ВыборкаСсылка.Уровень());
		
	КонецЦикла;
	
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	
	возврат ТабДок;
КонецФункции

Функция Задолженность(Договор,Ссылка)
	Суммадолга=0;
	
	СоставРеквизитов = "
	|ОграничиватьСуммуЗадолженности,
	|ДопустимаяСуммаЗадолженности,
	|ВалютаВзаиморасчетов,
	|ЗапрещаетсяПросроченнаяЗадолженность";
	
	Если ЗначениеЗаполнено(Договор) Тогда
		ДанныеДоговора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Договор, СоставРеквизитов);
	Иначе
		ДанныеДоговора = Новый Структура(СоставРеквизитов, Ложь, 0, Неопределено, Ложь);
		
	КонецЕсли;
	
	Если ДанныеДоговора.ОграничиватьСуммуЗадолженности Тогда
		СуммаДолга =- ОстатокДопустимогоКредита(Договор, ДанныеДоговора.ДопустимаяСуммаЗадолженности);
	иначе
		СостояниеРасчетов=Новый Структура("СуммаДолга");
		Документы.РеализацияТоваровУслуг.РассчитатьСостояние(
		Ссылка,
		Договор,СостояниеРасчетов);
		СуммаДолга=СостояниеРасчетов.СуммаДолга;
		
	КонецЕсли;  
	
	возврат СуммаДолга;
КонецФункции
Функция ОстатокДопустимогоКредита(Договор, ДопустимыйКредит)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос(ТекстЗапросаОбъектыРасчетов() + "
	|ВЫБРАТЬ
	|	РасчетыСКлиентамиОстатки.СуммаОстаток КАК ОстатокДолга
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(
	|		,
	|		ЗаказКлиента В (ВЫБРАТЬ ОбъектРасчетов ИЗ ОбъектыРасчетов)
	|	) КАК РасчетыСКлиентамиОстатки
	|");
	Запрос.УстановитьПараметр("Договор", Договор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ОстатокДопустимогоКредита = ДопустимыйКредит - Выборка.ОстатокДолга;
	Иначе
		ОстатокДопустимогоКредита = ДопустимыйКредит;
	КонецЕсли;
	
	Возврат ОстатокДопустимогоКредита;
	
КонецФункции
Функция ТекстЗапросаОбъектыРасчетов()
	
	ТекстЗапроса = "
	|ВЫБРАТЬ
	|	ДанныеДоговора.Ссылка КАК ОбъектРасчетов
	|
	|ПОМЕСТИТЬ ОбъектыРасчетов
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДанныеДоговора
	|ГДЕ
	|	ДанныеДоговора.Ссылка = &Договор
	|	И ДанныеДоговора.ПорядокРасчетов = ЗНАЧЕНИЕ(Перечисление.ПорядокРасчетов.ПоДоговорамКонтрагентов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК ОбъектРасчетов
	|ИЗ
	|	Документ.АктВыполненныхРабот КАК ДанныеДокумента
	|ГДЕ
