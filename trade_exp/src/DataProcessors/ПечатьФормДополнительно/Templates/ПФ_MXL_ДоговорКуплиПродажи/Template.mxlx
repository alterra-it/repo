							<v8:lang>ru</v8:lang>
							<v8:content>- с отсрочкой платежа, в течении ________ дней</v8:content>
						</v8:item>
					</tl>
				</c>
			</c>
		</row>
	</rowsItem>
	<rowsItem>
		<index>35</index>
