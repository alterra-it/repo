
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КоличествоСекундДоЗакрытия = 120;  
	
	ИнициализироватьСписокУстройств();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьСписокУстройств()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрайсЧекерСписокУстройств.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПрайсЧекерСписокУстройств КАК ПрайсЧекерСписокУстройств
		|ГДЕ
		|	НЕ ПрайсЧекерСписокУстройств.ПометкаУдаления";
	
	Элементы.Устройство.СписокВыбора.ЗагрузитьЗначения(Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку(0));
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПодключитьОбработчикОжидания("ПересчитатьКоличествоСекундДоЗакрытия", 1);
	ОткрытьФорму("Обработка.ПрайсЧекер.Форма.Инициализация");
	
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьКоличествоСекундДоЗакрытия()
	
	Если КоличествоСекундДоЗакрытия <= 0 Тогда
		ОтключитьОбработчикОжидания("ПересчитатьКоличествоСекундДоЗакрытия");
	КонецЕсли;
	
	КоличествоСекундДоЗакрытия = КоличествоСекундДоЗакрытия - 1;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	ЗавершитьРаботуСистемы(Ложь, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	Отказ = Истина;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Инициализация(Команда)
	Если Не ЗначениеЗаполнено(Устройство) Тогда  
		ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо указать устройство!");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Устройство) Тогда  
		ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо ввести пароль!");
		Возврат;
	КонецЕсли;
	
	Если ИнициализацияСервер(Устройство, Пароль) Тогда
		ОткрытьФорму("Обработка.ПрайсЧекер.Форма.Инициализация", Новый Структура("Устройство", Устройство));
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю("Пароль неверный!");
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ИнициализацияСервер(Устройство, Пароль)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	Справочник.ПрайсЧекерСписокУстройств КАК ПрайсЧекерСписокУстройств
		|ГДЕ
		|	ПрайсЧекерСписокУстройств.Ссылка = &Устройство
		|	И ПрайсЧекерСписокУстройств.Пароль = &Пароль
		|	И НЕ ПрайсЧекерСписокУстройств.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Устройство", Устройство);
	Запрос.УстановитьПараметр("Пароль", Пароль);
	
	Возврат Запрос.Выполнить().Выбрать().Следующий(); 

КонецФункции

&НаКлиенте
Процедура Назад(Команда)
	ОткрытьФорму("Обработка.ПрайсЧекер.Форма.Инициализация");
КонецПроцедуры

#КонецОбласти

