
&НаКлиенте
Процедура Док_УстановитьСтатусВыгруженоПосле(Команда)	
	УстановитьСтатус("Выгружен");
КонецПроцедуры    

&НаКлиенте
Процедура Док_УстановитьСтатусПодписаноПосле(Команда)
	УстановитьСтатус("Подписан");
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатус(Статус)	
	ВыделенныеСтроки = ОбщегоНазначенияУТКлиент.ПроверитьПолучитьВыделенныеВСпискеСсылки(Элементы.СписокДокументыПродажи);
	Если ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;    
	
	Для Каждого  ДокументСтр Из ВыделенныеСтроки Цикл
		УстановитьСтатусНаДокумент(ДокументСтр, Статус);
	Конеццикла;

	Элементы.СписокДокументыПродажи.Обновить();
КонецПроцедуры

&НаСервере
Процедура УстановитьСтатусНаДокумент(ДокументСтр,Статус)
	
	ДокументОбъект=ДокументСтр.Ссылка.ПолучитьОбъект();
	МетаданныеОбъекта=ДокументОбъект.Метаданные();
	Если Общегоназначения.ЕстьРеквизитОбъекта("СтатусДокументаВЭДО",МетаданныеОбъекта) И ДокументОбъект.СтатусДокументаВЭДО<>перечисления.СтатусыДокументаЭДО[Статус] Тогда
		ДокументОбъект.СтатусДокументаВЭДО = Перечисления.СтатусыДокументаЭДО[Статус];
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
		ДопМодуль.ОбработатьЛистСогласованияПоДокументу(Статус, ДокументСтр.Ссылка);
	КонецЕсли;	
	
КонецПроцедуры

#Область ПоискПоQR

&НаСервере
Функция ПолучитьДокументПродажи(ДокументОплаты)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходныйКассовыйОрдерРасшифровкаПлатежа.ОснованиеПлатежа КАК ОснованиеПлатежа
		|ИЗ
		|	Документ.ПриходныйКассовыйОрдер.РасшифровкаПлатежа КАК ПриходныйКассовыйОрдерРасшифровкаПлатежа
		|ГДЕ
		|	ПриходныйКассовыйОрдерРасшифровкаПлатежа.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", ДокументОплаты);
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		Возврат РезультатЗапроса.ОснованиеПлатежа;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура Док__ДокументПродажиОчисткаПосле(Элемент, СтандартнаяОбработка)
	Элементы._ДокументПродажи.Видимость = Ложь;
	ОчисткаПосле();
КонецПроцедуры         

&НаКлиенте
Процедура ОчиститьПоискQR()
	Элементы.СписокДокументыПродажи_ОчиститьПоискПоQR.Видимость = Ложь;
	ОчисткаПосле();
КонецПроцедуры  

&НаКлиенте
Процедура Док__ОтменитьПоискПоQRПосле(Команда)
	ОчиститьПоискQR();
КонецПроцедуры
	
&НаКлиенте
Процедура ОчисткаПосле()
	_ОтборДокумент.Очистить();
	УстановитьЭлементОтбораДинамическогоСписка();
КонецПроцедуры 
	
Процедура УстановитьЭлементОтбораДинамическогоСписка()
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(
		СписокДокументыПродажи,
		"Ссылка",
		_ОтборДокумент,
		ВидСравненияКомпоновкиДанных.ВСписке,
		,
		ЗначениеЗаполнено(_ОтборДокумент));
КонецПроцедуры

&НаКлиенте
Процедура Док_ОбработкаОповещенияПеред(ИмяСобытия, Параметр, Источник)
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Если Параметр.Количество() > 0 И ТипЗнч(Параметр[0])=Тип("Строка") Тогда
				СтрокаКода = Параметр[0];
				Если СтрНайти(НРег(СтрокаКода), "fn") <> 0 Тогда
					СФП_МаркерыКлиент.МаркерНачало("Журнал документов продажи сканирование");
					
					ОчиститьСообщения();
					СсылкаНаДокумент = АльтерраОбщегоНазначения.ПолучитьСсылкуНаДокументПоQR(СтрокаКода);
					СсылкаНаПродажу = ПолучитьДокументПродажи(СсылкаНаДокумент);
					Если СсылкаНаПродажу<>Неопределено ИЛИ ТипЗнч(СсылкаНаПродажу)=Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
						Элементы.СписокДокументыПродажи_ОчиститьПоискПоQR.Видимость = Истина;
						_ДокументПродажи = СсылкаНаПродажу;
						_ОтборДокумент.Добавить(_ДокументПродажи);
						УстановитьЭлементОтбораДинамическогоСписка();
						МенеджерОборудованияУТКлиент.ОбработатьСобытие();
					Иначе
						ОчиститьПоискQR();
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
&Вместо("ТекстЗапросаСписокДокументыПродажи")
Функция Док_ТекстЗапросаСписокДокументыПродажи()

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	РеестрДокументов.Ссылка КАК Ссылка,  
	|	РеестрДокументов.Ссылка.Кассир КАК Кассир,
	|	РеестрДокументов.НомерДокументаИБ КАК Номер,
	|	РеестрДокументов.ДатаДокументаИБ КАК Дата,
	|	РеестрДокументов.Статус КАК Статус,
	|	РеестрДокументов.Проведен КАК Проведен,
	|	РеестрДокументов.ПометкаУдаления КАК ПометкаУдаления,
	|	РеестрДокументов.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	РеестрДокументов.Партнер КАК Партнер,
	|	ВЫРАЗИТЬ(РеестрДокументов.Контрагент.Ключ КАК Справочник.Контрагенты) КАК Контрагент,
	|	РеестрДокументов.Контрагент КАК КонтрагентКлюч,
	|	РеестрДокументов.Договор КАК Договор,
	|	РеестрДокументов.Организация КАК Организация,
	|	РеестрДокументов.Подразделение КАК Подразделение,
	|	РеестрДокументов.МестоХранения КАК МестоХранения,
	|	ВЫРАЗИТЬ(РеестрДокументов.МестоХранения.Ключ КАК Справочник.Склады) КАК Склад,
	|	РеестрДокументов.Валюта КАК Валюта,
	|	РеестрДокументов.Сумма КАК СуммаДокумента,
	|	РеестрДокументов.Ответственный КАК Менеджер,
	|	РеестрДокументов.Автор КАК Автор,
	|	РеестрДокументов.Комментарий КАК Комментарий,
	|	РеестрДокументов.НомерПервичногоДокумента КАК НомерВходящегоДокумента,
	|	РеестрДокументов.ДатаПервичногоДокумента КАК ДатаВходящегоДокумента,
	|	РеестрДокументов.Дополнительно КАК Дополнительно,
	// ЭлектронноеВзаимодействие.ОбменСКонтрагентами
	|	СостоянияЭД.СостояниеЭДО КАК СостояниеВерсииЭД,
	|	СостоянияЭД.ПредставлениеСостояния КАК ПредставлениеСостояния,
	// Конец ЭлектронноеВзаимодействие.ОбменСКонтрагентами
	|	ВЫБОР
	|		КОГДА ДокументыСОшибкамиПроверкиКонтрагентов.Документ ЕСТЬ NULL
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьОшибкиПроверкиКонтрагентов,
	|	ВЫБОР
	|		КОГДА РеестрДокументов.Проведен
	|			ТОГДА 0
	|		КОГДА РеестрДокументов.ПометкаУдаления
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК НестандартнаяКартинка,
	|	РеестрДокументов.ДополнительнаяЗапись КАК ДополнительнаяЗапись,
	|	РеестрДокументов.ТипСсылки КАК ТипСсылки,
	|	&СтатусПроверки КАК СтатусПроверки,
	|	&ИндикаторПроверки КАК ИндикаторПроверки,
	|	ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) КАК ТипЗначения,
	// СтандартныеПодсистемы.УчетОригиналовПервичныхДокументов
	|	NULL КАК СостояниеОригиналаПервичногоДокумента,
	|	ИСТИНА КАК ОбщееСостояние,
	|	0 КАК СостояниеОригиналПолучен,
	// Конец СтандартныеПодсистемы.УчетОригиналовПервичныхДокументов
	|	РеестрДокументов.СторноИсправление КАК СторноИсправление,
	|	ВЫБОР 
	|		КОГДА НЕ РеестрДокументов.СторноИсправление
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ РеестрДокументов.СторнируемыйДокумент
	|	КОНЕЦ КАК СторнируемыйИсправляемыйДокумент,
	|	ВЫРАЗИТЬ("""" КАК Строка(50)) КАК СостояниеГИСМТ
	|ИЗ
	|	РегистрСведений.РеестрДокументов КАК РеестрДокументов
	|		{
	// ЭлектронноеВзаимодействие.ОбменСКонтрагентами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияПоОбъектамУчетаЭДО КАК СостоянияЭД
	|		ПО (СостоянияЭД.СсылкаНаОбъект = РеестрДокументов.Ссылка)
	// Конец ЭлектронноеВзаимодействие.ОбменСКонтрагентами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыСОшибкамиПроверкиКонтрагентов КАК ДокументыСОшибкамиПроверкиКонтрагентов
	|		ПО РеестрДокументов.Ссылка = ДокументыСОшибкамиПроверкиКонтрагентов.Документ
	|			И (&ИспользованиеПроверкиВозможно)}
	|{ГДЕ
	|	РеестрДокументов.Ссылка.* КАК Ссылка,
	|	РеестрДокументов.МестоХранения.* КАК МестоХранения,
	|	(ВЫРАЗИТЬ(РеестрДокументов.МестоХранения.Ключ КАК Справочник.Склады)).* КАК Склад,
	|	РеестрДокументов.Организация.* КАК Организация,
	|	РеестрДокументов.ДатаДокументаИБ КАК Дата,
	|	РеестрДокументов.НомерДокументаИБ КАК Номер,
	|	РеестрДокументов.Статус КАК Статус,
	|	РеестрДокументов.ТипСсылки КАК ТипСсылки,
	|	РеестрДокументов.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	|	РеестрДокументов.Партнер.* КАК Партнер,
	|	(ВЫРАЗИТЬ(РеестрДокументов.Контрагент.Ключ КАК Справочник.Контрагенты)).* КАК Контрагент,
	|	РеестрДокументов.Договор.* КАК Договор,
	|	РеестрДокументов.Подразделение.* КАК Подразделение,
	|	РеестрДокументов.Ответственный.* КАК Менеджер,
	|	РеестрДокументов.Автор.* КАК Автор,
	|	РеестрДокументов.Дополнительно КАК Дополнительно,
	|	РеестрДокументов.Комментарий КАК Комментарий,
	|	РеестрДокументов.Проведен КАК Проведен,
	|	РеестрДокументов.ПометкаУдаления КАК ПометкаУдаления,
	|	((РеестрДокументов.ДатаДокументаИБ >= &НачалоПериода
	|			ИЛИ &НачалоПериода = ДАТАВРЕМЯ(1, 1, 1))
	|			И (РеестрДокументов.ДатаДокументаИБ <= &КонецПериода
	|				ИЛИ &КонецПериода = ДАТАВРЕМЯ(1, 1, 1)))}";

	Возврат ТекстЗапроса;

КонецФункции

&НаКлиенте
Процедура Док_СписокДокументыПродажиПриАктивизацииСтрокиПосле(Элемент)
	
 ТекДанные = Элементы.СписокДокументыПродажи.ТекущиеДанные;
	 
 Если ТекДанные <> Неопределено Тогда
	 ТекущийДокумент = ТекДанные.Ссылка; 
 КонецЕсли;
 
КонецПроцедуры

#КонецОбласти