		|ГДЕ
		|	АктОРасхожденияхПослеПриемки.Ссылка = &АктОРасхождениях";
		
	КонецЕсли;
	
	#Вставка
	Запрос.Текст = СтрЗаменить(Запрос.Текст,
	"АктОРасхожденияхПослеПриемки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыАктаОРасхождениях.КВыполнению)",
	"АктОРасхожденияхПослеПриемки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыАктаОРасхождениях.КВыполнению) ИЛИ АктОРасхожденияхПослеПриемки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыАктаОРасхождениях.Претензия)");
	#КонецВставки
	
