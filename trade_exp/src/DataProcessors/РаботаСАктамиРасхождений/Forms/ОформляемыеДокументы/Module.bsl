	ИначеЕсли ТипДокумента = "СписаниеНедостачТоваров" Тогда
		ТекстШапки = НСтр("ru = 'Документ ""Списание недостач товаров"" для списания непризнанных недостач'");
	ИначеЕсли ТипДокумента = "КорректировкаЗадолженности" Тогда
		ТекстШапки = НСтр("ru = 'Документ ""Корректировка задолженности"" для отражения задолженности сторонней компании'");
	ИначеЕсли ТипДокумента = "ОприходованиеИзлишковТоваров" Тогда
		ТекстШапки = НСтр("ru = 'Документ ""Оприходование излишков товаров"" для оприходования излишков поставленных товаров'");
	ИначеЕсли ТипДокумента = "ИсправлениеПоступления" Тогда
		ТекстШапки = НСтр("ru = 'Отразить расхождения в документе ""Приобретение товаров и услуг""'");
	ИначеЕсли ТипДокумента = "ИзменениеПоступленияТоваров" Тогда
		ТекстШапки = НСтр("ru = 'Отразить расхождения в документе ""Поступление товаров на склад""'");
	ИначеЕсли ТипДокумента = "КорректировкаПоступленияТоваров" Тогда
		ТекстШапки = НСтр("ru = 'Документ ""Поступление товаров на склад""'");
	ИначеЕсли ТипДокумента = "КорректировкаПоступленияТоваровИсправления" Тогда
		ТекстШапки = НСтр("ru = 'Ввести корректировку документа ""Поступление товаров на склад""'");
	ИначеЕсли ТипДокумента = "ИсправлениеПриемкиТоваровНаХранение" Тогда
			ПредставлениеОбъекта = НСтр("ru = 'Приемка товаров на хранение'");
		ТекстШапки = СтрШаблон(НСтр("ru = 'Отразить расхождения в документе ""%1""'"), ПредставлениеОбъекта);
	ИначеЕсли ТипДокумента = "ВозвратТоваровПоставщикуПоПоступлению" Тогда
		ТекстШапки = НСтр("ru = 'Документ ""Возврат товаров поставщику"" для возврата перепоставленного товара'");
	КонецЕсли;
	
	Если ТипДокумента = "СписаниеНедостачТоваров"
		Или ТипДокумента = "ОприходованиеИзлишковТоваров"   
		Или ТипДокумента = "ПоступлениеТоваровДопоставкаПоПоступлению"
		Или ТипДокумента = "ОтгрузкаТоваровСХраненияПоПриемке"
		Или ТипДокумента = "ВозвратТоваровПоставщикуПоПоступлению" Тогда
		
		Если Описание.ВыводитьСклад Тогда
			
			СтрокаСклад = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'для склада ""%1"".'"), Описание.Склад);
			ТекстШапки = ТекстШапки + " " + СтрокаСклад;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ТипДокумента = "ЭлектронныйДокументПодтверждение" Тогда
		ТекстШапки = НСтр("ru = 'Подтвердить полученный электронный документ'");
	ИначеЕсли ТипДокумента = "ЭлектронныйДокументОтклонение" Тогда
		ТекстШапки = НСтр("ru = 'Отклонить полученный электронный документ'");	
	КонецЕсли;
	
	Возврат ТекстШапки;
	
	Результат = ПродолжитьВызов(ТипДокумента, Описание, ХозяйственнаяОперация);
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура Док_ТабличныйДокументВыборПосле(Элемент, Область, СтандартнаяОбработка)
	
	Если ТипЗнч(Область.Расшифровка) = Тип("Структура") 
		И Область.Расшифровка.ИмяКоманды = "Оформить"
		И ТипЗнч(Область.Расшифровка.Описание) = Тип("Структура")
	Тогда
		Описание = Область.Расшифровка.Описание;
		
		Если Описание.Свойство("ВозможноОформлениеПорчи") Тогда
			
			ОснованиеАкта = Описание.ОснованиеАкта;
			ЭтаФорма_ID = ЭтаФорма.УникальныйИдентификатор;
			ТипДокумента = ТипЗнч(Область.Расшифровка.Данные.ОформляемыйДокумент);
			
			ЭтоПорча = ТипДокумента = Тип("ДокументСсылка.ПорчаТоваров");
			ЭтоОприходование = ТипДокумента = Тип("ДокументСсылка.ОприходованиеИзлишковТоваров");
			ЭтоСписание = ТипДокумента = Тип("ДокументСсылка.СписаниеНедостачТоваров");
			
			
			СоответствиеДанных = Новый Соответствие;
			СоответствиеДанных.Вставить("Порча товаров (создание)", Тип("ДокументСсылка.ПорчаТоваров"));
			СоответствиеДанных.Вставить("Оприходование излишков товаров (создание)", Тип("ДокументСсылка.ОприходованиеИзлишковТоваров"));
			СоответствиеДанных.Вставить("Списание недостач товаров (создание)", Тип("ДокументСсылка.СписаниеНедостачТоваров"));
			
			ОткрытыеОкна = ПолучитьОкна();
			
			Для Каждого ОкноФормы Из ОткрытыеОкна Цикл
				
				Если СоответствиеДанных.Получить(ОкноФормы.Заголовок) <> ТипДокумента Тогда
					Продолжить;
				КонецЕсли;
				
				СодержимоеФормы = ОкноФормы.ПолучитьСодержимое();
				
				Если СодержимоеФормы <> Неопределено
					И СодержимоеФормы.ВладелецФормы <> Неопределено
					И СодержимоеФормы.ВладелецФормы.УникальныйИдентификатор = ЭтаФорма_ID 
					И Не ЗначениеЗаполнено(СодержимоеФормы.Объект.Ссылка) 
				Тогда
				
				    ДокОбъект = СодержимоеФормы.Объект;
					ТЧТовары = ДокОбъект.Товары;
					
					Если ЭтоОприходование Тогда
						Док_СвернутьСтрокиДляОприходования();
						ТаблицаИсточник = ТаблицаСтрокДляОприходования;
					Иначе
						ТаблицаИсточник = ТаблицаСтрокДляПорчи;
					КонецЕсли;
					
					ОтборОснование = Новый Структура("Основание", ОснованиеАкта);
					НайденныеСтроки = ТаблицаИсточник.НайтиСтроки(ОтборОснование);
					
					Если НайденныеСтроки.Количество() Тогда
						
						Если ЭтоПорча Тогда
							ЗаполнитьЗначенияСвойств(ДокОбъект, ПолучитьСтруктуруДанныхИзАкта());
							ТЧТовары.Очистить();
						КонецЕсли;
						
						Для каждого СтрокаТаблицы Из НайденныеСтроки Цикл
							
							Если ЭтоПорча И ОкноФормы.Заголовок = "Порча товаров (создание)" И СтрокаТаблицы.ОстатокПорча > 0 Тогда
								
								ТЧТоварыНоваяСтрока = ТЧТовары.Добавить();
								ЗаполнитьЗначенияСвойств(ТЧТоварыНоваяСтрока, СтрокаТаблицы);
								ТЧТоварыНоваяСтрока.Количество = СтрокаТаблицы.ОстатокПорча;
								
							ИначеЕсли ЭтоОприходование ИЛИ ЭтоСписание Тогда
								
								ДополнениеИмениКолонки = "";
								ИмяКолонкиОстатка = "Остаток";
								КоличествоПоСтроке = 0;
								
								Если ЭтоОприходование Тогда
									ДополнениеИмениКолонки = "Оприходование";
									ИмяКолонкиОстатка = ИмяКолонкиОстатка + ДополнениеИмениКолонки;
									КоличествоПоСтроке = СтрокаТаблицы.ОстатокОприходование;
								Иначе
									ИмяКолонкиОстатка = ИмяКолонкиОстатка + "Списание";
									КоличествоПоСтроке = СтрокаТаблицы.ОстатокСписание;
								КонецЕсли;
								
								СтруктураОтбора = Новый Структура;
								СтруктураОтбора.Вставить("Номенклатура", СтрокаТаблицы["Номенклатура" + ДополнениеИмениКолонки]);
								СтруктураОтбора.Вставить("Характеристика", СтрокаТаблицы["Характеристика" + ДополнениеИмениКолонки]);
								СтруктураОтбора.Вставить("Назначение", СтрокаТаблицы["Назначение" + ДополнениеИмениКолонки]);
								СтруктураОтбора.Вставить("Серия", СтрокаТаблицы["Серия" + ДополнениеИмениКолонки]);
								
								НайденныеСтроки = ТЧТовары.НайтиСтроки(СтруктураОтбора);
								
								Если НайденныеСтроки.Количество() > 0 Тогда
									Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
										Если СтрокаТаблицы[ИмяКолонкиОстатка] = 0 Тогда
											ТЧТовары.Удалить(НайденнаяСтрока);
										Иначе
											НайденнаяСтрока.Количество = КоличествоПоСтроке;	
										КонецЕсли;
										
									КонецЦикла;
								КонецЕсли;
								
							КонецЕсли;
							
						КонецЦикла;
						
					КонецЕсли;
					
					Если ЭтоОприходование И ЗначениеЗаполнено(ДокОбъект.ВидЦены) И ТЧТовары.Количество() > 0 Тогда
						ЗаполнитьЦеныДляОприходования(ДокОбъект);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_СвернутьСтрокиДляОприходования()
	
	ТаблицаСтрок = ТаблицаСтрокДляПорчи.Выгрузить();
	ТаблицаСтрок.Свернуть("НоменклатураОприходование, ХарактеристикаОприходование, 
							|НазначениеОприходование, СерияОприходование, Основание", "ОстатокОприходование");
							
	ТаблицаСтрокДляОприходования.Загрузить(ТаблицаСтрок);
							
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЦеныДляОприходования(Объект)
	ПараметрыЗаполнения = Новый Структура;
	КолонкиПоЗначению = Новый Структура("Упаковка", Справочники.УпаковкиЕдиницыИзмерения.ПустаяСсылка());
	
	ПараметрыЗаполнения.Вставить("Дата",				Объект.Дата);
	ПараметрыЗаполнения.Вставить("Валюта",				Объект.Валюта);
	ПараметрыЗаполнения.Вставить("ВидЦены",				Объект.ВидЦены);
	ПараметрыЗаполнения.Вставить("КолонкиПоЗначению",	КолонкиПоЗначению);
	
	СтруктураДействий = Новый Структура("ПересчитатьСумму", "Количество");
	
	ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(Объект.Товары,,ПараметрыЗаполнения,СтруктураДействий);
КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруДанныхИзАкта()
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("Дата", ТекущаяДата());
	СтруктураДанных.Вставить("Организация", АктОРасхождениях.Организация);
	СтруктураДанных.Вставить("АналитикаРасходов", АктОРасхождениях.Подразделение);
	СтруктураДанных.Вставить("СтатьяРасходов", ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("0А-000659"));
	
	Возврат СтруктураДанных;
КонецФункции

&НаКлиенте
Функция ПолучитьСтруктуруОтбораСтрок(СтрокаОтбора, ТипДокумента)
	ДополнениеИмениКолонки = "";
	Если ТипДокумента = Тип("ДокументСсылка.ОприходованиеИзлишковТоваров") Тогда
		ДополнениеИмениКолонки = "Оприходование";
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Номенклатура", СтрокаОтбора["Номенклатура" + ДополнениеИмениКолонки]);
	СтруктураОтбора.Вставить("Характеристика", СтрокаОтбора["Характеристика" + ДополнениеИмениКолонки]);
	СтруктураОтбора.Вставить("Назначение", СтрокаОтбора["Назначение" + ДополнениеИмениКолонки]);
	СтруктураОтбора.Вставить("Серия", СтрокаОтбора["Серия" + ДополнениеИмениКолонки]);
	
	Возврат СтруктураОтбора;
КонецФункции


