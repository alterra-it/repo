#Область События

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	ОбновитьСписок();
	ВидимостьДоступность();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	ПодключитьОбработчикОжидания("ЗапускОбновленияСписка", 5, Ложь);
	ПодключитьОбработчикОжидания("ОчисткаНадписей", 5, Ложь);
	ПодключитьОбработчикОжидания("ПечатьИзОчереди", 5, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтаФорма);
	Если Не ЭтоАдминистратор() Тогда
		Если Не ЗавершениеРаботы Тогда
			ЗавершитьРаботуСистемы(Ложь, Ложь);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПодразделениеПриИзменении(Элемент)
	ОбновитьСписок();
КонецПроцедуры

// ОПОВЕЩЕНИЕ
&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	ОчиститьСообщения();
	ВремяПоказа= 5;
	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Или Источник = "РучнойВводШтрихкода" Тогда
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Или ИмяСобытия = "ScanDataManual" Тогда
			
			Если ИмяСобытия = "ScanData" Тогда
				ДанныеШтрихкодов = ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Параметр);
				СтруктураДанных = ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
				Штрихкод = СокрЛП(СтруктураДанных.Штрихкод);
			ИначеЕсли ИмяСобытия = "ScanDataManual" Тогда
				Штрихкод = Параметр;
			КонецЕсли;
			
			// СКАНИРОВАНИЕ ВОДИТЕЛЯ
			Если Лев(Штрихкод, 4) = "8888" Тогда//1. Водитель
				Сотрудник = РСС_УправлениеОчередьюИСборкойЗаказов.ПоискСотрудникаПоШтрихкоду(Штрихкод);
				Если ЗначениеЗаполнено(Сотрудник) Тогда
					НадписьСотрудник= Сотрудник;
					
					Если АльтерраОбщегоНазначения.ЭтоВодитель(Сотрудник) Тогда
						СтатусВодителя= АльтерраОбщегоНазначения.ПолучитьТекущийСтатусВодителя(Сотрудник);
						
						// --ПЕЧАТЬ РЕЙСА--
						Если  СтатусВодителя = ПредопределенноеЗначение("Перечисление.СтатусыВодителей.Готов") Тогда
							СтатусыПечати = Новый СписокЗначений;    
							СтатусыПечати.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ДокументыНаПогрузкуГотовы"));
							СтатусыПечати.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыРейсов.Допланирование"));							
							
							Рейс= АльтерраОбщегоНазначения.ПолучитьПодготовленныйРейс(Сотрудник, СтатусыПечати);
							НомерРейса= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Рейс, "Номер");
							ВремяВыезда= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Рейс, "ВремяВыезда");
							Статус = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Рейс, "Статус");
							
							Если Рейс = Неопределено Тогда
								ПоказатьПредупреждение(, "Нет подготовленных рейсов для водителя!", ВремяПоказа, "Сканирование водителей");
								Возврат;
							ИначеЕсли НачалоДня(ВремяВыезда) <> НачалоДня(ТекущаяДата()) Тогда 
								ПоказатьПредупреждение(, "Найденный рейс "+НомерРейса+" дата выезда рейса прошла "+ВремяВыезда, ВремяПоказа, "Сканирование водителей");
								Возврат;
							Иначе //ПЕЧАТЬ
								Сообщить("Если документы не распечатались проверьте наличие бумаги в принтере, при возникновении проблем обратитесь к дежурному логисту или администратору ТЗ.");
								
								Если НужноВзятьБанковскийТерминал(Рейс) Тогда 
									ПоказатьПредупреждение(, "Возьми терминал", ВремяПоказа+5, "Сканирование водителей");									
								КонецЕсли;
								
								ФормаРейса= ПолучитьФорму("Документ.ЗаданиеНаПеревозкуРейс.ФормаОбъекта", Новый Структура("Ключ", Рейс), ЭтаФорма,,);
								ФормаРейса.НапечататьКомплектДокументовКлиент(Истина);
								ФормаРейса= Неопределено;
								
								Если Статус = ПредопределенноеЗначение("Перечисление.СтатусыРейсов.Допланирование") Тогда  
									НаСтатус = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Рейс, "СтатусПередДопланированием");
								Иначе								
									Если ЭтоВыбор(Рейс) Тогда
										//Выбор
										НаСтатус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСВПути");
									Иначе
										НаСтатус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ВодительДокументыПолучил");
									КонецЕсли;
 								КонецЕсли;
								
								УстановитьСтатусРейса(Рейс, НаСтатус);
								Если ПолучитьСтатус(Рейс) =  НаСтатус Тогда
									Сообщить("Рейс "+НомерРейса+" переведен в статус: "+ПолучитьСтатус(Рейс));
									АльтерраОбщегоНазначения.УстановитьСтатусВодителю(Сотрудник, ПредопределенноеЗначение("Перечисление.СтатусыВодителей.ВРейсе"), "Просканирован в ТЗ",,Рейс);
								Иначе
									ПоказатьПредупреждение(, "НЕ УДАЛОСЬ ПЕРЕВЕСТИ РЕЙС НА СТАТУС: "+НаСтатус + Символы.ПС+ "Сообщите логистам", ВремяПоказа, "Сканирование водителей");
								КонецЕсли;
								Возврат;
							КонецЕсли;
							
						// ДОСТАВКА ОСУЩЕСТВЛЕНА
						ИначеЕсли  СтатусВодителя = ПредопределенноеЗначение("Перечисление.СтатусыВодителей.ВРейсе") 
									И Не АльтерраОбщегоНазначения.ИспользуетМобильноеПриложение(Сотрудник)
									Тогда
								мСтатусов= Новый Массив;
								мСтатусов.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСВПути"));
								мСтатусов.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСНаПогрузке"));
								мСтатусов.Добавить(ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ВодительДокументыПолучил"));
								
								Рейс= АльтерраОбщегоНазначения.ПолучитьПодготовленныйРейс(Сотрудник, мСтатусов);
								НомерРейса= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Рейс, "Номер");
								
								Если Рейс = Неопределено Тогда
									ПоказатьПредупреждение(, "По водителю нет рейсов в пути!", ВремяПоказа, "Сканирование водителей");
									Возврат;
								Иначе
									НаСтатус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ДоставкаОсуществлена");
									УстановитьСтатусРейса(Рейс, НаСтатус);
									Если ПолучитьСтатус(Рейс) =  НаСтатус Тогда
										ПоказатьПредупреждение(, "Рейс "+НомерРейса+"  переведен в статус: "+ПолучитьСтатус(Рейс), ВремяПоказа, "Сканирование водителей");
										АльтерраОбщегоНазначения.УстановитьСтатусВодителю(Сотрудник, ПредопределенноеЗначение("Перечисление.СтатусыВодителей.Готов"), "Просканирован в ТЗ");
									Иначе
										ПоказатьПредупреждение(, "НЕ УДАЛОСЬ ПЕРЕВЕСТИ РЕЙС НА СТАТУС: "+НаСтатус + Символы.ПС+ "Сообщите логистам", ВремяПоказа, "Сканирование водителей");
									КонецЕсли;
									Возврат;
								КонецЕсли;
						Иначе
							// ВОДИТЕЛЬ ГОТОВ
							АльтерраОбщегоНазначения.УстановитьСтатусГотовВодителю(Сотрудник, "Просканирован на кассе");
							Если СтатусВодителя = ПредопределенноеЗначение("Перечисление.СтатусыВодителей.ВРейсе") Тогда
								ПоказатьПредупреждение(, "Зарегестрирован возврат из рейса "+Символы.ПС+"Водитель готов к работе!", ВремяПоказа, "Сканирование водителей");
							Иначе 
								ПоказатьПредупреждение(, "Готов к работе!", ВремяПоказа, "Сканирование водителей");
							КонецЕсли;
							Возврат;
						КонецЕсли;
					Иначе//Это водитель
						// --ВХОД ВЫХОД СОТРУДНИКА--
						РезРегистрации= ЗрегестрироватьСотрудникаПоШтрихкодуСервер(Сотрудник);
						ПоказатьПредупреждение(, РезРегистрации, 2, "Сканирование сотрудников");
						Возврат;
					КонецЕсли
				КонецЕсли
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ЭтоВыбор(Рейс)
	Возврат Рейс.Подразделение.Код = "0А-000003";
КонецФункции

&НаСервере
Функция НужноВзятьБанковскийТерминал(Рейс)
	Возврат Рейс.ОплатаБанковскойКартой;
КонецФункции

#КонецОбласти

#Область СканированиеВодителей

&НаКлиенте
Процедура ЗапускОбновленияСписка()
	ОбновитьСписок();
КонецПроцедуры

&НаКлиенте
Процедура ОчисткаНадписей()
	НадписьСотрудник= "";
	Информация= "";
	Элементы.Информация.Видимость= Ложь;
КонецПроцедуры

&НаСервере
Процедура ОбновитьСписок() 

	Если Не ЗначениеЗаполнено(Подразделение) Тогда
		Подразделение= Пользователи.ТекущийПользователь().Подразделение;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Подразделение", Подразделение, ВидСравненияКомпоновкиДанных.Равно,, ЗначениеЗаполнено(Подразделение));
КонецПроцедуры

&НаСервере
Процедура УстановитьСтатусРейса(Рейс, Статус)
	УстановитьПривилегированныйРежим(Истина);
	РейсОбъект= Рейс.ПолучитьОбъект();	
	РейсОбъект.Статус= Статус;
	РейсОбъект.Записать(РежимЗаписиДокумента.Проведение);
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

&НаСервере
Функция  ПолучитьСтатус(Рейс)
	Возврат Рейс.Статус;
КонецФункции

&НаСервере
Процедура ВидимостьДоступность()
	Элементы.Подразделение.Видимость= ЭтоАдминистратор();
	Если Подразделение.Код = "0А-000003" Тогда    //Убрали кнопку для Выбора 
		Элементы.ФормаНапечататьКомплектДокументов.Видимость = Ложь;
	КонецЕсли; 	
КонецПроцедуры

&НаСервере
Функция ЭтоАдминистратор()
	Возврат РольДоступна("ПолныеПрава") ИЛИ РольДоступна("ОтделЛогистики");
КонецФункции

&НаКлиенте
Процедура СканироватьШтрихкод(Команда)
	
	Оповестить("ScanDataManual", РучнойШтрихкод, "РучнойВводШтрихкода")
	
КонецПроцедуры

#КонецОбласти

#Область РегистрацияСотрудников

&НаСервере
Функция ЗрегестрироватьСотрудникаПоШтрихкодуСервер(Сотрудник)
	УстановитьПривилегированныйРежим(Истина);
	Ошибка= Ложь;
	Событие= Перечисления.СостоянияСотрудников.Вышел;
	
	Результат= АльтерраОбщегоНазначения.СотрудникВОфисе(Сотрудник);
	
	ПредыдущееСостояние= Результат.Состояние;
	ПериодПредудущегоСобытия= Результат.Период;
	
	//Проверяем двойное сканирование
	Если (ПериодПредудущегоСобытия+5*1) >= ТекущаяДата() Тогда
		Ошибка= Истина;
		Событие= ПредыдущееСостояние;
		Возврат "Между последним сконированием прошло меньше 5 секунд!";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		НадписьСотрудник= Сотрудник.Наименование+", "+Сотрудник.Должность;
		
		Если Сотрудник.Уволен Или Сотрудник.ПометкаУдаления Тогда
			Возврат "Сотрудник уволен!";
		Иначе
			НаборЗаписей= РегистрыСведений.УчетРабочегоВремениСотрудников.СоздатьНаборЗаписей();
			НоваяЗапись= НаборЗаписей.Добавить();
			НоваяЗапись.Период= ТекущаяДата();
			НоваяЗапись.Сотрудник= Сотрудник;
			НоваяЗапись.Пользователь= Сотрудник.Пользователь;
			НоваяЗапись.Подразделение= ?(ЗначениеЗаполнено(Сотрудник.Подразделение), Сотрудник.Подразделение, Сотрудник.Пользователь.ТекущееПодразделение);
			
			//Если последнее событие было вчера или позднее тогда всегда зашел
			Если НачалоДня(ПериодПредудущегоСобытия) < НачалоДня(ТекущаяДата()) Тогда
				НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Зашел;
			Иначе
				// Общая проверка
				Если  ПредыдущееСостояние = Перечисления.СостоянияСотрудников.Вышел Тогда//Вышел или ещё не было
					НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Зашел;
				Иначе
					НоваяЗапись.Событие= Перечисления.СостоянияСотрудников.Вышел;
				КонецЕсли;
			КонецЕсли;
			Событие= НоваяЗапись.Событие;
			
			НаборЗаписей.Записать(Ложь);
			Возврат "Сотрудник "+НоваяЗапись.Событие;
		КонецЕсли;
	Иначе 
		Ошибка= Истина;
		Возврат "Сотрудник не найден!";
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
КонецФункции

#КонецОбласти

//Не используется
#Область Печать

&НаКлиенте
Процедура ПечатьИзОчереди()
	Рейс= ПолучитьРейсКПечати();
	Если ЗначениеЗаполнено(Рейс) Тогда
		НапечататьРейс(Рейс);
		УдалитьИзОчереди(Рейс);
		
		Если ЭтоВыбор(Рейс) Тогда
			НаСтатус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ТСВПути");
		Иначе
			НаСтатус= ПредопределенноеЗначение("Перечисление.СтатусыРейсов.ВодительДокументыПолучил");
		КонецЕсли;
		УстановитьСтатусРейса(Рейс, НаСтатус);
		АльтерраОбщегоНазначения.УстановитьСтатусВодителю(АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Рейс, "Водитель"), ПредопределенноеЗначение("Перечисление.СтатусыВодителей.ВРейсе"), "С мобильного устройства",,Рейс);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьРейсКПечати()
	установитьПривилегированныйрежим(истина);
	//Запрос к очереди
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОчередьПечати.Документ КАК Документ
	|ИЗ
	|	РегистрСведений.ОчередьПечати КАК ОчередьПечати
	|ГДЕ
	|	ОчередьПечати.Подразделение = &Подразделение
	|	И ОчередьПечати.Документ.Проведен";
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Рейс= ВыборкаДетальныеЗаписи.Документ;
		Если ТипЗнч(Рейс) = Тип("ДокументСсылка.ЗаданиеНаПеревозкуРейс") 
			И НачалоДня(Рейс.ВремяВыезда) = НачалоДня(ТекущаяДата()) 
			И Рейс.Статус = Перечисления.СтатусыРейсов.ДокументыНаПогрузкуГотовы
			Тогда
			Возврат Рейс;
		КонецЕсли;
	КонецЕсли;
	установитьПривилегированныйрежим(ложь);	
	Возврат Неопределено;
КонецФункции

&НаСервере
Процедура УдалитьИзОчереди(Документ)
	РегистрыСведений.ОчередьПечати.УдалитьИзОчереди(Документ);
КонецПроцедуры

&НаКлиенте
Процедура НапечататьКомплектДокументов(Команда)	
	Рейс= Элементы.Список.ТекущиеДанные.Рейс;       
	НапечататьРейс(Рейс);
КонецПроцедуры

&НаКлиенте
Процедура НапечататьРейс(Рейс)
	ФормаРейса= ПолучитьФорму("Документ.ЗаданиеНаПеревозкуРейс.ФормаОбъекта", Новый Структура("Ключ", Рейс), ЭтаФорма,,);
	ФормаРейса.НапечататьКомплектДокументовКлиент(Истина);
	ФормаРейса= Неопределено;
КонецПроцедуры

&НаКлиенте
Процедура ОРК_ПечатьПакетаДокументов(Команда)
	Рейс= Элементы.Список.ТекущиеДанные.Рейс;       
	ОРК_НапечататьРейс(Рейс);
КонецПроцедуры

&НаКлиенте
Процедура ОРК_НапечататьРейс(Рейс)
	ФормаРейса= ПолучитьФорму("Документ.ЗаданиеНаПеревозкуРейс.ФормаОбъекта", Новый Структура("Ключ", Рейс), ЭтаФорма,,);
	ФормаРейса.ОРК_НапечататьКомплектДокументовКлиент(Истина);
	ФормаРейса= Неопределено;
КонецПроцедуры

#КонецОбласти

