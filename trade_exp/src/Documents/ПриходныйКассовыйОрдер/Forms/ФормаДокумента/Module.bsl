&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	Если Не ЗначениеЗаполнено(Объект.Номер) Тогда//Новый
		Если ЗначениеЗаполнено(Объект.ДокументОснование)  Тогда
			Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				//Задача №40041 от Селезневой ставить сумму не по взаиморасчетом, а по реализации						
				Объект.СуммаДокумента= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ДокументОснование, "СуммаДокумента");
				СуммаДокументаПриИзменении(Неопределено);
				
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Если ПоказатьПредупреждениеОбИзмененииСуммы(Объект) Тогда
				АльтерраОбщегоНазначения.СообщитьПользователю(Объект.Ссылка, "Необходимо изменить сумму", "Объект.СуммаДокумента");
			КонецЕсли;
		КонецЕсли;
		ЗаполнитьЗначения();
	КонецЕсли;
КонецПроцедуры

&ИзменениеИКонтроль("ЗаполнитьКассира")
&НаСервере
Процедура Док_ЗаполнитьКассира()
    #Удаление
	КассирКассы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Касса, "Кассир");
	Если ЗначениеЗаполнено(КассирКассы) Тогда
		Объект.Кассир = КассирКассы;
	Иначе
	#КонецУдаления
		Объект.Кассир = ДенежныеСредстваСервер.КассирПоследнегоРКОИлиПКО(Объект.Дата, Объект.Организация, Объект.Касса);
	#Удаление
	КонецЕсли;
    #КонецУдаления
КонецПроцедуры

&НаКлиенте
Процедура Док_СуммаНаличныхПриИзмененииПосле(Элемент)
	Сдача=СуммаНаличных-Объект.СуммаДокумента;
КонецПроцедуры

&НаСервере
Функция ПоказатьПредупреждениеОбИзмененииСуммы(Знач Объект)
	
	Если Не Объект.ДокументОснование.ИспользуетсяДоговор Тогда
		Если ЗначениеЗаполнено(Объект.ДокументОснование.ЗаказКлиента) Тогда
			ДокРасчетов= Объект.ДокументОснование.ЗаказКлиента;
		Иначе
			ДокРасчетов= Объект.ДокументОснование;
		КонецЕсли;
		ДолгКлиента= ПолучитьДолг(ДокРасчетов);
		
		Если ДолгКлиента <> Объект.ДокументОснование.СуммаДокумента Тогда
			Возврат Истина
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции
&НаСервереБезКонтекста
Функция ПолучитьДолг(ЗаказКлиента)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасчетыСКлиентамиОстатки.КОплатеОстаток КАК КОплатеОстаток
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(, ОбъектРасчетов.Объект = &ЗаказКлиента) КАК РасчетыСКлиентамиОстатки";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.КОплатеОстаток;
	КонецЦикла;
	
	Возврат 0;
КонецФункции 

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(Объект.Организация) тогда
		НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Владелец", "Объект.Организация");
		НовыйМассив = Новый Массив();                    
		НовыйМассив.Добавить(НоваяСвязь);                             
		НовыеСвязи = Новый ФиксированныйМассив(НовыйМассив);
		Элементы.Касса.СвязиПараметровВыбора = НовыеСвязи;	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ХозяйственнаяОперацияПриИзмененииПосле(Элемент)
	ЗаполнитьСтатьюДДС();
	ЗаполнитьЗначения();	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЗначения()
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзКассыККМ Тогда
		Если НЕ ЗначениеЗаполнено(Объект.ВТомЧислеНДС) И Объект.Касса.Владелец.Наименование="Альтерра ООО" Тогда
			Объект.ВТомЧислеНДС = "НДС";	
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.ПринятоОт) Тогда
			Объект.ПринятоОт = "Физическое лицо";	
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтатьюДДС()
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтПодотчетника Тогда
		ЗаполнитьТЧРасшифровка(Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("0А-000004")); //ВОЗВРАТ ПОДОТЧЕТА	
	КонецЕсли;
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента Тогда   
		ПриИзмененииКонтрагента();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТЧРасшифровка(Статья)
	Для каждого стрРасшировка из Объект.РасшифровкаПлатежа Цикл
		стрРасшировка.СтатьяДвиженияДенежныхСредств = Статья;
	КонецЦикла;
КонецПроцедуры


&НаКлиенте
Процедура Док_КассаПриИзмененииПосле(Элемент)
	ЗаполнитьЗначения();
КонецПроцедуры

