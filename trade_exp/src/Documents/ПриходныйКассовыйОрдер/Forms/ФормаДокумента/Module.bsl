&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи) 
	
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Отказ = ПроверкаНаВидКонтрагента(); 
	КонецЕсли;   
	
	ПодменитьНДСПоПоступлениюИзКассыККМАльтерра(); 
	ВставитьВТомЧислеНДСНаСервере();
	
КонецПроцедуры

&НаСервере
Функция ПроверкаНаВидКонтрагента() 
	
	СуммаОграничениеЮрЛиц = 100000;
	
	Если Не Объект.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда 
		
		Если Объект.СуммаДокумента >= СуммаОграничениеЮрЛиц Тогда 
			
			Сообщить("ПКО с суммой от " + СуммаОграничениеЮрЛиц + " можно создавать только для Физических лиц!");
			Возврат Истина;
			
		ИначеЕсли ЗначениеЗаполнено(Объект.ДокументОснование) Тогда 
			
			Если ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.РеализацияТоваровУслуг")
			Или ТипЗнч(Объект.ДокументОснование) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
				
				Возврат ПроверкаСуммыВсехПКОПоОснованию(СуммаОграничениеЮрЛиц);	 
				
			КонецЕсли; 
			
		КонецЕсли;
		
	КонецЕсли; 
	
	Возврат Ложь; 
	
КонецФункции

&НаСервере
Функция ПроверкаСуммыВсехПКОПоОснованию(СуммаОграничениеЮрЛиц)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ПриходныйКассовыйОрдер.СуммаДокумента), 0) КАК Сумма
	|ИЗ
	|	Документ.ПриходныйКассовыйОрдер КАК ПриходныйКассовыйОрдер
	|ГДЕ
	|	ПриходныйКассовыйОрдер.ДокументОснование = &ДокументОснование
	|	И ПриходныйКассовыйОрдер.Проведен = ИСТИНА
	|	И ПриходныйКассовыйОрдер.ПометкаУдаления = ЛОЖЬ
	|	И ПриходныйКассовыйОрдер.Ссылка <> &Ссылка";
	
	Запрос.УстановитьПараметр("ДокументОснование", Объект.ДокументОснование);   
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Запрос.УстановитьПараметр("Ссылка", Объект.ссылка);
	Иначе 
		Запрос.УстановитьПараметр("Ссылка", Документы.ПриходныйКассовыйОрдер.ПустаяСсылка());
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		
		ОбщаяСумма = Выборка.Сумма + Объект.СуммаДокумента; 
		
		Если ОбщаяСумма >= СуммаОграничениеЮрЛиц Тогда
			ОстатокНаличными = СуммаОграничениеЮрЛиц - Выборка.Сумма - 1;
			ОстатокНаличными = ?(ОстатокНаличными < 0,0,ОстатокНаличными);
			Сообщить("Общая сумма всех ПКО по одному основанию может превышать " + СуммаОграничениеЮрЛиц + " только для физических лиц!" +"
			|Остаток, который можно принять по данному ПКО = " + ОстатокНаличными );
			Возврат Истина;
		КонецЕсли; 
		
	КонецЕсли;
	
	Возврат Ложь; 
	
КонецФункции

