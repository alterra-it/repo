  <attributes>
    <name>ПриходныеКассовыеОрдера</name>
    <title>
      <key>ru</key>
      <value>Приходные кассовые ордера</value>
    </title>
    <id>1000001</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПриходныеКассовыеОрдера.Ref</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПриходныеКассовыеОрдера.Касса</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПриходныеКассовыеОрдера.ПлательщикПредставление</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПриходныеКассовыеОрдера.ПометкаУдаления</segments>
    </notDefaultUseAlwaysAttributes>
    <notDefaultUseAlwaysAttributes xsi:type="form:DataPath">
      <segments>ПриходныеКассовыеОрдера.Ссылка</segments>
    </notDefaultUseAlwaysAttributes>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ВЫРАЗИТЬ(РеестрДокументов.Ссылка КАК Документ.ПриходныйКассовыйОрдер) КАК Ссылка,
	РеестрДокументов.ПометкаУдаления КАК ПометкаУдаления,
	РеестрДокументов.НомерДокументаИБ КАК Номер,
	РеестрДокументов.ДатаДокументаИБ КАК Дата,
	РеестрДокументов.Проведен КАК Проведен,
	РеестрДокументов.Организация КАК Организация,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
			ТОГДА ДанныеСторно.Касса
		ИНАЧЕ ДокументПриходноКассовыйОрдер.Касса
	КОНЕЦ КАК Касса,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
			ТОГДА ДанныеСторно.Касса.ВалютаДенежныхСредств
		ИНАЧЕ ДокументПриходноКассовыйОрдер.Касса.ВалютаДенежныхСредств
	КОНЕЦ КАК Валюта,
	РеестрДокументов.Сумма КАК СуммаДокумента,
	РеестрДокументов.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	ВЫБОР
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика)
			ТОГДА РеестрДокументов.Контрагент
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзБанка)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.БанковскийСчет
					ИНАЧЕ ДокументПриходноКассовыйОрдер.БанковскийСчет
				КОНЕЦ
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствОтПодотчетника)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПогашениеЗаймаСотрудником)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.ПодотчетноеЛицо
					ИНАЧЕ ДокументПриходноКассовыйОрдер.ПодотчетноеЛицо
				КОНЕЦ
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойКассы)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойОрганизации)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.КассаОтправитель
					ИНАЧЕ ДокументПриходноКассовыйОрдер.КассаОтправитель
				КОНЕЦ
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзКассыККМ)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.КассаККМ
					ИНАЧЕ ДокументПриходноКассовыйОрдер.КассаККМ
				КОНЕЦ
		ИНАЧЕ РеестрДокументов.Контрагент
	КОНЕЦ КАК Аналитика,
	ВЫБОР
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствОтПоставщика)
			ТОГДА РеестрДокументов.Контрагент.Наименование
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзБанка)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.БанковскийСчет.Наименование
					ИНАЧЕ ДокументПриходноКассовыйОрдер.БанковскийСчет.Наименование
				КОНЕЦ
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратДенежныхСредствОтПодотчетника)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПогашениеЗаймаСотрудником)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.ПодотчетноеЛицо.Наименование
					ИНАЧЕ ДокументПриходноКассовыйОрдер.ПодотчетноеЛицо.Наименование
				КОНЕЦ
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойКассы)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзДругойОрганизации)
				ИЛИ РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВнутренняяПередачаДенежныхСредств)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.КассаОтправитель.Наименование
					ИНАЧЕ ДокументПриходноКассовыйОрдер.КассаОтправитель.Наименование
				КОНЕЦ
		КОГДА РеестрДокументов.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ПоступлениеДенежныхСредствИзКассыККМ)
			ТОГДА
				ВЫБОР
					КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
						ТОГДА ДанныеСторно.КассаККМ.Наименование
					ИНАЧЕ ДокументПриходноКассовыйОрдер.КассаККМ.Наименование
				КОНЕЦ
		ИНАЧЕ РеестрДокументов.Контрагент.Наименование
	КОНЕЦ КАК ПлательщикПредставление,
	ДокументПриходноКассовыйОрдер.Представление КАК Представление,
	ДокументПриходноКассовыйОрдер.МоментВремени КАК МоментВремени,
	ДокументПриходноКассовыйОрдер.Автор КАК Автор,
	РеестрДокументов.СторноИсправление КАК СторноИсправление,
	ВЫБОР
		КОГДА НЕ РеестрДокументов.СторноИсправление
			ТОГДА НЕОПРЕДЕЛЕНО
		ИНАЧЕ РеестрДокументов.СторнируемыйДокумент
	КОНЕЦ КАК СторнируемыйИсправляемыйДокумент,
		ВЫБОР
		КОГДА РеестрДокументов.Проведен
			ТОГДА 0
		КОГДА РеестрДокументов.ПометкаУдаления
			ТОГДА 1
		ИНАЧЕ 2
	КОНЕЦ КАК НестандартнаяКартинка,
	ВЫБОР
		КОГДА ТИПЗНАЧЕНИЯ(РеестрДокументов.Ссылка) = ТИП(Документ.Сторно) 
			ТОГДА ДанныеСторно.Основание
		ИНАЧЕ ДокументПриходноКассовыйОрдер.Основание
	КОНЕЦ КАК Основание,
	ВЫБОР
		КОГДА ДокументыСОшибкамиПроверкиКонтрагентов.Документ ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ЕстьОшибкиПроверкиКонтрагентов,
    СостоянияЭД.СостояниеЭДО КАК СостояниеВерсииЭД,
    СостоянияЭД.ПредставлениеСостояния КАК ПредставлениеСостояния
ИЗ
	РегистрСведений.РеестрДокументов КАК РеестрДокументов
	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходныйКассовыйОрдер КАК ДокументПриходноКассовыйОрдер
		ПО РеестрДокументов.Ссылка = ДокументПриходноКассовыйОрдер.Ссылка
	ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПриходныйКассовыйОрдер КАК ДанныеСторно
		ПО РеестрДокументов.СторнируемыйДокумент = ДанныеСторно.Ссылка
	{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыСОшибкамиПроверкиКонтрагентов КАК ДокументыСОшибкамиПроверкиКонтрагентов
		ПО ДокументПриходноКассовыйОрдер.Ссылка = ДокументыСОшибкамиПроверкиКонтрагентов.Документ
			И (&amp;ИспользованиеПроверкиВозможно)}
	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияПоОбъектамУчетаЭДО КАК СостоянияЭД
		ПО (СостоянияЭД.СсылкаНаОбъект = РеестрДокументов.Ссылка)
ГДЕ
	РеестрДокументов.ТипСсылки = &amp;ТипСсылки
	И Не РеестрДокументов.ДополнительнаяЗапись
{ГДЕ
	ВЫРАЗИТЬ(РеестрДокументов.Ссылка КАК Документ.ПриходныйКассовыйОрдер).* КАК Ссылка,
	РеестрДокументов.Организация.* КАК Организация,
	РеестрДокументов.ДатаДокументаИБ КАК Дата,
	РеестрДокументов.НомерДокументаИБ КАК Номер,
	РеестрДокументов.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	РеестрДокументов.Ответственный.* КАК Ответственный,
	РеестрДокументов.Комментарий КАК Комментарий,
	РеестрДокументов.Проведен КАК Проведен,
	РеестрДокументов.ПометкаУдаления КАК ПометкаУдаления}</queryText>
      <mainTable>InformationRegister.РеестрДокументов</mainTable>
      <dynamicDataRead>true</dynamicDataRead>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
  <commandInterface>
    <navigationPanel/>
    <commandBar/>
  </commandInterface>
  <extInfo xsi:type="form:DynamicListFormExtInfo"/>
</form:Form>
