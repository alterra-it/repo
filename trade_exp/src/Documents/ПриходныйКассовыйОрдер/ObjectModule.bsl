#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&Перед("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполненияПеред(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АрендаНоменклатуры") Тогда
		
		ДокОснование = ДанныеЗаполнения;
		ДанныеЗаполнения = Новый Структура;

		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДокОснование, , "Номер,Дата");
		Основание = ДокОснование;
		ДокументОснование = ДокОснование;
		ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента;

		РеквизитыОснования = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокОснование, "Организация, Подразделение, Партнер, СуммаЗалога");
		НоваяСтрока = РасшифровкаПлатежа.Добавить();
		НоваяСтрока.ОбъектРасчетов = Договор;
		НоваяСтрока.Организация = Организация;
		НоваяСтрока.ВалютаВзаиморасчетов = Валюта;
		НоваяСтрока.Партнер = РеквизитыОснования.Партнер;
		НоваяСтрока.Сумма = РеквизитыОснования.СуммаЗалога;
		НоваяСтрока.СуммаВзаиморасчетов = НоваяСтрока.Сумма;
		НоваяСтрока.Подразделение = РеквизитыОснования.Подразделение;
		НоваяСтрока.СтавкаНДС = АльтерраОбщегоНазначения.ПолучитьСтавкуНДСФилиала(РеквизитыОснования.Организация);

		СтрокаGUID = "cd661a74-ae8f-11e9-80db-002590e168ab"; 	// Обеспечительный платёж за аренду номенклатуры
		НовыйGUID = Новый УникальныйИдентификатор(СтрокаGUID);
		НоваяСтрока.СтатьяДвиженияДенежныхСредств= Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСсылку(НовыйGUID);

		СтавкаНДСЧислом = УчетНДСУПКлиентСервер.ЗначениеСтавкиНДС(НоваяСтрока.СтавкаНДС);
		НоваяСтрока.СуммаНДС = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(НоваяСтрока.Сумма, СтавкаНДСЧислом, Истина);
		СуммаДокумента = РасшифровкаПлатежа.Итог("Сумма");

		ПринятоОт = "" + Контрагент + " (Обеспечительный платеж)";

		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполненияПосле(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Сотрудник = АльтерраОбщегоНазначения.ПолучитьСотрудника(Пользователи.ТекущийПользователь());
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		Если ЗначениеЗаполнено(Сотрудник.Касса) Тогда
			Касса = Сотрудник.Касса;
			ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("ТекущаяКасса", , Касса);
			ПодразделениеКассы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Касса, "Подразделение");
			Подразделение = ПодразделениеКассы;
//			ПодразделениеОтправитель = ПодразделениеКассы;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") И ДанныеЗаполнения.Свойство("ХозяйственнаяОперация") Тогда
		
		Если ДанныеЗаполнения.ХозяйственнаяОперация	= Перечисления.ХозяйственныеОперации.ВозвратДенежныхСредствОтПодотчетника Тогда
			ЗаполнитьТЧРасшифровка(Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("0А-000004")); //ВОЗВРАТ ПОДОТЧЕТА	
		КонецЕсли;
		
		Если ДанныеЗаполнения.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента Тогда
			Если ДанныеЗаполнения.Свойство("Контрагент") Тогда
				Если ДанныеЗаполнения.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
					ЗаполнитьТЧРасшифровка(Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("0А-000007")); //ВЫРУЧКА ФИЗИЧЕСКИЕ ЛИЦА     
					ПринятоОт = "Физическое лицо";
				Иначе
					ЗаполнитьТЧРасшифровка(Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("0А-000002")); //ПОСТУПЛЕНИЯ ОТ ПОКУПАТЕЛЕЙ
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьТЧРасшифровка(Статья)
	Для Каждого стрРасшировка Из РасшифровкаПлатежа Цикл
		стрРасшировка.СтатьяДвиженияДенежныхСредств = Статья;
	КонецЦикла;
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	АльтерраОбщегоНазначения.ПроверитьКассыОрганизаций(ЭтотОбъект, Отказ);
		
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АрендаНоменклатуры") Тогда
		Если ДокументОснование.Статус <> Перечисления.СтатусыАренды.ВАренде Тогда
			Если Не РольДоступна("ПолныеПрава") Тогда
				Отказ= Истина;
			КонецЕсли;
			Сообщить("Оплатить можно только в статусе В аренде!", СтатусСообщения.ОченьВажное);
		КонецЕсли;
	КонецЕсли;

	Если ДеньгиВнесеныCотрудником = Истина И Не ЗначениеЗаполнено(СотрудникВнесшийДеньги) Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Укажите сотрудника, внесшего деньги";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;

КонецПроцедуры
&После("ЗаполнитьПоЗаказуКлиента")
Процедура Док_ЗаполнитьПоЗаказуКлиента(Знач ДокументОснование, ДанныеЗаполнения, СуммаКОплате)
	Если ДокументОснование.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Тогда
		ПринятоОт = "Физическое лицо";
	КонецЕсли;
КонецПроцедуры

&После("ЗаполнитьПоРеализацииТоваров")
Процедура Док_ЗаполнитьПоРеализацииТоваров(Знач РеализацияТоваров, ДанныеЗаполнения, СуммаКОплате)
	
	Для Каждого ТекущаяСтрока Из РасшифровкаПлатежа Цикл
		
		Если Не ЗначениеЗаполнено(ТекущаяСтрока.ОбъектРасчетов) Тогда
			
			ТекущееОснование = ДанныеЗаполнения.ДокументОснование;
			ТекущаяСтрока.ОснованиеПлатежа = ТекущееОснование;
			ТекущаяСтрока.Партнер = ДанныеЗаполнения.Партнер;
			
			Если ЗначениеЗаполнено(ДанныеЗаполнения.Договор) Тогда
				ПараметрОбъект = ДанныеЗаполнения.Договор;
			Иначе
				ПараметрОбъект = ДанныеЗаполнения.ДокументОснование.ЗаказКлиента;
			КонецЕсли;
			
			ТекущаяСтрока.ОбъектРасчетов = Справочники.ОбъектыРасчетов.НайтиПоРеквизиту("Объект", ПараметрОбъект);

		КонецЕсли;

		Если Не ЗначениеЗаполнено(ТекущаяСтрока.СтавкаНДС) Тогда
			
			СтруктураПересчетаСуммы = Новый Структура;
			СтруктураПересчетаСуммы.Вставить("ЦенаВключаетНДС", Истина);
			
			СтруктураПараметровДействия = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСтавкиНДС(
				ДанныеЗаполнения.ДокументОснование);
				
			СтруктураДействий = Новый Структура;
			СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", СтруктураПараметровДействия);
			СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
			
			ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, Неопределено);
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры
#КонецЕсли
