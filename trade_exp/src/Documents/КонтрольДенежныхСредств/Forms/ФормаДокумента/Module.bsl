
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	УстановитьДоступностьЭлементов();
	Объект.АвторДокумента=Пользователи.ТекущийПользователь();
	УстановитьПараметрыВыбораДокументыДокумент();
КонецПроцедуры


&НаСервере
Процедура УстановитьДоступностьЭлементов()
	ТолькоМенеджер= (рольдоступна("ОтчетыМенеджераПоПродажам") и не рольдоступна("Кассир"));
	ТолькоКассир= рольдоступна("Кассир");
	если рольдоступна("Полныеправа") или рольдоступна("ОтчетыИОбработкиБухгалтера") тогда
		возврат;
	конецесли;	
	если Объект.Статус=Перечисления.СтатусыКонтроляДС.Закрыт тогда
		Толькоменеджер=истина;
		ТолькоКассир=Истина;
	конецесли;	
	
	Элементы.Партнер.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.Контрагент.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.Договор.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.ДокументОснование.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.Сотрудник.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.ФормаОплаты.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.СуммаРасчета.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.ДатаРасчета.ТолькоПросмотр=ТолькоМенеджер;
	Элементы.ПлановаяДатаВнесения.ТолькоПросмотр=ТолькоМенеджер;
	
	Элементы.ДатаОплаты.ТолькоПросмотр=ТолькоКассир;
	Элементы.ДокументыОплаты.ТолькоПросмотр=ТолькоКассир;
	Элементы.Кассир.ТолькоПросмотр=ТолькоКассир;
	
	
КонецПроцедуры


&НаСервере
Функция СуммаДокументаОплаты(ДокументОплаты)

	 возврат ДокументОплаты.СуммаДокумента; 

КонецФункции 

&НаКлиенте
Процедура ДокументыДокументПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.ДокументыОплаты.ТекущиеДанные;
	ТекущаяСтрока.Сумма=СуммаДокументаОплаты(ТекущаяСтрока.Документ);
	РассчитатьКонтроль();
КонецПроцедуры
&НаСервере
Процедура РассчитатьКонтроль()

	Объект.Контроль=Объект.СуммаРасчета-Объект.ДокументыОплаты.Итог("Сумма");
	заполнитьзначениясвойств(Объект,РеквизитыОплаты());

КонецПроцедуры

&НаСервере
Функция РеквизитыОплаты()
    ДатаОплаты=дата('00010101');
	Кассир="";
	для каждого Док из Объект.ДокументыОплаты цикл
		если ДатаОплаты<Док.Документ.дата тогда
			ДатаОплаты=Док.Документ.Дата;
			ДокументОплаты=Док.Документ;
		конецесли;	
	конеццикла;
	если типзнч(ДокументОплаты)=тип("ДокументСсылка.ПриходныйКассовыйОрдер") тогда
		Кассир=ДокументОплаты.Кассир;
	иначеесли типзнч(ДокументОплаты)=тип("ДокументСсылка.ОперацияПоПлатежнойКарте") тогда 
		Кассир=ДокументОплаты.Ответственный;
	конецесли;	
	
	возврат Новый Структура("ДатаОплаты,Кассир",ДатаОплаты,Кассир);
	
КонецФункции


&НаКлиенте
Процедура ДокументыОплатыПослеУдаления(Элемент)
	  РассчитатьКонтроль();

КонецПроцедуры

&НаКлиенте
Процедура ДокументыОплатыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	РассчитатьКонтроль();
КонецПроцедуры

&НаКлиенте
Процедура СуммаРасчетаПриИзменении(Элемент)
	РассчитатьКонтроль();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
 	РассчитатьКонтроль();

	если Объект.Контроль=0 тогда
		Объект.Статус=предопределенноезначение("Перечисление.СтатусыКонтроляДС.Закрыт");
//	иначе
//		Объект.Статус=предопределенноезначение("Перечисление.СтатусыКонтроляДС.Создан");
	конецесли;	
	Отказ=не ПроверкаДублейДокументов();
    Объект.ИтогоВнесено=Объект.ДокументыОплаты.Итог("Сумма");
КонецПроцедуры

&НаСервере
Функция ПроверкаДублейДокументов()
	ТекстСообщения="";
	Результат=истина;
	ТаблицаДокументов=Объект.ДокументыОплаты.Выгрузить();
	для каждого стр из Объект.ДокументыОплаты цикл
		ПараметрыПоиска=новый Структура("Документ",стр.Документ);
		если ТаблицаДокументов.НайтиСтроки(ПараметрыПоиска).Количество()>1 тогда
			ТекстСообщения=ТекстСообщения+"Документ - "+стр.Документ+" уже присутствует в таблице"+символы.ПС;
			Результат=Ложь;
			прервать;
		конецесли;	
	конеццикла;	
	если не результат тогда
		Сообщить(ТекстСообщения);
	конецесли;	
	возврат Результат;
КонецФункции // ПроверкаДублейДокументов()

&НаСервере
Процедура УстановитьПараметрыВыбораДокументыДокумент()
	
	Элементы.ДокументыДокумент.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);
	ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ДокументыДокумент, "Партнер", Объект.Партнер);

КонецПроцедуры

