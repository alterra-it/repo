		|	Табель.ИтогоВПраздники <> Итог.ИтогоВПраздники
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Итог.НомерСтроки КАК НомерСтроки,
		|	Итог.ИтогоВПраздники КАК ИтогоВПраздники
		|ИЗ
		|	ВТИтог КАК Итог
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
		
		Запрос.УстановитьПараметр("ТЗ", Коллекция.Выгрузить());
		Запрос.УстановитьПараметр("НачалоМесяца", НачалоМесяца(Объект.ПериодРегистрации));
		Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(Объект.ПериодРегистрации));
		Запрос.УстановитьПараметр("ТекущийГод", Год(Объект.ПериодРегистрации));
		Запрос.УстановитьПараметр("ПроизводственныйКалендарь", ПроизводственныйКалендарь);
		
		МассивРезультатов = Запрос.ВыполнитьПакет();
		
		Если НЕ МассивРезультатов[3].Пустой() Тогда
			МассивРезультатов = МассивРезультатов[4].Выбрать();
			Пока МассивРезультатов.Следующий() Цикл
				МассивДляВозврата.Добавить(МассивРезультатов.ИтогоВПраздники);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат МассивДляВозврата;
КонецФункции

&НаКлиенте
Функция  ШапкаЗаполнена()
	Отказ= Истина;
	Если Объект.ПериодРегистрации = Дата("00010101") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен Период регистрации!",,"ПериодРегистрации", "Объект");
		Отказ= Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Отделы) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены Отделы!");		
		Отказ= Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.ГрафикРаботы) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен График работы!",,"ГрафикРаботы", "Объект");		
		Отказ= Ложь;
	КонецЕсли;
	
	Возврат Отказ;
КонецФункции

&НаСервере
Функция ПользовательИмеетПраваБухгалтера()

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Пользователи.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
		|		ПО Пользователи.Ссылка = ГруппыДоступаПользователи.Пользователь
		|ГДЕ
		|	ГруппыДоступаПользователи.Ссылка = &ГруппаДоступа
		|	И Пользователи.Ссылка = &ТекущийПользователь";
	
	Запрос.УстановитьПараметр("ГруппаДоступа", Справочники.ГруппыДоступа.НайтиПоНаименованию("Бухгалтер по ЗП"));
	Запрос.УстановитьПараметр("ТекущийПользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

