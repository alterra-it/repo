&НаКлиенте
Процедура ЗаполнитьСпискомСотрудников(Команда)
	Если Не ШапкаЗаполнена() Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ДанныеОВремени.Количество() > 0 Тогда
		ДиалогСВопросомОчиститьДанныеЗаполнитьСотрудников();
	Иначе
		ЗаполнитьСпискомСотрудниковНаСервере();
	КонецЕсли;
КонецПроцедуры
&НаКлиенте
Процедура ЗаполнитьСпискомСотрудниковНаСервере()
	Объект.ДанныеОВремени.Очистить();
	Комментарий = "";
	
	Для Каждого СтрОтдел Из Объект.Отделы Цикл 
		мСотрудников = УчетРабочегоВремениСервер.ПолучитьРаботающихСотрудников(СтрОтдел.Отдел, Объект.ПериодРегистрации);
		Для Каждого ТекСотрудник Из мСотрудников Цикл
			Для сч=1 По Объект.КоличествоСтрок Цикл
				НоваяСтрока = Объект.ДанныеОВремени.Добавить();
				НоваяСтрока.Сотрудник = ТекСотрудник.Сотрудник;
				НоваяСтрока.Должность = ТекСотрудник.Должность;
				НоваяСтрока.Подразделение = ТекСотрудник.Подразделение;
				НоваяСтрока.Отдел = ТекСотрудник.Отдел;
				НоваяСтрока.НомерСотрудника = сч;
			КонецЦикла;
		КонецЦикла;
		
		Если мСотрудников.Количество() > 0 Тогда
			Если ПустаяСтрока(Комментарий) Тогда
				Комментарий = Строка(СтрОтдел.Отдел) + " " + ПолучитьПодразделениеСотрудника(мСотрудников[0]);
			Иначе
				Комментарий = Комментарий + ", " + Строка(СтрОтдел.Отдел) + " " + ПолучитьПодразделениеСотрудника(мСотрудников[0]);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если ПустаяСтрока(Объект.Комментарий) И Не ПустаяСтрока(Комментарий) Тогда
		Объект.Комментарий = Комментарий;
	КонецЕсли;
КонецПроцедуры

