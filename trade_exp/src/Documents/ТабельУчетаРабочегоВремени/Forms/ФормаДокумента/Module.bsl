&НаСервере
Процедура ЗаполнитьВремяПоДанным1СНаСервере(НаТекущуюДату = Ложь, ПоГрафику = Ложь)			
	ДатаОкончанияРасчета = "";
	
	ТекущаяДатаРасчета = ТекущаяДата();
	НачалоМесяцаРегистрации = НачалоМесяца(Объект.ПериодРегистрации);
	ОкончаниеМесяцаРегистрации = КонецМесяца(Объект.ПериодРегистрации);
	
	Если НаТекущуюДату Тогда
		Если (ТекущаяДатаРасчета >= ОкончаниеМесяцаРегистрации) ИЛИ (ТекущаяДатаРасчета < НачалоМесяцаРегистрации) Тогда
			ДатаОкончанияРасчета = ОкончаниеМесяцаРегистрации;
		Иначе
			ДатаОкончанияРасчета = КонецДня(ТекущаяДатаРасчета - 86400);
		КонецЕсли;
	Иначе
		ДатаОкончанияРасчета = ОкончаниеМесяцаРегистрации;	
	КонецЕсли;
	
	Если Объект.ДанныеОВремени.Количество() > 0 Тогда
		СтрокиПоСотрудникам = Новый Соответствие;
		СотрудникиДокумента = Новый Массив;
		
		Для Каждого СтрокаДанныхОВремени Из Объект.ДанныеОВремени Цикл
			СтрСотрудник = СтрокаДанныхОВремени.Сотрудник;
			МассивСтрокПоСотруднику = Объект.ДанныеОВремени.НайтиСтроки(Новый Структура("Сотрудник",СтрСотрудник));
			СотрудникиДокумента.Добавить(СтрСотрудник);
			СтрокиПоСотрудникам.Вставить(СтрСотрудник, МассивСтрокПоСотруднику);
		КонецЦикла;	
		ВысотаСтроки = 1;
		УчетРабочегоВремениСервер.ТабельЗаполнитьДанныеПоСотрудникам(Объект,
																	СотрудникиДокумента,
																	СтрокиПоСотрудникам,
																	ДатаОкончанияРасчета,
																	ПоГрафику);	
	КонецЕсли;
	
	ВосстановитьДанныеЗаПервуюПоловинуМесяца();

КонецПроцедуры


&НаСервере
Процедура ВосстановитьДанныеЗаПервуюПоловинуМесяца()
	Если Объект.Статус = Перечисления.ТабельУчетаРабочегоВремениСтатус.Утвержден 
		ИЛИ Объект.Статус = Перечисления.ТабельУчетаРабочегоВремениСтатус.ПроверенБухгалтером Тогда
		ПромежуточнаяТаблица = Объект.ДанныеОВремени.Выгрузить();
		ТаблицаБыло = Объект.Ссылка.ДанныеОВремени.Выгрузить();
		Для н = 1 по 15 Цикл
			ПромежуточнаяТаблица.ЗагрузитьКолонку(ТаблицаБыло.ВыгрузитьКолонку("ПредставлениеПлан"+н), "ПредставлениеПлан"+н);
			ПромежуточнаяТаблица.ЗагрузитьКолонку(ТаблицаБыло.ВыгрузитьКолонку("НачалоСменыПлан"+н), "НачалоСменыПлан"+н);
			ПромежуточнаяТаблица.ЗагрузитьКолонку(ТаблицаБыло.ВыгрузитьКолонку("Представление"+н), "Представление"+н);
			ПромежуточнаяТаблица.ЗагрузитьКолонку(ТаблицаБыло.ВыгрузитьКолонку("Примечание"+н), "Примечание"+н);
		КонецЦикла;
		Объект.ДанныеОВремени.Загрузить(ПромежуточнаяТаблица);
	КонецЕсли;
КонецПроцедуры
