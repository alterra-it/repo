&НаСервере
Функция ДанныеОВремениСотрудник1ПриИзмененииНаСервере(Сотрудник)  	
	Отдел = Сотрудник.Отдел;
	Подразделение = Сотрудник.Подразделение;
	Должность = Сотрудник.Должность; 
	Ответ = Новый Структура("Отдел, Подразделение, Должность", Отдел,Подразделение,Должность);
	Возврат(Ответ);	
	
КонецФункции
&НаКлиенте
Процедура ДанныеОВремениСотрудник1ПриИзменении(Элемент) 
	ТекСтрока = Элементы.ДанныеОВремени.ТекущиеДанные;
	Сотрудник = ДанныеОВремениСотрудник1ПриИзмененииНаСервере(ТекСтрока.Сотрудник);
	ТекСтрока.Отдел = Сотрудник.Отдел;
	ТекСтрока.Подразделение = Сотрудник.Подразделение;
	ТекСтрока.Должность = Сотрудник.Должность;
КонецПроцедуры 

&НаКлиенте
Процедура СтатусОбработкаВыбора(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	ТекущийСтатус = Объект.Статус;
	Если ТекущиеПрава = "УТ" Тогда 
		Если (ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.ПроверенБухгалтером")
			ИЛИ ВыбранноеЗначение = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.Закрыт")) Тогда
			ПоказатьПредупреждение(,"У вас недостаточно прав для работы в выбранном статусе!");
			СтандартнаяОбработка = Ложь;
		ИначеЕсли ТекущийСтатус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.ПроверенБухгалтером")
			И ВыбранноеЗначение <> ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.Утвержден") Тогда
			ПоказатьПредупреждение(,"Из статуса ""Проверен бухгалтером"" доступен переход только на статус ""Утвержден""");
			СтандартнаяОбработка = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

