
////////////////////// События формы /////////////////////////////
&НаКлиенте
Перем ТекущиеПрава;

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//Задача № 70674
	Если НЕ Параметры.ЗначениеКопирования.Пустая() Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Копирование табеля запрещено!");
		СтандартнаяОбработка = Ложь;
		Отказ = Истина;
	КонецЕсли;
	//
	
	СписокВидовВремени = УчетРабочегоВремениСервер.ПолучитьСписокВидовВремениБуквенныйКод();
	Если Не ЗначениеЗаполнено(Объект.ПериодРегистрации) Тогда
		Объект.ПериодРегистрации = НачалоМесяца(ТекущаяДата());
	КонецЕсли;
	
	//МесяцРегистрацииСтрокой = УчетРабочегоВремениСервер.ПолучитьПредставлениеМесяца(Объект.ПериодРегистрации);
	//КолДнейВМес = День(КонецМесяца(Объект.ПериодРегистрации));
	
	Если Не ЗначениеЗаполнено(Объект.Автор) Тогда
		Объект.Автор = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Если Объект.КоличествоСтрок = 0 Тогда
		Объект.КоличествоСтрок = 1;
	КонецЕсли;
	
	КоличествоСтрокНачально = Объект.КоличествоСтрок;
	Объект.ПланФакт = Перечисления.ПланФакт.Факт;
	ОтображатьФакт = Истина;
	
	ЗагрузитьСписокОтделов();
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.НеУтвержден") Тогда
		Элементы.ДанныеОВремени.ИзменятьПорядокСтрок = Ложь;
	ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.НеУтвержден") Тогда
		Элементы.ДанныеОВремени.ИзменятьПорядокСтрок = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.ФормаОбщаяКомандаСвязанныеДокументы.Доступность = Истина;
	ТекущиеПрава = ИмеетПравоУтверждениеТабеля();
	
    ОбновитьДоступностьЭлементовФормыПоСтатусуИПравам();
	
	ОбновитьОформление();
	УстановитьТипыЗначений();
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		ОбновитьИтогКлиент();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступностьЭлементовФормы(Флаг)
	ТолькоПросмотр = НЕ Флаг;
КонецПроцедуры
&НаКлиенте
Процедура УстановитьДоступностьПоДням(Флаг)
	Элементы.Дата.ТолькоПросмотр = НЕ Флаг;
	Элементы.Номер.ТолькоПросмотр = НЕ Флаг;
	Элементы.МесяцОрганизацияГруппа.ТолькоПросмотр = НЕ Флаг;
	Элементы.Тело.ТолькоПросмотр = Ложь;
	Элементы.Тело.Доступность = Истина;
	Элементы.Основное.ТолькоПросмотр = НЕ Флаг;	
	СписокЭлементов = Новый Массив();
	Для н = 16 по 35 Цикл
		СписокЭлементов.Добавить("ДанныеОВремениГруппа" + н);
		СписокЭлементов.Добавить("день" + н);		
	КонецЦикла;
	
	СписокЭлементов.Добавить("ДанныеОВремениНомерСтроки");
	СписокЭлементов.Добавить("ДанныеОВремениСотрудник1");
	СписокЭлементов.Добавить("ДанныеОВремениНомерСотрудника");
	СписокЭлементов.Добавить("ДанныеОВремениСотрудникДолжность");
	СписокЭлементов.Добавить("ДанныеОВремениСотрудникОтдел");
	
	Для каждого Элемент из Элементы.Тело.ПодчиненныеЭлементы Цикл
		Если ТипЗнч(Элемент)= Тип("ТаблицаФормы") Тогда
			Для каждого ЭлементТаблицы из Элемент.ПодчиненныеЭлементы Цикл
				Если СписокЭлементов.Найти(ЭлементТаблицы.Имя) = Неопределено Тогда
					ЭлементТаблицы.ТолькоПросмотр = НЕ флаг;	
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
&НаКлиенте
Процедура ДоступностьВсегоКромеСтатуса(Флаг)
	 Элементы.Дата.ТолькоПросмотр = НЕ Флаг;
	 Элементы.Номер.ТолькоПросмотр = НЕ Флаг;
	 Элементы.МесяцОрганизацияГруппа.ТолькоПросмотр = НЕ Флаг; 
	 Элементы.Тело.ТолькоПросмотр = НЕ Флаг;
	 Элементы.Основное.ТолькоПросмотр = НЕ Флаг;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДоступностьЭлементовФормыПоСтатусуИПравам()
	Статус = Объект.Статус;
	
	//УТ - служба персонала
	Если ТекущиеПрава = "УТ" Тогда 
		Если Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.НеУтвержден")
			ИЛИ Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.УтвержденКАвансу") Тогда
			УстановитьДоступностьЭлементовФормы(Истина);
		ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.Утвержден") Тогда
			УстановитьДоступностьПоДням(Ложь);
			Элементы.Статус.ТолькоПросмотр = Истина;
		ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.ПроверенБухгалтером") Тогда
			УстановитьДоступностьПоДням(Ложь);
		Иначе
			УстановитьДоступностьЭлементовФормы(Ложь);
		КонецЕсли;
	
	//БУХ - Бухгалтер по зп
	ИначеЕсли ТекущиеПрава = "БУХ" Тогда
		ДоступностьВсегоКромеСтатуса(Ложь);
	
	//НЕТ - обычный пользователь
	ИначеЕсли ТекущиеПрава = "НЕТ" Тогда 
		Если Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.НеУтвержден") Тогда
			Элементы.Статус.Доступность = Ложь;
			Элементы.Статус.ТолькоПросмотр = Истина;
		ИначеЕсли Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.УтвержденКАвансу")
			ИЛИ Статус = ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.ПроверенБухгалтером")Тогда
            УстановитьДоступностьПоДням(Ложь);
			Элементы.Статус.Доступность = Ложь;
			Элементы.Статус.ТолькоПросмотр = Истина;
		Иначе
			УстановитьДоступностьЭлементовФормы(Ложь);
		КонецЕсли;
	КонецЕсли;
		
	Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.ТабельУчетаРабочегоВремениСтатус.НеУтвержден") Тогда
		Элементы.ДанныеОВремени.ИзменятьПорядокСтрок = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОформление()
	СкрытьДни();
	УстановитьОформлениеПредставлений();
	УстановитьУсловноеОформлениеПолей();
	УстановитьВидимостьСотрудниковПоСекции();
КонецПроцедуры

&НаКлиенте
Процедура СкрытьДни()
	
	МесяцРегистрацииСтрокой = УчетРабочегоВремениКлиент.ПолучитьПредставлениеМесяца(Объект.ПериодРегистрации);
	КолДнейВМес = День(КонецМесяца(Объект.ПериодРегистрации));
	
	МассивЭлементов = Новый Массив;
	МассивЭлементов.Добавить("Представление");
	МассивЭлементов.Добавить("ПредставлениеПлан");
	МассивЭлементов.Добавить("НачалоСменыПлан");
	МассивЭлементов.Добавить("ДанныеОВремениПримечание");
	МассивЭлементов.Добавить("день");
	
	Для Каждого ЭлементМассива Из МассивЭлементов Цикл
		Для сч = 28 по КолДнейВМес Цикл
			ЭтаФорма.Элементы[ЭлементМассива + сч].Видимость = Истина;
		КонецЦикла;
		Для сч = КолДнейВМес + 1 По 31 Цикл
		    ЭтаФорма.Элементы[ЭлементМассива + сч].Видимость = Ложь;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОформлениеПредставлений()
	
	ДанныеВыбора = УчетРабочегоВремениСервер.ПолучитьСписокВидовВремениСтруктурой("");
	ВидыДнейМесяца = ПолучитьВидыДней(Объект.ПериодРегистрации);
	
	МассивПредставлений = Новый Массив;
	МассивПредставлений.Добавить("Представление");
	МассивПредставлений.Добавить("ПредставлениеПлан");
	МассивПредставлений.Добавить("НачалоСменыПлан");
	
	Для Каждого ЭлементПредставление Из МассивПредставлений Цикл
		
		Для сч = 1 По КолДнейВМес Цикл
			
			Элемент = ЭтаФорма.Элементы[ЭлементПредставление + сч];
			
			СписокВыбораВремени = Элемент.СписокВыбора;
			СписокВыбораВремени.Очистить();
			
			Если ЭлементПредставление = "НачалоСменыПлан" Тогда
				
				СписокВыбораВремени.Добавить(Дата("00010101080000"), "08:00");
				СписокВыбораВремени.Добавить(Дата("00010101090000"), "09:00");
				СписокВыбораВремени.Добавить(Дата("00010101100000"), "10:00");
				СписокВыбораВремени.Добавить(Дата("00010101110000"), "11:00");
				СписокВыбораВремени.Добавить(Дата("00010101120000"), "12:00");
				
			Иначе
				
				Элемент.Заголовок = Строка(сч);
				
				Для Каждого ВидВремени Из ДанныеВыбора Цикл
					
					Если ЭлементПредставление = "ПредставлениеПлан" И ВидВремени.Представление = "[] Явка" Тогда
						Для сч2 = -11 по -8 Цикл
							НовыйСтруктураВидВремени = Новый Структура("ВидВремени, БуквенноеОбозначение, Часы, ЕстьРазделитель");
							ЗаполнитьЗначенияСвойств(НовыйСтруктураВидВремени,ВидВремени.Значение);
							НовыйСтруктураВидВремени["Часы"] = -сч2;
							НовыйВидПредставление = "[" + Строка(-сч2) +"] Явка";
							Элемент.СписокВыбора.Вставить(0, НовыйСтруктураВидВремени, НовыйВидПредставление);	
						КонецЦикла;
					КонецЕсли;
					
					Элемент.СписокВыбора.Добавить(ВидВремени.Значение, ВидВремени.Представление);
					
				КонецЦикла;
				
				Элемент.КнопкаСпискаВыбора = Истина;
				
				ТекДата = Дата(Год(Объект.ПериодРегистрации),Месяц(Объект.ПериодРегистрации), сч);
				ВидДня = ПолучитьВидДня(ВидыДнейМесяца, ТекДата);
				
				Если ВидДня = Неопределено Тогда
					Элемент.ЦветФонаЗаголовка = Новый Цвет(100, 100, 100);
					Элемент.ЦветТекста = Новый Цвет(100, 100, 100);
				ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Рабочий") Тогда
					Элемент.ЦветТекстаЗаголовка = Новый Цвет(0, 0, 0);
					Элемент.ЦветТекста = Новый Цвет(0, 0, 0);
				ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Суббота") Тогда
					Элемент.ЦветТекстаЗаголовка= Новый Цвет(0, 0, 255);
					Элемент.ЦветТекста = Новый Цвет(0, 0, 255);
				ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Воскресенье") Тогда
					Элемент.ЦветТекстаЗаголовка= Новый Цвет(255, 0, 0);
					Элемент.ЦветТекста = Новый Цвет(255, 0, 0);
					//Задача № 70674	
				ИначеЕсли Объект.ГрафикРаботы = НайтиПятидневку() Тогда 
					Если ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Праздник") Тогда
						Элемент.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 255);
						Элемент.ЦветТекста = Новый Цвет(255, 0, 255);
					ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Предпраздничный") Тогда
						Элемент.ЦветТекстаЗаголовка = Новый Цвет(0, 0, 128);
						Элемент.ЦветТекста = Новый Цвет(0, 0, 255);
					ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Нерабочий") Тогда
						Элемент.ЦветТекстаЗаголовка = Новый Цвет(255, 0, 0);
						Элемент.ЦветТекста = Новый Цвет(255, 0, 0);
					КонецЕсли;
					//	
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЗаголовкиШапки()
	
	ОтображатьВШапке = Ложь;
	План = "";
	
	Для сч = 1 По КолДнейВМес Цикл
		
		Если Не ОтображатьФакт И ОтображатьПлан Тогда
			План = "План";
			ОтображатьВШапке = Истина;
		КонецЕсли;
		Если ОтображатьФакт И Не ОтображатьПлан Тогда
			ОтображатьВШапке = Истина;
		КонецЕсли;
		
		Элемент = ЭтаФорма.Элементы["Представление" + План + сч];
		Элемент.ОтображатьВШапке = ОтображатьВШапке;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьСотрудниковПоСекции()
	Элементы.СотрудниковПоСекцииВСмену.Видимость = ОтображатьПлан;
КонецПроцедуры

&НаСервере
Функция ИмеетПравоУтверждениеТабеля()
	Если  РольДоступна("УтверждениеТабеляУчетаРабочегоВремени") Тогда
		Возврат "УТ";
	ИначеЕсли РольДоступна("ПолныеПрава") Тогда
		Возврат "ПП";
	ИначеЕсли ПользовательИмеетПраваБухгалтера() Тогда
		Возврат "БУХ";
	Иначе
		Возврат "НЕТ";
	КонецЕсли;	
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформлениеПолей()
	
	//ПлавающийГрафик = Справочники.Календари.НайтиПоНаименованию("Плавающий график");
	
	Для сч = 1 По КолДнейВМес Цикл
		
		//////////////
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("Представление" + Строка(сч));
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ; 
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ДанныеОВремени.НачалоСменыПлан" + Строка(сч));
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ДанныеОВремени.НачалоСмены" + Строка(сч));
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
		ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ДанныеОВремени.НачалоСменыПлан" + Строка(сч));
		
		//ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		//ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ГрафикРаботы");
		//ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		//ЭлементОтбора.ПравоеЗначение = ПлавающийГрафик;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоРозовый);
		
		//////////////
		
		Элемент = УсловноеОформление.Элементы.Добавить();
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("ДанныеОВремениПримечание" + Строка(сч));
		
		ЭлементОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ОтображатьФакт");
		ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ЭлементОтбора.ПравоеЗначение = Ложь;
		
		Элемент.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
		
