Процедура УпорядочитьСписокЗапросом(ПолеСортировки)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВнешняяТаблица.НомерСтроки КАК НомерСтроки,
	|	ВнешняяТаблица.Сотрудник КАК Сотрудник
	|ПОМЕСТИТЬ ВнешняяТаблица
	|ИЗ
	|	&ВнешняяТаблица КАК ВнешняяТаблица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК СотрудникСсылка,
	|	ВнешняяТаблица.НомерСтроки КАК НомерСтроки,
	|	Должности.Наименование КАК Должность,
	|	Отделы.Наименование КАК Отдел,
	|	Сотрудники.Наименование КАК Сотрудник
	|ИЗ
	|	ВнешняяТаблица КАК ВнешняяТаблица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Должности КАК Должности
	|			ПО Сотрудники.Должность = Должности.Ссылка
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Отделы КАК Отделы
	|			ПО Сотрудники.Отдел = Отделы.Ссылка
	|		ПО ВнешняяТаблица.Сотрудник = Сотрудники.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Отдел,
	|	Должность,
	|	Сотрудник";
	
	Запрос.УстановитьПараметр("ВнешняяТаблица",Объект.ДанныеОВремени.Выгрузить(,"НомерСтроки, Сотрудник"));
	
	Если ЗначениеЗаполнено(ПолеСортировки) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "УПОРЯДОЧИТЬ ПО
		|	Отдел,
		|	Должность",  "УПОРЯДОЧИТЬ ПО
		|	"+ПолеСортировки);
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	ТаблицаЗначений = Объект.ДанныеОВремени.Выгрузить();
	
	Объект.ДанныеОВремени.Очистить();
	
	Для каждого Строка из РезультатЗапроса Цикл
		ПараметрыПоиска = Новый Структура("НомерСтроки",Строка.НомерСтроки);
		МассивСтрок = ТаблицаЗначений.НайтиСтроки(ПараметрыПоиска);
		Для каждого строкаМассива из МассивСтрок Цикл
			НоваяСтрока = Объект.ДанныеОВремени.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,строкаМассива);
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура Очистить(Команда)
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаОчисткаДанныхОВремени",ЭтаФорма);	
	
	ПоказатьВопрос(Оповещение,"Табель будет очищен?",РежимДиалогаВопрос.ДаНетОтмена,0,КодВозвратаДиалога.Да,"Очистить?");
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаОчисткаДанныхОВремени(Результат, Параметры) Экспорт		
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОчиститьДанныеОВремениСотрудниковНаСервере();
	КонецЕсли;	
КонецПроцедуры

Процедура ОчиститьДанныеОВремениСотрудниковНаСервере()
	
	Если Объект.ДанныеОВремени.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаЗначений = Новый ТаблицаЗначений;
	ТаблицаЗначений = Объект.ДанныеОВремени.Выгрузить(,"Сотрудник,НомерСотрудника,Автомобиль,Отдел,Подразделение,Должность");
	Объект.ДанныеОВремени.Очистить();
	Объект.ДанныеОВремени.Загрузить(ТаблицаЗначений);	
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьЗаПериод(Команда)
	ДатаНачалаОчищения = Неопределено;
	Оповещение = Новый ОписаниеОповещения("ПослеВводаДаты", ЭтотОбъект);	
	ПоказатьВводДаты(Оповещение,ТекущаяДата(),"Введите дату начала",ЧастиДаты.Дата);	
КонецПроцедуры

&НаКлиенте
Процедура ПослеВводаДаты(Дата, Параметры) Экспорт
	
	ДатаНачалаОчищения = Дата;
	
	Если Не Дата = Неопределено Тогда
		Если Месяц(Объект.ПериодРегистрации) = Месяц(Дата) Тогда
			ДатаНачалаОчищения = Дата;
			ДиалогСВопросом();
		Иначе
			Сообщить("Месяц даты начала очищения данных должен соответствовать месяцу регистрации данных!");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДиалогСВопросом()
	
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса",
	ЭтотОбъект);	
	
	ПоказатьВопрос(Оповещение,
	"Данные будут очищены с "+Строка(ДатаНачалаОчищения) + ". Выполнить действие?",РежимДиалогаВопрос.ДаНетОтмена, 0, КодВозвратаДиалога.Да);    
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОчиститьДанныеЗаПериод();
		ОбновитьИтогКлиент();
	КонецЕсли;	
	
КонецПроцедуры

Процедура ОчиститьДанныеЗаПериод()
	
	Если  ДатаНачалаОчищения = Неопределено Тогда
		ВОзврат;
	КонецЕсли;
	
	НомерДняДаты = День(ДатаНачалаОчищения);
	
	Если Объект.ДанныеОВремени.Количество() <> 0  Тогда
		Для каждого строка из Объект.ДанныеОВремени Цикл
			Для Инд=НомерДняДаты по КолДнейВМес Цикл
				Строка["Часов"+Строка(Инд)] = 0;
				Строка["ВидВремени"+Строка(Инд)] = Справочники.ВидыИспользованияРабочегоВремени.ПустаяСсылка();
				Строка["Примечание"+Строка(Инд)] = "";
				Строка["Представление"+Строка(Инд)] = "";
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	ВосстановитьДанныеЗаПервуюПоловинуМесяца();
КонецПроцедуры

