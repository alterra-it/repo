&НаКлиенте
Процедура ДанныеОВремениВремяПредставлениеОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	ДанныеОВремени = УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(Текст);
	Если ДанныеОВремени <> Неопределено Тогда
		Если ДанныеОВремени.Часы <= 14 Тогда
			УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, ДанныеОВремени.ВидВремени, ДанныеОВремени.Часы, ДанныеОВремени.БуквенноеОбозначение);
		Иначе
			Сообщить("Ограничение по вводу количества часов: не более 14!");
			УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, Неопределено, Неопределено, Неопределено);
		КонецЕсли;
	Иначе
		УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, Неопределено, Неопределено, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

