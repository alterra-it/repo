&НаКлиенте
Функция ПолучитьВидДня(МассивДнейМесяца, ДеньМесяца)
	
	Результат = Неопределено;
	
	Для Каждого ЭлементМассива из МассивДнейМесяца Цикл
		Если ЭлементМассива["Дата"] = ДеньМесяца Тогда
			Результат = ЭлементМассива["ВидДня"];
			Прервать;
		КонецЕсли;
	КонецЦикла;
		
	Возврат Результат;
	
КонецФункции

&НаСервере
Функция ПолучитьВидыДней(НачалоМесяца)
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ДанныеПроизводственногоКалендаря.Дата,
	|	ДанныеПроизводственногоКалендаря.ВидДня
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.Дата Между &ДатаНачала И &ДатаОкончания
	|	И ДанныеПроизводственногоКалендаря.ПроизводственныйКалендарь = &ПроизводственныйКалендарь" ;
	
	Запрос.УстановитьПараметр("ДатаНачала",НачалоДня(НачалоМесяца));
	Запрос.УстановитьПараметр("ДатаОкончания",КонецМесяца(НачалоДня(НачалоМесяца)));
	Запрос.УстановитьПараметр("ПроизводственныйКалендарь", Справочники.ПроизводственныеКалендари.НайтиПоКоду("РФ"));
	
	МассивСтруктур = Новый Массив;
	
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(Запрос.Выполнить().Выгрузить());
	
КонецФункции

