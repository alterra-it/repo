	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаОчисткаДанных(Результат, Параметры) Экспорт		
	Если Результат = КодВозвратаДиалога.Да Тогда
		Объект.ДанныеОВремени.Очистить();
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИтогКлиент()
	
	Коллекция = Объект.ДанныеОВремени;
	ИтогПоСекциям = СотрудниковПоСекцииВСмену;
	МассивИтогоВПраздники = ОбновитьИтогСервер();
	МассивСотрудниковБезОтдела = Новый Массив;
	ССЧРасчет = 0;
	
	МассивЗаполнен = ЗначениеЗаполнено(МассивИтогоВПраздники) И МассивИтогоВПраздники.Количество() = Коллекция.Количество();
	
	ИтогПоСекциям.Очистить();
	ЗагрузитьСписокОтделов();
	
	Для Каждого ДанныеОВремени Из Коллекция Цикл
		
		КолЧасов = 0;
		КолЧасовПлан = 0;
		КолЧасовОтпуск = 0;
		КолЧасовОтпускПлан = 0;
		КолДней = 0;
		КолДнейПлан = 0;
		КолДнейОтпуск = 0;
		КолДнейОтпускПлан = 0;
		КолВоКТУ = 0;
		КолВоКТУЧасы = 0;
		
		Для сч = 1 По КолДнейВМес Цикл
			
			ДанныеПримечание = ДанныеОВремени["Примечание"+сч];
			Часов = ДанныеОВремени["Часов"+сч];
			ЧасовПлан = ДанныеОВремени["ЧасовПлан"+сч];
			КТУ = ?(ТипЗнч(ДанныеПримечание) = Тип("Число"),ДанныеПримечание,0);
			Если  ТипЗнч(ДанныеПримечание) = Тип("Число") И ДанныеПримечание <> 0 Тогда 
				КолЧасовОтпуск = КолЧасовОтпуск + КТУ; 
				КолДнейОтпуск = КолДнейОтпуск + 1;
			КонецЕсли; 
			КТУЧасы = Часов*КТУ;
			КолЧасов = КолЧасов + Часов;
			КолЧасовПлан = КолЧасовПлан + ЧасовПлан;
			КолВоКТУ = КолВоКТУ + КТУ;
			КолВоКТУЧасы = КолВоКТУЧасы + КТУЧасы;
			Если Часов <> 0 Тогда 
				КолДней = КолДней + 1;
			КонецЕсли;
			Если ЧасовПлан <> 0 Тогда 
				КолДнейПлан = КолДнейПлан + 1;
			КонецЕсли;
			
			ДанныеПоПлану = ?(ЗначениеЗаполнено(ДанныеОВремени["ЧасовПлан" + сч]), 1, 0);
			Если ДанныеПоПлану > 0 Тогда
				ОтделСотрудника = ДанныеОВремени.Отдел;
				Если ЗначениеЗаполнено(ОтделСотрудника) Тогда
					ОтборДляИтогов = Новый Структура("Отдел", ОтделСотрудника);
					НайденнаяСтрока = ИтогПоСекциям.НайтиСтроки(ОтборДляИтогов)[0];
					ИтогДня = НайденнаяСтрока["д" + сч] + ДанныеПоПлану;
					НайденнаяСтрока["д" + сч] = ИтогДня;
				Иначе
					ДанныеСотрудника = ДанныеОВремени.Сотрудник; 
					СотрудникБезОтдела = МассивСотрудниковБезОтдела.Найти(ДанныеСотрудника);
					Если СотрудникБезОтдела = Неопределено Тогда
						МассивСотрудниковБезОтдела.Добавить(ДанныеСотрудника);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
		ДанныеОВремени.ИтогоЧасов = Строка(КолЧасов);
		ДанныеОВремени.ИтогоЧасовПлан = Строка(КолЧасовПлан);
		ДанныеОВремени.ИтогоЧасовОтпуск = Строка(КолЧасовОтпуск); 
		ДанныеОВремени.ИтогоДнейОтпуск = Строка(КолДнейОтпуск);
		ССЧРасчет = ССЧРасчет + КолЧасовПлан;
		
		Если МассивЗаполнен Тогда
			ДанныеОВремени.ИтогоВПраздники = Строка(МассивИтогоВПраздники[ДанныеОВремени.НомерСтроки - 1]);
		КонецЕсли;
		
		ДанныеОВремени.ИтогоДней = Строка(КолДней);
		ДанныеОВремени.ИтогоДнейПлан = Строка(КолДнейПлан);
		Если КолЧасов <> 0 Тогда
			ДанныеОВремени.ИтогоКТУ = ОКР(КолВоКТУЧасы/КолЧасов,2,РежимОкругления.Окр15как20);
		КонецЕсли;
		
	КонецЦикла;
	
	ССЧ = ССЧРасчет/164;
	
	Если МассивСотрудниковБезОтдела.Количество() > 0 Тогда
		Для Каждого СтрСотрудник из МассивСотрудниковБезОтдела Цикл
			Сообщить("У сотрудника " + СтрСотрудник + " не заполнен Отдел");
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

