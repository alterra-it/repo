#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	ТабДок = Новый ТабличныйДокумент;
	Для Каждого Ссылка Из МассивОбъектов Цикл
		СформироватьПечатнуюФорму(Ссылка, ТабДок, ПараметрыПечати);
	КонецЦикла;
	УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"ПечатнаяФорма", НСтр("ru = 'ТабельУчетаРабочегоВремени'"), ТабДок);
КонецПроцедуры

Процедура СформироватьПечатнуюФорму(Ссылка, ТабДок, ПараметрыПечати)
	
	ПечататьПлан = ПараметрыПечати.ТипДанных = "План";
	ДополнениеСтроки = ?(ПечататьПлан, "План", "");
	
	Макет = ПолучитьМакет("ПечатнаяФорма");
	Если ПечататьПлан Тогда
		Макет.УдалитьОбласть(Макет.Область("КТУ"), ТипСмещенияТабличногоДокумента.ПоГоризонтали);
		Макет.УдалитьОбласть(Макет.Область("ИтогоВПраздники"), ТипСмещенияТабличногоДокумента.ПоГоризонтали);
		Макет.Область("День").ШиринаКолонки = 3; 
	КонецЕсли;
	
	КолДнейВМес = День(КонецМесяца(Ссылка.ПериодРегистрации));
	ГраницаДляОстальных = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	ГраницаДляПоследней = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 2);
	
	ОбластьЗаголовокОсн = Макет.ПолучитьОбласть("Заголовок|Осн");
	ОбластьЗаголовокДень = Макет.ПолучитьОбласть("Заголовок|День");
	
	ОбластьШапкаОсн = Макет.ПолучитьОбласть("Шапка|Осн");
	ОбластьШапкаДень = Макет.ПолучитьОбласть("Шапка|День");
	
	ОбластьСтрокаОсн = Макет.ПолучитьОбласть("Строка|Осн");
	ОбластьСтрокаДень = Макет.ПолучитьОбласть("Строка|День");
	
	ОбластьЛинияОсн = Макет.ПолучитьОбласть("Линия|Осн");
	ОбластьЛинияДень = Макет.ПолучитьОбласть("Линия|День");
	
	ОбластьПодвалОсн = Макет.ПолучитьОбласть("Подвал|Осн");
	ОбластьПодвалДень = Макет.ПолучитьОбласть("Подвал|День");
	
	//ОбластьОтдел = Макет.ПолучитьОбласть(?(ПечататьПлан, "Отдел|Осн", "Отдел"));
	ОбластьОтдел = Макет.ПолучитьОбласть("Отдел|Осн");
	ОбластьОтделДень = Макет.ПолучитьОбласть("Отдел|День");
	ОбластьОтделИтого = Макет.ПолучитьОбласть("ОтделИтого");
	
	//Заголовок
	ОбластьЗаголовокОсн.Параметры.Номер = Ссылка.Номер;
	ОбластьЗаголовокОсн.Параметры.Дата = Формат(Ссылка.Дата, "ДФ=dd.MM.yyyy");
	ОбластьЗаголовокОсн.Параметры.ПериодРегистрации = Формат(Ссылка.ПериодРегистрации, "ДФ='ММММ гггг'");
	Для Каждого СтрОтдел Из Ссылка.Отделы Цикл
		Если ЗначениеЗаполнено(ОбластьЗаголовокОсн.Параметры.Отдел) Тогда
			ОбластьЗаголовокОсн.Параметры.Отдел = ОбластьЗаголовокОсн.Параметры.Отдел + ", " + Строка(СтрОтдел.Отдел);
		Иначе                                                  
			ОбластьЗаголовокОсн.Параметры.Отдел = Строка(СтрОтдел.Отдел);
		КонецЕсли;
	КонецЦикла;
	ОбластьЗаголовокОсн.Параметры.ГрафикРаботы = Ссылка.ГрафикРаботы;
	Если ПечататьПлан Тогда
		ОбластьЗаголовокОсн.Параметры.ПланФакт = "Плановые показатели учета времени";
	Иначе
		ОбластьЗаголовокОсн.Параметры.ПланФакт = "Фактические данные по учету времени";
	КонецЕсли;
	ТабДок.Вывести(ОбластьЗаголовокОсн);
	
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ОбластьЗаголовокДень);
	КонецЦикла;	
	
	//Шапка
	ТабДок.Вывести(ОбластьШапкаОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ОбластьШапкаДень.Параметры.День = НомерДня;
		Если НомерДня = КолДнейВМес Тогда
			ОбластьШапкаДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляПоследней;
		Иначе
			ОбластьШапкаДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляОстальных;
		КонецЕсли;
		ТабДок.Присоединить(ОбластьШапкаДень);
	КонецЦикла;
	
	//Строки
	
	Результат = ПолучитьДанныеЗапроса(Ссылка);
	
	ВыборкаОтдел = Результат[1].Выбрать();
	Выборка = Результат[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	//Результат = ПолучитьДанныеЗапроса(Ссылка);
	//
	//ВыборкаОтдел = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
	//НомерСтроки = 1;
	
	//ДополнениеСтроки = ?(ПечататьПлан, " / количество сотрудников в день:", "");
	
	Пока ВыборкаОтдел.Следующий() Цикл
		
		ИтогоЧасовПоОтделу = 0;
		ИтогоЧасовПоОтделуПлан = 0;
		ИтогоЧасовЗаОтчетныйПериод = 0;
		ИтогоЧасовВПримечании = 0;
		ОбластьОтдел.Параметры.Отдел = ВыборкаОтдел.ОтделИмя + ?(ПечататьПлан, " / количество сотрудников в день:", "");
		Если ПечататьПлан Тогда
			ОбластьОтдел.ТекущаяОбласть.ГраницаСправа = ГраницаДляПоследней;
		КонецЕсли;
		ТабДок.Вывести(ОбластьОтдел);
		
		Если ПечататьПлан Тогда
			ОбластьОтделДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляОстальных;
			Для НомерДня = 1 По КолДнейВМес Цикл
				ОбластьОтделДень.Параметры.СотрудниковВДень = ВыборкаОтдел["СотрудниковВДень" + НомерДня];
				
				//Если НомерДня = 1 Тогда
				//	ОбластьОтделДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляПоследней;
				//Иначе
					//ОбластьОтделДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляОстальных;
				//КонецЕсли;
				ТабДок.Присоединить(ОбластьОтделДень);
			КонецЦикла;
		КонецЕсли;
			
		Выборка.Сбросить();
		
		Пока Выборка.НайтиСледующий(Новый Структура("Отдел", ВыборкаОтдел.Отдел)) Цикл
			
			ВыборкаДетальныеЗаписи = Выборка.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				ЗаполнитьЗначенияСвойств(ОбластьСтрокаОсн.Параметры, ВыборкаДетальныеЗаписи);
				
				ОбластьСтрокаОсн.Параметры.ИтогоЧасов = ВыборкаДетальныеЗаписи["ИтогоЧасов" + ДополнениеСтроки];
				ОбластьСтрокаОсн.Параметры.ИтогоДней = ВыборкаДетальныеЗаписи["ИтогоДней" + ДополнениеСтроки];
				
				//ОбластьСтрокаОсн.Параметры.Ном = НомерСтроки;
				//ОбластьСтрокаОсн.Параметры.Сотрудник = ВыборкаДетальныеЗаписи.Сотрудник;
				//ОбластьСтрокаОсн.Параметры.Уволен = ВыборкаДетальныеЗаписи.Уволен;
				//ОбластьСтрокаОсн.Параметры.ТабНомер = ВыборкаДетальныеЗаписи.ТабНомер;
				//ОбластьСтрокаОсн.Параметры.Должность = ВыборкаДетальныеЗаписи.Должность;
				//ОбластьСтрокаОсн.Параметры.ИтогоЧасов = ВыборкаДетальныеЗаписи["ИтогоЧасов" + ДополнениеСтроки];
				//ОбластьСтрокаОсн.Параметры.ИтогоДней = ВыборкаДетальныеЗаписи["ИтогоДней" + ДополнениеСтроки];
				//ОбластьСтрокаОсн.Параметры.ИтогоЧасовОтпуск = ВыборкаДетальныеЗаписи.ИтогоЧасовОтпуск; 
				//ОбластьСтрокаОсн.Параметры.ИтогоВПраздники = ВыборкаДетальныеЗаписи.ИтогоВПраздники;
				//ОбластьСтрокаОсн.Параметры.ИтогоДней = ВыборкаДетальныеЗаписи.ИтогоДней;
				//ОбластьСтрокаОсн.Параметры.ИтогоДнейОтпуск = ВыборкаДетальныеЗаписи.ИтогоДнейОтпуск;
				//ОбластьСтрокаОсн.Параметры.ИтогоКТУ = ВыборкаДетальныеЗаписи.ИтогоКТУ;
				
				ТабДок.Вывести(ОбластьСтрокаОсн);
				
				Для НомерДня = 1 По КолДнейВМес Цикл
					
					ОбластьСтрокаДень.Параметры.Представление = ВыборкаДетальныеЗаписи["Представление" + ДополнениеСтроки + НомерДня];
					ДанныеПримечание = ВыборкаДетальныеЗаписи["Примечание" + НомерДня];
					ДанныеСмена = Формат(ВыборкаДетальныеЗаписи["НачалоСменыПлан" + НомерДня], "ДФ=hh:mm");
					
					ОбластьСтрокаДень.Параметры.Примечание = ?(ПечататьПлан, ДанныеСмена, ДанныеПримечание);
					
					//Если НомерДня = КолДнейВМес Тогда
					//	ОбластьСтрокаДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляПоследней;
					//Иначе
						ОбластьСтрокаДень.ТекущаяОбласть.ГраницаСправа = ГраницаДляОстальных;
					//КонецЕсли;
					ТабДок.Присоединить(ОбластьСтрокаДень);
				КонецЦикла;
				
				ИтогоЧасовЗаОтчетныйПериод = ИтогоЧасовЗаОтчетныйПериод + ВыборкаДетальныеЗаписи.ИтогоЧасов;
				ИтогоЧасовВПримечании = ИтогоЧасовВПримечании + ВыборкаДетальныеЗаписи.ИтогоЧасовОтпуск;
				//НомерСтроки = НомерСтроки+1;
				
			КонецЦикла;
			
		КонецЦикла;
		
		Если Не ПечататьПлан Тогда
			ОбластьОтделИтого.Параметры.ИтогоЧасовЗаОтчетныйПериод = ИтогоЧасовЗаОтчетныйПериод;
			ОбластьОтделИтого.Параметры.ИтогоЧасовВПримечании = ИтогоЧасовВПримечании;
			ОбластьОтделИтого.Параметры.ИтогоЧасовПоОтделу = ИтогоЧасовЗаОтчетныйПериод + ИтогоЧасовВПримечании;
			ТабДок.Вывести(ОбластьОтделИтого);
		КонецЕсли;

	КонецЦикла;
	
	//Линия
	ТабДок.Вывести(ОбластьЛинияОсн);
	
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ОбластьЛинияДень);
	КонецЦикла;
	
	//Подвал
	ОбластьПодвалОсн.Параметры.Комментарий = Ссылка.Комментарий;
	ОбластьПодвалОсн.Параметры.Автор = Ссылка.Автор;
	ТабДок.Вывести(ОбластьПодвалОсн);
	
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ОбластьПодвалДень);
	КонецЦикла;
	
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	
	ТабДок.АвтоМасштаб = Истина;
	
КонецПроцедуры

