		УправлениеПечатьюКлиент.ВыполнитьКомандуПечати(
			"Документ.ТабельУчетаРабочегоВремени",
			"ПечатнаяФорма",
			МассивДокументов,
			Неопределено,
			ПараметрыПечати);
	                                           
	//КонецЕсли;
КонецПроцедуры
