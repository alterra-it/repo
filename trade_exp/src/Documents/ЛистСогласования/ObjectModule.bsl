#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&Вместо("ОбработкаЗаполнения")
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
		
	Автор = Пользователи.ТекущийПользователь();
	
	Документы.ЛистСогласования.ЗаполнитьДанныеПоОснованию(ДанныеЗаполнения, ЭтотОбъект);
	
КонецПроцедуры

&Вместо("ОбработкаПроверкиЗаполнения")
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления Тогда
		Если Не ЗначениеЗаполнено(Проблема) Тогда
			ПроверяемыеРеквизиты.Добавить("Проблема");
		КонецЕсли;
	КонецЕсли;
	
	Если Исполнен Тогда
		ПроверяемыеРеквизиты.Добавить("ДатаИсполнения");
	КонецЕсли;
КонецПроцедуры

&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		ЗаписатьВРегистр();
		Возврат;
	КонецЕсли;
	
	Если Не ЛистыСогласованияСервер.ИмеетПолныеПрава() Тогда
		
		Если ДопМодульСервер.ЭтоКассовыйДокументПоЛистуСогласования(Основание) Тогда
			ОтметкаКассы = ЗначениеЗаполнено(Основание.Кассир) И Не РольДоступна("ОтменаЛистовСогласованияСОтметкойКассы");
		Иначе
			ОтметкаКассы = Ложь;
		КонецЕсли;  
		
		//Запись Пометка удаления
		Если ПометкаУдаления Тогда
			Отказ = Истина;
			Сообщить("Нет прав на удаление!");
		КонецЕсли;
		
		//Проверим нет ли других листов
		Если Не Аннулирован Тогда
			
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности Тогда
				Отказ = Отказ ИЛИ ЛистыСогласованияСервер.ЕстьДругиеЛистыПоЗадолженности(ЭтотОбъект);
			КонецЕсли;
			
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов Тогда
				Отказ = Отказ ИЛИ ЛистыСогласованияСервер.ЕстьДругиеЛистыПоТранзитам(ЭтотОбъект);
			КонецЕсли;
			
		КонецЕсли;
		
		//Проверки по статусам
		Если (Аннулирован ИЛИ Ссылка.Аннулирован) И (Согласован ИЛИ Ссылка.Согласован) Тогда
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И Не ЛистыСогласованияСервер.ИмеетПравоАннулированияЛистовПоЗадолженности() Тогда
				Сообщить("Нет прав на аннулирование листов согласования!");
				Отказ = Истина;
			КонецЕсли;
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов И Не ЛистыСогласованияСервер.ИмеетПравоАннулированияЛистовПоТранзитам() Тогда
				Сообщить("Нет прав на аннулирование листов согласования!");
				Отказ= Истина;
			КонецЕсли;
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не ЛистыСогласованияСервер.ИмеетПравоАннулированияЛистовПоОформлению() Тогда
				Сообщить("Нет прав на аннулирование листов согласования!");
				Отказ = Истина;
			КонецЕсли;
			
			Если Ссылка.Аннулирован И Не Аннулирован Тогда //значит снята галочка
				Если ОтметкаКассы Тогда 
					Сообщить("У документа основания установлена отметка кассы!");
					Отказ = Истина;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли (Исполнен ИЛИ Ссылка.Исполнен) И Не (Аннулирован ИЛИ Ссылка.Аннулирован) Тогда
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И Не ЛистыСогласованияСервер.ИмеетПравоИсполненияЛистовПоЗадолженности() Тогда
				Сообщить("Нет прав на исполнение!");
				Отказ = Истина;
			КонецЕсли;
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов И Не ЛистыСогласованияСервер.ИмеетПравоИсполненияЛистовПоТранзитам() Тогда
				Сообщить("Нет прав на исполнение!");
				Отказ = Истина;
			КонецЕсли;
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не ЛистыСогласованияСервер.ИмеетПравоИсполненияЛистовПоОформлению() Тогда
				Сообщить("Нет прав на исполнение!");
				Отказ = Истина;
			КонецЕсли;     
			
			Если Ссылка.Исполнен И Не Исполнен Тогда
				Если ОтметкаКассы Тогда 
					Сообщить("У документа основания установлена отметка кассы!");
					Отказ = Истина;
				КонецЕсли;
			КонецЕсли;
			
		ИначеЕсли (Согласован ИЛИ Ссылка.Согласован) И (Согласован <> Ссылка.Согласован) И Не (Аннулирован ИЛИ Ссылка.Аннулирован) И Не (Исполнен ИЛИ Ссылка.Исполнен) Тогда
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовПоЗадолженности() Тогда
				Сообщить("Нет прав на согласование!");
				Отказ = Истина;
			КонецЕсли;
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовПоТранзитам() Тогда
				Сообщить("Нет прав на согласование!");
				Отказ = Истина;
			КонецЕсли;
			Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовПоОформлению() Тогда
				Сообщить("Нет прав на согласование!");
				Отказ = Истина;
			КонецЕсли;
			
			Если Согласовано.Пользователь <> Пользователи.ТекущийПользователь() И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовЗаДругого() Тогда
				Сообщить("Не вы согласовывали лист!");
				Отказ = Истина;
			КонецЕсли;
			
			Если Ссылка.Согласован И Не Согласован Тогда
				Если ОтметкаКассы Тогда 
					Сообщить("У документа основания установлена отметка кассы!");
					Отказ = Истина;;
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		Если  ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И НЕ ДополнительныеСвойства.Свойство("ПрограммноеСозданиеЛиста") Тогда
			Если СуммаСогласования <= СуммаОплаты и Не Аннулирован  Тогда
				Отказ= Истина;
				Сообщить("Сумма согласования <= Сумма оплаты");
			КонецЕсли;
		КонецЕсли;
		
		Если СуммаСогласования < 0 Тогда
			Отказ = Истина;
			Сообщить("Сумма согласования не может быть меньше нуля!");
		КонецЕсли;
		Если СуммаОплаты < 0 Тогда
			Отказ = Истина;
			Сообщить("Сумма оплаты не может быть меньше нуля!");
		КонецЕсли;
		
		// изменение
		Если  ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности или
			ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов	Тогда 
			Если ОстатокДоступногоЛимита<=0 И Согласован Тогда
				Отказ = Истина;
				Сообщить("Пользователю не разрешено согласовывать задолженность!");
			КонецЕсли;
		КонецЕсли;
		
		Если Исполнен И Не Согласован Тогда
			Сообщить("Документ ещё не согласован!");
			Отказ = Истина;
		КонецЕсли;
		
		Если Аннулирован И (Согласован ИЛИ Исполнен) Тогда
			Сообщить("Прежде чем аннулировать нужно отменить согласование или исполнение!");
			Отказ = Истина;
		КонецЕсли;		
		
		Если  ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов Тогда
			
			Если ТипЗнч(Основание) <> Тип("ДокументСсылка.ЗаказКлиента") Тогда 
				Отказ = Истина;
				Сообщить("Согласование транзитов возможно только на основании Заказа клиента!");
			КонецЕсли;
		КонецЕсли;
		
		Если  ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов Тогда  	
			Если НачалоДня(ОплатаДо) < НачалоДня(Дата) Тогда
				Отказ = Истина;
				Сообщить("Дата оплаты меньше даты листа согласования!");
			КонецЕсли; 			
		КонецЕсли;	                               
		
		//Проверка на менеджеров Задача Тупициной
		Если Найти(ОсновнойМенеджер.Наименование, "Сектор выписки") > 0 Тогда
			Отказ = Истина;
			Сообщить("Основным менеджером не может быть Сектор выписки!");
		КонецЕсли;
		
		Если ОсновнойМенеджер.Недействителен Или ОсновнойМенеджер.ПометкаУдаления Тогда
			Сообщить("Учетная запись ответственного менеджера отключена или удалена. Укажите действующего менеджера.");
			Отказ = Истина;
		КонецЕсли;
		
		Если Не Отказ И ЗначениеЗаполнено(ОсновнойМенеджер) И НЕ ДополнительныеСвойства.Свойство("ПрограммноеСозданиеЛиста") Тогда 
			УстановитьПривилегированныйРежим(истина);
			ПрочитанныеСвойства = Пользователи.СвойстваПользователяИБ(ОсновнойМенеджер.ИдентификаторПользователяИБ);
			Если ПрочитанныеСвойства <> Неопределено И Не Пользователи.ВходВПрограммуРазрешен(ПрочитанныеСвойства) Тогда	
				Отказ = Истина;
				ОбщегоНазначения.СообщитьПользователю("Ответственному запрещена работа в 1С. Выберите другого ответственного");
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	ЕстьМаркированныйТовар=ЕстьМаркированныйТовар(ЭтотОбъект.Основание);
КонецПроцедуры                   

Функция ЕстьМаркированныйТовар(Основание)  
	//если значениезаполнено(Основание) тогда
	//	ТипДокумента=Основание.Метаданные().имя ;
	//иначе     
	//	Возврат ложь;
	//конецесли;	          
	//если не (ТипДокумента="РеализацияТоваровУслуг" или ТипДокумента="ЗаказКлиента") тогда
	//	возврат ложь;
	//конецесли;	
	//если Основание.Метаданные().ТабличныеЧасти.Найти("Товары") = НЕОПРЕДЕЛЕНО тогда
	//	Возврат Ложь;
	//конецесли;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Документ.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК Документ
	|ГДЕ
	|	Документ.Ссылка = &Ссылка
	|	И Документ.Номенклатура.ВидНоменклатуры.ПродукцияМаркируемаяДляГИСМ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	Документ.Ссылка
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК Документ
	|ГДЕ
	|	Документ.Ссылка = &Ссылка
	|	И Документ.Номенклатура.ВидНоменклатуры.ПродукцияМаркируемаяДляГИСМ";
	
	Запрос.УстановитьПараметр("Ссылка", Основание);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	возврат  не РезультатЗапроса.Пустой();
	
	
КонецФункции // ()


&Вместо("ОбработкаПроведения")
Процедура ОбработкаПроведения(Отказ, Режим)
	
	ЗаписатьВРегистр();
	
	
	ПроверитьФормуОплатыДатуДоставкиНаСервере(Истина);
	
	Если НЕ ОтправленоСогласователю И НЕ Согласован И АльтерраОбщегоНазначения.ЭтоРабочаяБаза() Тогда
		
		 Сотрудник = Ссылка.Согласовано.Пользователь;
		 НавСсылка = ПолучитьНавигационнуюСсылку(Ссылка);
		 
		 ТелоСообщения = "Требуется согласовать "+ Ссылка + " !" + Символы.ПС + НавСсылка;
		 
		 Результат = АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТелоСообщения, Сотрудник);		
		 
		 Если Результат <> Неопределено Тогда 
			 ОтправленоСогласователю = Истина;
		 Иначе
			 Сообщить("Не получилось отправить данные в Битрикс!");
		 КонецЕсли; 
		 
	КонецЕсли;	
	
	Если Отказ <> Истина Тогда
		УведомлениеПоСогласованиюТранзитов()
	КонецЕсли;
	
КонецПроцедуры

Процедура УведомлениеПоСогласованиюТранзитов()
	Если Согласован И НЕ ОтправленоМенеджеру Тогда
	    Если ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов") Тогда
	        
	        Если Основание.Товары.Количество() <> 0 Тогда
	            АвторЗаказа = Основание.Автор;    
	            НомерЗадачи = НайтиНомерЗадачи(Основание.Комментарий);            
	            
	            Запрос = Новый Запрос;
	            Запрос.Текст = 
	            "ВЫБРАТЬ РАЗЛИЧНЫЕ
	            |    ЗаказКлиентаТовары.Номенклатура.МенеджерПоставок КАК МенеджерОП
	            |ИЗ
	            |    Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	            |ГДЕ
	            |    ЗаказКлиентаТовары.Ссылка = &Ссылка
	            |    И НЕ ЗаказКлиентаТовары.Номенклатура.МенеджерПоставок.ПометкаУдаления
	            |    И ЗаказКлиентаТовары.Номенклатура.МенеджерПоставок <> ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)";
	            
	            Запрос.УстановитьПараметр("Ссылка", Основание);
	            РезультатЗапроса = Запрос.Выполнить();
				
				Если НЕ РезультатЗапроса.Пустой() Тогда
				    
				    ТекстСообщенияЛичный = "По задаче №" + НомерЗадачи + ", заказ клиента №" + ЭтотОбъект.Основание.Номер + " согласован Лист на поставку товара под заказ";
				    ТекстСообщенияЗадача = "По данной задаче согласован лист на поставку товара под заказ. Автор заказа: " + АвторЗаказа; 
					
					Выборка = РезультатЗапроса.Выбрать();
				    Пока Выборка.Следующий() Цикл
				        МенеджерОП = Выборка.МенеджерОП;
				        РезультатЛичный = АльтерраВзаимодействиеСБитрикс24.ВыполнитьЗапросУниверсальный("5508", "im.message.add", МенеджерОП, ТекстСообщенияЛичный);
				    КонецЦикла;
				    
				    РезультатЗадача = АльтерраВзаимодействиеСБитрикс24.ВыполнитьЗапросУниверсальный("5508", "task.commentitem.add",, ТекстСообщенияЗадача, НомерЗадачи); 
				
				    Если ЗначениеЗаполнено(РезультатЗадача.ОписаниеОшибки) Тогда
						Сообщить("Не получилось отправить данные в задачу Битрикс! " + РезультатЗадача.ОписаниеОшибки);
					Иначе
						ОтправленоМенеджеру = Истина;
					КонецЕсли;
				            
				КонецЕсли;
	            
	        КонецЕсли;
	        
	    КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

Функция НайтиНомерЗадачи(Комментарий)
	
	Результат = "";
    ПозицияView = Найти(Комментарий, "view/");
    Если ПозицияView = 0 Тогда
        Возврат Результат;
    КонецЕсли;
    
    ПозицияНачала = ПозицияView + 5;
    
    Для i = ПозицияНачала По СтрДлина(Комментарий) Цикл
        Символ = Сред(Комментарий, i, 1);
        Если Символ >= "0" И Символ <= "9" Тогда
            Результат = Результат + Символ;
        ИначеЕсли Не ПустаяСтрока(Результат) Тогда
            Прервать;
        КонецЕсли;
    КонецЦикла;
	
    Возврат Результат; 
	
КонецФункции



Процедура ЗаписатьВРегистр()
	
	ИспользоватьМАП= НачалоДня(Дата) >= Дата(2019,08,01) И ЗначениеЗаполнено(МАП) И (ОсновнойМенеджер <> МАП);
	
	Движения.Удержания.Записывать = Истина;
	Движения.ИзросходованныйЛимитСогласования.Записывать = Истина;
	Движения.Удержания.Очистить();
	Движения.ИзросходованныйЛимитСогласования.Очистить();
	
	Если Согласован И Не Аннулирован Тогда
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности Тогда
			Удержание= Справочники.Удержания.ПросрочкаЗадолжностиПоЛистамСогласования;
		ИначеЕсли ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов Тогда
			Удержание= Справочники.Удержания.ПросрочкаЗадолжностиПоЛистамСогласованияТранзиты;
		Иначе
			Удержание= Проблема.Удержание;
		КонецЕсли;
		
		// регистр Удержания
		Если ЗначениеЗаполнено(Удержание) Тогда
			Если Удержание.Тариф <> 0 Тогда 
				Движение = Движения.Удержания.Добавить();
				Движение.Сотрудник = ОсновнойМенеджер;
				Движение.Удержание = Удержание;
				Если ИспользоватьМАП Тогда
					Движение.СуммаУдержания = Удержание.Тариф/2;
				Иначе
					Движение.СуммаУдержания = Удержание.Тариф;
				КонецЕсли;
				Движение.ДатаНачалаДействия = Дата;
				Движение.ДатаОкончанияДействия = ДатаИсполнения;
				Движение.Периодический = Истина;
				Движение.Закрыт = Исполнен;
				Движение.Организация = Организация;
				Движение.Проблема = Проблема;
				
				//Добавляем половину удержания за МАП
				Если ИспользоватьМАП Тогда
					Движение = Движения.Удержания.Добавить();
					Движение.Сотрудник = МАП;
					Движение.Удержание = Удержание;
					Движение.СуммаУдержания = Удержание.Тариф/2;
					Движение.ДатаНачалаДействия = Дата;
					Движение.ДатаОкончанияДействия = ДатаИсполнения;
					Движение.Периодический = Истина;
					Движение.Закрыт = Исполнен;
					Движение.Организация = Организация;
					Движение.Проблема = Проблема;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ВидОперации <> Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не Исполнен Тогда
			Если СуммаСогласования <> 0 Тогда 
				Движение = Движения.ИзросходованныйЛимитСогласования.Добавить();
				Движение.ВидДвижения= ВидДвиженияНакопления.Приход;
				Движение.ВидОперации= ВидОперации;
				Движение.Период = Дата;
				Движение.Согласовано= Согласовано;
				Движение.Сумма= СуммаСогласования;
			КонецЕсли;
			
			Если СуммаОплаты <> 0 Тогда 
				Движение = Движения.ИзросходованныйЛимитСогласования.Добавить();
				Движение.ВидДвижения= ВидДвиженияНакопления.Расход;
				Движение.ВидОперации= ВидОперации;
				Движение.Период = Дата;
				Движение.Согласовано= Согласовано;
				Движение.Сумма= СуммаОплаты;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&Вместо("ОбработкаУдаленияПроведения")
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	Если (Аннулирован ИЛИ Ссылка.Аннулирован) И (Согласован ИЛИ Ссылка.Согласован) Тогда
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И Не ЛистыСогласованияСервер.ИмеетПравоАннулированияЛистовПоЗадолженности() Тогда
			Сообщить("Нет прав на аннулирование!");
			Отказ= Истина;
		КонецЕсли;
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов И Не ЛистыСогласованияСервер.ИмеетПравоАннулированияЛистовПоТранзитам() Тогда
			Сообщить("Нет прав на аннулирование!");
			Отказ= Истина;
		КонецЕсли;
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не ЛистыСогласованияСервер.ИмеетПравоАннулированияЛистовПоОформлению() Тогда
			Сообщить("Нет прав на аннулирование!");
			Отказ= Истина;
		КонецЕсли;
		
	ИначеЕсли (Исполнен ИЛИ Ссылка.Исполнен) И Не (Аннулирован ИЛИ Ссылка.Аннулирован) Тогда
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И Не ЛистыСогласованияСервер.ИмеетПравоИсполненияЛистовПоЗадолженности() Тогда
			Сообщить("Нет прав на исполнение!");
			Отказ= Истина;
		КонецЕсли;
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов И Не ЛистыСогласованияСервер.ИмеетПравоИсполненияЛистовПоТранзитам() Тогда
			Сообщить("Нет прав на исполнение!");
			Отказ= Истина;
		КонецЕсли;
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не ЛистыСогласованияСервер.ИмеетПравоИсполненияЛистовПоОформлению() Тогда
			Сообщить("Нет прав на исполнение!");
			Отказ= Истина;
		КонецЕсли;                                  
		
	ИначеЕсли (Согласован ИЛИ Ссылка.Согласован) И Не (Аннулирован ИЛИ Ссылка.Аннулирован) И Не (Исполнен ИЛИ Ссылка.Исполнен) Тогда
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовПоЗадолженности() Тогда
			Сообщить("Нет прав на согласование!");
			Отказ= Истина;
		КонецЕсли;
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовПоТранзитам() Тогда
			Сообщить("Нет прав на согласование!");
			Отказ= Истина;
		КонецЕсли;
		Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовПоОформлению() Тогда
			Сообщить("Нет прав на согласование!");
			Отказ= Истина;
		КонецЕсли;
		
		Если Согласовано.Пользователь <> Пользователи.ТекущийПользователь() И Не ЛистыСогласованияСервер.ИмеетПравоСоглосованияЛистовЗаДругого() Тогда
			Сообщить("Не вы согласовавали лист!");
			Отказ= Истина;
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры



Функция ПроверитьФормуОплатыДатуДоставкиНаСервере(ТолькоПроверка = Ложь)
Если ЗначениеЗаполнено(ЭтотОбъект.Основание) И ЭтотОбъект.Проблема = Справочники.Проблемы.НайтиПоКоду("000000001") Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка.ПрибытиеНаОтгрузку КАК ДатаДоставки,
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка.ОплатаБанковскойКартой КАК ОплатаБанковскойКартой,
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка.НужнаИнкассация КАК НужнаИнкассация,
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
			|ГДЕ
			|	ЗаказНаДоставкуКлиентуОснования.Документ = &Ссылка
			|	И ЗаказНаДоставкуКлиентуОснования.Ссылка.Проведен";
		
		Запрос.УстановитьПараметр("Ссылка", ЭтотОбъект.Основание);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() Тогда     
			Если ТолькоПроверка Тогда  
				Если Не ЭтотОбъект.Аннулирован Тогда
					ОшибкаПоДокументу = "";
					Если ЭтотОбъект.ДатаДоставки <> Выборка.ДатаДоставки Тогда    
						Если ЗначениеЗаполнено(Выборка.ДатаДоставки) Тогда
							ОшибкаПоДокументу = СтрШаблон("%1%2. ","Разные даты доставки - ",Выборка.ДатаДоставки);
						Иначе                            
							ОшибкаПоДокументу = СтрШаблон("%1%2. ","Разные даты доставки - ","Не заполнено");
						КонецЕсли;	
					КонецЕсли;	             
					
					Если Выборка.ОплатаБанковскойКартой Тогда   
						ФормаОплатыПоДокументу = Перечисления.ФормыОплаты.ПлатежнаяКарта;
					ИначеЕсли Выборка.НужнаИнкассация Тогда  
						ФормаОплатыПоДокументу = Перечисления.ФормыОплаты.Наличная;  
					Иначе
						ФормаОплатыПоДокументу = Неопределено;
					КонецЕсли;	
					
					
					Если ФормаОплатыПоДокументу <> ЭтотОбъект.ФормаОплаты Тогда   
						Если ЗначениеЗаполнено(ФормаОплатыПоДокументу) Тогда
							ОшибкаПоДокументу = СтрШаблон("%1%2%3. ",ОшибкаПоДокументу,"Разные формы оплаты - ",ФормаОплатыПоДокументу); 
						Иначе               
							ОшибкаПоДокументу = СтрШаблон("%1%2%3. ",ОшибкаПоДокументу,"Разные формы оплаты - ","Не заполнено");
						КонецЕсли;	
					КонецЕсли;
					Если ОшибкаПоДокументу <> "" Тогда    
						ТекущееСообщение = Новый СообщениеПользователю;
						ТекущееСообщение.Текст = СтрШаблон("%1 %2",ОшибкаПоДокументу,Выборка.Ссылка);
						ТекущееСообщение.КлючДанных = Выборка.Ссылка;
						ТекущееСообщение.Сообщить(); 
						Возврат Истина;
					Иначе
						Возврат Ложь;	
					КонецЕсли;	
				КонецЕсли;
			Иначе	
				ЭтотОбъект.ДатаДоставки = Выборка.ДатаДоставки;         	
				Если Выборка.ОплатаБанковскойКартой Тогда   
					ЭтотОбъект.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта;
				ИначеЕсли Выборка.НужнаИнкассация Тогда  
					ЭтотОбъект.ФормаОплаты = Перечисления.ФормыОплаты.Наличная;  
				Иначе
					ЭтотОбъект.ФормаОплаты = Неопределено;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
КонецЕсли;	
КонецФункции	  



&Вместо("ПриКопировании")
Процедура ПриКопировании(ОбъектКопирования)
	Автор= Пользователи.ТекущийПользователь();
	Согласовано= Неопределено;
	Согласован= Ложь;
	Исполнен= Ложь;
	Исполнитель= Неопределено;
	Согласователь= Неопределено;
	Аннулирован= Ложь;
КонецПроцедуры

#КонецЕсли
    