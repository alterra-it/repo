&НаКлиенте
Процедура УведомлениеПоСогласованиюОформления()
	
	Если Объект.Согласован И НЕ Объект.ОтправленоМенеджеру Тогда
		Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") Тогда
			
			ТекстСообщения = "Оформлен Лист согласования " + Объект.НомерДокумента + " от " + Объект.Дата + " по контрагенту " + Объект.Контрагент + " ,Документ№" + Объект.СчетФактура + ", причина - " + Объект.Комментарий;
			
			Результат = АльтерраВзаимодействиеСБитрикс24.ВыполнитьЗапросУниверсальный("5508", "im.message.add", Объект.ОсновнойМенеджер, ТекстСообщения);
			
			Если ЗначениеЗаполнено(Результат.ОписаниеОшибки) Тогда
				Сообщить("Не получилось отправить данные в задачу Битрикс! " + Результат.ОписаниеОшибки);
			Иначе
				Объект.ОтправленоМенеджеру = Истина;
			КонецЕсли; 
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры



