Функция ПолучитьСогласовано()
	Возврат Объект.Ссылка.Согласовано;
КонецФункции
                                                                                                  
&НаКлиенте
Процедура АннулированПриИзменении(Элемент)
	Если Объект.Аннулирован Тогда
		Объект.ПользовательАннулировал= ТекущийПользователь();
		
		ТекДата= ТекущаяДата();
		Если День(ТекДата) <= 8 Тогда
			Объект.ДатаРегистрацииАннулирования = НачалоМесяца(ТекДата)-1;
		Иначе
			Объект.ДатаРегистрацииАннулирования = ТекДата;
		КонецЕсли;
		
		
		Объект.Согласован= Ложь;
		Объект.Исполнен= Ложь;
		Элементы.Согласован.ТолькоПросмотр= Истина;
		Элементы.Исполнен.ТолькоПросмотр= Истина;
	Иначе
		Объект.ПользовательАннулировал= Неопределено;
		Объект.ДатаРегистрацииАннулирования= Неопределено;
	КонецЕсли;
	
	УстановкаВидимости();
	//УстановкаДоступностиПоПравам();
КонецПроцедуры

