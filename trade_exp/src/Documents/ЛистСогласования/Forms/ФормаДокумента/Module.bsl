&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
	
	Объект.Проблема = ПредопределенноеЗначение("Справочник.Проблемы.ПустаяСсылка");
	
	ВидОперацииПриИзмененииСервер();
	
	Объект.Согласован = Ложь;
	Объект.Исполнен = Ложь;
	Объект.Аннулирован = Ложь;
	
	ОбновитьЗадолженностьСервер();
	РасчетатьИтоговаяСуммаСогласования();
	УстановкаВидимости();
	УстановкаДоступностиПоПравам();
	
КонецПроцедуры

&НаКлиенте
Процедура СогласованиеПросроченнойЗадолженностиПриИзменении(Элемент)
	ВидОперацииПриИзменении(Элемент);
КонецПроцедуры

&НаСервере
Процедура ВидОперацииПриИзмененииСервер()
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов 
		ИЛИ (Объект.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления И Объект.Ссылка = Документы.ЛистСогласования.ПустаяСсылка()) Тогда		
		Объект.Дата = ТекущаяДата();
	Иначе
		Объект.Дата = Объект.ДатаДокумента;
	КонецЕсли;

	Основание = Объект.Основание;
	
	Если Объект.ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления
		И ТипЗнч(Основание) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
		Объект.ОсновнойМенеджер = Объект.Договор.Менеджер;
	Иначе
		Если Не ЗначениеЗаполнено(Основание.Контрагент.Партнер.ОсновнойМенеджер) Тогда
			Объект.ОсновнойМенеджер = Объект.АвторДокумента;
		Иначе
			Объект.ОсновнойМенеджер = Основание.Контрагент.Партнер.ОсновнойМенеджер;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановкаДоступностиПоПравам();
	УстановкаВидимости();   
	ПроверитьФормуОплатыДатуДоставкиНаСервере(Истина);
	Если СтатусПереданВБухгалтерию() Тогда
		Элементы.ДатаПередачиВБухгалтерию.Видимость = Истина;
	КонецЕсли; 
	
	ПроверитьОтправленоМенеджеру();
	
	
КонецПроцедуры 

&НаСервере
Процедура ПроверитьОтправленоМенеджеру()

Если Объект.Согласован Тогда
	УстановитьПривилегированныйРежим(Истина);
	Объект.ОтправленоМенеджеру = Истина;
	УстановитьПривилегированныйРежим(Ложь);
КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИсполненПриИзменении(Элемент)
	Если Объект.Исполнен Тогда
		Если  Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") Тогда
			НеИсп= Объект.Проблемы.НайтиСтроки(Новый Структура("Выполнено", Ложь));
			Если НеИсп.Количество() > 0 Тогда 
				Объект.Исполнен= Ложь;
				Сообщить("Есть не закрытые проблемы!");
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
		ТекДата = ТекущаяДата();
		Если День(ТекДата) <= 8 И НЕ ПроверитьПроблему() Тогда
			Объект.ДатаИсполнения = НачалоМесяца(ТекДата)-1;
		Иначе 
			Объект.ДатаИсполнения = ТекДата;
		КонецЕсли;
		
		Объект.Исполнитель= ТекущийПользователь();
		Объект.ДатаРегистрацииИсполнения= ТекущаяДата();
	Иначе
		Объект.ДатаИсполнения= Неопределено;
		Объект.Исполнитель= Неопределено;
		Объект.ДатаРегистрацииИсполнения= Неопределено;
	КонецЕсли;
	
	УстановкаДоступностиПоПравам();
КонецПроцедуры

&НаКлиенте
Процедура СогласованПриИзменении(Элемент)
	Если Объект.Согласован Тогда
		РасчетатьИзросходованныйЛимит();
		Если Объект.ОстатокДоступногоЛимита < 0 Тогда
			Объект.Согласован= Ложь;
			Сообщить("Привышен лимит согласования!", СтатусСообщения.Важное);
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.Согласован Тогда
		Объект.Согласователь= ТекущийПользователь();
		Объект.ДатаРегистрацииСогласования= ТекущаяДата();
		Элементы.Согласовано.ТолькоПросмотр= Истина;
	Иначе
		Объект.Согласователь= Неопределено;
		Объект.ДатаРегистрацииСогласования= Неопределено;
		Элементы.Согласовано.ТолькоПросмотр= Ложь;
	КонецЕсли;
	
	УстановкаДоступностиПоПравам();
	Если Объект.Согласован Тогда
		Объект.ОтправленоСогласователю = Истина;
	Иначе
		Объект.ОтправленоСогласователю = Ложь;
	КонецЕсли;	
		
КонецПроцедуры



&НаКлиенте
Процедура СогласованоПриИзменении(Элемент)
	РасчетатьИзросходованныйЛимит();
	СтароеСогласовано = ПолучитьСогласовано();
	Если СтароеСогласовано <> Объект.Согласовано и Объект.Согласовано <> Неопределено Тогда
		Объект.ОтправленоСогласователю = Ложь;
	КонецЕсли;
КонецПроцедуры 

