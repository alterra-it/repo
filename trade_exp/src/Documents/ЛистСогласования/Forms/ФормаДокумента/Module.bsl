&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	РасчетатьИтоговаяСуммаСогласования();
	
	УстановитьЗаголовокСтраницы();
	СтатусЭДО=ВернутьРеквизитЭДО(Объект.Основание);
	
	Если Объект.СтатусЛистаСогласования = Перечисления.СтатусыЛистовСогласования.ПустаяСсылка() Тогда
		Объект.СтатусЛистаСогласования = Перечисления.СтатусыЛистовСогласования.ВРаботе;
	КонецЕсли;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды      
	
КонецПроцедуры          

&НаСервере
Функция ВернутьРеквизитЭДО(Основание)
	если значениезаполнено(Основание) и
		ОбщегоНазначения.ЕстьРеквизитОбъекта("СтатусДокументаВЭДО",Основание.Метаданные()) тогда	
		Возврат Основание.СтатусДокументаВЭДО;
	иначе        
		возврат Перечисления.СтатусыДокументаЭДО.ПустаяСсылка();
	конецесли; 

КонецФункции // ВернутьРеквизитЭДО()


// Если ТолькоПроверка = Истина - будет подготовлено сообщение о различиях ДатыДоставки и ФормыОплаты. 
// Если ТолькоПроверка = Ложь - будут заполнены поля текущего документа ДатыДоставки и ФормыОплаты 
&НаСервере
Функция ПроверитьФормуОплатыДатуДоставкиНаСервере(ТолькоПроверка = Ложь)
Если ЗначениеЗаполнено(Объект.Основание) И Объект.Проблема = Справочники.Проблемы.НайтиПоКоду("000000001") Тогда
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка.ПрибытиеНаОтгрузку КАК ДатаДоставки,
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка.ОплатаБанковскойКартой КАК ОплатаБанковскойКартой,
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка.НужнаИнкассация КАК НужнаИнкассация,
			|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК Ссылка
			|ИЗ
			|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
			|ГДЕ
			|	ЗаказНаДоставкуКлиентуОснования.Документ = &Ссылка
			|	И ЗаказНаДоставкуКлиентуОснования.Ссылка.Проведен";
		
		Запрос.УстановитьПараметр("Ссылка", Объект.Основание);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		
		Если Выборка.Следующий() Тогда     
			Если ТолькоПроверка Тогда  
				Если Не Объект.Аннулирован Тогда
					ОшибкаПоДокументу = "";
					Если Объект.ДатаДоставки <> Выборка.ДатаДоставки Тогда    
						Если ЗначениеЗаполнено(Выборка.ДатаДоставки) Тогда
							ОшибкаПоДокументу = СтрШаблон("%1%2. ","Разные даты доставки - ",Выборка.ДатаДоставки);
						Иначе                            
							ОшибкаПоДокументу = СтрШаблон("%1%2. ","Разные даты доставки - ","Не заполнено");
						КонецЕсли;	
					КонецЕсли;	             
					
					Если Выборка.ОплатаБанковскойКартой Тогда   
						ФормаОплатыПоДокументу = Перечисления.ФормыОплаты.ПлатежнаяКарта;
					ИначеЕсли Выборка.НужнаИнкассация Тогда  
						ФормаОплатыПоДокументу = Перечисления.ФормыОплаты.Наличная;  
					Иначе
						ФормаОплатыПоДокументу = Неопределено;
					КонецЕсли;	
					
					
					Если ФормаОплатыПоДокументу <> Объект.ФормаОплаты Тогда   
						Если ЗначениеЗаполнено(ФормаОплатыПоДокументу) Тогда
							ОшибкаПоДокументу = СтрШаблон("%1%2%3. ",ОшибкаПоДокументу,"Разные формы оплаты - ",ФормаОплатыПоДокументу); 
						Иначе               
							ОшибкаПоДокументу = СтрШаблон("%1%2%3. ",ОшибкаПоДокументу,"Разные формы оплаты - ","Не заполнено");
						КонецЕсли;	
					КонецЕсли;
					Если ОшибкаПоДокументу <> "" Тогда    
						ТекущееСообщение = Новый СообщениеПользователю;
						ТекущееСообщение.Текст = СтрШаблон("%1 %2",ОшибкаПоДокументу,Выборка.Ссылка);
						ТекущееСообщение.КлючДанных = Выборка.Ссылка;
						ТекущееСообщение.Сообщить(); 
						Возврат Истина;
					Иначе
						Возврат Ложь;	
					КонецЕсли;	
				КонецЕсли;
			Иначе	
				Объект.ДатаДоставки = Выборка.ДатаДоставки;         	
				Если Выборка.ОплатаБанковскойКартой Тогда   
					Объект.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта;
				ИначеЕсли Выборка.НужнаИнкассация Тогда  
					Объект.ФормаОплаты = Перечисления.ФормыОплаты.Наличная;  
				Иначе
					Объект.ФормаОплаты = Неопределено;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
КонецЕсли;	
КонецФункции	  

