&НаСервере
Процедура УстановитьЗаголовокСтраницы()
	НеИсп= Объект.Проблемы.НайтиСтроки(Новый Структура("Выполнено", Ложь));
	Элементы.СтраницаПроблемы.Заголовок= "Проблемы ("+НеИсп.Количество()+" из "+Объект.Проблемы.Количество()+")";
КонецПроцедуры

//расчет остатка лимита
&НаСервере
Процедура РасчетатьИзросходованныйЛимит()
	Если Объект.ВидОперации <> Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления Тогда
		Объект.ОстатокДоступногоЛимита= ЛистыСогласованияСервер.ПолучитьОстатокДоступногоЛимита(Объект)-Объект.СуммаСогласования+Объект.СуммаОплаты;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура РасчетатьИтоговаяСуммаСогласования()
	Если Объект.ВидОперации <> Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления Тогда
		ИтоговаяСуммаСогласования= ЛистыСогласованияСервер.РасчетатьИтоговаяСуммаСогласования(Объект)+Объект.СуммаСогласования-Объект.СуммаОплаты;
	ИначеЕсли Объект.Проблема = Справочники.Проблемы.НайтиПоКоду("000000001") Тогда//Доставка по звонку
		ИтоговаяСуммаСогласования= Объект.СуммаДокумента - Объект.СуммаОплаты;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УстановкаВидимости()
	Элементы.ПричинаАнулирования.Видимость= Ложь;
	Элементы.ДокументыСданыКомментарий.Видимость= Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.ВидОперации) Тогда
		Элементы.ГруппаИсполнение.Видимость= Ложь;
		Элементы.ГруппаСогласованиеОбщая.Видимость= Ложь;
		Элементы.Аннулирован.Видимость= Ложь;
		Элементы.Проблема.Видимость= Ложь;
		Элементы.СтраницаПроблемы.Видимость= Ложь;
		Элементы.СуммаСогласования.Видимость= Ложь;
		Элементы.СуммаОплаты.Видимость= Ложь;
		Элементы.ЗадолженностьПоДоговору.Видимость= Ложь;
		Элементы.ЗадолженностьПоПартнеру.Видимость= Ложь;
		Элементы.ОплатаДо.Видимость= Ложь;
		Элементы.СогласованиеПросроченнойЗадолженности.Видимость= Ложь;
	Иначе
		Элементы.ГруппаИсполнение.Видимость= Истина;
		Элементы.ГруппаСогласованиеОбщая.Видимость= Истина;
		Элементы.Аннулирован.Видимость= Истина;
	КонецЕсли;
	
	Элементы.СчетФактураВыд.Видимость = Ложь;
	Элементы.СчетФактураВход.Видимость = Ложь;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") Тогда
		Элементы.Проблема.Видимость= Истина;
		Элементы.СтраницаПроблемы.Видимость= Истина;
		Элементы.ОплатаДо.Видимость= Ложь;
		Элементы.СуммаСогласования.Видимость= Ложь;
		Элементы.СуммаОплаты.Видимость= Истина;
		Элементы.ЗадолженностьПоДоговору.Видимость= Ложь;
		Элементы.ЗадолженностьПоПартнеру.Видимость= Ложь;
		Элементы.ОстатокДоступногоЛимита.Видимость= Ложь;
		Элементы.ПричинаАнулирования.Видимость= Объект.Аннулирован;
		Элементы.ДокументыСданыКомментарий.Видимость= Объект.ДокументыСданы;
		Элементы.СогласованиеПросроченнойЗадолженности.Видимость= Ложь;
		Если ТипЗнч(Объект.Основание) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ ТипЗнч(Объект.Основание) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
			Элементы.СчетФактураВыд.Видимость = Истина;
		ИначеЕсли ТипЗнч(Объект.Основание) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") ИЛИ ТипЗнч(Объект.Основание) = Тип("ДокументСсылка.ПриобретениеУслугПрочихАктивов") Тогда
			Элементы.СчетФактураВход.Видимость = Истина;
		КонецЕсли;
	ИначеЕсли Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности") ИЛИ Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов") Тогда
		Элементы.Проблема.Видимость= Ложь;
		Элементы.СтраницаПроблемы.Видимость= Ложь;
		Элементы.ОплатаДо.Видимость= Истина;
		Элементы.СуммаСогласования.Видимость= Истина;
		Элементы.СуммаОплаты.Видимость= Истина;
		Элементы.ЗадолженностьПоДоговору.Видимость= Истина;
		Элементы.ЗадолженностьПоПартнеру.Видимость= Истина;
		Элементы.ОстатокДоступногоЛимита.Видимость= Истина;
		Элементы.СогласованиеПросроченнойЗадолженности.Видимость= Истина;
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Объект.Проблема) Тогда 
		Элементы.ДатаДоставки.Видимость = Ложь;
		Элементы.ФормаОплаты.Видимость = Ложь; 
		Элементы.ЗаполнитьДатуИФормуОплаты.Видимость = Ложь; 
	КонецЕсли;
	Если ПроверитьПроблему()  Тогда 
		Элементы.ДатаДоставки.Видимость = Истина;
		Элементы.ФормаОплаты.Видимость = Истина; 
		Элементы.ЗаполнитьДатуИФормуОплаты.Видимость = Истина;
	Иначе
		Элементы.ДатаДоставки.Видимость = Ложь;
		Элементы.ФормаОплаты.Видимость = Ложь; 
		Элементы.ЗаполнитьДатуИФормуОплаты.Видимость = Ложь; 
	КонецЕсли;
	
КонецПроцедуры       

&НаСервере
Функция ПроверитьПроблему()  
	Если Объект.Проблема = Справочники.Проблемы.НайтиПоКоду("000000001") Тогда // Доставка по звонку
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;	
КонецФункции	

&НаКлиенте
Процедура УстановкаДоступностиПоПравам()
	УстановитьТолькоПросмотр(Истина);
	ЭтаФорма.ТолькоПросмотр=Истина;
	
	//Открываем права по полям
	Если ИмеетПравоДобавленияИзмененияЛистовСогласования() И Не (Объект.Согласован ИЛИ Объект.Исполнен ИЛИ Объект.Аннулирован) Тогда
		УстановитьТолькоПросмотр(Ложь);
		ЭтаФорма.ТолькоПросмотр=Ложь;
		Элементы.Аннулирован.ТолькоПросмотр= Ложь;
	КонецЕсли;
	Если  Объект.Исполнен ИЛИ Объект.Аннулирован Тогда
		Элементы.Проблемы.ТолькоПросмотр= Истина;
	Иначе
		Элементы.Проблемы.ТолькоПросмотр= Ложь;
	КонецЕсли;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности") И ИмеетПравоАннулированияЛистовПоЗадолженности() Тогда		
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Аннулирован.ТолькоПросмотр= Ложь;
	КонецЕсли;		
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") И ИмеетПравоАннулированияЛистовПоОформлению() Тогда		
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Аннулирован.ТолькоПросмотр= Ложь;
	КонецЕсли;		
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов") И ИмеетПравоАннулированияЛистовПоТранзитам() Тогда		
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Аннулирован.ТолькоПросмотр= Ложь;
	КонецЕсли;		
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности") И ИмеетПравоИсполненияЛистовПоЗадолженности() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Исполнен.ТолькоПросмотр= Ложь;
		Элементы.ДокументыСданы.ТолькоПросмотр= Ложь;
		Если ИмеетПравоРедактироватьДатуИсполнения() Тогда
			Элементы.ДатаИсполнения.ТолькоПросмотр= Ложь;
		КонецЕсли;
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов") И ИмеетПравоИсполненияЛистовПоТранзитам() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Исполнен.ТолькоПросмотр= Ложь;
		Элементы.ДокументыСданы.ТолькоПросмотр= Ложь;
		Если ИмеетПравоРедактироватьДатуИсполнения() Тогда
			Элементы.ДатаИсполнения.ТолькоПросмотр= Ложь;
		КонецЕсли;
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") И ИмеетПравоИсполненияЛистовПоОформлению() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Исполнен.ТолькоПросмотр= Ложь;
		Элементы.ДокументыСданы.ТолькоПросмотр= Ложь;
		Элементы.СтраницаПроблемы.ТолькоПросмотр= Ложь;
		Если ИмеетПравоРедактироватьДатуИсполнения() Тогда
			Элементы.ДатаИсполнения.ТолькоПросмотр= Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности") И ИмеетПравоСоглосованияЛистовПоЗадолженности() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Согласован.ТолькоПросмотр= Ложь;
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов") И ИмеетПравоСоглосованияЛистовПоТранзитам() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Согласован.ТолькоПросмотр= Ложь;
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") И ИмеетПравоСоглосованияЛистовПоОформлению() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Согласован.ТолькоПросмотр= Ложь;
	КонецЕсли;
	
	Если ИмеетПравоСоглосованияЛистовЗаДругого() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Согласовано.ТолькоПросмотр= Ложь;
	КонецЕсли;
	
	Если ИмеетРольЛогистОператор() ИЛИ ИмеетРольУдалениеПеремещенийБухгалтерия() ИЛИ ИмеетПолныеПрава() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.Статус.ТолькоПросмотр = Ложь;
	КонецЕсли;
	
	//Видимость конкретных полей	
	Если Объект.Согласован Тогда
		Элементы.Согласовано.ТолькоПросмотр= Истина;
	КонецЕсли;
	
	Если ИмеетПравоРедактироватьДату() Тогда
		Элементы.Дата.ТолькоПросмотр= Ложь;
		Элементы.Ответственный.ТолькоПросмотр= Ложь;
	КонецЕсли;
	
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеОформления") И ИмеетПравоВноситьЧастичнуюОплатуПоЗадолженности() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.СуммаОплаты.ТолькоПросмотр= Ложь;
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности") И ИмеетПравоВноситьЧастичнуюОплатуПоЗадолженности() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.СуммаОплаты.ТолькоПросмотр= Ложь;
	КонецЕсли;
	Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов") И ИмеетПравоВноситьЧастичнуюОплатуПоТранзитам() Тогда
		ЭтаФорма.ТолькоПросмотр= Ложь;
		Элементы.СуммаОплаты.ТолькоПросмотр= Ложь;
	КонецЕсли;
	ИмеетРольЛогистОператор();
КонецПроцедуры

