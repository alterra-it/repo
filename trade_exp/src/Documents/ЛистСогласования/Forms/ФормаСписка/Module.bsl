
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Если Параметры.Свойство("Основание") Тогда
		Если ЗначениеЗаполнено(Параметры.Основание) Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Список.Отбор, "Основание", Параметры.Основание, ВидСравненияКомпоновкиДанных.Равно,, ЗначениеЗаполнено(Параметры.Основание));
			Элементы.ГруппаОтбор.Видимость= Ложь;
		КонецЕсли;
	КонецЕсли;
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды   
	
	СвойстваСписка = ОбщегоНазначения.СтруктураСвойствДинамическогоСписка();
	СвойстваСписка.ОсновнаяТаблица = "Документ.ЛистСогласования";
	СвойстваСписка.ДинамическоеСчитываниеДанных = Истина;
	ТекстЗапроса = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	ДокументЛистСогласования.Ссылка КАК Ссылка,
	               |	ДокументЛистСогласования.ПометкаУдаления КАК ПометкаУдаления,
	               |	ДокументЛистСогласования.Номер КАК Номер,
	               |	ДокументЛистСогласования.Дата КАК Дата,
	               |	ДокументЛистСогласования.Проведен КАК Проведен,
	               |	ДокументЛистСогласования.ЗадолженностьПоДоговору КАК ЗадолженностьПоДоговору,
	               |	ДокументЛистСогласования.ЗадолженностьПоПартнеру КАК ЗадолженностьПоПартнеру,
	               |	ДокументЛистСогласования.Проблема КАК Проблема,
	               |	ДокументЛистСогласования.ДатаИсполнения КАК ДатаИсполнения,
	               |	ДокументЛистСогласования.Согласовано КАК Согласовано,
	               |	ДокументЛистСогласования.Комментарий КАК Комментарий,
	               |	ДокументЛистСогласования.Автор КАК Автор,
	               |	ДокументЛистСогласования.ВидОперации КАК ВидОперации,
	               |	ДокументЛистСогласования.Основание.Ссылка КАК Основание,
	               |	ДокументЛистСогласования.Основание.Контрагент КАК Контрагент,
	               |	ДокументЛистСогласования.Согласован КАК Согласован,
	               |	ДокументЛистСогласования.Исполнен КАК Исполнен,
	               |	ДокументЛистСогласования.ОсновнойМенеджер КАК ОсновнойМенеджер,
	               |	ДокументЛистСогласования.ОплатаДо КАК ОплатаДо,
	               |	ДокументЛистСогласования.Исполнитель КАК Исполнитель,
	               |	ДокументЛистСогласования.Согласователь КАК Согласователь,
	               |	ДокументЛистСогласования.ДатаРегистрацииИсполнения КАК ДатаРегистрацииИсполнения,
	               |	ДокументЛистСогласования.ДатаРегистрацииСогласования КАК ДатаРегистрацииСогласования,
	               |	ДокументЛистСогласования.Организация КАК Организация,
	               |	ДокументЛистСогласования.СуммаДокумента КАК СуммаДокумента,
	               |	ДокументЛистСогласования.ОстатокДоступногоЛимита КАК ОстатокДоступногоЛимита,
	               |	ДокументЛистСогласования.СуммаОплаты КАК СуммаОплаты,
	               |	ДокументЛистСогласования.Аннулирован КАК Аннулирован,
	               |	ДокументЛистСогласования.ДатаРегистрацииАннулирования КАК ДатаРегистрацииАннулирования,
	               |	ДокументЛистСогласования.ПользовательАннулировал КАК ПользовательАннулировал,
	               |	ДокументЛистСогласования.СуммаСогласования КАК СуммаСогласования,
	               |	ДокументЛистСогласования.МоментВремени КАК МоментВремени,
	               |	ДокументЛистСогласования.Согласовано.Пользователь КАК СогласованоПользователь,
	               |	ДокументЛистСогласования.СуммаДокумента - ДокументЛистСогласования.СуммаОплаты КАК ИтоговаяСуммаСогласования,
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ДокументЛистСогласования.Основание.Кассир.Наименование, 0) <> 0
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК ОтметкаКассы,
	               |	ДокументЛистСогласования.ДокументыСданы КАК ДокументыСданы,
	               |	ДокументЛистСогласования.ФормаОплаты КАК ФормаОплаты,
	               |	ДокументЛистСогласования.ДатаДоставки КАК ДатаДоставки,
	               |	ДокументЛистСогласования.СчетФактура КАК СчетФактура,
	               |	ДокументЛистСогласования.ЕстьМаркированныйТовар КАК МаркированныйТовар
	               |ИЗ
	               |	Документ.ЛистСогласования КАК ДокументЛистСогласования";
	СвойстваСписка.ТекстЗапроса = ТекстЗапроса;
	ОбщегоНазначения.УстановитьСвойстваДинамическогоСписка(Элементы.Список,	СвойстваСписка);
КонецПроцедуры

