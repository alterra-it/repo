&НаСервере
Процедура ОбновитьВидимостьГруппыТН()
	
	Элементы.ГруппаТН.Видимость = 
		СтрНайти(НРег(СтрЗаменить(Объект.Партнер.Наименование, " ", "")), "транспортныерасходы") <> 0 ИЛИ
		СтрНайти(НРег(СтрЗаменить(Объект.Контрагент.Наименование, " ", "")), "транспортныерасходы") <> 0;
		
	Если Не Элементы.ГруппаТН.Видимость Тогда
		Объект.ТНВСоставеДокументовНаТовар = Ложь;
		Объект.ТННекорректноеОформление = Ложь;
		Объект.ТНКомментарий = "";
	Иначе
		Элементы.ГруппаТН.Доступность = АльтерраОбщегоНазначения._ЕстьРоль("ПриобретениеТоваровУслуг_КорректировкаТН");
	КонецЕсли;

