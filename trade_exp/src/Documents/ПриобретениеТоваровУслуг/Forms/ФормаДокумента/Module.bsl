&НаСервере
Процедура ОбновитьПараметрыВыбораЦен()
	Если ДопМодуль.НовоеЦенообразованиеЗакупа(Объект.Дата) тогда   
		Элементы.ТоварыВидЦеныПоставщика.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.Подразделение", Объект.Подразделение );
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.ДатаОтбора", Объект.Дата );  
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.ГруппаВидовЦен", Объект.соглашение.ГруппаВидовЦен );
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.Владелец", Объект.Партнер );
	КонецЕсли;    
КонецПроцедуры

&НаСервере
Процедура ПодставитьВидЦены()  
	если не ДопМодуль.НовоеЦенообразованиеЗакупа(Объект.Дата) тогда  
		возврат;
	конецесли;
	ВидЦеныПоставщика=ЦеныПредприятияЗаполнениеСервер.ПолучитьЦенуПартнера(Объект);	
	для каждого стр из Объект.Товары цикл
		стр.ВидЦеныПоставщика=ВидЦеныПоставщика;
	конеццикла;
КонецПроцедуры

&НаКлиенте 
&Вместо("ЗаполнитьЦеныВыделенныхСтрокПоВидуЦенПоставщика")
Процедура Док_ЗаполнитьЦеныВыделенныхСтрокПоВидуЦенПоставщика(Команда)
	если ДопМодуль.НовоеЦенообразованиеЗакупа(Объект.дата) тогда	
		Если ЦеныПредприятияЗаполнениеКлиент.НеобходимоЗаполнениеЦенПоВидуЦен(Объект, "Товары", НСтр("ru='Товары'")) Тогда
			ОписаниеОповещения=Новый ОписаниеОповещения("ЗаполнитьЦеныВыделенныхСтрокВыборВидЦеныПоставщикаЗавершение", ЭтотОбъект);
			
			ОткрытьФорму(
			"Справочник.ГруппировкиВидовЦен.ФормаВыбора",,,,,,
			ОписаниеОповещения);
			
		КонецЕсли;
	иначе	
		ПродолжитьВызов();
	Конецесли;
КонецПроцедуры  

&НаКлиенте
&Перед ("ЗаполнитьЦеныВыделенныхСтрокВыборВидЦеныПоставщикаЗавершение")
Процедура Док_ЗаполнитьЦеныВыделенныхСтрокВыборВидЦеныПоставщикаЗавершение(ВидЦен, ДополнительныеПараметры) Экспорт
	  если ДопМодуль.НовоеЦенообразованиеЗакупа(Объект.дата) тогда	   
		ВидЦен=	ПодборТоваровВызовСервера.ВернутьВидЦенПоПараметрамПоставщика(Объект.Соглашение,Объект.Подразделение,Объект.Партнер);
		конецесли;
	
КонецПроцедуры

&НаКлиенте
&После ("ЗагрузитьИзВнешнегоФайлаЗавершение")
Процедура Док_ЗагрузитьИзВнешнегоФайлаЗавершение(АдресЗагруженныхДанных, ДополнительныеПараметры) Экспорт
	 ПодставитьВидЦены();
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПодобратьТовары")
Процедура Док_ПодобратьТовары(Команда)
	
	// &ЗамерПроизводительности
	ОценкаПроизводительностиКлиент.НачатьЗамерВремени(Истина,
		"Документ.ПриобретениеТоваровУслуг.ФормаДокумента.Команда.ПодобратьТовары");
	
	Отказ = Ложь;
	Если Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		ОчиститьСообщения();
		СообщитьОбОшибкахОткрытияПодбора(Отказ);
	КонецЕсли;
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ХозяйственныеОперацииРаздельнойЗакупки = ХозяйственныеОперацииРаздельнойЗакупки();
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Документ",        Объект.Ссылка);
	ПараметрыФормы.Вставить("Партнер",         Объект.Партнер);
	ПараметрыФормы.Вставить("Соглашение",      Объект.Соглашение);
	ПараметрыФормы.Вставить("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС);
	ПараметрыФормы.Вставить("Склад",      Объект.Склад);
	ПараметрыФормы.Вставить("Валюта",     Объект.Валюта);
	ПараметрыФормы.Вставить("Дата",       Объект.Дата);
	ПараметрыФормы.Вставить("РежимПодбораИспользоватьСкладыВТабличнойЧасти", Истина);
	ПараметрыФормы.Вставить("РежимПодбораИсключитьГруппыДоступныеВЗаказах",  Истина);
	
	Если Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПриемНаКомиссию") Тогда
		ПараметрыФормы.Вставить("ОтборПоТипуНоменклатуры", Новый ФиксированныйМассив(НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТаре(Ложь)));
		ПараметрыФормы.Вставить("СкрыватьРучныеСкидки", Истина);
	ИначеЕсли ХозяйственныеОперацииРаздельнойЗакупки.Найти(Объект.ХозяйственнаяОперация) <> Неопределено Тогда
		ОтборПоТипуНоменклатуры = Новый ФиксированныйМассив(НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТареУслугеРаботе(Ложь));
		ПараметрыФормы.Вставить("ОтборПоТипуНоменклатуры", ОтборПоТипуНоменклатуры);
	Иначе
		ПараметрыФормы.Вставить("ОтборПоТипуНоменклатуры", Новый ФиксированныйМассив(НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТареУслугеРаботе(Ложь)));
	КонецЕсли;
	
	#Вставка
	ПараметрыФормы.Вставить("Подразделение", Объект.Подразделение);
	#КонецВставки
	
	ОткрытьФорму("Обработка.ПодборТоваровВДокументЗакупки.Форма", ПараметрыФормы, ЭтаФорма, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ЗаполнитьЦеныПоСоглашениюСервер")
Функция Док_ЗаполнитьЦеныПоСоглашениюСервер(ПоВсемСтрокам = Ложь, ТекстОшибки = "")
	
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Соглашение, "ЦенаВключаетНДС") <> Объект.ЦенаВключаетНДС Тогда
		ТекстОшибки = 
		НСтр("ru = 'Установленные значения полей ""Цена включает НДС"" в документе и соглашении разные.'");
		Возврат Ложь;
	КонецЕсли;
	
	Если ПоВсемСтрокам Тогда
		МассивСтрок = Неопределено;
	Иначе
		МассивСтрок = Новый Массив;
		Для Каждого Строка Из Элементы.Товары.ВыделенныеСтроки Цикл
			МассивСтрок.Добавить(Объект.Товары.НайтиПоИдентификатору(Строка));
		КонецЦикла;
	КонецЕсли;
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	ПересчитатьСуммуСУчетомРучнойСкидки = Новый Структура("Очищать", Ложь);
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковок");
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки", "КоличествоУпаковок");
	СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов", Неопределено);
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", ПересчитатьСуммуСУчетомРучнойСкидки);
	
	ПараметрыЗаполненияЦены = ЦеныПартнеровЗаполнениеСервер.НовыйПараметрыЗаполненияЗаполнитьЦены();
	ПараметрыЗаполненияЦены.Вставить("ПоляЗаполнения", "Цена, ВидЦеныПоставщика");
	ПараметрыЗаполненияЦены.Вставить("Дата", Объект.Дата);
	ПараметрыЗаполненияЦены.Вставить("Организация", Объект.Организация);
	ПараметрыЗаполненияЦены.Вставить("Валюта", Объект.Валюта);
	ПараметрыЗаполненияЦены.Вставить("Соглашение", Объект.Соглашение);
	ПараметрыЗаполненияЦены.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
	#Вставка
	ПараметрыЗаполненияЦены.Вставить("ВидЦеныПоставщика", ЦеныПредприятияЗаполнениеСервер.ПолучитьЦенуПартнера(Объект));
	#КонецВставки
	
	ЦеныРассчитаны = ЦеныПартнеровЗаполнениеСервер.ЗаполнитьЦены(
		Объект.Товары,
		МассивСтрок, // Массив строк
		ПараметрыЗаполненияЦены,
		СтруктураДействий);
	Если Объект.ПоступлениеПоЗаказам Тогда
		ОбновитьОтклоненияОтЗаказа();
	КонецЕсли;
	ОбщегоНазначенияУТ.ЗаполнитьДубликатыЗависимыхРеквизитовВКоллекции(Объект.Товары, ЗависимыеРеквизиты());
	РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
	
	Возврат ЦеныРассчитаны;
	
КонецФункции

&НаСервере
&ИзменениеИКонтроль("СоглашениеПриИзмененииСервер")
Процедура Док_СоглашениеПриИзмененииСервер(ПересчитыватьЦены=Истина)
	
	НаправлениеДеятельностиСтарое = Объект.НаправлениеДеятельности;
	ЦенаВключаетНДС = Объект.ЦенаВключаетНДС;
	
	ЗакупкиСервер.УстановитьДоступностьДоговора(Объект, Элементы.Договор.Доступность, Элементы.Договор.Видимость, Объект.Договор);
	
	Если ЗначениеЗаполнено(Объект.Соглашение) Тогда
		
		ДокументЗакупки = РеквизитФормыВЗначение("Объект");
		УсловияЗакупок = ЗакупкиСервер.ПолучитьУсловияЗакупок(ДокументЗакупки.Соглашение, Истина, Истина);
		ДокументЗакупки.ЗаполнитьУсловияЗакупок(УсловияЗакупок);
		ЗначениеВРеквизитФормы(ДокументЗакупки, "Объект");
		
		Если Договор <> Объект.Договор Тогда
			ДоговорПриИзмененииСервер();
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.Организация) Тогда
			ДенежныеСредстваСервер.ПроверитьЗаполнитьБанковскийСчетОрганизацииПоВладельцу(Объект.Организация, Объект.БанковскийСчетОрганизации, , Объект.НаправлениеДеятельности);
		КонецЕсли;
		
		ВалютаДокумента = Объект.Валюта;
		
		МассивРеквизитов = Новый Массив;
		МассивРеквизитов.Добавить("Валюта");
		МассивРеквизитов.Добавить("ВалютаВзаиморасчетов");
		МассивРеквизитов.Добавить("Партнер");
		МассивРеквизитов.Добавить("НаправлениеДеятельности");
		МассивРеквизитов.Добавить("Организация");
		МассивРеквизитов.Добавить("Соглашение");
		ВзаиморасчетыСервер.ФормаПриИзмененииРеквизитов(ЭтаФорма, МассивРеквизитов);
	    	
		Если ПересчитыватьЦены Тогда
			СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
			
			ПараметрыЗаполненияЦены = ЦеныПартнеровЗаполнениеСервер.НовыйПараметрыЗаполненияЗаполнитьЦены();
			ПараметрыЗаполненияЦены.Вставить("ПоляЗаполнения", "Цена, СтавкаНДС, ВидЦеныПоставщика");
			ПараметрыЗаполненияЦены.Вставить("Дата", Объект.Дата);
			ПараметрыЗаполненияЦены.Вставить("Организация", Объект.Организация);
			ПараметрыЗаполненияЦены.Вставить("Валюта", Объект.Валюта);
			ПараметрыЗаполненияЦены.Вставить("Соглашение", Объект.Соглашение);
			ПараметрыЗаполненияЦены.Вставить("НалогообложениеНДС", Объект.НалогообложениеНДС);
			#Вставка
			ПараметрыЗаполненияЦены.Вставить("ВидЦеныПоставщика", ЦеныПредприятияЗаполнениеСервер.ПолучитьЦенуПартнера(Объект));
			#КонецВставки
			
			СтруктураДействий = Новый Структура;
			СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковок");
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
			СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
			СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки", "КоличествоУпаковок");
			СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов", Неопределено);
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
			
			ЦеныПартнеровЗаполнениеСервер.ЗаполнитьЦены(
				Объект.Товары,
				Неопределено, // Массив строк
				ПараметрыЗаполненияЦены,
				СтруктураДействий);
			
		ИначеЕсли ЦенаВключаетНДС <> Объект.ЦенаВключаетНДС Тогда
			
			СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВТЧ(Объект);
			
			СтруктураДействий = Новый Структура;
			СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
			СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
			
			ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий, Неопределено);
			
		КонецЕсли;
		
		Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПриемНаКомиссию
			И ИспользоватьРучныеСкидкиВЗакупках Тогда
			ЗакупкиСервер.ОтменитьРучныеСкидки(Объект, "Товары", Истина);
		КонецЕсли;
		
		СкладГруппа = Справочники.Склады.ЭтоГруппаИСкладыИспользуютсяВТЧДокументовЗакупки(Объект.Склад);
		СкладПриИзмененииСервер();
		ХозяйственнаяОперацияПриИзмененииСервер(Ложь);
		ВернутьМногооборотнуюТаруПриИзмененииСервер();
		ОбновитьДоступностьЭлементовВозвратнойТары(ЭтаФорма);
		
		СтруктураНаименованийТабличныхЧастей = Новый Структура("Товары");
		ЗаполнитьСлужебныеРеквизитыПоНоменклатуре(СтруктураНаименованийТабличныхЧастей);
		ЗакупкиСервер.ЗаполнитьСлужебныеРеквизитыНомераГТД(Объект.Товары);
		МногооборотнаяТараСервер.ОбновитьПризнакБезВозвратнойТары(Объект.Товары, Объект.ВернутьМногооборотнуюТару);
		ОбщегоНазначенияУТ.ЗаполнитьДубликатыЗависимыхРеквизитовВКоллекции(Объект.Товары, ЗависимыеРеквизиты());
		
		Если Объект.ПоступлениеПоЗаказам Тогда
			ОбновитьОтклоненияОтЗаказа();
		КонецЕсли;
		РассчитатьИтоговыеПоказателиПоступления(ЭтаФорма);
		
		ОбновитьТекстДокументыНаОсновании();
		
	КонецЕсли;
	
	Если ИспользоватьНаправленияДеятельности Тогда
		НаправленияДеятельностиСервер.ЗаполнитьНаправлениеПоУмолчанию(Объект.НаправлениеДеятельности, Объект.Соглашение, Объект.Договор);
	КонецЕсли;
	
	ОтветственныеЛицаСервер.ЗаполнитьСписокВыбораМенеджера(Элементы.Менеджер, Объект);
	ОтветственныеЛицаСервер.УстановитьМенеджера(
		Объект, ЗакупкиСервер.ДокументОснование(Объект, "ПоступлениеПоЗаказам, ЗаказПоставщику, Товары.ЗаказПоставщику"));

	ЗаполнитьПодчиненныеСвойстваПоСтатистике("Договор");
	
	ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(Объект);
	ПриИзмененииНаправленияДеятельностиСервер();
	
	Если НаправлениеДеятельностиСтарое <> Объект.НаправлениеДеятельности Тогда
		НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
	КонецЕсли;
	
	ДоставкаТоваров.ПриЧтенииСозданииРаспоряженийНаСервере(Элементы, Объект, Объект.ПоступлениеПоЗаказам,,СводнаяИнформацияПоДоставке);
	
	Распоряжение = РаспоряжениеДляПолученияВариантаПриемкиТоваров();
	Объект.ВариантПриемкиТоваров = ЗакупкиСервер.ПолучитьВариантПриемкиТоваров(Распоряжение, Объект.Договор);
	
КонецПроцедуры

#Область ПриобретениеТранспортных
&НаКлиенте
Процедура ОткрытьФормуТранспортных(ТипТранспортных)
	Форма = ПолучитьФорму("Документ.ПриобретениеТоваровУслуг.ФормаОбъекта",, ЭтотОбъект);
    ДанныеФормы = Форма.Объект;
	
	ЗаполнитьОбъектПриобретениеТранспортных(ДанныеФормы, ТипТранспортных);
		
	КопироватьДанныеФормы(ДанныеФормы, Форма.Объект);
	Форма.Элементы.Договор.Доступность = Истина;
	Форма.Элементы.Соглашение.Доступность = Истина;
	Форма.Элементы.Соглашение.Видимость = Истина;
	Форма.Объект.Товары[0].АналитикаРасходовОбязательна = Истина;
	Форма.Объект.Товары[0].БезВозвратнойТары = Истина;
	Форма.Объект.Товары[0].ТипНоменклатуры = ПолучитьТипНоменклатуры(); 
    Форма.Открыть();   
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОбъектПриобретениеТранспортных(ДанныеФормы, ТипТранспортных)
	Попытка
		Док = ДанныеФормыВЗначение(ДанныеФормы, Тип("ДокументОбъект.ПриобретениеТоваровУслуг"));

		Док.Дата = Объект.Дата+1;
		Если ТипТранспортных = "Транспортные поставщика" Тогда
			Док.Партнер = Объект.Партнер;
			Док.Контрагент = Объект.Контрагент;
			Док.Соглашение = Объект.Соглашение; 
			Док.Договор = Объект.Договор;
			Док.Организация = Справочники.Организации.НайтиПоНаименованию("Альтерра ООО");
			Док.НомерВходящегоДокумента = Объект.НомерВходящегоДокумента;
			Док.ДатаВходящегоДокумента = Объект.ДатаВходящегоДокумента; 
		ИначеЕсли ТипТранспортных = "Транспортные" ИЛИ ТипТранспортных = "НДС" Тогда
			Док.Партнер = Справочники.Партнеры.НайтиПоНаименованию("Транспортные расходы");
			Док.Контрагент = Справочники.Контрагенты.НайтиПоНаименованию("Транспортные расходы");
			Док.Соглашение = Справочники.СоглашенияСПоставщиками.НайтиПоНаименованию("Транспортные расходы");
			Док.Организация = Справочники.Организации.НайтиПоНаименованию("АСК-Р");
			Док.Руководитель = Справочники.ОтветственныеЛицаОрганизаций.ПустаяСсылка();  
			Док.ГлавныйБухгалтер = Справочники.ОтветственныеЛицаОрганизаций.ПустаяСсылка();
		КонецЕсли;
		
		Док.ВариантПриемкиТоваров = ЗакупкиСервер.ПолучитьВариантПриемкиТоваров(,Объект.Договор);
		Док.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ЗакупкаУПоставщика;
		Док.ПорядокРасчетов = Объект.ПорядокРасчетов;
		Док.Склад = Объект.Склад;
		
		Док.СпособДоставки = Перечисления.СпособыДоставки.СиламиПоставщикаДоНашегоСклада;
		
		Док.Подразделение = Объект.Подразделение;
		Док.ЦенаВключаетНДС = Истина;
		Док.НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС; 
		Док.Принял = Справочники.ФизическиеЛица.ПустаяСсылка();
		
		Номенклатура =Справочники.Номенклатура.НайтиПоКоду("0А-00000005"); 
		СтрокаТЧ = Док.Товары.Добавить();
		СтрокаТЧ.Номенклатура = Номенклатура;
		СтрокаТЧ.КоличествоУпаковок = 1;
		СтрокаТЧ.Количество = 1;
		СтрокаТЧ.СтавкаНДС = ПолучитьСтавкуНДС(Док.Дата);
		СтрокаТЧ.ВидЦеныПоставщика = Справочники.ВидыЦенПоставщиков.НайтиПоНаименованию("Основной договор (закупка) АА");    
		СтрокаТЧ.СписатьНаРасходы = Истина;
		СтрокаТЧ.СтатьяРасходов = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("0А-000002");
		СтрокаТЧ.Подразделение = Объект.Подразделение;
		СтрокаТЧ.АналитикаРасходов = Объект.Ссылка;
		
		Если ТипТранспортных = "НДС" Тогда
			СтавкаЧисло = СтрокаТЧ.СтавкаНДС.Ставка;
			Док.Договор = Справочники.ДоговорыКонтрагентов.НайтиПоНаименованию("НДС " + СтавкаЧисло + "%", Истина);
			
			ТаблицаТовары = Объект.Товары.Выгрузить(, "Сумма, СтавкаНДС");
			ТаблицаТовары.Свернуть("СтавкаНДС", "Сумма");
			БезНДС = Справочники.СтавкиНДС.НайтиПоНаименованию("Без НДС");
			Цена = (ТаблицаТовары.Найти(БезНДС, "СтавкаНДС").Сумма) * (СтавкаЧисло/100);
			СтрокаТЧ.Цена = Цена;
			СтрокаТЧ.Сумма = Цена;
		КонецЕсли;
		
	    ЗначениеВДанныеФормы(Док, ДанныеФормы);  
		Сообщить("Документ успешно создан");    
	Исключение       
		Сообщить("Не удалось создать документ"); 
	КонецПопытки;
КонецПроцедуры

&НаКлиенте
Процедура Док_СоздатьТранспортныеПосле(Команда)
	ОткрытьФормуТранспортных("Транспортные поставщика");
КонецПроцедуры

&НаКлиенте
Процедура Док_СоздатьТранспортныеПоставщикаПосле(Команда)
	ОткрытьФормуТранспортных("Транспортные");
КонецПроцедуры

&НаКлиенте
Процедура Док_СоздатьНДСПосле(Команда)
	Если НетТоваровБезНДС() Тогда
		АльтерраОбщегоНазначения.СообщитьПользователю("Объект.Товары", "Нет строчек товаров с НДС - ""Без НДС"", невозможно выполнить операцию!");
		Возврат;
	КонецЕсли;
	ОткрытьФормуТранспортных("НДС"); 
КонецПроцедуры

&НаСервере
Функция ПолучитьТипНоменклатуры()

	Номенклатура = Справочники.Номенклатура.НайтиПоКоду("0А-00000005");	
	Возврат Номенклатура.ТипНоменклатуры;

КонецФункции

&НаСервере
Функция НетТоваровБезНДС()
	КолонкаНДС = Объект.Товары.Выгрузить().ВыгрузитьКолонку("СтавкаНДС");
	БезНДС = Справочники.СтавкиНДС.НайтиПоНаименованию("Без НДС");
	Возврат КолонкаНДС.Найти(БезНДС) = Неопределено;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСтавкуНДС(Период)
	Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	СтавкиНДС.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.СтавкиНДС КАК СтавкиНДС
		|ГДЕ
		|	СтавкиНДС.Основная
		|	И СтавкиНДС.НачалоПериода <= &Дата
		|	И (СтавкиНДС.КонецПериода >= &Дата ИЛИ СтавкиНДС.КонецПериода = ДАТАВРЕМЯ(1,1,1))");
	Запрос.УстановитьПараметр("Дата", Период);
	Результат = Запрос.Выполнить().Выбрать();
	Результат.Следующий();
	Возврат Результат.Ссылка;
КонецФункции
#КонецОбласти
   

