
&НаКлиенте
Процедура Док__НазначитьСкидкиПосле(Команда)
	ПараметрыФормы=Новый Структура;
	// для подстановки
	ПараметрыФормы.Вставить("ВидЦены",Неопределено);
	ПараметрыФормы.Вставить("ПроцентСкидки",0);
	ДополнительныеПараметры = Новый Структура;
	
	ОписаниеОповещения=Новый ОписаниеОповещения("НазначитьСкидкиЗавершение", ЭтотОбъект, ДополнительныеПараметры);  
	ОткрытьФорму("Документ.ПередачаТоваровМеждуОрганизациями.Форма.Док_ФормаНазначениеСкидок",ПараметрыФормы,,,,,
	ОписаниеОповещения);
	
КонецПроцедуры
&НаКлиенте
Процедура НазначитьСкидкиЗавершение(ПараметрыФормы, ДополнительныеПараметры) Экспорт
	
	Если ПараметрыФормы<>НЕОПРЕДЕЛЕНО и ЗначениеЗаполнено(ПараметрыФормы.ВидЦены) Тогда
		
		ЦеныРассчитаны = ЗаполнитьЦеныИСкидкиСервер(ПараметрыФормы,КэшированныеЗначения);
		//	ПродажиКлиент.ОповеститьОбОкончанииЗаполненияЦенПоВидуЦен(ЦеныРассчитаны, ВидЦен);
		
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция ЗаполнитьЦеныИСкидкиСервер(ПараметрыСкидок,КэшированныеЗначения)
	
	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("Дата", Объект.Дата);
	ПараметрыЗаполнения.Вставить("Валюта", Объект.Валюта);
	ПараметрыЗаполнения.Вставить("ВидЦены", ПараметрыСкидок.ВидЦены);
	ПараметрыЗаполнения.Вставить("ПоляЗаполнения", "Цена, ВидЦены");	
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковок");
	если параметрыСкидок.процентскидки<>0 тогда
		СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	конецесли;	
	
	ЦеныРассчитаны = ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(Объект.Товары, , ПараметрыЗаполнения, СтруктураДействий);
	
	ПараметрыТаблицы=Новый Структура("ЦенаПокупки",параметрыСкидок.ЦенаПокупки);
	ПараметрыТаблицы.Вставить("ПроцентНадбавки",параметрыСкидок.ПроцентНадбавки);
	ТоварыЦенаПокупки=ТаблицаТоваровЦенаПокупки(ПараметрыТаблицы);
	
	СтруктураДействий = Новый Структура();
	СтруктураДействий.Вставить("ПересчитатьЦенуСкидкуПоСуммеВПродажах");
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС",  ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект));
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", Новый Структура("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС));
	СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
	для каждого ТекущаяСтрока из Объект.Товары цикл
		
		НайденныеСтроки=ТоварыЦенаПокупки.НайтиСтроки(Новый Структура("Номенклатура,Характеристика",ТекущаяСтрока.Номенклатура,ТекущаяСтрока.Характеристика));
		ЦенаПокупки=0;ЦенаПродажи=0;
		если НайденныеСтроки<>НЕОПРЕДЕЛЕНО и НайденныеСтроки.Количество()>0 тогда
			ЦенаПокупки=НайденныеСтроки[0].ЦенаПокупки;
		конецесли;	
		СуммаПродажи=ТекущаяСтрока.сумма*(100-параметрыСкидок.процентскидки)/100;
		если ТекущаяСтрока.КоличествоУпаковок<>0 тогда
			ЦенаПродажи=СуммаПродажи/ТекущаяСтрока.КоличествоУпаковок;
		конецесли;
		если ЦенаПродажи>ЦенаПокупки тогда
			ТекущаяСтрока.Сумма=СуммаПродажи;
			ТекущаяСтрока.ВидЦены=?(параметрыСкидок.процентскидки=0,ТекущаяСтрока.ВидЦены,"");
		иначе
			ТекущаяСтрока.Сумма=ЦенаПокупки*ТекущаяСтрока.КоличествоУпаковок;
			ТекущаяСтрока.ВидЦены="";
		конецесли;
	конеццикла;	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Объект.Товары, СтруктураДействий,КэшированныеЗначения);	
	
	РассчитатьИтоговыеПоказателиПередачиТоваровМеждуОрганизациями(ЭтаФорма);
	
	Возврат ЦеныРассчитаны;
	
КонецФункции
&НаСервере
Функция ТаблицаТоваровЦенаПокупки(ПараметрыТаблицы)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика
		|ПОМЕСТИТЬ ВР
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
		|	ЦеныНоменклатурыСрезПоследних.Цена * (1 + &Наценка / 100) КАК ЦенаПокупки
		|ИЗ
		|	ВР КАК ВР
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Период, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
		|		ПО ВР.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
		|			И ВР.Характеристика = ЦеныНоменклатурыСрезПоследних.Характеристика";
	
	Запрос.УстановитьПараметр("ВидЦены", ПараметрыТаблицы.ЦенаПокупки);
	Запрос.УстановитьПараметр("Наценка", ПараметрыТаблицы.ПроцентНадбавки);
	Запрос.УстановитьПараметр("период", Объект.Дата);
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	
	возврат Запрос.Выполнить().Выгрузить();

КонецФункции // ТаблицаТоваровЦенаПокупки()
