Процедура ДвиженияПеремещенийКПередаче(ДокОбъект,Движения)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПередачаТоваровМеждуОрганизациямиТовары.Номенклатура,
	|	ПередачаТоваровМеждуОрганизациямиТовары.Количество,
	|	ПередачаТоваровМеждуОрганизациямиТовары.Ссылка.Склад,
	|	ПередачаТоваровМеждуОрганизациямиТовары.Ссылка.СкладПолучатель,
	|	ПередачаТоваровМеждуОрганизациямиТовары.Ссылка.ОрганизацияПолучатель как Организация,
	|	&Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) как ВидДвижения,
	|	&Ссылка,
	|	ПередачаТоваровМеждуОрганизациямиТовары.НомерСтроки,
	|	ПередачаТоваровМеждуОрганизациямиТовары.Характеристика
	|ИЗ
	|	Документ.ПередачаТоваровМеждуОрганизациями.Товары КАК ПередачаТоваровМеждуОрганизациямиТовары
	|ГДЕ
	|	ПередачаТоваровМеждуОрганизациямиТовары.Ссылка = &Ссылка
	|	И НЕ ПередачаТоваровМеждуОрганизациямиТовары.Ссылка.СкладПолучатель.Ссылка ЕСТЬ NULL 
	|";
	
	Запрос.УстановитьПараметр("Ссылка", ДокОбъект.Ссылка);
	Запрос.УстановитьПараметр("Период", ДокОбъект.Дата);
	
	НаборЗаписей = Движения.ТоварыОрганизацийКПередачеПеремещения;
	НаборЗаписей.Записывать = Истина;
	НаборЗаписей.Загрузить(Запрос.Выполнить().Выгрузить());  
	НаборЗаписей.Записать();
КонецПроцедуры


&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения)=Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 
		//Основание=реализация
		ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.РеализацияТоваровВДругуюОрганизацию;
		Дата = ДанныеЗаполнения.Дата;
		Организация = Справочники.Организации.НайтиПоНаименованию("Альтерра ООО");
		ОрганизацияПолучатель = ДанныеЗаполнения.Организация;
		Склад = ДанныеЗаполнения.Склад;
		Получатель = ДанныеЗаполнения.Организация;
		АдресДоставки = ПолучитьЗаказНаДоставку(ДанныеЗаполнения);
		
		Грузополучатель = ДанныеЗаполнения.Контрагент;
		ЗаполнитьПередачуПодДеятельность();
		ДокументОснования = ДанныеЗаполнения.Ссылка;//,
		
		ДатаПлатежа = ТекущаяДата();
		ЦенаВключаетНДС = Истина;
		
		//заполнение товары
		Для каждого Товар из ДанныеЗаполнения.Товары Цикл
			СтрТовара = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(СтрТовара, Товар,,"ВидЦены,Цена");
		КонецЦикла;
		
		//НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС;
		НалогообложениеНДС = Справочники.Организации.НалогообложениеНДС(
		Организация,
		Неопределено, // Склад
		Дата);
		
		КэшированныеЗначения = Неопределено;
		СтруктураДействий = Новый Структура;
		СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС",   Новый Структура("НалогообложениеНДС, Дата, Организация", НалогообложениеНДС, Дата, Организация));
		
		//СтруктураДействий.Вставить("ПересчитатьЦенуСкидкуПоСуммеВПродажах");
		СтруктураДействий.Вставить("ПересчитатьЦенуПоСумме");
		СтруктураДействий.Вставить("ПересчитатьСуммуНДС", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(ЭтотОбъект));
		СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", Новый Структура("ЦенаВключаетНДС", ЦенаВключаетНДС));
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Товары, СтруктураДействий, КэшированныеЗначения);

	КонецЕсли;
КонецПроцедуры

Функция ПолучитьЗаказНаДоставку(Документ)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка.АдресДоставки КАК АдресДоставки
		|ПОМЕСТИТЬ втИтог
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Документ = &Ссылка
		|ОБЪЕДИНИТЬ ВСЕ
		|ВЫБРАТЬ 
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка.АдресДоставки КАК АдресДоставки
		|ИЗ
		|   Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Документ = &ЗаказСсылка
		|;
		|ВЫБРАТЬ РАЗЛИЧНЫЕ *
		|ИЗ
		|  втИтог КАК втИтог
		|";
	
	Запрос.УстановитьПараметр("Ссылка", Документ);
	Запрос.УстановитьПараметр("ЗаказСсылка", Документ.ЗаказКлиента);

	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.АдресДоставки;
	КонецЦикла;
	Возврат "";
КонецФункции // ПолучитьЗаказНаДоставку()

#КонецЕсли
