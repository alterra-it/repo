&НаСервере
&ИзменениеИКонтроль("ОбработатьПодарочныеСертификатыНаСервере")
Процедура Док_ОбработатьПодарочныеСертификатыНаСервере()

	ОтборПоПодарочномуСертификату = Объект.ПодарочныеСертификаты.Выгрузить(,"ПодарочныйСертификат").ВыгрузитьКолонку("ПодарочныйСертификат");
	Выборка = Справочники.ПодарочныеСертификаты.ВыборкаДанныхПоПодарочнымСертификатамДляОбработки(ОтборПоПодарочномуСертификату, Объект);

	Для Каждого стрСертификат Из Объект.ПодарочныеСертификаты Цикл

		Выборка.Сбросить();
		Если Выборка.НайтиСледующий(СтрСертификат.ПодарочныйСертификат, "ПодарочныйСертификат") Тогда
            #Удаление
			стрСертификат.Сумма = Выборка.Сумма;

			стрСертификат.Номинал        = Выборка.Номинал;
			стрСертификат.ВалютаНоминала = Выборка.ВалютаНоминала;
            #КонецУдаления 
			#Вставка
			Если Выборка.Номинал <> 1 тогда
				стрСертификат.Сумма = Выборка.Сумма;	
			КонецЕсли;
			стрСертификат.Номинал        = Выборка.Номинал;
			стрСертификат.ВалютаНоминала = Выборка.ВалютаНоминала;
            #КонецВставки
		КонецЕсли;	
	КонецЦикла;

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("НастроитьРМКЛокализация")
Процедура Док_НастроитьРМКЛокализация(ДоступныеВидыОплаты, ЭлементыНаПерегруппировку)

	//++ Локализация
	Элементы.СмешаннаяОплата.Видимость = Элементы.СмешаннаяОплата.Видимость ИЛИ ДоступныеВидыОплаты.СБП;
	Элементы.ОплатитьСБП.Видимость = ДоступныеВидыОплаты.СБП;
	#Вставка
	Элементы.ОплатитьСБП.Видимость = Ложь;
	#КонецВставки
	ЭлементыНаПерегруппировку.Добавить(Элементы.ОплатитьСБП);

	СуммаСБПВыполнена = РозничныеПродажиКлиентСерверЛокализация.СуммаОплатыСБППоДокументу(Объект.ОплатаПлатежнымиКартами, Истина);
	СуммаСБПОжидание = РозничныеПродажиКлиентСерверЛокализация.СуммаОплатыСБППоДокументу(Объект.ОплатаПлатежнымиКартами);
	Элементы.ГруппаСуммаСБПОжидается.Видимость = СуммаСБПВыполнена > 0 ИЛИ СуммаСБПОжидание > 0;
	Элементы.ГруппаИтогиДекорация.Видимость = НЕ Элементы.ГруппаСуммаСБПОжидается.Видимость;

	Элементы.ОплатитьСБП.Доступность = Истина;
	Элементы.СмешаннаяОплата.Доступность = Истина;

	Если СуммаСБПВыполнена > 0 Тогда
		Элементы.СуммаСБП.Заголовок = НСтр("ru = 'СБП оплачено'");
		ИнформационнаяПанельСуммаСБП = СуммаСБПВыполнена;
	ИначеЕсли СуммаСБПОжидание > 0 Тогда
		Элементы.СуммаСБП.Заголовок = НСтр("ru = 'СБП ожидается'");
		ИнформационнаяПанельСуммаСБП = СуммаСБПОжидание;
		Элементы.ОплатитьСБП.Доступность = Ложь;
		Элементы.СмешаннаяОплата.Доступность = Ложь;
	КонецЕсли;

	Если СуммаСБПВыполнена > 0 ИЛИ СуммаСБПОжидание > 0 Тогда
		Элементы.ОплатитьНаличными.Доступность = Ложь;
		Элементы.ОплатитьКартой.Доступность = Ложь;
	КонецЕсли;
	//-- Локализация

КонецПроцедуры

