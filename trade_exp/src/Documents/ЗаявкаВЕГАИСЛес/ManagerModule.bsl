			|	И Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			|	И Товары.Номенклатура.Родитель В ИЕРАРХИИ
			|			(ВЫБРАТЬ
			|				Номенклатура.Ссылка КАК Ссылка
			|			ИЗ
			|				ВТ_ГруппыЕГАИС КАК Номенклатура)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СУММА(ЕСТЬNULL(ВТ_Товары.Объем, 0)) КАК ОбъемДревесины,
			|	ЗаказКлиента.Ссылка КАК Основание,
			|	ЗаказКлиента.Номер КАК НомерДокумента,
			|	ЗаказКлиента.Организация КАК Организация,
			|	ЗаказКлиента.Склад КАК Склад,
			|	ЗаказКлиента.Партнер КАК Клиент,
			|	ЗаказКлиента.Подразделение КАК Подразделение,
			|	ТИП(Документ.ЗаказКлиента) КАК ТипДокумента,
			|	ВЫБОР
			|		КОГДА ЗаказКлиента.Контрагент.ЮридическоеФизическоеЛицо = ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо)
			|				И НЕ ЗаказКлиента.Контрагент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ИндивидуальныйПредприниматель)
			|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо)
			|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ЮридическоеЛицо)
			|	КОНЕЦ КАК ТипКлиента,
			|	ЗаказКлиента.Контрагент КАК Контрагент,
			|	ВЫБОР
			|		КОГДА ЗаказКлиента.Контрагент.ЮридическоеФизическоеЛицо = ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ЮридическоеЛицо)
			|				Или ЗаказКлиента.Контрагент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ИндивидуальныйПредприниматель)
			|			ТОГДА ВЫБОР
			|					КОГДА КонтрагентыДополнительныеРеквизиты.Свойство.Наименование = ""Номер декларации о сделке с древесиной ЕГАИС (Контрагенты)""
			|						ТОГДА КонтрагентыДополнительныеРеквизиты.Значение
			|				КОНЕЦ
			|	КОНЕЦ КАК НомерДекларацииЮЛ,
			|	ЗаказКлиента.Дата КАК ДатаДокумента
			|ИЗ
			|	ВТ_Товары КАК ВТ_Товары
			|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиента
			|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты
			|			ПО (ЗаказКлиента.Контрагент = КонтрагентыДополнительныеРеквизиты.Ссылка
			|					И КонтрагентыДополнительныеРеквизиты.Свойство.Наименование = ""Номер декларации о сделке с древесиной ЕГАИС (Контрагенты)"")
			|		ПО (ВТ_Товары.Ссылка = ЗаказКлиента.Ссылка)
			|
			|СГРУППИРОВАТЬ ПО
			|	ЗаказКлиента.Ссылка,
			|	ЗаказКлиента.Номер,
			|	ЗаказКлиента.Организация,
			|	ЗаказКлиента.Склад,
			|	ЗаказКлиента.Партнер,
			|	ЗаказКлиента.Подразделение,
			|	ЗаказКлиента.Контрагент,
			|	ВЫБОР
			|		КОГДА ЗаказКлиента.Контрагент.ЮридическоеФизическоеЛицо = ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо)
			|				И НЕ ЗаказКлиента.Контрагент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ИндивидуальныйПредприниматель)
			|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ФизическоеЛицо)
			|		ИНАЧЕ ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ЮридическоеЛицо)
			|	КОНЕЦ,
			|	ВЫБОР
			|		КОГДА ЗаказКлиента.Контрагент.ЮридическоеФизическоеЛицо = ЗНАЧЕНИЕ(Перечисление.ЮридическоеФизическоеЛицо.ЮридическоеЛицо)
			|				Или ЗаказКлиента.Контрагент.ЮрФизЛицо = ЗНАЧЕНИЕ(Перечисление.ЮрФизЛицо.ИндивидуальныйПредприниматель)
			|			ТОГДА ВЫБОР
			|					КОГДА КонтрагентыДополнительныеРеквизиты.Свойство.Наименование = ""Номер декларации о сделке с древесиной ЕГАИС (Контрагенты)""
			|						ТОГДА КонтрагентыДополнительныеРеквизиты.Значение
			|				КОНЕЦ
			|	КОНЕЦ,
			|	ЗаказКлиента.Дата";
		КонецЕсли;
		Запрос.УстановитьПараметр("Ссылка", Основание);
		 
		Выборка= Запрос.Выполнить().Выбрать();
			
		Если Выборка.Количество() = 0 Тогда
			Сообщить("Табличная часть выбранного документа не содержит пиломатериалы из сосны!");
		КонецЕсли;
			
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(Объект,Выборка);
		КонецЕсли;
			
		Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
			Объект.Контрагент = ПартнерыИКонтрагенты.ПолучитьКонтрагентаПартнераПоУмолчанию(Объект.Клиент);
		КонецЕсли;
			
		Если Объект.ТипКлиента = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо И ЗначениеЗаполнено(Объект.Клиент) Тогда
			Объект.ФИОФЛ = Объект.Клиент.Наименование;
		КонецЕсли;
				
	КонецЕсли;                               
	
	УстановитьПривилегированныйРежим(Ложь); 
	
КонецПроцедуры

Процедура ДобавитьТабдок(ТДПриемник, ТДИсточник)Экспорт
	
	ТДИсточник.Область(1,1,ТДИсточник.ВысотаТаблицы,
	ТДИсточник.ШиринаТаблицы).СоздатьФорматСтрок();
	ТДПриемник.Вывести(ТДИсточник);
	ТДПриемник.ВывестиГоризонтальныйРазделительСтраниц();
	
КонецПроцедуры

Функция СуществуютРейсыИлиЗаказыНаДоставку(Объект)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказыКДоставке.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
	|ГДЕ
	|	ЗаказыКДоставке.ДокументПродажи = &ДокументПродажи";
	
	Запрос.УстановитьПараметр("ДокументПродажи", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда 
		 Возврат Истина;
	 Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

Функция ПроверкаНаличияЗаявкиНаСоответствующийДокументПродажи(СсылкаНаДокумент) Экспорт	

	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА
		|	И Номенклатура.ЕГАИСЛес = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЧекККМ.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ДокументьПродажиНаличиеТовара
		|ИЗ
		|	Документ.ЧекККМ КАК ЧекККМ
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ЧекККМТовары
		|		ПО ЧекККМ.Ссылка = ЧекККМТовары.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
		|		ПО (ЧекККМТовары.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка)
		|ГДЕ
		|	ЧекККМ.Ссылка = &Ссылка
		|	И ЧекККМТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				Номенклатура.Ссылка КАК Ссылка
		|			ИЗ
		|				ВТ_ГруппыЕГАИС КАК Номенклатура)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|		ПО РеализацияТоваровУслуг.Ссылка = РеализацияТоваровУслугТовары.Ссылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
		|		ПО (РеализацияТоваровУслугТовары.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка)
		|ГДЕ
		|	РеализацияТоваровУслуг.Ссылка = &Ссылка
		|	И РеализацияТоваровУслугТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				Номенклатура.Ссылка КАК Ссылка
		|			ИЗ
		|				ВТ_ГруппыЕГАИС КАК Номенклатура)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ДокументьПродажиНаличиеТовара.Ссылка КАК Ссылка,
		|	ЗаявкаВЕГАИСЛес.Ссылка КАК ЗаявкаВЕГАИСЛес,
		|	ЗаявкаВЕГАИСЛес.Проведен КАК Проведен,
		|	ЗаявкаВЕГАИСЛес.ПометкаУдаления КАК ПометкаУдаления
		|ИЗ
		|	ВТ_ДокументьПродажиНаличиеТовара КАК ВТ_ДокументьПродажиНаличиеТовара
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаявкаВЕГАИСЛес КАК ЗаявкаВЕГАИСЛес
		|		ПО ВТ_ДокументьПродажиНаличиеТовара.Ссылка = ЗаявкаВЕГАИСЛес.Основание";
	
	Запрос.УстановитьПараметр("Ссылка", СсылкаНаДокумент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ОшибкаНайдена = Ложь;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.ЗаявкаВЕГАИСЛес = Null Тогда
			Сообщить("Заявка в ЕГАИС Лес по данному документу отсутствует (создайте документ нажав на соответствующую кнопку)!");
			ОшибкаНайдена = Истина;
		Иначе
			Если Не ВыборкаДетальныеЗаписи.Проведен Тогда
				Если ВыборкаДетальныеЗаписи.ПометкаУдаления Тогда
		             Сообщить("Заявка в ЕГАИС Лес по данному документу помечена на удаление (снимите пометку на удаление, исправьте документ при необходимости и проведите его)!");
				 Иначе
					 Сообщить("Заявка в ЕГАИС Лес по данному документу не проведена (исправьте документ при необходимости и проведите его)!");
				КонецЕсли;
				АльтерраОбщегоНазначения.СообщитьПользователю(ВыборкаДетальныеЗаписи .ЗаявкаВЕГАИСЛес, Строка(ВыборкаДетальныеЗаписи .ЗаявкаВЕГАИСЛес));
		        ОшибкаНайдена = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	Возврат ОшибкаНайдена;
	
КонецФункции

Процедура ПроверкаНаличияЗаявкиПриСозданииНовой(СсылкаНаДокумент,Отказ) Экспорт	
	
	Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание",СсылкаНаДокумент);
	Если Не Заявка.Пустая() Тогда
		 Сообщить("Заявка в ЕГАИС Лес по данному документу продажи уже существует!");
		 АльтерраОбщегоНазначения.СообщитьПользователю(Заявка, Строка(Заявка));
		 Отказ = Истина;
	 КонецЕсли; 
	 
КонецПроцедуры

Функция ПолучитьДанныеФЛ(Партнер,Контрагент) Экспорт
	
	Структура = Новый Структура;
	Структура.Вставить("ФИО",Партнер.Наименование);
	Структура.Вставить("Адрес",УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Партнер,Справочники.ВидыКонтактнойИнформации.АдресПартнера));
	Структура.Вставить("Паспорт",ФизическиеЛицаУТ.ПолучитьДокументФизическогоЛицаПоУмолчанию(Контрагент,Справочники.ВидыДокументовФизическихЛиц.ПаспортРФ));
	Возврат Структура;
	
КонецФункции

Процедура СозданиеОбновлениеЗаявкиЛесЕГАИСРеализации(Объект)Экспорт
	
	ЕстьПиломатериалы = ЕстьПиломатериалыВДокументе(Объект.Ссылка);
	Если ЕстьПиломатериалы = Истина Тогда
		Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание",Объект.Ссылка);
		Если Заявка.Пустая() Тогда
			ЗаявкаЕГАИС = Документы.ЗаявкаВЕГАИСЛес.СоздатьДокумент();
			Документы.ЗаявкаВЕГАИСЛес.ЗаполнитьДанныеПоОснованию(Объект.Ссылка, ЗаявкаЕГАИС);
			ЗаявкаЕГАИС.Дата = ЗаявкаЕГАИС.ДатаДокумента; 
			ЗаявкаЕГАИС.Записать(РежимЗаписиДокумента.Проведение);
			Сообщить("Создана заявка Лес ЕГАИС");
		Иначе 
			ЗаявкаЕГАИС = Заявка.Ссылка.ПолучитьОбъект();
			Если Не ЗаявкаЕГАИС.Статус Тогда
				Документы.ЗаявкаВЕГАИСЛес.ЗаполнитьДанныеПоОснованию(Объект.Ссылка, ЗаявкаЕГАИС);
				//Изменяем дату заявки в ЕГАИС Лес при установке отметки кассы на реализацию 
				Если Объект.ДополнительныеСвойства.УстановкаОтметки = Истина Тогда
					ЗаявкаЕГАИС.Дата = ТекущаяДата();					
				Иначе 
					ЗаявкаЕГАИС.Дата = ЗаявкаЕГАИС.ДатаДокумента;
				КонецЕсли;
				Попытка 
			 		ЗаявкаЕГАИС.Записать(РежимЗаписиДокумента.Проведение);
					Сообщить("Изменена заявка Лес ЕГАИС - " + ЗаявкаЕГАИС);
				Исключение 
					Сообщить(ОписаниеОшибки());                               
				КонецПопытки;
			Иначе
				Сообщить("Заявка уже внесена! Данные не изменены у документа - " + ЗаявкаЕГАИС);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура СозданиеЗаявкиЛесЕГАИС(Ссылка) Экспорт
	
	ЕстьПиломатериалы = ЕстьПиломатериалыВДокументе(Ссылка);
	Если ЕстьПиломатериалы = Истина Тогда
		Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание",Ссылка);
		Если Заявка.Пустая() Тогда
			ЗаявкаЕГАИС = Документы.ЗаявкаВЕГАИСЛес.СоздатьДокумент();
			Документы.ЗаявкаВЕГАИСЛес.ЗаполнитьДанныеПоОснованию(Ссылка, ЗаявкаЕГАИС);
			
			Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
				ЗаявкаЕГАИС.Дата = ТекущаяДата();
			Иначе		
				ЗаявкаЕГАИС.Дата = ЗаявкаЕГАИС.ДатаДокумента;
			КонецЕсли;
			
			Если ТипЗнч(Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
				ЗаявкаЕГАИС.ЗаявкаСозданаНаОснованииПеремещения = Истина;
				ЗаявкаЕГАИС.Контрагент = Справочники.Контрагенты.НайтиПоНаименованию("ЦО Альтерра", Истина);
				ЗаявкаЕГАИС.Клиент = ЗаявкаЕГАИС.Контрагент.Партнер;
			КонецЕсли;
			
		ИначеЕсли НЕ Заявка.Проведен Тогда
			ЗаявкаЕГАИС = Заявка.ПолучитьОбъект();
			Документы.ЗаявкаВЕГАИСЛес.ЗаполнитьДанныеПоОснованию(Ссылка, ЗаявкаЕГАИС);
			ЗаявкаЕГАИС.Дата = ЗаявкаЕГАИС.ДатаДокумента;
			ЗаявкаЕГАИС.ПометкаУдаления = Ложь;
			ЗаявкаЕГАИС.Статус = Ложь;
		КонецЕсли;
		Попытка 
			ЗаявкаЕГАИС.Записать(РежимЗаписиДокумента.Проведение);
			Сообщить("Создана/обновлена заявка Лес ЕГАИС");
		Исключение 
			                               
		КонецПопытки;

	КонецЕсли;
	
КонецПроцедуры

Функция ЕстьПиломатериалыВДокументе(Ссылка)Экспорт 
	
	Запрос = Новый Запрос;
	Если ТипЗнч(Ссылка)= Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда 	
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА
		|	И Номенклатура.ЕГАИСЛес = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
		|	РеализацияТоваровУслугТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И РеализацияТоваровУслугТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				Номенклатура.Ссылка КАК Ссылка
		|			ИЗ
		|				ВТ_ГруппыЕГАИС КАК Номенклатура)";
		
	ИначеЕсли ТипЗнч(Ссылка)= Тип("ДокументСсылка.ПеремещениеТоваров") Тогда 	
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА
		|	И Номенклатура.ЕГАИСЛес = ИСТИНА
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПеремещениеТоваров.Номенклатура КАК Номенклатура,
		|	ПеремещениеТоваров.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваров
		|ГДЕ
		|	ПеремещениеТоваров.Ссылка = &Ссылка
		|	И ПеремещениеТоваров.Номенклатура.Родитель В ИЕРАРХИИ
		|			(ВЫБРАТЬ
		|				Номенклатура.Ссылка КАК Ссылка
		|			ИЗ
		|				ВТ_ГруппыЕГАИС КАК Номенклатура)";
		
	ИначеЕсли ТипЗнч(Ссылка)= Тип("ДокументСсылка.ЧекККМ") Тогда 
		Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|	ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА
		|	И Номенклатура.ЕГАИСЛес = ИСТИНА
		|	;
		|			
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЧекККМТовары.Номенклатура КАК Номенклатура,				
		|	ЧекККМТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
		|ГДЕ
		|	ЧекККМТовары.Ссылка = &Ссылка
		|	И ЧекККМТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|		(ВЫБРАТЬ
		|			Номенклатура.Ссылка КАК Ссылка
		|		ИЗ
		|			ВТ_ГруппыЕГАИС КАК Номенклатура)";

	ИначеЕсли ТипЗнч(Ссылка)= Тип("ДокументСсылка.ЗаказКлиента") Тогда 
		 Запрос.Текст =
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка
		|	ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.ЭтоГруппа = ИСТИНА
		|	И Номенклатура.ЕГАИСЛес = ИСТИНА
		|	;
		|			
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,				
		|	ЗаказКлиентаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|ГДЕ
		|	ЗаказКлиентаТовары.Ссылка = &Ссылка
		|	И ЗаказКлиентаТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|		(ВЫБРАТЬ
		|			Номенклатура.Ссылка КАК Ссылка
		|		ИЗ
		|			ВТ_ГруппыЕГАИС КАК Номенклатура)";

	КонецЕсли;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() = 0 Тогда
		Возврат Ложь;
	Иначе 
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

Процедура ОтменитьПроведениеЗаявкиЕГАИСЛес(Ссылка)Экспорт 
	
	Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание",Ссылка);
	Если НЕ Заявка.Пустая() Тогда
		ЗаявкаЕГАИС = Заявка.Ссылка.ПолучитьОбъект();
		Если Не ЗаявкаЕГАИС.Статус Тогда
			ЗаявкаЕГАИС.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		Иначе
			Сообщить("Заявка уже внесена! Данные не изменены у документа - " + ЗаявкаЕГАИС);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ПометкаНаУдалениеЗаявкиЕГАИСЛес(Ссылка)Экспорт
	
	Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание",Ссылка);
	Если НЕ Заявка.Пустая() Тогда
		ЗаявкаЕГАИС = Заявка.Ссылка.ПолучитьОбъект();
		Если Не ЗаявкаЕГАИС.Статус Тогда
			Если Ссылка.ПометкаУдаления Тогда  
				ЗаявкаЕГАИС.ПометкаУдаления = Истина;
				ЗаявкаЕГАИС.Записать();
				Сообщить("Помечена на удаление заявка Лес ЕГАИС - " + ЗаявкаЕГАИС);
			Иначе
				ЗаявкаЕГАИС.ПометкаУдаления = Ложь;
				ЗаявкаЕГАИС.Записать();
			КонецЕсли;
		Иначе
			Сообщить("Заявка уже внесена! Данные не изменены у документа - " + ЗаявкаЕГАИС);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверкаЕГАИС(ДокументПродажи, ЭтотОбъект) Экспорт
	
	СвязанныеДокументы = КритерииОтбора.СвязанныеДокументы.Найти(ДокументПродажи);
	ДокументЕГАИС = Неопределено;
	
	Для каждого Документ из СвязанныеДокументы Цикл
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаявкаВЕГАИСЛес") И НЕ Документ.Статус Тогда
			ДокументЕГАИС = Документ;
		КонецЕсли;
	КонецЦикла;
	
	Если ДокументЕГАИС <> Неопределено Тогда
		Если Документы.ЗаявкаВЕГАИСЛес.ЕстьПиломатериалыВДокументе(ДокументПродажи) Тогда
			ОбъемДревесиныАкта = 0;
			ОбъемДревесиныДокументаОснования = 0;
			РассчетОбъемДревесиныДокументаОснования(ОбъемДревесиныДокументаОснования, ДокументПродажи);
			РассчетОбъемДревесиныАкта(ОбъемДревесиныАкта, ЭтотОбъект);
			ОбъектДокументЕГАИС = ДокументЕГАИС.ПолучитьОбъект();
			ОбъектДокументЕГАИС.ОбъемДревесины = ОбъемДревесиныДокументаОснования - ОбъемДревесиныАкта;
			ОбъектДокументЕГАИС.Записать();
			Если ТипЗнч(ЭтотОбъект) = Тип("ДокументОбъект.ВозвратТоваровОтКлиента") Тогда
				ТекстСообщенияВБт24 ="Был создан возврат на пиломатериал, в документе " + ДокументЕГАИС + " был изменен объем древесины. Его документ основания: " + ДокументПродажи;
			ИначеЕсли ТипЗнч(ЭтотОбъект) = Тип("ДокументОбъект.КорректировкаРеализации") Тогда
				ТекстСообщенияВБт24 ="Была создана корректировка на пиломатериал, в документе " + ДокументЕГАИС + " был изменен объем древесины. Его документ основания: " + ДокументПродажи;
			КонецЕсли;
			АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитриксПоИДЧата(ТекстСообщенияВБт24, "chat94681");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры  

Функция РассчетОбъемДревесиныДокументаОснования(ОбъемДревесиныДокументаОснования, ДокументПродажи) Экспорт
	
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда	
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
		|	РеализацияТоваровУслугТовары.Ссылка КАК Ссылка,
		|	РеализацияТоваровУслугТовары.Количество КАК Количество,
		|	РеализацияТоваровУслугТовары.Номенклатура.ОбъемЧислитель КАК ОбъемЧислитель,
		|	РеализацияТоваровУслугТовары.Номенклатура.ОбъемЗнаменатель КАК ОбъемЗнаменатель
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И РеализацияТоваровУслугТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|		(ВЫБРАТЬ
		|			Номенклатура.Ссылка КАК Ссылка
		|		ИЗ
		|			Справочник.Номенклатура КАК Номенклатура
		|		ГДЕ
		|			Номенклатура.ЭтоГруппа = ИСТИНА
		|			И Номенклатура.ЕГАИСЛес = ИСТИНА)";
	
	ИначеЕсли ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ЧекККМТовары.Номенклатура КАК Номенклатура,
		|	ЧекККМТовары.Ссылка КАК Ссылка,
		|	ЧекККМТовары.Количество КАК Количество,
		|	ЧекККМТовары.Номенклатура.ОбъемЧислитель КАК ОбъемЧислитель,
		|	ЧекККМТовары.Номенклатура.ОбъемЗнаменатель КАК ОбъемЗнаменатель
		|ИЗ
		|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
		|ГДЕ
		|	ЧекККМТовары.Ссылка = &Ссылка
		|	И ЧекККМТовары.Номенклатура.Родитель В ИЕРАРХИИ
		|		(ВЫБРАТЬ
		|			Номенклатура.Ссылка КАК Ссылка
		|		ИЗ
		|			Справочник.Номенклатура КАК Номенклатура
		|		ГДЕ
		|			Номенклатура.ЭтоГруппа = ИСТИНА
		|			И Номенклатура.ЕГАИСЛес = ИСТИНА)";
	
	КонецЕсли;
		
		Запрос.УстановитьПараметр("Ссылка", ДокументПродажи);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаНоменклатурыРеализации = РезультатЗапроса.Выгрузить();
		
		Для каждого Строка из ВыборкаНоменклатурыРеализации Цикл 
			ОбъемДревесиныДокументаОснования = ОбъемДревесиныДокументаОснования + ((Строка.ОбъемЧислитель / Строка.ОбъемЗнаменатель) * Строка.Количество)
		КонецЦикла;
	
	Возврат ОбъемДревесиныДокументаОснования
	
КонецФункции 

Функция РассчетОбъемДревесиныАкта(ОбъемДревесиныАкта, ЭтотОбъект) Экспорт
	
		НоменклатураПиломатериал = Новый Массив;
				
		Для Каждого Строка ИЗ ЭтотОбъект.Товары Цикл 
			Если Строка.Номенклатура.ЦеноваяГруппа = Справочники.ЦеновыеГруппы.НайтиПоНаименованию("Пиломатериал основной ассортимент") ИЛИ
				Строка.Номенклатура.ЦеноваяГруппа = Справочники.ЦеновыеГруппы.НайтиПоНаименованию("Пиломатериал основной ассортимент н/к") Тогда
				ОбъемДревесиныАкта  = ОбъемДревесиныАкта  + ((Строка.Номенклатура.ОбъемЧислитель / Строка.Номенклатура.ОбъемЗнаменатель) * Строка.Количество)
			КонецЕсли;
		КонецЦикла;

		Возврат ОбъемДревесиныАкта  
	
КонецФункции




#КонецЕсли

