#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ТНДляПеревозкиПиломатериала") Тогда
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"ТНДляПеревозкиПиломатериала", НСтр("ru = 'ТН для перевозки пиломатериала ЮР лицо'"), СформироватьПечатнуюФормуТН(МассивОбъектов));
	КонецЕсли;
	
КонецПроцедуры

Функция ЗапросФормированиеПечатнойФормыБланка(СсылкаНаДокумент) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаВЕГАИСЛес.Ссылка КАК Ссылка,
		|	ЗаявкаВЕГАИСЛес.Дата КАК Дата,
		|	ЗаявкаВЕГАИСЛес.НомерДокумента КАК НомерДокумента,
		|	ЗаявкаВЕГАИСЛес.ФИОФЛ КАК ФИОпокупателя,
		|	ЗаявкаВЕГАИСЛес.ПаспортСерияФЛ КАК ПаспортСерия,
		|	ЗаявкаВЕГАИСЛес.ПаспортНомерФЛ КАК ПаспортНомер,
		|	ЗаявкаВЕГАИСЛес.АдресРегистрацииФЛ КАК АдресРегистрации,
		|	ЗаявкаВЕГАИСЛес.Организация.НаименованиеСокращенное КАК НазваниеОрганизации
		|ИЗ
		|	Документ.ЗаявкаВЕГАИСЛес КАК ЗаявкаВЕГАИСЛес
		|ГДЕ
		|	ЗаявкаВЕГАИСЛес.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", СсылкаНаДокумент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Возврат Выборка;
	
КонецФункции

Функция СформироватьПечатнуюФормуБланка(СсылкаНаДокумент) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	МакетОбработки = ПолучитьМакет("БланкПоПиломатериалу");
	ОбластьШапка = МакетОбработки.ПолучитьОбласть("Шапка");
	ОбластьПодвал = МакетОбработки.ПолучитьОбласть("Подвал");
	Для каждого Ссылка из СсылкаНаДокумент Цикл			
		Выборка = ЗапросФормированиеПечатнойФормыБланка(Ссылка.Ссылка);
		
		Пока Выборка.Следующий() Цикл
			ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,Выборка);
			ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,Выборка);	
		КонецЦикла;	
		
		ТабличныйДокумент.Вывести(ОбластьШапка);
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		Если СуществуютРейсыИлиЗаказыНаДоставку(Ссылка.Основание) Тогда
		Массив = Новый Массив;
        Массив.Добавить(Ссылка);
		ТабДокТН = СформироватьПечатнуюФормуТН(Массив);
		ДобавитьТабдок(ТабличныйДокумент, ТабДокТН);
		ТабличныйДокумент.ДвусторонняяПечать = ТипДвустороннейПечати.ПереворотВлево;
		КонецЕсли;
	КонецЦикла;	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ТолькоПросмотр=Истина;
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ЗапросФормированиеПечатнойФормыТН(СсылкаНаДокумент) Экспорт	
	
	Запрос = Новый Запрос;
	//Если СуществуютРейсыИлиЗаказыНаДоставку(СсылкаНаДокумент.Основание) Тогда
	Рейс = Документы.ЗаданиеНаПеревозкуРейс.ПолучитьРейсПоДокументуПродажи(СсылкаНаДокумент.Основание);
	Если Рейс <> Неопределено Тогда 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаВЕГАИСЛес.Ссылка КАК Ссылка,
		|	ЗаявкаВЕГАИСЛес.Дата КАК Дата,
		|	ЗаявкаВЕГАИСЛес.НомерДокумента КАК Номер,
		|	ВЫБОР
		|		КОГДА ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|			ТОГДА ЗаявкаВЕГАИСЛес.Организация.НаименованиеПолное + "", "" + ОрганизацииКонтактнаяИнформация.Представление
		|		ИНАЧЕ ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель.НаименованиеПолное + "", "" + ГрузоотправителиКонтактнаяИнформация.Представление
		|	КОНЕЦ КАК Грузоотправитель,
		|	ЗаданиеНаПеревозкуРейс.Перевозчик.НаименованиеПолное + "", "" + ЕСТЬNULL(ПеревозчикКонтактнаяИнформация.Представление, """") КАК Перевозчик,
		|	ЗаявкаВЕГАИСЛес.НомерДекларацииЮЛ КАК НомерДекларации,
		|	ЗаявкаВЕГАИСЛес.ОбъемДревесины КАК ОбъемДревесины,
		|	ВЫБОР
		|		КОГДА ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|			ТОГДА ЗаявкаВЕГАИСЛес.Организация.ИНН
		|		ИНАЧЕ ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель.ИНН
		|	КОНЕЦ КАК ИННГрузоотправителя,
		|	ЗаданиеНаПеревозкуРейс.Автомобиль.Код КАК ГосНомерТС,
		|	ЗаказНаДоставкуКлиенту.АдресДоставки КАК ПунктНазначения,
		|	ЗаданиеНаПеревозкуРейс.Перевозчик.ИНН КАК ИННПеревозчика,
		|	ЗаказНаДоставкуКлиенту.Подразделение.Адрес КАК ПунктОтправления,
		|	ВЫБОР
		|		КОГДА ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|			ТОГДА ЗаявкаВЕГАИСЛес.Организация.НаименованиеПолное + "", "" + ОрганизацииКонтактнаяИнформация.Представление
		|		ИНАЧЕ ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель.НаименованиеПолное + "", "" + ГрузоотправителиКонтактнаяИнформация.Представление
		|	КОНЕЦ КАК Грузополучатель,
		|	ВЫБОР
		|		КОГДА ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|			ТОГДА ЗаявкаВЕГАИСЛес.Организация.ИНН
		|		ИНАЧЕ ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель.ИНН
		|	КОНЕЦ КАК ИННГрузополучателя
		|ИЗ
		|	Документ.ЗаявкаВЕГАИСЛес КАК ЗаявкаВЕГАИСЛес
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|		ПО ЗаявкаВЕГАИСЛес.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
		|			И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК ГрузоотправителиКонтактнаяИнформация
		|		ПО ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ГрузоотправителиКонтактнаяИнформация.Ссылка
		|			И (ГрузоотправителиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеНаПеревозкуРейс
		|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК ПеревозчикКонтактнаяИнформация
		|				ПО ЗаданиеНаПеревозкуРейс.Перевозчик = ПеревозчикКонтактнаяИнформация.Ссылка
		|					И (ПеревозчикКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента))
		|			ПО ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка = ЗаданиеНаПеревозкуРейс.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|			ПО ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку = ЗаказНаДоставкуКлиенту.Ссылка
		|		ПО (ЗаявкаВЕГАИСЛес.Основание = ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи
		|				ИЛИ ЗаявкаВЕГАИСЛес.Основание.ЗаказКлиента = ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи)
		|ГДЕ
		|	ЗаявкаВЕГАИСЛес.Ссылка = &Ссылка";
	Иначе
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаВЕГАИСЛес.Ссылка КАК Ссылка,
		|	ЗаявкаВЕГАИСЛес.Дата КАК Дата,
		|	ЗаявкаВЕГАИСЛес.НомерДокумента КАК Номер,
		|	ВЫБОР
		|		КОГДА ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|			ТОГДА ЗаявкаВЕГАИСЛес.Организация.НаименованиеПолное + "", "" + ОрганизацииКонтактнаяИнформация.Представление
		|		ИНАЧЕ ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель.НаименованиеПолное + "", "" + ГрузоотправителиКонтактнаяИнформация.Представление
		|	КОНЕЦ КАК Грузоотправитель,
		|	ЗаявкаВЕГАИСЛес.НаименованиеИЮрАдресЮЛ КАК Перевозчик,
		|	ЗаявкаВЕГАИСЛес.Контрагент.НаименованиеПолное + "", "" + КонтрагентыКонтактнаяИнформация.Представление КАК Грузополучатель,
		|	ЗаявкаВЕГАИСЛес.ГосНомерТСЮЛ КАК ГосНомерТС,
		|	ЗаявкаВЕГАИСЛес.ПунктНазначенияЮЛ КАК ПунктНазначения,
		|	ЗаявкаВЕГАИСЛес.НомерДекларацииЮЛ КАК НомерДекларации,
		|	ЗаявкаВЕГАИСЛес.ОбъемДревесины КАК ОбъемДревесины,
		|	ВЫБОР
		|		КОГДА ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
		|			ТОГДА ЗаявкаВЕГАИСЛес.Организация.ИНН
		|		ИНАЧЕ ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель.ИНН
		|	КОНЕЦ КАК ИННГрузоотправителя,
		|	ЗаявкаВЕГАИСЛес.ИННЮЛ КАК ИННПеревозчика,
		|	ЗаявкаВЕГАИСЛес.Контрагент.ИНН КАК ИННГрузополучателя,
		|	СкладыКонтактнаяИнформация.Представление КАК ПунктОтправления
		|ИЗ
		|	Документ.ЗаявкаВЕГАИСЛес КАК ЗаявкаВЕГАИСЛес
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Организации.КонтактнаяИнформация КАК ОрганизацииКонтактнаяИнформация
		|		ПО ЗаявкаВЕГАИСЛес.Организация = ОрганизацииКонтактнаяИнформация.Ссылка
		|			И (ОрганизацииКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресОрганизации))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
		|		ПО ЗаявкаВЕГАИСЛес.Контрагент = КонтрагентыКонтактнаяИнформация.Ссылка
		|			И (КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяИнформация
		|		ПО ЗаявкаВЕГАИСЛес.Склад = СкладыКонтактнаяИнформация.Ссылка
		|			И (СкладыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресСклада))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК ГрузоотправителиКонтактнаяИнформация
		|		ПО ЗаявкаВЕГАИСЛес.Склад.Грузоотправитель = ГрузоотправителиКонтактнаяИнформация.Ссылка
		|			И (ГрузоотправителиКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ЮрАдресКонтрагента))
		|ГДЕ
		|	ЗаявкаВЕГАИСЛес.Ссылка = &Ссылка";
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Ссылка", СсылкаНаДокумент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Возврат Выборка;

КонецФункции

Функция СформироватьПечатнуюФормуТН(СсылкаНаДокумент) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	МакетОбработки = ПолучитьМакет("ТНДляПеревозкиПиломатериала");		
	
	ОбластьШапка = МакетОбработки.ПолучитьОбласть("Шапка");
	ОбластьДанные = МакетОбработки.ПолучитьОбласть("Данные");
	ОбластьПодвал = МакетОбработки.ПолучитьОбласть("Подвал");
	
	Инд = 0;
	Длина1 = 0;
	Длина2 = 0;    
	
	Для каждого Ссылка из СсылкаНаДокумент Цикл			
		
		Выборка = ЗапросФормированиеПечатнойФормыТН(Ссылка.Ссылка);
		
		Пока Выборка.Следующий() Цикл
			
			Инд = 12;
			Длина1 = СтрДлина(Выборка.ИННГрузоотправителя);
			Длина2 = СтрДлина(Выборка.ИННПеревозчика);
			Длина3 = СтрДлина(Выборка.ИННГрузоотправителя);
			
			ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры,Выборка);
			
			Пока Инд > 0 Цикл
			    ИмяПараметра1 = "И1"+Инд;
				ИмяПараметра2 = "И2"+Инд;
				ИмяПараметра3 = "И3"+Инд;
				
				Если Длина1 > 0 Тогда
					 ОбластьШапка.Параметры[ИмяПараметра1] = Сред(Выборка.ИННГрузоотправителя,Длина1,1);
				 Иначе
					 ОбластьШапка.Параметры[ИмяПараметра1] = "0";
				КонецЕсли;
				
				Если Длина2 > 0 Тогда
					 ОбластьШапка.Параметры[ИмяПараметра2] = Сред(Выборка.ИННПеревозчика,Длина2,1);
					 Иначе
					 ОбластьШапка.Параметры[ИмяПараметра2] = "0";
				КонецЕсли;
				
				Если Длина3 > 0 Тогда
					 ОбластьШапка.Параметры[ИмяПараметра3] = Сред(Выборка.ИННГрузоотправителя,Длина3,1);
					 Иначе
					 ОбластьШапка.Параметры[ИмяПараметра3] = "0";
				КонецЕсли;
				
				Инд = Инд-1;
				Длина1 = Длина1 - 1;
				Длина2 = Длина2 - 1;
				Длина3 = Длина3 - 1;
			КонецЦикла;
						
			ЗаполнитьЗначенияСвойств(ОбластьДанные.Параметры,Выборка);
			ЗаполнитьЗначенияСвойств(ОбластьПодвал.Параметры,Выборка);
			
		КонецЦикла;	
		
		ТабличныйДокумент.Вывести(ОбластьШапка);
		ТабличныйДокумент.Вывести(ОбластьДанные);
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
	КонецЦикла;
		
	Возврат ТабличныйДокумент;
	
КонецФункции

Процедура ЗаполнитьДанныеПоОснованию(Основание, Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Если ЗначениеЗаполнено(Основание) Тогда
		Запрос = Новый Запрос;                
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЧекККМ") Тогда
			Запрос.Текст =
			"ВЫБРАТЬ
			|	Номенклатура.Ссылка КАК Ссылка
			|ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
