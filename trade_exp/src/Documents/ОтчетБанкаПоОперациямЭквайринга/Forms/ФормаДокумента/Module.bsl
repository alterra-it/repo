&НаКлиенте
Процедура Док_ПослеЗаписиПосле (ПараметрыЗаписи)
	МассивЧеков = НайтиЧекиБезИД();
	
	Если МассивЧеков.Количество() > 0 Тогда   
		Режим = РежимДиалогаВопрос.ДаНет;
		
		Ответ = Вопрос("Есть незаполненные ИД транзакции, заполнить?", Режим, 0);
		
		Если Ответ = КодВозвратаДиалога.Да Тогда
			Для ин = 0 По МассивЧеков.Вграница() Цикл
				СтрукЧека = МассивЧеков[ин];
				АльтерраОбщегоНазначенияКлиент.ИзвлечьIDТранзакции(СтрукЧека.Ссылка, СтрукЧека.Дата, СтрукЧека.Сумма);
			КонецЦикла;  
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры 

&НаСервере 

Функция НайтиЧекиБезИД()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ Различные
	|	ОтчетБанкаПоОперациямЭквайрингаПокупки.ЭквайринговыйТерминал КАК Терминал
	|ПОМЕСТИТЬ Терминалы
	|ИЗ
	|	Документ.ОтчетБанкаПоОперациямЭквайринга.Покупки КАК ОтчетБанкаПоОперациямЭквайрингаПокупки
	|ГДЕ
	|	ОтчетБанкаПоОперациямЭквайрингаПокупки.Ссылка = &Ссылка
	|  	И НЕ ОтчетБанкаПоОперациямЭквайрингаПокупки.ЭквайринговыйТерминал.Наименование ПОДОБНО ""%Доставк%""  
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМОплатаПлатежнымиКартами.Ссылка КАК Ссылка,
	|	ЧекККМОплатаПлатежнымиКартами.Сумма КАК Сумма,
	|	ЧекККМОплатаПлатежнымиКартами.Ссылка.Дата КАК Дата
	|ИЗ
	|	Документ.ЧекККМ.ОплатаПлатежнымиКартами КАК ЧекККМОплатаПлатежнымиКартами
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеБезналичныхОплат КАК ДанныеБезналичныхОплат
	|		ПО ЧекККМОплатаПлатежнымиКартами.Ссылка = ДанныеБезналичныхОплат.ДокументОплаты
	|ГДЕ
	|	ЧекККМОплатаПлатежнымиКартами.Ссылка.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ЧекККМОплатаПлатежнымиКартами.Ссылка.ПометкаУдаления = Ложь
	|	И ЧекККМОплатаПлатежнымиКартами.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И НЕ ЧекККМОплатаПлатежнымиКартами.Ссылка ЕСТЬ NULL
	|	И (ДанныеБезналичныхОплат.IDТранзакции ЕСТЬ NULL
	|			ИЛИ ДанныеБезналичныхОплат.IDТранзакции = ""ID not found""
	|			ИЛИ ДанныеБезналичныхОплат.IDТранзакции = ""Не найден лог"")
	|	И ЧекККМОплатаПлатежнымиКартами.ЭквайринговыйТерминал В
	|			(ВЫБРАТЬ
	|				Терминалы.Терминал КАК Терминал
	|			ИЗ
	|				Терминалы КАК Терминалы)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОперацияПоПлатежнойКарте.Ссылка КАК Ссылка,
	|	ОперацияПоПлатежнойКарте.Дата КАК Дата, 
	|	ОперацияПоПлатежнойКарте.СуммаДокумента КАК Сумма
	|ИЗ
	|	Документ.ОперацияПоПлатежнойКарте КАК ОперацияПоПлатежнойКарте
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеБезналичныхОплат КАК ДанныеБезналичныхОплат
	|		ПО (ОперацияПоПлатежнойКарте.Ссылка = ДанныеБезналичныхОплат.ДокументОплаты)
	|ГДЕ 
	|    ОперацияПоПлатежнойКарте.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И  ОперацияПоПлатежнойКарте.ПометкаУдаления = Ложь
	|	И (ДанныеБезналичныхОплат.IDТранзакции ЕСТЬ NULL
	|			ИЛИ ДанныеБезналичныхОплат.IDТранзакции = ""ID not found""
	|			ИЛИ ДанныеБезналичныхОплат.IDТранзакции = ""Не найден лог"")
	|	И ОперацияПоПлатежнойКарте.ЭквайринговыйТерминал В
	|			(ВЫБРАТЬ
	|				Терминалы.Терминал КАК Терминал
	|			ИЗ
	|				Терминалы КАК Терминалы)"; 
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("ДатаНачала",НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ДатаОкончания",КонецДня(ТекущаяДата()));
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Выборка1 = МассивРезультатов[1].Выбрать();                   
	Выборка2 = МассивРезультатов[2].Выбрать();                   

	МассивЧеков = Новый Массив();
	
	Если Выборка1.Количество() > 0 Тогда
		Пока Выборка1.Следующий() Цикл
			СтрукЧека = Новый Структура("Ссылка,Дата,Сумма");
			ЗаполнитьЗначенияСвойств(СтрукЧека,Выборка1);
			МассивЧеков.Добавить(СтрукЧека);
		КонецЦикла;
	КонецЕсли;   
	
	Если Выборка2.Количество() > 0 Тогда
		Пока Выборка2.Следующий() Цикл
			СтрукЧека = Новый Структура("Ссылка,Дата,Сумма");
			ЗаполнитьЗначенияСвойств(СтрукЧека,Выборка2);
			МассивЧеков.Добавить(СтрукЧека);
		КонецЦикла;
	КонецЕсли; 
	
	Возврат МассивЧеков;

	
	
КонецФункции


	