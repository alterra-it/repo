#Область СобытияФормы

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	Элементы.ИсключитьИзКонтроля.Доступность= РольДоступна("РазрешитьИсключатьДокументыИзКонтроляОрдерногоУчета");
	Элементы.ОтработанБезРазбора.Доступность= ЯвляетсяРуководителемОтделаКачества() ИЛИ РольДоступна("ПолныеПрава");
	
	Если Объект.Статус = Перечисления.СтатусыАктаОРасхождениях.Отработано и Объект.Проведен Тогда
		Если  АльтерраОбщегоНазначения._РольДоступна("ПравкаОтработанныхАктов") ИЛИ РольДоступна("ПолныеПрава") Тогда
			ЭЛементы.ГруппаСтраницы.ТолькоПросмотр = Истина;
			Элементы.ГруппаТоварыЗаполнить.Доступность = Ложь;
			Элементы.ТоварыРазбитьСтроку.Доступность = Ложь;
			Элементы.ТоварыУказатьСерии.Доступность = Ложь;
			Элементы.ТоварыИзменитьДействие.Доступность = Ложь;
			Элементы.ТоварыДействие.Доступность = Ложь;
			Элементы.ТоварыЕстьКомментарийМенеджера.Доступность = Ложь;
			Элементы.ТоварыЕстьКомментарийПолучателя.Доступность = Ложь;
			Элементы.ОтработанБезРазбора.Доступность= ЯвляетсяРуководителемОтделаКачества() ИЛИ РольДоступна("ПолныеПрава");
		Иначе
			ЭтаФорма.ТолькоПросмотр = Истина;
			Элементы.ТоварыДействие.Доступность = Ложь;
			Элементы.ТоварыЕстьКомментарийМенеджера.Доступность = Ложь;
			Элементы.ТоварыЕстьКомментарийПолучателя.Доступность = Ложь;
		КонецЕсли;
	КонецЕсли;
	РассчитатьУбыток();
	
КонецПроцедуры

&После("ПриЧтенииСозданииНаСервере")
&НаСервере
Процедура Док_ПриЧтенииСозданииНаСервере()
	УстановитьДоступностьПересчета();
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
	Если Не ПараметрыЗаписи.Свойство("ВопросЗадан") И СтатусОтработано() И НЕ Объект.ОтработанБезРазбора Тогда
       Отказ = Истина;
       Оповещение = Новый ОписаниеОповещения("ОтработкаБезРазбораЗавершение", ЭтаФорма, ПараметрыЗаписи);
       ТекстВопроса = "Акт отработан без разбора?";
       ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПосле(Отказ, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ПолучитьПредыдущиеРасхождения();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ОповеститьМенеджераОРасхождениях();		
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтработкаБезРазбораЗавершение(Результат, ПараметрыЗаписи) экспорт 
	ПараметрыЗаписи.Вставить("ВопросЗадан", Истина);
	Объект.ОтработанБезРазбора = Результат = КодВозвратаДиалога.Да;
	Записать(ПараметрыЗаписи);
	Если ПараметрыЗаписи.Свойство("Закрыть") Тогда
		Закрыть();
	КонецЕсли;
КонецПроцедуры 

#КонецОбласти

#Область СозданиеБлокировки

&НаКлиенте
Процедура Док__СоздатьБлокировкуПосле(Команда)
	Док__СоздатьБлокировкуПослеНаСервере();
КонецПроцедуры

&НаСервере
Процедура Док__СоздатьБлокировкуПослеНаСервере()
	
	СоздатьДокумент = Ложь;

	Док = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
	Док.Дата = ТекущаяДата();
	Док.Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Разблокировано;
	Док.Склад = Объект.СкладОтправитель;
	Док.Ответственный = Пользователи.ТекущийПользователь();
   	Док.Комментарий = "Автоматически создан документ разблокировки на основании акта о расхождениях после перемещения №: "+Объект.Номер;
	
	Для Каждого Товар Из Объект.Товары Цикл
		Если Товар.КоличествоУпаковокРасхождения <> 0 И
			Товар.Действие = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ОформитьРазблокировав Тогда
		НоваяСтрока = Док.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Товар);
		НоваяСтрока.Количество = ?(Товар.КоличествоУпаковокРасхождения < 0, (-1) * Товар.КоличествоУпаковокРасхождения, Товар.КоличествоУпаковокРасхождения);
		СоздатьДокумент = Истина;
		КонецЕсли;
	КонецЦикла;
	
	
	Если СоздатьДокумент Тогда
		Док.Записать(РежимЗаписиДокумента.Запись);
		
		АльтерраОбщегоНазначения.СообщитьПользователю(Док.Ссылка, "Создана разблокировка товара: " + Док.Ссылка);
	Иначе
		АльтерраОбщегоНазначения.СообщитьПользователю(, "Создание документа невозможно - не найдены строки, в которых есть указанный вид действия и есть расхождения!");
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ПересчетТранспортныхРасходов

&НаКлиенте
Процедура Док_ПересчитатьТранспортныеРасходыВместо(Команда)
	
	Если Объект.Ссылка.Пустая() Тогда 
		Сообщить("Необходимо записать документ");
	ИначеЕсли Не Объект.Проведен Тогда
		Сообщить("Необходимо провести документ");
	Иначе
		ПересчитатьТранспортныеРасходы();	
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьТранспортныеРасходы()
	
	Запрос = Новый Запрос (
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АктОРасхожденияхТовары.ДокументОснование Как ПеремещениеСсылка
	|ПОМЕСТИТЬ
	|	втПеремещения
	|ИЗ 
	|	Документ.АктОРасхожденияхПослеПеремещения.Товары КАК АктОРасхожденияхТовары
	|СОЕДИНЕНИЕ	
	|	Документ.АктОРасхожденияхПослеПеремещения КАК АктОРасхождениях
	|ПО
	|	АктОРасхожденияхТовары.Ссылка = АктОРасхождениях.Ссылка
	|	И АктОРасхождениях.Проведен
	|	И Не АктОРасхождениях.ПометкаУдаления
	|ГДЕ
	|	АктОРасхождениях.Ссылка = &АктСсылка
	|	И НЕ (АктОРасхожденияхТовары.ДокументОснование = ЗНАЧЕНИЕ(Документ.ПеремещениеТоваров.ПустаяСсылка)) 
	|;	
	|	
	|///////////////////////////////////////////////////////////////////////////////	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказНаДоставку.Ссылка Как ЗаказНаДоставкуСсылка
	|ПОМЕСТИТЬ
	|	втЗаказыНаДоставку
	|ИЗ 
	|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуОснования
	|СОЕДИНЕНИЕ	
	|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставку
	|	ПО
	|		ЗаказНаДоставкуОснования.Ссылка = ЗаказНаДоставку.Ссылка
	|		И ЗаказНаДоставкуОснования.Документ ССЫЛКА Документ.ПеремещениеТоваров
	|		И ЗаказНаДоставку.Проведен
	|		И Не ЗаказНаДоставку.ПометкаУдаления
	|СОЕДИНЕНИЕ
	|	втПеремещения 
	|	ПО 
	|		ЗаказНаДоставкуОснования.Документ ССЫЛКА Документ.ПеремещениеТоваров
	|		И ЗаказНаДоставкуОснования.Документ = втПеремещения.ПеремещениеСсылка
	|;	
	|
	|///////////////////////////////////////////////////////////////////////////////	
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНаПеревозку.Ссылка Как ЗаданиеНаПеревозкуСсылка
	|ИЗ 
	|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуОснования
	|СОЕДИНЕНИЕ	
	|	Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеНаПеревозку
	|	ПО
	|		ЗаданиеНаПеревозкуОснования.Ссылка = ЗаданиеНаПеревозку.Ссылка
	|		И ЗаданиеНаПеревозку.Проведен
	|		И Не ЗаданиеНаПеревозку.ПометкаУдаления
	|СОЕДИНЕНИЕ
	|	втЗаказыНаДоставку 
	|	ПО 
	|		ЗаданиеНаПеревозкуОснования.Документ = втЗаказыНаДоставку.ЗаказНаДоставкуСсылка");

	Запрос.УстановитьПараметр("АктСсылка", Объект.Ссылка);
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Сообщить("Не найдены документы ""Задание на перевозку (Рейс)"" для пересчета транспортных расходов");	
	Иначе
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			ЗаданиеНаПеревозкуОбъект = Выборка.ЗаданиеНаПеревозкуСсылка.ПолучитьОбъект();
			Документы.ЗаданиеНаПеревозкуРейс.СформироватьЗатраты(ЗаданиеНаПеревозкуОбъект, Ложь);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Док_ГруппаСтраницыПриСменеСтраницыПосле(Элемент, ТекущаяСтраница)
	УстановитьДоступностьПересчета();
КонецПроцедуры

