#КонецОбласти

#Область ОповещениеМенеджераОРасхождениях

&НаСервере
Процедура ПолучитьПредыдущиеРасхождения()
	
	ПредыдущиеРасхождения.Очистить();
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПредыдущиеРасхожденияТЗ = РеквизитФормыВЗначение("ПредыдущиеРасхождения");
		ПредыдущиеРасхожденияТЗ = ПолучитьРасхожденияПоТоварам(Объект.Ссылка).Выгрузить(); 
		ЗначениеВРеквизитФормы(ПредыдущиеРасхожденияТЗ, "ПредыдущиеРасхождения")
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОповеститьМенеджераОРасхождениях()
	
	ПредыдущиеРасхожденияТЗ = РеквизитФормыВЗначение("ПредыдущиеРасхождения");
	РезультатРасхождений = ПолучитьОснованияРасхождений(Объект.Ссылка, ПредыдущиеРасхожденияТЗ);
	
	Если Не РезультатРасхождений.Пустой() Тогда
		
		ВыборкаДокумент = РезультатРасхождений.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДокумент.Следующий() Цикл
			
			ВыборкаОтветственный = ВыборкаДокумент.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаОтветственный.Следующий() Цикл
				
				Если ЗначениеЗаполнено(ВыборкаОтветственный.Ответственный) Тогда
				
					Адресат = ВыборкаОтветственный.Ответственный;
					
					ВыборкаНоменклатура = ВыборкаОтветственный.Выбрать();
					СписокТоваров = "";
					Пока ВыборкаНоменклатура.Следующий() Цикл
						Если СписокТоваров <> "" Тогда
							СписокТоваров = СписокТоваров + Символы.ПС;
						КонецЕсли;
						СписокТоваров = СписокТоваров + Символы.Таб + Символы.Таб + ВыборкаНоменклатура.Номенклатура;
					КонецЦикла;
					
					ТекстСообщения = "По документу " + ВыборкаДокумент.ИсходныйДокумент + Символы.ПС 
						+ "поступило не все количество по следующим позициям:" + Символы.ПС
						+ СписокТоваров + "." + Символы.ПС
						+ "Расхождения можно посмотреть:" + Символы.ПС
						+ Объект.Ссылка;
						
					Попытка
						АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения, Адресат);
						ЗаписьЖурналаРегистрации("Оповещение менеджера о расхождениях после перемещения", УровеньЖурналаРегистрации.Информация,,,  Адресат);
					Исключение
						ТекстОшибки = "Оповещение менеджера " + ВыборкаОтветственный.Ответственный + " о расхождениях после перемещения";
						ЗаписьЖурналаРегистрации(ТекстОшибки, УровеньЖурналаРегистрации.Ошибка,,,  ОписаниеОшибки());
						ТекстОшибки = "Не удалось оповестить " + ВыборкаОтветственный.Ответственный + " о расхождениях: ";
						Сообщить(ТекстОшибки);
					КонецПопытки;	
				Иначе
					ТекстОшибки = "У документа " + ВыборкаДокумент.ИсходныйДокумент + " не указан ответственный." 
					+ " Оповещение о расхождениях не отправлено";
					Сообщить(ТекстОшибки);						
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьРасхожденияПоТоварам(АктСсылка) 
	
	Запрос = Новый Запрос (
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АктТовары.Номенклатура КАК Номенклатура,		
	|	АктТовары.ДокументОснование Как ПеремещениеСсылка
	|ИЗ 
	|	Документ.АктОРасхожденияхПослеПеремещения.Товары КАК АктТовары
	|СОЕДИНЕНИЕ	
	|	Документ.АктОРасхожденияхПослеПеремещения КАК Акт
	|ПО
	|	АктТовары.Ссылка = Акт.Ссылка
	|	И Акт.Проведен
	|	И Не Акт.ПометкаУдаления
	|ГДЕ
	|	Акт.Ссылка = &АктСсылка
	|	И АктТовары.КоличествоУпаковок - АктТовары.КоличествоУпаковокПоДокументу < 0");
	
	Запрос.УстановитьПараметр("АктСсылка", АктСсылка);
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция ПолучитьОснованияРасхождений(АктСсылка, ПредыдущиеРасхождения) 
	
	Запрос = Новый Запрос (
    "ВЫБРАТЬ 
	|	ПредыдущиеРасхождения.Номенклатура,
	|	ПредыдущиеРасхождения.ПеремещениеСсылка
	|ПОМЕСТИТЬ
	|	втПредыдущиеРасхождения
	|ИЗ 
	|	&ПредыдущиеРасхождения КАК ПредыдущиеРасхождения
	|;
	|/////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АктТовары.Номенклатура КАК Номенклатура,		
	|	АктТовары.ДокументОснование Как ПеремещениеСсылка
	|ПОМЕСТИТЬ втРасхожденияНоменклатуры
	|ИЗ 
	|	Документ.АктОРасхожденияхПослеПеремещения.Товары КАК АктТовары
	|СОЕДИНЕНИЕ	
	|	Документ.АктОРасхожденияхПослеПеремещения КАК Акт
	|ПО
	|	АктТовары.Ссылка = Акт.Ссылка
	|	И Акт.Проведен
	|	И Не Акт.ПометкаУдаления
	|ЛЕВОЕ СОЕДИНЕНИЕ	
	|	втПредыдущиеРасхождения 
	|ПО 
	|	АктТовары.Номенклатура = втПредыдущиеРасхождения.Номенклатура
	|	И АктТовары.ДокументОснование = втПредыдущиеРасхождения.ПеремещениеСсылка
	|ГДЕ
	|	Акт.Ссылка = &АктСсылка
	|	И АктТовары.КоличествоУпаковок - АктТовары.КоличествоУпаковокПоДокументу < 0
	|	И втПредыдущиеРасхождения.Номенклатура ЕСТЬ NULL
	|;
	|/////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Перемещение.Ссылка КАК ПеремещениеСсылка,
	|	Перемещение.Ответственный КАК ПеремещениеОтветственный,
	|	ПеремещениеТовары.Номенклатура,
	|	ПеремещениеТовары.ЗаказНаПеремещение КАК ЗаказСсылка			
	|ПОМЕСТИТЬ втПеремещениеНоменклатуры
	|ИЗ
	|	втРасхожденияНоменклатуры
	|СОЕДИНЕНИЕ
	|	Документ.ПеремещениеТоваров КАК Перемещение 
	|ПО
	|	втРасхожденияНоменклатуры.ПеремещениеСсылка = Перемещение.Ссылка
	|	И Перемещение.Проведен
	|	И НЕ Перемещение.ПометкаУдаления
	|СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТовары
	|ПО 
	|	Перемещение.Ссылка = ПеремещениеТовары.Ссылка
	|	И втРасхожденияНоменклатуры.Номенклатура = ПеремещениеТовары.Номенклатура
	|;
	|/////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ 
	|	ЕСТЬNULL(Заказ.Ссылка, втПеремещениеНоменклатуры.ПеремещениеСсылка) КАК ИсходныйДокумент,
	|	ЕСТЬNULL(Заказ.Ответственный, втПеремещениеНоменклатуры.ПеремещениеОтветственный) КАК Ответственный,
	|	втПеремещениеНоменклатуры.Номенклатура
	|ИЗ 
	|	втПеремещениеНоменклатуры	
	|ЛЕВОЕ СОЕДИНЕНИЕ
	|	Документ.ЗаказНаПеремещение КАК Заказ 
	|ПО
	|	втПеремещениеНоменклатуры.ЗаказСсылка = Заказ.Ссылка
	|	И Заказ.Проведен
	|	И НЕ Заказ.ПометкаУдаления
	|УПОРЯДОЧИТЬ ПО
	|	1, Номенклатура.Наименование
	|ИТОГИ ПО
	|	ЕСТЬNULL(Заказ.Ссылка, втПеремещениеНоменклатуры.ПеремещениеСсылка),
	|	ЕСТЬNULL(Заказ.Ответственный, втПеремещениеНоменклатуры.ПеремещениеОтветственный)");

	Запрос.УстановитьПараметр("АктСсылка", АктСсылка);
	Запрос.УстановитьПараметр("ПредыдущиеРасхождения", ПредыдущиеРасхождения);
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
	
КонецФункции		

&НаКлиенте
&ИзменениеИКонтроль("ПерезаполнитьПоПоступлениюОтветПользователя")
Процедура Док_ПерезаполнитьПоПоступлениюОтветПользователя(РезультатВопроса, ДополнительныеПараметры)

	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	Иначе
		Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Запись));
	КонецЕсли;
    #Удаление
	Если Объект.Проведен Тогда 
	#КонецУдаления
	#Вставка
	Если НЕ Объект.Ссылка.Пустая() Тогда
	#КонецВставки
		ЗаполнитьПоПриемкеСервер();

		ПоказатьОповещениеПользователя(
		НСтр("ru = 'Количество перезаполнено'"),
		,
		НСтр("ru='В строках перезаполнено количество.'"),
		БиблиотекаКартинок.Информация32);
		
		#Вставка
		ЗаполнитьСуммуРасхождений();
		#КонецВставки
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСуммуРасхождений()

	ТЧАкта = Новый ТаблицаЗначений;
	ТЧАкта.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число"));
	ТЧАкта.Колонки.Добавить("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЧАкта.Колонки.Добавить("Характеристика", Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	ТЧАкта.Колонки.Добавить("Назначение", Новый ОписаниеТипов("СправочникСсылка.Назначения"));
	ТЧАкта.Колонки.Добавить("СкладОтправитель", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТЧАкта.Колонки.Добавить("КоличествоПоДокументу", Новый ОписаниеТипов("Число"));
	ТЧАкта.Колонки.Добавить("Количество", Новый ОписаниеТипов("Число"));
	ТЧАкта.Колонки.Добавить("Перемещение", Новый ОписаниеТипов("ДокументСсылка.ПеремещениеТоваров"));
	
	Для каждого Строка Из Объект.Товары Цикл
	
		стр = ТЧАкта.Добавить();            
		стр.Номенклатура = Строка.Номенклатура;
		стр.Характеристика = Строка.Характеристика;
		стр.Назначение = Строка.Назначение;
		стр.СкладОтправитель = Объект.СкладОтправитель;
		стр.КоличествоПоДокументу = Строка.КоличествоУпаковокПоДокументу;
		стр.Количество = Строка.КоличествоУпаковок;
		стр.НомерСтроки = Строка.НомерСтроки;
		стр.Перемещение = ДокументыОснования[0].ДокументОснование; 
	
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		    "ВЫБРАТЬ
			|	АктОРасхожденияхПослеПеремещенияТовары.НомерСтроки КАК НомерСтроки,
			|	АктОРасхожденияхПослеПеремещенияТовары.Номенклатура КАК Номенклатура,
			|	АктОРасхожденияхПослеПеремещенияТовары.Характеристика КАК Характеристика,
			|	АктОРасхожденияхПослеПеремещенияТовары.Назначение КАК Назначение,
			|	АктОРасхожденияхПослеПеремещенияТовары.СкладОтправитель КАК СкладОтправитель,
			|	АктОРасхожденияхПослеПеремещенияТовары.КоличествоПоДокументу КАК ПоДокументу,
			|	АктОРасхожденияхПослеПеремещенияТовары.Количество КАК Факт,
			|	АктОРасхожденияхПослеПеремещенияТовары.Количество - АктОРасхожденияхПослеПеремещенияТовары.КоличествоПоДокументу КАК Расхождения,
			|	АктОРасхожденияхПослеПеремещенияТовары.Перемещение КАК Перемещение
			|ПОМЕСТИТЬ ВТРасхождения
			|ИЗ
			|	&ТЧАкта КАК АктОРасхожденияхПослеПеремещенияТовары
			|ГДЕ
			|	АктОРасхожденияхПослеПеремещенияТовары.Количество - АктОРасхожденияхПослеПеремещенияТовары.КоличествоПоДокументу <> 0
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СебестоимостьТоваров.Регистратор КАК Регистратор,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Характеристика КАК Характеристика,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Назначение КАК Назначение,
			|	СУММА(СебестоимостьТоваров.Количество) КАК Количество,
			|	СУММА(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) КАК Сумма
			|ПОМЕСТИТЬ ВТСебестоимостьСПеремещением
			|ИЗ
			|	ВТРасхождения КАК ВТРасхождения
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
			|		ПО ВТРасхождения.Перемещение = СебестоимостьТоваров.Регистратор
			|			И ВТРасхождения.Номенклатура = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура
			|			И ВТРасхождения.СкладОтправитель = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.МестоХранения
			|			И ВТРасхождения.Назначение = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Назначение
			|ГДЕ
			|	НЕ СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура ЕСТЬ NULL
			|	И НЕ ВТРасхождения.Номенклатура.Наименование ПОДОБНО ""%н/к%""
			|
			|СГРУППИРОВАТЬ ПО
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Характеристика,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.МестоХранения,
			|	СебестоимостьТоваров.Регистратор,
			|	СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Назначение
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТРасхождения.Номенклатура КАК Номенклатура,
			|	ВТРасхождения.Характеристика КАК Характеристика,
			|	СебестоимостьТоваровОстатки.АналитикаУчетаНоменклатуры.МестоХранения КАК МестоХранения,
			|	СебестоимостьТоваровОстатки.КоличествоОстаток КАК Количество,
			|	СебестоимостьТоваровОстатки.СтоимостьОстаток + СебестоимостьТоваровОстатки.ДопРасходыОстаток КАК Сумма,
			|	ВЫБОР
			|		КОГДА СебестоимостьТоваровОстатки.КоличествоОстаток <> 0
			|				И НЕ СебестоимостьТоваровОстатки.КоличествоОстаток ЕСТЬ NULL
			|			ТОГДА (СебестоимостьТоваровОстатки.СтоимостьОстаток + СебестоимостьТоваровОстатки.ДопРасходыОстаток) / СебестоимостьТоваровОстатки.КоличествоОстаток
			|		ИНАЧЕ СебестоимостьТоваровОстатки.КоличествоОстаток
			|	КОНЕЦ КАК Стоимость
			|ПОМЕСТИТЬ ВТСебестоимостьБезПеремещения
			|ИЗ
			|	ВТРасхождения КАК ВТРасхождения
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСебестоимостьСПеремещением КАК ВТСебестоимостьСПеремещением
			|		ПО ВТРасхождения.Перемещение = ВТСебестоимостьСПеремещением.Регистратор
			|			И ВТРасхождения.Номенклатура = ВТСебестоимостьСПеремещением.Номенклатура
			|			И ВТРасхождения.СкладОтправитель = ВТСебестоимостьСПеремещением.МестоХранения
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров.Остатки(&ДатаДокумента, ) КАК СебестоимостьТоваровОстатки
			|		ПО (СебестоимостьТоваровОстатки.АналитикаУчетаНоменклатуры.Номенклатура = ВТРасхождения.Номенклатура)
			|			И (СебестоимостьТоваровОстатки.АналитикаУчетаНоменклатуры.Характеристика = ВТРасхождения.Характеристика)
			|			И (СебестоимостьТоваровОстатки.АналитикаУчетаНоменклатуры.МестоХранения = ВТРасхождения.СкладОтправитель)
			|ГДЕ
			|	ВТСебестоимостьСПеремещением.Номенклатура ЕСТЬ NULL
			|	И НЕ ВТРасхождения.Номенклатура.Наименование ПОДОБНО ""%н/к%"" 
			|	и СебестоимостьТоваровОстатки.КоличествоОстаток<>0;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ЦеныНоменклатурыПоставщиков.Номенклатура КАК Номенклатура,
			|	МАКСИМУМ(ЦеныНоменклатурыПоставщиков.Период) КАК Период
			|ПОМЕСТИТЬ ВТПериодЦенНоменклатуры
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатурыПоставщиков КАК ЦеныНоменклатурыПоставщиков
			|ГДЕ
			|	ЦеныНоменклатурыПоставщиков.Период < &ДатаДокумента
			|	И ЦеныНоменклатурыПоставщиков.Номенклатура В
			|			(ВЫБРАТЬ
			|				ВТРасхождения.Номенклатура
			|			ИЗ
			|				ВТРасхождения КАК ВТРасхождения)
			|	И НЕ ЦеныНоменклатурыПоставщиков.Номенклатура В
			|				(ВЫБРАТЬ
			|					ВТСебестоимостьБезПеремещения.Номенклатура КАК Номенклатура
			|				ИЗ
			|					ВТСебестоимостьБезПеремещения КАК ВТСебестоимостьБезПеремещения
			|				ГДЕ
			|					НЕ ВТСебестоимостьБезПеремещения.Сумма ЕСТЬ NULL
			|		
			|				ОБЪЕДИНИТЬ ВСЕ
			|		
			|				ВЫБРАТЬ
			|					ВТСебестоимостьСПеремещением.Номенклатура
			|				ИЗ
			|					ВТСебестоимостьСПеремещением КАК ВТСебестоимостьСПеремещением
			|				ГДЕ
			|					НЕ ВТСебестоимостьСПеремещением.Сумма ЕСТЬ NULL)
			|	И НЕ ЦеныНоменклатурыПоставщиков.Номенклатура.Наименование ПОДОБНО ""%н/к%""
			|
			|СГРУППИРОВАТЬ ПО
			|	ЦеныНоменклатурыПоставщиков.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ЦеныНоменклатурыПоставщиков.Номенклатура КАК Номенклатура,
			|	МАКСИМУМ(ЦеныНоменклатурыПоставщиков.Цена) КАК Цена
			|ПОМЕСТИТЬ ВТЦеныПоставщиков
			|ИЗ
			|	РегистрСведений.ЦеныНоменклатурыПоставщиков КАК ЦеныНоменклатурыПоставщиков
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодЦенНоменклатуры КАК ВТПериодЦенНоменклатуры
			|		ПО (ВТПериодЦенНоменклатуры.Период = ЦеныНоменклатурыПоставщиков.Период)
			|			И (ВТПериодЦенНоменклатуры.Номенклатура = ЦеныНоменклатурыПоставщиков.Номенклатура)
			|ГДЕ
			|	НЕ ЦеныНоменклатурыПоставщиков.Номенклатура В
			|				(ВЫБРАТЬ
			|					ВТСебестоимостьБезПеремещения.Номенклатура КАК Номенклатура
			|				ИЗ
			|					ВТСебестоимостьБезПеремещения КАК ВТСебестоимостьБезПеремещения
			|				ГДЕ
			|					НЕ ВТСебестоимостьБезПеремещения.Сумма ЕСТЬ NULL
			|		
			|				ОБЪЕДИНИТЬ ВСЕ
			|		
			|				ВЫБРАТЬ
			|					ВТСебестоимостьСПеремещением.Номенклатура
			|				ИЗ
			|					ВТСебестоимостьСПеремещением КАК ВТСебестоимостьСПеремещением
			|				ГДЕ
			|					НЕ ВТСебестоимостьСПеремещением.Сумма ЕСТЬ NULL)
			|	И НЕ ЦеныНоменклатурыПоставщиков.Номенклатура.Наименование ПОДОБНО ""%н/к%""
			|
			|СГРУППИРОВАТЬ ПО
			|	ЦеныНоменклатурыПоставщиков.Номенклатура
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТРасхождения.Номенклатура КАК Номенклатура,
			|	ВТЦеныПоставщиков.Цена КАК Цена,
			|	ВТРасхождения.Расхождения КАК Количество,
			|	ВЫБОР
			|		КОГДА ВТРасхождения.Расхождения > 0
			|			ТОГДА ВТРасхождения.Расхождения * ВТЦеныПоставщиков.Цена
			|		ИНАЧЕ ВТЦеныПоставщиков.Цена * -1 * ВТРасхождения.Расхождения
			|	КОНЕЦ КАК Сумма
			|ПОМЕСТИТЬ ВТОстатки
			|ИЗ
			|	ВТРасхождения КАК ВТРасхождения
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦеныПоставщиков КАК ВТЦеныПоставщиков
			|		ПО ВТРасхождения.Номенклатура = ВТЦеныПоставщиков.Номенклатура
			|ГДЕ
			|	НЕ ВТРасхождения.Номенклатура В
			|				(ВЫБРАТЬ
			|					ВТСебестоимостьБезПеремещения.Номенклатура КАК Номенклатура
			|				ИЗ
			|					ВТСебестоимостьБезПеремещения КАК ВТСебестоимостьБезПеремещения
			|				ГДЕ
			|					НЕ ВТСебестоимостьБезПеремещения.Сумма ЕСТЬ NULL
			|		
			|				ОБЪЕДИНИТЬ ВСЕ
			|		
			|				ВЫБРАТЬ
			|					ВТСебестоимостьСПеремещением.Номенклатура
			|				ИЗ
			|					ВТСебестоимостьСПеремещением КАК ВТСебестоимостьСПеремещением
			|				ГДЕ
			|					НЕ ВТСебестоимостьСПеремещением.Сумма ЕСТЬ NULL)
			|	И НЕ ВТРасхождения.Номенклатура.Наименование ПОДОБНО ""%н/к%""
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ТоварыДругогоКачества.Номенклатура КАК КачественнаяНоменклатура,
			|	ВТРасхождения.Номенклатура КАК Номенклатура,
			|	ВТРасхождения.Расхождения КАК Количество,
			|	ВЫБОР
			|		КОГДА НЕ ВТСебестоимостьБезПеремещения.Сумма ЕСТЬ NULL
			|			ТОГДА ВТСебестоимостьБезПеремещения.Сумма / ВТСебестоимостьБезПеремещения.Количество * ВТРасхождения.Расхождения * 0.702
			|		ИНАЧЕ ВЫБОР
			|				КОГДА НЕ ВТСебестоимостьСПеремещением.Сумма ЕСТЬ NULL
			|					ТОГДА ВТСебестоимостьСПеремещением.Сумма / ВТСебестоимостьСПеремещением.Количество * ВТРасхождения.Расхождения * 0.702
			|				ИНАЧЕ ВТОстатки.Сумма / ВТОстатки.Количество * ВТРасхождения.Расхождения * 0.6
			|			КОНЕЦ
			|	КОНЕЦ КАК Сумма
			|ПОМЕСТИТЬ ВТНКНоменклатура
			|ИЗ
			|	ВТРасхождения КАК ВТРасхождения
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТоварыДругогоКачества КАК ТоварыДругогоКачества
			|			ЛЕВОЕ СОЕДИНЕНИЕ ВТСебестоимостьСПеремещением КАК ВТСебестоимостьСПеремещением
			|			ПО (ВТСебестоимостьСПеремещением.Номенклатура = ТоварыДругогоКачества.Номенклатура)
			|			ЛЕВОЕ СОЕДИНЕНИЕ ВТСебестоимостьБезПеремещения КАК ВТСебестоимостьБезПеремещения
			|			ПО (ВТСебестоимостьБезПеремещения.Номенклатура = ТоварыДругогоКачества.Номенклатура)
			|			ЛЕВОЕ СОЕДИНЕНИЕ ВТОстатки КАК ВТОстатки
			|			ПО (ВТОстатки.Номенклатура = ТоварыДругогоКачества.Номенклатура)
			|		ПО ВТРасхождения.Номенклатура = ТоварыДругогоКачества.НоменклатураБрак
			|ГДЕ
			|	НЕ ТоварыДругогоКачества.Номенклатура ЕСТЬ NULL
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТРасхождения.НомерСтроки КАК НомерСтроки,
			|	ВТРасхождения.Номенклатура КАК Номенклатура,
			|	ВТРасхождения.Характеристика КАК Характеристика,
			|	ВТРасхождения.Назначение КАК Назначение,
			|	ВТСебестоимостьСПеремещением.Сумма КАК Сумма,
			|	ВТСебестоимостьСПеремещением.Количество КАК Количество,
			|	ВТРасхождения.Расхождения КАК Расхождения,
			|	ВЫБОР
			|		КОГДА ВТСебестоимостьСПеремещением.Количество <> 0
			|			ТОГДА ВЫБОР
			|					КОГДА ВТРасхождения.Расхождения > 0
			|						ТОГДА ВТСебестоимостьСПеремещением.Сумма * ВТРасхождения.Расхождения / ВТСебестоимостьСПеремещением.Количество
			|					ИНАЧЕ -1 * ВТСебестоимостьСПеремещением.Сумма * ВТРасхождения.Расхождения / ВТСебестоимостьСПеремещением.Количество
			|				КОНЕЦ
			|		ИНАЧЕ 0
			|	КОНЕЦ КАК Себестоимость
			|ИЗ
			|	ВТРасхождения КАК ВТРасхождения
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСебестоимостьСПеремещением КАК ВТСебестоимостьСПеремещением
			|		ПО ВТРасхождения.Перемещение = ВТСебестоимостьСПеремещением.Регистратор
			|			И ВТРасхождения.Номенклатура = ВТСебестоимостьСПеремещением.Номенклатура
			|			И ВТРасхождения.СкладОтправитель = ВТСебестоимостьСПеремещением.МестоХранения
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТРасхождения.НомерСтроки,
			|	ВТРасхождения.Номенклатура,
			|	ВТРасхождения.Характеристика,
			|	ВТРасхождения.Назначение,
			|	ВТСебестоимостьСПеремещением.Сумма,
			|	ВТСебестоимостьСПеремещением.Количество,
			|	ВТРасхождения.Расхождения
			|
			|ИМЕЮЩИЕ
			|	НЕ ВЫБОР
			|			КОГДА ВТСебестоимостьСПеремещением.Количество <> 0
			|				ТОГДА ВЫБОР
			|						КОГДА ВТРасхождения.Расхождения > 0
			|							ТОГДА ВТСебестоимостьСПеремещением.Сумма * ВТРасхождения.Расхождения / ВТСебестоимостьСПеремещением.Количество
			|						ИНАЧЕ ВТСебестоимостьСПеремещением.Сумма * -1 * ВТРасхождения.Расхождения / ВТСебестоимостьСПеремещением.Количество
			|					КОНЕЦ
			|			ИНАЧЕ 0
			|		КОНЕЦ ЕСТЬ NULL
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВТРасхождения.НомерСтроки,
			|	ВТРасхождения.Номенклатура,
			|	ВТРасхождения.Характеристика,
			|	ВТРасхождения.Назначение,
			|	ВТСебестоимостьБезПеремещения.Сумма,
			|	ВТСебестоимостьБезПеремещения.Количество,
			|	ВТРасхождения.Расхождения,
			|	ВЫБОР
			|		КОГДА ВТРасхождения.Расхождения > 0
			|			ТОГДА ВТСебестоимостьБезПеремещения.Стоимость * ВТРасхождения.Расхождения
			|		ИНАЧЕ ВТСебестоимостьБезПеремещения.Стоимость * -1 * ВТРасхождения.Расхождения
			|	КОНЕЦ
			|ИЗ
			|	ВТРасхождения КАК ВТРасхождения
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСебестоимостьБезПеремещения КАК ВТСебестоимостьБезПеремещения
			|		ПО ВТРасхождения.Номенклатура = ВТСебестоимостьБезПеремещения.Номенклатура
			|			И ВТРасхождения.СкладОтправитель = ВТСебестоимостьБезПеремещения.МестоХранения
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТРасхождения.НомерСтроки,
			|	ВТРасхождения.Номенклатура,
			|	ВТРасхождения.Характеристика,
			|	ВТРасхождения.Назначение,
			|	ВТСебестоимостьБезПеремещения.Сумма,
			|	ВТСебестоимостьБезПеремещения.Количество,
			|	ВТРасхождения.Расхождения,
			|	ВТСебестоимостьБезПеремещения.Стоимость
			|
			|ИМЕЮЩИЕ
			|	НЕ ВЫБОР
			|			КОГДА ВТРасхождения.Расхождения > 0
			|				ТОГДА ВТСебестоимостьБезПеремещения.Стоимость * ВТРасхождения.Расхождения
			|			ИНАЧЕ ВТСебестоимостьБезПеремещения.Стоимость * -1 * ВТРасхождения.Расхождения
			|		КОНЕЦ ЕСТЬ NULL
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВТРасхождения.НомерСтроки,
			|	ВТРасхождения.Номенклатура,
			|	ВТРасхождения.Характеристика,
			|	ВТРасхождения.Назначение,
			|	ВТНКНоменклатура.Сумма,
			|	ВТНКНоменклатура.Количество,
			|	ВТРасхождения.Расхождения,
			|	ВТНКНоменклатура.Сумма
			|ИЗ
			|	ВТНКНоменклатура КАК ВТНКНоменклатура
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРасхождения КАК ВТРасхождения
			|		ПО ВТНКНоменклатура.Номенклатура = ВТРасхождения.Номенклатура
			|ГДЕ
			|	НЕ ВТНКНоменклатура.Сумма ЕСТЬ NULL
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВТРасхождения.НомерСтроки,
			|	ВТРасхождения.Номенклатура,
			|	ВТРасхождения.Характеристика,
			|	ВТРасхождения.Назначение,
			|	ВТОстатки.Сумма,
			|	ВТОстатки.Количество,
			|	ВТРасхождения.Расхождения,
			|	ВТОстатки.Сумма
			|ИЗ
			|	ВТОстатки КАК ВТОстатки
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРасхождения КАК ВТРасхождения
			|		ПО ВТОстатки.Номенклатура = ВТРасхождения.Номенклатура
			|ГДЕ
			|	НЕ ВТОстатки.Сумма ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("ДатаДокумента", Объект.Дата);
	Запрос.УстановитьПараметр("ТЧАкта", ТЧАкта);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ПараметрыОтбора = Новый Структура();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
			
		СтрокаТЧ = Объект.Товары.НайтиСтроки(Новый Структура("НомерСтроки", ВыборкаДетальныеЗаписи.НомерСтроки)); 
		Если СтрокаТЧ <> Неопределено Тогда 
			СтрокаТЧ[0].СуммаРасхождений = ВыборкаДетальныеЗаписи.Себестоимость;
		КонецЕсли;  
			
	КонецЦикла;
	
	РассчитатьУбыток();

КонецПроцедуры


&НаСервере
Процедура РассчитатьУбыток()

	ИтоговаяСумма = 0;
	СуммаПоВсемРасхождениям = 0;
	Для каждого Строка Из Объект.Товары Цикл
	
		Если Строка.КоличествоУпаковокРасхождения > 0 Тогда
			ИтоговаяСумма = ИтоговаяСумма-Строка.СуммаРасхождений;
			СуммаПоВсемРасхождениям = СуммаПоВсемРасхождениям+Строка.СуммаРасхождений;
		Иначе
			ИтоговаяСумма = ИтоговаяСумма+Строка.СуммаРасхождений;
			СуммаПоВсемРасхождениям = СуммаПоВсемРасхождениям+Строка.СуммаРасхождений;
		КонецЕсли;

	КонецЦикла;
	Убыток = ИтоговаяСумма;
	СуммаПоРасхождениям = СуммаПоВсемРасхождениям;

КонецПроцедуры 

&НаКлиенте
Процедура Док_ПерезаполнитьПоПоступлениюПосле(Команда)
	ЗаполнитьСуммуРасхождений();
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ЯвляетсяРуководителемОтделаКачества()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ                                   
		|	ВЫБОР
		|		КОГДА КОЛИЧЕСТВО(ГруппыДоступа.Ссылка) = 0
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК ЯвляетсяРуководителемОтделаКачества
		|ИЗ
		|	Справочник.ГруппыДоступа КАК ГруппыДоступа
		|ГДЕ
		|	ГруппыДоступа.Ссылка = &ГруппаДоступа
		|	И ГруппыДоступа.Пользователи.Пользователь = &Пользователь";
	
	Запрос.УстановитьПараметр("ГруппаДоступа", Справочники.ГруппыДоступа.НайтиПоНаименованию("Руководитель отдела качества"));
	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ЯвляетсяРуководителемОтделаКачества;
	КонецЕсли;

	Возврат Ложь;
	
КонецФункции // ЯвляетсяРуководителемОтделаКачества()


&НаСервере
Функция СтатусОтработано()
	Возврат Объект.Статус = Перечисления.СтатусыАктаОРасхождениях.Отработано
КонецФункции // СтатусОтработано()

&НаКлиенте
Процедура Док_ПередЗакрытииПеред(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
   ПараметрыЗаписи = Новый Структура();
   ПараметрыЗаписи.Вставить("Закрыть", Истина);
	Если НезаполненыеОтработкиРасхождений() И Модифицированность Тогда
       Отказ = Истина;
       ТекстВопроса = НСтр("ru = 'Данные были изменены. Сохранить изменения?'");
       Оповещение = Новый ОписаниеОповещения("ВопросПередЗакрытиемЗавершение", ЭтотОбъект);
       ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередЗакрытиемЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
       ПараметрыЗаписи = Новый Структура();
       ПараметрыЗаписи.Вставить("Закрыть", Истина);
       Если Записать(ПараметрыЗаписи) Тогда
       		Закрыть();
       КонецЕсли;
	ИначеЕсли Результат = КодВозвратаДиалога.Нет Тогда
       Модифицированность = Ложь;
       Закрыть();
	КонецЕсли;
        
КонецПроцедуры


&НаКлиенте
Процедура Док_ПровестиИЗакрытьВместоПеред(Команда)
	ПараметрыЗаписи = Новый Структура();
    ПараметрыЗаписи.Вставить("РежимЗаписи", ПредопределенноеЗначение("РежимЗаписиДокумента.Проведение"));
    ПараметрыЗаписи.Вставить("Закрыть", Истина);
	
	Если НезаполненыеОтработкиРасхождений() И Записать(ПараметрыЗаписи) Тогда
		Закрыть();
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура Док_СтатусПриИзмененииПосле(Элемент)
	Если Не СтатусОтработано() Тогда
		Объект.ОтработанБезРазбора = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция НезаполненыеОтработкиРасхождений()
	НетОшибок = Истина;
	Для ТекИндекс = 0 По Объект.Товары.Количество()-1 Цикл
		
		ТекущаяСтрока = Объект.Товары[ТекИндекс];
		Если Объект.Статус <> Перечисления.СтатусыАктаОРасхождениях.НеСогласовано 
			И (ТекущаяСтрока.КоличествоУпаковок - ТекущаяСтрока.КоличествоУпаковокПоДокументу) <> 0 
			И Не ЗначениеЗаполнено(ТекущаяСтрока.Действие) Тогда
			
			ТекстОшибки = НСтр("ru='Не заполнено поле ""Как отражать расхождение"" в строке %НомерСтроки% списка ""Товары""'");
			ТекстОшибки =  СтрЗаменить(ТекстОшибки, "%НомерСтроки%", ТекущаяСтрока.НомерСтроки);
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
				ТекстОшибки,
				,
				ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("Товары", ТекущаяСтрока.НомерСтроки, "Действие"),
				,
				Истина);
			НетОшибок = Ложь;
		КонецЕсли;
	КонецЦикла;
	Возврат НетОшибок;
КонецФункции 

&НаКлиенте
Процедура ПроверитьУстановленоОформитьИЕстьНазначениеОтправителя(ПоказыватьОповещение = Ложь, Строка = Неопределено)
	Строка = ?(ЗначениеЗаполнено(Строка), Строка, Элементы.Товары.ТекущиеДанные);
	
	Если Строка <> Неопределено И ДействиеРавноОформить(Строка.Действие) И ЗначениеЗаполнено(Строка.НазначениеОтправителя) Тогда
		
		Если ПоказыватьОповещение Тогда
			ПоказатьПредупреждение(,"Внимание!
			|При оприходовании этого товара необходимо указать ""Назначение отправителя"" в поле ""Назначение""");
		Иначе
			Сообщить("Внимание! При оприходовании товара в строке " + Строка.НомерСтроки + " необходимо указать ""Назначение отправителя"" в поле ""Назначение""");
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДействиеРавноОформить(Действие)
	Возврат Действие = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ДопоставкаНеТребуется;
КонецФункции

&НаКлиенте
&После("ВыборДействияЗавершение")
Процедура Док_ВыборДействияЗавершение(Результат, ДополнительныеПараметры)
	ПроверитьУстановленоОформитьИЕстьНазначениеОтправителя(Истина);
КонецПроцедуры

&НаКлиенте
&После("ИзменитьДействиеВыделенныхСтрокЗавершение")
Процедура Док_ИзменитьДействиеВыделенныхСтрокЗавершение(Результат, ДополнительныеПараметры)
	Для каждого Строка из Объект.Товары Цикл
		СтруктураСтрока = Новый Структура("Действие, НазначениеОтправителя, НомерСтроки");
		ЗаполнитьЗначенияСвойств(СтруктураСтрока, Строка);
		ПроверитьУстановленоОформитьИЕстьНазначениеОтправителя(Ложь, СтруктураСтрока);
	КонецЦикла;
КонецПроцедуры

