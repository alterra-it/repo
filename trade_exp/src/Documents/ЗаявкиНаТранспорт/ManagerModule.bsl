#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
// Печать 
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Для Каждого Ссылка Из МассивОбъектов Цикл
		ДанныеПечати = ПолучитьДанныеПечати(Ссылка);
		ТабДок = Обработки.ПечатьТранспортнойНакладнойЛогистика.СформироватьПечатнуюФормуТранспортнойНакладной(ДанныеПечати, Новый СписокЗначений);		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"Макет", НСтр("ru = 'Печать ТТН'"), ТабДок);
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьДанныеПечати(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаявкиНаТранспорт.Ссылка,
	|	ЗаявкиНаТранспорт.ПометкаУдаления,
	|	ЗаявкиНаТранспорт.Номер,
	|	ЗаявкиНаТранспорт.Дата КАК ДатаЗаявки,
	|	ЗаявкиНаТранспорт.Проведен,
	|	ЗаявкиНаТранспорт.Автор,
	|	ЗаявкиНаТранспорт.АдресОтправителя,
	|	ЗаявкиНаТранспорт.АдресПогрузки,
	|	ЗаявкиНаТранспорт.БанковскийСчетГрузоотправителя,
	|	ЗаявкиНаТранспорт.Вес,
	|	ЗаявкиНаТранспорт.ВидЗагрузки,
	|	ЗаявкиНаТранспорт.Грузоотправитель,
	|	ЗаявкиНаТранспорт.Грузополучатель,
	|	ЗаявкиНаТранспорт.ДатаВыполнения,
	|	ЗаявкиНаТранспорт.ДатаПрибытия,
	|	ЗаявкиНаТранспорт.ДатаПрибытияНаСкладПлан,
	|	ЗаявкиНаТранспорт.ДатаРаботы,
	|	ЗаявкиНаТранспорт.ЕдИзм,
	|	ЗаявкиНаТранспорт.Основание,
	|	ЗаявкиНаТранспорт.Количество,
	|	ЗаявкиНаТранспорт.Комментарий,
	|	ЗаявкиНаТранспорт.КомментарийЛогиста,
	|	ЗаявкиНаТранспорт.КомментарийМенеджера,
	|	ЗаявкиНаТранспорт.КонтактноеЛицо,
	|	ЗаявкиНаТранспорт.КонтактноеЛицоГрузополучателя,
	|	ЗаявкиНаТранспорт.Менеджер,
	|	ЗаявкиНаТранспорт.НаименованиеТовара,
	|	ЗаявкиНаТранспорт.Объем,
	|	ЗаявкиНаТранспорт.Поставщик,
	|	ЗаявкиНаТранспорт.Статус,
	|	ЗаявкиНаТранспорт.СтоимостьГруза,
	|	ЗаявкиНаТранспорт.СтоимостьДоставки,
	|	ЗаявкиНаТранспорт.СчетПоставщика,
	|	ЗаявкиНаТранспорт.ТелефонКонтактногоЛица,
	|	ЗаявкиНаТранспорт.ТипУпаковки,
	|	ЗаявкиНаТранспорт.ТранспортнаяКомпания,
	|	ЗаявкиНаТранспорт.ФактическаяСтоимостьДоставки,
	|	ЗаявкиНаТранспорт.ФирмаПлательщик
	|ИЗ
	|	Документ.ЗаявкиНаТранспорт КАК ЗаявкиНаТранспорт
	|ГДЕ
	|	ЗаявкиНаТранспорт.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Процедура ЗаполнитьДанныеПоОснованию(Основание, Объект)   Экспорт
	
	Если ЗначениеЗаполнено(Основание) Тогда
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			КонтактыКонтактногоЛицаОтпровителя= АльтерраОбщегоНазначения.ПулучитьКонтактыКонтактногоЛица(Основание.КонтактноеЛицо);
			СведеньяОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Основание.Организация, ТекущаяДата());
			СведеньяОПартнере = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Основание.Контрагент, ТекущаяДата());

			//Шапка
			 Объект.Основание = Основание;
			//Покупатель
			Объект.КонтактноеЛицоГрузополучателя = Основание.Автор;
			Объект.Грузополучатель = Справочники.Партнеры.НайтиПоНаименованию(Основание.Организация.Наименование);
			Объект.АдресОтправителя = АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформацию(Основание.Склад, Справочники.ВидыКонтактнойИнформации.АдресСклада);
			
			//Поставщик
			Объект.Поставщик = Основание.Партнер;
			Объект.Контрагент = Основание.Контрагент;

			Объект.Грузоотправитель = Основание.Организация;
			Объект.КонтактноеЛицо = Основание.КонтактноеЛицо;
			ТелефонКонтактЛица = КонтактыКонтактногоЛицаОтпровителя[Справочники.ВидыКонтактнойИнформации.ТелефонКонтактногоЛица];
			Объект.КонтактноеЛицо = Объект.КонтактноеЛицо + " " + ТелефонКонтактЛица;
			Объект.АдресПогрузки = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведеньяОПартнере, "ФактическийАдрес");
			
			ВыборкаБанковскихСчетов = Справочники.БанковскиеСчетаОрганизаций.Выбрать(,Основание.Организация); 
			Если ВыборкаБанковскихСчетов.Следующий() Тогда
				Объект.БанковскийСчетГрузоотправителя = ВыборкаБанковскихСчетов.Ссылка;
			КонецЕсли;
			
			//Подвал
			СтрукВесОбъем = АльтерраОбщегоНазначения.ПолучитьВесОбъемТоваров(Основание.Товары.Выгрузить());
			
			Объект.Вес = СтрукВесОбъем.Вес; 
			Объект.Объем =  СтрукВесОбъем.Объем;
			Объект.СтоимостьГруза = Основание.СуммаДокумента;
			Объект.ДатаПрибытияНаСкладПлан =  Основание.ДатаПоступления;
		КонецЕсли;
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
	    	Объект.Основание = Основание;
			//Общие реквизиты
			СведеньяОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Основание.Организация, ТекущаяДата());
			
			//Шапка
			
			//Покупатель
			Объект.Грузополучатель = Справочники.Партнеры.НайтиПоНаименованию(Основание.Организация.Наименование);
			Объект.АдресПогрузки = АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформацию(Основание.СкладОтправитель, Справочники.ВидыКонтактнойИнформации.АдресСклада);
			Объект.КонтактноеЛицоГрузополучателя = Основание.Ответственный;
				
			Объект.Грузоотправитель = Основание.Организация;
			Объект.АдресОтправителя = АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформацию(Основание.СкладПолучатель, Справочники.ВидыКонтактнойИнформации.АдресСклада);
			
			ВыборкаБанковскихСчетов = Справочники.БанковскиеСчетаОрганизаций.Выбрать(,Основание.Организация); 
			Если ВыборкаБанковскихСчетов.Следующий() Тогда
				Объект.БанковскийСчетГрузоотправителя = ВыборкаБанковскихСчетов.Ссылка;
			КонецЕсли;
			
			//Подвал
			СтрукВесОбъем = АльтерраОбщегоНазначения.ПолучитьВесОбъемТоваров(Основание.Товары.Выгрузить());
			
			Объект.Вес = СтрукВесОбъем.Вес; 
			Объект.Объем =  СтрукВесОбъем.Объем;
		КонецЕсли;
	КонецЕсли; 

КонецПроцедуры


#КонецЕсли