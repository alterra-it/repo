&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	
	Если ЭтотОбъект.Проведен Тогда
		Документы.ЗаявкаВЕГАИСЛес.СозданиеЗаявкиЛесЕГАИС(Ссылка);
	Иначе 
		// При отмене проведения перемещения, отменяем проведение заявки Лес ЕГАИС.
		Документы.ЗаявкаВЕГАИСЛес.ОтменитьПроведениеЗаявкиЕГАИСЛес(Ссылка);
	КонецЕсли;
	
	// При пометке/снятии пометки на удаление перемещения, помечаем/снимаем пометку заявку Лес ЕГАИС
	Если ЭтотОбъект.ПометкаУдаления ИЛИ (НЕ ЭтотОбъект.ПометкаУдаления И НЕ ЭтотОбъект.Проведен) Тогда
		Документы.ЗаявкаВЕГАИСЛес.ПометкаНаУдалениеЗаявкиЕГАИСЛес(Ссылка);
	КонецЕсли;  
	
	
	Если ЭтотОбъект.ПометкаУдаления и НЕ (РольДоступна("ПолныеПрава") или РольДоступна("УдалениеПеремещенийБухгалтерия")) Тогда    
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
						|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК Ссылка
						|ИЗ
						|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
						|		Левое СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
						|		ПО ЗаказНаДоставкуКлиентуОснования.Ссылка = ЗаданиеНаПеревозкуРейсОснования.Документ
						|ГДЕ
						|	ЗаказНаДоставкуКлиентуОснования.Документ = &Ссылка
						|	И (ЗаказНаДоставкуКлиентуОснования.Ссылка.ПометкаУдаления = ЛОЖЬ
						|	ИЛИ (НЕ ЗаданиеНаПеревозкуРейсОснования.Ссылка есть null 
						|			и ЗаданиеНаПеревозкуРейсОснования.Ссылка.ПометкаУдаления = ЛОЖЬ))";
		Запрос.УстановитьПараметр("Ссылка", Ссылка);                                          
		Выборка = Запрос.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда
			Сообщить("Нельзя удалять Перемещение, по которому есть доставка. Удалите Заказ на доставку или Перемещение из Заказа на доставку");
			Отказ = Истина;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры


#Область Проверки

Процедура ПроверитьЧтоНетПриходныхОрдеровНаТовары(Объект, Отказ)  Экспорт

	Запрос = Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТП.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.ТоварыКПоступлению КАК ТП
	|ГДЕ
	|	ТП.ДокументПоступления = &Ссылка
	|	И ТИПЗНАЧЕНИЯ(ТП.Регистратор) = ТИП(Документ.ПриходныйОрдерНаТовары)
	|	И ТП.Регистратор.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПриходныхОрдеров.Принят)";

	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда 
		Сообщить("Существуют принятые складские ордера. Распроводить документ запрещено!");
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Регистратор, Строка(Выборка.Регистратор));
		КонецЦикла;

		Отказ = Истина;
