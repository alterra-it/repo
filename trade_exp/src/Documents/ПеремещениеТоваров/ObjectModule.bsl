		События.Записать();
	КонецЕсли;
	
	Если Код = "1" или Код = "3" Тогда 
		  НаборЗаписей=РегистрыСведений.СобытияДокументовАльтерра.СоздатьМенеджерЗаписи();
          НаборЗаписей.Период = дата;
          НаборЗаписей.Документ = Ссылка;
          НаборЗаписей.Событие = Перечисления.СобытияДокументов.ТребуетсяПовторноеУведомлениеПодрядчику;
