&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если Не ЗначениеЗаполнено(ВариантПриемкиТоваров) Тогда
		ВариантПриемкиТоваров= Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	КонецЕсли;
	
	Если Не ЭтоНовый() Тогда
		Если АльтерраОбщегоНазначения.ТабличнаяЧастьИзменилась(Ссылка.Товары, Товары) тогда
			РегистрыСведений.СобытияДокументовАльтерра.ЗаписатьСобытие(Ссылка, Перечисления.СобытияДокументов.ИзменениеТабличнойЧасти);
		КонецЕсли;
	иначе
		ЭтотОбъект.ПеремещениеНаФилиал=Документы.ПеремещениеТоваров.ПеремещениеНаФилиал(ЭтотОбъект);	
	КонецЕсли;
	Если Ссылка.Статус <> Статус Тогда
			ДатаПринятия = ?(Статус = Перечисления.СтатусыПеремещенийТоваров.Принято, ТекущаяДата(), Дата(1, 1, 1, 0, 0, 0)); 
	КонецЕсли	

КонецПроцедуры

&Вместо("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Автор = Пользователи.ТекущийПользователь();
	
		
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АрендаНоменклатуры") ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АрендаНоменклатурыВозврат") Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения,,"Дата,Номер");
		Дата= ТекущаяДата();
		ДатаРаспоряжения= Дата;
		Статус= Перечисления.СтатусыПеремещенийТоваров.Принято;
		Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АрендаНоменклатуры") Тогда
			СкладОтправитель= ДанныеЗаполнения.Склад;
			СкладПолучатель= Подразделение.СкладАренды;
		Иначе
			СкладПолучатель= ДанныеЗаполнения.Склад;
			СкладОтправитель= Подразделение.СкладАренды;
		КонецЕсли;
		Ответственный= Пользователи.ТекущийПользователь();
		ОрганизацияПолучатель= Организация;
		СпособДоставки= Перечисления.СпособыДоставки.Самовывоз;
		ВариантПриемкиТоваров= Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
		ХозяйственнаяОперация= Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		ДокументОснование= ДанныеЗаполнения;
		
		Товары.Очистить();
		Для Каждого ТоварОснования Из ДанныеЗаполнения.Товары Цикл
			НоваяСтрока= Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТоварОснования);
			НоваяСтрока.КоличествоУпаковок= НоваяСтрока.Количество;
		КонецЦикла;
	Иначе
		Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
			Если ДанныеЗаполнения.Свойство("МассивЗаказов") Тогда
				Основания = ДанныеЗаполнения.МассивЗаказов;
				Если ЗначениеЗаполнено(Основания[0].Комментарий) Тогда
					КомментарийДляСклада = Основания[0].Комментарий;
				КонецЕсли;
				Если Основания.Количество() > 0 Тогда
					Для каждого ЗаказОснования из Основания Цикл
						ЗаказКлиента = ЗаказОснования.ДокументОснование;
						Если ЗначениеЗаполнено(ЗаказКлиента) 
							И Не БонусыАльтерраРезерв.ПолучитьЗначениеРеквизита(ЗаказКлиента, "КомментарийДляСклада") = Ложь
						Тогда
							КомментарийДляСклада = КомментарийДляСклада + ЗаказКлиента.КомментарийДляСклада + "; "; 
						КонецЕсли;
					КонецЦикла;
					ВидПодтоварки = Основания[0].ВидПодтоварки;
	
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		

		
		//№ 80624
		Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ 
			ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") ИЛИ
			ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда
			
			СкладОтправитель= ДанныеЗаполнения.Склад;
			ДокументОснование= ДанныеЗаполнения;
			
			ТабличнаяЧастьТовары = ?(ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации"), ДанныеЗаполнения.Расхождения, ДанныеЗаполнения.Товары);
			
			Товары.Очистить();
			Для Каждого ТоварОснования Из ТабличнаяЧастьТовары Цикл
				НоваяСтрока= Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ТоварОснования,,"КодСтроки,ИдентификаторСтроки,Кладовщик");
				Если ТоварОснования.Количество < 0 Тогда
					НоваяСтрока.Количество = -1*ТоварОснования.Количество; 
					НоваяСтрока.КоличествоУпаковок = -1*ТоварОснования.КоличествоУпаковок;
				КонецЕсли;
			КонецЦикла;
					
		КонецЕсли;
				
		//Если ДанныеЗаполнения.Свойство("ВидПодтоварки") Тогда
		//	ЭтотОбъект.ВидПодтоварки = ДанныеЗаполнения.ВидПодтоварки;
		//КонецЕсли;
		
		ПродолжитьВызов(ДанныеЗаполнения, СтандартнаяОбработка);
	КонецЕсли;
	
	ПослеЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка);
КонецПроцедуры


Процедура ПослеЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения=Неопределено Тогда 
			Возврат;
	КонецЕсли; 
	
	СправочникСклады_ГруппаПодрядчики = Справочники.Склады.НайтиПоНаименованию("Подрядчики");
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		Если ДанныеЗаполнения.Свойство("МассивЗаказов") Тогда
			
			Если (ЗначениеЗаполнено(СкладПолучатель) И 
				ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И 
				СкладПолучатель.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики)) ИЛИ
				(ЗначениеЗаполнено(СкладОтправитель) И 
				ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И 
				СкладОтправитель.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики)) Тогда 
				Запрос = Новый запрос; 
				Запрос.Текст =  "ВЫБРАТЬ
				|	ЗаказНаПеремещениеТовары.НомерСтроки КАК НомерСтроки,
				|	ЗаказНаПеремещениеТовары.КомментарийОтИнженера КАК КомментарийОтИнженера
				|ИЗ
				|	Документ.ЗаказНаПеремещение.Товары КАК ЗаказНаПеремещениеТовары
				|ГДЕ
				|	ЗаказНаПеремещениеТовары.Ссылка = &Ссылка
				|
				|УПОРЯДОЧИТЬ ПО
				|	НомерСтроки"; 
				ЗАпрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения.МассивЗаказов[0]); 
				Выборка = Запрос.Выполнить().Выбрать(); 
				Для Каждого Строка из Товары Цикл 
					Выборка.Следующий();
					Строка.КомментарийОтИнженера = Выборка.КомментарийОтИнженера; 
				КонецЦикла; 	
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)		
		ДвиженияПеремещенийКПередаче(ЭтотОбъект, ЭтотОбъект.Движения);
		
		ДопМодуль.КонтрольОстатков(ЭтотОбъект,Отказ);
		
		Альтерра_СкладСервер.КонтрольОстатковПоТоварамНаСкладах(ЭтотОбъект,Отказ);
		
		РегистрыСведений.СостоянияОтгрузкиНакладных.ОбновитьСостояниеОтгрузкиНакладной(ЭтотОбъект,СкладОтправитель);  
		
		ОтправкаУведомленийПодрядчику(); 
		
КонецПроцедуры

Процедура ОтправкаУведомленийПодрядчику()
	ПовторнаяОтправка = Ложь; 
	УведомлениеОтправлено = Ложь; 
	Запрос = Новый Запрос; 
	Запрос.Текст="
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СобытияДокументовАльтерраСрезПоследних.Документ КАК Документ,
	|	СобытияДокументовАльтерраСрезПоследних.Событие КАК Событие
	|ИЗ
	|	РегистрСведений.СобытияДокументовАльтерра.СрезПоследних(, Событие = &Событие1) КАК СобытияДокументовАльтерраСрезПоследних
	|ГДЕ
	|	СобытияДокументовАльтерраСрезПоследних.Документ = &Документ
	|
	|ОБЪЕДИНИТЬ ВСЕ 
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	СобытияДокументовАльтерраСрезПоследних.Документ,
	|	СобытияДокументовАльтерраСрезПоследних.Событие
	|ИЗ
	|	РегистрСведений.СобытияДокументовАльтерра.СрезПоследних(, Событие = &Событие2) КАК СобытияДокументовАльтерраСрезПоследних
	|ГДЕ
	|	СобытияДокументовАльтерраСрезПоследних.Документ = &Документ";
	Запрос.УстановитьПараметр("Документ",Ссылка);
	Запрос.УстановитьПараметр("Событие1",Перечисления.СобытияДокументов.УведомлениеПодрядчику); 
	Запрос.УстановитьПараметр("Событие2",Перечисления.СобытияДокументов.ТребуетсяПовторноеУведомлениеПодрядчику);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		Если Выборка.Событие = Перечисления.СобытияДокументов.ТребуетсяПовторноеУведомлениеПодрядчику Тогда
			ПовторнаяОтправка = Истина;
		КонецЕсли;
		Если Выборка.Событие = Перечисления.СобытияДокументов.УведомлениеПодрядчику Тогда
			УведомлениеОтправлено = Истина; 
		КонецЕсли;
	КонецЦикла; 
	 
	СправочникСклады_ГруппаПодрядчики = Справочники.Склады.НайтиПоНаименованию("Подрядчики");
	Если ЗначениеЗаполнено(СкладПолучатель) И 
		ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И 
		СкладПолучатель.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики) И
		СкладПолучатель.ОтправкаУведомлений = Истина И
		СкладПолучатель.ТипСкладаПодрядчика = Ложь И
		Статус = Перечисления.СтатусыПеремещенийТоваров.Принято Тогда 
			Если УведомлениеОтправлено = Ложь Тогда 
				ОтправитьСМСиEmail("0");//Если это первое перемещение на транзитный склад со статусом "Принято", который надо уведомлять - то отправляем уведомление. Код "0" означает первую отправку документа 
			Иначе
				Если ПовторнаяОтправка Тогда 
					ОтправитьСМСиEmail("1");//Повторная отправка
				КонецЕсли;
				
			КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СкладОтправитель) И 
		ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И 
		СкладОтправитель.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики) И
		СкладОтправитель.ОтправкаУведомлений = Истина И
		СкладОтправитель.ТипСкладаПодрядчика = Истина И
		Статус = Перечисления.СтатусыПеремещенийТоваров.Принято Тогда 
			Если УведомлениеОтправлено = Ложь Тогда 
				ОтправитьСМСиEmail("2");//Если это первое перемещение с договорного склада со статусом "Принято", который надо уведомлять - то отправляем уведомление. Код "2" означает первую отправку документа 
			Иначе
				Если ПовторнаяОтправка Тогда 
					ОтправитьСМСиEmail("3");//Повторная отправка
				КонецЕсли;
			КонецЕсли;
	КонецЕсли;
КонецПроцедуры

Процедура ОтправитьСМСиEmail(код)


	Если Не ЗначениеЗаполнено(Ссылка) Тогда
		ОбщегоНазначения.СообщитьПользователю("Документ должен быть записан!");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Номер) Тогда
		ОбщегоНазначения.СообщитьПользователю("Номер документа должен быть указан!");
		Возврат;
	КонецЕсли;
	
	ФайлОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Печатные формы перемещения", Истина);
	ФайлОбработка2 = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Печатные формы перемещения", Истина);

	Если Не ЗначениеЗаполнено(ФайлОбработка) Тогда
		ОбщегоНазначения.СообщитьПользователю("Ошибка! Не найдена доп. обработка 'Печатные формы перемещения'..");
		Возврат;
	КонецЕсли;
	МассивСкладов = Новый Массив; 
	Если код = "0" или код ="1" Тогда
		УведомленияПодрядчикуПочта = СкладПолучатель.EMAILподрядчика;
		УведомленияПодрядчикуТелефон =СкладПолучатель.ТелефонПодрядчика;
		МассивСкладов.Добавить(СкладПолучатель); 
		МассивСкладов.Добавить(СкладПолучатель.ДопСкладПодрядчика); 
		ДопПочта = СкладПолучатель.ДопEMAILподрядчика; 
	КонецЕсли; 	
	Если код = "2" или код = "3" Тогда
		УведомленияПодрядчикуПочта = СкладОтправитель.EMAILподрядчика;
		УведомленияПодрядчикуТелефон =СкладОтправитель.ТелефонПодрядчика;
		МассивСкладов.Добавить(СкладОтправитель.ДопСкладПодрядчика);
		МассивСкладов.Добавить(СкладОтправитель);
		ДопПочта = СкладОтправитель.ДопEMAILподрядчика; 
	КонецЕсли; 		
	
	ПараметрыПечати = Новый Структура;
	ПараметрыПечати.Вставить("ВыводитьСумму", Истина);
	
	МассивДокументов = Новый Массив;
	МассивДокументов.Добавить(Ссылка);
	
	ОбъектыПечати = Новый СписокЗначений;
	ОбъектыПечати.Добавить(Ссылка);
	
	ДвоичныеДанные = ФайлОбработка.ХранилищеОбработки.Получить();
	ФайлОбработка = ПолучитьИмяВременногоФайла();
	ДвоичныеДанные.Записать(ФайлОбработка);
	
	ДвоичныеДанные2 = ФайлОбработка2.ХранилищеОбработки.Получить();
	ФайлОбработка2 = ПолучитьИмяВременногоФайла();
	ДвоичныеДанные2.Записать(ФайлОбработка2);

	
	СуммаИтог = 0;
	ТабличныйДокумент = ВнешниеОбработки.Создать(ФайлОбработка).СформироватьПечатнуюФормуНакладнаяНаПеремещениеПодрядчику(МассивДокументов, ОбъектыПечати, ПараметрыПечати, СуммаИтог);
	ФайлТабДок = ПолучитьИмяВременногоФайла();
	ТабличныйДокумент.Записать(ФайлТабДок, ТипФайлаТабличногоДокумента.XLSX);
	АдресВХ = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ФайлТабДок));
	
	Если код = "0" или код = "1" Тогда 
		ТабличныйДокумент2 = ВнешниеОбработки.Создать(ФайлОбработка2).СформироватьПечатнуюФормуВедомостьОстатковНаСкладах(Ссылка, МассивСкладов, "1");
	Иначе
		ТабличныйДокумент2 = ВнешниеОбработки.Создать(ФайлОбработка2).СформироватьПечатнуюФормуВедомостьОстатковНаСкладах(Ссылка, МассивСкладов, "0");
	КонецЕсли; 
	ФайлТабДок2 = ПолучитьИмяВременногоФайла();
	ТабличныйДокумент2.Записать(ФайлТабДок2, ТипФайлаТабличногоДокумента.XLSX);
	АдресВХ2 = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ФайлТабДок2));

	
	
	
	
	МассивФайлов = Новый Массив;
	МассивФайлов.Добавить(Новый Структура("Представление, АдресВоВременномХранилище","Ведомость по остаткам на складе" + ".xlsx", АдресВХ2));

	
	ПараметрыОтправки = Новый Структура;
	ПараметрыОтправки.Вставить("Кому", УведомленияПодрядчикуПочта);
	Если код = "0" Тогда //1 Перемещение на транзит поставщика
		МассивФайлов.Добавить(Новый Структура("Представление, АдресВоВременномХранилище", "Поступление ТМЦ на " + СкладПолучатель + " "+ номер +  ".xlsx", АдресВХ));
		ПараметрыОтправки.Вставить("Тема", "Альтерра поступление ТМЦ на " + СкладПолучатель);
