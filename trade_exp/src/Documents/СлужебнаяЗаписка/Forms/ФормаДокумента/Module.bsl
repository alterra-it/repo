
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОграничениеДоступностиОстатков = АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков();
	
	РольДоступна = Ложь;
	
	Если ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда 
		Отказ = Истина; 
		Сообщить("Копирование запрещенно"); 
	КонецЕсли;
	
	Если Не ПроверкаРоли() Тогда
		Отказ = Истина; 
		Сообщить("Не достаточно прав для создания документа");
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Ответственный = Пользователи.ТекущийПользователь();
		Объект.Утверждающий1 = РеквизитФормыВЗначение("Объект").ПолучитьРуководителяПользователя(Объект.Ответственный);
		Объект.Статус = "Подготовлено";
	КонецЕсли; 
	
	Если Не ЗначениеЗаполнено(Объект.ЗаСчет) Тогда   
		Элементы.ЗаСчет.ЦветРамки = Новый Цвет(255,0,0);
	КонецЕсли;
	

	Если ТипЗнч(Объект.Товары[0].Основание) = Тип("ДокументСсылка.ПересчетТоваров") И НЕ РольДоступна("ПолныеПрава") Тогда
		Элементы.Товары.ТолькоПросмотр = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПроверкаРоли()
	РольДоступна = Пользователи.РолиДоступны("ДобавлениеИзменениеСлужебнойЗаписки");
	Возврат РольДоступна;
КонецФункции 

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОтобразитьОснования();
	УстановитьВидимостьПоВиду();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПоВиду()
	
	Для каждого Элемент Из Элементы.Товары.ПодчиненныеЭлементы Цикл
		Элемент.Видимость = Истина;
	КонецЦикла;
	Для каждого Элемент Из Элементы.ГруппаСписываемыйТовар.ПодчиненныеЭлементы Цикл
		Элемент.Видимость = Истина;
	КонецЦикла;
	
	Элементы.ГруппаПриходуемыйТовар.Видимость             = Ложь;
	Элементы.ГруппаСписываемыйТовар.ОтображатьЗаголовок   = Ложь;
	Элементы.ГруппаСписываемыйТовар.ОтображатьВШапке      = Ложь;
	Элементы.Основание.Видимость = Ложь;
	Элементы.Отклонение.Видимость                   = Ложь;
	Элементы.Количество.Видимость                   = Ложь;
	Элементы.ПричинаСписания.Видимость              = Ложь;
	Элементы.КоличествоУпаковок.Заголовок           = "Количество";
	Элементы.Цена.Заголовок                         = "Цена";
	Элементы.Цена.Видимость                         = Ложь;
	Элементы.ЗаполнитьЦеныПоСебестоимости.Видимость = Ложь;
	
	Если Объект.Вид = ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Пересчет") Тогда
		Элементы.Сумма.Видимость                              = Ложь;
		Элементы.КоличествоУпаковок.Заголовок                 = "По учету (весь товар)";
		Элементы.ПричинаБлокировки.Видимость                  = Ложь;
		Элементы.Отклонение.Видимость                         = Истина;
		Элементы.ЯПХ.Видимость                                = Истина;
		Элементы.КоличествоУпаковокПоФакту.Видимость          = Истина;
	ИначеЕсли  
		Объект.Вид = ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Пересорт") Тогда
		Элементы.ГруппаПриходуемыйТовар.Видимость             = Истина;
		Элементы.ГруппаСписываемыйТовар.ОтображатьЗаголовок   = Истина;
		Элементы.ГруппаСписываемыйТовар.ОтображатьВШапке      = Истина;
		Элементы.ЗаполнитьЦеныПоСебестоимости.Видимость       = Истина;
		Элементы.ЦенаПриходуемый.Видимость         		 	  = Ложь;
		Элементы.КоличествоУпаковокПоФакту.Видимость          = Ложь;
		
	Иначе
		Элементы.Цена.Заголовок                               = "Себестоимость ед., руб";
		Элементы.Цена.Видимость                               = Истина;
		Элементы.Количество.Видимость                         = Истина;
		Элементы.ЗаполнитьЦеныПоСебестоимости.Видимость       = Истина;
		Элементы.ЕдиницаИзмерения.Видимость                   = Ложь;
		Элементы.КоличествоУпаковок.Видимость                 = Ложь;
		Элементы.КоличествоУпаковокПоФакту.Видимость          = Ложь;
		Элементы.ПричинаСписания.Видимость                    = Истина;
	КонецЕсли;
	
	РассчитатьПоСтроке();
	УстановитьВидимостьПоРолям();

КонецПроцедуры

Процедура УстановитьВидимостьПоРолям()
	
	Если ОграничениеДоступностиОстатков И Объект.Вид = ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Пересчет") Тогда
		УчетСкрыт = Объект.Товары[0].Основание.УчетСкрыт;
		Если УчетСкрыт Тогда
			ОтображатьОстатки = АльтерраОбщегоНазначения.ЕстьПравоПросмотраОстатков(Пользователи.ТекущийПользователь());
			Элементы.КоличествоУпаковок.Видимость = ОтображатьОстатки;
			Элементы.Отклонение.Видимость = ОтображатьОстатки;
			Элементы.КоличествоПоУчетуВЗонеХранения.Видимость = ОтображатьОстатки;
			Элементы.ЯПХ.Видимость = ОтображатьОстатки;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьПоСтроке()
	
	Если Элементы.Отклонение.Видимость Тогда
		Для каждого Стр Из Объект.Товары Цикл 
			Если ТипЗнч(Стр.Основание) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
				Стр.Отклонение = Документы.ПересчетТоваров.НовыйРасчетОтклонения(Стр, Стр.Основание.НовыйРасчетОтклонения);
			Иначе	
				Стр.Отклонение = Стр.КоличествоУпаковокФакт - Стр.КоличествоУпаковок;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступность(Основание)
	
	Если Объект.ИДБизнесПроцесса <> "" Или Не ПроверкаРоли() Тогда
		ЭтаФорма.ТолькоПросмотр = Истина;
		Элементы.ПересчетТоваров.Доступность = Ложь;
		Элементы.БлокировкаДвижения.Доступность = Ложь;
		Элементы.ОтправитьНаСогласование.Доступность = Ложь;
	КонецЕсли;
	
	Если Основание = "БлокировкаДвиженияТоваров" Тогда
		Элементы.Товары.ТолькоПросмотр = Ложь;
		Элементы.Вид.ТолькоПросмотр    = Ложь;
		Элементы.Вид.СписокВыбора.Очистить();
		Элементы.Вид.РежимВыбораИзСписка = Истина;
		ЗначенияВид = Новый Массив;
		ЗначенияВид.Добавить(ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Оприходование"));
		ЗначенияВид.Добавить(ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.ПереводВНк"));
		ЗначенияВид.Добавить(ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.СписаниеНедостачи"));
		ЗначенияВид.Добавить(ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Пересорт"));
		Элементы.Вид.СписокВыбора.ЗагрузитьЗначения(ЗначенияВид);
	КонецЕсли;
	
	Если Объект.Вид = ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Пересчет") Тогда
		Элементы.Товары.ТолькоПросмотр = Истина;
		Элементы.Вид.ТолькоПросмотр    = Истина;
		Элементы.Вид.РежимВыбораИзСписка = Ложь;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОснования(Команда)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ТипДокумента", Команда.Имя);
	
	Если Объект.Товары.Количество() > 0 Тогда
		ПоказатьВопрос(Новый ОписаниеОповещения("ВыбратьОснованияЗавершение", ЭтотОбъект, ДополнительныеПараметры),
						"Табличная часть будет очищена. Продолжить?", РежимДиалогаВопрос.ДаНет);
	Иначе
		ОткрытьФормуВыбора(Команда.Имя);
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьОснованияЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Объект.Товары.Очистить();
		Объект.Исполнитель = Неопределено;
		ОткрытьФормуВыбора(ДополнительныеПараметры.ТипДокумента);
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбора(Документ)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("РежимВыбора", Истина);
	ПараметрыОткрытия.Вставить("ЗакрыватьПриВыборе",Истина);
	
	ОбработкаВыбора = Новый ОписаниеОповещения("ПриЗакрытииФормыВыбора", ЭтаФорма);
	
	Если Документ = "БлокировкаДвиженияТоваров" Тогда
		ПараметрыОткрытия.Вставить("МножественныйВыбор",Истина);
		ОткрытьФорму("Документ.БлокировкаДвиженияТоваров.ФормаСписка", ПараметрыОткрытия, ЭтаФорма,,,, ОбработкаВыбора);
	Иначе
		ПараметрыОткрытия.Вставить("МножественныйВыбор",Ложь);
		ОткрытьФорму("Документ.ПересчетТоваров.ФормаВыбора", ПараметрыОткрытия, ЭтаФорма,,,, ОбработкаВыбора);
	КонецЕсли;
	
	УстановитьДоступность(Документ);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытииФормыВыбора(Результат, ДопПараметры) Экспорт

    Если Результат = Неопределено Тогда 
        Возврат;
	КонецЕсли;
	
	Если ТипЗнч(Результат) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
		ЕстьЗаписка = ПроверитьПересчет(Результат);
		Если ЕстьЗаписка = Истина Тогда
			Сообщить("По выбранному документу уже создана служебная записка.");
			Возврат;
		КонецЕсли;
	КонецЕсли; 
	
	ЗаполнитьПоОснованиям(Результат);
	ВидПриИзменении("");
	ОтобразитьОснования();

КонецПроцедуры

&НаСервере
Функция ПроверитьПересчет(Ссылка)
	ЕстьЗаписка = Документы.ПересчетТоваров.ЕстьСлужебнаяЗаписка(Ссылка);
	Возврат ЕстьЗаписка;
КонецФункции

&НаСервере
Процедура ЗаполнитьПоОснованиям(Основания)
	
	Запрос = Новый Запрос;
	
	Если ТипЗнч(Основания) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
		Объект.Вид = ПредопределенноеЗначение("Перечисление.ВидыСлужебныхЗаписок.Пересчет");
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПересчетТоваровТовары.Ссылка КАК Основание,
		|	ПересчетТоваровТовары.Количество КАК Количество,
		|	ПересчетТоваровТовары.КоличествоФакт КАК КоличествоФакт,
		|	ПересчетТоваровТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ПересчетТоваровТовары.КоличествоУпаковокФакт КАК КоличествоУпаковокФакт,
		|	ПересчетТоваровТовары.ЯПХ КАК ЯПХ,
		|	ПересчетТоваровТовары.КоличествоПоУчетуВЗонеХранения КАК КоличествоПоУчетуВЗонеХранения,
		|	ПересчетТоваровТовары.Номенклатура КАК Номенклатура,
		|	ПересчетТоваровТовары.Номенклатура.Код КАК Код,
		|	ПересчетТоваровТовары.Упаковка КАК Упаковка,
		|	ПересчетТоваровТовары.Характеристика КАК Характеристика,
		|	ПересчетТоваровТовары.Назначение КАК Назначение,
		|	ПересчетТоваровТовары.Ссылка.Склад КАК Склад
		|ИЗ
		|	Документ.ПересчетТоваров.Товары КАК ПересчетТоваровТовары
		|ГДЕ
		|	ПересчетТоваровТовары.Ссылка = &Основание"
	Иначе
		
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаДвиженияТоваровТовары.Ссылка КАК Основание,
		|	БлокировкаДвиженияТоваровТовары.Номенклатура КАК Номенклатура,
		|	БлокировкаДвиженияТоваровТовары.Номенклатура.Код КАК Код,
		|	БлокировкаДвиженияТоваровТовары.Характеристика КАК Характеристика,
		|	БлокировкаДвиженияТоваровТовары.Упаковка КАК Упаковка,
		|	БлокировкаДвиженияТоваровТовары.Количество КАК Количество,
		|	БлокировкаДвиженияТоваровТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	БлокировкаДвиженияТоваровТовары.Ссылка.ПричинаБлокировки.Ссылка КАК ПричинаБлокировки,
		|	БлокировкаДвиженияТоваровТовары.Ссылка.Склад КАК Склад
		|ИЗ
		|	Документ.БлокировкаДвиженияТоваров.Товары КАК БлокировкаДвиженияТоваровТовары
		|ГДЕ
		|	БлокировкаДвиженияТоваровТовары.Ссылка В(&Основание)";
	КонецЕсли; 
	
	Запрос.УстановитьПараметр("Основание", Основания);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Склады = Новый Массив;
	Пока Выборка.Следующий() Цикл
		Если Склады.Количество() = 0 Тогда
			Склады.Добавить(Выборка.Склад);
		Иначе
			Если Склады.Найти(Выборка.Склад) = Неопределено Тогда 
				Сообщить("Выбранные документы должны быть по одному складу!");
				Объект.Товары.Очистить();
				Прервать;
			КонецЕсли; 
		КонецЕсли; 
		Стр = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(Стр, Выборка);
	КонецЦикла;
	Объект.Склад = Склады[0];
	
	Если ТипЗнч(Основания) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
		Объект.Исполнитель = РеквизитФормыВЗначение("Объект").ПолучитьИсполнителя(Объект.Склад);
	КонецЕсли;
   
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьОснования()
	
	Если Объект.Товары.Количество() = 0 Тогда 
		Основания  = "";
		Возврат;
	КонецЕсли;
	
	ЕстьПересчет = Ложь;
	МассивОснований = Новый Массив;
	Для каждого Стр Из Объект.Товары Цикл
		Если МассивОснований.Найти(Стр.Основание) = Неопределено Тогда
			МассивОснований.Добавить(Стр.Основание);  
			
			Если ТипЗнч(Стр.Основание) = Тип("ДокументСсылка.ПересчетТоваров") Тогда
				ЕстьПересчет = Истина;
			КонецЕсли;
		КонецЕсли; 
	КонецЦикла;
	
	МассивСтрок = Новый Массив;
	Для каждого СтрМассивОснований Из МассивОснований Цикл
		МассивСтрок.Добавить(Новый ФорматированнаяСтрока(Строка(СтрМассивОснований),,,, ПолучитьНавигационнуюСсылку(СтрМассивОснований)));
	    МассивСтрок.Добавить(Символы.ПС);
	КонецЦикла; 
	
	МассивСтрок.Удалить(МассивСтрок.Количество() - 1);
	Основания = Новый ФорматированнаяСтрока(МассивСтрок);
	Элементы.Основания.МаксимальнаяВысота = МассивСтрок.Количество() - 1;
	Элементы.Основания.Высота = МассивСтрок.Количество() - 1;
	Элементы.ГруппаОснования.Высота = МассивСтрок.Количество() - 1;
	Элементы.ЯПХ.Видимость = ЕстьПересчет;
	Элементы.КоличествоПоУчетуВЗонеХранения.Видимость = ЕстьПересчет;
КонецПроцедуры

&НаКлиенте
Процедура ВидПриИзменении(Элемент)
	УстановитьВидимостьПоВиду();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПослеУдаления(Элемент)
	ОтобразитьОснования();
КонецПроцедуры

&НаКлиенте
Процедура ТоварыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
		Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьЦеныПоСебестоимости(Команда)
	
	ОчиститьСообщения();
	Если Объект.Товары.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='В документе не заполнена таблица ""Товары"". Цены не могут быть заполнены'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, , "Товары", "Объект");		
		Возврат;
	КонецЕсли;
	ЗаполнитьЦеныПоСебестоимостиНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЦеныПоСебестоимостиНаСервере()
	
	ПараметрыЗаполнения = Новый Структура;
	ПараметрыЗаполнения.Вставить("Дата", ТекущаяДата());
	ПараметрыЗаполнения.Вставить("Организация", Справочники.Организации.НайтиПоНаименованию("Альтерра ООО"));
	ПараметрыЗаполнения.Вставить("Валюта", Справочники.Валюты.НайтиПоНаименованию("руб"));
	ПараметрыЗаполнения.Вставить("Склад", Объект.Склад);
	
	ПродажиСервер.ЗаполнитьЦеныПоСебестоимости(
	Объект.Товары, // Табличная часть
	Неопределено, // Выделенные строки (заполнять во всех строках)
	ПараметрыЗаполнения);
	
	Если Элементы.ГруппаПриходуемыйТовар.Видимость = Истина Тогда
		НоменклатураОприходование = Объект.Товары.Выгрузить(, "НомерСтроки,НоменклатураОприходование, ХарактеристикаОприходование, НазначениеОприходование");
		НоменклатураОприходование.Колонки.Добавить("Цена");
		ДругиеИменаКолонок = Новый Структура("НоменклатураОприходование, ХарактеристикаОприходование, НазначениеОприходование", "Номенклатура", "Характеристика", "Назначение");
		ПараметрыЗаполнения.Вставить("ДругиеИменаКолонок", ДругиеИменаКолонок);
		
		ПродажиСервер.ЗаполнитьЦеныПоСебестоимости(
		НоменклатураОприходование, // Табличная часть
		Неопределено, // Выделенные строки (заполнять во всех строках)
		ПараметрыЗаполнения);
	КонецЕсли; 
	
	Для каждого Стр Из Объект.Товары Цикл
		Стр.Сумма = Стр.КоличествоУпаковок * Стр.Цена;
		Если Элементы.ГруппаПриходуемыйТовар.Видимость = Истина Тогда
			Для каждого СтрокаТЗ Из НоменклатураОприходование Цикл
				Если Стр.НоменклатураОприходование = СтрокаТЗ.НоменклатураОприходование Тогда
					Стр.ЦенаОприходование = СтрокаТЗ.Цена;
				КонецЕсли; 
			КонецЦикла; 
		Стр.СуммаОприходование = Стр.КоличествоУпаковок * Стр.ЦенаОприходование;
		КонецЕсли;
	КонецЦикла;
	
	Модифицированность = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ОтправитьНаСогласование(Команда)
	Если Объект.ИДБизнесПроцесса = "" Тогда
		Элементы.ОтправитьНаСогласование.Доступность = Ложь;
		ПоказатьВопрос(Новый ОписаниеОповещения("ОтправитьНаСогласованиеЗавершение", ЭтотОбъект),
							"Документ будет сохранен, дальнейшее изменение будет невозможно. Продолжить?", РежимДиалогаВопрос.ДаНет);  
	Иначе
		Сообщить("Эта служебная записка уже была отправлена на согласование");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьНаСогласованиеЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Попытка
			Записать(Новый Структура("РежимЗаписи",РежимЗаписиДокумента.Проведение));
			ОтправитьНаСогласованиеНаСервере();
		Исключение
			Ошибка = ИнформацияОбОшибке();
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = КраткоеПредставлениеОшибки(Ошибка);
			Сообщение.Сообщить();
			ТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
		КонецПопытки;
		ЭтаФорма.Прочитать();
		УстановитьДоступность(Неопределено);
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьНаСогласованиеНаСервере()
	Документы.СлужебнаяЗаписка.ОтправитьНаСогласованиеСлужебнуюЗаписку(Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура ЗаСчетПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(Объект.ЗаСчет) Тогда   
		Элементы.ЗаСчет.ЦветРамки = Новый Цвет(255,0,0); 
	Иначе
		Элементы.ЗаСчет.ЦветРамки = Новый Цвет(160,160,160);
	КонецЕсли;
КонецПроцедуры



