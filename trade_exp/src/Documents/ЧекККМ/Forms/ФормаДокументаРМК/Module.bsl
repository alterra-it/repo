&НаКлиенте
Процедура НапечататьПакетНаПринтер(Знач Объект, ИмяПринтера=Неопределено)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		МассивОбъектов= Новый Массив;
		МассивОбъектов.Добавить(Объект.Ссылка);
		ТабличныеДокументы= Новый СписокЗначений;
		ПараметрКоманды= Новый Массив;
		ПараметрКоманды.Добавить(Объект.Ссылка);
		ПараметрыПечати= Новый Структура;
		ПараметрыПечати.Вставить("ИмяПринтера", ИмяПринтера);
		Если Объект.Проведен Тогда
			ТабличныйДокумент= АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(МассивОбъектов, "Печать чека", "ПечатьТоварногоЧека", ПараметрыПечати);
			ТабличныйДокумент.Напечатать();
			
			ТабличныйДокумент= СформироватьТНСекцию(МассивОбъектов);
			ТабличныйДокумент.Напечатать();
		Иначе
			Сообщить("Перед печатью необходимо провести документы!");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
&НаСервере
Функция СформироватьТНСекцию(МассивОбъектов)
	Обработка= Обработки.ПечатьТНСекции.Создать();
	ТабличныйДокумент= Обработка.СформироватьПечатнуюФормуПечатьТНСекции(МассивОбъектов);
	
	Возврат ТабличныйДокумент;
КонецФункции

