//	НачислитьБонусныеБаллы();// Альтерра ПроектЧеки
	конецесли;
	если ПараметрыПримененияСкидок.Свойство("НазначеныСкидки") тогда
		 ПараметрыПримененияСкидок.НазначеныСкидки=ложь;
