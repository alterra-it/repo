#Область СобытияФормы
&НаСервере
Процедура Док_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИспользоватьРучныеСкидкиВПродажах = Истина;//Альтерра Колдомаева В Чеках ручные скидки нужны @Бирюкова

	_ЯвляетсяКассиром = Документы.ЧекККМ.ЯвляетсяКассиром(); 
	
	если Параметры.свойство("Основание") И ЗначениеЗаполнено(Параметры.Основание) И ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Параметры.Основание, "КассаККМ") тогда
		если _ЯвляетсяКассиром и Параметры.Основание.КассаККМ <> Объект.КассаККМ тогда
			Объект.КассаККМ = Параметры.Основание.КассаККМ;  	
		конецесли;
	ИначеЕсли (Параметры.свойство("Основание") И ТипЗнч(Параметры.Основание) <> Тип("ДокументСсылка.АрендаНоменклатурыВозврат")) или НЕ ЗначениеЗаполнено(Объект.КассаККМ) Тогда
		Объект.КассаККМ = Документы.ЧекККМ.ИнициализироватьКассуККМ(_ЯвляетсяКассиром);
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаполнитьПоУмолчанию();
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(Объект.ДатаСоздания) тогда
		Объект.ДатаСоздания = Объект.Дата;
	КонецЕсли;
	Если  Объект.Статус = Перечисления.СтатусыЧековККМ.ОтложенСРезервированием 
		Или Объект.Статус = Перечисления.СтатусыЧековККМ.ОтложенБезРезервирования
	Тогда
		Объект.ДатаОткрытия = ТекущаяДатаСеанса();	
	КонецЕсли;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "_ДобавитьУслугуБезНДС", "Видимость", НЕ АльтерраОбщегоНазначения.ЕстьБлокировкаУслуги(ТекущаяДата()));
	
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоУмолчанию()
	
	ТекПользователь = Пользователи.ТекущийПользователь();
	Объект.Автор = ТекПользователь;
	Объект.Кассир = ТекПользователь;
	Объект.Менеджер = ТекПользователь;
	
	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда
		Объект.Склад = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.КассаККМ, "Склад");
	КонецЕсли;	
	Объект.Подразделение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Подразделение");
	Объект.Соглашение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Подразделение, "СоглашениеСКлиентомПоУмолчанию");

	УстановитьВидЦены();
	
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	Если _ЯвляетсяКассиром Тогда
		СтруктураПодключенногоОборудования = ПодключаемоеОборудованиеУТВызовСервера.ОборудованиеПодключенноеККассеПоОрганизации(ПараметрыКассыККМ.Организация);
		Если СтруктураПодключенногоОборудования.ККТ.Количество() = 0 Тогда	
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Подключаемое оборудование удалено или не используется. Обратитесь в техническую поддержку.");
			ЭтаФорма.Доступность = Ложь;  
		КонецЕсли;
	КонецЕсли;
	
	Если Параметры.свойство("Склад") тогда
		Если Не _ЯвляетсяКассиром тогда
			Объект.Склад = Параметры.Склад;
		КонецЕсли;	
	КонецЕсли;	
	
	Элементы.НовыйЧек.Видимость = _ЯвляетсяКассиром;
	Элементы.ВозвратТовара.Видимость =_ЯвляетсяКассиром; 
	Элементы._ЗаказнаДоставку.Видимость = Не _ЯвляетсяКассиром;
	Элементы._ПроверитьНакладные.Видимость = _ЯвляетсяКассиром;
	Элементы._ГруппаСостояниеСмены.Видимость = _ЯвляетсяКассиром; 
	Элементы.ГруппаНижняяКоманднаяПанель.Видимость = _ЯвляетсяКассиром; 
	Элементы._ГруппаНижняяПанельМенеджер.Видимость = Не _ЯвляетсяКассиром; 
	 
	КомандыПечати = ПолучитьИзВременногоХранилища(АдресКомандПечатиВоВременномХранилище);
	
	Для Каждого КомандаПечати Из КомандыПечати Цикл
		
		ИмяКнопки = "_"+КомандаПечати.ИмяКоманды;
		
		Если СтрНайти(ИмяКнопки, "КомандаДляВыводаВПустоеПодменю") > 0 Тогда
			Прервать;
		КонецЕсли;
		
		НоваяКоманда = ЭтаФорма.Команды.Добавить(ИмяКнопки);
		НоваяКоманда.Действие = "Подключаемый_ОбработатьКомандуПечати";
		НоваяКоманда.Заголовок = КомандаПечати.Заголовок;
		НоваяКоманда.Отображение = ОтображениеКнопки.Текст;
		
		НоваяКнопка = Элементы.Добавить(ИмяКнопки, Тип("КнопкаФормы"), Элементы._ПодменюПечать);
		НоваяКнопка.ИмяКоманды = НоваяКоманда.Имя;
		НоваяКнопка.Высота = 3;
		НоваяКнопка.Ширина = 12;		
	КонецЦикла;
	
	Если Объект.КОплатеБаллами <> 0  Тогда
		Объект.ОплатаБаллами = Истина;
		Элементы.ОплатитьКартой.Доступность = Ложь;
		Элементы.ОплатитьНаличными.Доступность = Ложь;
	КонецЕсли; 
	
   ПоказатьИнформациюПоБонусам();  
	
   НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Подразделение", "Объект.Подразделение",РежимИзмененияСвязанногоЗначения.Очищать);
   
   НовыйМассив = Новый Массив();
   НовыйМассив.Добавить(НоваяСвязь);
   
   НовыеСвязи = Новый ФиксированныйМассив(НовыйМассив);
   Элементы.Склад.СвязиПараметровВыбора = НовыеСвязи;
	
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытии(Отказ)   
	ИспользоватьРучныеСкидкиВПродажах = Истина;//Альтерра Колдомаева В Чеках ручные скидки нужны @Бирюкова
	
	РазрешениеЭкрана = ПолучитьИнформациюЭкрановКлиента();
	ВысотаЭкрана = РазрешениеЭкрана[0].Высота;
	ШиринаЭкрана = РазрешениеЭкрана[0].Ширина;
	Если (ВысотаЭкрана>0 И ВысотаЭкрана<900) Или (ШиринаЭкрана>0 И ШиринаЭкрана <1900) Тогда
		ПроцентПоВысоте = Окр(100*ВысотаЭкрана/900,0);   
		ПроцентПоШирине = Окр(100*ШиринаЭкрана/1900,0);
		Если ПроцентПоВысоте<ПроцентПоШирине Тогда
			ЭтаФорма.Масштаб = ПроцентПоВысоте - 2;	
		Иначе   
			ЭтаФорма.Масштаб = ПроцентПоШирине - 2;
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

