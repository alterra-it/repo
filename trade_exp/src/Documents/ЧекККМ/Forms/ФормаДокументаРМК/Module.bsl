    Объект.СпособВводаКлиента = СпособВводаКлиента;
	//158234
КонецПроцедуры 

&НаКлиенте
&ИзменениеИКонтроль("СчитатьКартуЛояльности")
Процедура Док_СчитатьКартуЛояльности1(Команда)

	Если ТолькоПросмотр Тогда // Чек пробит. Изменение информации запрещено.
		Возврат;
	КонецЕсли;

	РозничныеПродажиКлиент.ОчиститьОкноСообщений(ЭтотОбъект);

	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Организация", Объект.Организация);
	ПараметрыОткрытия.Вставить("НеИспользоватьРучнойВвод", Не ПраваДоступа.ИзменениеКартЛояльности);
	ПараметрыОткрытия.Вставить("НеПодключатьОборудование", Истина); 
	#Вставка
    ПараметрыОткрытия.Вставить("ТипЗапроса", 1); 
	#КонецВставки
	ОткрытьФорму(
	"Справочник.КартыЛояльности.Форма.СчитываниеКартыЛояльности",
	ПараметрыОткрытия,
	ЭтотОбъект,
	УникальныйИдентификатор);
	
КонецПроцедуры


&НаКлиенте
Процедура СобытиеСчитатьКартуЛояльности()
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтотОбъект);
	ОбновитьДанныеИнформационнойПанели(ЭтотОбъект, Истина = ТолькоПросмотр);
	
	//Объект.Подразделение= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Подразделение");
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) Тогда
		Объект.Партнер= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.КартаЛояльности, "Партнер");
		Объект.Соглашение= АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
	КонецЕсли;

	Док_СоглашениеПриИзмененииПосле(Неопределено);
	ОчиститьБонусыСервер();// Альтерра ПроектЧеки
	ПоказатьИнформациюПоБонусам();
	 //158234 запись в чек способ ввода клиента
    СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.КартаЛояльности");
    Объект.СпособВводаКлиента = СпособВводаКлиента;    
    //158234	
КонецПроцедуры

