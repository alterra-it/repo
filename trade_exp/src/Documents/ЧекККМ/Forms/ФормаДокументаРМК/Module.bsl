//Заполнение параметров отправки электронного чека по партнеру в РМК
Процедура ЗаполнитьПараметрыОтправкиЭлектронногоЧекаПоПартнеруВРМК() 
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ЗначениеЗаполнено(Объект.Партнер) Тогда
		
		ВариантОтправкиЭлектронногоЧека = Перечисления.ВариантыОтправкиЭлектронногоЧекаПокупателю.НеОтправлять;
		КонтактныеДанныеЭлектронногоЧека = "";
		
	Иначе
		
		ВариантОтправкиЭлектронногоЧека = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Партнер, "ВариантОтправкиЭлектронногоЧека");
		
		Если Не ЗначениеЗаполнено(ВариантОтправкиЭлектронногоЧека) Тогда
			ВариантОтправкиЭлектронногоЧека = Перечисления.ВариантыОтправкиЭлектронногоЧекаПокупателю.НеОтправлять;
		КонецЕсли;
		
		КонтактныеДанныеЭлектронногоЧека = "";
		
		Если ВариантОтправкиЭлектронногоЧека = Перечисления.ВариантыОтправкиЭлектронногоЧекаПокупателю.ОтправитьSMS Тогда
			
			НомерТелефонаКлиента = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(Объект.Партнер,Справочники.ВидыКонтактнойИнформации.ТелефонПартнера,,ТекущаяДатаСеанса(),Новый Структура("ТолькоПервая",Истина));
			
			КонтактныеДанныеЭлектронногоЧека = РозничныеПродажиКлиентСервер.НомерТелефонаВФормате10Знаков(НомерТелефонаКлиента);
			
		ИначеЕсли ВариантОтправкиЭлектронногоЧека = Перечисления.ВариантыОтправкиЭлектронногоЧекаПокупателю.ОтправитьEmail Тогда
			
			КонтактныеДанныеЭлектронногоЧека = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(Объект.Партнер,Справочники.ВидыКонтактнойИнформации.EmailПартнера,,ТекущаяДатаСеанса(),Новый Структура("ТолькоПервая",Истина));
			
		КонецЕсли;
		
	КонецЕсли;
	
	ДанныеФискальнойОперации.ВариантОтправкиЭлектронногоЧека  = ВариантОтправкиЭлектронногоЧека;
	ДанныеФискальнойОперации.КонтактныеДанныеЭлектронногоЧека = КонтактныеДанныеЭлектронногоЧека;
	
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры
