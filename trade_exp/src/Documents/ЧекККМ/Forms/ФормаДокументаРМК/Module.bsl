	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док__ПроверитьНакладные(Команда)
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
	ПараметрыФормы.Вставить("Признак", Ложь);
	ПараметрыФормы.Вставить("Штрихкод", Неопределено);
	
	ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаПроверкиПоСекциям", ПараметрыФормы, ЭтаФорма,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыПриИзмененииПосле(Элемент)
	Если Объект.Комментарий = "Создан из помощника продаж" Тогда
		Для каждого СтрокаТЧ из Объект.Товары Цикл
			Если Не ЗначениеЗаполнено(СтрокаТЧ.Склад) Тогда
				СтрокаТЧ.Склад = Объект.Склад;
			КонецЕсли;
			Если Не ЗначениеЗаполнено(СтрокаТЧ.ВидЦены) Тогда
				СтрокаТЧ.ВидЦены = Объект.ВидЦены;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	//ПоказатьИнформациюПоБонусам();
КонецПроцедуры

