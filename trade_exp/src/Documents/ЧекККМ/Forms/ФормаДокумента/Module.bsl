КонецПроцедуры

&НаСервере
Функция ПолучитьОтделМенеджера(Менеджер) 

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДополнительныеСведения.Значение.Наименование КАК Отдел
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО (ДополнительныеСведения.Объект = Пользователи.Ссылка)
		|ГДЕ
		|	Пользователи.Ссылка = &Ссылка
		|	И ДополнительныеСведения.Свойство.Наименование = ""Отделы (Пользователи)""";
	
	Запрос.УстановитьПараметр("Ссылка", Менеджер);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Отдел;
КонецФункции

&НаСервере
Функция ПолучитьПодразделениеМенеджера(Менеджер)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Пользователи.Подразделение КАК Подразделение
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.Ссылка = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Менеджер);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Подразделение;
КонецФункции

#Область Бригадиры
&НаКлиенте
Процедура Док_Соглашение1ОбработкаВыбораПосле(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	Если АльтерраОбщегоназначения.ЭтоБригадир(Объект.Партнер) Тогда
		Если БонусыАльтерра.НужноПодтверждениеВыбораСоглашения(ВыбранноеЗначение) Тогда
			ИдентификацияВыбораСоглашения(ЭтотОбъект, Объект.Партнер, ВыбранноеЗначение);
			СтандартнаяОбработка = ложь;
		КонецЕсли;
	КонецЕсли; 
КонецПроцедуры

&НаКлиенте
Процедура ИдентификацияВыбораСоглашения(Объект, Партнер, ВыбранноеЗначение) Экспорт 
	Оповещение = Новый ОписаниеОповещения("ОткрытьПараметрыЗавершение",Объект, ВыбранноеЗначение);   	
	ПараметрыФормы = Новый Структура("Владелец", Партнер);
	ОткрытьФорму("Справочник.БонусныеПрограммыЛояльности.Форма.Спр_СМСИдентификация", ПараметрыФормы, ЭтаФорма,,,,Оповещение,);
КонецПроцедуры 

&НаКлиенте
Процедура ОткрытьПараметрыЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	Если Результат = Истина тогда
		Объект.Соглашение = ДополнительныеПараметры;
		Док_Соглашение1ПриИзмененииПосле(Элементы.Соглашение);	
	Иначе
		Сообщить("Идентификация не пройдена. Выберите другое соглашение или повторите попытку.");
	конецесли;
КонецПроцедуры 
#КонецОбласти
