&НаКлиенте
Процедура Док_ТоварыПередУдалениемПосле(Элемент, Отказ)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	Если ТекущиеДанные <> неопределено Тогда                            
		УдаляемаяНоменклатура = ТекущиеДанные.номенклатура; 
		Если ЭтоУслугаРезки(УдаляемаяНоменклатура) ТОгда 
			Объект.Нарезка.Очистить();
		КонецЕсли;
	КонецЕсли;
	//-
КонецПроцедуры 

&НаСервере
Функция ЭтоУслугаРезки(номенклатура) 
	Если номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
		И Найти(Номенклатура.Наименование, "резк") > 0 Тогда 
		Возврат Истина; 
	Иначе
		Возврат Ложь; 
	КонецЕсли;
КонецФункции

 

