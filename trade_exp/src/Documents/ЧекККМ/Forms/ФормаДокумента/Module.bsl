&НаСервере
Процедура Док_ПриОткрытииПослеНаСервере()	
	Элементы.ДатаСоздания.ТолькоПросмотр=Истина;
	Элементы.ДатаОткрытия.ТолькоПросмотр=Истина;
	
   НоваяСвязь = Новый СвязьПараметраВыбора("Отбор.Подразделение", "Объект.Подразделение",РежимИзмененияСвязанногоЗначения.Очищать);
   НовыйМассив = Новый Массив();
   НовыйМассив.Добавить(НоваяСвязь);
   НовыеСвязи = Новый ФиксированныйМассив(НовыйМассив);
   Элементы.Склад.СвязиПараметровВыбора = НовыеСвязи;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	Док_ПриОткрытииПослеНаСервере(); 
	
	Если АльтерраОбщегоназначения.ЭтоБригадир(Объект.Партнер) Тогда
		Элементы.БонусныеБаллыСуммаБонусныхБалловЗаКП.Заголовок = "Доп. баллы";
		Элементы.ТоварыСуммаНачисленныхБалловЗаКП.Заголовок = "Доп. баллы";
	КонецЕсли;

КонецПроцедуры
