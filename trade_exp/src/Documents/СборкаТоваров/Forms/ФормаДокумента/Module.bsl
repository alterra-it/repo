&НаСервереБезКонтекста
Функция ЕстьОрдераПоДокументу(Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РасходныйОрдерНаТовары.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
	|ГДЕ
	|	РасходныйОрдерНаТовары.Накладная = &Накладная
	|	И РасходныйОрдерНаТовары.Проведен = ИСТИНА
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПриходныйОрдерНаТовары.Ссылка
	|ИЗ
	|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
	|ГДЕ
	|	ПриходныйОрдерНаТовары.Распоряжение = &Накладная
	|	И ПриходныйОрдерНаТовары.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("Накладная", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

&НаСервере
Функция ПроверитьИзменения()
	
	Если Объект.Ссылка.Склад <> Объект.Склад Или Объект.Ссылка.Номенклатура <> Объект.Номенклатура 
		Или Объект.Ссылка.КоличествоУпаковок <> Объект.КоличествоУпаковок Или Объект.Товары.Количество() <> Объект.Ссылка.Товары.Количество() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Индекс = 0;
	
	Для Каждого Стр Из Объект.Ссылка.Товары Цикл
		Если Стр.Номенклатура <> Объект.Товары[Индекс].Номенклатура Или Стр.КоличествоУпаковок <> Объект.Товары[Индекс].КоличествоУпаковок Тогда
			Возврат Истина;
		КонецЕсли;
		Индекс = Индекс + 1;
	КонецЦикла;
	
	Возврат Ложь;	
	
КонецФункции	

&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
	
	Если ЕстьОрдераПоДокументу(Объект.Ссылка) и ПроверитьИзменения()  Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса",ЭтотОбъект);	
		
		ПоказатьВопрос(Оповещение,"Если необходимо сохранить изменения в документе, нажмите 'Ок' и кнопку 'Оформить ордера', если нет, то нажмите 'Отмена'",РежимДиалогаВопрос.ОКОтмена,0,КодВозвратаДиалога.ОК);  
	КонецЕсли; 
	//--  
	Если ЗначениеЗаполнено(Объект.Патерностер) Тогда 
		Если ПолучитьСкладПатерностера() <> Объект.Склад Тогда
			Сообщить("Выбран патерностер с другого склада!!! Повторите выбор!");
			Объект.Патерностер = Неопределено;
			Отказ = Истина;
			Возврат;
		КонецЕсли;	
	КонецЕсли;
	Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПатерностер",ЭтотОбъект);
	Если ЗначениеЗаполнено(Объект.Патерностер) Тогда
		ЗанятостьПатерностера = ПроверитьЗанятостьПатерностера(); 
		Если ЗанятостьПатерностера.Свойство("Занятость") Тогда
			Если  ЗанятостьПатерностера.Занятость = 1  Тогда
				ПатерностерЗанят = Истина; 
			Иначе     
				ПатерностерЗанят = Ложь;
			КонецЕсли;	
			
			Если Не ПатерностерЗанят Тогда  
				ЗаписатьПатерностерВРегистр();			 
			ИначеЕсли Объект.Патерностер <> ЗанятостьПатерностера.Патерностер Или Объект.Номенклатура <> ЗанятостьПатерностера.Номенклатура Или Объект.Характеристика <> ЗанятостьПатерностера.Характеристика Тогда
				ПоказатьВопрос(Оповещение,",Данный вал уже занят, заменить значение 'Ок', если нет, то нажмите 'Отмена'",РежимДиалогаВопрос.ОКОтмена,0,КодВозвратаДиалога.ОК);
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли  ЗначениеЗаполнено(Объект.Характеристика) Тогда  
				
		Если ПроверитьНаличиеПатерностераВРегистре() Тогда
			ПоказатьВопрос(Оповещение,",Патерностер не выбран, очистить значение в регистре 'Ок', если нет, то нажмите 'Отмена'",РежимДиалогаВопрос.ОКОтмена,0,КодВозвратаДиалога.ОК);
		КонецЕсли;
	КонецЕсли;	
//-- 
КонецПроцедуры

&НаСервере
Функция ПроверитьНаличиеПатерностераВРегистре()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Патерностеры.Патерностер КАК Патерностер
	|ИЗ
	|	РегистрСведений.Патерностеры КАК Патерностеры
	|ГДЕ
	|	Патерностеры.Склад = &Склад
	|	И Патерностеры.Номенклатура = &Номенклатура
	|	И Патерностеры.Характеристика = &Характеристика
	|	И НЕ Патерностеры.Патерностер = ЗНАЧЕНИЕ(Справочник.Патерностеры.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("Номенклатура", Объект.Номенклатура);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Характеристика", Объект.Характеристика);
	
	РезультатЗапроса = Запрос.Выполнить(); 
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;	
КонецФункции

