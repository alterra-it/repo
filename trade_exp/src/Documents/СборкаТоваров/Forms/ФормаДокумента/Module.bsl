&НаСервере
Функция ПолучитьСписокХарактеристик(СтрНоменклатура)

Запрос = Новый Запрос;
Запрос.Текст = 
"ВЫБРАТЬ
|	ТоварыНаСкладахОстатки.Характеристика КАК Характеристика,
|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК ВНаличииОстаток
|ПОМЕСТИТЬ ВТ_Остатки
|ИЗ
|	РегистрНакопления.ТоварыНаСкладах.Остатки КАК ТоварыНаСкладахОстатки
|ГДЕ
|	ТоварыНаСкладахОстатки.Номенклатура = &Номенклатура
|	И ТоварыНаСкладахОстатки.Склад = &Склад
|	И ТоварыНаСкладахОстатки.ВНаличииОстаток > 0
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ
|	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика
|ИЗ
|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Остатки КАК ВТ_Остатки
|		ПО (ХарактеристикиНоменклатуры.Ссылка = ВТ_Остатки.Характеристика)
|ГДЕ
|	ХарактеристикиНоменклатуры.Владелец = &Номенклатура
|	И ВТ_Остатки.ВНаличииОстаток ЕСТЬ NULL";

Запрос.УстановитьПараметр("Номенклатура", СтрНоменклатура);
Запрос.УстановитьПараметр("Склад", Объект.Склад);

Список = Новый СписокЗначений;
Выборка = Запрос.Выполнить().Выбрать();

Пока Выборка.Следующий() Цикл
	Список.Добавить(Выборка.Характеристика)
КонецЦикла;

Возврат Список;

КонецФункции 
