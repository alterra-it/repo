&НаСервере
Процедура ПроверитьПатерностерВидимость() 
Если ЗначениеЗаполнено(Объект.Патерностер) И Объект.Ссылка.Проведен Тогда       
	Элементы.ПроверитьПатерностер.Видимость = Истина; 
Иначе
	Элементы.ПроверитьПатерностер.Видимость = Ложь;	
КонецЕсли;
КонецПроцедуры	    


&НаКлиенте
Процедура Док_ПатерностерПриИзмененииПосле(Элемент)  
ОчиститьСообщения();
Если ЗначениеЗаполнено(Объект.Патерностер) Тогда 
	Если ПолучитьСкладПатерностера() <> Объект.Склад Тогда
		Сообщить("Выбран патерностер с другого склада!!! Повторите выбор!");
		Объект.Патерностер = Неопределено;
		Возврат;
	КонецЕсли;	
КонецЕсли;	
Если ЗначениеЗаполнено(Объект.Патерностер) И Объект.Патерностер <> СтароеЗначениеПатерностера() Тогда 
	ЗанятостьПатерностера = ПроверитьЗанятостьПатерностера(); 
	Если ЗанятостьПатерностера.Свойство("Занятость") Тогда
		Если  ЗанятостьПатерностера.Занятость = 1  Тогда
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаЗанятыйПатерностер",ЭтотОбъект,ЗанятостьПатерностера.Характеристика);
			ПоказатьВопрос(Оповещение,СтрШаблон("На данном валу уже хранится - %1. Заменить на данном валу - 'Ок', для выбора свободного вала, нажмите - 'Отмена'. Свободные валы - %2",ЗанятостьПатерностера.Номенклатура,ЗанятостьПатерностера.СвободныеВалы),РежимДиалогаВопрос.ОКОтмена,0,КодВозвратаДиалога.ОК);
		КонецЕсли; 
	КонецЕсли;
КонецЕсли;
Если Не ЗначениеЗаполнено(Объект.Патерностер) Тогда
	ПроверитьПатерностерВидимость();
КонецЕсли;	
КонецПроцедуры    

&НаСервере
Функция СтароеЗначениеПатерностера()  
Возврат Объект.Ссылка.Патерностер;
КонецФункции	

&НаСервере
Функция ПроверитьЗанятостьПатерностера()    
Если НЕ Объект.Ссылка.Пустая() Тогда    
	ДатаДляЗапроса = Объект.Дата;
Иначе
	ДатаДляЗапроса = ТекущаяДата();
КонецЕсли;
Возврат РегистрыСведений.Патерностеры.ПроверитьЗанятостьПатерностера(Объект.Склад, Объект.Номенклатура, Объект.Характеристика, Объект.Патерностер, ДатаДляЗапроса);	
КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопросаЗанятыйПатерностер(Результат, Параметры) Экспорт

Если Результат = КодВозвратаДиалога.ОК Тогда 
	ЗаписатьПатерностерВРегистр();;   
ИначеЕсли Результат = КодВозвратаДиалога.Отмена Тогда   
	Объект.Патерностер = СтароеЗначениеПатерностера();
КонецЕсли;	

КонецПроцедуры   

&НаСервере
Функция ПолучитьСкладПатерностера()
Запрос = Новый Запрос;
Запрос.Текст = 
"ВЫБРАТЬ
|	Патерностеры.Склад КАК Склад
|ИЗ
|	Справочник.Патерностеры КАК Патерностеры
|ГДЕ
|	Патерностеры.Ссылка = &Ссылка";

Запрос.УстановитьПараметр("Ссылка", Объект.Патерностер);

РезультатЗапроса = Запрос.Выполнить();

Выборка = РезультатЗапроса.Выбрать();

Если Выборка.Следующий() Тогда
