#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	ДопМодуль.КонтрольОстатков(ЭтотОбъект,Отказ);
	
	//+Альтерра
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
        |	ТаблицаТовары.ОбъектРасходов КАК ОбъектРасходов,
        |	ТаблицаТовары.АналитикаОбъекта КАК АналитикаОбъекта,
        |	СУММА(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) КАК Сумма
        |ИЗ
        |	Документ.СборкаТоваров.Товары КАК ТаблицаТовары
        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
        |		ПО ТаблицаТовары.Ссылка = СебестоимостьТоваров.Регистратор
        |			И  ТаблицаТовары.Номенклатура = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура
        |ГДЕ
        |	ТаблицаТовары.Ссылка = &Ссылка
        |	И НЕ ТаблицаТовары.ОбъектРасходов = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
        |	И НЕ ТаблицаТовары.АналитикаОбъекта = ЗНАЧЕНИЕ(Справочник.АналитикаОбъекта.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
        |	ТаблицаТовары.ОбъектРасходов,
        |	ТаблицаТовары.АналитикаОбъекта";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Движение = Движения.РасходыПоОбъектам.Добавить();
		Движение.Период = Дата;
		Движение.Организация = Организация;
		Движение.Подразделение = Подразделение;
		Движение.ОбъектРасходов = ВыборкаДетальныеЗаписи.ОбъектРасходов;
		Движение.АналитикаОбъекта = ВыборкаДетальныеЗаписи.АналитикаОбъекта;
		Движение.Сумма = ВыборкаДетальныеЗаписи.Сумма;
	КонецЦикла;
	Движения.РасходыПоОбъектам.Записывать = Истина;
	//-
	
	РегистрыСведений.СостоянияОтгрузкиНакладных.ОбновитьСостояниеОтгрузкиНакладной(ЭтотОбъект,Склад);

КонецПроцедуры

//+Альтерра
&После("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Для каждого СтрокаТЧ из Товары Цикл  
		
		Если НЕ СтрокаТЧ.ОбъектРасходов.Пустая() и СтрокаТЧ.АналитикаОбъекта.Пустая() Тогда
			ИндексМассива = СтрокаТЧ.НомерСтроки-1;
			ОбщегоНазначения.СообщитьПользователю("Нельзя по строке реквизит ""Объект расходов"" заполнить, а ""Аналитика объекта"" нет. Исправьте или очистите значения этих реквизитов в строке",, 
				"Объект.Товары[" + ИндексМассива + "].АналитикаОбъекта");
			Отказ = Истина;
		ИначеЕсли СтрокаТЧ.ОбъектРасходов.Пустая() и НЕ СтрокаТЧ.АналитикаОбъекта.Пустая() Тогда
			ИндексМассива = СтрокаТЧ.НомерСтроки-1;
			ОбщегоНазначения.СообщитьПользователю("Нельзя по строке реквизит ""Аналитика объекта"" заполнить, а ""Объект расходов"" нет. Исправьте или очистите значения этих реквизитов в строке",, 
				"Объект.Товары[" + ИндексМассива + "].ОбъектРасходов");
			Отказ = Истина;
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры
//-

&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	
	УстановитьПривилегированныйРежим(Истина);
		
	Если ЭтотОбъект.ПометкаУдаления и Отказ = Ложь Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриходныйОрдерНаТовары.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПриходныйОрдерНаТовары КАК ПриходныйОрдерНаТовары
		|ГДЕ
		|	ПриходныйОрдерНаТовары.Распоряжение = &Распоряжение
		|   И ПриходныйОрдерНаТовары.ПометкаУдаления = Ложь
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РасходныйОрдерНаТовары.Ссылка
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
		|ГДЕ
		|	РасходныйОрдерНаТовары.Накладная = &Распоряжение
		|   И РасходныйОрдерНаТовары.ПометкаУдаления = Ложь";
		
		Запрос.УстановитьПараметр("Распоряжение", ЭтотОбъект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			ДокументОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ДокументОбъект.УстановитьПометкуУдаления(Истина);
			Сообщить("Удален: "+ДокументОбъект.Ссылка);
		КонецЦикла;
		
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&После("ПередУдалением")
Процедура Док_ПередУдалением(Отказ)
	ДопМодульСервер.ПроверитьНаличиеРасходногоОрдераНаТовары(Ссылка, Отказ);
КонецПроцедуры

&После("ОбработкаУдаленияПроведения")
Процедура Док_ОбработкаУдаленияПроведения(Отказ)
	
 РегистрыСведений.СостоянияОтгрузкиНакладных.УдалениеЗаписейВРегистре(ЭтотОбъект);
	
КонецПроцедуры

&Перед("ОбработкаПроведения")
Процедура Док_ОбработкаПроведенияПеред(Отказ, РежимПроведения)
	Если (Найти(Номенклатура, "м/прокат") > 0) И Не РольДоступна("Оператор1С") Тогда
		Если ПроверитьНарезкаВыводимогоТовара() Тогда
			Сообщить("Запрещено проводить сборку!");
			Отказ = Истина;
		КонецЕсли; 
	КонецЕсли;
КонецПроцедуры

Функция ПроверитьНарезкаВыводимогоТовара() 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СборкаТоваровТовары.Номенклатура КАК Номенклатура
		|ИЗ
		|	Документ.СборкаТоваров.Товары КАК СборкаТоваровТовары
		|ГДЕ
		|	СборкаТоваровТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	НоменклатураКомплектации = Выборка.Номенклатура;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс КАК Класс
		|ИЗ
		|	РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
		|ГДЕ
		|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура = &Номенклатура
		|	И ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Номенклатура", НоменклатураКомплектации);
	Запрос.УстановитьПараметр("Подразделение", Склад.Подразделение);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	КлассКомплектации = Выборка.Класс;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс КАК Класс
		|ИЗ
		|	РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
		|ГДЕ
		|	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура = &Номенклатура
		|	И ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Подразделение = &Подразделение";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Подразделение", Склад.Подразделение);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();

	Если Выборка.Класс = Перечисления.ABCКлассификация_Альтерра.ВыводимыйТовар 
		или КлассКомплектации = Перечисления.ABCКлассификация_Альтерра.ВыводимыйТовар Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

#КонецЕсли


