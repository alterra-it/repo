&НаКлиенте
Процедура СброситьПоСекции(Команда)
	
	МассивВыдСтрок = Элементы.Товары.ВыделенныеСтроки;
	Если МассивВыдСтрок.Количество() <> 0 тогда
		
		Для Каждого ТекСтрока Из МассивВыдСтрок Цикл
			СтрокаКоллекции = Объект.Товары.НайтиПоИдентификатору(ТекСтрока);
			СтрокаКоллекции.ТоварПринят = ЛОЖЬ;
			СтрокаКоллекции.Кладовщик = "";
		КонецЦикла;
	КонецЕсли;	

КонецПроцедуры

#Область ПересчетБонусов  

&НаКлиенте
Процедура Док_ТоварыКоличествоУпаковокПриИзмененииПосле(Элемент)
	
	ТекущиеДанные= Элементы.Товары.ТекущиеДанные;
	ТекущаяСтрока= Элементы.Товары.ТекущаяСтрока;
	
	ПересчитатьБонусыВСтрокеНаСервере(ТекущаяСтрока);
	РассчитатьИтоговыеПоказателиВозврата(ЭтаФорма);
	РассчитатьСуммуКомпенсации(ЭтаФорма); 
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьБонусыВСтрокеНаСервере(ТекущаяСтрока)
	
	СтрВозврата = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	СтрОснования = Неопределено;
	Если ТипЗнч(Объект.ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Основание = Объект.ДокументРеализации.Товары.Найти(стрВозврата.КодСтроки, "КодСтроки");
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.КоличествоУпаковок - ЕСТЬNULL(ВозвратТоваровОтКлиентаТовары.КоличествоУпаковок, 0) КАК КоличествоУпаковок,
		|	РеализацияТоваровУслугТовары.СуммаНачисленныхБонусныхБалловВВалюте - ЕСТЬNULL(ВозвратТоваровОтКлиентаТовары.СуммаНачисленныхБонусныхБалловВВалюте, 0) КАК СуммаНачисленныхБонусныхБалловВВалюте,
		|	РеализацияТоваровУслугТовары.СуммаБонусныхБалловКСписаниюВВалюте - ЕСТЬNULL(ВозвратТоваровОтКлиентаТовары.СуммаБонусныхБалловКСписаниюВВалюте, 0) КАК СуммаБонусныхБалловКСписаниюВВалюте,
		|	РеализацияТоваровУслугТовары.ПроцентАвтоматическойСкидки <> 0 КАК ЕстьСкидка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
		|		ПО РеализацияТоваровУслугТовары.Ссылка = ВозвратТоваровОтКлиентаТовары.Ссылка.ДокументРеализации
		|			И РеализацияТоваровУслугТовары.Номенклатура = ВозвратТоваровОтКлиентаТовары.Номенклатура
		|			И РеализацияТоваровУслугТовары.Характеристика = ВозвратТоваровОтКлиентаТовары.Характеристика
		|			И (ВозвратТоваровОтКлиентаТовары.Ссылка <> &Возврат)
		|			И (ВозвратТоваровОтКлиентаТовары.Ссылка.Проведен)
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И РеализацияТоваровУслугТовары.Номенклатура = &Номенклатура
		|	И РеализацияТоваровУслугТовары.Характеристика = &Характеристика";
		Запрос.УстановитьПараметр("Номенклатура", стрВозврата.Номенклатура);
		Запрос.УстановитьПараметр("Ссылка", Объект.ДокументРеализации);  
		Запрос.УстановитьПараметр("Возврат", Объект.Ссылка);
		Запрос.УстановитьПараметр("Характеристика", стрВозврата.Характеристика);
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			СтрОснования = ВыборкаДетальныеЗаписи;
		КонецЕсли;
	ИначеЕсли Объект.ЧекККМ<>Документы.ЧекККМ.ПустаяСсылка() Тогда
		Основание = Объект.ЧекККМ;
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЧекККМТовары.СуммаБонусныхБалловКСписаниюВВалюте КАК СуммаБонусныхБалловКСписаниюВВалюте,
		|	ЧекККМТовары.СуммаНачисленныхБонусныхБалловВВалюте КАК СуммаНачисленныхБонусныхБалловВВалюте,
		|	ЧекККМТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ЧекККМТовары.ПроцентАвтоматическойСкидки <> 0
		|		ИЛИ ЧекККМТовары.ПроцентРучнойСкидки <> 0 КАК ЕстьСкидка
		|ИЗ
		|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
		|ГДЕ
		|	ЧекККМТовары.Ссылка = &Ссылка
		|	И ЧекККМТовары.Номенклатура = &Номенклатура
		|	И ЧекККМТовары.Характеристика = &Характеристика";
		Запрос.УстановитьПараметр("Номенклатура",  стрВозврата.Номенклатура);
		Запрос.УстановитьПараметр("Ссылка", Основание);
		Запрос.УстановитьПараметр("Характеристика", стрВозврата.Характеристика);
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			СтрОснования = ВыборкаДетальныеЗаписи;
		КонецЕсли;
	КонецЕсли;
	
	Если стрОснования <> Неопределено Тогда
		Если стрОснования.СуммаБонусныхБалловКСписаниюВВалюте > 0 Тогда
			стрВозврата.Количество = Мин(стрВозврата.КоличествоУпаковок, стрОснования.КоличествоУпаковок);
			СтруктураДействий = Новый Структура;
			ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий, ЭтаФорма);

			стрВозврата.СуммаБонусныхБалловКСписаниюВВалюте= (стрОснования.СуммаБонусныхБалловКСписаниюВВалюте*стрВозврата.КоличествоУпаковок)/стрОснования.КоличествоУпаковок;
			стрВозврата.СуммаБонусныхБалловКСписанию= стрВозврата.СуммаБонусныхБалловКСписаниюВВалюте;
			стрВозврата.СуммаНачисленныхБонусныхБалловВВалюте= (стрОснования.СуммаНачисленныхБонусныхБалловВВалюте*стрВозврата.КоличествоУпаковок)/стрОснования.КоличествоУпаковок;
			
			Если Не СтрОснования.ЕстьСкидка Тогда
				БонусыАльтерра.ПересчитатьСуммыСУчетомБонусов(Объект, СтрВозврата);
			КонецЕсли;   
			
			ДокОбъект = РеквизитФормыВЗначение("Объект");
			БонусныеБаллыСервер.ЗаполнитьБонусныеБаллыВозвратТоваровОтКлиента(ДокОбъект); 
			ЗначениеВРеквизитФормы(ДокОбъект,"Объект");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область Зеленение 

&НаКлиенте
Процедура СКТоварыПередУдалением(Элемент, Отказ)
	
	Если ЗначениеЗаполнено(Элементы.товары.ТекущиеДанные.Кладовщик) тогда
		Предупреждение("Товар выдан со склада. Удаление строки запрещено!!!");
		Отказ = Истина;
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура СКТоварыПередНачаломИзменения(Элемент, Отказ)
	Если ЗначениеЗаполнено(Элементы.товары.ТекущиеДанные.Кладовщик) тогда
		Предупреждение("Товар выдан со склада. Удаление строки запрещено!!!");
		Отказ = Истина;
	КонецЕсли;	

КонецПроцедуры

&После("УстановитьУсловноеОформление")
Процедура Спр_УстановитьУсловноеОформление()
	
	АльтерраОбщегоНазначения.УстановитьОформлениеЗеленениеСтрокТабличныхЧастей(ЭтаФорма,"Товары");
	Элементы.УменьшенДолгСтрокой.Доступность=РольДоступна("ПолныеПрава") Или РольДоступна("ОтметкаКассы");

КонецПроцедуры

#КонецОбласти


#Область ВводНаОсновании    

&НаСервере
Процедура СоздатьНовыйДокумент(ИмяДокумента, НовыйОбъект)
	Документы[ИмяДокумента].ЗаполнитьДанныеПоОснованию(Объект.Ссылка, НовыйОбъект);
КонецПроцедуры

&НаКлиенте
Процедура Док__ВводНаОснованииПропуск(Команда)
	
	ИмяДокумента = "Пропуск";
	ФормаДок = ПолучитьФорму("Документ." +  ИмяДокумента + ".ФормаОбъекта");
	ДанныеФормы = ФормаДок.Объект;
	
	Если Объект.Ссылка.Пустая() Тогда
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Данные еще не записаны.
		|Выполнение действия ""%1"" возможно только после записи данных.'"),
		"Реализация товаров и услуг");
		
		ПоказатьПредупреждение( , ТекстВопроса);
		Возврат;	
	КонецЕсли;
	
	СоздатьНовыйДокумент(ИмяДокумента, ДанныеФормы);
	КопироватьДанныеФормы(ДанныеФормы, ФормаДок.Объект);
	ФормаДок.Открыть();	
	
КонецПроцедуры 

#КонецОбласти

&НаКлиенте
Процедура Док__ОплатаНаМестеПосле(Команда)
		
	ОткрытьФорму("Обработка.БезналичнаяОплатаБезПодключенияОборудования.Форма",Новый Структура("ДокументПродажи",Объект.Ссылка));

КонецПроцедуры

&НаСервере
Функция НоменклатурыХватает(ТЧВозврат)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВозвратТоваровОтКлиентаТовары.Ссылка КАК Ссылка,
		|	ВозвратТоваровОтКлиентаТовары.Номенклатура КАК Номенклатура,
		|	ВозвратТоваровОтКлиентаТовары.Характеристика КАК Характеристика,
		|	-1 * ВозвратТоваровОтКлиентаТовары.Количество КАК Количество,
		|	ВозвратТоваровОтКлиентаТовары.Назначение КАК Назначение
		|ПОМЕСТИТЬ ВТКоличествоПоДокументам
		|ИЗ
		|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
		|ГДЕ
		|	ВозвратТоваровОтКлиентаТовары.ДокументРеализации = &Ссылка
		|	И НЕ ВозвратТоваровОтКлиентаТовары.Ссылка.ПометкаУдаления
		|	И ВозвратТоваровОтКлиентаТовары.Ссылка.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КорректировкаРеализацииРасхождения.Ссылка,
		|	КорректировкаРеализацииРасхождения.Номенклатура,
		|	КорректировкаРеализацииРасхождения.Характеристика,
		|	КорректировкаРеализацииРасхождения.Количество,
		|	КорректировкаРеализацииРасхождения.Назначение
		|ИЗ
		|	Документ.КорректировкаРеализации.Расхождения КАК КорректировкаРеализацииРасхождения
		|ГДЕ
		|	КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование = &Ссылка
		|	И НЕ КорректировкаРеализацииРасхождения.Ссылка.ПометкаУдаления
		|	И КорректировкаРеализацииРасхождения.Ссылка.Проведен
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Ссылка,
		|	РеализацияТоваровУслугТовары.Номенклатура,
		|	РеализацияТоваровУслугТовары.Характеристика,
		|	РеализацияТоваровУслугТовары.Количество,
		|	РеализацияТоваровУслугТовары.Назначение
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка = &Ссылка
		|	И НЕ РеализацияТоваровУслугТовары.Ссылка.ПометкаУдаления
		|	И РеализацияТоваровУслугТовары.Ссылка.Проведен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТКоличествоПоДокументам.Номенклатура КАК Номенклатура,
		|	ВТКоличествоПоДокументам.Характеристика КАК Характеристика,
		|	ВТКоличествоПоДокументам.Назначение КАК Назначение,
		|	СУММА(ВТКоличествоПоДокументам.Количество) КАК Количество 
		|ПОМЕСТИТЬ ВТОстатки
		|ИЗ
		|	ВТКоличествоПоДокументам КАК ВТКоличествоПоДокументам
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТКоличествоПоДокументам.Номенклатура,
		|	ВТКоличествоПоДокументам.Характеристика,
		|	ВТКоличествоПоДокументам.Назначение
		|	;
		|///////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ 
		|	ТЗТЧВозврат.Номенклатура КАК Номенклатура,
		|	ТЗТЧВозврат.Характеристика КАК Характеристика,
		|	ТЗТЧВозврат.Назначение КАК Назначение,
		|	ТЗТЧВозврат.Количество КАК Количество
		|ПОМЕСТИТЬ ВТТЧВозврат
		|ИЗ
		|	&ТЗТЧВозврат КАК ТЗТЧВозврат
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТЧВозврат.Номенклатура КАК Номенклатура,
		|	ВТТЧВозврат.Характеристика КАК Характеристика,
		|	ВТТЧВозврат.Назначение КАК Назначение,
		|	(ВТОстатки.Количество-ВТТЧВозврат.Количество) КАК Количество
		|ИЗ
		|	ВТТЧВозврат КАК ВТТЧВозврат
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОстатки КАК ВТОстатки
		|			ПО (ВТТЧВозврат.Номенклатура = ВТОстатки.Номенклатура
		|				И ВТТЧВозврат.Характеристика = ВТОстатки.Характеристика
		|				И ВТТЧВозврат.Назначение = ВТОстатки.Назначение)
		|Где
		|	(ВТОстатки.Количество-ВТТЧВозврат.Количество) < 0";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка.ДокументРеализации);
	Запрос.УстановитьПараметр("ТЗТЧВозврат", ТЧВозврат);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Ложь; 
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции;


