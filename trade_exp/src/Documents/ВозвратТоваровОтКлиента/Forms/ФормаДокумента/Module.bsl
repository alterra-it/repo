&ИзменениеИКонтроль("УстановитьДоступностьСпособаКомпенсации")
&НаКлиентеНаСервереБезКонтекста
Процедура Док_УстановитьДоступностьСпособаКомпенсации(Форма)

	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Форма.Элементы,
		"СпособКомпенсации",
		"Доступность",
		Форма.СуммаКомпенсации <> 0
#Вставка
		И ПроверитьДоступностьРоли() 
#КонецВставки
		И Форма.Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратТоваровОтКлиента"));
		


КонецПроцедуры

&НаСервереБезКонтекста
Функция ПроверитьДоступностьРоли()
	Возврат РольДоступна("ПолныеПрава");
КонецФункции

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	// договор на форме	
	Элементы.ИспользуетсяДоговор.Доступность = Не значениезаполнено(Объект.ДокументРеализации);
	Элементы.Договор.Доступность = Объект.ИспользуетсяДоговор И Не значениезаполнено(Объект.ДокументРеализации);
	Элементы.Договор.Видимость = Объект.ИспользуетсяДоговор;
	// Доступность элементов
	Элементы.Партнер.Доступность = Не значениезаполнено(Объект.ДокументРеализации);
	Если Не значениезаполнено(Объект.ЧекККМ) Тогда
		Элементы.Контрагент.Доступность = Не значениезаполнено(Объект.ДокументРеализации);
	КонецЕсли;
	Элементы.Организация.Доступность = Не значениезаполнено(Объект.ДокументРеализации);
	Элементы.Соглашение.Доступность = Не значениезаполнено(Объект.ДокументРеализации);
	Элементы._ЗаполнитьШапкуПоДокументуПродажи.Видимость = Не значениезаполнено(Объект.ЧекККМ);
	
	Элементы.ИсключитьИзКонтроля.Доступность = РольДоступна("РазрешитьИсключатьДокументыИзКонтроляОрдерногоУчета");
	
	УстановитьДоступностьПоОтметкеКассы();
	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	
	Если Объект.Кассир.Пустая() Тогда // проверка отметки кассы
		Объект.ДатаПоследнегоОткрытия = ТекущаяДатаСеанса();
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура Док__ЗаполнитьШапкуПоДокументуПродажиПосле(Команда)
	
	Док_ЗаполнитьШапкуПоЗаказуНаСервере();

КонецПроцедуры 

&НаСервере
Процедура Док_ЗаполнитьШапкуПоЗаказуНаСервере()
	
	Если ЗначениеЗаполнено(Объект.ДокументРеализации) Тогда
		
		Отказ = Ложь;
		Если АльтерраОбщегоНазначения.ЕстьЗеленение(Объект) > 0 Тогда
			Сообщить("В документе есть зелененные строки!");
			Отказ = Истина;
		КонецЕсли;
		Если ЗначениеЗаполнено(Объект.Кассир) Тогда
			Сообщить("В документе стоит отметка кассы!");
			Отказ = Истина;
		КонецЕсли;
		
		Если Не Отказ Тогда
			Объект.Партнер = Объект.ДокументРеализации.Партнер;
			Объект.Контрагент = Объект.ДокументРеализации.Контрагент;
			Объект.Соглашение = Объект.ДокументРеализации.Соглашение;
			Объект.Договор = Объект.ДокументРеализации.Договор;
			Объект.Организация = Объект.ДокументРеализации.Организация;
			Объект.ИспользуетсяДоговор = Объект.ДокументРеализации.ИспользуетсяДоговор;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

