&После("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	МассивНепроверяемыхРеквизитов = Новый Массив;
	МассивНепроверяемыхРеквизитов.Добавить("Договор");
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты,МассивНепроверяемыхРеквизитов);
КонецПроцедуры

&Перед("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	
	Если ТипДанныхЗаполнения = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Если ЗначениеЗаполнено(ДанныеЗаполнения.ЗаказКлиента) И ТипЗнч(ДанныеЗаполнения.ЗаказКлиента) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			СпособВводаКлиента = ДанныеЗаполнения.СпособВводаКлиента;
			ТоварПодЗаказ = ДанныеЗаполнения.ЗаказКлиента.ТоварПодЗаказ;
			Если ТоварПодЗаказ Тогда
				Если Не рольДоступна("ПолныеПрава") И Не рольДоступна("ВозможностьВозвратаТовараПодЗаказ") Тогда
					ВызватьИсключение("В заказе, на основе которого создана реализация, присутствует товар под заказ! Обратитесь к Администратору торгового зала!");
					Возврат;
				Иначе
					Сообщить("В заказе, на основе которого создана реализация, присутствует товар под заказ!");
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Если ТипДанныхЗаполнения = Тип("ДокументСсылка.ЧекККМ") Тогда
		Если ДанныеЗаполнения.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания тогда
			Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор("0562ed9b-4ca4-11e1-8e7d-001e101f9843"));
			СпособВводаКлиента = ДанныеЗаполнения.СпособВводаКлиента;
		КонецЕсли;	
	КонецЕсли;
	
	Если Не ДанныеЗаполнения = Неопределено И Не БонусыАльтерраРезерв.ПолучитьЗначениеРеквизита(ДанныеЗаполнения, "Магазин") = Ложь Тогда
		Магазин = ДанныеЗаполнения.Магазин;
	КонецЕсли;
	
КонецПроцедуры

&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполненияПосле(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах")  Тогда
		Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Если ДанныеЗаполнения.ПорядокРасчетов = Перечисления.ПорядокРасчетов.ПоДоговорамКонтрагентов Тогда
				ПорядокРасчетов = ДанныеЗаполнения.ПорядокРасчетов;
			КонецЕсли;
			ИспользуетсяДоговор = ДанныеЗаполнения.ИспользуетсяДоговор;
		КонецЕсли;	
	КонецЕсли;

	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Соглашение= ДанныеЗаполнения.Соглашение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения) И Типзнч(ДанныеЗаполнения) <> Тип("Структура") Тогда
		Менеджер = ДанныеЗаполнения.Менеджер;
		Если Не БонусыАльтерраРезерв.ПолучитьЗначениеРеквизита(ДанныеЗаполнения, "ПодразделениеМенеджера") = Ложь 
				и Не БонусыАльтерраРезерв.ПолучитьЗначениеРеквизита(ДанныеЗаполнения, "ОтделМенеджера") = Ложь Тогда
			ПодразделениеМенеджера = ДанныеЗаполнения.ПодразделениеМенеджера;
			ОтделМенеджера = ДанныеЗаполнения.ОтделМенеджера;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПодразделениеМенеджера) и Не ЗначениеЗаполнено(ОтделМенеджера) Тогда
		ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Менеджер); 
		ОтделМенеджера = ПолучитьОтделМенеджера(Менеджер);
	КонецЕсли;
	
КонецПроцедуры

&После("ПриКопировании")
Процедура Док_ПриКопировании(ОбъектКопирования)
	
	Для Каждого ТекСтрока Из Товары Цикл
		ТекСтрока.Кладовщик = "";
	КонецЦикла; 
	
КонецПроцедуры

&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, ПараметрыЗаписи)	
	
	Если ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг") 
		И ЗначениеЗаполнено(ДокументРеализации.Кассир) = Ложь Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Запись документа без отметки кассы в документе продажи запрещена.";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
	
	//Проверить на новом релизе, убрать при необходимости
	Если ДокументРеализации = Неопределено Тогда
		ПроверитьИЗаполнитьСпособОпределенияСебестоимости();
	КонецЕсли;
	
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью1(Отказ, РежимЗаписи, РежимПроведения)
	
	Если Не Отказ И ЗначениеЗаполнено(Ссылка) И Не Проведен И ЗначениеЗаполнено(ДокументРеализации) И ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Попытка
			Если РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда	
				Если Не ПометкаУдаления Тогда                               // Записанный документ проводится
					НаличиеКорректировки = АльтерраОбщегоНазначения.ПолучитьКорректировкуНазначения(Ссылка, Ложь, Ложь);
					Если ЗначениеЗаполнено(НаличиеКорректировки) Тогда
						ДополнительныеСвойства.Вставить("НаличиеКорректировки", НаличиеКорректировки);
					КонецЕсли;
				КонецЕсли;
			Иначе
				Если Не Ссылка.ПометкаУдаления И ПометкаУдаления Тогда      // Пометка на удаление записанного документа
					Если Не РольДоступна("ПолныеПрава") Тогда
						АльтерраОбщегоНазначения.ПроверитьНаличиеПриходныхОрдеров(Ссылка, Ложь, Ложь, "Сначала необходимо пометить на удаление следуюшие документы:", Отказ);
			        КонецЕсли;
					
					Если Не Отказ Тогда
						НаличиеКорректировки = АльтерраОбщегоНазначения.ПолучитьКорректировкуНазначения(Ссылка, Ложь, Ложь);
						Если ЗначениеЗаполнено(НаличиеКорректировки) Тогда
							НаличиеКорректировки.ПолучитьОбъект().УстановитьПометкуУдаления(Истина);
						КонецЕсли;
					КонецЕсли;
				ИначеЕсли Ссылка.ПометкаУдаления И Не ПометкаУдаления Тогда // Пометка на удаление снимается
					НаличиеКорректировки = АльтерраОбщегоНазначения.ПолучитьКорректировкуНазначения(Ссылка, Ложь, Истина);
					Если ЗначениеЗаполнено(НаличиеКорректировки) Тогда
						НаличиеКорректировки.ПолучитьОбъект().УстановитьПометкуУдаления(Ложь);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
			ВызватьИсключение;
		КонецПопытки;	
	КонецЕсли; 		
КонецПроцедуры
	
&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	
	ТаблицаДвижений = БонусыАльтерраРезерв.ПолучитьТаблицуБонусныхБаловДляПроведенияВозврата(ЭтотОбъект, Отказ);
	
	Если ТаблицаДвижений.Количество() > 0 Тогда
		ДатаОтложенногоНачисления = НачалоДня(ДокументРеализации.Дата)+3600*24*3;
		Для каждого Стр Из ТаблицаДвижений Цикл
			Если Стр.ВидДвижения = ВидДвиженияНакопления.Расход И Стр.Период < ДатаОтложенногоНачисления Тогда
				Стр.Период = ДатаОтложенногоНачисления; //Контрзапись по дате начисления, чтобы баллы не уходили в минус
			КонецЕсли;
		КонецЦикла;
		Движения.БонусныеБаллы.Загрузить(ТаблицаДвижений);
		Движения.БонусныеБаллы.Записывать = Истина;
	КонецЕсли; 
	
    УстановитьПривилегированныйРежим(Истина);
	Если Не СкладыСервер.ИспользоватьОрдернуюСхемуПриПоступлении(Склад, Дата) Тогда 
		Заказ = Документы.ЗаказКлиента.ПустаяСсылка();
		
		Если ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Заказ = ДокументРеализации.ЗаказКлиента;
		КонецЕсли;
		
		Если Не Заказ = Неопределено Тогда
			Если Не Заказ.Пустая() Тогда
				
				Назначение = Документы.КорректировкаНазначенияТоваров.НазначениеЗаказа(Заказ);
			
				//Если Документы.КорректировкаНазначенияТоваров.ЕстьДоступныйРезервОстаток(Назначение, Заказ, Перечисления.ВидыОперацийКорректировкиНазначения.СнятьРезерв)  Тогда
				Если Документы.КорректировкаНазначенияТоваров.ЕстьТоварыКСнятиюРезерва(Назначение) Тогда
					Если ДополнительныеСвойства.Свойство("НаличиеКорректировки") Тогда
						Попытка
							ДополнительныеСвойства.НаличиеКорректировки.ПолучитьОбъект().Записать(РежимЗаписиДокумента.Проведение);
						Исключение
							ВызватьИсключение;
						КонецПопытки;
					Иначе
						КорректировкаНазначения = Документы.КорректировкаНазначенияТоваров.СоздатьДокумент();
						
						ОрганизацияЗаказа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Заказ, "Организация");
						
						КорректировкаНазначения.Организация = ОрганизацияЗаказа;
						КорректировкаНазначения.Назначение = Назначение;
						КорректировкаНазначения.ВидОперации = Перечисления.ВидыОперацийКорректировкиНазначения.СнятьРезерв;
						КорректировкаНазначения.Дата = ТекущаяДатаСеанса();
						КорректировкаНазначения.УстановитьНовыйНомер(); 
						КорректировкаНазначения.Автор = Справочники.Пользователи.НайтиПоНаименованию("Администратор"); 
						КорректировкаНазначения.Ответственный = ПараметрыСеанса.ТекущийПользователь;
						КорректировкаНазначения.Комментарий = "Создана автоматически при создании документа "" " + Ссылка + """";
						
						
						Для Каждого СтрокаТовара Из Товары Цикл
							Если СтрокаТовара.Назначение = Назначение Тогда
								СтрокаПродукция = КорректировкаНазначения.Товары.Добавить();
								ЗаполнитьЗначенияСвойств(СтрокаПродукция, СтрокаТовара);
							КонецЕсли;
						КонецЦикла;
						
						ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(КорректировкаНазначения, Документы.КорректировкаНазначенияТоваров));
						НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(КорректировкаНазначения, ПараметрыУказанияСерий);
						
						Документы.КорректировкаНазначенияТоваров.ЗаполнитьПоОснованию(Назначение,ОрганизацияЗаказа,КорректировкаНазначения.Ссылка, Перечисления.ВидыОперацийКорректировкиНазначения.СнятьРезерв, КорректировкаНазначения.Товары);
						
						Если КорректировкаНазначения.Товары.Количество()>0 Тогда
							КорректировкаНазначения.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе	
		Если ДополнительныеСвойства.Свойство("НаличиеКорректировки") Тогда
			Попытка
				ДополнительныеСвойства.НаличиеКорректировки.ПолучитьОбъект().Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ВызватьИсключение;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
   УстановитьПривилегированныйРежим(Ложь);
   
   Если ЭтотОбъект.Проведен Тогда
	   Если ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.ОтчетОРозничныхПродажах") ИЛИ ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.ЧекККМ") Тогда
		   Документы.ЗаявкаВЕГАИСЛес.ПроверкаЕГАИС(ЧекККМ, ЭтотОбъект);
	   ИначеЕсли ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
    		Документы.ЗаявкаВЕГАИСЛес.ПроверкаЕГАИС(ДокументРеализации, ЭтотОбъект); 
	   КонецЕсли;
   КонецЕсли;
 
КонецПроцедуры

Функция ЕстьТоварыКОбособленномуОбеспечению(Назначение,МассивНоменклатуры) 
	
	Если Не ЗначениеЗаполнено(Назначение) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОбеспечениеЗаказов.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.ОбеспечениеЗаказов КАК ОбеспечениеЗаказов
	|ГДЕ
	|	ОбеспечениеЗаказов.Назначение = &Назначение
	|	И ОбеспечениеЗаказов.Номенклатура В(&Номенклатура)";
	
	Запрос.УстановитьПараметр("Назначение", Назначение);
	Запрос.УстановитьПараметр("Номенклатура", МассивНоменклатуры);
	
	УстановитьПривилегированныйРежим(Истина);
	Возврат Не Запрос.Выполнить().Пустой();
	УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции

&Перед("ОбработкаУдаленияПроведения")
Процедура Док_ОбработкаУдаленияПроведения(Отказ)
	
	Если Не Отказ И ЗначениеЗаполнено(ДокументРеализации) И ТипЗнч(ДокументРеализации) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		Попытка
			Если Не РольДоступна("ПолныеПрава") Тогда
				Если ПометкаУдаления Тогда     // Пометка на удаление проведенного документа
					АльтерраОбщегоНазначения.ПроверитьНаличиеПриходныхОрдеров(Ссылка, Истина, Ложь, "Сначала необходимо пометить на удаление следуюшие документы:", Отказ);
				Иначе                          // Распроведение документа
					АльтерраОбщегоНазначения.ПроверитьНаличиеПриходныхОрдеров(Ссылка, Истина, Ложь, "Сначала необходимо снять с проведения следуюшие документы:", Отказ);
				КонецЕсли;
			КонецЕсли;
			
			Если Не Отказ Тогда
				НаличиеКорректировки = АльтерраОбщегоНазначения.ПолучитьКорректировкуНазначения(Ссылка, Истина, Ложь);
				Если ЗначениеЗаполнено(НаличиеКорректировки) Тогда
					Если ПометкаУдаления Тогда // Пометка на удаление проведенного документа
						НаличиеКорректировки.ПолучитьОбъект().УстановитьПометкуУдаления(Истина);
					Иначе                      // Распроведение документа
						НаличиеКорректировки.ПолучитьОбъект().Записать(РежимЗаписиДокумента.ОтменаПроведения);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		Исключение
			ВызватьИсключение; 
		КонецПопытки;
	КонецЕсли; 
	
КонецПроцедуры

&После("ОбработкаУдаленияПроведения")
Процедура Док_ОбработкаУдаленияПроведения1(Отказ)
	АльтерраОбщегоНазначения.КонтрольОтметкиКассы(ЭтотОбъект, Отказ);
КонецПроцедуры   

Процедура ПроверитьИЗаполнитьСпособОпределенияСебестоимости() 
	
	Для каждого Строка из Товары Цикл
		Если Строка.СпособОпределенияСебестоимости.Пустая() Тогда
			 Строка.СпособОпределенияСебестоимости = Перечисления.СпособыОпределенияСебестоимости.ИзТекущегоДокумента;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОтделМенеджера(Менеджер)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДополнительныеСведения.Значение.Наименование КАК Отдел
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО (ДополнительныеСведения.Объект = Пользователи.Ссылка)
		|ГДЕ
		|	Пользователи.Ссылка = &Ссылка
		|	И ДополнительныеСведения.Свойство.Наименование = ""Отделы (Пользователи)""";
	
	Запрос.УстановитьПараметр("Ссылка", Менеджер);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Отдел;
КонецФункции

&НаСервере
Функция ПолучитьПодразделениеМенеджера(Менеджер)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Пользователи.Подразделение КАК Подразделение
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.Ссылка = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Менеджер);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Подразделение;
КонецФункции

#КонецЕсли

&ИзменениеИКонтроль("ЗаполнитьДокументНаОснованииРеализацииТоваровИУслуг")
Процедура Док_ЗаполнитьДокументНаОснованииРеализацииТоваровИУслуг(Знач ДокументОснование, ПараметрыОформления)

	ВводитьНаОснованииНепроведенного = Ложь;
	Если Не ПараметрыОформления = Неопределено
		И ТипЗнч(ПараметрыОформления) = Тип("Структура") Тогда

		ПараметрыОформления.Свойство("ВводитьНаОснованииНепроведенного", ВводитьНаОснованииНепроведенного);
		ВводитьНаОснованииНепроведенного = ?(ВводитьНаОснованииНепроведенного = Неопределено,
		Ложь,
		ВводитьНаОснованииНепроведенного);

	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаТовары.ОбъектРасчетов КАК ОбъектРасчетов
	|ПОМЕСТИТЬ ОбъектыРасчетов
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаТовары
	|ГДЕ
	|	ТаблицаТовары.Ссылка = &ДокументОснование
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 1
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка КАК ДокументРеализации,
	|	РеализацияТоваровУслуг.Ссылка КАК Ссылка,
	|	РеализацияТоваровУслуг.Соглашение КАК Соглашение,
	|	РеализацияТоваровУслуг.Организация КАК Организация,
	|	РеализацияТоваровУслуг.Партнер КАК Партнер,
	|	РеализацияТоваровУслуг.Контрагент КАК Контрагент,
	|	РеализацияТоваровУслуг.КонтактноеЛицо КАК КонтактноеЛицо,
	|	РеализацияТоваровУслуг.Валюта КАК Валюта,
	|	РеализацияТоваровУслуг.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	РеализацияТоваровУслуг.Сделка КАК Сделка,
	|	РеализацияТоваровУслуг.Подразделение КАК Подразделение,
	|	РеализацияТоваровУслуг.Статус КАК СтатусДокумента,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.Склад.ЭтоГруппа
	|				И РеализацияТоваровУслуг.Склад.ВыборГруппы = ЗНАЧЕНИЕ(Перечисление.ВыборГруппыСкладов.РазрешитьВЗаказах)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)
	|		ИНАЧЕ РеализацияТоваровУслуг.Склад
	|	КОНЕЦ КАК Склад,
	|	РеализацияТоваровУслуг.ХозяйственнаяОперация КАК ХозяйственнаяОперацияРеализация,
	|	РеализацияТоваровУслуг.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	РеализацияТоваровУслуг.НалогообложениеНДС КАК НалогообложениеНДС,
	|	РеализацияТоваровУслуг.Договор КАК Договор,
	|	РеализацияТоваровУслуг.ВернутьМногооборотнуюТару КАК ВозвратПереданнойМногооборотнойТары,
	|	РеализацияТоваровУслуг.ТребуетсяЗалогЗаТару КАК ПредусмотренЗалогЗаТару,
	|	НЕ РеализацияТоваровУслуг.Проведен
	|		И НЕ &ВводитьНаОснованииНепроведенного КАК ЕстьОшибкиПроведен,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРеализацийТоваровУслуг.Отгружено)
	|				ИЛИ РеализацияТоваровУслуг.ХозяйственнаяОперация = ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияКлиентуРеглУчет)
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ИСТИНА
	|	КОНЕЦ КАК ЕстьОшибкиСтатус,
	|	РеализацияТоваровУслуг.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	РеализацияТоваровУслуг.ГруппаФинансовогоУчета КАК ГруппаФинансовогоУчета,
	|	РеализацияТоваровУслуг.ОплатаВВалюте КАК ОплатаВВалюте,
	|	РеализацияТоваровУслуг.КлиентКонтрагент КАК КлиентКонтрагент,
	|	РеализацияТоваровУслуг.КлиентПартнер КАК КлиентПартнер,
	|	РеализацияТоваровУслуг.КлиентДоговор КАК КлиентДоговор
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка = &ДокументОснование
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 2
	|ВЫБРАТЬ
	|	РасчетыСКлиентами.ОбъектРасчетов КАК ОбъектРасчетов,
	|	РасчетыСКлиентами.Валюта КАК ВалютаВзаиморасчетов,
	|	ЕСТЬNULL(РасчетыСКлиентами.СуммаОстаток, 0) КАК СуммаОстаток
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(
	|			,
	|			ОбъектРасчетов В
	|				(ВЫБРАТЬ
	|					ОбъектыРасчетов.ОбъектРасчетов
	|				ИЗ
	|					ОбъектыРасчетов)) КАК РасчетыСКлиентами
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 3
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	КорректировкаРеализации.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ДанныеПоследнейКорректировки
	|ИЗ
	|	Документ.КорректировкаРеализации КАК КорректировкаРеализации
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеестрДокументовСторноИсправление
	|		ПО КорректировкаРеализации.Ссылка = РеестрДокументовСторноИсправление.СторнируемыйДокумент
	|			И РеестрДокументовСторноИсправление.Проведен
	|			И НЕ РеестрДокументовСторноИсправление.ДополнительнаяЗапись
	|ГДЕ
	|	КорректировкаРеализации.Проведен
	|	И РеестрДокументовСторноИсправление.Ссылка ЕСТЬ NULL
	|	И КорректировкаРеализации.ДокументОснование = &ДокументОснование
	|	И НЕ КорректировкаРеализации.ВидКорректировки В (ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.РеализацияПерепоставленногоТовара),
	|													ЗНАЧЕНИЕ(Перечисление.ХозяйственныеОперации.ВозвратНедопоставленногоТовара))
	|
	|УПОРЯДОЧИТЬ ПО
	|	КорректировкаРеализации.МоментВремени УБЫВ
	|;
	|
	|//////////////////////////////////////////////////////////////////////////////// 4
	|ВЫБРАТЬ
	|	ЕСТЬNULL(АналитикаНаборов.КлючАналитики, ЗНАЧЕНИЕ(Справочник.КлючиАналитикиУчетаНаборов.ПустаяСсылка)) КАК АналитикаУчетаНаборов,
	|	ТаблицаТовары.НоменклатураНабора КАК НоменклатураНабора,
	|	ТаблицаТовары.ХарактеристикаНабора КАК ХарактеристикаНабора,
	|	АналитикаНоменклатуры.КлючАналитики КАК АналитикаУчетаНоменклатуры,
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	СправочникНоменклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ТаблицаТовары.Назначение КАК Назначение,
	|	ТаблицаТовары.Серия КАК Серия,
	|	ТаблицаТовары.Упаковка КАК Упаковка,
	|	ТаблицаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ТаблицаТовары.Количество КАК Количество,	
	|	ТаблицаТовары.Сумма КАК Сумма,
	|	ТаблицаТовары.СтавкаНДС КАК СтавкаНДС,
	|	ТаблицаТовары.СуммаНДС КАК СуммаНДС,
	|	ТаблицаТовары.СуммаСНДС КАК СуммаСНДС,
	|	ТаблицаТовары.Склад КАК Склад
	|ПОМЕСТИТЬ ТоварыДокументаПродажи
	|ИЗ
	|	Документ.КорректировкаРеализации.Товары КАК ТаблицаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ДанныеПоследнейКорректировки КАК ДанныеПоследнейКорректировки
	|		ПО ТаблицаТовары.Ссылка = ДанныеПоследнейКорректировки.Ссылка
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаНаборов КАК АналитикаНаборов
	|		ПО ТаблицаТовары.НоменклатураНабора = АналитикаНаборов.НоменклатураНабора
	|			И ТаблицаТовары.ХарактеристикаНабора = АналитикаНаборов.ХарактеристикаНабора
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.АналитикаУчетаНоменклатуры КАК АналитикаНоменклатуры
	|		ПО ТаблицаТовары.Номенклатура = АналитикаНоменклатуры.Номенклатура
	|			И ТаблицаТовары.Характеристика = АналитикаНоменклатуры.Характеристика
	|			И ТаблицаТовары.Назначение = АналитикаНоменклатуры.Назначение
	|			И ТаблицаТовары.Серия = АналитикаНоменклатуры.Серия
	|			И ТаблицаТовары.Склад = АналитикаНоменклатуры.МестоХранения
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ТаблицаТовары.Номенклатура = СправочникНоменклатура.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТаблицаТовары.АналитикаУчетаНаборов,
	|	ТаблицаТовары.НоменклатураНабора,
	|	ТаблицаТовары.ХарактеристикаНабора,
	|	ТаблицаТовары.АналитикаУчетаНоменклатуры,
	|	ТаблицаТовары.Номенклатура,
	|	СправочникНоменклатура.ТипНоменклатуры,
	|	ТаблицаТовары.Характеристика,
	|	ТаблицаТовары.Назначение,
	|	ТаблицаТовары.Серия,
	|	ТаблицаТовары.Упаковка,
	|	ТаблицаТовары.КоличествоУпаковок,
	|	ТаблицаТовары.Количество,
	#Удаление
	|	ТаблицаТовары.Сумма,
	#КонецУдаления
	#Вставка
	|	ТаблицаТовары.Сумма+ ТаблицаТовары.СуммаРТ,
	#КонецВставки
	|	ТаблицаТовары.СтавкаНДС,
	#Удаление
	|	ТаблицаТовары.СуммаНДС,
	|	ТаблицаТовары.СуммаСНДС,
	#КонецУдаления
	#Вставка
	|	ТаблицаТовары.СуммаНДС + ТаблицаТовары.СуммаНДСРТ,            
	|	ТаблицаТовары.СуммаСНДС + ТаблицаТовары.СуммаСНДСРТ,
	#КонецВставки
	|	ТаблицаТовары.Склад
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК ТаблицаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеПоследнейКорректировки КАК ДанныеПоследнейКорректировки
	|		ПО ИСТИНА
	|		
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РеестрДокументов КАК РеестрДокументовСторноИсправление
	|		ПО ТаблицаТовары.Ссылка = РеестрДокументовСторноИсправление.СторнируемыйДокумент
	|			И РеестрДокументовСторноИсправление.Проведен
	|			И НЕ РеестрДокументовСторноИсправление.ДополнительнаяЗапись
	|		
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО ТаблицаТовары.Номенклатура = СправочникНоменклатура.Ссылка
	|
