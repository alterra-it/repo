&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если Объект.Автор.Пустая() Тогда
		ЗаполнитьАвтораНаСервере();
	КонецЕсли;	
	ПолучитьВариантыОценокНаСервере();
	ЗаполнитьГруппыКомпетенций();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьАвтораНаСервере()
	Объект.Автор = Пользователи.ТекущийПользователь();
КонецПроцедуры

&НаСервере
Процедура ПолучитьВариантыОценокНаСервере()
	Запрос = Новый Запрос;
	Запрос.Текст =
	 "ВЫБРАТЬ
	 |	КомпетенцииСотрудников.Код КАК Код,
	 |	ЕСТЬNULL(ВариантыОценокКомпетенцииОценки.Наименование, """") КАК Наименование,
	 |	ЕСТЬNULL(ВариантыОценокКомпетенцииОценки.Балл, 0) КАК Балл
	 |ИЗ
	 |	Справочник.КомпетенцииСотрудников КАК КомпетенцииСотрудников
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВариантыОценокКомпетенции КАК ВариантыОценокКомпетенции
	 |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВариантыОценокКомпетенции.Оценки КАК ВариантыОценокКомпетенцииОценки
	 |			ПО ВариантыОценокКомпетенции.Ссылка = ВариантыОценокКомпетенцииОценки.Ссылка
	 |		ПО КомпетенцииСотрудников.ВариантОценки = ВариантыОценокКомпетенции.Ссылка
	 |ГДЕ
	 |	НЕ КомпетенцииСотрудников.ЭтоГруппа
	 |	И НЕ ВариантыОценокКомпетенции.ПометкаУдаления";
	
	ВариантыОценок.Загрузить(Запрос.Выполнить().Выгрузить());
КонецПроцедуры

&НаКлиенте
Процедура СотрудникПриИзменении(Элемент)
	Если НЕ Объект.ШаблонОцениванияСотрудника.Пустая()Тогда
		ЗаполнитьКомпетенции();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ШаблонОцениванияСотрудникаПриИзменении(Элемент)
	Если НЕ Объект.ШаблонОцениванияСотрудника.Пустая()Тогда
		ЗаполнитьКомпетенции();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьКомпетенции()	
	Если Объект.ОценкиКомпетенций.Количество() > 0 Тогда
		Режим = РежимДиалогаВопрос.ДаНет;
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект, );
		ПоказатьВопрос(Оповещение, "Данные табличной части будут очищены. Продолжить?", Режим, 0);
	Иначе
		ЗаполнитьКомпетенцииНаСервере();
		ЗаполнитьГруппыКомпетенций();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
        ЗаполнитьКомпетенцииНаСервере();
		ЗаполнитьГруппыКомпетенций();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКомпетенцииНаСервере()
	Объект.ОценкиКомпетенций.Загрузить(Объект.ШаблонОцениванияСотрудника.Компетенции.Выгрузить());	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьГруппыКомпетенций()
	Если Объект.ОценкиКомпетенций.Количество() = 0 Тогда Возврат КонецЕсли;
	НачНомер = Объект.ОценкиКомпетенций[0].ПолучитьИдентификатор();
	Для НомерСтроки = НачНомер По НачНомер + Объект.ОценкиКомпетенций.Количество() - 1 Цикл
		Элементы.ОценкиКомпетенций.ТекущаяСтрока = НомерСтроки;
		Компетенция = Элементы.ОценкиКомпетенций.ТекущиеДанные.Компетенция;
		Элементы.ОценкиКомпетенций.ТекущиеДанные.ГруппаКомпетенций = ПолучитьГруппуКомпетенции(Компетенция);
	КонецЦикла;
	Элементы.ОценкиКомпетенций.ТекущаяСтрока = НачНомер;
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьКодКомпетенции(Компетенция)
    Возврат Компетенция.Код;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьГруппуКомпетенции(Компетенция)
    Возврат Компетенция.Родитель;
КонецФункции

&НаКлиенте
Процедура ОценкиКомпетенцийПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	Компетенция = Элемент.ТекущиеДанные.Компетенция;	                                
	Если Элемент.ТекущийЭлемент.Имя = "ОценкиКомпетенцийЗначение" Тогда
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Код", ПолучитьКодКомпетенции(Компетенция));
		Строки = ВариантыОценок.НайтиСтроки(ПараметрыОтбора);
		Список = Новый СписокЗначений();
		Для Каждого Строка Из Строки Цикл
			Если Строка.Наименование <> "" Тогда
				Список.Добавить(Строка.Наименование);
			КонецЕсли;
		КонецЦикла;
	    Если Список.Количество() > 0 Тогда
			Оповещение = Новый ОписаниеОповещения("ВыполнитьПослеВыбора", ЭтотОбъект, );
			ПоказатьВыборИзСписка(Оповещение, Список, Элемент.ТекущийЭлемент);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьПослеВыбора(Результат, Параметры) Экспорт
	Если Результат <> Неопределено Тогда
		Элементы.ОценкиКомпетенций.ТекущиеДанные.Значение = Результат.Значение;
	КонецЕсли;
	НомерСтроки = Элементы.ОценкиКомпетенций.ТекущаяСтрока;
	Если НомерСтроки + 1 = Объект.ОценкиКомпетенций.Количество() Тогда
		Элементы.ОценкиКомпетенций.ТекущаяСтрока = НомерСтроки - 1;
	Иначе
		Элементы.ОценкиКомпетенций.ТекущаяСтрока = НомерСтроки + 1;
	КонецЕсли;
КонецПроцедуры
