#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область ОбработчикиСобытий
	
&После("ПриКопировании")
Процедура Док_ПриКопировании(ОбъектКопирования)
	ПодтвержденСкладом = Ложь;
	ПодтвержденОтделомКачества = Ложь;
КонецПроцедуры

&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью1(Отказ, РежимЗаписи, РежимПроведения)
	Документы.ПересчетТоваров.ИнициализироватьНовыйРасчетОтклонения(ЭтотОбъект);
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если НЕ Ссылка.ПодтвержденСкладом И ЭтотОбъект.ПодтвержденСкладом Тогда
		ЭтотОбъект.ДатаПодтвержденияСкладом = ТекущаяДата();
	ИначеЕсли Ссылка.ПодтвержденСкладом И НЕ ЭтотОбъект.ПодтвержденСкладом Тогда 
		 ЭтотОбъект.ДатаПодтвержденияСкладом = Дата(1,1,1);
	КонецЕсли;
	
	Если НЕ Ссылка.ПодтвержденОтделомКачества И ЭтотОбъект.ПодтвержденОтделомКачества Тогда
		ЭтотОбъект.ДатаПодтвержденияОтделомКачества = ТекущаяДата();
	ИначеЕсли Ссылка.ПодтвержденОтделомКачества И НЕ ЭтотОбъект.ПодтвержденОтделомКачества Тогда 
		ЭтотОбъект.ДатаПодтвержденияОтделомКачества = Дата(1,1,1);
	КонецЕсли;    
	 
	УчетСкрыт = СкрытьКоличествоУчета();	

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Блокировки

&НаСервере
Процедура СоздатьБлокировку(ПричинаБлокировки) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	БылаПометкаУдаления = Ложь;
	ДокБлокировка = Документы.БлокировкаДвиженияТоваров.НайтиПоРеквизиту("ДокументОснование", ЭтотОбъект.Ссылка);
	Если ДокБлокировка = Документы.БлокировкаДвиженияТоваров.ПустаяСсылка() Тогда
		ДокументБлокировки = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
	Иначе
		ДокументБлокировки = ДокБлокировка.ПолучитьОбъект();
		БылаПометкаУдаления = ДокБлокировка.ПометкаУдаления;
		ДокументБлокировки.УстановитьПометкуУдаления(Ложь);
		Если Не БылаПометкаУдаления Тогда // если была пометка, то отмену сделала предыдущая строка
			ДокументБлокировки.Записать(РежимЗаписиДокумента.ОтменаПроведения); // чтобы товары, которые уже были заблокированы при пересчете отклонений отобразились как незаблокированные, чтоб их тоже можно было заблокировать
		КонецЕсли;
	КонецЕсли;
	
	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("Дата", ТекущаяДата());
	ПараметрыЗаполнения.Вставить("Склад", ЭтотОбъект.Склад);
	ПараметрыЗаполнения.Вставить("ДокументОснование", ЭтотОбъект.Ссылка);
	ПараметрыЗаполнения.Вставить("Статус", Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано);
	ПараметрыЗаполнения.Вставить("ПричинаБлокировки", Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию(ПричинаБлокировки));
	ПараметрыЗаполнения.Вставить("Комментарий", "Создан на минусовые отклонения");
	ТоварыВПараметры = ПолучитьТЗТовары(ЭтотОбъект.Товары.Выгрузить());
	Если ТоварыВПараметры.Количество() < 1 Тогда
		Сообщить("Блокировку создавать не на что. Возможно блокируемые товары уже заблокированы");
		// возвращаем исходное состояние документа блокировки, если он был
		Если ДокБлокировка <> Документы.БлокировкаДвиженияТоваров.ПустаяСсылка() Тогда
			ДокументБлокировки.Записать(РежимЗаписиДокумента.Проведение);
			ДокументБлокировки.УстановитьПометкуУдаления(БылаПометкаУдаления);
		КонецЕсли;
	Иначе
		ПараметрыЗаполнения.Вставить("Товары", ТоварыВПараметры);
		Альтерра_СкладСервер.СоздатьИзменитьБлокировкуДвиженияТоваров(ДокументБлокировки, ПараметрыЗаполнения, Истина);	
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьТЗТовары(тзТовары)
	
	ТЗ = тзТовары.СкопироватьКолонки();
	
	Для Каждого стр Из тзТовары Цикл
		Отклонение = Документы.ПересчетТоваров.НовыйРасчетОтклонения(стр, ЭтотОбъект.НовыйРасчетОтклонения); 
		Если Отклонение < 0 Тогда // Сделано, чтоб если оно и так положительное, то не было лишнего запроса
			УжеЗаблокированныхНаСкладе = ПолучитьНетНаСкладе(ЭтотОбъект.Дата, ЭтотОбъект.Склад, стр.Номенклатура);
			// Отклонение минусовое. И нужно, чтоб не блокировались те, которые уже заблокированы
			Отклонение = Отклонение + УжеЗаблокированныхНаСкладе;
		КонецЕсли;
		// Если Отклонение после учета заблокированных все равно минусовое, то блокируем
        Если Отклонение < 0 Тогда
            Остатки = Альтерра_СкладСервер.ПолучитьОстатки(стр.Номенклатура, стр.Характеристика, ЭтотОбъект.Склад, Истина);
			Отклонение = -Отклонение;
			Если Остатки > 0 Тогда
	            Если Остатки < Отклонение Тогда
	               стр.Количество = Остатки;
	               стр.КоличествоУпаковок = Остатки;
	            Иначе
	               стр.Количество = Отклонение;
	               стр.КоличествоУпаковок = Отклонение;
	            КонецЕсли;
	            ЗаполнитьЗначенияСвойств(ТЗ.Добавить(), стр);
			КонецЕсли
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТЗ;
	
КонецФункции

&НаСервере
Функция ПолучитьНетНаСкладе(ДатаОстатков, Склад, Номенклатура)
		
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	БлокировкаОстатки.ПричинаБлокировки КАК ПричинаБлокировки,
	|	БлокировкаОстатки.КоличествоОстаток КАК КоличествоОстаток
	|ИЗ
	|	РегистрНакопления.БлокировкаДвиженияТоваров.Остатки(КОНЕЦПЕРИОДА(&ДатаОстатков, ДЕНЬ), Склад = &Склад И ПричинаБлокировки В (&СписокПричин)) КАК БлокировкаОстатки
	|ГДЕ
	|	БлокировкаОстатки.Номенклатура = &Номенклатура";
	Запрос.УстановитьПараметр("ДатаОстатков", ДатаОстатков);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	// Причины блокировки, по которым уже нет товара на складе
   	СписокПричин = Новый Массив;
    //СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Брак"));
	//СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Брак от покупателей"));
	//СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Товар в паллетах, поддоны под товаром"));
	//СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Возврат поставщику"));
	//СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Для благотворительности"));
	//СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Сроки годности"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Пересортица"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Нет на складе"));
	//СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Брак на складе"));
    Запрос.УстановитьПараметр("СписокПричин", СписокПричин);
	Результат = Запрос.Выполнить().Выбрать();
	Количество = 0;
	Пока Результат.Следующий() Цикл
		Количество = Количество + Результат.КоличествоОстаток;
	КонецЦикла;
	
	Возврат Количество;
	
КонецФункции

&НаСервере
Функция ПолучитьБлокировкиПоТоварам(ВсеТовары = Истина, Товар = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	
	Если ВсеТовары Тогда
		ЗапросВыбораТоваров = " 
			|ВЫБРАТЬ
			|	Товары.Номенклатура,
			|	Товары.Характеристика
			|ПОМЕСТИТЬ
			|	втПересчетТоваров
			|ИЗ
			|	&Товары КАК Товары
			|;";
		Запрос.УстановитьПараметр("Товары", Товары.Выгрузить());
		Запрос.УстановитьПараметр("Склад", Склад);
		Запрос.УстановитьПараметр("ДатаОстатков", ТекущаяДата());
			
	Иначе
		ЗапросВыбораТоваров = " 
			|ВЫБРАТЬ
			|	&Номенклатура КАК Номенклатура, 
			|	&Характеристика КАК Характеристика
			|ПОМЕСТИТЬ
			|	втПересчетТоваров
			|;";	
			
		Запрос.УстановитьПараметр("Номенклатура", Товар.Номенклатура);
		Запрос.УстановитьПараметр("Характеристика", Товар.Характеристика);
		Запрос.УстановитьПараметр("Склад", Товар.Склад);
		Запрос.УстановитьПараметр("ДатаОстатков", Товар.Дата);
	КонецЕсли;
		
	Запрос.Текст = ЗапросВыбораТоваров + Символы.ПС + " 
		|ВЫБРАТЬ
		|	ПересчетТоваров.Номенклатура КАК Номенклатура,
		|	ПересчетТоваров.Характеристика КАК Характеристика,
		|	БлокировкаОстатки.Склад КАК Склад,
		|	БлокировкаОстатки.ПричинаБлокировки КАК ПричинаБлокировки,
		|	БлокировкаОстатки.КоличествоОстаток КАК КоличествоОстаток
		|ИЗ
		|	втПересчетТоваров КАК ПересчетТоваров
		|	СОЕДИНЕНИЕ
		|		РегистрНакопления.БлокировкаДвиженияТоваров.Остатки(КОНЕЦПЕРИОДА(&ДатаОстатков, ДЕНЬ), Склад = &Склад
		|			И ПричинаБлокировки В (&СписокПричин)) КАК БлокировкаОстатки
		|	ПО ПересчетТоваров.Номенклатура = БлокировкаОстатки.Номенклатура
		|	И ПересчетТоваров.Характеристика = БлокировкаОстатки.Характеристика
		|УПОРЯДОЧИТЬ ПО
		|	ПересчетТоваров.Номенклатура,
		|	ПересчетТоваров.Характеристика,
		|	БлокировкаОстатки.ПричинаБлокировки
		|ИТОГИ ПО
		|	ПересчетТоваров.Номенклатура,
		|	ПересчетТоваров.Характеристика";
	
   	СписокПричин = Новый Массив;
    СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Брак"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Брак от покупателей"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Товар в паллетах, поддоны под товаром"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Возврат поставщику"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Для благотворительности"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Сроки годности"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Пересортица"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Нет на складе"));
	СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Брак на складе"));
    //+Альтерра 
    СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Расхождения при перемещении (брак, излишки)"));
    СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Расхождения при поступлении (брак, излишки)"));
    СписокПричин.Добавить(Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Расхождения при поступлении (нет кода маркировки)"));
    //+
    Запрос.УстановитьПараметр("СписокПричин", СписокПричин);
	
	Результат = Запрос.Выполнить();
	
	ТаблицаЗначенийБлокировок = Новый ТаблицаЗначений; 
	ТаблицаЗначенийБлокировок.Колонки.Добавить("Номенклатура");
	ТаблицаЗначенийБлокировок.Колонки.Добавить("Характеристика");
	ТаблицаЗначенийБлокировок.Колонки.Добавить("Блокировка");
	
	ВыборкаНоменклатура = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаНоменклатура.Следующий() Цикл
		
		ВыборкаХарактеристика = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаХарактеристика.Следующий() Цикл
			
			ВыборкаДетальная = ВыборкаХарактеристика.Выбрать();
			
			БлокировкиТоваров = "";
			Пока ВыборкаДетальная.Следующий() Цикл
				
				Если БлокировкиТоваров <> "" Тогда
					БлокировкиТоваров = БлокировкиТоваров + ", " ;
				КонецЕсли;
				
				БлокировкиТоваров = БлокировкиТоваров + ВыборкаДетальная.ПричинаБлокировки + " - " +Строка(ВыборкаДетальная.КоличествоОстаток);
			КонецЦикла;
			
			СтрокаТаблицы = ТаблицаЗначенийБлокировок.Добавить();
			СтрокаТаблицы.Номенклатура = ВыборкаНоменклатура.Номенклатура;
			СтрокаТаблицы.Характеристика = ВыборкаХарактеристика.Характеристика;
			СтрокаТаблицы.Блокировка = БлокировкиТоваров;
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТаблицаЗначенийБлокировок;
	
КонецФункции      

#КонецОбласти  

#Область ПересчетКоличества
 
&НаСервере
Функция ПересчитатьПоУчетуВДокументе(ТЗТовары, ТолькоДляНулевогоФакта = Истина) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст =  	
		"ВЫБРАТЬ
		|	Товары.НомерСтроки КАК НомерСтроки,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Количество КАК Количество,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Товары.КоличествоФакт КАК КоличествоФакт,
		|	Товары.КоличествоУпаковокФакт КАК КоличествоУпаковокФакт,
		|	Товары.СпособВводаКоличестваТовара КАК СпособВводаКоличестваТовара,
		|	Товары.Отсканирован КАК Отсканирован
		|ПОМЕСТИТЬ ВР_Табл
		|ИЗ
		|	&Товары КАК Товары
		|ГДЕ
		|	&КоличествоФакт
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
		|	ТоварыНаСкладахОстатки.Характеристика КАК Характеристика,
		|	ТоварыНаСкладахОстатки.Назначение КАК Назначение,
		|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК Количество,
		|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК КоличествоУпаковок,
		|	ВЫБОР
		|		КОГДА &НовыйРасчетОтклонения
		|			ТОГДА ЕСТЬNULL(ЯПХОстатки.КоличествоОстаток, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ЯПХ,
		|	ВЫБОР
		|		КОГДА &НовыйРасчетОтклонения
		|			ТОГДА ТоварыНаСкладахОстатки.ВНаличииОстаток - ЕСТЬNULL(ЯПХОстатки.КоличествоОстаток, 0)
