				Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВРаботе") Тогда
					Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Приостановлено")
				КонецЕсли;
			КонецЕсли;
			
			Попытка
				ОбщегоНазначенияУТКлиент.ПровестиИЗакрыть(ЭтаФорма)
			Исключение
			КонецПопытки;
		Иначе
			Попытка
				ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма);
			Исключение
			КонецПопытки;
			ЗаполнитьДополнительныеПоля();
			ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
			ЗаполнитьПризнакРасхождение();
			УстановитьОформлениеФормыДокумента();
		КонецЕсли;
	Иначе
		Сообщить("Необходимо заполнить тип пересчета");
	КонецЕсли
КонецПроцедуры

