#Область ОписаниеПеременных

&НаКлиенте
Перем КэшированныеЗначения; //используется механизмом обработки изменения реквизитов ТЧ

&НаКлиенте
Перем ТекущиеДанныеИдентификатор; //используется для передачи текущей строки в обработчик ожидания

&НаКлиенте
Перем ВыполняетсяЗапись; //используется для передачи текущей строки в обработчик ожидания

#КонецОбласти

#Область ОбработчикиСобытийФормы
                            
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;

	ТолькоРасхождения = Истина;
	ФильтрПоЯчейке = ПредопределенноеЗначение("Справочник.СкладскиеЯчейки.ПустаяСсылка");
	УстановитьПривилегированныйРежим(Истина);
	ВремяСохраненияДокументов=Константы.ВремяСохраненияДокументов.Получить();
	УстановитьПривилегированныйРежим(Ложь);

	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	
	// Обработчик механизма "ВерсионированиеОбъектов"
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	
	ЗаполнитьДополнительныеПоля();

	СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
	ИспользоватьСтатусыПересчетовТоваров = Ложь;
	
	Если Параметры.Свойство("Склад") Тогда
		Объект.Склад = Параметры.Склад;
		ИспользоватьСтатусыПересчетовТоваров = СкладыСервер.ИспользоватьСтатусыПересчетовТоваров(Объект.Склад );
	КонецЕсли;
	
	Если Параметры.Свойство("Сотрудник") Тогда
		ИсполнительСотрудник = Параметры.Сотрудник;
		Исполнитель = Пользователи.ТекущийПользователь();
		Для каждого СтрокаТЧ из ИсполнительСотрудник.РабочиеУчастки Цикл
			СекцииСотрудника.Добавить(СтрокаТЧ.РабочийУчасток);
		КонецЦикла;
	ИначеЕсли Параметры.Свойство("ТекущийСотрудникТСД") Тогда
		ИсполнительСотрудник = Параметры.ТекущийСотрудникТСД;
		Исполнитель = Пользователи.ТекущийПользователь();
		Для каждого СтрокаТЧ из ИсполнительСотрудник.РабочиеУчастки Цикл
			СекцииСотрудника.Добавить(СтрокаТЧ.РабочийУчасток);
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Дата = ТекущаяДата(); 
		Если ИспользоватьСтатусыПересчетовТоваров Тогда
			Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Подготовлено; 
		КонецЕсли;
		Объект.Ответственный = ИсполнительСотрудник.Пользователь;
		Объект.Исполнитель = Исполнитель;
	КонецЕсли;  
	
	ПредыдущаяДата = Объект.Дата;	
	
	Если СекцииСотрудника.Количество() > 0 Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДоступныеЯчейки, "РабочийУчасток", СекцииСотрудника.ВыгрузитьЗначения(), ВидСравненияКомпоновкиДанных.ВСписке,,Истина);	
	КонецЕсли;

	ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач = 
		СкладыСервер.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач(Объект.Склад, Объект.Дата) ИЛИ
		Объект.Склад.ИспользоватьСтатусыПересчетовТоваров; 
		
	ПриЧтенииСозданииНаСервере();
	
	ОграничениеДоступностиОстатков = АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков();
	
	УстановитьОтборСекцииПоСотруднику();
	ПроверитьДоступныеРоли();
	
	Элементы.ТоварыКоличествоПоУчетуВЗонеХранения.Видимость = Объект.НовыйРасчетОтклонения;
	Элементы.ТоварыКоличествоУпаковок.Видимость = Не Объект.НовыйРасчетОтклонения;  
    //	
	УстановитьВидимостьКоличеств();  
	Элементы.РедактированиеСтрокиНаТСД.Видимость = Ложь;    
	ЗадаватьВопросПриДобавленииТовара();  
	
	//Подключение оповещений из очереди 
	СообщениеОбработано = Истина;
	Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
		Если Не ПолучитьСостояниеОповещений() Тогда
			ОповещенияИзОчереди = Истина;
		Иначе
			ОповещенияИзОчереди = ИсполнительСотрудник.ОповещенияИзОчереди; 
		КонецЕсли;
	Иначе 
		ОповещенияИзОчереди = Ложь; 	
	КонецЕсли; 
	Инт = 60;
	Для каждого Стр Из СекцииСотрудника Цикл
		ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
		Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
			Инт = ЗнчИнтервала;
		КонецЕсли; 
	КонецЦикла; 
	ИнтервалОповещений = Инт;
	
	//новый расчет откл
	ИнициализироватьНовыйРасчетОтклонения(); 
	
	ЗаполнитьПризнакРасхождение();
	УстановитьУсловноеОформлениеТаблицы();  
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)

	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	ПриЧтенииСозданииНаСервере();

	МодификацияКонфигурацииПереопределяемый.ПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
		И Не Объект.УчетныеДанныеЗаполнены 
		И Объект.Товары.Количество() > 0
		И Не Отказ
		И НЕ ВыполняетсяЗапись Тогда
		
		ТекстВопроса = НСтр("ru='При проведении будет перезаполнено учетное количество во всех строках табличной части. Продолжить?'");
		
		ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗаписьюЗавершение", ЭтотОбъект), 
			ТекстВопроса,
			РежимДиалогаВопрос.ОКОтмена,
			,
			КодВозвратаДиалога.ОК);
		Отказ = Истина;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписьюЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса <> КодВозвратаДиалога.ОК Тогда
		Возврат;
	КонецЕсли;
	
	ВыполняетсяЗапись = Истина;
	Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	ВыполняетсяЗапись = Ложь;

КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)

	ТекущийОбъект.ОтборПересчета = Новый ХранилищеЗначения(ОтборПересчета.Настройки, Новый СжатиеДанных(9));


	МодификацияКонфигурацииПереопределяемый.ПередЗаписьюНаСервере(ЭтаФорма, Отказ, ТекущийОбъект, ПараметрыЗаписи);

	// ИнтеграцияС1СДокументооборотом  такой процедуры больше нет
	//ИнтеграцияС1СДокументооборот.ПередЗаписьюНаСервере(ЭтаФорма, ТекущийОбъект, ПараметрыЗаписи);
	// Конец ИнтеграцияС1СДокументооборотом
	
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
		
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	ЗаполнитьПризнакРасхождение();

	МодификацияКонфигурацииПереопределяемый.ПослеЗаписиНаСервере(ЭтаФорма, ТекущийОбъект, ПараметрыЗаписи);
	
КонецПроцедуры
                              
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	
	ИнициализироватьСканер();
	
	УстановитьОформлениеФормыДокумента();
	
	Если ВремяСохраненияДокументов > 0 Тогда
		ПодключитьОбработчикОжидания("ОбработатьОжидание", ВремяСохраненияДокументов, Ложь);
	КонецЕсли;
	
	УстановитьПоказываемыеТовары();
	УстановитьНазванияИВидимостьКнопок(); 
	
	Если ОповещенияИзОчереди Тогда 
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);
		ПроверкаЭлектроннойОчереди(); 
	Иначе 
		Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПризнакРасхождение()
	Документы.ПересчетТоваров.НовыйРасчетОтклонения_Табл(Объект.Товары, Объект.НовыйРасчетОтклонения);	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтаФорма);
	
	ОтключитьСканер();
	
	Если ВремяСохраненияДокументов > 0 Тогда
		ОтключитьОбработчикОжидания("ОбработатьОжидание");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		//+Альтерра
		Если (ИмяСобытия = "ScanData" ИЛИ ИмяСобытия = "Barcode") И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;

			Если ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.НовыйШтрихкод Тогда
				НовыйШтрихкод = "";
				Если ТипЗнч(Параметр) = Тип("Строка") Тогда
					НовыйШтрихкод = Параметр;
				КонецЕсли;
			ИначеЕсли Элементы.РедактированиеСтрокиНаТСД.Видимость=Ложь И Элементы.ВыборЯчейки.Видимость = Истина Тогда
				ОбработатьШтрихкод(ШтрихКод1[0]);
			Иначе
			    ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Штрихкод1));
			КонецЕсли;
			
			//+Альтерра
			ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
			Если ТекущиеДанные <> Неопределено Тогда
				Если Не ЗначениеЗаполнено(ТекущиеДанные.СпособВводаКоличестваТовара) Тогда
					ТекущиеДанные.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Сканер");
				КонецЕсли;	
				ТекущиеДанные.Отсканирован = Истина;
			КонецЕсли;
		//-

			
		КонецЕсли;
		//-
	КонецЕсли;
	// Конец ПодключаемоеОборудование
	
	// Неизвестные штрихкоды
	Если Источник = "ПодключаемоеОборудование"
		И ИмяСобытия = "НеизвестныеШтрихкоды"
		И Параметр.ФормаВладелец = УникальныйИдентификатор Тогда
		
		КэшированныеЗначения.Штрихкоды.Очистить();
		ДанныеШтрихкодов = Новый Массив;
		
		Для Каждого ПолученныйШтрихкод Из Параметр.ПолученыНовыеШтрихкоды Цикл
			ДанныеШтрихкодов.Добавить(ПолученныйШтрихкод);
		КонецЦикла;
		
		Для Каждого ПолученныйШтрихкод Из Параметр.ЗарегистрированныеШтрихкоды Цикл
			ДанныеШтрихкодов.Добавить(ПолученныйШтрихкод);
		КонецЦикла;
		
		ОбработатьШтрихкоды(ДанныеШтрихкодов);
		
		//+Альтерра
		ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			Если Не ЗначениеЗаполнено(ТекущиеДанные.СпособВводаКоличестваТовара) Тогда
				ТекущиеДанные.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Сканер");
			КонецЕсли;	
			ТекущиеДанные.Отсканирован = Истина;
		КонецЕсли;
		//-

		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(РезультатВыбора, ИсточникВыбора)
	
	Если НоменклатураКлиент.ЭтоУказаниеСерий(ИсточникВыбора) Тогда
		НоменклатураКлиент.ОбработатьУказаниеСерии(ЭтаФорма, ПараметрыУказанияСерий, РезультатВыбора);
		Если Не Элементы.Товары.ТекущиеДанные.ИзлишекПорча Тогда
			Объект.УчетныеДанныеЗаполнены = Ложь;
		КонецЕсли;
	ИначеЕсли ИсточникВыбора.ИмяФормы = "Справочник.Назначения.Форма.ФормаВыбора" Тогда	
		Элементы.Товары.ТекущиеДанные.Назначение = РезультатВыбора;	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	МодификацияКонфигурацииКлиентПереопределяемый.ПослеЗаписи(ЭтаФорма, ПараметрыЗаписи);
	УстановитьНазванияИВидимостьКнопок();
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	// СтандартныеПодсистемы.Свойства
	//УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы
&НаКлиенте
Процедура ФактПриИзменении(Элемент)
	ИзменитьКоличествоВСтрокеПоИдентификатору(ТекущаяСтрокаТСД,"КоличествоУпаковокФакт",Количество);
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
		
	ТекущаяСтрока.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Клавиатура");	

    СтруктураДействий = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействий);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения); 
		
	НовыйРасчетОтклонения_СтрТабл_Клиент(ТекущаяСтрока);
КонецПроцедуры

&НаКлиенте
Процедура КомментарийСтрокиПриИзменении(Элемент)
	ИзменитьКоличествоВСтрокеПоИдентификатору(ТекущаяСтрокаТСД, "Комментарий", КомментарийСтроки);
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
