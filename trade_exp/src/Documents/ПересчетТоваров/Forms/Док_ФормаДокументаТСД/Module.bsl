Процедура СоздатьШК(Штрихкод)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШтрихкодыНоменклатуры.Штрихкод,
	|	ШтрихкодыНоменклатуры.Номенклатура,
	|	ШтрихкодыНоменклатуры.Характеристика,
	|	ШтрихкодыНоменклатуры.Упаковка,
	|	ШтрихкодыНоменклатуры.Номенклатура.Наименование КАК НоменклатураПредставление,
	|	ШтрихкодыНоменклатуры.Характеристика.Наименование КАК ХарактеристикаПредставление,
	|	ШтрихкодыНоменклатуры.Упаковка.Наименование КАК УпаковкаПредставление
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод
	|";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ОписаниеОшибки = НСтр("ru='Такой штрихкод уже назначен для номенклатуры %Номенклатура%'");
		ОписаниеОшибки = СтрЗаменить(ОписаниеОшибки, "%Номенклатура%", """" + Выборка.НоменклатураПредставление + """"
		+ ?(ЗначениеЗаполнено(Выборка.Характеристика), " " + НСтр("ru='с характеристикой'") + " """ + Выборка.ХарактеристикаПредставление + """", "")
		+ ?(ЗначениеЗаполнено(Выборка.Упаковка), " " + НСтр("ru='в упаковке'") + " """ + Выборка.УпаковкаПредставление + """", ""));
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = ОписаниеОшибки;
		Сообщение.Сообщить();
		
	Иначе
		МенеджерЗаписи = РегистрыСведений.ШтрихкодыНоменклатуры.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Штрихкод = Штрихкод;
		МенеджерЗаписи.Номенклатура = Номенклатура;
		МенеджерЗаписи.Характеристика = Характеристика;

		МенеджерЗаписи.Записать();
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Штрихкод записан!";
		Сообщение.Сообщить();
	КонецЕсли;

КонецПроцедуры

Функция ИзменитьЯчейку()
	
	Записано = Ложь;
	
	Попытка
		НачатьТранзакцию();
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
		НаборЗаписей.Отбор.Склад.Установить(Объект.Склад);
		НаборЗаписей.Отбор.Ячейка.Установить(Ячейка);
		НаборЗаписей.Записать();
		
		МенеджерЗаписи = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Склад = Объект.Склад;
		МенеджерЗаписи.Ячейка = НоваяЯчейка;
		МенеджерЗаписи.Номенклатура = Номенклатура;
		МенеджерЗаписи.ОсновнаяЯчейка=Истина;
		
		МенеджерЗаписи.Записать();
		
		Записано = Истина;
		УстановитьПривилегированныйРежим(Ложь);
		ЗафиксироватьТранзакцию();
	Исключение
		Сообщить("Ошибка записи!");
		Записано = Ложь;
		ОтменитьТранзакцию();
	КонецПопытки;
	
	Возврат Записано;	
	
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформлениеТаблицы() Экспорт
	
		ОформитьТаблицуВЗависимостиОтОтклонения(ВидСравненияКомпоновкиДанных.Меньше, WebЦвета.Голубой, "Объект.Товары.КоличествоУпаковокОтклонение");
		ОформитьТаблицуВЗависимостиОтОтклонения(ВидСравненияКомпоновкиДанных.Больше, WebЦвета.СветлоРозовый,"Объект.Товары.КоличествоУпаковокОтклонение"); 
		ОформитьТаблицуВЗависимостиОтОтклонения(ВидСравненияКомпоновкиДанных.равно, WebЦвета.Желтый,"Объект.Товары.КоличествоУпаковокФакт");
  	
КонецПроцедуры
	
&НаСервере
Процедура ОформитьТаблицуВЗависимостиОтОтклонения(ВидСравнения, Цвет,Поле)
		
	    ЭлементОформления = УсловноеОформление.Элементы.Добавить();
		ГруппаЭлементовОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаЭлементовОтбора.Использование = Истина;
				
		ЭлементОтбора = ГруппаЭлементовОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных(Поле);  
		ЭлементОтбора.ВидСравнения   = ВидСравнения;  
		ЭлементОтбора.ПравоеЗначение = 0;  
		ЭлементОтбора.Использование  = Истина;   
		
		ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", Цвет);
		ЭлементОформления.Использование = Истина;
		ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
		ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("Товары");	
		ПолеОформления.Использование = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьДоступныеРоли() 
	
	УстановитьПривилегированныйРежим(Истина);
		
    РабочийПользователь = ИсполнительСотрудник.Пользователь;
	ПользовательИБ = ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(РабочийПользователь.ИдентификаторПользователяИБ);
	
	Если Не (ПользовательИБ = Неопределено) Тогда
		РольПолныеПрава = ПользовательИБ.Роли.Содержит(Метаданные.Роли.ПолныеПрава);
		РольПодтверждениеОтделомКачества = ПользовательИБ.Роли.Содержит(Метаданные.Роли.ПодтверждениеОтделомКачества);
		РуководительСкладскогоКомплекса = ПользовательИБ.Роли.Содержит(Метаданные.Роли.РуководительСкладскогоКомплекса);
	КонецЕсли;
	
	
	
	Если ОграничениеДоступностиОстатков Тогда
		СкрытьКоличествоУчетаВПересчетах = Объект.РабочийУчасток.СкрытьКоличествоПоУчету;
	Иначе
		СкрытьКоличествоУчетаВПересчетах = Объект.Склад.СкрытьКоличествоУчетаВПересчетах;
	КонецЕсли;
		
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьКоличеств(); 
	
 УстановитьПривилегированныйРежим(Истина);
			
	Если ОграничениеДоступностиОстатков Тогда
		СкрытьКоличествоУчетаВПересчетах = Объект.РабочийУчасток.СкрытьКоличествоПоУчету;
	Иначе
		СкрытьКоличествоУчетаВПересчетах = Объект.Склад.СкрытьКоличествоУчетаВПересчетах;
    КонецЕсли;
		
УстановитьПривилегированныйРежим(Ложь);

	Если СкрытьКоличествоУчетаВПересчетах  				
		И Не (РольПолныеПрава 
			Или РольПодтверждениеОтделомКачества
			Или РуководительСкладскогоКомплекса) Тогда
			    Элементы.ТоварыКоличествоПоУчетуВЗонеХранения.Видимость = Ложь;
				Элементы.ТоварыКоличествоУпаковок.Видимость = Ложь;
				Элементы.ГруппаПоУчету.Видимость = Ложь;
				Элементы.ТоварыКоличествоУпаковокФакт.Ширина = 11;
	КонецЕсли;
КонецПроцедуры    

&НаСервере
Процедура УстановитьОтборСекцииПоСотруднику()
	МассивРабочихУчастков = Новый Массив();
  	Для Индекс = 0 По СекцииСотрудника.Количество() - 1 Цикл
		МассивРабочихУчастков.Добавить(СекцииСотрудника[Индекс].Значение);
	КонецЦикла;
	МассивПараметровВыбора = Новый Массив();	    
	ПараметрВыбора = Новый ПараметрВыбора("Отбор.Ссылка", Новый ФиксированныйМассив(МассивРабочихУчастков));		
	МассивПараметровВыбора.Добавить(ПараметрВыбора);
	ПараметрВыбора = Новый ПараметрВыбора("Отбор.ПометкаУдаления", Ложь);   
	МассивПараметровВыбора.Добавить(ПараметрВыбора);
	Элементы.РабочийУчасток.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
КонецПроцедуры

&НаСервере
Функция ЗаполнитьБлокировкиПоТоварам(ВсеТовары = Истина, Товар = Неопределено);
	
	Результат = "";
	ДокументОбъект = РеквизитФормыВЗначение("Объект"); 
	
	Если ВсеТовары Тогда
		ТаблицаЗначенийБлокировок = ДокументОбъект.ПолучитьБлокировкиПоТоварам();
		
		Для Каждого СтрокаБлокировки Из ТаблицаЗначенийБлокировок Цикл
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Номенклатура", СтрокаБлокировки.Номенклатура);
			СтруктураПоиска.Вставить("Характеристика", СтрокаБлокировки.Характеристика);
			
			НайденныеТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска);
			
			Для Каждого СтрокаТоваров Из НайденныеТовары Цикл
				СтрокаТоваров.БлокировкаТоваров = СтрокаБлокировки.Блокировка;
			КонецЦикла;
		КонецЦикла;
	Иначе
		ТаблицаЗначенийБлокировок = ДокументОбъект.ПолучитьБлокировкиПоТоварам(Ложь, Товар);	
		Если ТаблицаЗначенийБлокировок.Количество() > 0 Тогда
			Результат = ТаблицаЗначенийБлокировок[0].Блокировка;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
КонецФункции  

Функция ПолучитьЯчейку(НоменклатураСсылка, СкладСсылка)
	
	Если ЗначениеЗаполнено(НоменклатураСсылка) И ЗначениеЗаполнено(СкладСсылка) Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
			|ИЗ
			|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
			|ГДЕ
			|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = &Номенклатура
			|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
			|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА";
		
		Запрос.УстановитьПараметр("Номенклатура", НоменклатураСсылка);
		Запрос.УстановитьПараметр("Склад", СкладСсылка);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		Если РезультатЗапроса.Следующий() И ЗначениеЗаполнено(РезультатЗапроса.Ячейка) Тогда  
			Возврат РезультатЗапроса.Ячейка;
		КонецЕсли;
	КонецЕсли;
                                             
    Возврат Справочники.СкладскиеЯчейки.ПустаяСсылка();                          
	
КонецФункции

&НаКлиенте
Процедура Док_ИзменитьЯчейку(Команда)
	
	Элементы.РедактированиеСтрокиНаТСД.Видимость=Ложь;
	Элементы.ВыборЯчейки.Видимость = Истина;

КонецПроцедуры

&НаКлиенте
Процедура Док_ДоступныеЯчейкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Элементы.РедактированиеСтрокиНаТСД.Видимость=Истина;
	Элементы.ВыборЯчейки.Видимость = Ложь;
	
	НоваяЯчейка = Элементы.ДоступныеЯчейки.ТекущиеДанные.Ссылка;
	Если ИзменитьЯчейку() Тогда
			Ячейка = ПолучитьЯчейку(Номенклатура,Объект.Склад);	
			Сообщить("Ячейка изменена!");
	Иначе
			Ячейка = "";
			Сообщить("При измененеии ячейки произошли проблемы! Ячейка не изменена!");
	КонецЕсли;
	ДоступныеЯчейки.Отбор.Элементы.Очистить();
	
КонецПроцедуры

&НаСервере
Процедура ЗадаватьВопросПриДобавленииТовара();     
	НаименованиеТипаПересчета = Объект.ТипПересчета.Наименование;
	БезВопросаПриДобавленииТовара = (НаименованиеТипаПересчета = "Пустые места") Или (НаименованиеТипаПересчета = "Мало штук");
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов) 
	//+Альтерра	
	Штрихкод = ДанныеШтрихкодов[0].Штрихкод;
	
	// Штрихкод ячейки
	Если СтрДлина(Штрихкод) > 35   Тогда
		
		Если Элементы.РедактированиеДокументаНаТСД.Видимость Тогда
			
			МассивСсылок = СсылкаНаЯчейкуПоШтрихкоду(Штрихкод);
			
			// Ячейка найдена
			Если МассивСсылок.Количество() > 0 Тогда
				НайденнаяЯчейка = МассивСсылок[0];
				
				ФильтрПоЯчейке = НайденнаяЯчейка;
				
				Элементы.ФормаСброситьФильтрПоЯчейке.Заголовок = "Сбросить фильтр по " + НайденнаяЯчейка;
				УстановитьПоказываемыеТовары();
			Иначе
				Сообщить("Ячейка не найдена");
			КонецЕсли;
		КонецЕсли;
	Иначе   
		
		ДобавляемыйТовар = ТоварКДобавлению(Штрихкод); 
		Если Не БезВопросаПриДобавленииТовара И ДобавляемыйТовар <> "" Тогда
			ДополнительныеПараметры = Новый Структура;
	 		ДополнительныеПараметры.Вставить("ДанныеШтрихкодов", ДанныеШтрихкодов);
			ТекстВопроса = "Добавить новый товар в пересчет:" + Символы.ПС + ДобавляемыйТовар + "?";
			ПоказатьВопрос(Новый ОписаниеОповещения("ДобавитьТоварВПересчетЗавершение", ЭтотОбъект, ДополнительныеПараметры), ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);	
		Иначе
			ОбработатьТоварПоШтрихкоду(ДанныеШтрихкодов);	
		КонецЕсли;
	КонецЕсли;    
	//-     

	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры




Функция ТоварКДобавлению(Штрихкод) Экспорт     
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ 
		|	Штрихкоды.Номенклатура КАК Номенклатура, 
		|	СпрНоменклатура.Наименование КАК НоменклатураНаименование,
		|	Штрихкоды.Характеристика КАК Характеристика
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК Штрихкоды
		|СОЕДИНЕНИЕ 
		|	Справочник.Номенклатура КАК СпрНоменклатура
		|		ПО Штрихкоды.Номенклатура = СпрНоменклатура.Ссылка
		|ГДЕ Штрихкоды.Штрихкод = &Штрихкод";	
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод);
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	ДобавляемыйТовар = "";
	Если Выборка.Следующий() Тогда
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура", Выборка.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", Выборка.Характеристика);
		
		НайденныеТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска); 
		Если НайденныеТовары.Количество() = 0 Тогда
			ДобавляемыйТовар = Выборка.НоменклатураНаименование;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДобавляемыйТовар;
КонецФункции

&НаКлиенте
Процедура ОбработатьШтрихкод(ШтрихКод1) 
	
	СсылкаНаЯчейку = ПолучитьЯчейкуПоШтрихкоду(ШтрихКод1); 
	Если СсылкаНаЯчейку <> Неопределено Тогда
		ДоступныеЯчейки.Отбор.Элементы.Очистить();
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДоступныеЯчейки, "Ссылка", СсылкаНаЯчейку, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	Иначе
		Сообщить("Ячейка не найдена!");
	КонецЕсли;
КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПолучитьЯчейкуПоШтрихкоду(ШтрихКод1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладскиеЯчейки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
	|ГДЕ
	|	СкладскиеЯчейки.Штрихкод = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод1);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда	
		Возврат ВыборкаДетальныеЗаписи.Ссылка;   
	Иначе 
		Возврат Неопределено; 
	КонецЕсли;
КонецФункции


&НаКлиенте
Процедура ДобавитьТоварВПересчетЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда      
		ОбработатьТоварПоШтрихкоду(ДополнительныеПараметры.ДанныеШтрихкодов);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьТоварПоШтрихкоду(ДанныеШтрихкодов)
	СтруктураДействийСДобавленнымиСтроками = Новый Структура;
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействийСДобавленнымиСтроками);
		
	СтруктураДействийСИзмененнымиСтроками = Новый Структура;
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействийСИзмененнымиСтроками);
	
	СтруктураДействий = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	
	СтруктураДействий.Штрихкоды                              = ДанныеШтрихкодов;
	СтруктураДействий.СтруктураДействийСДобавленнымиСтроками = СтруктураДействийСДобавленнымиСтроками;
	СтруктураДействий.СтруктураДействийСИзмененнымиСтроками  = СтруктураДействийСИзмененнымиСтроками;
	СтруктураДействий.ПараметрыУказанияСерий                 = ПараметрыУказанияСерий;
	СтруктураДействий.ИмяКолонкиКоличество                   = "КоличествоУпаковокФакт";
	СтруктураДействий.НеИспользоватьУпаковки                 = Не ИспользоватьАдресноеХранение;
	СтруктураДействий.ИзменятьКоличество                     = Истина;
	СтруктураДействий.ТолькоТовары                           = Истина;
	
	ОбработатьШтрихкодыСервер(СтруктураДействий,КэшированныеЗначения);
	
	ШтрихкодированиеНоменклатурыКлиент.ОбработатьНеизвестныеШтрихкоды(СтруктураДействий,КэшированныеЗначения,ЭтаФорма);
	
	Если ШтрихкодированиеНоменклатурыКлиент.НужноОткрытьФормуУказанияСерийПослеОбработкиШтрихкодов(СтруктураДействий) Тогда
		
		ТекущиеДанныеИдентификатор = СтруктураДействий.МассивСтрокССериями[0];
		
		ПодключитьОбработчикОжидания("ОткрытьПодборСерийПриСканированииШтрихкодаНоменклатуры",0.1,Истина);
			
	КонецЕсли;   
	
	Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
		Элементы.Товары.ТекущаяСтрока = СтруктураДействий.ТекущаяСтрока;
	КонецЕсли;
	
	ТекущаяСтрокаТСД = СтруктураДействий.ТекущаяСтрока;    
	ЗаполнениеДанныхГруппыРедактированиеСтрокиНаТСД(ТекущаяСтрокаТСД);
КонецПроцедуры

&НаКлиенте
