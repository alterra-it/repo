	ШтрихкодированиеНоменклатурыСервер.ОбработатьШтрихкоды(ЭтаФорма, Объект, СтруктураПараметровДействия, КэшированныеЗначения);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействий)
	
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиницСуффикс", "Факт");
	СтруктураДействий.Вставить("ЗаполнитьФлагРасхождение");
	СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковокОтклонение");
	
КонецПроцедуры

Процедура ПриЧтенииСозданииНаСервере()
	ИнициализироватьКомпоновкуДанных(Ложь);
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыПоНоменклатуре()
	
	ПараметрыЗаполненияРеквизитов = Новый Структура;
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
											Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакТипНоменклатуры",
											Новый Структура("Номенклатура", "ТипНоменклатуры"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакАртикул",
											Новый Структура("Номенклатура", "Артикул"));
	ПараметрыЗаполненияРеквизитов.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины",
											Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
	
	НоменклатураСервер.ЗаполнитьСлужебныеРеквизитыПоНоменклатуреВКоллекции(Объект.Товары,ПараметрыЗаполненияРеквизитов);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьОформлениеФормыДокумента()
	
	Если ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач Тогда
		
		СтатусДокумента = Объект.Статус;
		
		Если (СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Подготовлено")) Или 
			СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Приостановлено") Тогда
			
			Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
				УстановитьДоступность(Истина,Ложь)
			Иначе
				УстановитьДоступность(Ложь,Ложь);
			КонецЕсли;
			
		ИначеЕсли СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВРаботе")
			ИЛИ СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВнесениеРезультатов") Тогда
			
			УстановитьДоступность(Ложь,Истина);
			
		ИначеЕсли СтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Выполнено") ИЛИ Объект.Просчитано Тогда
			
			УстановитьДоступность(Ложь,Ложь);
			
		КонецЕсли;
		
	Иначе
		
		Если Объект.Просчитано Тогда
			УстановитьДоступность(Ложь,Ложь);
		ИначеЕсли ЗначениеЗаполнено(Объект.ВремяНачала)Тогда
			УстановитьДоступность(Ложь,Истина);
		Иначе
			УстановитьДоступность(Истина,Ложь);
		КонецЕсли; 
		
	КонецЕсли;
	
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаКлиенте
