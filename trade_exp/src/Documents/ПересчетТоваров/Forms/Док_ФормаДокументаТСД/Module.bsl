&НаКлиенте
Процедура ОбработатьОжидание() Экспорт
	
	Если ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач И Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Выполнено") Тогда
		Возврат;
	КонецЕсли;
	
	АктивнаСтрокаРедактирования = Элементы.РедактированиеСтрокиНаТСД.Видимость;
	НомерСтроки = Неопределено;
	
	Если АктивнаСтрокаРедактирования Тогда
		ПоискПоИдентификатору = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
		Если ПоискПоИдентификатору <> Неопределено Тогда
			НомерСтроки = ПоискПоИдентификатору.НомерСтроки;
		КонецЕсли;
	КонецЕсли;
	
	ДанныеИзменены = Ложь;
	ДанныеИзменены = ЗаписатьИзменениеТабличнойЧасти();
	
	Если ДанныеИзменены Тогда
		
		ЭтаФорма.Прочитать();
		ЗаполнитьДополнительныеПоля();
		ЗаполнитьПризнакРасхождение();
		
		Если АктивнаСтрокаРедактирования И НомерСтроки <> Неопределено Тогда
			ТекущаяСтрокаТСД = Объект.Товары[НомерСтроки-1].ПолучитьИдентификатор();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаписатьИзменениеТабличнойЧасти()
	
	ДанныеИзменены = Ложь;
	
	Попытка
		Если Не Объект.Ссылка.Пустая()Тогда
		Если ТабличнаяЧастьИзменилась(Объект.Ссылка.Товары.Выгрузить(),Объект.Товары.Выгрузить()) Тогда
			ДокументОбъект = Объект.Ссылка.ПолучитьОбъект();
			ДокументОбъект.Товары.Загрузить(Объект.Товары.Выгрузить());
			Объект.Товары.Сортировать("СкладскаяЯчейка, Номенклатура");
			УстановитьПривилегированныйРежим(Истина);
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект,истина);
			УстановитьПривилегированныйРежим(Ложь);
			ДанныеИзменены = Истина;
		КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат ДанныеИзменены;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнениеДанныхГруппыРедактированиеСтрокиНаТСД(ТекущаяСтрокаТСД)
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
				
		Если ТипЗнч(ТекущаяСтрокаТСД) <> Тип("Неопределено") Тогда
			
			ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
			
			Номенклатура = "";
			Характеристика = "";
			ПоУчету = 0;
			Количество = 0;
			Ячейка = "";
			НоваяЯчейка = "";
			НовыйШтрихкод = "";
			АдресКартинки = "";

			Если ЭлементСписка <> Неопределено Тогда
				Элементы.РедактированиеДокументаНаТСД.Видимость = Ложь;
				Элементы.ВыборНоменклатуры.Видимость            = Ложь;
				Элементы.РедактированиеСтрокиНаТСД.Видимость    = Истина;
				
				Номенклатура = ЭлементСписка.Номенклатура;
				Характеристика = ЭлементСписка.Характеристика;
				КомментарийСтроки = ЭлементСписка.Комментарий;
				//Количество = ЭлементСписка.КоличествоУпаковокФакт;
				//Если Объект.НовыйРасчетОтклонения Тогда
				//	ПоУчету = ЭлементСписка.КоличествоПоУчетуВЗонеХранения;	
				//Иначе
				//	ПоУчету = ЭлементСписка.КоличествоУпаковок;
				//КонецЕсли;
				СтруктураПоиска = Новый Структура;   
				СтруктураПоиска.Вставить("Номенклатура", ЭлементСписка.Номенклатура); 
				СтруктураПоиска.Вставить("Характеристика", ЭлементСписка.Характеристика);
			    ОбщееКоличество = ПолучитьКоличествоСУчетомНазначений(СтруктураПоиска);
				Количество = ОбщееКоличество.Факт;
				ПоУчету = ОбщееКоличество.Учет;
				
				ЯПХ = ЭлементСписка.ЯПХ; 
				КлассТовара = ПолучитьКлассТовара(Номенклатура);
				
				Товар = Новый Структура;
				Товар.Вставить("Номенклатура", Номенклатура);
				Товар.Вставить("Характеристика", ПредопределенноеЗначение("Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка"));
				Товар.Вставить("Склад", Объект.Склад);
				Товар.Вставить("Дата", ТекущаяДата());
				Блокировки = ЗаполнитьБлокировкиПоТоварам(Ложь, Товар);
				ЭлементСписка.БлокировкаТоваров = Блокировки;
				
				Если ЭлементСписка.БлокировкаТоваров <> "" Тогда
					БлокировкаТоваров = ЭлементСписка.БлокировкаТоваров;
				Иначе
					Элементы.БлокировкаТоваров.Видимость = Ложь;
				КонецЕсли;         
				
				Если ЭлементСписка.ЯПХ <> "" Тогда
					ЯПХ = ЭлементСписка.ЯПХ;
				Иначе
					Элементы.ЯПХ.Видимость = Ложь;
				КонецЕсли;
				
				//Ячейка = ЭлементСписка.Ячейка; 
				Ячейка = ПолучитьЯчейку(Номенклатура,Объект.Склад);
				ПолучитьАдресКартинки(Номенклатура);
				
				НовыйРасчетОтклонения_СтрТабл_Клиент(ЭлементСписка);
			Конецесли;
			
		Иначе
			Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
				СредстваМультимедиа.ВоспроизвестиТекст("Товар не найден!","ru-RU");	
			КонецЕсли;
			Сообщить("Штрихкод не найден!");
		КонецЕсли;
		
	#КонецЕсли

КонецПроцедуры  

&НаСервере
Функция ПолучитьКоличествоСУчетомНазначений(СтруктураПоиска)
	НайденныеСтроки = Объект.Товары.НайтиСтроки(СтруктураПоиска);
	ОбщееКоличествоУчет = 0;
	ОбщееКоличествоФакт = 0;
	Для каждого НайденнаяСтрока из НайденныеСтроки Цикл 
		Если Объект.НовыйРасчетОтклонения Тогда
			ОбщееКоличествоУчет = ОбщееКоличествоУчет + НайденнаяСтрока.КоличествоПоУчетуВЗонеХранения;
		Иначе
			ОбщееКоличествоУчет = ОбщееКоличествоУчет + НайденнаяСтрока.КоличествоУпаковок;
		КонецЕсли;
		ОбщееКоличествоФакт = ОбщееКоличествоФакт + НайденнаяСтрока.КоличествоУпаковокФакт;
	КонецЦикла;
	Возврат Новый Структура("Учет, Факт", ОбщееКоличествоУчет, ОбщееКоличествоФакт); 
	
	
КонецФункции


&НаСервере
Функция ПолучитьКлассТовара(ДобавляемыйТовар)
	Возврат РегистрыСведений.ABCКлассификацияНоменклатуры_Альтерра.ВернутьКлассТовара(ДобавляемыйТовар, Объект.Склад.Подразделение);	
КонецФункции


Функция ТабличнаяЧастьИзменилась(ИсходнаяТЧ,НоваяТЧ) Экспорт
			
	ИсходнаяСтрокаТаблицы = "";
	
	НоваяСтрокаТаблицы = "";
	
	Для каждого Строка из ИсходнаяТЧ Цикл
		ИсходнаяСтрокаТаблицы = ИсходнаяСтрокаТаблицы + Строка(Строка.Номенклатура) + Строка(Строка.Характеристика) + Строка(Строка.Назначение) + Строка(Строка.КоличествоУпаковокФакт);
	КонецЦикла;
	
	Для каждого Строка из НоваяТЧ Цикл
		НоваяСтрокаТаблицы = НоваяСтрокаТаблицы + Строка(Строка.Номенклатура) + Строка(Строка.Характеристика) + Строка(Строка.Назначение) + Строка(Строка.КоличествоУпаковокФакт);
	КонецЦикла;
	
	Если ИсходнаяСтрокаТаблицы = НоваяСтрокаТаблицы Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

