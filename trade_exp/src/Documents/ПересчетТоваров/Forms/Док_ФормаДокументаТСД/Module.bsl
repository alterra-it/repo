#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Док__ВернутьсяКТЧ(Команда)
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
	Если ТекущаяСтрока <> Неопределено Тогда
		ПерераспределитьФакт(Номенклатура, Характеристика, ТекущаяСтрока.НомерСтроки);
	КонецЕсли;
	ТекущаяСтрока.СкладскаяЯчейка = ПолучитьЯчейку(ТекущаяСтрока.Номенклатура, Объект.Склад);	

	Если СкрытьКоличествоУчетаВПересчетах  
		И Не (РольПолныеПрава Или РольПодтверждениеОтделомКачества Или РуководительСкладскогоКомплекса) Тогда		
		
		Если (Количество > 0) И (ПоУчету <> Количество) И (ТекущаяСтрока.СчетчикОтображенияВопроса < 3) Тогда
			
			ТекущаяСтрока.СчетчикОтображенияВопроса = ТекущаяСтрока.СчетчикОтображенияВопроса + 1;
			
			ТекстВопроса = "Есть расхождения. Продолжить?";
			ПоказатьВопрос(Новый ОписаниеОповещения("ВернутьсяКТаблицеЗавершение", ЭтотОбъект), ТекстВопроса, РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Да);	
			
		Иначе
			ВернутьсяКТаблице();		
		КонецЕсли;
	Иначе
		ВернутьсяКТаблице();	
	КонецЕсли; 
	
КонецПроцедуры 

&НаСервере
Процедура ПерераспределитьФакт(Номенклатура, Характеристика, ТекНомерСтроки) 
	
	Факт = Количество;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗТовары.НомерСтроки КАК НомерСтроки,
		|	ТЗТовары.Номенклатура КАК Номенклатура,
		|	ТЗТовары.Характеристика КАК Характеристика,
		|	ТЗТовары.Назначение КАК Назначение
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&ТЗТовары КАК ТЗТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТТовары.НомерСтроки КАК НомераСтрок
		|ИЗ
		|	ВТТовары КАК ВТТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Назначения КАК СпрНазначения
		|		ПО ВТТовары.Назначение = СпрНазначения.Ссылка
		|ГДЕ
		|	ВТТовары.Номенклатура = &Номенклатура
		|	И ВТТовары.Характеристика = &Характеристика
		|	И ВТТовары.Назначение <> ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|УПОРЯДОЧИТЬ ПО
		|	СпрНазначения.Заказ.Дата";
	
	Запрос.УстановитьПараметр("ТЗТовары", Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	УстановитьПривилегированныйРежим(Истина);
	НомераСтрок = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("НомераСтрок");
    УстановитьПривилегированныйРежим(Ложь); 

	Если Объект.НовыйРасчетОтклонения Тогда
		Для каждого НомерСтроки из НомераСтрок Цикл
			Если Объект.Товары[НомерСтроки-1].КоличествоПоУчетуВЗонеХранения <= Факт Тогда
				 Объект.Товары[НомерСтроки-1].КоличествоУпаковокФакт = Объект.Товары[НомерСтроки-1].КоличествоПоУчетуВЗонеХранения;
				 Объект.Товары[НомерСтроки-1].КоличествоФакт = Объект.Товары[НомерСтроки-1].КоличествоПоУчетуВЗонеХранения;
				 Факт = Факт - Объект.Товары[НомерСтроки-1].КоличествоПоУчетуВЗонеХранения;
			Иначе
				Объект.Товары[НомерСтроки-1].КоличествоУпаковокФакт = Факт;
				Объект.Товары[НомерСтроки-1].КоличествоФакт = Факт;
				Факт = 0;
			КонецЕсли;
		КонецЦикла;  
	Иначе
		Для каждого НомерСтроки из НомераСтрок Цикл
			Если Объект.Товары[НомерСтроки-1].КоличествоУпаковок <= Факт Тогда
				 Объект.Товары[НомерСтроки-1].КоличествоУпаковокФакт = Объект.Товары[НомерСтроки-1].КоличествоУпаковок;
				 Объект.Товары[НомерСтроки-1].КоличествоФакт = Объект.Товары[НомерСтроки-1].КоличествоУпаковок;
				 Факт = Факт - Объект.Товары[НомерСтроки-1].КоличествоУпаковок;
			Иначе
				Объект.Товары[НомерСтроки-1].КоличествоУпаковокФакт = Факт;
				Объект.Товары[НомерСтроки-1].КоличествоФакт = Факт;
				Факт = 0;
			КонецЕсли;
		КонецЦикла;	
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Товары[ТекНомерСтроки-1].Назначение) Тогда
		Объект.Товары[ТекНомерСтроки-1].КоличествоУпаковокФакт = Объект.Товары[ТекНомерСтроки-1].КоличествоУпаковокФакт + Факт;
		Объект.Товары[ТекНомерСтроки-1].КоличествоФакт = Объект.Товары[ТекНомерСтроки-1].КоличествоФакт + Факт;
	Иначе
		Объект.Товары[ТекНомерСтроки-1].КоличествоУпаковокФакт = Факт;
		Объект.Товары[ТекНомерСтроки-1].КоличествоФакт = Факт;
	КонецЕсли;
	
	
КонецПроцедуры


