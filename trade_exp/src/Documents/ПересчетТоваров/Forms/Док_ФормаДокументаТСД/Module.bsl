&НаСервере
Процедура УстановитьЗначениеПараметраНастроек(Настройки, ИмяПараметра, Значение)
	
	Параметр = Настройки.ПараметрыДанных.Элементы.Найти(ИмяПараметра);
	
	Если Параметр <> Неопределено Тогда
		Параметр.Значение = Значение;
		Параметр.Использование = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборПересчетаНастройкиОтборПриИзменении(Элемент)
	Объект.ТочкаПересчета = ПолучитьДанныеИзОтбора("ТочкаПересчета", ВидСравненияКомпоновкиДанных.ВИерархии);	
	Объект.РабочийУчасток = ПолучитьДанныеИзОтбора("РабочийУчасток", ВидСравненияКомпоновкиДанных.Равно);	
	Элементы.ТоварыПодборТоваров.Видимость = Истина;
КонецПроцедуры

&НаКлиенте
Функция ПолучитьДанныеИзОтбора(ИмяПоля, ВидСравнения)

	Отбор = ОтборПересчета.Настройки.Отбор;       
	Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	
	НайденныйЭлемент = Неопределено;
	Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл    
		Если Не (ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных")) Тогда
			Если ЭлементОтбора.ЛевоеЗначение = Поле И ЭлементОтбора.ВидСравнения = ВидСравнения Тогда
				НайденныйЭлемент = ЭлементОтбора;
				Прервать;
			КонецЕсли;     
		КонецЕсли;	
	КонецЦикла;
	
	Данные = Неопределено;
	
	Если Не (НайденныйЭлемент = Неопределено) И НайденныйЭлемент.Использование Тогда
		Данные = НайденныйЭлемент.ПравоеЗначение; 		
	КонецЕсли;
	
	Возврат Данные;
КонецФункции

&НаКлиенте
Процедура УстановитьОтбор(ИмяПоля, ВидСравнения, ЗначениеПоля, ИндексВставки)

	Отбор = ОтборПересчета.Настройки.Отбор;       
	Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	
	НайденныйЭлемент = Неопределено;
	Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл    
		Если Не (ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных")) Тогда
			Если ЭлементОтбора.ЛевоеЗначение = Поле И ЭлементОтбора.ВидСравнения = ВидСравнения Тогда
				НайденныйЭлемент = ЭлементОтбора;
				Прервать;
			КонецЕсли;     
		КонецЕсли;	
	КонецЦикла;
	
	ИндексВставки = ?(ИндексВставки > Отбор.Элементы.Количество() - 1, Отбор.Элементы.Количество() - 1, ИндексВставки);
	
	Если НайденныйЭлемент = Неопределено Тогда
		НайденныйЭлемент = Отбор.Элементы.Вставить(ИндексВставки, Тип("ЭлементОтбораКомпоновкиДанных"));
		НайденныйЭлемент.ЛевоеЗначение  = ИмяПоля;
		НайденныйЭлемент.ВидСравнения = ВидСравнения;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
		НайденныйЭлемент.ПравоеЗначение = ЗначениеПоля;
		НайденныйЭлемент.Использование  = Истина;
	Иначе                                 
		НайденныйЭлемент.ПравоеЗначение = Неопределено;
		НайденныйЭлемент.Использование  = Ложь;
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
Процедура БракНаСкладе(Команда)
	
    ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Номенклатура", Номенклатура);
	ПараметрыФормы.Вставить("Склад", Объект.Склад);
	ПараметрыФормы.Вставить("ДобавитьФотоТовара", Истина);
	ПараметрыФормы.Вставить("ПричинаБлокировки", "Брак на складе");
	
	ОткрытьФорму("Документ.БлокировкаДвиженияТоваров.Форма.Док_ФормаДокументаТСД", ПараметрыФормы);	
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти                    

#Область Оповещения 
&НаКлиенте
Процедура Оповещения(Команда)
	Если ОповещенияИзОчереди Тогда
		ПричинаОтказа = "";
		ОповещенияПоСекцииПодключены = ПолучитьСостояниеОповещений();
				
		Если ПричинаОтказа = "" Тогда
			ОповещенияИзОчереди = Ложь;
			Сообщить("Оповещения отключены");
			Элементы.ГруппаСписокОчереди.Видимость = Ложь;
			ОтключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди");  
		Иначе
			Сообщить(ПричинаОтказа);
		КонецЕсли;
	Иначе
		ОповещенияИзОчереди = Истина;
		Сообщить("Оповещения подключены");
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);  
		ПроверкаЭлектроннойОчереди(); 
	КонецЕсли;
	ЗаписатьЗначениеОповещения();
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСписокОчереди(Команда)
	Если КлиентовВОчереди > 0 Тогда   
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Приостановлено");
        ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма, Истина); 		
		ОткрытьФорму("Обработка.РабочееМестоКладовщикаАльтерра.Форма.Форма", Новый Структура("Сотрудник,ИмяКоманды, ОткрытьОчередь",ИсполнительСотрудник,"Отгрузка", Истина),ЭтотОбъект);  
	Иначе
		Сообщить("Список очереди пуст");
	КонецЕСли;	
КонецПроцедуры  

&НаСервере
Функция ЭлектроннаяОчередьНаСекции()
	Запрос = Новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ
				 |	РабочиеУчастки.Ссылка КАК Ссылка,
				 |	РабочиеУчастки.ЭлектроннаяОчередь КАК ЭлектроннаяОчередь
				 |ИЗ
				 |	Справочник.РабочиеУчастки КАК РабочиеУчастки
				 |ГДЕ
				 |	РабочиеУчастки.Ссылка В(&Секции)
				 |	И РабочиеУчастки.ЭлектроннаяОчередь = Истина" ;
	Запрос.УстановитьПараметр("Секции", СекцииСотрудника()); 
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 
		Возврат Истина; 
	Иначе 
		Возврат Ложь; 
	КонецЕсли;
	
КонецФункции 

&НаСервере
Функция ПолучитьСостояниеОповещений()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиРабочиеУчастки.Ссылка.ОповещенияИзОчереди КАК ОповещенияИзОчереди
		|ИЗ
		|	Справочник.Сотрудники.РабочиеУчастки КАК СотрудникиРабочиеУчастки
		|ГДЕ
		|	СотрудникиРабочиеУчастки.РабочийУчасток В(&РабочийУчасток)
		|	И СотрудникиРабочиеУчастки.Ссылка <> &Сотрудник
		|
		|СГРУППИРОВАТЬ ПО
		|	СотрудникиРабочиеУчастки.Ссылка.ОповещенияИзОчереди";
	
	Запрос.УстановитьПараметр("РабочийУчасток", СекцииСотрудника());
	Запрос.УстановитьПараметр("Сотрудник", ИсполнительСотрудник);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() = 1 И Результат.Найти(Истина, "ОповещенияИзОчереди") = Неопределено Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции 


&НаКлиенте
Процедура ПроверкаЭлектроннойОчереди() Экспорт
	ОбновитьСписокОчереди();  
КонецПроцедуры   

&НаСервере
Процедура ОбновитьСписокОчереди() 

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЭлектроннаяОчередьКлиентов.Документ КАК Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления КАК Получатель
	|ИЗ
	|	РегистрСведений.ЭлектроннаяОчередьКлиентов КАК ЭлектроннаяОчередьКлиентов 
	|ГДЕ
	|   ЭлектроннаяОчередьКлиентов.ТребуетсяОповещениеКладовщику = Истина 
	|	И ЭлектроннаяОчередьКлиентов.ПолучательУведомления В (&Секции)   
	|	И не ЭлектроннаяОчередьКлиентов.Состояние = &Статус
	|
	|
	|СГРУППИРОВАТЬ ПО
