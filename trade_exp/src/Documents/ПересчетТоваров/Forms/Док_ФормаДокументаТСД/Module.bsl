Процедура ТоварыПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Отказ=Истина;
	
	Элементы.РедактированиеДокументаНаТСД.Видимость=Ложь;
	Элементы.ВыборНоменклатуры.Видимость = Истина;

КонецПроцедуры

&НаКлиенте
Процедура СписокНоменклатура1Выбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Номенклатура = Элементы.СписокНоменклатура1.ТекущиеДанные.Ссылка;
	Если ЗначениеЗаполнено(Номенклатура) Тогда
		
		ПоискСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
		Если ЗначениеЗаполнено(ПоискСтроки) Тогда
			ТекущаяСтрокаТСД = ПоискСтроки[0].ПолучитьИдентификатор();
		Иначе
			НоваяСтрока = Объект.Товары.Добавить();
			НоваяСтрока.Номенклатура = Номенклатура;
			
			ТекущаяСтрокаТСД = НоваяСтрока.ПолучитьИдентификатор();
			ПересчитатьПоУчетуВДокументе(ТекущаяСтрокаТСД);		
			ТекущаяСтрокаТСД_ПроверитьЗаполнение(Номенклатура);
		КонецЕсли;
		
		ЗаполнениеДанныхГруппыРедактированиеСтрокиНаТСД(ТекущаяСтрокаТСД);
		
		ЭтаФорма.ОбновитьОтображениеДанных();
		
		Элементы.Товары.ТекущаяСтрока = ТекущаяСтрокаТСД;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТекущаяСтрокаТСД_ПроверитьЗаполнение(Номенклатура)
	Если Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД) = Неопределено Тогда
		ЭтаФорма.ОбновитьОтображениеДанных();
		
		ПоискСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", Номенклатура));
		Если ЗначениеЗаполнено(ПоискСтроки) Тогда
			ТекущаяСтрокаТСД = ПоискСтроки[0].ПолучитьИдентификатор();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

