&НаСервере
Процедура ПересчитатьПоУчетуВДокументе(ТекущаяСтрокаТСД = Неопределено)
	ДокОбъект = РеквизитФормыВЗначение("Объект"); 
	
	ТолькоДляНулевогоФакта = Истина;
	Если ТекущаяСтрокаТСД = Неопределено Тогда
		ТЗТовары = ДокОбъект.Товары.Выгрузить();
	Иначе
		ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);  
		
		ТЗВсеТовары = ДокОбъект.Товары.Выгрузить();
		СтруктураПоиска = Новый Структура("Номенклатура", ЭлементСписка.Номенклатура);	
		ТЗТовары = ТЗВсеТовары.Скопировать(СтруктураПоиска);        
		ТолькоДляНулевогоФакта = Ложь;   
	КонецЕсли; 
	
	ТаблицаЗначенийПоУчету = ДокОбъект.ПересчитатьПоУчетуВДокументе(ТЗТовары, ТолькоДляНулевогоФакта);
	
	Для Каждого СтрокаПоУчету Из ТаблицаЗначенийПоУчету Цикл
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура", СтрокаПоУчету.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", СтрокаПоУчету.Характеристика);
		СтруктураПоиска.Вставить("Назначение", СтрокаПоУчету.Назначение);
		
		НайденныеТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеТовары.Количество() > 0 Тогда
			Для Каждого СтрокаТоваров Из НайденныеТовары Цикл       
				ДокОбъект.Товары[СтрокаТоваров.Номерстроки-1].Количество = СтрокаПоУчету.Количество;
				ДокОбъект.Товары[СтрокаТоваров.Номерстроки-1].КоличествоУпаковок = СтрокаПоУчету.КоличествоУпаковок;
				ДокОбъект.Товары[СтрокаТоваров.Номерстроки-1].ЯПХ = СтрокаПоУчету.ЯПХ;
				ДокОбъект.Товары[СтрокаТоваров.Номерстроки-1].КоличествоПоУчетуВЗонеХранения = СтрокаПоУчету.КоличествоПоУчетуВЗонеХранения;
			КонецЦикла;
		Иначе           
			НоваяСтрокаТоваров = ДокОбъект.Товары.Добавить();	
			 
			НоваяСтрокаТоваров.Номенклатура = СтрокаПоУчету.Номенклатура;
			НоваяСтрокаТоваров.Характеристика = СтрокаПоУчету.Характеристика;
			НоваяСтрокаТоваров.Назначение = СтрокаПоУчету.Назначение;
			НоваяСтрокаТоваров.Количество = СтрокаПоУчету.Количество;
			НоваяСтрокаТоваров.КоличествоУпаковок = СтрокаПоУчету.КоличествоУпаковок;
			НоваяСтрокаТоваров.ЯПХ = СтрокаПоУчету.ЯПХ;
			НоваяСтрокаТоваров.КоличествоПоУчетуВЗонеХранения = СтрокаПоУчету.КоличествоПоУчетуВЗонеХранения;
			Если ДокОбъект.Статус = Перечисления.СтатусыПересчетовТоваров.Выполнено И ДокОбъект.Проведен Тогда
				ДокОбъект.Записать(РежимЗаписиДокумента.Проведение);  
			Иначе     
				ДокОбъект.Записать(РежимЗаписиДокумента.Запись);
			КонецЕсли;	
		КонецЕсли;
	КонецЦикла;	     
	ЗначениеВРеквизитФормы(ДокОбъект,"Объект");

	
	Если ТекущаяСтрокаТСД = Неопределено Тогда
		// Удаление товаров с план = 0 и факт = 0  
		КоличествоТоваров = Объект.Товары.Количество() - 1;
		ИндексСтроки = КоличествоТоваров;
		Для Счетчик = 0 По КоличествоТоваров Цикл 
	   		Товар = Объект.Товары.Получить(ИндексСтроки); 
			Если Товар.КоличествоУпаковок = 0 И Товар.КоличествоУпаковокФакт = 0 Тогда
				Объект.Товары.Удалить(Товар);			
			КонецЕсли; 
	    	ИндексСтроки = ИндексСтроки - 1; 
		КонецЦикла;	
		
		ЗаполнитьДополнительныеПоля();
		ЗаполнитьПризнакРасхождение();   
	Иначе 
		Товар = Новый Структура;
		Товар.Вставить("Номенклатура", Номенклатура);
		Товар.Вставить("Характеристика", ПредопределенноеЗначение("Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка"));
		Товар.Вставить("Склад", Объект.Склад);
		Товар.Вставить("Дата", ТекущаяДата());
		СтрокаБлокировкаТоваров = ЗаполнитьБлокировкиПоТоварам(Ложь, Товар);
		ЭлементСписка.БлокировкаТоваров = СтрокаБлокировкаТоваров;    
		НовыйРасчетОтклонения_СтрТабл(ЭлементСписка);
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ВзятьВРаботу(Команда) 
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.Приостановлено") Тогда
		ПересчетПриостановлен = Истина;
	Иначе
		ПересчетПриостановлен = Ложь;
	КонецЕсли;	
	
		
	//Перезаполнение таб части
	Если ЗначениеЗаполнено(Объект.ТочкаПересчета) Тогда  // для ТЗ перезаполнять таб часть не нужно
		
		Если НЕ ДопМодуль.Тип_ТоварПодОстаток(Объект.Ссылка)Тогда
			
			Режим = РежимДиалогаВопрос.ДаНет; 
			Ответ = Вопрос("Перезаполнить данные по учету? Табличная часть будет очищена!", Режим, 0); 
			
			Если Ответ = КодВозвратаДиалога.Да Тогда
				
				Объект.Дата = ТекущаяДата();
				ПерезаполнитьПоОтбору(); 	
				
			ИначеЕсли НЕ ПересчетПриостановлен  Тогда		
				Возврат;  
			КонецЕсли; 
			
		КонецЕсли; 
		
	КонецЕсли;
	
	// Конец Перезаполнение таб части
	
	Если Не ЗначениеЗаполнено(Объект.Дата) Тогда
		Объект.Дата = ТекущаяДата();
		ИнициализироватьНовыйРасчетОтклонения();
	КонецЕсли;	
	Если Не ЗначениеЗаполнено(Объект.ВремяНачала) Тогда
		Объект.ВремяНачала = ТекущаяДата();
	КонецЕсли;
	
	Объект.ИсполнительСотрудник = ИсполнительСотрудник;
	Объект.Исполнитель = Исполнитель;
	Если ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВРаботе"); 
	КонецЕсли; 
	
	ПересчитатьПоУчетуВДокументе();
 	Объект.УчетныеДанныеЗаполнены = Истина; 
	
	Попытка
		ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма, Истина);
		УстановитьОформлениеФормыДокумента();
	Исключение
	КонецПопытки;
	
	ЗаполнитьДополнительныеПоля();
	ЗаполнитьПризнакРасхождение(); 
	
	Альтерра_СкладСервер.ЗаписьВРегистрЖурналРаботыТСД(ПредопределенноеЗначение("Перечисление.СобытияРаботыТСД.Документ"),,Объект.Ссылка);
КонецПроцедуры 

&НаКлиенте
Процедура ПерезаполнитьПоОтбору()  
	Если ЗначениеЗаполнено(Объект.РабочийУчасток) Тогда
		УстановитьОтбор(Элементы.РабочийУчасток.Имя, ВидСравненияКомпоновкиДанных.Равно, Объект.РабочийУчасток, 1); 
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект.ТочкаПересчета) Тогда
		УстановитьОтбор(Элементы.ТочкаПересчета.Имя, ВидСравненияКомпоновкиДанных.ВИерархии, Объект.ТочкаПересчета, 1); 
	КонецЕсли;
	
	ЗаполнитьСервер();
	ЗагрузитьТоварыПоОтбору();
КонецПроцедуры

&НаКлиенте
Процедура Завершить(Команда)
	Если ЗначениеЗаполнено(Объект.ТипПересчета) Тогда

		Объект.ВремяОкончания = ТекущаяДата();
		Объект.Просчитано = Истина;
		
		Если ЗначениеЗаполнено(Объект.Ссылка) И Объект.Проведен 
			И Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВРаботе")
			И ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач Тогда
				Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВнесениеРезультатов"); 
		КонецЕсли;
		
		Если НЕ РольПодтверждениеОтделомКачества И ИспользуетсяОрдернаяСхема() Тогда
			Объект.ПодтвержденСкладом = Истина;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда	
			Попытка;
				ОбщегоНазначенияУТКлиент.ПровестиИЗакрыть(ЭтаФорма);
				Сообщить("Завершен Пересчет товаров № " + Объект.Номер + " от " + Объект.Дата);
			Исключение
			КонецПопытки;
		Иначе
			Попытка;
				ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма);
			Исключение
			КонецПопытки;
			ЗаполнитьДополнительныеПоля();
			ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
			ЗаполнитьПризнакРасхождение();
			УстановитьОформлениеФормыДокумента();
		КонецЕсли;
	Иначе
		Сообщить("Необходимо заполнить тип пересчета");
	КонецЕсли
КонецПроцедуры

