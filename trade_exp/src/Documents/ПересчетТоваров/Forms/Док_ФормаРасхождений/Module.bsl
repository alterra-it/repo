&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Товары = Параметры.Товары.Выгрузить();
	Товары.Свернуть("Номенклатура, Расхождение", "КоличествоУпаковокОтклонение");	
	Пересчет = Параметры.Пересчет;
	СкладПересчета = Параметры.Склад;
	ЗаполнитьТаблицыТоваров(Товары, Пересчет);	

КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если РасхожденийНет = Истина Тогда 
		Сообщить("Расхождений нет");
		ЭтаФорма.Закрыть();
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицыТоваров(Товары, Пересчет)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Расхождение КАК Расхождение,
	|	Товары.КоличествоУпаковокОтклонение КАК КоличествоУпаковокОтклонение
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|ГДЕ
	|	Товары.Расхождение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СписаниеНедостачТоваровТовары.Номенклатура КАК Номенклатура,
	|	СУММА(-СписаниеНедостачТоваровТовары.Количество) КАК КоличествоОформлено
	|ПОМЕСТИТЬ ВТ_Объединение
	|ИЗ
	|	Документ.СписаниеНедостачТоваров.Товары КАК СписаниеНедостачТоваровТовары
	|ГДЕ
	|	СписаниеНедостачТоваровТовары.Ссылка.ПересчетТоваров = &Пересчет
	|	И СписаниеНедостачТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	СписаниеНедостачТоваровТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОприходованиеИзлишковТоваровТовары.Номенклатура,
	|	СУММА(ОприходованиеИзлишковТоваровТовары.Количество)
	|ИЗ
	|	Документ.ОприходованиеИзлишковТоваров.Товары КАК ОприходованиеИзлишковТоваровТовары
	|ГДЕ
	|	ОприходованиеИзлишковТоваровТовары.Ссылка.ПересчетТоваров = &Пересчет
	|	И ОприходованиеИзлишковТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ОприходованиеИзлишковТоваровТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПересортицаТоваровТовары.Номенклатура,
	|	-СУММА(ПересортицаТоваровТовары.Количество)
	|ИЗ
	|	Документ.ПересортицаТоваров.Товары КАК ПересортицаТоваровТовары
	|ГДЕ
	|	ПересортицаТоваровТовары.Ссылка.ПересчетТоваров = &Пересчет
	|	И ПересортицаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПересортицаТоваровТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПересортицаТоваровТовары.НоменклатураОприходование,
	|	СУММА(ПересортицаТоваровТовары.Количество)
	|ИЗ
	|	Документ.ПересортицаТоваров.Товары КАК ПересортицаТоваровТовары
	|ГДЕ
	|	ПересортицаТоваровТовары.Ссылка.ПересчетТоваров = &Пересчет
	|	И ПересортицаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПересортицаТоваровТовары.НоменклатураОприходование
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПорчаТоваровТовары.Номенклатура,
	|	-СУММА(ПорчаТоваровТовары.Количество)
	|ИЗ
	|	Документ.ПорчаТоваров.Товары КАК ПорчаТоваровТовары
	|ГДЕ
	|	ПорчаТоваровТовары.Ссылка.ПересчетТоваров = &Пересчет
	|	И ПорчаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПорчаТоваровТовары.Номенклатура
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПорчаТоваровТовары.НоменклатураОприходование,
	|	СУММА(ПорчаТоваровТовары.Количество)
	|ИЗ
	|	Документ.ПорчаТоваров.Товары КАК ПорчаТоваровТовары
	|ГДЕ
	|	ПорчаТоваровТовары.Ссылка.ПересчетТоваров = &Пересчет
	|	И ПорчаТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПорчаТоваровТовары.НоменклатураОприходование
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура КАК Номенклатура,
	|	СУММА(ПеремещениеТоваровТовары.КоличествоУпаковок) КАК КоличествоУпаковок
	|ПОМЕСТИТЬ ВТ_Перемещения
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка.ДокументОснование = &Пересчет
	|	И ПеремещениеТоваровТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	ВТ_Товары.КоличествоУпаковокОтклонение КАК КоличествоУпаковокОтклонение,
	|	ЕСТЬNULL(СУММА(ВТ_Объединение.КоличествоОформлено), 0) КАК КоличествоОформлено,
	|	ЕСТЬNULL(ВТ_Перемещения.КоличествоУпаковок, 0) КАК КоличествоУпаковокВПеремещении
	|ПОМЕСТИТЬ ВТ_Соединение
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Объединение КАК ВТ_Объединение
	|		ПО ВТ_Товары.Номенклатура = ВТ_Объединение.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Перемещения КАК ВТ_Перемещения
	|		ПО ВТ_Товары.Номенклатура = ВТ_Перемещения.Номенклатура
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Товары.КоличествоУпаковокОтклонение,
	|	ВТ_Товары.Номенклатура,
	|	ЕСТЬNULL(ВТ_Перемещения.КоличествоУпаковок, 0)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Соединение.Номенклатура КАК Номенклатура,
	|	ВТ_Соединение.КоличествоУпаковокОтклонение КАК КоличествоУпаковокОтклонение,
	|	ВТ_Соединение.КоличествоОформлено КАК КоличествоОформлено,
	|	ВТ_Соединение.КоличествоУпаковокВПеремещении КАК КоличествоУпаковокВПеремещении,
	|	ВЫБОР
	|		КОГДА ВТ_Соединение.КоличествоУпаковокОтклонение > 0
	|			ТОГДА ВТ_Соединение.КоличествоУпаковокОтклонение - ВТ_Соединение.КоличествоОформлено - ВТ_Соединение.КоличествоУпаковокВПеремещении
	|		ИНАЧЕ ВТ_Соединение.КоличествоУпаковокОтклонение - ВТ_Соединение.КоличествоОформлено + ВТ_Соединение.КоличествоУпаковокВПеремещении
	|	КОНЕЦ КАК Расхождение,
	|	СпрНоменклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ПОМЕСТИТЬ ВТ_ОбщийРезультат
	|ИЗ
	|	ВТ_Соединение КАК ВТ_Соединение
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО (ВТ_Соединение.Номенклатура = СпрНоменклатура.Ссылка)
	|ГДЕ
	|	ВТ_Соединение.КоличествоУпаковокОтклонение - ВТ_Соединение.КоличествоОформлено <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОбщийРезультат.Номенклатура КАК Номенклатура,
	|	ВТ_ОбщийРезультат.КоличествоУпаковокОтклонение КАК КоличествоУпаковокОтклонение,
	|	ВТ_ОбщийРезультат.КоличествоОформлено КАК КоличествоОформлено,
	|	ВТ_ОбщийРезультат.Расхождение КАК Расхождение,
	|	ВТ_ОбщийРезультат.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	ВТ_ОбщийРезультат КАК ВТ_ОбщийРезультат
	|ГДЕ
	|	ВТ_ОбщийРезультат.Расхождение > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ОбщийРезультат.Номенклатура КАК Номенклатура,
	|	ВТ_ОбщийРезультат.КоличествоУпаковокОтклонение КАК КоличествоУпаковокОтклонение,
	|	ВТ_ОбщийРезультат.КоличествоОформлено КАК КоличествоОформлено,
	|	ВТ_ОбщийРезультат.Расхождение КАК Расхождение,
	|	ВТ_ОбщийРезультат.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ИЗ
	|	ВТ_ОбщийРезультат КАК ВТ_ОбщийРезультат
	|ГДЕ
	|	ВТ_ОбщийРезультат.Расхождение < 0";
	Запрос.УстановитьПараметр("Товары", Товары);
	Запрос.УстановитьПараметр("Пересчет", Пересчет);
	
	ПакетРезультатов = Запрос.ВыполнитьПакет();
	РезультатИзлишки = ПакетРезультатов[5].Выгрузить();
	Если РезультатИзлишки.Количество()> 0 Тогда 
		ТаблицаИзлишки.Загрузить(РезультатИзлишки);
		Элементы.ТаблицаИзлишек.Видимость = Истина;
	КонецЕсли;

	РезультатНедостачи = ПакетРезультатов[6].Выгрузить();
	Если РезультатНедостачи.Количество()> 0 Тогда 
		ТаблицаНедостачи.Загрузить(РезультатНедостачи); 
		Элементы.ТаблицаНедостачи.Видимость = Истина;
	КонецЕсли;
	
	Если РезультатИзлишки.Количество()= 0 И РезультатНедостачи.Количество()= 0 Тогда
		РасхожденийНет = Истина;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПеремещения(Команда)

	СоздатьДокументыПеремещения("Излишки");
	СоздатьДокументыПеремещения("Недостачи");

КонецПроцедуры

&НаСервере
Процедура СоздатьДокументыПеремещения(Вид)
	
	Если Вид = "Излишки" Тогда
		Товары = ТаблицаИзлишки.Выгрузить();
	Иначе
		Товары = ТаблицаНедостачи.Выгрузить();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.Расхождение КАК Расхождение,
	|	Товары.Склад КАК Склад,
	|	Товары.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА ВТ_Товары.Расхождение < 0
	|			ТОГДА -ВТ_Товары.Расхождение
	|		ИНАЧЕ ВТ_Товары.Расхождение
	|	КОНЕЦ КАК КоличествоУпаковок,
	|	ВТ_Товары.Склад КАК Склад,
	|	ВТ_Товары.ЕдиницаИзмерения КАК Упаковка,
	|	ВЫБОР
	|		КОГДА ВТ_Товары.Расхождение < 0
	|			ТОГДА -ВТ_Товары.Расхождение
	|		ИНАЧЕ ВТ_Товары.Расхождение
	|	КОНЕЦ КАК Количество
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ИТОГИ ПО
	|	Склад";
	Запрос.УстановитьПараметр("Товары", Товары);
	Результат = Запрос.Выполнить();
	
	ВыборкаСклад = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Склад");
	Пока ВыборкаСклад.Следующий() Цикл
		ТаблицаТоваров = Новый ТаблицаЗначений();
		ТаблицаТоваров.Колонки.Добавить("Номенклатура");
		ТаблицаТоваров.Колонки.Добавить("КоличествоУпаковок");
		ТаблицаТоваров.Колонки.Добавить("Количество");
		ТаблицаТоваров.Колонки.Добавить("Упаковка");

		ВыборкаТовары = ВыборкаСклад.Выбрать();
		Пока ВыборкаТовары.Следующий() Цикл
			Если ВыборкаТовары.Склад = Справочники.Склады.ПустаяСсылка() Тогда
				Сообщить("Укажите склад для товара " + ВыборкаТовары.Номенклатура);
			Иначе
				СтрокаТаблицы = ТаблицаТоваров.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТаблицы, ВыборкаТовары);
			КонецЕсли;
		КонецЦикла;
		
		Если ТаблицаТоваров.Количество()> 0 Тогда
			НовыйДокумент = Документы.ПеремещениеТоваров.СоздатьДокумент();
			НовыйДокумент.Дата = ТекущаяДата();
			НовыйДокумент.ДокументОснование = Пересчет;
			Если Вид = "Излишки" Тогда
				НовыйДокумент.СкладОтправитель = ВыборкаСклад.Склад;
				НовыйДокумент.СкладПолучатель = СкладПересчета;
			Иначе
				НовыйДокумент.СкладОтправитель = СкладПересчета;
				НовыйДокумент.СкладПолучатель = ВыборкаСклад.Склад;
			КонецЕсли;
			НовыйДокумент.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
			НовыйДокумент.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
			НовыйДокумент.Товары.Загрузить(ТаблицаТоваров);
			
			Попытка
				НовыйДокумент.Записать();
			
		   		Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = "Создан документ " + НовыйДокумент.Ссылка;
				Сообщение.КлючДанных = НовыйДокумент.Ссылка;
				Сообщение.Сообщить();
			Исключение
				Сообщить(ОписаниеОшибки());
			КонецПопытки;	
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры

