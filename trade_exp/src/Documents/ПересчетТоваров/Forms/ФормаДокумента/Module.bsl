#Область ОтображениеЭлементовФормы

Процедура УстановитьУсловноеОформлениеЭлемента(ЛевоеЗначение, ВидСравнения, ПравоеЗначение, Цвет, ПравоеЗначениеЭтоПутьКДаннымПоля) Экспорт
	
	ЭлементОФормления = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = ЭлементОФормления.Поля.Элементы.Добавить();
    ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Товары.Имя);
		
	Для Каждого Колонка Из Элементы.Товары.ПодчиненныеЭлементы Цикл
 		ПолеЭлемента = ЭлементОФормления.Поля.Элементы.Добавить();
 		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Колонка.Имя);
		
		Если Тип(Колонка) = Тип("ГруппаФормы") Тогда
			Для Каждого Подэлемент Из Колонка.ПодчиненныеЭлементы Цикл
 				ПолеЭлемента = ЭлементОформления.Поля.Элементы.Добавить();
 				ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Подэлемент.Имя);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
		
    ОтборЭлемента = ЭлементОФормления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
    ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных(ЛевоеЗначение);
    ОтборЭлемента.ВидСравнения = ВидСравнения;
    Если ПравоеЗначениеЭтоПутьКДаннымПоля Тогда
		ОтборЭлемента.ПравоеЗначение = Новый ПолеКомпоновкиДанных(ПравоеЗначение);	
	Иначе		
    	ОтборЭлемента.ПравоеЗначение = ПравоеЗначение;      
	КонецЕсли;
    ЭлементОФормления.Оформление.УстановитьЗначениеПараметра("ЦветФона", Цвет);
КонецПроцедуры
 
