#Область ПечатьКомплектаДокументов
&НаКлиенте
Процедура Док_НапечататьКомплектДокументовПосле(Команда)
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Сообщить("Перед печатью комплекта документов необходимо записать пересчет!");
		Возврат;
	КонецЕсли;
	
	КоллекцияПечатныхФорм = ПолучитьКомплектДокументов(Объект.Ссылка);
	ДополнительныеПараметры = Новый Структура("ЗаголовокФормы", "Печать комплекта по пересчету");
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм,,ДополнительныеПараметры);
КонецПроцедуры


&НаСервереБезКонтекста
Функция ПолучитьКомплектДокументов(Ссылка)
	Комплект = Новый Массив();
	ПараметрыПечати = Новый Структура();
	ОбъектыПечати = Новый СписокЗначений();
	
	ПечатнаяФорма = Новый Структура("ИмяМакета,ИмяВРег, ТабличныйДокумент, ОфисныеДокументы, СинонимМакета, Экземпляров,
									|ПолныйПутьКМакету, ДоступенВыводНаДругихЯзыках, Защита, ИмяФайлаПечатнойФормы, ТекстОшибкиФормирования,
									|Картинка");
	ПечатнаяФорма.Экземпляров = 1;
	ПечатнаяФорма.Защита = Ложь;

	
	СвязанныеДокументыПоТипу = ПолучитьСвязанныеДокументы(Ссылка);

	//Результат пересчета товаров	
	ПараметрыПечати.Вставить("ВыводитьГрадацииКачества", Ложь);
	ПараметрыПечати.Вставить("ВыводитьРезультатыПересчета", Истина);
	ПараметрыПечати.Вставить("ДополнитьКомплектВнешнимиПечатнымиФормами", Ложь);
	
	МассивОбъектов = Новый Массив();
	МассивОбъектов.Добавить(Ссылка);
	
	ПересчетТабДок = Документы.ПересчетТоваров.ПечатьЗаданияЭкспорт(МассивОбъектов, ОбъектыПечати, ПараметрыПечати);
	ПересчетТабДок.АвтоМасштаб = Истина;
	ПересчетТабДок.ЭкземпляровНаСтранице = 0;
	ПечатнаяФорма.ИмяМакета = "ЗаданиеНаПересчет";
	ПечатнаяФорма.ИмяВРег = ВРег(ПечатнаяФорма.ИмяМакета);
	ПечатнаяФорма.ТабличныйДокумент = ПересчетТабДок;
	ПечатнаяФорма.СинонимМакета = "Результаты пересчета товаров";
	ПечатнаяФормаПересчета = СкопироватьСтруктуру(ПечатнаяФорма);
	Комплект.Добавить(ПечатнаяФормаПересчета);
	//
	
	ПараметрыПечати = Новый Структура("ПечатьКомплектаДокументовПересчет", Истина);
	
	//Порча товаров - Акт о порче, бое, ломе ТМЦ (ТОРГ-15)
	Документ = СвязанныеДокументыПоТипу.Получить("ПорчаТоваров");
	Если ЗначениеЗаполнено(Документ) Тогда
		ПорчаТабДок = ПорчаТоваровЛокализация.СформироватьПечатнуюФормуТОРГ15Экспорт(Документ, ОбъектыПечати, ПараметрыПечати); 
		ПорчаТабДок.АвтоМасштаб = Истина;
		ПорчаТабДок.ЭкземпляровНаСтранице = 0;
		ПечатнаяФорма.ИмяМакета = "ТОРГ15";
		ПечатнаяФорма.ИмяВРег = ВРег(ПечатнаяФорма.ИмяМакета);
		ПечатнаяФорма.ТабличныйДокумент = ПорчаТабДок;
		ПечатнаяФорма.СинонимМакета = "Акт о порче, бое, ломе ТМЦ (ТОРГ-15) ";
		ПечатнаяФормаПорчи = СкопироватьСтруктуру(ПечатнаяФорма);
		Комплект.Добавить(ПечатнаяФормаПорчи);
	КонецЕсли;
	
	//Пересортица товаров - Акт о пересортице товаров
	Документ = СвязанныеДокументыПоТипу.Получить("ПересортицаТоваров");
	Если ЗначениеЗаполнено(Документ) Тогда
		ПересортицаТабДок = АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(
							Документ, 
							"Печатные формы пересортица", 
							"АктОПересортицеТоваров", 
							ПараметрыПечати);
		ПересортицаТабДок.АвтоМасштаб = Истина;
		ПересортицаТабДок.ЭкземпляровНаСтранице = 0;
		ПечатнаяФорма.ИмяМакета = "АктОПересортицеТоваров";
		ПечатнаяФорма.ИмяВРег = ВРег(ПечатнаяФорма.ИмяМакета);
		ПечатнаяФорма.ТабличныйДокумент = ПересортицаТабДок;
		ПечатнаяФорма.СинонимМакета = "Акт о пересортице товаров";
		ПечатнаяФормаПересортицы = СкопироватьСтруктуру(ПечатнаяФорма);
		Комплект.Добавить(ПечатнаяФормаПересортицы);
	КонецЕсли;
	
	//Оприходование излишков товаров - Акт об оприходовании товаров
	Документ = СвязанныеДокументыПоТипу.Получить("ОприходованиеИзлишковТоваров");
	Если ЗначениеЗаполнено(Документ) Тогда
		ОприходованиеТабДок = Документы.ОприходованиеИзлишковТоваров.ПечатьАктаОбОприходованииТоваровЭкспорт(Документ, ОбъектыПечати);
		ОприходованиеТабДок.АвтоМасштаб = Истина;
		ОприходованиеТабДок.ЭкземпляровНаСтранице = 0;
		ПечатнаяФорма.ИмяМакета = "АктОбОприходованииТоваров";
		ПечатнаяФорма.ИмяВРег = ВРег(ПечатнаяФорма.ИмяМакета);
		ПечатнаяФорма.ТабличныйДокумент = ОприходованиеТабДок;
		ПечатнаяФорма.СинонимМакета = "Акт об оприходовании товаров";
		ПечатнаяФормаОприходования = СкопироватьСтруктуру(ПечатнаяФорма);
		Комплект.Добавить(ПечатнаяФормаОприходования);
	КонецЕсли;
	
	//Списание недостач товаров - Акт о списании товаров (ТОРГ-16)
	Документ = СвязанныеДокументыПоТипу.Получить("СписаниеНедостачТоваров");
	Если ЗначениеЗаполнено(Документ) Тогда
		СписаниеТабДок = АльтерраОбщегоНазначения.ВыполнитьКомандуПечатиВнешнейОбработки(
							Документ, 
							"Печатные формы списание товаров (ТОРГ16)", 
							"ТОРГ16", 
							ПараметрыПечати);
		СписаниеТабДок.АвтоМасштаб = Истина;
		СписаниеТабДок.ЭкземпляровНаСтранице = 0;
		ПечатнаяФорма.ИмяМакета = "ТОРГ16";
		ПечатнаяФорма.ИмяВРег = ВРег(ПечатнаяФорма.ИмяМакета);
		ПечатнаяФорма.ТабличныйДокумент = СписаниеТабДок;
		ПечатнаяФорма.СинонимМакета = "Акт о списании товаров (ТОРГ-16)";
		ПечатнаяФормаСписания = СкопироватьСтруктуру(ПечатнаяФорма);
		Комплект.Добавить(ПечатнаяФормаСписания);
	КонецЕсли;
			
	Возврат Комплект;
КонецФункции

&НаСервереБезКонтекста
Функция СкопироватьСтруктуру(Источник)
	Приемник = Новый Структура();
	Для каждого Элемент из Источник Цикл
		Приемник.Вставить(Элемент.Ключ, Элемент.Значение);
	КонецЦикла;
	Возврат Приемник;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСвязанныеДокументы(Ссылка)
	СвязанныеДокументыПоТипу = Новый Соответствие();
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	СписаниеНедостачТоваров.Ссылка КАК Ссылка,
	                      |	""СписаниеНедостачТоваров"" КАК Ключ
	                      |ИЗ
	                      |	Документ.СписаниеНедостачТоваров КАК СписаниеНедостачТоваров
	                      |ГДЕ
	                      |	СписаниеНедостачТоваров.ПересчетТоваров = &Ссылка
	                      |	И СписаниеНедостачТоваров.Проведен
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	ОприходованиеИзлишковТоваров.Ссылка,
	                      |	""ОприходованиеИзлишковТоваров""
	                      |ИЗ
	                      |	Документ.ОприходованиеИзлишковТоваров КАК ОприходованиеИзлишковТоваров
	                      |ГДЕ
	                      |	ОприходованиеИзлишковТоваров.ПересчетТоваров = &Ссылка
	                      |	И ОприходованиеИзлишковТоваров.Проведен
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	ПересортицаТоваров.Ссылка,
	                      |	""ПересортицаТоваров""
	                      |ИЗ
	                      |	Документ.ПересортицаТоваров КАК ПересортицаТоваров
	                      |ГДЕ
	                      |	ПересортицаТоваров.ПересчетТоваров = &Ссылка
	                      |	И ПересортицаТоваров.Проведен
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	ПорчаТоваров.Ссылка,
	                      |	""ПорчаТоваров""
	                      |ИЗ
	                      |	Документ.ПорчаТоваров КАК ПорчаТоваров
	                      |ГДЕ
	                      |	ПорчаТоваров.ПересчетТоваров = &Ссылка
	                      |	И ПорчаТоваров.Проведен");
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивОбъектов = СвязанныеДокументыПоТипу.Получить(Выборка.Ключ);
		МассивОбъектов = ?(ЗначениеЗаполнено(МассивОбъектов), МассивОбъектов, Новый Массив());
		МассивОбъектов.Добавить(Выборка.Ссылка);
		СвязанныеДокументыПоТипу.Вставить(Выборка.Ключ, МассивОбъектов);
	КонецЦикла;
	
	Возврат СвязанныеДокументыПоТипу;
КонецФункции
#КонецОбласти









