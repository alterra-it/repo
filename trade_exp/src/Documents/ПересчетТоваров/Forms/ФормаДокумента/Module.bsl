Процедура УстановитьОтображениеКолонокТаблицы_НовыйРасчетОтклонения(ТаблицаТовары)
	Элементы.ТоварыКоличествоУпаковок.Заголовок = "По учету (весь товар)";         
	Элементы.Переместить(Элементы.ТоварыКоличествоУпаковок, Элементы.ГруппаНовыйРасчетОтклонения);
	Элементы.Переместить(Элементы.ГруппаНовыйРасчетОтклонения_СкрываемыеКолонки, Элементы.ГруппаНовыйРасчетОтклонения);
	
	НовыйЭлемент = Элементы.Добавить("ТоварыЯПХ", Тип("ПолеФормы"), ТаблицаТовары);
	НовыйЭлемент.Заголовок = "По учету (в ЯПХ)"; 
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = "Объект.Товары.ЯПХ";
	НовыйЭлемент.Видимость = Истина;
	НовыйЭлемент.ТолькоПросмотр = Истина;
	Элементы.Переместить(НовыйЭлемент, Элементы.ГруппаНовыйРасчетОтклонения_СкрываемыеКолонки);
	
	НовыйЭлемент = Элементы.Добавить("ТоварыКоличествоПоУчетуВЗонеХранения", Тип("ПолеФормы"), ТаблицаТовары);
	НовыйЭлемент.Заголовок = "По учету (в зоне хранения)";
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = "Объект.Товары.КоличествоПоУчетуВЗонеХранения";
	НовыйЭлемент.Видимость = Истина;
	НовыйЭлемент.ТолькоПросмотр = Истина;
	Элементы.Переместить(НовыйЭлемент, Элементы.ГруппаНовыйРасчетОтклонения_СкрываемыеКолонки);
		
	Элементы.ТоварыКоличествоУпаковокФакт.Заголовок = "Факт";
	Элементы.Переместить(Элементы.ТоварыКоличествоУпаковокФакт, Элементы.ГруппаНовыйРасчетОтклонения);
	
	Элементы.Переместить(Элементы.ТоварыКоличествоУпаковокОтклонение, Элементы.ГруппаНовыйРасчетОтклонения);
