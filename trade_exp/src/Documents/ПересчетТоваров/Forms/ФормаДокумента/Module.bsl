Процедура СоздатьБлокировку()
	ДокументРазблокировки = ПолучитьДокументБлокировки("Разблокировано");
	Если ЗначениеЗаполнено(ДокументРазблокировки) И НЕ ДокументРазблокировки.ПометкаУдаления Тогда 
		ДокБлокировкаОбъект = ДокументРазблокировки.ПолучитьОбъект();
	    ДокБлокировкаОбъект.ПометкаУдаления = Истина;
	    ДокБлокировкаОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		АльтерраОбщегоНазначения.СообщитьПользователю(ДокументРазблокировки,  "Документ разблокировки: " + ДокументРазблокировки + " помечен на удаление");
	КонецЕсли;
	РеквизитФормыВЗначение("Объект").Ссылка.ПолучитьОбъект().СоздатьБлокировку("Нет на складе");
