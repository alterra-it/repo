&НаСервере
Процедура ЗаполнитьБлокировкуПоПересортице(ДокументПересчета, ПричинаБлокировкиУникальныйИдентификатор)
	
	ПричинаБлокировки = Справочники.ПричиныБлокировкиДвиженияТоваров.ПолучитьСсылку(ПричинаБлокировкиУникальныйИдентификатор);
	Склад = ДокументПересчета.Склад;
	ДатаСеанса = ТекущаяДатаСеанса();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	БлокировкаДвиженияТоваровОстатки.Номенклатура КАК Номенклатура,
	|	БлокировкаДвиженияТоваровОстатки.Характеристика КАК Характеристика,
	|	БлокировкаДвиженияТоваровОстатки.КоличествоОстаток КАК КоличествоУпаковок
	|ИЗ
	|	РегистрНакопления.БлокировкаДвиженияТоваров.Остатки(&Дата, Склад = &Склад и ПричинаБлокировки = &ПричинаБлокировки и Номенклатура В (&СписокНоменклатуры)) КАК БлокировкаДвиженияТоваровОстатки";

	Запрос.УстановитьПараметр("Дата", ДатаСеанса);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("ПричинаБлокировки", ПричинаБлокировки);
	Запрос.УстановитьПараметр("СписокНоменклатуры", ДокументПересчета.Товары.Выгрузить(, "Номенклатура"));
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда
		ДокументБлокировки = ПолучитьДокументБлокировки("Разблокировано");
		Если НЕ ЗначениеЗаполнено(ДокументБлокировки) Тогда
			ДокументБлокировки = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
		Иначе
			ДокументБлокировки = ДокументБлокировки.ПолучитьОбъект();
		КонецЕсли;
		ДокументБлокировки.Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Разблокировано;
		ДокументБлокировки.Склад = Склад;
		ДокументБлокировки.ПричинаБлокировки = ПричинаБлокировки;
		ДокументБлокировки.Ответственный = ПользователиКлиентСервер.ТекущийПользователь();
		ДокументБлокировки.ДокументОснование = ДокументПересчета;
		ДокументБлокировки.Дата = ДатаСеанса;
		//Для обновления списка товаров в разблокировке, если она уже была создана и потом удалена
		ДокументБлокировки.ПометкаУдаления = Ложь;
		ДокументБлокировки.Товары.Очистить();
		//
		ДокументБлокировки.Товары.Загрузить(РезультатЗапроса.Выгрузить());
		ДокументБлокировки.Записать(РежимЗаписиДокумента.Проведение);
		АльтерраОбщегоНазначения.СообщитьПользователю(ДокументБлокировки.Ссылка, "Создан/обновлен документ: " + ДокументБлокировки.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьБлокирокиПоТоварам();
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект"); 
	ТаблицаЗначенийБлокировок = ДокументОбъект.ПолучитьБлокировкиПоТоварам();
	
	Для Каждого СтрокаБлокировки Из ТаблицаЗначенийБлокировок Цикл
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура", СтрокаБлокировки.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", СтрокаБлокировки.Характеристика);
		
		НайденныеТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		
		Для Каждого СтрокаТоваров Из НайденныеТовары Цикл
			СтрокаТоваров.БлокировкаТоваров = СтрокаБлокировки.Блокировка;
		КонецЦикла;
		
	КонецЦикла;
КонецПроцедуры   

