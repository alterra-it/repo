&НаСервере
Процедура НастройкаОтображенияГруппыПодтверждения()
	
	ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач = 
			СкладыСервер.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач(Объект.Склад, Объект.Дата); 
		
    Элементы._Подтверждение.Видимость = ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач;
	
	Элементы.ПодтвержденСкладом.Доступность = РольДоступнаПодтверждениеСкладом();
	
	Элементы.ПодтвержденОтделомКачества.Доступность = РольДоступнаПодтверждениеОтделомКачества();
	
	Если ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач Тогда
		ЕстьСлужебнаяЗаписка();
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПодтвержденСкладомПриИзмененииПосле(Элемент)
	Если ИзменитьСтатусДокумента() Тогда
		ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма);
	КонецЕсли;
	УстановитьДоступностьТЧ();
КонецПроцедуры

&НаКлиенте
Процедура Док_ПодтвержденОтделомКачестваПриИзмененииПосле(Элемент)
	Если ИзменитьСтатусДокумента() Тогда
		ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма);
	КонецЕсли;
	Если Объект.ПодтвержденОтделомКачества и АльтерраОбщегоНазначения.ЭтоРабочаяБаза() И ИспользуетсяОрдернаяСхема() Тогда  
		ОтправитьОповещенияОНехваткеМенеджеру();
	КонецЕсли;	
	УстановитьДоступностьТЧ();
КонецПроцедуры 

&НаСервере
Процедура ОтправитьОповещенияОНехваткеМенеджеру()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.КоличествоУпаковокОтклонение КАК Отклонение
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	&Товары КАК Товары
		|ГДЕ
		|	Товары.КоличествоУпаковокОтклонение < 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Номенклатура КАК Номенклатура,
		|	ВТ.Характеристика КАК Характеристика,
		|	СпрНазначения.Ссылка КАК Назначение,
		|	-ВТ.Отклонение КАК КоличествоНехватка,
		|	ЗаказКлиента.Менеджер КАК Менеджер,
		|	ЗаказКлиента.Номер КАК НомерЗаказа
		|ИЗ
		|	Справочник.Назначения КАК СпрНазначения
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ КАК ВТ
		|		ПО СпрНазначения.Ссылка = ВТ.Назначение
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиента
		|		ПО СпрНазначения.Ссылка.Заказ = ЗаказКлиента.Ссылка";
	ТЗТовары = Объект.Товары.Выгрузить();
	Запрос.УстановитьПараметр("Товары", ТЗТовары);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ТекстСообщения = СтрШаблон("В результате пересчета № %1 на %2 обнаружена нехватка товара %3 %4 по заказу %5 в количестве %6", Объект.Номер, Объект.Склад,  
			Выборка.Номенклатура, Выборка.Характеристика, Выборка.НомерЗаказа, Выборка.КоличествоНехватка);
		АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(ТекстСообщения, Выборка.Менеджер);
	КонецЦикла;
	

	
КонецПроцедуры

&НаКлиенте                        
Процедура УстановитьДоступностьТЧ()
	Если (Объект.ПодтвержденОтделомКачества ИЛИ Объект.ПодтвержденСкладом) И ИспользуетсяОрдернаяСхема() Тогда
		Элементы.Товары.ТолькоПросмотр = Истина;
	Иначе
		Элементы.Товары.ТолькоПросмотр = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере                    
Функция ИзменитьСтатусДокумента()
	
	ПровестиДокумент = Ложь;                    
	
	Если Объект.ПодтвержденОтделомКачества И ИспользуетсяОрдернаяСхема() Тогда 
		
		Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Выполнено;
		ПровестиДокумент = Истина;
		
	КонецЕсли;
	
	Если (Объект.ПодтвержденОтделомКачества = Ложь И Объект.ПодтвержденСкладом = Ложь) И ИспользуетсяОрдернаяСхема() Тогда
		
		Объект.Статус = Перечисления.СтатусыПересчетовТоваров.ВнесениеРезультатов; 
		ПровестиДокумент = Истина;
		
	КонецЕсли;
	
	Возврат ПровестиДокумент; 

КонецФункции

&НаСервере
Функция Док_СтатусПриИзмененииПослеНаСервере()
	
	ПрошлыйСтатус = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "Статус");
	ПодтвержденСкладом = Объект.ПодтвержденСкладом;
    ПодтвержденОК = Объект.ПодтвержденОтделомКачества;
	ПересчетПоУчетуБезВопроса = Ложь;
	
	Если Объект.Ссылка.Пустая() И Объект.Склад.ИспользоватьСтатусыПересчетовТоваров Тогда
		ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Подготовлено;
	КонецЕсли;	
	
	Если Объект.Статус <> ПрошлыйСтатус Тогда
		
		Если Не ЗначениеЗаполнено(Объект.Статус) И ЗначениеЗаполнено(ПрошлыйСтатус) Тогда
			Объект.Статус = ПрошлыйСтатус;
		ИначеЕсли Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Подготовлено И ЗначениеЗаполнено(ПрошлыйСтатус) Тогда
			ТекстСообщения = НСтр("ru = 'Запрещено изменение статуса на <Подготовлено> с любых других статусов'");
		ИначеЕсли ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Выполнено Тогда
			
			Если (ПодтвержденСкладом ИЛИ ПодтвержденОК) И НЕ ИспользуетсяОрдернаяСхема() Тогда
				ТекстСообщения = НСтр("ru = 'Невозможно изменить статус, так как документ подтвержден.'");
			КонецЕсли;
			
		ИначеЕсли Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Выполнено Тогда
			
			Если Не (ПодтвержденСкладом И ПодтвержденОК) И ИспользуетсяОрдернаяСхема() Тогда
				ТекстСообщения = НСтр("ru = 'Невозможно изменить статус, так как документ не подтвержден.'");
			КонецЕсли;
			
		ИначеЕсли (Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Отменено) И Не ЗначениеЗаполнено(Объект.Комментарий) Тогда
			ТекстСообщения = НСтр("ru = 'Для статуса Отменено необходимо добавить комментарий'");  
		ИначеЕсли Объект.Статус = Перечисления.СтатусыПересчетовТоваров.ВРаботе 
			И Не Объект.Ссылка.Проведен
			И Объект.Склад.ИспользоватьСтатусыПересчетовТоваров Тогда
			
			ТекстСообщения = НСтр("ru = 'Статус В работе можно выбирать только в проведенных документах'");
		КонецЕсли;
				
		Если Не ПустаяСтрока(ТекстСообщения) Тогда // обработка ошибок
			Объект.Статус = ПрошлыйСтатус;
			УстановитьСостояниеРедактированияПоСтатусу();
			АльтерраОбщегоНазначения.СообщитьПользователю(,ТекстСообщения,"Статус");
		Иначе
			ПересчетПоУчетуБезВопроса = ИнициироватьПересчетПоУчету(ПрошлыйСтатус);
		КонецЕсли;
		
		Если Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Отменено Тогда
			Если Объект.Проведен Тогда
				ДокОбъект = РеквизитФормыВЗначение("Объект");
				ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
				ЗначениеВРеквизитФормы(ДокОбъект, "Объект");				
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ПересчетПоУчетуБезВопроса;
	
КонецФункции

&НаСервере
Функция ИнициироватьПересчетПоУчету(ПрошлыйСтатус)
	
	Если (ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.ВнесениеРезультатов ИЛИ
		ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Подготовлено ИЛИ
		ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Выполнено ИЛИ
		ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Отменено ИЛИ
		ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Приостановлено)
		
		И Объект.Статус = Перечисления.СтатусыПересчетовТоваров.ВРаботе
		И СкладыСервер.ИспользоватьОрдернуюСхемуПриОтраженииИзлишковНедостач(Объект.Склад, Объект.Дата) Тогда
		
		Если ПрошлыйСтатус = Перечисления.СтатусыПересчетовТоваров.Подготовлено Тогда
			Возврат Истина;
		Иначе
			УчетныеДанныеЗаполнены_Альтерра = Ложь;
		КонецЕсли;
	КонецЕсли; 
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура Док_ПередЗаписьюВместо(Отказ, ПараметрыЗаписи) 
	
	Если Не ВыполняетсяЗапись И Не Отказ Тогда
		
		Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение
			И (Не Объект.УчетныеДанныеЗаполнены ИЛИ Не УчетныеДанныеЗаполнены_Альтерра) 
			И Объект.Товары.Количество() > 0 Тогда
			
			ТекстВопроса = НСтр("ru='При проведении будет перезаполнено учетное количество во всех строках табличной части. Продолжить?'");
			
			ПоказатьВопрос(Новый ОписаниеОповещения("ПередЗаписьюЗавершение", ЭтотОбъект), 
			ТекстВопроса,
			РежимДиалогаВопрос.ОКОтмена,
			,
			КодВозвратаДиалога.ОК);
			Отказ = Истина;
			
		Иначе
			ПередЗаписью_После();
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПередЗаписьюЗавершение")
Процедура Док_ПередЗаписьюЗавершение(РезультатВопроса, ДополнительныеПараметры)
	
	Если РезультатВопроса <> КодВозвратаДиалога.ОК Тогда
		Возврат;	
	КонецЕсли;
	
#Вставка
	НетиповойПересчетПоУчету(Неопределено);
#КонецВставки
	
	ВыполняетсяЗапись = Истина;
	Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));
	ВыполняетсяЗапись = Ложь;
	
#Вставка
	ПередЗаписью_После();
#КонецВставки
	
КонецПроцедуры

&НаКлиенте                          
Процедура ПередЗаписью_После()  	
	
    Режим = РежимДиалогаВопрос.ДаНет; 
    
    Если Объект.ПодтвержденОтделомКачества И ИспользуетсяОрдернаяСхема() И РольДоступнаПодтверждениеОтделомКачества() Тогда
        
		ДокБлокировка = ПолучитьДокументБлокировки("Заблокировано");	
		Если НЕ ДокБлокировка.Пустая() ИЛИ НЕ Объект.ПометкаУдаления Тогда         
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаРазблокировать", ЭтотОбъект,);
			ПоказатьВопрос(Оповещение, "Снять блокировки по причине ""нет на складе""?", Режим, 0);
		КонецЕсли;
		
    ИначеЕсли Строка(Объект.Статус) = "Внесение результатов" И ИспользуетсяОрдернаяСхема()Тогда
   		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаСоздатьБлокировку", ЭтотОбъект, );
		ПоказатьВопрос(Оповещение, "Создать блокировку на минусовые отклонения?", Режим, 0);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_СтатусПриИзмененииПосле(Элемент)
	
	//Перезаполнение таб части при взятии в работу 
	
	ВРаботе = Ложь;	
	
	Если (Объект.ПодтвержденОтделомКачества ИЛИ Объект.ПодтвержденСкладом) И ИспользуетсяОрдернаяСхема() Тогда  
		Подтвержден = Истина;
	Иначе
		Подтвержден = Ложь;
	КонецЕсли;
	

		Если ВзятьВРаботу() и Не Подтвержден  Тогда 
			
			ВРаботе = Истина;
			Если ЗначениеЗаполнено(Объект.ТочкаПересчета) Тогда  // для ТЗ перезаполнять таб часть не нужно
				Если Не ДопМодуль.Тип_ТоварПодОстаток(Объект.Ссылка)  Тогда    
					
					Режим = РежимДиалогаВопрос.ДаНет;	
					Ответ = Вопрос("Перезаполнить данные по учету? Табличная часть будет очищена!", Режим, 0); 
					
					Если Ответ = КодВозвратаДиалога.Да Тогда 	
						ПерезаполнитьПоОтбору();				
					Иначе 
						Объект.Статус =	ПолучитьПрошлыйСтатус();
						ВРаботе = Ложь;
					КонецЕсли; 
					
				КонецЕсли; 
			КонецЕсли;
		
	КонецЕсли;
	// Конец Перезаполнение таб части
	
	
	УчетныеДанныеЗаполнены_Альтерра = Истина;
	
	Если Док_СтатусПриИзмененииПослеНаСервере() Или ВРаботе Тогда // ПересчетПоУчетуБезВопроса 
		ПередЗаписьюЗавершение(КодВозвратаДиалога.ОК, Неопределено);
	КонецЕсли; 
	
КонецПроцедуры
 

&НаКлиенте
Процедура ПерезаполнитьПоОтбору()  
	
	Если ЗначениеЗаполнено(Объект.РабочийУчасток) Тогда
		УстановитьОтбор(Элементы.РабочийУчасток.Имя, ВидСравненияКомпоновкиДанных.Равно, Объект.РабочийУчасток, 1); 
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Объект.ТочкаПересчета) Тогда
		УстановитьОтбор(Элементы.ТочкаПересчета.Имя, ВидСравненияКомпоновкиДанных.ВИерархии, Объект.ТочкаПересчета, 1); 
	КонецЕсли; 
	
	ЗаполнитьСервер();  
КонецПроцедуры

&НаСервере 
Функция ПолучитьПрошлыйСтатус()
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ссылка, "Статус"); 
КонецФункции

&НаКлиенте
Процедура Док_СтраницыФормыПриСменеСтраницыПосле(Элемент, ТекущаяСтраница)
