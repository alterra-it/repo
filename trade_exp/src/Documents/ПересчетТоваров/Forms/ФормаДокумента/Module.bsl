&НаКлиенте 
Перем НужноЗакрыватьФорму; 

#Область СобытияФормы

&НаСервере
Процедура Док_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
	УчетныеДанныеЗаполнены_Альтерра = Истина;
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	НастройкаОтображенияГруппыПодтверждения();
	
	Если Параметры.Свойство("Сотрудник") Тогда
		Объект.ИсполнительСотрудник = Параметры.Сотрудник;
		Для каждого СтрокаТЧ из Объект.ИсполнительСотрудник.РабочиеУчастки Цикл
			СекцииСотрудника.Добавить(СтрокаТЧ.РабочийУчасток);
		КонецЦикла;
	КонецЕсли;
	
	ДоступныеЯчейки.Параметры.УстановитьЗначениеПараметра("Ссылка",СекцииСотрудника.ВыгрузитьЗначения());
	
	АдресаЯчеек.Параметры.УстановитьЗначениеПараметра("Ссылка",Объект.Ссылка);
	
	Элементы.ИсключитьИзКонтроля.Доступность= РольДоступна("РазрешитьИсключатьДокументыИзКонтроляОрдерногоУчета");
	Элементы.Склад.ТолькоПросмотр = (ЗначениеЗаполнено(Объект.Склад) И (Объект.Товары.Количество() > 0));  
	
	НовыйПараметр = Новый ПараметрВыбора("Отбор.ПометкаУдаления", Ложь);   
	НовыйМассив = Новый Массив();
	НовыйМассив.Добавить(НовыйПараметр);
	НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
	Элементы.РабочийУчасток.ПараметрыВыбора = НовыеПараметры;
		
	ОграничениеДоступностиОстатков = АльтерраОбщегоНазначения.ПолучитьОграничениеДоступностиОстатков();
	
	УстановитьОтображениеКолонокТаблицы();
	ЗаполнитьБлокирокиПоТоварам();
	УстановитьУсловноеОформлениеТаблицы();
	УстановитьВидимостьПоУчету();      
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.Дата = ТекущаяДата();    
	КонецЕсли;
	
	ДействияПоТипуПересчета();
	
	ИнициализироватьНовыйРасчетОтклонения();
	
	СкорректироватьУсловноеОформление();

КонецПроцедуры      

#Область СкорректироватьУсловноеОформление

&НаСервере
Процедура СкорректироватьУсловноеОформление()
	Проверка = ИспользуетсяОрдернаяСхема();
	СписокВыбора = Элементы.Статус.СписокВыбора;

	СписокВыбора.Очистить();
	Элементы.Статус.СписокВыбора.Очистить();
	
	СписокВыбора.Добавить(Перечисления.СтатусыПересчетовТоваров.Подготовлено);
	СписокВыбора.Добавить(Перечисления.СтатусыПересчетовТоваров.ВРаботе);
	СписокВыбора.Добавить(Перечисления.СтатусыПересчетовТоваров.ВнесениеРезультатов);
	СписокВыбора.Добавить(Перечисления.СтатусыПересчетовТоваров.Выполнено);

	Если ТипЗнч(Проверка) = Тип("Булево") Тогда
		Если Проверка Тогда
			Элементы.ДвиженияПоРасхождениям.Видимость = Ложь;
			Элементы.ТоварыПриход.Видимость = Ложь;
			Элементы.ТоварыРасход.Видимость = Ложь;
			СписокВыбора.Добавить(Перечисления.СтатусыПересчетовТоваров.Отменено);
			СписокВыбора.Добавить(Перечисления.СтатусыПересчетовТоваров.Приостановлено);
		Иначе
			Элементы.Статус.Видимость = Истина;
			Элементы.ДвиженияПоРасхождениям.Видимость = Истина;
			Элементы.ТоварыПриход.Видимость = Истина;
			Элементы.ТоварыРасход.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УбратьУсловноеОформлениеУПересчетаБезСтатуса()
	Результат = НайтиНужныйЭлементУО();
	
	Если Результат <> Неопределено Тогда
		УсловноеОформление.Элементы.Удалить(Результат);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеУПересчетаСоСтатусом()
	Если НайтиНужныйЭлементУО() <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыКоличествоУпаковокОтклонение.Имя);
	
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.ТоварыКоличествоУпаковокФакт.Имя);

	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Статус");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить(Перечисления.СтатусыПересчетовТоваров.ВРаботе);
	СписокЗначений.Добавить(Перечисления.СтатусыПересчетовТоваров.Подготовлено);
	ОтборЭлемента.ПравоеЗначение = СписокЗначений;

	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветТекстаОтмененнойСтрокиДокумента);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<для внесения результата>'"));
	Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
КонецПроцедуры

&НаСервере
Функция НайтиНужныйЭлементУО()
	ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Статус");
	Для Каждого Элемент Из УсловноеОформление.Элементы Цикл
		Для Каждого ЭлементОтбора Из Элемент.Отбор.Элементы Цикл 
			Если ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") И ЭлементОтбора.ЛевоеЗначение = ЛевоеЗначение Тогда
				Возврат Элемент; 
			КонецЕсли;
		КонецЦикла;
	КонецЦикла; 
	
	Возврат Неопределено;
КонецФункции

#КонецОбласти

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	
	ИнициализироватьСканер();

	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		Если АльтерраОбщегоНазначения._РольДоступна("РаботаСТСД") Тогда
		Элементы.СтраницыФормы.Видимость=Истина;
		Элементы.ГруппаИнформация.Видимость=Ложь;
		Элементы.УсловияПересчетаТоваров.Видимость=Ложь;
		Элементы.ГруппаТоварыШапка.Видимость=Ложь;
		Элементы._ШапкаТСД.Видимость=Истина;
		Элементы.Товары.Видимость=Ложь;
		Элементы.ГруппаИнвентаризационныеОписи.Видимость=Ложь;
		Элементы.ИсполнительСотрудник.Видимость=Ложь;
	КонецЕсли;
   #КонецЕсли
   
	Если НЕ АльтерраОбщегоНазначения._ЕстьРоль("ПодтверждениеОтделомКачества") ИЛИ НЕ Объект.Проведен Тогда
		Элементы.ОчиститьПересортицу.Доступность = Ложь;
		Элементы.ОчиститьБлокировкуНетНаСкладе.Доступность = Ложь;
	КонецЕсли;
	
	Элементы.Дата.ТолькоПросмотр = НЕ АльтерраОбщегоНазначения._ЕстьРоль("ИзменениеДатыВПересчетеТоваров");
	
	Если НЕ АльтерраОбщегоНазначения._РольДоступна("ПолныеПрава") Тогда
		Если ЗначениеЗаполнено(Объект.ВремяНачала) Тогда
			Элементы.ВремяНачала.Доступность = Ложь;	
		КонецЕсли;
		Если ЗначениеЗаполнено(Объект.ВремяОкончания) Тогда
			Элементы.ВремяОкончания.Доступность = Ложь;	
		КонецЕсли;
	КонецЕсли;
	
	Проверка = ИспользуетсяОрдернаяСхема();
	Если ТипЗнч(Проверка) = Тип("Булево") Тогда
		Если Проверка Тогда
			Элементы.ДвиженияПоРасхождениям.Видимость = Ложь;
			Элементы.ТоварыПриход.Видимость = Ложь;
			Элементы.ТоварыРасход.Видимость = Ложь;
		Иначе
			Элементы.ДвиженияПоРасхождениям.Видимость = Истина;
			Элементы.ТоварыПриход.Видимость = Истина;
			Элементы.ТоварыРасход.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ВремяНачала <> Дата(1,1,1) И Объект.ВремяОкончания <> Дата(1,1,1) Тогда
		Элементы.ДвиженияПоРасхождениям.Доступность = Истина;
	Иначе
		Элементы.ДвиженияПоРасхождениям.Доступность = Ложь;
	КонецЕсли;
	
   ЭтаФорма.ОбновитьОтображениеДанных();
   
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ОбработкаОповещения")
Процедура Док_ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
		// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		#Удаление
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Параметр));
		КонецЕсли; 
		#КонецУдаления
		#Вставка
		Если (ИмяСобытия = "ScanData" ИЛИ ИмяСобытия = "Barcode") И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;
			
			Если ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.НовыйШтрихкод Тогда
				НовыйШтрихкод = "";
				Если ТипЗнч(Параметр) = Тип("Строка") Тогда
					НовыйШтрихкод = Параметр;
				КонецЕсли;
			Иначе
				ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Штрихкод1));
			КонецЕсли;
			
			//+Альтерра
			ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
			Если ТекущиеДанные <> Неопределено Тогда
				Если Не ЗначениеЗаполнено(ТекущиеДанные.СпособВводаКоличестваТовара) Тогда
					ТекущиеДанные.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Сканер");
				КонецЕсли;	
				ТекущиеДанные.Отсканирован = Истина;
			КонецЕсли;
			//-
		КонецЕсли;
	    #КонецВставки
	КонецЕсли;
	// Конец ПодключаемоеОборудование
	
	// СтандартныеПодсистемы.Свойства 
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства

	// Неизвестные штрихкоды
	Если Источник = "ПодключаемоеОборудование"
		И ИмяСобытия = "НеизвестныеШтрихкоды"
		И Параметр.ФормаВладелец = УникальныйИдентификатор Тогда
		
		КэшированныеЗначения.Штрихкоды.Очистить();
		ДанныеШтрихкодов = Новый Массив;
		
		Для Каждого ПолученныйШтрихкод Из Параметр.ПолученыНовыеШтрихкоды Цикл
			ДанныеШтрихкодов.Добавить(ПолученныйШтрихкод);
		КонецЦикла;
		
		Для Каждого ПолученныйШтрихкод Из Параметр.ЗарегистрированныеШтрихкоды Цикл
			ДанныеШтрихкодов.Добавить(ПолученныйШтрихкод);
		КонецЦикла;
		
		ОбработатьШтрихкоды(ДанныеШтрихкодов);
		
		#Вставка
		//+Альтерра
		ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
		Если ТекущиеДанные <> Неопределено Тогда
			Если Не ЗначениеЗаполнено(ТекущиеДанные.СпособВводаКоличестваТовара) Тогда
				ТекущиеДанные.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Сканер");
			КонецЕсли;	
			ТекущиеДанные.Отсканирован = Истина;
		КонецЕсли;
		//-
        #КонецВставки
		
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте 
&После("ПослеЗаписи")
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	Если РольДоступнаПодтверждениеОтделомКачества()	и Объект.Проведен Тогда
		Элементы.ОчиститьПересортицу.Доступность = Истина;
		Элементы.ОчиститьБлокировкуНетНаСкладе.Доступность = Истина;
	КонецЕсли;
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВРаботе") И НЕ ИспользуетсяОрдернаяСхема() Тогда
		Если Объект.ВремяНачала = Дата(1,1,1) Тогда
			Объект.ВремяНачала = ТекущаяДата();
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПересчетовТоваров.ВнесениеРезультатов") И НЕ ИспользуетсяОрдернаяСхема() Тогда
		Если Объект.ВремяОкончания = Дата(1,1,1) ИЛИ Объект.ВремяОкончания<=Объект.ВремяНачала Тогда
			Объект.ВремяОкончания = ТекущаяДата();
			Элементы.ДвиженияПоРасхождениям.Доступность = Истина;
		КонецЕсли;
	КонецЕсли;
	
	УчетныеДанныеЗаполнены_Альтерра = Истина;
КонецПроцедуры            

&НаКлиенте
&ИзменениеИКонтроль("ОбработатьШтрихкоды")
Процедура Док_ОбработатьШтрихкоды(ДанныеШтрихкодов)
	
	Если Не ШтрихкодированиеНоменклатурыКлиент.ШтрихкодыВалидны(ДанныеШтрихкодов) Тогда
		Возврат;
	КонецЕсли;
	
	ИзменятьКоличество = Не (СостояниеРедактирования = "НеРедактируется"); 
	
	СтруктураДействийСДобавленнымиСтроками = Новый Структура;
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	СтруктураДействийСДобавленнымиСтроками.Вставить("ПроверитьСериюРассчитатьСтатус", Новый Структура("Склад, ПараметрыУказанияСерий", Объект.Склад, ПараметрыУказанияСерий));
	СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействийСДобавленнымиСтроками);
	
	Если СостояниеРедактирования = "ОграниченноеРедактирование" Тогда
		СтруктураДействийСДобавленнымиСтроками.Вставить("ЗаполнитьФлагИзлишекПорча");
	КонецЕсли;
	
	СтруктураДействийСИзмененнымиСтроками = Новый Структура;
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействийСИзмененнымиСтроками);
	
	СтруктураДействий = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	
	СтруктураДействий.Штрихкоды                              = ДанныеШтрихкодов;
	СтруктураДействий.СтруктураДействийСДобавленнымиСтроками = СтруктураДействийСДобавленнымиСтроками;
	СтруктураДействий.СтруктураДействийСИзмененнымиСтроками  = СтруктураДействийСИзмененнымиСтроками;
	СтруктураДействий.ПараметрыУказанияСерий                 = ПараметрыУказанияСерий;
	СтруктураДействий.ИмяКолонкиКоличество                   = "КоличествоУпаковокФакт";
	СтруктураДействий.НеИспользоватьУпаковки                 = Не ИспользоватьАдресноеХранение;
	СтруктураДействий.ИзменятьКоличество                     = ИзменятьКоличество;
	СтруктураДействий.ТолькоТовары                           = Истина;
	
	ОбработатьШтрихкодыСервер(СтруктураДействий,КэшированныеЗначения);
	
	ШтрихкодированиеНоменклатурыКлиент.ОбработатьНеизвестныеШтрихкоды(СтруктураДействий,КэшированныеЗначения,ЭтаФорма);
	
	Если ШтрихкодированиеНоменклатурыКлиент.НужноОткрытьФормуУказанияСерийПослеОбработкиШтрихкодов(СтруктураДействий) Тогда
		
		ТекущиеДанныеИдентификатор = СтруктураДействий.МассивСтрокССериями[0];
		
		ПодключитьОбработчикОжидания("ОткрытьПодборСерийПриСканированииШтрихкодаНоменклатуры",0.1,Истина);
			
	КонецЕсли;
	
	Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
		Элементы.Товары.ТекущаяСтрока = СтруктураДействий.ТекущаяСтрока;
	КонецЕсли;
	
	#Вставка   
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		ТекущаяСтрокаТСД = СтруктураДействий.ТекущаяСтрока;
		
		Если типзнч(СтруктураДействий.ТекущаяСтрока) <> Тип("Неопределено") Тогда
			
			ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
						
			Номенклатура = "";
			Характеристика = "";
		    ПоУчету = 0;
		    ПоФакту = 0;
		    Ячейка = "";
			НоваяЯчейка = "";
			НовыйШтрихкод = "";
						
			Если ЭлементСписка <> Неопределено Тогда
				Элементы.СтраницыФормы.Видимость=Ложь;
				Элементы._РедактированиеСтрокиНаТСД.Видимость=Истина;
				Номенклатура = ЭлементСписка.Номенклатура;
				Характеристика = ЭлементСписка.Характеристика;
				ПоУчету = ЭлементСписка.КоличествоУпаковок;
				ПоФакту = ЭлементСписка.КоличествоУпаковокФакт;
				Ячейка = ПолучитьЯчейку(Номенклатура,Объект.Склад);
				Попытка
					АдресКартинки = ПолучитьАдресКартинки(Номенклатура);
				Исключение
					Элементы.ГруппаКартинка.Видимость = Ложь;
				КонецПопытки;
				
			Конецесли;
		Иначе
				Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
				СредстваМультимедиа.ВоспроизвестиТекст("Товар не найден!","ru-RU");	
				КонецЕсли;
			Сообщить("Штрихкод не найден!");
		КонецЕсли;
		
	#КонецЕсли
	
	ЭтаФорма.ОбновитьОтображениеДанных();
	#КонецВставки
КонецПроцедуры

#КонецОбласти

#Область СобытияЭлементовФормы  

&НаКлиенте
Процедура Док_СписокВыборПосле(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Элементы._РедактированиеСтрокиНаТСД.Видимость=Истина;
	Элементы._ВыборНК.Видимость = Ложь;

	НоменклатураНК = Элементы.Список.ТекущиеДанные.НоменклатураБрак;
	
	ВвестиЧисло(ПоФакту,"Введите количество");
	НоваяСтрока = Объект.Товары.Добавить();
	ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
	НоваяСтрока.Номенклатура = НоменклатураНК; 
	НоваяСтрока.КоличествоУпаковок = ПоФакту;
	НоваяСтрока.Количество = ПоФакту;

КонецПроцедуры   

