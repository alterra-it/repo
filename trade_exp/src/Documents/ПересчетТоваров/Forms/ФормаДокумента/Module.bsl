&НаСервере
Функция Док_УпорядочитьНоменклатуруПоАХПослеСервер(Склад, ДатаДокумента)
	
	МодифицировалиТаб = Ложь;                                                                                            
	ОрдерныйОтгрузка 	 = СкладыСервер.ИспользоватьОрдернуюСхемуПриОтгрузке(Склад, ДатаДокумента);
	ОрдерныйПоступление  = СкладыСервер.ИспользоватьОрдернуюСхемуПриПоступлении(Склад, ДатаДокумента);
	Если ОрдерныйОтгрузка ИЛИ ОрдерныйПоступление Тогда
		ТаблицаТоварыДляСортировкиАХ = Объект.Товары.Выгрузить();
		Если ТаблицаТоварыДляСортировкиАХ.Количество()>1 Тогда
			ЗапросАХ = Новый Запрос;
			ЗапросАХ.Текст = 
			"ВЫБРАТЬ
			|	*
			|ПОМЕСТИТЬ ВТНоменклатур
			|ИЗ
			|	&ТаблДляСортировкиАХ КАК ТаблАХ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	*,
			|	ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Код, """") КАК ЯчейкаПредставление,
			|	ЕСТЬNULL(РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка, ИСТИНА) КАК ОсновнаяЯчейка
			|ИЗ
			|	ВТНоменклатур КАК ВТНоменклатур
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
			|		ПО ВТНоменклатур.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
			|		И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка)
			|		И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
			|УПОРЯДОЧИТЬ ПО
			|	ЯчейкаПредставление";
			ЗапросАХ.УстановитьПараметр("ТаблДляСортировкиАХ", ТаблицаТоварыДляСортировкиАХ);   
			ЗапросАХ.УстановитьПараметр("Склад", Объект.Склад);   
			РезультатАХ = ЗапросАХ.Выполнить().Выгрузить();
			Объект.Товары.Загрузить(РезультатАХ);
			МодифицировалиТаб = Истина;
		КонецЕсли;  
	КонецЕсли;  
	Возврат МодифицировалиТаб;	
КонецФункции

&НаКлиенте
Процедура Док_ДвиженияПоРасхождениямПосле(Команда)
	Если Объект.ВремяНачала<>Дата(1, 1, 1, 0, 0, 0) Тогда
		Док_ДвиженияПоРасхождениямПослеНаСервере();
	Конецесли;
КонецПроцедуры

&НаСервере
Процедура Док_ДвиженияПоРасхождениямПослеНаСервере()
	
	СписокНоменклатуры = Новый Массив;
	Для каждого Строка из Объект.Товары Цикл
		СписокНоменклатуры.Добавить(Строка.Номенклатура);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ТоварыНаСкладахОстаткиИОбороты.Номенклатура КАК Номенклатура,
		|	ТоварыНаСкладахОстаткиИОбороты.Характеристика КАК Характеристика,
		|	ТоварыНаСкладахОстаткиИОбороты.Назначение КАК Назначение,
		|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииПриход КАК Приход,
		|	ТоварыНаСкладахОстаткиИОбороты.ВНаличииРасход КАК Расход
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.ОстаткиИОбороты(&ДатаНачала, &ДатаОкончания,,, Номенклатура В
		|		(&СписокНоменклатуры)) КАК ТоварыНаСкладахОстаткиИОбороты
		|ГДЕ
		|	ТоварыНаСкладахОстаткиИОбороты.Склад = &Склад";
	
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("ДатаОкончания", ?(Объект.ВремяОкончания = Дата(1,1,1,0,0,0), ТекущаяДата(), Объект.ВремяОкончания));
	Запрос.УстановитьПараметр("ДатаНачала", Объект.ВремяНачала);
	Запрос.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивПоСтроке = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура, Характеристика, Назначение", ВыборкаДетальныеЗаписи.Номенклатура, ВыборкаДетальныеЗаписи.Характеристика, ВыборкаДетальныеЗаписи.Назначение));
		Для каждого Строка из МассивПоСТроке Цикл
			Если Строка.КоличествоУпаковокОтклонение<>0 Тогда
				Строка.Приход = ВыборкаДетальныеЗаписи.Приход;
				Строка.Расход = ВыборкаДетальныеЗаписи.Расход;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

