 КонецПроцедуры
  
 Функция ПолучитьВидимость()
	 
	 Видимость = Ложь;
	 
	 Если ОграничениеДоступностиОстатков Тогда
		 Если ЗначениеЗаполнено(Объект.РабочийУчасток) Тогда
			 СкрытиеУчета = Объект.РабочийУчасток.СкрытьКоличествоПоУчету;
			 Объект.УчетСкрыт = СкрытиеУчета;
			 
			 Видимость = Не СкрытиеУчета 
			 Или (СкрытиеУчета И (РольДоступнаПодтверждениеОтделомКачества() Или РольДоступнаРуководительСкладскогоКомплекса()));
		 Иначе
			 Видимость = РольДоступнаПодтверждениеОтделомКачества() Или РольДоступнаРуководительСкладскогоКомплекса();
			 Объект.УчетСкрыт = Истина;
		 КонецЕсли;
	 Иначе
		 Видимость = Не ЗначениеЗаполнено(Объект.Склад)
		 Или (ЗначениеЗаполнено(Объект.Склад) 
		 И (Не Объект.Склад.СкрытьКоличествоУчетаВПересчетах 
		 Или (Объект.Склад.СкрытьКоличествоУчетаВПересчетах 
		 И (РольДоступнаПодтверждениеОтделомКачества() Или РольДоступнаРуководительСкладскогоКомплекса()))));
	 КонецЕсли;
	 
	 Возврат Видимость;
	 
 КонецФункции 

