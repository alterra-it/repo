&НаКлиенте
Процедура Док_ОбработкаВыбораПосле(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ИмяФормы = "Обработка.ЗагрузкаДанныхИзВнешнихФайлов.Форма.Форма" Тогда	
		ПолучитьЗагруженныеТоварыИзХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	КонецЕсли;
		
	ЗаполнитьБлокирокиПоТоварам();
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьЗагруженныеТоварыИзХранилища(АдресТоваровВХранилище)
	
	ТоварыИзХранилища = ПолучитьИзВременногоХранилища(АдресТоваровВХранилище);	
	ТоварыИзХранилища.Колонки.Добавить("КоличествоФакт",         Новый ОписаниеТипов("Число"));
	ТоварыИзХранилища.Колонки.Добавить("КоличествоУпаковокФакт", Новый ОписаниеТипов("Число"));
	ТоварыИзХранилища.Колонки.Добавить("Назначение", Новый ОписаниеТипов("СправочникСсылка.Назначения"));
	
	ПересчитатьПоУчетуЗагруженные(ТоварыИзХранилища);	
	ЗаполнитьПризнакРасхождение();
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ПересчитатьПоУчетуЗагруженные(ТоварыЗагруженные)      

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.КоличествоФакт КАК КоличествоФакт,
		|	Товары.КоличествоУпаковокФакт КАК КоличествоУпаковокФакт
		|ПОМЕСТИТЬ ВР_Табл
		|ИЗ
		|	&Товары КАК Товары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_Табл.Номенклатура КАК Номенклатура,
		|	ВР_Табл.Характеристика КАК Характеристика,
		|	ВР_Табл.Назначение КАК Назначение,
		|	ВР_Табл.КоличествоФакт КАК КоличествоФакт,
		|	ВР_Табл.КоличествоУпаковокФакт КАК КоличествоУпаковокФакт,
		|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК Количество,
		|	ТоварыНаСкладахОстатки.ВНаличииОстаток КАК КоличествоУпаковок,
		|	ВЫБОР
		|		КОГДА &НовыйРасчетОтклонения
		|			ТОГДА ЕСТЬNULL(ЯПХОстатки.КоличествоОстаток, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ЯПХ,
		|	ВЫБОР
		|		КОГДА &НовыйРасчетОтклонения
		|			ТОГДА ТоварыНаСкладахОстатки.ВНаличииОстаток - ЕСТЬNULL(ЯПХОстатки.КоличествоОстаток, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК КоличествоПоУчетуВЗонеХранения
		|ИЗ
		|	ВР_Табл КАК ВР_Табл
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Период, Склад = &Склад) КАК ТоварыНаСкладахОстатки
		|		ПО ВР_Табл.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
		|			И ВР_Табл.Характеристика = ТоварыНаСкладахОстатки.Характеристика
		|		ЛЕВОЕ СОЕДИНЕНИЕ  (ВЫБРАТЬ
		|			ТоварыВЯчейкеПромежуточногоХранения.Номенклатура КАК Номенклатура,
		|			ТоварыВЯчейкеПромежуточногоХранения.Характеристика КАК Характеристика,
		|			ТоварыВЯчейкеПромежуточногоХранения.Назначение КАК Назначение,
		|			ТоварыВЯчейкеПромежуточногоХранения.Склад КАК Склад,
		|			СУММА(ТоварыВЯчейкеПромежуточногоХранения.Количество) КАК КоличествоОстаток
		|		ИЗ
		|			РегистрСведений.ТоварыВЯчейкеПромежуточногоХранения КАК ТоварыВЯчейкеПромежуточногоХранения
		|		ГДЕ
		|			ТоварыВЯчейкеПромежуточногоХранения.Склад = &Склад
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ТоварыВЯчейкеПромежуточногоХранения.Номенклатура,
		|			ТоварыВЯчейкеПромежуточногоХранения.Характеристика,
		|			ТоварыВЯчейкеПромежуточногоХранения.Назначение,
		|			ТоварыВЯчейкеПромежуточногоХранения.Склад) КАК ЯПХОстатки
		|		ПО ВР_Табл.Номенклатура = ЯПХОстатки.Номенклатура
		|			И ВР_Табл.Характеристика = ЯПХОстатки.Характеристика
		|			И ВР_Табл.Назначение = ЯПХОстатки.Назначение";
	
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("НовыйРасчетОтклонения", Объект.НовыйРасчетОтклонения);
	Запрос.УстановитьПараметр("Товары", ТоварыЗагруженные);
	Объект.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
	ЗаполнитьБлокирокиПоТоварам();

КонецПроцедуры

#КонецОбласти

#Область ВыборочнаяПроверка 

&НаКлиенте
Процедура Док__ВыборачнаяПроверка(Команда)
	Док__ВыборачнаяПроверкаНаСервере();
КонецПроцедуры

&НаСервере
Процедура Док__ВыборачнаяПроверкаНаСервере()  
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СпрНоменклатура.Ссылка КАК Номенклатура
		|ПОМЕСТИТЬ ВТ_Номенклатура
		|ИЗ
		|	РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ТоварныеОграничения КАК ТоварныеОграничения
		|			ПО СпрНоменклатура.Ссылка = ТоварныеОграничения.Номенклатура
		|		ПО ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура = СпрНоменклатура.Ссылка
		|ГДЕ
		|	СпрНоменклатура.ЭтоГруппа = ЛОЖЬ
		|	И СпрНоменклатура.ПометкаУдаления = ЛОЖЬ
		|	И ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс В(&Класс)
		|	И ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Подразделение = &Подразделение
		|	И ТоварныеОграничения.МаксимальноеКоличествоЗапаса > 1
		|	И ТоварныеОграничения.Склад = &ТорговыйЗал
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПартнерыДополнительныеРеквизиты.Ссылка КАК Клиенты
		|ПОМЕСТИТЬ ВТ_Клиенты
		|ИЗ
		|	Справочник.Партнеры.ДополнительныеРеквизиты КАК ПартнерыДополнительныеРеквизиты
		|ГДЕ
		|	ПартнерыДополнительныеРеквизиты.Ссылка.ПометкаУдаления = ЛОЖЬ
		|	И ПартнерыДополнительныеРеквизиты.Свойство = &СвойствоГруппаКлиентов
		|	И ПартнерыДополнительныеРеквизиты.Значение В(&ГруппаКлиентов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
		|	СУММА(ЕСТЬNULL(ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот, 0)) КАК СуммаВыручкиОборот
		|ПОМЕСТИТЬ ВыручкаТорговыйЗал
		|ИЗ
		|	ВТ_Номенклатура КАК ВТ_Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
		|				&Дата1,
		|				&Дата2,
		|				Период,
		|				АналитикаУчетаНоменклатуры.Номенклатура В
		|						(ВЫБРАТЬ
		|							ВТ_Номенклатура.Номенклатура КАК Номенклатура
		|						ИЗ
		|							ВТ_Номенклатура КАК ВТ_Номенклатура)
		|					И АналитикаУчетаНоменклатуры.МестоХранения = &ТорговыйЗал
		|					И АналитикаУчетаПоПартнерам.Партнер В
		|						(ВЫБРАТЬ
		|							ВТ_Клиенты.Клиенты КАК Клиенты
		|						ИЗ
		|							ВТ_Клиенты КАК ВТ_Клиенты)
		|					И Подразделение = &Подразделение
		|					И Склад = &ТорговыйЗал) КАК ВыручкаИСебестоимостьПродажОбороты
		|		ПО ВТ_Номенклатура.Номенклатура = ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаНоменклатуры.Номенклатура
		|ГДЕ
		|	ЕСТЬNULL(ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот, 0) = 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Номенклатура.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Номенклатура.Номенклатура КАК Номенклатура,
		|	СУММА(ЕСТЬNULL(ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот, 0)) КАК СуммаВыручкиОборот
		|ПОМЕСТИТЬ ВыручкаСклад
		|ИЗ
		|	ВТ_Номенклатура КАК ВТ_Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
		|				&Дата1,
		|				&Дата2,
		|				Период,
		|				АналитикаУчетаНоменклатуры.Номенклатура В
		|						(ВЫБРАТЬ
		|							ВТ_Номенклатура.Номенклатура КАК Номенклатура
		|						ИЗ
		|							ВТ_Номенклатура КАК ВТ_Номенклатура)
		|					И АналитикаУчетаНоменклатуры.МестоХранения = &Склад
		|					И АналитикаУчетаПоПартнерам.Партнер В
		|						(ВЫБРАТЬ
		|							ВТ_Клиенты.Клиенты КАК Клиенты
		|						ИЗ
		|							ВТ_Клиенты КАК ВТ_Клиенты)
		|					И Подразделение = &Подразделение
		|					И Склад = &Склад) КАК ВыручкаИСебестоимостьПродажОбороты
		|		ПО ВТ_Номенклатура.Номенклатура = ВыручкаИСебестоимостьПродажОбороты.АналитикаУчетаНоменклатуры.Номенклатура
		|ГДЕ
		|	ЕСТЬNULL(ВыручкаИСебестоимостьПродажОбороты.СуммаВыручкиОборот, 0) <> 0
		|	И ВТ_Номенклатура.Номенклатура В
		|			(ВЫБРАТЬ
		|				ВыручкаТорговыйЗал.Номенклатура КАК Номенклатура
		|			ИЗ
		|				ВыручкаТорговыйЗал КАК ВыручкаТорговыйЗал)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Номенклатура.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВыручкаСклад.Номенклатура КАК Номенклатура,
		|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0) КАК КоличествоУпаковок,
		|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0) КАК Количество,
		|	ВыручкаСклад.Номенклатура.ЕдиницаИзмерения КАК Упаковка,
		|	ВЫБОР
		|		КОГДА &НовыйРасчетОтклонения
		|			ТОГДА ЕСТЬNULL(ЯПХОстатки.КоличествоОстаток, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ЯПХ,
		|	ВЫБОР
		|		КОГДА &НовыйРасчетОтклонения
		|			ТОГДА ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0) - ЕСТЬNULL(ЯПХОстатки.КоличествоОстаток, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК КоличествоПоУчетуВЗонеХранения
		|ИЗ
		|	ВыручкаСклад КАК ВыручкаСклад
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОст, Склад = &ТорговыйЗал) КАК ТоварыНаСкладахОстатки
		|		ПО ВыручкаСклад.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ТоварыВЯчейкеПромежуточногоХранения.Номенклатура КАК Номенклатура,
		|			ТоварыВЯчейкеПромежуточногоХранения.Склад КАК Склад,
		|			СУММА(ТоварыВЯчейкеПромежуточногоХранения.Количество) КАК КоличествоОстаток
		|		ИЗ
		|			РегистрСведений.ТоварыВЯчейкеПромежуточногоХранения КАК ТоварыВЯчейкеПромежуточногоХранения
		|		ГДЕ
		|			ТоварыВЯчейкеПромежуточногоХранения.Склад = &ТорговыйЗал
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ТоварыВЯчейкеПромежуточногоХранения.Номенклатура,
		|			ТоварыВЯчейкеПромежуточногоХранения.Склад) КАК ЯПХОстатки
		|		ПО ВыручкаСклад.Номенклатура = ЯПХОстатки.Номенклатура";

	//Пересчет делается на торговом зале
	ТекДата = ТекущаяДата();
	ГруппаКлиентов = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Группы партнеров");
	Запрос.УстановитьПараметр("СвойствоГруппаКлиентов", ГруппаКлиентов);
	Запрос.УстановитьПараметр("Дата1", НачалоДня(ДобавитьМесяц(ТекДата,-1)));
	Запрос.УстановитьПараметр("Дата2", ТекДата);
	Запрос.УстановитьПараметр("ДатаОст", ТекДата);
	Класс = Новый Массив;
	Класс.Добавить(Перечисления.ABCКлассификация_Альтерра.AКласс);
	Класс.Добавить(Перечисления.ABCКлассификация_Альтерра.BКласс);
	Класс.Добавить(Перечисления.ABCКлассификация_Альтерра.CКласс);
	Класс.Добавить(Перечисления.ABCКлассификация_Альтерра.Новинка);
	Запрос.УстановитьПараметр("Класс", Класс);
	Запрос.УстановитьПараметр("Подразделение", Объект.Склад.Подразделение);
	Запрос.УстановитьПараметр("НовыйРасчетОтклонения", Объект.НовыйРасчетОтклонения);
	Свойство = Новый Массив;
	Свойство.Добавить(Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Частные лица", Истина,, ГруппаКлиентов));
	Свойство.Добавить(Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Сотрудники", Истина,, ГруппаКлиентов));
	Запрос.УстановитьПараметр("ГруппаКлиентов", Свойство);
	
	Запрос.УстановитьПараметр("Склад", Объект.ГоловнойСклад);
	Запрос.УстановитьПараметр("ТорговыйЗал", Объект.Склад);
	
	Объект.Товары.Загрузить(Запрос.Выполнить().Выгрузить());
	
	ЗаполнитьБлокирокиПоТоварам();
	ЗаполнитьПризнакРасхождение();
	Модифицированность = Истина;
КонецПроцедуры

#КонецОбласти

#Область ПересчетКоличества

&НаКлиенте
Процедура НетиповойПересчетПоУчету(Команда)
	НетиповойПересчетПоУчету_НаСервере();
	
	ВыполняетсяЗапись = Истина;
	ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма);
	ВыполняетсяЗапись = Ложь;
		
	ЗаполнитьБлокирокиПоТоварам(); 
	ЗаполнитьПризнакРасхождение();	
КонецПроцедуры


&НаСервере
Процедура НетиповойПересчетПоУчету_НаСервере()                      
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");                   
	ТаблицаЗначенийПоУчету = ДокументОбъект.ПересчитатьПоУчетуВДокументе(ДокументОбъект.Товары.Выгрузить(), ПересчитыватьУчетПриНулевомФакте);

	Для Каждого СтрокаПоУчету Из ТаблицаЗначенийПоУчету Цикл
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Номенклатура", СтрокаПоУчету.Номенклатура);
		СтруктураПоиска.Вставить("Характеристика", СтрокаПоУчету.Характеристика);
		СтруктураПоиска.Вставить("Назначение", СтрокаПоУчету.Назначение); 
		
		НайденныеТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеТовары.Количество() > 0 Тогда 
			
			Для Каждого СтрокаТоваров Из НайденныеТовары Цикл       
				Объект.Товары[СтрокаТоваров.Номерстроки-1].Количество = СтрокаПоУчету.Количество;
				Объект.Товары[СтрокаТоваров.Номерстроки-1].КоличествоУпаковок = СтрокаПоУчету.КоличествоУпаковок;
				Объект.Товары[СтрокаТоваров.Номерстроки-1].ЯПХ = СтрокаПоУчету.ЯПХ;
				Объект.Товары[СтрокаТоваров.Номерстроки-1].КоличествоПоУчетуВЗонеХранения = СтрокаПоУчету.КоличествоПоУчетуВЗонеХранения;
				Объект.Товары[СтрокаТоваров.Номерстроки-1].СпособВводаКоличестваТовара = СтрокаПоУчету.СпособВводаКоличестваТовара;
				Объект.Товары[СтрокаТоваров.Номерстроки-1].Отсканирован = СтрокаПоУчету.Отсканирован;

			КонецЦикла;
			
		// Добавлять строки с новыми назначениями (для склада)	
		Иначе                                           
			ПоискНоменклатуры = Новый Структура;
			ПоискНоменклатуры.Вставить("Номенклатура", СтрокаПоУчету.Номенклатура);   
			НайденнаяНоменклатура = Объект.Товары.НайтиСтроки(ПоискНоменклатуры);
			Если НайденнаяНоменклатура.Количество() > 0 Тогда  
				НоваяСтрокаТоваров1 = Объект.Товары.Вставить(НайденнаяНоменклатура[0].НомерСтроки);     
			Иначе
				НоваяСтрокаТоваров1 = Объект.Товары.Добавить(); 
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(НоваяСтрокаТоваров1, СтрокаПоУчету); 				
		КонецЕсли;  
	КонецЦикла;	    
	
	УдаляемыеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("Количество, КоличествоФакт, КоличествоУпаковок, КоличествоУпаковокФакт, КоличествоПоУчетуВЗонеХранения", 0, 0, 0, 0, 0));	
	Для Каждого Стр Из УдаляемыеСтроки Цикл
		Объект.Товары.Удалить(Стр);
	КонецЦикла;
	 
КонецПроцедуры

