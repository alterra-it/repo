#Область Блокировка

&НаСервере
Функция ПолучитьДокументБлокировки(СтатусБлокировки)
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	БлокировкаДвиженияТоваров.Ссылка КАК Ссылка
	                      |ИЗ
	                      |	Документ.БлокировкаДвиженияТоваров КАК БлокировкаДвиженияТоваров
	                      |ГДЕ
	                      |	БлокировкаДвиженияТоваров.ДокументОснование = &ДокументОснование
	                      |	И БлокировкаДвиженияТоваров.Статус = Значение(Перечисление.СтатусыБлокировкиДвиженияНоменклатуры.%СтатусБлокировки%)");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "%СтатусБлокировки%", СтатусБлокировки);
	Запрос.УстановитьПараметр("ДокументОснование", Объект.Ссылка);
	
	Результат = Запрос.Выполнить().Выбрать();
	Если Результат.Следующий() Тогда
		Возврат Результат.Ссылка;
	Иначе
		Возврат Документы.БлокировкаДвиженияТоваров.ПустаяСсылка();
	КонецЕсли;
КонецФункции

