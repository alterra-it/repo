&НаКлиенте
Процедура Док_ТоварыНоменклатураПриИзмененииПосле(Элемент)
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;   
	Если НЕ ЗначениеЗаполнено(ТекущаяСтрока.Номенклатура) Тогда 
		ТекущаяСтрока.КоличествоПоУчетуВЗонеХранения = 0;
		ТекущаяСтрока.ЯПХ = 0;
	КонецЕсли;
	
	ЗаполнитьБлокирокиПоТоварам();
КонецПроцедуры   

&НаСервере
&ИзменениеИКонтроль("ЗаполнитьПризнакРасхождение")
Процедура Док_ЗаполнитьПризнакРасхождение()

#Удаление
	Для Каждого СтрТабл Из Объект.Товары Цикл
		СтрТабл.Расхождение = СтрТабл.КоличествоФакт <> СтрТабл.Количество Или СтрТабл.КоличествоУпаковок <> СтрТабл.КоличествоУпаковокФакт;
		СтрТабл.КоличествоУпаковокОтклонение = СтрТабл.КоличествоУпаковокФакт - СтрТабл.КоличествоУпаковок;
	КонецЦикла;
#КонецУдаления

#Вставка
	Документы.ПересчетТоваров.НовыйРасчетОтклонения_Табл(Объект.Товары, Объект.НовыйРасчетОтклонения);
#КонецВставки

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ЗаполнитьФактПоУчетуСервер")
Процедура Док_ЗаполнитьФактПоУчетуСервер()

	Для Каждого СтрТабл Из Объект.Товары Цикл

		СтрТабл.КоличествоФакт = СтрТабл.Количество;
		СтрТабл.КоличествоУпаковокФакт = СтрТабл.КоличествоУпаковок;
		СтрТабл.Расхождение = (СтрТабл.КоличествоФакт <> СтрТабл.Количество) Или (СтрТабл.КоличествоУпаковок <> СтрТабл.КоличествоУпаковокФакт);
		СтрТабл.КоличествоУпаковокОтклонение = СтрТабл.КоличествоУпаковокФакт - СтрТабл.КоличествоУпаковок;

#Вставка                 
		Если Объект.НовыйРасчетОтклонения Тогда
			КоэффициентУпаковки = ВернутьКоэффициентУпаковки(СтрТабл.Упаковка, СтрТабл.Номенклатура);
			СтрТабл.КоличествоУпаковокФакт = СтрТабл.КоличествоПоУчетуВЗонеХранения;
			СтрТабл.КоличествоФакт = КоэффициентУпаковки * СтрТабл.КоличествоПоУчетуВЗонеХранения;
		КонецЕсли;
		
		СтрТабл.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Клавиатура");
#КонецВставки

	КонецЦикла;

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("СкладПомещениеПриИзмененииСервер")
Процедура Док_СкладПомещениеПриИзмененииСервер()

	ИспользоватьАдресноеХранениеТекущее = ИспользоватьАдресноеХранение;

	НастроитьПоСкладуПомещению();

	Если ИспользоватьАдресноеХранение И Объект.Статус = Перечисления.СтатусыПересчетовТоваров.ВРаботе Тогда
		Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Подготовлено;
	ИначеЕсли Не ИспользоватьАдресноеХранение И Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Подготовлено Тогда 
		Объект.Статус = Перечисления.СтатусыПересчетовТоваров.ВРаботе;
	КонецЕсли;

	Если ИспользоватьАдресноеХранениеТекущее
		И Не ИспользоватьАдресноеХранение Тогда

		Для Каждого СтрТабл Из Объект.Товары Цикл

			СтрТабл.Упаковка               = Неопределено;
			СтрТабл.КоличествоУпаковок     = СтрТабл.Количество;
			СтрТабл.КоличествоУпаковокФакт = СтрТабл.КоличествоФакт; 
			
#Удаление
			СтрТабл.КоличествоУпаковокОтклонение = СтрТабл.КоличествоФакт - СтрТабл.КоличествоУпаковок;
#КонецУдаления

#Вставка       
			НовыйРасчетОтклонения_СтрТабл(СтрТабл);
#КонецВставки

		КонецЦикла;

	КонецЕсли;

	СтруктураЯчеек = Документы.ПересчетТоваров.ПолучитьЯчейкиИзлишковИБракаПоУмолчанию(Объект.Ссылка, Объект.Склад, Объект.Помещение);
	ЗаполнитьЗначенияСвойств(Объект, СтруктураЯчеек);
	Элементы.ЯчейкаКонсолидацииИзлишковТоваров.Доступность = Объект.ИспользоватьОтдельнуюЯчейкуИзлишков;
	Элементы.ЯчейкаКонсолидацииИспорченныхТоваров.Доступность = Объект.ИспользоватьОтдельнуюЯчейкуПорчи;

	ИнициализироватьКомпоновкуДанных(Истина);
	ПодготовитьЗаполнитьУстановитьВидимостьСерий(); 
	
#Вставка
	Если Объект.Ссылка.Пустая() И Объект.Склад.ИспользоватьСтатусыПересчетовТоваров  Тогда
		Объект.Статус = Перечисления.СтатусыПересчетовТоваров.Подготовлено;
	КонецЕсли;
#КонецВставки

КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ПолучитьВесЗавершение")
Процедура Док_ПолучитьВесЗавершение(РезультатВыполнения, ТекущаяСтрока)
	
	Если РезультатВыполнения.Результат Тогда
		ТекущаяСтрока.КоличествоУпаковокФакт = РезультатВыполнения.Вес;
		
		СтруктураДействий = Новый Структура;
		
		Если ИспользоватьАдресноеХранение Тогда
			ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействий);
		Иначе
			ТекущаяСтрока.КоличествоФакт = РезультатВыполнения.Вес;
			
			СтруктураДействий.Вставить("ЗаполнитьФлагРасхождение");
			СтруктураДействий.Вставить("ПересчитатьКоличествоУпаковокОтклонение");
		КонецЕсли;
		
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
#Вставка
	НовыйРасчетОтклонения_СтрТабл_Клиент(ТекущаяСтрока);
#КонецВставки
	Иначе
		МенеджерОборудованияУТКлиент.СообщитьОбОшибке(РезультатВыполнения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыУпаковкаПриИзмененииПосле(Элемент)
	НовыйРасчетОтклонения_СтрТабл_Клиент(Элементы.Товары.ТекущиеДанные);
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыКоличествоУпаковокФактПриИзмененииПосле(Элемент)

	НовыйРасчетОтклонения_СтрТабл_Клиент(Элементы.Товары.ТекущиеДанные); 
	
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;	
	ТекущиеДанные.СпособВводаКоличестваТовара = ПредопределенноеЗначение("Перечисление.СпособыВводаКоличестваТовара.Клавиатура");	

КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыКоличествоУпаковокОтклонениеПриИзмененииПосле(Элемент)
	ТекДанные = Элементы.Товары.ТекущиеДанные;
	КоэффициентУпаковки = ВернутьКоэффициентУпаковки(ТекДанные.Упаковка, ТекДанные.Номенклатура);
	ДопМодульКлиент.ПересчитатьФакт(ТекДанные, Объект.НовыйРасчетОтклонения, КоэффициентУпаковки);
КонецПроцедуры  

&НаСервереБезКонтекста
Функция ВернутьКоэффициентУпаковки(Упаковка, Номенклатура)
	Возврат Справочники.УпаковкиЕдиницыИзмерения.КоэффициентУпаковки(Упаковка, Номенклатура);
КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("РазбитьСтрокуЗавершение")
Процедура Док_РазбитьСтрокуЗавершение(НоваяСтрока, ДополнительныеПараметры)

	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;

	Если НоваяСтрока <> Неопределено Тогда

		Если ЗначениеЗаполнено(Объект.ЯчейкаКонсолидацииИзлишковТоваров) Тогда
			НоваяСтрока.Ячейка = Объект.ЯчейкаКонсолидацииИзлишковТоваров
		КонецЕсли;
		НоваяСтрока.ИзлишекПорча       = Истина;
		НоваяСтрока.Количество         = 0;
		НоваяСтрока.КоличествоУпаковок = 0;
		НоваяСтрока.КоличествоУпаковокОтклонение = 0;
#Вставка
	НоваяСтрока.КоличествоПоУчетуВЗонеХранения = 0;
	НоваяСтрока.ЯПХ = 0;
#КонецВставки

		СтруктураДействий = Новый Структура;
		ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковокФакт(СтруктураДействий);

		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(НоваяСтрока, СтруктураДействий, КэшированныеЗначения);
		
#Вставка                   
	НовыйРасчетОтклонения_СтрТабл_Клиент(ТекущаяСтрока);
	НовыйРасчетОтклонения_СтрТабл_Клиент(НоваяСтрока);
#КонецВставки

	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыПриНачалеРедактированияПосле(Элемент, НоваяСтрока, Копирование)
	Если НоваяСтрока Тогда
		Элементы.Товары.ТекущиеДанные.КоличествоПоУчетуВЗонеХранения = 0;
		Элементы.Товары.ТекущиеДанные.ЯПХ = 0;
	КонецЕсли;
КонецПроцедуры

