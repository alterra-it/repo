	Если НЕ ЗначениеЗаполнено(Объект.ТипПересчета) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан тип пересчета");
		Возврат;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Объект.Склад) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран склад");
		Возврат;
	КонецЕсли;
	Если ПустаяСтрока(Объект.ТипПересчета.ИдентификаторАлгоритма) тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для типа пересчета: "+Объект.ТипПересчета.Наименование+" в справочнике не определен алгоритм заполнения документа");
		Возврат;
	КонецЕсли;	
	
	Если СокрЛП(Объект.ТипПересчета.ИдентификаторАлгоритма) <> "АВС30днейНетПродаж" тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Алгоритм в типе пересчета указан неверно! ("+СокрЛП(Объект.ТипПересчета.ИдентификаторАлгоритма)+")");
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст="ВЫБРАТЬ
	             |	ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	             |	ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика,
	             |	ЗапасыИПотребностиОстатки.Назначение КАК Назначение,
	             |	ЗапасыИПотребностиОстатки.Склад КАК Склад,
	             |	Склады.Подразделение КАК Подразделение,
	             |	ЗапасыИПотребностиОстатки.ВНаличииОстаток КАК ВНаличииОстаток,
	             |	Витрины.Свойство КАК Свойство
	             |ПОМЕСТИТЬ НОМЕНКЛАТУРАНУЖНЫХВИТРИН
	             |ИЗ
	             |	РегистрНакопления.ЗапасыИПотребности.Остатки(&Дата, Склад = &Склад) КАК ЗапасыИПотребностиОстатки
	             |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады КАК Склады
	             |		ПО ЗапасыИПотребностиОстатки.Склад = Склады.Ссылка
	             |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	             |			ДополнительныеСведения.Объект КАК Объект,
	             |			ДополнительныеСведения.Свойство КАК Свойство,
	             |			ДополнительныеСведения.Значение КАК Значение
	             |		ИЗ
	             |			РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	             |		ГДЕ
	             |			ДополнительныеСведения.Свойство В
	             |					(ВЫБРАТЬ
	             |						СтруктураПредприятия.ВитринаТЗ КАК ВитринаТЗ
	             |					ИЗ
	             |						Справочник.СтруктураПредприятия КАК СтруктураПредприятия
	             |					ГДЕ
	             |						СтруктураПредприятия.Ссылка = &Подразделение)
	             |			И ДополнительныеСведения.Значение В
	             |					(ВЫБРАТЬ
	             |						ЗначенияСвойствОбъектов.Ссылка КАК Ссылка
	             |					ИЗ
	             |						Справочник.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	             |					ГДЕ
	             |						(ЗначенияСвойствОбъектов.Наименование ПОДОБНО ""ВИТРИНА""
	             |							ИЛИ ЗначенияСвойствОбъектов.Наименование ПОДОБНО ""Самообслуживание""))) КАК Витрины
	             |		ПО ЗапасыИПотребностиОстатки.Номенклатура = Витрины.Объект
	             |ГДЕ
	             |	ЗапасыИПотребностиОстатки.Склад = &Склад
	             |	И НЕ ЗапасыИПотребностиОстатки.Номенклатура В
	             |				(ВЫБРАТЬ
	             |					ВыручкаИСебестоимостьПродаж.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура
	             |				ИЗ
	             |					РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(&ДатаНачалаРасчета, &Дата, Авто, ) КАК ВыручкаИСебестоимостьПродаж
	             |				ГДЕ
	             |					ВыручкаИСебестоимостьПродаж.АналитикаУчетаПоПартнерам.Партнер <> ЗНАЧЕНИЕ(Справочник.Партнеры.НашеПредприятие)
	             |					И ВыручкаИСебестоимостьПродаж.Склад = &Склад
	             |				СГРУППИРОВАТЬ ПО
	             |					ВыручкаИСебестоимостьПродаж.АналитикаУчетаНоменклатуры.Номенклатура
	             |				ИМЕЮЩИЕ
	             |					СУММА(ВыручкаИСебестоимостьПродаж.СуммаВыручкиОборот) <> 0)
	             |	И НЕ Витрины.Свойство ЕСТЬ NULL
	             |	И &ABC_ОтборПоГруппамНоменклатур
	             |;
	             |
	             |////////////////////////////////////////////////////////////////////////////////
	             |ВЫБРАТЬ
	             |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Номенклатура КАК Номенклатура,
	             |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Характеристика КАК Характеристика,
				 |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Назначение КАК Назначение,
	             |	СУММА(НОМЕНКЛАТУРАНУЖНЫХВИТРИН.ВНаличииОстаток) КАК ВНаличииОстаток
	             |ИЗ
	             |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН КАК НОМЕНКЛАТУРАНУЖНЫХВИТРИН
	             |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ABCКлассификацияНоменклатуры_Альтерра.СрезПоследних КАК ABCКлассификацияНоменклатуры_АльтерраСрезПоследних
	             |		ПО НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Номенклатура = ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Номенклатура
	             |			И НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Подразделение = ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Подразделение
	             |ГДЕ
	             |	ABCКлассификацияНоменклатуры_АльтерраСрезПоследних.Класс В(&СписокКлассификаций)
	             |
	             |СГРУППИРОВАТЬ ПО
	             |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Номенклатура,
	             |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Характеристика,
				 |	НОМЕНКЛАТУРАНУЖНЫХВИТРИН.Назначение";
	
	Если ABC_ОтборПоГруппамНоменклатур Тогда
		ABC_Массив = Новый Массив;
		Для Каждого Элемент Из ABC_ГруппыНоменклатур Цикл
			Если ЗначениеЗаполнено(Элемент.Значение) Тогда
				ABC_Массив.Добавить(Элемент.Значение);
			КонецЕсли;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ABC_Массив) Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ABC_ОтборПоГруппамНоменклатур", "ЗапасыИПотребностиОстатки.Номенклатура.Родитель В ИЕРАРХИИ(&ABC_Массив)");
			Запрос.УстановитьПараметр("ABC_Массив", ABC_Массив);
		Иначе
			Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ABC_ОтборПоГруппамНоменклатур", "ИСТИНА");
		КонецЕсли;
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ABC_ОтборПоГруппамНоменклатур", "ИСТИНА");
	КонецЕсли;
	
	СписокКлассификаций = Новый Массив;	
	СписокКлассификаций.Добавить(Перечисления.ABCКлассификация_Альтерра.AКласс);
	СписокКлассификаций.Добавить(Перечисления.ABCКлассификация_Альтерра.BКласс);
	СписокКлассификаций.Добавить(Перечисления.ABCКлассификация_Альтерра.CКласс);
	СписокКлассификаций.Добавить(Перечисления.ABCКлассификация_Альтерра.ВыводимыйТовар);
	Запрос.УстановитьПараметр("СписокКлассификаций", СписокКлассификаций);
	
	Запрос.УстановитьПараметр("Склад",Объект.Склад);
	Запрос.УстановитьПараметр("Подразделение",Объект.Склад.Подразделение);
	Запрос.УстановитьПараметр("ДатаНачалаРасчета",ДОБАВИТЬМЕСЯЦ(Объект.Дата,-1));
	Запрос.УстановитьПараметр("Дата",Объект.Дата);
	
	Объект.Товары.Очистить();
	Выборка = Запрос.Выполнить().Выбрать();	
	Пока Выборка.Следующий() Цикл
		Если Выборка.ВНаличииОстаток > 0 Тогда 
			НоваяСтрока = Объект.Товары.Добавить();
			НоваяСтрока.Номенклатура = Выборка.Номенклатура;
			НоваяСтрока.Характеристика = Выборка.Характеристика;
			НоваяСтрока.Назначение = Выборка.Назначение;
		КонецЕсли;
	КонецЦикла;
	
	Объект.УчетныеДанныеЗаполнены = Ложь;
	ЭтаФорма.Модифицированность = Истина;
		
КонецПроцедуры

