	ПараметрыФормы.Вставить("Склад", Объект.Склад);
	ОткрытьФорму("Документ.ПересчетТоваров.Форма.Док_ФормаРасхождений", ПараметрыФормы, ЭтаФорма, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
