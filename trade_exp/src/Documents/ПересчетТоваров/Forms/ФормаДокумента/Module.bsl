КонецПроцедуры

#КонецОбласти

#Область СлужебнаяЗаписка

&НаСервере
Процедура ЕстьСлужебнаяЗаписка()
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьЗаписка = Документы.ПересчетТоваров.ЕстьСлужебнаяЗаписка(Объект.Ссылка);
	Если ЕстьЗаписка <> Неопределено Тогда
		Элементы.СоздатьСлужебнуюЗаписку.Доступность = Не ЕстьЗаписка;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция  СоздатьСлужебнуюЗапискуНаСервере()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		СлужебнаяЗаписка = Документы.СлужебнаяЗаписка.СоздатьДокумент();
		СлужебнаяЗаписка.Заполнить(Объект.Ссылка);
		СлужебнаяЗаписка.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
		Возврат СлужебнаяЗаписка.Ссылка;
	Исключение
		Ошибка = ИнформацияОбОшибке();
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = КраткоеПредставлениеОшибки(Ошибка);
		Сообщение.Сообщить();
		ТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);

КонецФункции

&НаКлиенте
Процедура СоздатьСлужебнуюЗаписку(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Или Модифицированность Тогда
			ПоказатьВопрос(Новый ОписаниеОповещения("СоздатьСлужебнуюЗапискуЗавершение", ЭтаФорма),
					"Документ будет проведен. Продолжить?", РежимДиалогаВопрос.ДаНет);
		Иначе
			Результат = СоздатьСлужебнуюЗапискуНаСервере();
			Если Результат <> Неопределено Тогда
				Элементы.СоздатьСлужебнуюЗаписку.Доступность =  Ложь;
				ПоказатьОповещениеПользователя(НСтр("ru = 'Создан новый документ'"), ПолучитьНавигационнуюСсылку(Результат), Результат, БиблиотекаКартинок.ВводНаОсновании);
				ПараметрыФормы = Новый Структура("Ключ", Результат);
				ОткрытьФорму("Документ.СлужебнаяЗаписка.Форма.ФормаДокумента", ПараметрыФормы);
			КонецЕсли;
		КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура СоздатьСлужебнуюЗапискуЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		Попытка
			ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма);
			Результат = СоздатьСлужебнуюЗапискуНаСервере();
			Если Результат <> Неопределено Тогда
				Элементы.СоздатьСлужебнуюЗаписку.Доступность =  Ложь;
				ПоказатьОповещениеПользователя(НСтр("ru = 'Создан новый документ'"), ПолучитьНавигационнуюСсылку(Результат), Результат, БиблиотекаКартинок.ВводНаОсновании);
				ПараметрыФормы = Новый Структура("Ключ", Результат);
				ОткрытьФорму("Документ.СлужебнаяЗаписка.Форма.ФормаДокумента", ПараметрыФормы);
			КонецЕсли;
		Исключение
			Ошибка = ИнформацияОбОшибке();
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = КраткоеПредставлениеОшибки(Ошибка);
			Сообщение.Сообщить();
			ТекстОшибки = ПодробноеПредставлениеОшибки(Ошибка);
		КонецПопытки;
		
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область КомпоновкаДанныхОтбора

&НаСервере    
&ИзменениеИКонтроль("ИнициализироватьКомпоновкуДанных")
Процедура Док_ИнициализироватьКомпоновкуДанных(ВсегдаИспользоватьНастройкиПоУмолчанию)
	
	Если ИспользоватьАдресноеХранение Тогда
		СхемаКомпоновкиДанных = Документы.ПересчетТоваров.ПолучитьМакет("ОтборПересчетаПоЯчейкам");
	Иначе
		#Удаление
		СхемаКомпоновкиДанных = Документы.ПересчетТоваров.ПолучитьМакет("ОтборПересчетаПоСкладу");
		#КонецУдаления
		
		#Вставка
		СхемаКомпоновкиДанных = Документы.ПересчетТоваров.ПолучитьМакет("ОтборПересчетаПоТочке");
    	#КонецВставки
	КонецЕсли;
	
	URLСхемы = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, Новый УникальныйИдентификатор());
	
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(URLСхемы);
	
	ОтборПересчета.Инициализировать(ИсточникНастроек);
	
	ТекОбъект = РеквизитФормыВЗначение("Объект");
	ТекНастройки = ТекОбъект.ОтборПересчета.Получить();
	Если ТекНастройки = Неопределено
		Или ВсегдаИспользоватьНастройкиПоУмолчанию Тогда
		ОтборПересчета.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
	Иначе
		ОтборПересчета.ЗагрузитьНастройки(ТекНастройки);
	КонецЕсли;
	
	ОтборПересчета.Восстановить(СпособВосстановленияНастроекКомпоновкиДанных.ПроверятьДоступность);
	
	УстановитьЗначениеПараметраНастроек(ОтборПересчета.Настройки, "Склад" , Объект.Склад);
	УстановитьЗначениеПараметраНастроек(ОтборПересчета.Настройки, "Помещение", Объект.Помещение);

КонецПроцедуры

&НаСервере  
&ИзменениеИКонтроль("ЗаполнитьСервер")
Процедура Док_ЗаполнитьСервер()
	#Удаление
	УстановитьЗначениеПараметраНастроек(ОтборПересчета.Настройки, "ДатаОстатков", ?(ЗначениеЗаполнено(Объект.Дата),
		Новый Граница(Объект.Дата, ВидГраницы.Включая),
		Новый Граница(ТекущаяДатаСеанса(), ВидГраницы.Включая)));
	#КонецУдаления  
	
	#Вставка
	УстановитьПривилегированныйРежим(Истина);
	
	УстановитьЗначениеПараметраНастроек(ОтборПересчета.Настройки, "ДатаОстатков", ?(ЗначениеЗаполнено(Объект.Дата), Объект.Дата, ТекущаяДатаСеанса()));
    #КонецВставки
	
	Если ИспользоватьАдресноеХранение Тогда
		СхемаКомпоновкиДанных = Документы.ПересчетТоваров.ПолучитьМакет("ОтборПересчетаПоЯчейкам");
	Иначе	
	#Удаление
		СхемаКомпоновкиДанных = Документы.ПересчетТоваров.ПолучитьМакет("ОтборПересчетаПоСкладу"); 
	#КонецУдаления  
	
	#Вставка  
		СхемаКомпоновкиДанных = Документы.ПересчетТоваров.ПолучитьМакет("ОтборПересчетаПоТочке");
	#КонецВставки
	КонецЕсли;
	
	ТекстЗапроса = СхемаКомпоновкиДанных.НаборыДанных.ЗаполнениеПоОтборам.Запрос;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса,
		"&ТекстЗапросаКоэффициентУпаковки",
		Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаКоэффициентаУпаковки(
		"ТоварыВЯчейках.Упаковка", Неопределено));
	СхемаКомпоновкиДанных.НаборыДанных.ЗаполнениеПоОтборам.Запрос = ТекстЗапроса;

	СегментыСервер.ВключитьОтборПоСегментуНоменклатурыВСКД(ОтборПересчета);
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, ОтборПересчета.ПолучитьНастройки(),,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	Объект.Товары.Загрузить(ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных));
	
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	ЗаполнитьПризнакРасхождение();
	
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
	
	#Вставка 
	УстановитьПривилегированныйРежим(Ложь);
	#КонецВставки
КонецПроцедуры     

&НаКлиенте
Процедура УстановитьОтбор(ИмяПоля, ВидСравнения, ЗначениеПоля, ИндексВставки)

	Отбор = ОтборПересчета.Настройки.Отбор;       
	Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	
	НайденныйЭлемент = Неопределено;
	Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл    
		Если Не (ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных")) Тогда
			Если ЭлементОтбора.ЛевоеЗначение = Поле И ЭлементОтбора.ВидСравнения = ВидСравнения Тогда
				НайденныйЭлемент = ЭлементОтбора;
				Прервать;
			КонецЕсли;     
		КонецЕсли;	
	КонецЦикла;
	
	ИндексВставки = ?(ИндексВставки > Отбор.Элементы.Количество() - 1, Отбор.Элементы.Количество() - 1, ИндексВставки);
	
	Если НайденныйЭлемент = Неопределено Тогда
		НайденныйЭлемент = Отбор.Элементы.Вставить(ИндексВставки, Тип("ЭлементОтбораКомпоновкиДанных"));
		НайденныйЭлемент.ЛевоеЗначение  = ИмяПоля;
		НайденныйЭлемент.ВидСравнения = ВидСравнения;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеПоля) Тогда
		НайденныйЭлемент.ПравоеЗначение = ЗначениеПоля;
		НайденныйЭлемент.Использование  = Истина;
	Иначе                                 
		НайденныйЭлемент.ПравоеЗначение = Неопределено;
		НайденныйЭлемент.Использование  = Ложь;
	КонецЕсли;
	
КонецПроцедуры    

&НаКлиенте
Функция ПолучитьДанныеИзОтбора(ИмяПоля, ВидСравнения)

	Отбор = ОтборПересчета.Настройки.Отбор;       
	Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	
	НайденныйЭлемент = Неопределено;
	Для Каждого ЭлементОтбора Из Отбор.Элементы Цикл    
		Если Не (ТипЗнч(ЭлементОтбора) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных")) Тогда
			Если ЭлементОтбора.ЛевоеЗначение = Поле И ЭлементОтбора.ВидСравнения = ВидСравнения Тогда
				НайденныйЭлемент = ЭлементОтбора;
				Прервать;
			КонецЕсли;     
		КонецЕсли;	
	КонецЦикла;
	
	Данные = Неопределено;
	
	Если Не (НайденныйЭлемент = Неопределено) И НайденныйЭлемент.Использование Тогда
		Данные = НайденныйЭлемент.ПравоеЗначение; 		
	КонецЕсли;
	
	Возврат Данные;
КонецФункции

#КонецОбласти

