#Область Экспортные
Функция ПолучитьТоварДляВозврата(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АрендаНоменклатурыОстатки.Номенклатура КАК Номенклатура,
	|	АрендаНоменклатурыОстатки.Характеристика КАК Характеристика,
	|	АрендаНоменклатурыОстатки.ВАрендеОстаток КАК ВАрендеОстаток
	|ПОМЕСТИТЬ ВТ_ОстатокАренды
	|ИЗ
	|	РегистрНакопления.АрендаНоменклатуры.Остатки КАК АрендаНоменклатурыОстатки
	|ГДЕ
	|	АрендаНоменклатурыОстатки.ДокументАренды = &Аренда
	|	И АрендаНоменклатурыОстатки.ВАрендеОстаток > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АрендаНоменклатурыТовары.Номенклатура КАК Номенклатура,
	|	АрендаНоменклатурыТовары.Характеристика КАК Характеристика,
	|	АрендаНоменклатурыТовары.УслугаАренды КАК УслугаАренды,
	|	АрендаНоменклатурыТовары.Цена КАК Цена,
	|	АрендаНоменклатурыТовары.Сумма КАК Сумма,
	|	АрендаНоменклатурыТовары.СтавкаНДС КАК СтавкаНДС,
	|	АрендаНоменклатурыТовары.СуммаНДС КАК СуммаНДС,
	|	АрендаНоменклатурыТовары.СуммаСНДС КАК СуммаСНДС,
	|	АрендаНоменклатурыТовары.ЦенаУслуги КАК ЦенаУслуги,
	|	АрендаНоменклатурыТовары.СуммаУслуги КАК СуммаУслуги,
	|	АрендаНоменклатурыТовары.СуммаНДСУслуги КАК СуммаНДСУслуги,
	|	АрендаНоменклатурыТовары.СуммаСНДСУслуги КАК СуммаСНДСУслуги,
	|	АрендаНоменклатурыТовары.СуммаЗалога КАК СуммаЗалога,
	|	АрендаНоменклатурыТовары.Период КАК Период,
	|	АрендаНоменклатурыТовары.ДатаВозврата КАК ДатаВозврата,
	|	ВТ_ОстатокАренды.ВАрендеОстаток КАК Количество,
	|	ВТ_ОстатокАренды.ВАрендеОстаток КАК КоличествоУслуги,
	|	&ДатаСдачиВАренду КАК ДатаСдачиВАренду
	|ИЗ
	|	ВТ_ОстатокАренды КАК ВТ_ОстатокАренды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.АрендаНоменклатуры.Товары КАК АрендаНоменклатурыТовары
	|		ПО (АрендаНоменклатурыТовары.Номенклатура = ВТ_ОстатокАренды.Номенклатура)
	|			И (АрендаНоменклатурыТовары.Характеристика = ВТ_ОстатокАренды.Характеристика)
	|ГДЕ
	|	АрендаНоменклатурыТовары.Ссылка = &Аренда";

	Запрос.УстановитьПараметр("Аренда", Объект.Основание);
	Запрос.УстановитьПараметр("ДатаСдачиВАренду", Объект.ДатаСдачиВАренду);
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();

	Возврат ТЗ;
	
КонецФункции


#КонецОбласти
