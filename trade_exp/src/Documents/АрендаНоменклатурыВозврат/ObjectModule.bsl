#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&Вместо("ОбработкаЗаполнения")
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АрендаНоменклатуры") Тогда
		Основание= ДанныеЗаполнения;
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения,,"Дата,Номер,Автор");
		
		ТЗ= Документы.АрендаНоменклатурыВозврат.ПолучитьТоварДляВозврата(ЭтотОбъект);
		Товары.Загрузить(ТЗ);
	КонецЕсли;
	
	СуммаУслуг= Товары.Итог("СуммаСНДСУслуги");	
	СуммаЗалога= Товары.Итог("СуммаЗалога");
	
	Автор= Пользователи.ТекущийПользователь();
КонецПроцедуры

&Вместо("ОбработкаПроведения")
Процедура ОбработкаПроведения(Отказ, Режим)
	
	// регистр АрендаНоменклатуры Приход
	Для Каждого ТекСтрокаТовары Из Товары Цикл
		Движение = Движения.АрендаНоменклатуры.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.ДокументАренды= Основание;
		Движение.Период = Дата;
		Движение.Организация = Организация;
		Движение.Подразделение = Подразделение;
		Движение.Партнер = Партнер;
		Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
		Движение.Характеристика = ТекСтрокаТовары.Характеристика;
		Движение.КАренде = 0;
		Движение.ВАренде = ТекСтрокаТовары.Количество;
		Движение.СтоимостьАренды = 0;
		Движение.ДатаВозврата = ДатаВозвратаФакт;
	КонецЦикла;
	Движения.АрендаНоменклатуры.Записать(Истина);
	
	Документы.АрендаНоменклатуры.СоздатьДокументПеремещение(Ссылка, Отказ);
	
	Если Основание.Статус = Перечисления.СтатусыАренды.ВАренде И Не Отказ Тогда
		ЕстьОстатки = Документы.АрендаНоменклатуры.ЕстьОстаткиПоАренде(Основание);
		Если Не ЕстьОстатки Тогда
			ДокАренды = Основание.ПолучитьОбъект();
			ДокАренды.Статус = Перечисления.СтатусыАренды.Выполнен;
			ДокАренды.Записать(РежимЗаписиДокумента.Проведение);
			Сообщить("Аренда переведена в статус Выполнен");
		КонецЕсли;
	КонецЕсли;
	
	Если Основание.Статус = Перечисления.СтатусыАренды.Выполнен И Не Отказ Тогда	
		ЕстьОстатки = Документы.АрендаНоменклатуры.ЕстьОстаткиПоАренде(Основание);
		Если ЕстьОстатки Тогда
			ДокАренды = Основание.ПолучитьОбъект();
			ДокАренды.Статус = Перечисления.СтатусыАренды.ВАренде;
			ДокАренды.Записать(РежимЗаписиДокумента.Проведение);
			Сообщить("Аренда переведена в статус К Заказу");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьОплата = Документы.АрендаНоменклатуры.ЕстьПКО_РКО(Ссылка);
	Если ЕстьОплата Тогда
		Сообщить("Документ оплачен!");
		Если Не РольДоступна("ПолныеПрава") Тогда
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&Вместо("ОбработкаУдаленияПроведения")
Процедура ОбработкаУдаленияПроведения(Отказ)
	Документы.АрендаНоменклатуры.УдалитьДокументПеремещение(Ссылка, Отказ);
КонецПроцедуры

&Вместо("ПриЗаписи")
Процедура ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Проведен И Основание.Статус = Перечисления.СтатусыАренды.Выполнен И Не Отказ Тогда	
			ДокАренды = Основание.ПолучитьОбъект();
			ДокАренды.Статус = Перечисления.СтатусыАренды.ВАренде;
			ДокАренды.Записать(РежимЗаписиДокумента.Проведение);
			Сообщить("Аренда переведена в статус В Аренде");
		КонецЕсли;
		
КонецПроцедуры

#КонецЕсли

