
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТаблицаУстановкаЦен.Загрузить(Параметры.Объект.ТаблицаУстановкаЦен.Выгрузить());
	
	ДокументЦенообразования=Параметры.Объект.Ссылка;
	
	ДатаУЦ=Параметры.ДатаУЦ;
	
	ПостроитьТаблицу();	
	
	ЗаполнитьТаблицу();
	
	ЗаполнитьДокументы();
	
	ОбновитьИнформацию();
КонецПроцедуры

&НаСервере
Процедура ПостроитьТаблицу()
	ПараметрыФормыКолонки=Новый Структура("Вид,Доступность",ВидПоляФормы.ПолеФлажка,ложь);
	МассивТипов=Новый Массив();
	МассивТипов.Добавить(тип("Число"));
	ОписаниеТиповКолонки=Новый ОписаниеТипов(МассивТипов);
	
	ТаблицаФормы = РеквизитФормыВЗначение("ТоварыКРаспределению");
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЦОДокумент.ВидЦены.РегионПрисутствия КАК Регион,
	|	ЦОДокумент.ВидЦены.ФорматПодразделения КАК Формат
	|ИЗ
	|	Документ.Ценообразование.ТаблицаУстановкаЦен КАК ЦОДокумент
	|ГДЕ
	|	ЦОДокумент.Ссылка = &Документ
	|	И ЦОДокумент.Цена <> 0
	|ИТОГИ ПО
	|	Регион";
	
	Запрос.УстановитьПараметр("Документ", ДокументЦенообразования);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаРегион = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВидТаблицы="ТоварыКРаспределению";
	Пока ВыборкаРегион.Следующий() Цикл
		ИмяГруппы="" + ВыборкаРегион.Регион;
		ГруппаКолонок=Элементы.Добавить(ВидТаблицы + ИмяГруппы, тип("ГруппаФормы"),
		Элементы.ТоварыКРаспределению);
		ГруппаКолонок.Заголовок=ИмяГруппы;
		ГруппаКолонок.Группировка=ГруппировкаКолонок.Горизонтальная;
		ГруппаКолонок.ОтображатьВШапке=Истина;
		
		ВыборкаФормат = ВыборкаРегион.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаФормат.Следующий() Цикл
			ИмяКолонки="" + ИмяГруппы + "_" + ВыборкаФормат.Формат;
			ЗаголовокКолонки=ВыборкаФормат.Формат;
			ТаблицаФормы.Колонки.Добавить(ИмяКолонки, ОписаниеТиповКолонки, ЗаголовокКолонки, 3);
			ДобавляемыеРеквизиты = Новый Массив;
			УдаляемыеРеквизиты = Новый Массив;
			ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяКолонки, ОписаниеТиповКолонки, ВидТаблицы,
			ЗаголовокКолонки));
			ИзменитьРеквизиты(ДобавляемыеРеквизиты, УдаляемыеРеквизиты);
			НоваяКолонка=Элементы.Добавить(ВидТаблицы + ИмяКолонки, тип("ПолеФормы"), ГруппаКолонок);
			НоваяКолонка.Заголовок = ЗаголовокКолонки; 
			НоваяКолонка.ПутьКДанным = ВидТаблицы + "." + ИмяКолонки;
			НоваяКолонка.ПутьКДаннымПодвала = ВидТаблицы + "." + ИмяКолонки;
			заполнитьзначениясвойств(НоваяКолонка, ПараметрыФормыКолонки);
		КонецЦикла;
	КонецЦикла;
	
	
	ЗначениеВРеквизитФормы(ТаблицаФормы, "ТоварыКРаспределению");	
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицу()
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ТаблицаУстановкаЦен.Номенклатура КАК Номенклатура,
	|	ТаблицаУстановкаЦен.ВидЦены КАК ВидЦены,
	|	ТаблицаУстановкаЦен.НомерУЦ КАК НомерУЦ,
	|	ТаблицаУстановкаЦен.ДатаУЦ КАК ДатаУЦ,
	|	ТаблицаУстановкаЦен.Группировка КАК Группировка
	|ПОМЕСТИТЬ ВР_УстановкаЦен
	|ИЗ
	|	&ТаблицаУстановкаЦен КАК ТаблицаУстановкаЦен
	|ГДЕ
	|	ТаблицаУстановкаЦен.Цена <> 0
	|	И ТаблицаУстановкаЦен.Цена <> ТаблицаУстановкаЦен.ЦенаТекущая
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВР_УстановкаЦен.Номенклатура КАК Номенклатура,
	|	ВР_УстановкаЦен.ВидЦены КАК ВидЦены,
	|	ВР_УстановкаЦен.Группировка КАК Группировка,
	|	ВидыЦен.РегионПрисутствия КАК Регион,
	|	ВидыЦен.ФорматПодразделения КАК Формат
	|ИЗ
	|	ВР_УстановкаЦен КАК ВР_УстановкаЦен
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
	|		ПО ВР_УстановкаЦен.ВидЦены = ВидыЦен.Ссылка
	|ИТОГИ ПО
	|	Номенклатура,
	|	Группировка";
	
	Запрос.УстановитьПараметр("ТаблицаУстановкаЦен", ТаблицаУстановкаЦен.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаНоменклатура = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаНоменклатура.Следующий() Цикл  
		
	ВыборкаГруппировка = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаГруппировка.Следующий() Цикл  
		стр=ТоварыКРаспределению.Добавить();  
		стр.Номенклатура=ВыборкаГруппировка.Номенклатура; 
		Стр.Группировка=ВыборкаГруппировка.Группировка;
		Стр.Группировка2=ВыборкаГруппировка.Группировка;   
		Стр.Распределено=ВыборкаГруппировка.Группировка<>0;
		ВыборкаДетальныеЗаписи = ВыборкаГруппировка.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			стр[""+ВыборкаДетальныеЗаписи.Регион+"_"+ВыборкаДетальныеЗаписи.Формат]=истина;
			
		КонецЦикла; 
	конеццикла;	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ОпределитьНомерГруппировки()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыКРаспределению.Группировка КАК Группировка
	|ПОМЕСТИТЬ ВР_Товары
	|ИЗ
	|	&ТоварыКРаспределению КАК ТоварыКРаспределению
	|ГДЕ
	|	ТоварыКРаспределению.Группировка <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВР_Товары.Группировка КАК Группировка
	|ИЗ
	|	ВР_Товары КАК ВР_Товары
	|
	|УПОРЯДОЧИТЬ ПО
	|	Группировка";
	
	Запрос.УстановитьПараметр("ТоварыКРаспределению",ТоварыКРаспределению.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	если ВыборкаДетальныеЗаписи.Следующий() тогда
		возврат ВыборкаДетальныеЗаписи.Группировка+1;
	Конецесли;
	возврат 1;
	
КонецФункции // ()

&НаСервере
Процедура РаспределитьПоКратности()
	КоличествоОпт=КратностьОпт;КоличествоРозница=КратностьРозница;     
	НомерГруппировки=ОпределитьНомерГруппировки();
	для каждого стр из ТоварыКРаспределению цикл
		если стр.Группировка<>0 тогда
			продолжить;
		конецесли;	
		если количествоОпт<>1 или КоличествоРозница<>1 тогда
			стр.Группировка=НомерГруппировки;
			КоличествоОпт=КоличествоОпт-1;
			КоличествоРозница=КоличествоРозница-1;
		иначе
			Стр.Группировка=НомерГруппировки;
			КоличествоОпт=КратностьОпт;
			КоличествоРозница=КратностьРозница; 
			НомерГруппировки=НомерГруппировки+1;
		конецесли;
	конеццикла;
КонецПроцедуры

&НаСервере
Процедура РаспределитьНаСервере()                 
	
	РаспределитьПоКратности();
	
	ЗаполнитьДокументы();
	
	
КонецПроцедуры     

&НаСервере
Процедура ЗаполнитьДокументы()
	
	ДокументыРозница.Очистить();     
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыКРаспределению.Группировка КАК Группировка,
	|	ТоварыКРаспределению.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВР_Распределение
	|ИЗ
	|	&ТоварыКРаспределению КАК ТоварыКРаспределению
	|ГДЕ
	|	ТоварыКРаспределению.Группировка <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВР_Распределение.Группировка КАК НомерУЦ,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВР_Распределение.Номенклатура) КАК Количество,
	|	&ДатаУЦ КАК ДатаУЦ,
	|	ВР_Распределение.Группировка КАК Группировка
	|ИЗ
	|	ВР_Распределение КАК ВР_Распределение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Ценообразование.ТаблицаУстановкаЦен КАК ЦенообразованиеТаблицаУстановкаЦен
	|		ПО ВР_Распределение.Номенклатура = ЦенообразованиеТаблицаУстановкаЦен.Номенклатура
	|			И (ЦенообразованиеТаблицаУстановкаЦен.ВидЦены.ГруппаВидовЦен.ТипГруппировкиЦен = ЗНАЧЕНИЕ(Перечисление.ТипыЦен.Опт))
	|ГДЕ
	|	ЦенообразованиеТаблицаУстановкаЦен.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВР_Распределение.Группировка,
	|	ВР_Распределение.Группировка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВР_Распределение.Группировка КАК Группировка,
	|	&ДатаУЦ КАК ДатаУЦ,
	|	ЦенообразованиеТаблицаУстановкаЦен.ВидЦены.РегионПрисутствия КАК Регион,
	|	ЦенообразованиеТаблицаУстановкаЦен.ВидЦены.ФорматПодразделения КАК Формат,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВР_Распределение.Номенклатура) КАК Количество
	|ИЗ
	|	ВР_Распределение КАК ВР_Распределение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Ценообразование.ТаблицаУстановкаЦен КАК ЦенообразованиеТаблицаУстановкаЦен
	|		ПО ВР_Распределение.Номенклатура = ЦенообразованиеТаблицаУстановкаЦен.Номенклатура
	|			И (ЦенообразованиеТаблицаУстановкаЦен.ВидЦены.ГруппаВидовЦен.ТипГруппировкиЦен = ЗНАЧЕНИЕ(Перечисление.ТипыЦен.Опт))
	|ГДЕ
	|	ЦенообразованиеТаблицаУстановкаЦен.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВР_Распределение.Группировка,
	|	ЦенообразованиеТаблицаУстановкаЦен.ВидЦены.РегионПрисутствия,
	|	ЦенообразованиеТаблицаУстановкаЦен.ВидЦены.ФорматПодразделения
	|ИТОГИ
	|	МАКСИМУМ(Количество)
	|ПО
	|	Группировка";
	
	Запрос.УстановитьПараметр("ДатаУЦ", ДатаУЦ);
	Запрос.УстановитьПараметр("Ссылка", ДокументЦенообразования);
	Запрос.УстановитьПараметр("ТоварыКРаспределению", ТоварыКРаспределению.Выгрузить());
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ДокументыОпт.Загрузить(результатыЗапроса[1].Выгрузить());
	
	//ДокументыРозница.Загрузить(результатыЗапроса[2].Выгрузить());   
	ДокументыРозница.Очистить();
	ВыборкаГруппировка = РезультатыЗапроса[2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	пока ВыборкаГруппировка.Следующий() Цикл
		СтрНомерУЦ=ДокументыРозница.Добавить();
		заполнитьзначенияСвойств(СтрНомерУЦ,ВыборкаГруппировка);
		СтрНомерУЦ.ДатаУЦ=ДатаУЦ;
		ВыборкаЗаписи=ВыборкаГруппировка.Выбрать();  
		перваястрока=истина;
		пока  ВыборкаЗаписи.Следующий() цикл
			СтрЗапись=ДокументыРозница.Добавить();
			заполнитьзначенияСвойств(СтрЗапись,ВыборкаЗаписи);
			если Перваястрока тогда
				перваястрока=ложь;
				НомерРегиона=1;НомерФормата=1;
				Регион=ВыборкаЗаписи.Регион;
				Формат=ВыборкаЗаписи.Формат;
				СтрЗапись.НомерУЦ=""+ВыборкаЗаписи.Группировка+"."+НомерРегиона+"."+НомерФормата;
			иначе
				если Регион<>ВыборкаЗаписи.Регион тогда
					Регион=ВыборкаЗаписи.Регион;
					НомерРегиона=НомерРегиона+1;
				конецесли;	
				если Формат<>ВыборкаЗаписи.Формат тогда
					Формат=ВыборкаЗаписи.Формат;
					НомерФормата=НомерФормата+1;
				конецесли;	     
				СтрЗапись.НомерУЦ=""+ВыборкаЗаписи.Группировка+"."+НомерРегиона+"."+НомерФормата;
			конецесли;	
			
		конеццикла;
	конеццикла;
	
	
КонецПроцедуры

&НаКлиенте
Процедура Распределить(Команда)
	РаспределитьНаСервере();    
	ОбновитьИнформацию();
КонецПроцедуры

&НаСервере
Процедура ТоварыКРаспределениюГруппировкаПриИзмененииНаСервере()
	ЗаполнитьДокументы();
	
КонецПроцедуры

&НаКлиенте
Процедура ТоварыКРаспределениюГруппировкаПриИзменении(Элемент)
	ТоварыКРаспределениюГруппировкаПриИзмененииНаСервере();    
	ТекущаяСтрока=Элементы.ТоварыКРаспределению.ТекущиеДанные;
	ТекущаяСтрока.Распределено=ТекущаяСтрока.Группировка<>0;
	ТекущаяСтрока.Группировка2= ТекущаяСтрока.Группировка;
    ОбновитьИнформацию();
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнформацию()
	
	ПараметрыОтбора=Новый Структура("Распределено",ложь);
	КоличествоНеРаспределенных=ТоварыКРаспределению.НайтиСтроки(ПараметрыОтбора).Количество();
	
	Элементы.НеРаспределено.Видимость= КоличествоНеРаспределенных<>0;
	Элементы.Информация.Видимость= КоличествоНеРаспределенных<>0;
	Элементы.НеРаспределено.Заголовок="Не распределено "+КоличествоНеРаспределенных+" позиций";
КонецПроцедуры


&НаСервере
Функция СохранитьРаспределениеНаСервере()
	
	ОбработатьТаблицуУЦСУчетомРаспределения();
	
	возврат ПоместитьВоВременноеХранилище(ТаблицаУстановкаЦен.Выгрузить());
	
	
КонецФункции // ()

&НаСервере
Процедура ОбработатьТаблицуУЦСУчетомРаспределения()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаУстановкиЦен.Номенклатура КАК Номенклатура,
		|	ТаблицаУстановкиЦен.ВидЦены КАК ВидЦены,
		|	ТаблицаУстановкиЦен.Цена КАК Цена,
		|	ТаблицаУстановкиЦен.ЦенаТекущая КАК ЦенаТекущая,
		|	ТаблицаУстановкиЦен.ПроцентПорог КАК ПроцентПорог,
		|	ТаблицаУстановкиЦен.Процент КАК Процент,
		|	ТаблицаУстановкиЦен.ПроцентТекущая КАК ПроцентТекущая
		|ПОМЕСТИТЬ ВР_ТаблицаУстановкаЦен
		|ИЗ
		|	&ТаблицаУстановкиЦен КАК ТаблицаУстановкиЦен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыКРаспределению.Номенклатура КАК Номенклатура,
		|	ТоварыКРаспределению.Группировка КАК Группировка
		|ПОМЕСТИТЬ ВР_ТоварыКРаспределению
		|ИЗ
		|	&ТоварыКРаспределению КАК ТоварыКРаспределению
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыОпт.НомерУЦ КАК НомерУЦ,
		|	ДокументыОпт.Группировка КАК Группировка,
		|	ДокументыОпт.ДатаУЦ КАК ДатаУЦ
		|ПОМЕСТИТЬ ВР_ДокументыОпт
		|ИЗ
		|	&ДокументыОпт КАК ДокументыОпт
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыРозница.НомерУЦ КАК НомерУЦ,
		|	ДокументыРозница.ДатаУЦ КАК ДатаУЦ,
		|	ДокументыРозница.Регион КАК Регион,
		|	ДокументыРозница.Формат КАК Формат,
		|	ДокументыРозница.Группировка КАК Группировка
		|ПОМЕСТИТЬ ВР_ДокументыРозница
		|ИЗ
		|	&ДокументыРозница КАК ДокументыРозница
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВР_ТаблицаУстановкаЦен.Номенклатура КАК Номенклатура,
		|	ВидыЦен.Ссылка КАК ВидЦены,
		|	ВР_ТаблицаУстановкаЦен.Цена КАК Цена,
		|	ВР_ТаблицаУстановкаЦен.ЦенаТекущая КАК ЦенаТекущая,
		|	ВР_ТаблицаУстановкаЦен.ПроцентПорог КАК ПроцентПорог,
		|	ВР_ТаблицаУстановкаЦен.Процент КАК Процент,
		|	ВР_ТаблицаУстановкаЦен.ПроцентТекущая КАК ПроцентТекущая,
		|	ВР_ТоварыКРаспределению.Группировка КАК Группировка
		|ПОМЕСТИТЬ ВР_Установка
		|ИЗ
		|	ВР_ТаблицаУстановкаЦен КАК ВР_ТаблицаУстановкаЦен
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВР_ТоварыКРаспределению КАК ВР_ТоварыКРаспределению
		|		ПО ВР_ТаблицаУстановкаЦен.Номенклатура = ВР_ТоварыКРаспределению.Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыЦен КАК ВидыЦен
		|		ПО ВР_ТаблицаУстановкаЦен.ВидЦены = ВидыЦен.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_Установка.Номенклатура КАК Номенклатура,
		|	ВР_Установка.ВидЦены КАК ВидЦены,
		|	ВР_Установка.Цена КАК Цена,
		|	ВР_Установка.ЦенаТекущая КАК ЦенаТекущая,
		|	ВР_Установка.ПроцентПорог КАК ПроцентПорог,
		|	ВР_Установка.Процент КАК Процент,
		|	ВР_Установка.ПроцентТекущая КАК ПроцентТекущая,
		|	ВР_Установка.Группировка КАК Группировка,
		|	ВР_ДокументыОпт.НомерУЦ КАК НомерУЦ,
		|	ВР_ДокументыОпт.ДатаУЦ КАК ДатаУЦ
		|ИЗ
		|	ВР_Установка КАК ВР_Установка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВР_ДокументыОпт КАК ВР_ДокументыОпт
		|		ПО ВР_Установка.Группировка = ВР_ДокументыОпт.Группировка
		|ГДЕ
		|	ВР_Установка.ВидЦены.ГруппаВидовЦен.ТипГруппировкиЦен <> ЗНАЧЕНИЕ(Перечисление.ТипыЦен.Розница)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВР_Установка.Номенклатура,
		|	ВР_Установка.ВидЦены,
		|	ВР_Установка.Цена,
		|	ВР_Установка.ЦенаТекущая,
		|	ВР_Установка.ПроцентПорог,
		|	ВР_Установка.Процент,
		|	ВР_Установка.ПроцентТекущая,
		|	ВР_Установка.Группировка,
		|	ВР_ДокументыРозница.НомерУЦ,
		|	ВР_ДокументыРозница.ДатаУЦ
		|ИЗ
		|	ВР_Установка КАК ВР_Установка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВР_ДокументыРозница КАК ВР_ДокументыРозница
		|		ПО ВР_Установка.Группировка = ВР_ДокументыРозница.Группировка
		|			И ВР_Установка.ВидЦены.РегионПрисутствия = ВР_ДокументыРозница.Регион
		|			И ВР_Установка.ВидЦены.ФорматПодразделения = ВР_ДокументыРозница.Формат
		|ГДЕ
		|	ВР_Установка.ВидЦены.ГруппаВидовЦен.ТипГруппировкиЦен = ЗНАЧЕНИЕ(Перечисление.ТипыЦен.Розница)";
	
	Запрос.УстановитьПараметр("ТаблицаУстановкиЦен",ТаблицаУстановкаЦен.Выгрузить());
	Запрос.УстановитьПараметр("ТоварыКРаспределению",ТоварыКРаспределению.Выгрузить());
	Запрос.УстановитьПараметр("ДокументыОпт",ДокументыОпт.Выгрузить());
	Запрос.УстановитьПараметр("ДокументыРозница",ДокументыРозница.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
    ТаблицаУстановкаЦен.загрузить(РезультатЗапроса.Выгрузить());

КонецПроцедуры


&НаКлиенте
Процедура СохранитьРаспределение(Команда)
	АдресРезультата=СохранитьРаспределениеНаСервере();
	Закрыть(АдресРезультата);	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьРаспределение(Команда)
	Закрыть(Неопределено);
КонецПроцедуры

&НаСервере
Процедура ФильтрПриИзмененииНаСервере()
	
	СтруктураОтбора = Новый Структура();
	
	Если Фильтр=1 Тогда
		СтруктураОтбора.Вставить("Распределено", Истина);
	иначеесли Фильтр=2 тогда
		СтруктураОтбора.Вставить("Распределено", ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураОтбора) Тогда
		Элементы.ТоварыКРаспределению.ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураОтбора);
	Иначе
		Элементы.ТоварыКРаспределению.ОтборСтрок = Неопределено;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ФильтрПриИзменении(Элемент)
	ФильтрПриИзмененииНаСервере();
КонецПроцедуры
