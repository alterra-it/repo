&НаСервере
Функция СтруктураПараметровСервер()
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Объект", Объект);
	СтруктураПараметров.Вставить("ДатаУЦ", ?(Объект.Приоритет=1,ТекущаяДата(),ТекущаяДата()+24*60*60));
	возврат СтруктураПараметров;	
	
КонецФункции // ()

