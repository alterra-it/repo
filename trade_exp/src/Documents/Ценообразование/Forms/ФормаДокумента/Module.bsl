&НаКлиенте
Процедура ПерейтиВОбработкуМониторинг(Команда)
	
	СтандартнаяОбработка=Ложь;
	ПараметрыКоманды = Новый Структура;
	если ЭтаФорма.ТекущийЭлемент.Имя="ПерейтиВОбработкуЦО" тогда 
		ПараметрыКоманды.Вставить("ТипФормы",1);    
	    ПараметрыКоманды.Вставить("СписокЦенАнализа",МассивВидовЦен());  
		ПараметрыКоманды.Вставить("РегионыПрисутствияАнализЦен",МассивРегионов());  
	иначе         
		НомерРегиона=число(прав(ЭтаФорма.ТекущийЭлемент.Имя,1)); 
		ПараметрыКоманды.Вставить("РегионМониторинг", РегионыПрисутствия.Получить(НомерРегиона-1).Значение);
		ПараметрыКоманды.Вставить("ТипФормы",0);  
	конецесли;
// 	ПараметрыКоманды.Вставить("Идентификатор",Объект.Ссылка);	
//	ПараметрыКоманды.Вставить("Ссылка",ДопОбработка());
//	ПараметрыКоманды.Вставить("ЭтоОтчет", Ложь);
   ПараметрыКоманды.Вставить("ИД",ЭтаФорма.УникальныйИдентификатор);
    ПараметрыКоманды.Вставить("ОткрытиеИзДокумента");  
	
	ПараметрыКоманды.Вставить("АдресРезультата",ЗаполнитьПараметрыНаСервере(ПараметрыКоманды));
	
	ОповещениеПереходВОбработку = Новый ОписаниеОповещения("ПереходВОбработку",  ЭтотОбъект);
	
	ИмяОбработки = ПолучитьИмяВнешней("c:\ит-отдел\Устинов\Обработки\Ценообразование\Ценообразование.epf");   

//	ИмяОбработки = ДополнительныеОтчетыИОбработкиВызовСервера.ПодключитьВнешнююОбработку(ПараметрыКоманды.ссылка); 
	ОткрытьФорму("ВнешняяОбработка." + ИмяОбработки + ".Форма", ПараметрыКоманды);

КонецПроцедуры   

