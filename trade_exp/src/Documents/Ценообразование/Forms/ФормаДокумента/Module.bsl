&НаСервере   
Функция ЗаполнитьПараметрыНаСервере(ПараметрыКоманды) 
	СтруктураПараметров = Новый Структура();
	если ПараметрыКоманды.ТипФормы тогда
		СтруктураПараметров.Вставить("ТаблицаАнализЦен",ТаблицаАнализЦен.Выгрузить()); 
	иначе	
		СтруктураПараметров.Вставить("ТаблицаМониторинга",Объект.ТаблицаМониторинга.Выгрузить());  
	конецесли;     
	 
	
	Возврат ПоместитьВоВременноеХранилище(СтруктураПараметров,ПараметрыКоманды.ИД);

КонецФункции

&НаСервере
Функция МассивВидовЦен()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТаблицаЦен.ВидЦены КАК ВидЦены
		|ПОМЕСТИТЬ ВР_ТаблицаЦен
		|ИЗ
		|	&ТаблицаЦен КАК ТаблицаЦен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_ТаблицаЦен.ВидЦены КАК ВидЦены
		|ИЗ
		|	ВР_ТаблицаЦен КАК ВР_ТаблицаЦен";
	
	Запрос.УстановитьПараметр("ТаблицаЦен",Объект.ТаблицаУстановкаЦен.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();

	возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("ВидЦены");
КонецФункции // ()


&НаСервере
Функция ПолучитьИмяВнешней(ИмяФайла)
    дд = Новый ДвоичныеДанные(ИмяФайла);
    АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(дд);
    ИмяОбр = ВнешниеОбработки.Подключить(АдресВоВременномХранилище,,);
    
    Возврат ИмяОбр;
КонецФункции   

