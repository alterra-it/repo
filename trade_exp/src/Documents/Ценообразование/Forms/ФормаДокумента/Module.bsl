#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Процедура ПостроитьТаблицуВидовЦен()
 	ВидыЦен.ЗагрузитьЗначения(Объект.ВидыЦен.Выгрузить().ВыгрузитьКолонку("ВидЦены"));
 	РегионыПрисутствия.ЗагрузитьЗначения(Объект.РегионыПрисутствия.Выгрузить().ВыгрузитьКолонку("Регион"));
	
	РегионыФорматы(РегионыПрисутствия);
	
	ПостроитьТаблицу("ТаблицаВидовЦен",  2);

	ПостроитьТаблицу("ТаблицаВидовЦенБезФормата",  1);

	ПостроитьТаблицу("ТаблицаВидовЦенБезРегионов",  0);
	

КонецПроцедуры

&НаСервере
Процедура ПостроитьТаблицу(ВидТаблицы, Режим)
	Если Режим <> 0 Тогда
		ПараметрыКолонки=Новый Структура("Вид", ВидПоляФормы.ПолеФлажка);
		МассивТипов=Новый Массив;
		МассивТипов.Добавить(тип("Число"));
		ОписаниеТиповКолонки=Новый ОписаниеТипов(МассивТипов);
		ТаблицаФормы = РеквизитФормыВЗначение(ВидТаблицы);   
		ТаблицаФормы.Очистить();
		Для Каждого колонка Из РегионыПрисутствия Цикл
			если режим=2 тогда
				МассивСтрокФорматов=РегионыФорматы.НайтиСтроки(Новый Структура("Регион", Колонка.Значение));
				Если МассивСтрокФорматов.Количество() > 0 Тогда
					ИмяГруппы="" + Колонка;    
					если Элементы.Найти(ВидТаблицы + ИмяГруппы)=НЕОПРЕДЕЛЕНО тогда
						ГруппаКолонок=Элементы.Добавить(ВидТаблицы + ИмяГруппы, тип("ГруппаФормы"),
						Элементы.ТаблицаВидовЦен);
						ГруппаКолонок.Заголовок=ИмяГруппы;
						ГруппаКолонок.Группировка=ГруппировкаКолонок.Горизонтальная;
						ГруппаКолонок.ОтображатьВШапке=Истина;
					конецесли;
					Для Каждого Стр Из МассивСтрокФорматов Цикл
						ИмяКолонки="" + Колонка + "_" + Стр.Формат;
						ЗаголовокКолонки=Стр.Формат;       
						если ТаблицаФормы.Колонки.Найти(ИмяКолонки)=НЕОПРЕДЕЛЕНО тогда
							ТаблицаФормы.Колонки.Добавить(ИмяКолонки, ОписаниеТиповКолонки, ЗаголовокКолонки, 3);
							ДобавляемыеРеквизиты = Новый Массив;
							УдаляемыеРеквизиты = Новый Массив;
							ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяКолонки, ОписаниеТиповКолонки, ВидТаблицы,
							ЗаголовокКолонки));
							ИзменитьРеквизиты(ДобавляемыеРеквизиты, УдаляемыеРеквизиты);  
							НоваяКолонка=Элементы.Добавить(ВидТаблицы + ИмяКолонки, тип("ПолеФормы"), ГруппаКолонок);
							НоваяКолонка.Заголовок = ЗаголовокКолонки;
							НоваяКолонка.ПутьКДанным = ВидТаблицы + "." + ИмяКолонки;
							НоваяКолонка.ПутьКДаннымПодвала = ВидТаблицы + "." + ИмяКолонки;
							заполнитьзначениясвойств(НоваяКолонка, ПараметрыКолонки);  
						конецесли;
					КонецЦикла;
				КонецЕсли;
			иначе 
				ИмяКолонки="" + Колонка + "_ТСК" ;
				ЗаголовокКолонки=Колонка;       
				если ТаблицаФормы.Колонки.Найти(ИмяКолонки)=НЕОПРЕДЕЛЕНО тогда
					ТаблицаФормы.Колонки.Добавить(ИмяКолонки, ОписаниеТиповКолонки, ЗаголовокКолонки, 3);
					ДобавляемыеРеквизиты = Новый Массив;
					УдаляемыеРеквизиты = Новый Массив;
					ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяКолонки, ОписаниеТиповКолонки, ВидТаблицы,
					ЗаголовокКолонки));
					ИзменитьРеквизиты(ДобавляемыеРеквизиты, УдаляемыеРеквизиты);            
					НоваяКолонка=Элементы.Добавить(ВидТаблицы + ИмяКолонки, тип("ПолеФормы"), Элементы[ВидТаблицы]);
					НоваяКолонка.Заголовок = ЗаголовокКолонки;
					НоваяКолонка.ПутьКДанным = ВидТаблицы + "." + ИмяКолонки;
					НоваяКолонка.ПутьКДаннымПодвала = ВидТаблицы + "." + ИмяКолонки;
					заполнитьзначениясвойств(НоваяКолонка, ПараметрыКолонки);
				конецесли;
			конецесли;	
		КонецЦикла;
		ЗначениеВРеквизитФормы(ТаблицаФормы, ВидТаблицы);  
	иначе	
	ТаблицаВидовЦенБезРегионов.Очистить();	
	КонецЕсли;            
	
	// заполняем таблицу
	ДобавитьСтрокиВТаблицу(режим, РегионыПрисутствия);
	
	РаскраситьТаблицу(режим, ВидТаблицы);
	
КонецПроцедуры

&НаСервере
Процедура РегионыФорматы(РегионыПрисутствия)

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВидыЦен.РегионПрисутствия КАК Регион,
	|	ВидыЦен.ФорматПодразделения КАК Формат
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	ВидыЦен.РегионПрисутствия В(&РегионПрисутствия)
	|	И НЕ ВидыЦен.НеИспользуетсяВОбработкеЦО и НЕ ВидыЦен.ГруппаВидовЦен.НеИспользуетсяВОбработкеЦО
	|
	|УПОРЯДОЧИТЬ ПО
	|	Формат";

	Запрос.УстановитьПараметр("РегионПрисутствия", РегионыПрисутствия);

	РезультатЗапроса = Запрос.Выполнить();

	РегионыФорматы.Загрузить(РезультатЗапроса.Выгрузить());
КонецПроцедуры


&НаСервере
Процедура ДобавитьСтрокиВТаблицу(Режим, РегионыПрисутствия = Неопределено)
	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВидыЦен.Ссылка КАК Ссылка,
	|	ВидыЦен.ГруппаВидовЦен КАК ГруппаВидовЦен,
	|	ВидыЦен.РегионПрисутствия КАК РегионПрисутствия,
	|	ВидыЦен.ФорматПодразделения КАК ФорматПодразделения,
	|	ВидыЦен.Ссылка В (&ВидыЦен) КАК Пометка
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	&УсловиеРегион
	|	И НЕ ВидыЦен.ГруппаВидовЦен.НеИспользуетсяВОбработкеЦО и НЕ ВидыЦен.НеИспользуетсяВОбработкеЦО
	|ИТОГИ ПО
	|	ГруппаВидовЦен";

	Запрос.УстановитьПараметр("ВидыЦен", ВидыЦен);
	Запрос.УстановитьПараметр("режим", ?(Режим = 0, 1, Режим));
	Запрос.УстановитьПараметр("РегионыПрисутствия", РегионыПрисутствия);

	Если режим = 0 Тогда
		Запрос.Текст=стрзаменить(Запрос.Текст, "&УсловиеРегион",
			"ВидыЦен.РегионПрисутствия.Ссылка есть NULL и не ВидыЦен.ГруппаВидовЦен.ссылка есть NULL");
	ИначеЕсли режим = 2 Тогда
		Запрос.Текст=стрзаменить(Запрос.Текст, "&УсловиеРегион",
			"ВидыЦен.РегионПрисутствия.Ссылка в (&РегионыПрисутствия) И ВидыЦен.Колонка <> 0");
	Иначе
		Запрос.Текст=стрзаменить(Запрос.Текст, "&УсловиеРегион",
			"ВидыЦен.РегионПрисутствия.Ссылка в (&РегионыПрисутствия) И ВидыЦен.Колонка = 0");
	КонецЕсли;
	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаГруппаВидовЦен = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаГруппаВидовЦен.Следующий() Цикл
		// Вставить обработку выборки ВыборкаГруппаВидовЦен  
		Если режим = 2 Тогда
			Стр=ТаблицаВидовЦен.Добавить();
		ИначеЕсли режим = 1 Тогда
			Стр=ТаблицаВидовЦенБезФормата.Добавить();
		ИначеЕсли режим = 0 Тогда
			Стр=ТаблицаВидовЦенБезРегионов.Добавить();
		КонецЕсли;
		Стр.ВидЦены=ВыборкаГруппаВидовЦен.ГруппаВидовЦен;
		ВыборкаДетальныеЗаписи = ВыборкаГруппаВидовЦен.Выбрать();

		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			// Вставить обработку выборки ВыборкаДетальныеЗаписи 
			УстановитьПометкиВТаблице(ВыборкаДетальныеЗаписи, стр, режим);

		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура РаскраситьТаблицу(Режим, ВидТаблицы)
	ТаблицаФормы = РеквизитФормыВЗначение(ВидТаблицы);   
	// колонки
	Для Каждого колонка Из ТаблицаФормы.Колонки Цикл
		Если колонка.Имя = "ВидЦены" Или колонка.Имя = "Колонка" Тогда
			Продолжить;
		КонецЕсли;
		Если Этаформа[ВидТаблицы].Итог(Колонка.имя) > 0 Тогда
			Элементы[ВидТаблицы + Колонка.имя].ЦветФонаЗаголовка=webцвета.ЗеленоватоЛимонный;
		Иначе
			Элементы[ВидТаблицы + Колонка.имя].ЦветФонаЗаголовка=Новый Цвет;
		КонецЕсли;
	КонецЦикла;
	Если режим <> 0 Тогда
		Для Каждого стр Из Этаформа[ВидТаблицы] Цикл
			Количество=0;
			Для Каждого колонка Из ТаблицаФормы.Колонки Цикл
				Если колонка.Имя = "ВидЦены" Или колонка.Имя = "Колонка" Тогда
					Продолжить;
				КонецЕсли;
				Количество=Количество + стр[колонка.имя];
			КонецЦикла;
			стр.Колонка=Количество > 0;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура УстановитьПометкиВТаблице(Стрзапроса, СтрТаблицы, Режим)
	Если Не стрзапроса.Пометка Тогда
		Возврат;
	КонецЕсли;
	Если Режим = 0 Тогда
		СтрТаблицы.Колонка=Истина;
	Иначе
		Ячейка="" + стрзапроса.РегионПрисутствия + "_" + стрзапроса.ФорматПодразделения;
		СтрТаблицы[Ячейка]=Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВидыЦен()
    	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТаблицаСебестоимости.Регион КАК Регион
		|ПОМЕСТИТЬ ВР_ТаблицаСебестоимости
		|ИЗ
		|	&ТаблицаСебестоимости КАК ТаблицаСебестоимости
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТаблицаЦен.ВидЦены КАК ВидЦены
		|ПОМЕСТИТЬ ВР_ТаблицаЦен
		|ИЗ
		|	&ТаблицаЦен КАК ТаблицаЦен
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_ТаблицаСебестоимости.Регион КАК Регион
		|ИЗ
		|	ВР_ТаблицаСебестоимости КАК ВР_ТаблицаСебестоимости
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВР_ТаблицаЦен.ВидЦены КАК ВидЦены
		|ИЗ
		|	ВР_ТаблицаЦен КАК ВР_ТаблицаЦен";
	
	Запрос.УстановитьПараметр("ТаблицаСебестоимости",Объект.ТаблицаСебестоимости.Выгрузить() );
	Запрос.УстановитьПараметр("ТаблицаЦен",Объект.ТаблицаУстановкаЦен.Выгрузить() );
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Объект.РегионыПрисутствия.Загрузить(РезультатЗапроса[2].Выгрузить());
	Объект.ВидыЦен.Загрузить(РезультатЗапроса[3].Выгрузить());
	
	//СтруктураПараметров.Вставить("Регионы",РезультатЗапроса[2].Выгрузить().ВыгрузитьКолонку("Регион"));
	//СтруктураПараметров.Вставить("ВидыЦен",РезультатЗапроса[3].Выгрузить().ВыгрузитьКолонку("ВидЦены"));  

	

КонецПроцедуры


&НаСервере
Процедура РассчитатьТекущуюПереоценку()

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ТаблицаОграничений.НомерСтроки КАК НомерСтроки,
		|	ТаблицаОграничений.Регион КАК Регион,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЦеныНоменклатуры.Регистратор) КАК ТекущаяПереоценка
		|ИЗ
		|	Документ.Ценообразование.ТаблицаОграничений КАК ТаблицаОграничений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
		|		ПО ТаблицаОграничений.Регион = ЦеныНоменклатуры.ВидЦены.РегионПрисутствия
		|			И (ЦеныНоменклатуры.Период МЕЖДУ НАЧАЛОПЕРИОДА(&ДатаДокумента, ДЕНЬ) И КОНЕЦПЕРИОДА(&ДатаДокумента, ДЕНЬ))
		|ГДЕ
		|	ТаблицаОграничений.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ТаблицаОграничений.НомерСтроки,
		|	ТаблицаОграничений.Регион";
	
	Запрос.УстановитьПараметр("Ссылка", объект.Ссылка);
	Запрос.УстановитьПараметр("ДатаДокумента", объект.Дата);

	ТаблицаТекущейПереоценки = Запрос.Выполнить().Выгрузить();
	для каждого стр из Объект.ТаблицаОграничений цикл                                  
		НайденныеСтроки=ТаблицаТекущейПереоценки.НайтиСтроки(Новый Структура("НомерСтроки",стр.Номерстроки));
		если НайденныеСтроки.Количество()>0 тогда
			стр.ТекущаяПереоценка= НайденныеСтроки[0].ТекущаяПереоценка;  
		конецесли;
	конеццикла;	

КонецПроцедуры


&НаСервере
Процедура УсловноеОформление()
	УсловноеОформление.Элементы.Очистить();
	УсловноеОформлениеОсновное();
	УсловноеОформлениеМониторинг();
	УсловноеОформлениеТаблицыЦен();
	УсловноеОформлениеУстановкаЦен();
КонецПроцедуры

&НаСервере
Функция ВернутьПараметрыТаблицы()  
	
	СтруктураПараметров=Новый Структура();
	СтруктураПараметров.Вставить("Регионы",Объект.РегионыПрисутствия.Выгрузить().ВыгрузитьКолонку("Регион"));
	СтруктураПараметров.Вставить("ВидыЦен",Объект.ВидыЦен.Выгрузить().ВыгрузитьКолонку("ВидЦены"));  
	
	
	
	возврат СтруктураПараметров;
КонецФункции

&НаСервере
Процедура УсловноеОформлениеТаблицыЦен()
		СтруктураПараметров=ВернутьПараметрыТаблицы();	
		ПостроениеТаблицыАнализа(СтруктураПараметров);
		ЗаполнениеТаблицыАнализа();
		УстановитьОформлениеСтраницыТаблицыЦен();
КонецПроцедуры

&НаСервере
Процедура УсловноеОформлениеУстановкаЦен()
	если Объект.ПревышенЛимитВРамкахДня тогда
		Элементы.УстановкаЦен.ЦветТекстаЗаголовка=WebЦвета.Красный;
	конецесли;      
	Элементы.ТаблицаОграниченийУЦТекущееКоличество.Заголовок=
	"Плановое кол-во SKU на день переоценки по всем согласованным документам на "+формат(объект.ДатаПереоценкиРозница, "ДЛФ=Д");

	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ЭлементКолонки=Элементы["ТаблицаОграниченийУЦТекущееКоличество"];
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементКолонки.Имя);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.ТаблицаОграничений.Лимит");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.равно; 
	ОтборЭлемента.ПравоеЗначение = 1;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.Красный);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОформлениеСтраницыТаблицыЦен()
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ЭлементКолонки=Элементы["ТаблицаАнализЦенНоменклатура"];
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементКолонки.Имя);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаАнализЦен.Скорректировать");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.равно; 
	ОтборЭлемента.ПравоеЗначение = ИСТИНА;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.розовый);
КонецПроцедуры

&НаСервере
Процедура УстановитьЗначениеКолонки(Колонка, КолонкаСтр, Стр, СтрСтрока)
	Если колонка[КолонкаСтр] <> 0 Тогда
		Стр[СтрСтрока]=колонка[КолонкаСтр];
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеТаблицыАнализа()
	ТаблицаЦен=Объект.ТаблицаУстановкаЦен.Выгрузить();
	ТаблицаСебестоимости=Объект.ТаблицаСебестоимости.Выгрузить();
	
	для каждого стр из ТаблицаАнализЦен цикл
		МассивСтрокСС=ТаблицаСебестоимости.НайтиСтроки(Новый Структура("Номенклатура",стр.Номенклатура));
		для каждого КолонкаСС из МассивСтрокСС цикл
			УстановитьЗначениеКолонки(КолонкаСС,"СебестоимостьНовая",стр,"НоваяСС_"+КолонкаСС.Регион);
		конеццикла;	
		МассивСтрок=ТаблицаЦен.НайтиСтроки(Новый Структура("Номенклатура",стр.Номенклатура));
		для каждого Колонка из МассивСтрок цикл
			УстановитьЗначениеКолонки(Колонка,"Цена",стр,Колонка.ВидЦены.Идентификатор);
			УстановитьЗначениеКолонки(Колонка,"ЦенаТекущая",стр,Колонка.ВидЦены.Идентификатор+"Текущая");
			УстановитьЗначениеКолонки(Колонка,"ПроцентПорог",стр,"ПроцентПорог_"+Колонка.ВидЦены.Идентификатор);
			УстановитьЗначениеКолонки(Колонка,"Процент",стр,"Процент_"+Колонка.ВидЦены.Идентификатор);
			УстановитьЗначениеКолонки(Колонка,"ПроцентТекущая",стр,"Процент_"+Колонка.ВидЦены.Идентификатор+"Текущая");
		конеццикла;	
	конеццикла;	
КонецПроцедуры	
&НаСервере
Процедура ПостроениеТаблицыАнализа(СтруктураПараметров)
	ТаблицаАнализЦен.Загрузить(Объект.ТаблицаАнализЦен.Выгрузить());
	ТаблицаФормы = РеквизитФормыВЗначение("ТаблицаАнализЦен");
	ТипКолонки = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15, 2));
	
	МассивОписания=Новый Массив();
	МассивОписания.Добавить(тип("Строка"));
	МассивОписания.Добавить(тип("Число"));
	ТипКолонкиНовая = Новый ОписаниеТипов(МассивОписания,,,Новый КвалификаторыЧисла(15, 2),Новый КвалификаторыСтроки(30));
	// Добавляем колонки		
	НовыеРеквизиты = Новый Массив;     
	МассивРегионов=СтруктураПараметров.Регионы;	
	Для Каждого Колонка Из МассивРегионов Цикл  
		ТаблицаФормы.Колонки.Добавить("НоваяСС_"+Колонка.Наименование,ТипКолонки); 
		НовыеРеквизиты.Добавить(Новый РеквизитФормы("НоваяСС_"+Колонка.Наименование,ТипКолонки,"ТаблицаАнализЦен"));
	конеццикла;
	МассивВидовЦен=СтруктураПараметров.ВидыЦен;
	Для Каждого стр Из МассивВидовЦен Цикл

		ТаблицаФормы.Колонки.Добавить(стр.Идентификатор + "Текущая", ТипКолонки);
		НовыеРеквизиты.Добавить(Новый РеквизитФормы(стр.Идентификатор + "Текущая", ТипКолонки, "ТаблицаАнализЦен"));
		ТаблицаФормы.Колонки.Добавить("Процент_" + стр.Идентификатор + "Текущая", ТипКолонки);
		НовыеРеквизиты.Добавить(Новый РеквизитФормы("Процент_" + стр.Идентификатор + "Текущая", ТипКолонки,
			"ТаблицаАнализЦен"));  
		//	конецесли;	
		ТаблицаФормы.Колонки.Добавить(стр.Идентификатор, ТипКолонкиНовая);
		НовыеРеквизиты.Добавить(Новый РеквизитФормы(стр.Идентификатор, ТипКолонкиНовая, "ТаблицаАнализЦен"));
		ТаблицаФормы.Колонки.Добавить("Раскраска_" + стр.Идентификатор, ТипКолонки);
		НовыеРеквизиты.Добавить(Новый РеквизитФормы("Раскраска_" + стр.Идентификатор, ТипКолонки, "ТаблицаАнализЦен"));   
		//	если РежимПерехода<>0 тогда
		ТаблицаФормы.Колонки.Добавить("Процент_" + стр.Идентификатор, ТипКолонки);
		НовыеРеквизиты.Добавить(Новый РеквизитФормы("Процент_" + стр.Идентификатор, ТипКолонки, "ТаблицаАнализЦен"));
		Если стр.ФорматПодразделения <> Справочники.ФорматыПодразделений.ТСК Тогда
			ТаблицаФормы.Колонки.Добавить("ПроцентПорог_" + стр.Идентификатор, ТипКолонки);
			НовыеРеквизиты.Добавить(Новый РеквизитФормы("ПроцентПорог_" + стр.Идентификатор, ТипКолонки,
				"ТаблицаАнализЦен"));
		КонецЕсли;

	КонецЦикла;	
	ИзменитьРеквизиты(НовыеРеквизиты); 
		Для Каждого Колонка Из МассивРегионов Цикл    
		ИмяКолонки="НоваяСС_"+Колонка.Наименование; 
		если Элементы.Найти("ТаблицаАнализЦен" + "_" + ИмяКолонки)= НЕОПРЕДЕЛЕНО тогда
			НовыйЭлемент = Элементы.Добавить("ТаблицаАнализЦен" + "_" + ИмяКолонки, Тип("ПолеФормы"), Элементы["ГруппаНоваяСебестоимость"]);
			НовыйЭлемент.Заголовок="Регион "+Колонка.Наименование;
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода; 
			НовыйЭлемент.Ширина=4;
			НовыйЭлемент.ПутьКДанным = "ТаблицаАнализЦен" + "." + ИмяКолонки;   
		конецесли;
	КонецЦикла;        
	
	ДобавлениеКолонокТаблицыАнализа(Элементы["ТаблицаАнализЦен"],МассивВидовЦен);
		
	ЗначениеВРеквизитФормы(ТаблицаФормы, "ТаблицаАнализЦен");
		
КонецПроцедуры

&НаСервере
Процедура ДобавлениеКолонокТаблицыАнализа(ТаблицаФормы,СписокЦенАнализа)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыЦен.Ссылка КАК ВидЦены,
	|	ВидыЦен.РегионПрисутствия КАК Регион,
	|	ВидыЦен.ФорматПодразделения КАК ФорматПодразделения,
	|	ВидыЦен.Идентификатор КАК Идентификатор,
	|	ВЫБОР
	|		КОГДА ВидыЦен.ГруппаВидовЦен.ТипГруппировкиЦен = ЗНАЧЕНИЕ(Перечисление.ТипыЦен.Розница)
	|			ТОГДА ""Розница""
	|		ИНАЧЕ ""Опт""
	|	КОНЕЦ КАК ГруппаОптРозница,
	|	ВЫБОР
	|		КОГДА ВидыЦен.ГруппаВидовЦен.ТипГруппировкиЦен = ЗНАЧЕНИЕ(Перечисление.ТипыЦен.Розница)
	|			ТОГДА 1
	|		ИНАЧЕ 2
	|	КОНЕЦ КАК Приоритет,
	|	ВидыЦен.ГруппаВидовЦен.Наименование КАК Наименование,
	|	ВидыЦен.ФорматПодразделения <> ЗНАЧЕНИЕ(Справочник.ФорматыПодразделений.ТСК) КАК МД
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	ВидыЦен.Ссылка В(&ВидыЦен)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Приоритет,
	|	ВидыЦен.РегионПрисутствия.Код,
	|	ВидыЦен.ГруппаВидовЦен.Код
	|ИТОГИ ПО
	|	ГруппаОптРозница,
	|	Регион,
	|	ФорматПодразделения";
	
	Запрос.УстановитьПараметр("ВидыЦен", СписокЦенАнализа);    
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаГруппа = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);  
	
	Пока ВыборкаГруппа.Следующий() Цикл
		ИмяКолонки="ТаблицаАнализЦен_"+ВыборкаГруппа.ГруппаОптРозница; 
		если Элементы.Найти(ИмяКолонки)= НЕОПРЕДЕЛЕНО тогда
			НовыйЭлементГруппа = Элементы.Добавить( ИмяКолонки, тип("ГруппаФормы"),Элементы.ТаблицаАнализЦен);
			НовыйЭлементГруппа.Заголовок=ВыборкаГруппа.ГруппаОптРозница;
			НовыйЭлементГруппа.Группировка=ГруппировкаКолонок.Горизонтальная;
			НовыйЭлементГруппа.ОтображатьВШапке=Истина;     
			НовыйЭлементГруппа.ГоризонтальноеПоложениеВШапке=ГоризонтальноеПоложениеЭлемента.Центр;   
			если ВыборкаГруппа.ГруппаОптРозница="Розница" тогда
				НовыйЭлементГруппа.ЦветФонаЗаголовка=webЦвета.БледноЗеленый;
			иначе
				НовыйЭлементГруппа.ЦветФонаЗаголовка=webЦвета.Голубой;
			конецесли;
		конецесли;
		
		ВыборкаРегионПрисутствия =ВыборкаГруппа.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		
		Пока ВыборкаРегионПрисутствия.Следующий() Цикл
			ИмяКолонки="ТаблицаАнализЦен_"+ВыборкаГруппа.ГруппаОптРозница+"_"+ВыборкаРегионПрисутствия.Регион; 
			если Элементы.Найти(ИмяКолонки)= НЕОПРЕДЕЛЕНО тогда
				НовыйЭлементРегион = Элементы.Добавить( ИмяКолонки, тип("ГруппаФормы"),НовыйЭлементГруппа);
				НовыйЭлементРегион.Заголовок="Регион "+ВыборкаРегионПрисутствия.Регион;
				НовыйЭлементРегион.Группировка=ГруппировкаКолонок.Горизонтальная;  
				НовыйЭлементРегион.ГоризонтальноеПоложениеВШапке=ГоризонтальноеПоложениеЭлемента.Центр;
				НовыйЭлементРегион.ОтображатьВШапке=Истина;                                     
				если ВыборкаРегионПрисутствия.Регион.Цвет<>"" тогда          
					Массив=СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(ВыборкаРегионПрисутствия.Регион.Цвет);
					НовыйЭлементРегион.ЦветФонаЗаголовка=Новый Цвет(Число(массив[1]),Число(массив[0]),Число(массив[2]));
				конецесли;
 			конецесли;
			
			ВыборкаФорматПодразделения = ВыборкаРегионПрисутствия.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Пока ВыборкаФорматПодразделения.Следующий() Цикл
				ИмяКолонки="ТаблицаАнализЦен_Формат_"+ВыборкаГруппа.ГруппаОптРозница+"_"+ВыборкаРегионПрисутствия.Регион+"_"+ВыборкаФорматПодразделения.ФорматПодразделения; 
				если Элементы.Найти(ИмяКолонки)= НЕОПРЕДЕЛЕНО тогда
					НовыйЭлементФормат = Элементы.Добавить(ИмяКолонки, тип("ГруппаФормы"), НовыйЭлементРегион);
					НовыйЭлементФормат.Заголовок=ВыборкаФорматПодразделения.ФорматПодразделения;
					НовыйЭлементФормат.Группировка=ГруппировкаКолонок.Горизонтальная;   
					НовыйЭлементФормат.ГоризонтальноеПоложениеВШапке=ГоризонтальноеПоложениеЭлемента.Центр;
					НовыйЭлементФормат.ОтображатьВШапке=Истина;                                    
					НовыйЭлементФормат.Ширина=4;
					если ВыборкаФорматПодразделения.ФорматПодразделения.Цвет<>"" тогда          
						Массив=СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(ВыборкаФорматПодразделения.ФорматПодразделения.Цвет);
						НовыйЭлементФормат.ЦветФонаЗаголовка=Новый Цвет(Число(массив[0]),Число(массив[1]),Число(массив[2]));
					конецесли;
					
				конецесли;
				ВыборкаДетальныеЗаписи = ВыборкаФорматПодразделения.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл          
					ИмяКолонки=ВыборкаДетальныеЗаписи.Идентификатор;
					Если Элементы.Найти("ТаблицаАнализЦен_" + ИмяКолонки) = Неопределено Тогда  
					//	если РежимПерехода<>0 тогда                 
						ИмяКолонки=ВыборкаДетальныеЗаписи.Идентификатор + "Текущая";
						НовыйЭлемент = Элементы.Добавить("ТаблицаАнализЦен_" + ИмяКолонки, Тип("ПолеФормы"),
							НовыйЭлементФормат);
						НовыйЭлемент.Заголовок="Текущая " + ВыборкаДетальныеЗаписи.Наименование;
						НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
						НовыйЭлемент.Ширина=10;
						НовыйЭлемент.ПутьКДанным = "ТаблицаАнализЦен" + "." + ИмяКолонки;

						ИмяКолонки="Процент_" + ИмяКолонки;
						НовыйЭлемент = Элементы.Добавить("ТаблицаАнализЦен_" + ИмяКолонки, Тип("ПолеФормы"),
							НовыйЭлементФормат);
						НовыйЭлемент.Заголовок="%";
						НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
						НовыйЭлемент.Ширина=4;
						НовыйЭлемент.ПутьКДанным = "ТаблицаАнализЦен" + "." + ИмяКолонки;

						Если ВыборкаДетальныеЗаписи.МД Тогда
							ИмяКолонки="ПроцентПорог_" + ВыборкаДетальныеЗаписи.Идентификатор;
							НовыйЭлемент = Элементы.Добавить("ТаблицаАнализЦен_" + ИмяКолонки, Тип("ПолеФормы"),
								НовыйЭлементФормат);
							НовыйЭлемент.Заголовок="% по порогу";
							НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
							НовыйЭлемент.Ширина=4;
							НовыйЭлемент.ПутьКДанным = "ТаблицаАнализЦен" + "." + ИмяКолонки;
						КонецЕсли;
					//	конецесли;           
						ИмяКолонки=ВыборкаДетальныеЗаписи.Идентификатор;
						НовыйЭлемент = Элементы.Добавить("ТаблицаАнализЦен_" + ИмяКолонки, Тип("ПолеФормы"),
							НовыйЭлементФормат);
						НовыйЭлемент.Заголовок="Новая " + ВыборкаДетальныеЗаписи.Наименование;
						НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
						НовыйЭлемент.Ширина=10;
						НовыйЭлемент.ПутьКДанным = "ТаблицаАнализЦен" + "." + ИмяКолонки;   
						// раскраска
						ИмяКолонки="Раскраска_" + ВыборкаДетальныеЗаписи.Идентификатор;
						НовыйЭлементРаскраска = Элементы.Добавить("ТаблицаАнализЦен_" + ИмяКолонки, Тип("ПолеФормы"),
							НовыйЭлементФормат);
						НовыйЭлементРаскраска.ПутьКДанным = "ТаблицаАнализЦен" + "." + ИмяКолонки;
						НовыйЭлементРаскраска.Видимость=Ложь;
						УстановитьУсловноеОформлениеЯчейкиТаблицы(НовыйЭлемент, ИмяКолонки);
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;   
		КонецЦикла;
		
	КонецЦикла;
	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеЯчейкиТаблицы(НовыйЭлемент,ИмяКолонки)
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(НовыйЭлемент.Имя);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаАнализЦен" + "." + ИмяКолонки);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; 
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить(2);
	СписокЗначений.Добавить(4);
	ОтборЭлемента.ПравоеЗначение = СписокЗначений;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.розовый);
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(НовыйЭлемент.Имя);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаАнализЦен" + "." + ИмяКолонки);
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке; 
	СписокЗначений = Новый СписокЗначений;
	СписокЗначений.Добавить(3);
	СписокЗначений.Добавить(5);
	СписокЗначений.Добавить(6);
	ОтборЭлемента.ПравоеЗначение = СписокЗначений;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.Хаки);
	
КонецПроцедуры

&НаСервере
Процедура УсловноеОформлениеМониторинг()
	СчетчикСтраниц=0;
	Для Каждого стр Из Объект.ТаблицаОграничений Цикл
		Если стр.мониторинг Тогда
			СчетчикСтраниц=СчетчикСтраниц + 1;
			Элементы["Мониторинг_" + СчетчикСтраниц].Видимость=Истина;
			Элементы["Мониторинг_" + СчетчикСтраниц].Заголовок="Мониторинг " + стр.Регион;
			СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("Регион", стр.Регион); 
			СтрМониторинга=СтраницыМониторинга.Добавить();
			СтрМониторинга.Регион=стр.Регион;
			Элементы["ТаблицаМониторинга_" + СчетчикСтраниц].ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураОтбора);
			ПостроитьКолонкиКонтрагентов(СчетчикСтраниц,стр.Регион);
			ЗаполнитьКолонкиКонтрагентов(СчетчикСтраниц,стр.Регион);
			УстановитьОформлениеСтраницыМониторинга(СчетчикСтраниц);     
			ОформитьЗаголовокСтраницы(СчетчикСтраниц,Стр.Регион);

		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура УстановитьОформлениеСтраницыМониторинга(СчетчикСтраниц)
	ТипВидимости=Объект.Мониторинг;
	Элементы["ТаблицаМониторингаГруппаОпт_"+СчетчикСтраниц].Видимость=?(ТипВидимости = 2, Ложь, Истина);
	Элементы["ТаблицаМониторингаГруппаРозницаВОпте_"+СчетчикСтраниц].Видимость=?(ТипВидимости = 2 Или ТипВидимости = 0, Ложь, Истина);
	Элементы["ТаблицаМониторингаГруппаРозница_"+СчетчикСтраниц].Видимость=?(ТипВидимости = 1, Ложь, Истина);
	Элементы["ТаблицаМониторингаГруппаОптВРознице_"+СчетчикСтраниц].Видимость=?(ТипВидимости = 1 Или ТипВидимости = 0, Ложь, Истина);
	Элементы["ГруппаКонкуренты1_"+СчетчикСтраниц].Видимость=Объект.СпособОтЦенКонкурентов;
	Элементы["ГруппаКонкуренты2_"+СчетчикСтраниц].Видимость=Объект.СпособОтЦенКонкурентов;
	Элементы["ТаблицаМониторингаЦенаРекомендованная2_"+СчетчикСтраниц].Видимость=Объект.СпособОтМОЦ_РРЦ;
	Элементы["ТаблицаМониторингаЦенаРекомендованная1_"+СчетчикСтраниц].Видимость=Объект.СпособОтМОЦ_РРЦ;
	Элементы["ТаблицаМониторингаИтогЦена1_"+СчетчикСтраниц].Заголовок=ПодписьБазовыйВидГруппировкиЦены();
	//условное оформление
	Элемент = УсловноеОформление.Элементы.Добавить();
	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ЭлементКолонки=Элементы["ТаблицаМониторингаТоварнаяКатегория_Номенклатура_"+СчетчикСтраниц];
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ЭлементКолонки.Имя);
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ТаблицаМониторинга.Скорректировать");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.равно; 
	ОтборЭлемента.ПравоеЗначение = 1;
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.розовый);


		
КонецПроцедуры

&НаСервере
Процедура ОформитьЗаголовокСтраницы(СчетчикСтраниц,Регион=НЕОПРЕДЕЛЕНО)   
	если Регион=НЕОПРЕДЕЛЕНО тогда 
	    НайденнаяСтрока=СтраницыМониторинга.НайтиПоИдентификатору(СчетчикСтраниц-1);
		если НайденнаяСтрока<>НЕОПРЕДЕЛЕНО тогда
			Регион=НайденнаяСтрока.Регион;
		иначе     
			Возврат;
		конецесли;	
	конецесли;	
	Строки=ТаблицаМониторинга.Выгрузить(Новый Структура("Скорректировать,Регион",1,Регион));
	если строки.Количество()>0 тогда
		Элементы["Мониторинг_"+СчетчикСтраниц].ЦветТекстаЗаголовка=WebЦвета.Красный;
	иначе
		Элементы["Мониторинг_"+СчетчикСтраниц].ЦветТекстаЗаголовка=Новый Цвет();
	конецесли;	

КонецПроцедуры

&НаСервере
Функция ПодписьБазовыйВидГруппировкиЦены()

	 Возврат "Итог.знач.цены("+Объект.БазоваяОптМониторинг.Наименование+")";
	
КонецФункции // ()

&НаСервере
Процедура ЗаполнитьКолонкиКонтрагентов(СчетчикСтраниц, Регион)
	Для Каждого стр Из ТаблицаМониторинга Цикл
		Если Не стр.ГруппаТоварнойКатегории Тогда
			МассивСтрок=Объект.ТаблицаКонкурентов.НайтиСтроки(Новый Структура("Номенклатура,Регион",
				стр.ТоварнаяКатегория_Номенклатура, Регион));
			Для Каждого СтрокаКонкурентов Из МассивСтрок Цикл
				ПартнерКод=СОКРЛП(стрзаменить(СтрокаКонкурентов.Партнер.Код, "-", ""));
				Стр["КонтрагентЦена_" + СтрокаКонкурентов.ТипЦены + "_" + ПартнерКод]=СтрокаКонкурентов.Цена;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПостроитьКолонкиКонтрагентов(СчетчикСтраниц,Регион)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВР_Конкуренты.Партнер КАК Партнер,
		|	ВР_Конкуренты.ТипЦены КАК ТипЦены
		|ПОМЕСТИТЬ ВР_Партнеры
		|ИЗ
		|	&ТаблицаКонкуренты КАК ВР_Конкуренты
		|ГДЕ
		|	ВР_Конкуренты.Регион = &Регион
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВР_Партнеры.Партнер КАК Партнер,
		|	ВР_Партнеры.ТипЦены КАК ТипЦены,
		|	ВР_Партнеры.Партнер.Код КАК ПартнерКод
		|ИЗ
		|	ВР_Партнеры КАК ВР_Партнеры";
	
	Запрос.УстановитьПараметр("Регион", Регион);
	Запрос.УстановитьПараметр("ТаблицаКонкуренты", Объект.ТаблицаКонкурентов.Выгрузить());
	
	ТаблицаФормы = РеквизитФормыВЗначение("ТаблицаМониторинга");  
//	УдаляемыеРеквизиты=УдаляемыеРеквизитыКолонок(ТаблицаФормы);
	
	ТипКолонки = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15, 2));

	НовыеРеквизиты = Новый Массив;     

	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл    
		ПартнерКод=""+ВыборкаДетальныеЗаписи.ТипЦены+"_"+СОКРЛП(стрзаменить(ВыборкаДетальныеЗаписи.ПартнерКод,"-",""));
		если ТаблицаФормы.Колонки.Найти("КонтрагентЦена_"+ПартнерКод)=НЕОПРЕДЕЛЕНО тогда	
//			ТаблицаФормы.Колонки.Добавить("Контрагент_"+ВыборкаДетальныеЗаписи.ПартнерКод,ТипКолонки); 
//			НовыеРеквизиты.Добавить(Новый РеквизитФормы("Контрагент_"+ВыборкаДетальныеЗаписи.ПартнерКод,ТипКолонки,"ТаблицаМониторинга"));  
			//ТаблицаФормы.Колонки.Добавить("КонтрагентНоменклатура_"+ВыборкаДетальныеЗаписи.ПартнерКод,ТипКолонки); 
			//НовыеРеквизиты.Добавить(Новый РеквизитФормы("КонтрагентНоменклатура_"+ВыборкаДетальныеЗаписи.ПартнерКод,ТипКолонки,"ТаблицаМониторинга"));  
			ТаблицаФормы.Колонки.Добавить("КонтрагентЦена_"+ПартнерКод,ТипКолонки); 
			НовыеРеквизиты.Добавить(Новый РеквизитФормы("КонтрагентЦена_"+ПартнерКод,ТипКолонки,"ТаблицаМониторинга"));  
			ТаблицаФормы.Колонки.Добавить("КонтрагентПроцент_"+ПартнерКод,ТипКолонки); 
			НовыеРеквизиты.Добавить(Новый РеквизитФормы("КонтрагентПроцент_"+ПартнерКод,ТипКолонки,"ТаблицаМониторинга"));  
		конецесли;
	КонецЦикла;
	
	ИзменитьРеквизиты(НовыеРеквизиты);   
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл     
		ПартнерКод=""+Выборка.ТипЦены+"_"+СОКРЛП(стрзаменить(Выборка.ПартнерКод,"-",""));

		если Элементы.Найти("Контрагент_"+ПартнерКод)=НЕОПРЕДЕЛЕНО тогда	       
			
			НовыйЭлементГруппа = Элементы.Добавить("Контрагент_" +ПартнерКод, тип("ГруппаФормы"), Элементы["ГруппаКонкуренты"+Выборка.ТипЦены+"_"+СчетчикСтраниц]);
			НовыйЭлементГруппа.Заголовок=Выборка.Партнер;
			НовыйЭлементГруппа.Группировка=ГруппировкаКолонок.Горизонтальная;
			НовыйЭлементГруппа.ОтображатьВШапке=Истина;     
			НовыйЭлементГруппа.ГоризонтальноеПоложениеВШапке=ГоризонтальноеПоложениеЭлемента.Центр;   
			
			НовыйЭлемент = Элементы.Добавить("КонтрагентЦена_" + ПартнерКод, Тип("ПолеФормы"),НовыйЭлементГруппа);
			НовыйЭлемент.Заголовок="Цена";
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода; 
			НовыйЭлемент.Ширина=5;
			НовыйЭлемент.ПутьКДанным = "ТаблицаМониторинга.КонтрагентЦена_"+ ПартнерКод;   

			НовыйЭлемент = Элементы.Добавить("КонтрагентПроцент_" + ПартнерКод, Тип("ПолеФормы"),НовыйЭлементГруппа);
			НовыйЭлемент.Заголовок="%";
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода; 
			НовыйЭлемент.Ширина=4;
			НовыйЭлемент.ПутьКДанным = "ТаблицаМониторинга.КонтрагентПроцент_" + ПартнерКод;   
			
		конецесли;
	КонецЦикла;

	ЗначениеВРеквизитФормы(ТаблицаФормы, "ТаблицаМониторинга");
	
КонецПроцедуры

&НаСервере
Процедура УсловноеОформлениеОсновное()
	СтатусПользователя=ПолучитьПрава();
	Элементы.НаПроверку.Видимость=СтатусПользователя = 1;
	Элементы.Аннулировать.Видимость=СтатусПользователя = 1;
	Элементы.Проверено.Видимость=СтатусПользователя > 1;
	Элементы.НаДоработку.Видимость=СтатусПользователя > 1;
	Элементы.Отклонить.Видимость=СтатусПользователя > 1;
	Элементы.Согласовано.Видимость=СтатусПользователя = 3;
КонецПроцедуры

&НаСервере
Функция ПолучитьПрава()
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ первые 1
	|	ВЫБОР
	|		КОГДА Сотрудники.ПравоНаПроверку
	|			ТОГДА 2
	|		КОГДА Сотрудники.ПравоНаСогласование
	|			ТОГДА 3
	|		ИНАЧЕ 1
	|	КОНЕЦ КАК Статус
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Пользователь = &Пользователь";

	Запрос.УстановитьПараметр("Пользователь", Пользователи.ТекущийПользователь());

	РезультатЗапроса = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();

	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.статус;
	Иначе
		Возврат 1;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ТаблицаМониторингаСкорректировать_1ПриИзменении(Элемент)
	 ОформитьЗаголовокСтраницы(1);
КонецПроцедуры

&НаСервере
Функция ПолучитьРегионы()

	возврат Объект.ТаблицаОграничений.Выгрузить().ВыгрузитьКолонку("Регион");

КонецФункции // ПолучитьРегионы()


&НаКлиенте
Процедура ИзменитьСоставРегионовНажатие(Элемент)
	СтандартнаяОбработка=Ложь;
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("РегионыПрисутствия", ПолучитьРегионы());
	
	ОповещениеВыбораРегиона = Новый ОписаниеОповещения("ПослеВыбораРегиона",  ЭтотОбъект);
	ОткрытьФорму("Документ.Ценообразование.Форма.ФормаВыбораРегионов", СтруктураПараметров, ЭтотОбъект, , , ,
	ОповещениеВыбораРегиона, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры      

&НаКлиенте
