
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

	СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);

КонецПроцедуры

&НаСервере
Процедура УстановитьПериодыРасхода()
		
	ОписаниеЧисла = ОбщегоНазначения.ОписаниеТипаЧисло(15, 2);
	РеквизитыКДобавлению = Новый Массив;
	ЭлементыКДобавлению = Новый Массив;
	РеквизитыКУдалению = Новый Массив;
	Для к = 1 По КоличествоПериодов Цикл
		РеквизитыКУдалению.Добавить("Объект.Товары.МесяцРасхода" + Строка(к));
	КонецЦикла;	
	Для Каждого Стр Из Объект.Периоды Цикл
		РеквизитКолонкаТаблицы = Новый РеквизитФормы("МесяцРасхода"+стр.Номерстроки,
		ОписаниеЧисла,"Объект.Товары",стр.Период);
		РеквизитыКДобавлению.Добавить(РеквизитКолонкаТаблицы);
		ЭлементыКДобавлению.Добавить(РеквизитКолонкаТаблицы);
	КонецЦикла;		
	ИзменитьРеквизиты(РеквизитыКДобавлению, РеквизитыКУдалению);
	
	Для Каждого ЭлементКДобавлению Из ЭлементыКДобавлению Цикл
		ЭлементКолонка = Элементы.Найти("Товары" + ЭлементКДобавлению.Имя);
		Если ЭлементКолонка = НЕОПРЕДЕЛЕНО тогда
			НовыйЭлемент = Элементы.Вставить("Товары" + ЭлементКДобавлению.Имя, Тип("ПолеФормы"), Элементы.Товары, Элементы.ТоварыМесяцРасходаРастяжка);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеНадписи;
			НовыйЭлемент.ПутьКДанным = "Объект.Товары." + ЭлементКДобавлению.Имя;
			НовыйЭлемент.Заголовок = ЭлементКДобавлению.Заголовок;
			НовыйЭлемент.Ширина = 12;
			НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
			НовыйЭлемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Право;
		Иначе
			ЭлементКолонка.Заголовок = ЭлементКДобавлению.Заголовок;
		КонецЕсли;
	КонецЦикла;                                         
	
	КоличествоПериодов = Объект.Периоды.Количество();  
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПериодыРасхода()
	
	Для Каждого период Из Объект.Периоды Цикл
		Для Каждого стр Из Объект.Товары Цикл
			СтрокаРасход = Объект.ТоварыРасход.НайтиСтроки(Новый Структура("Номенклатура,ДатаНачала",стр.Номенклатура,период.ДатаНачала));
			Если строкаРасход <> Неопределено И строкаРасход.Количество() <> 0 тогда
				стр["МесяцРасхода" + Период.НомерСтроки] = строкарасход[0].Количество;
			КонецЕсли;	
		КонецЦикла;	
	КонецЦикла;	

КонецПроцедуры

&НаКлиенте
Процедура ПериодРасходаПриИзменении(Элемент)
	
	Объект.ДатаНачалаРасхода = ПериодРасхода.ДатаНачала;
	Объект.ДатаОкончанияРасхода = ПериодРасхода.ДатаОкончания; 
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодыРасхода(Команда)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("АдресВХранилище",ТаблицаПериодовВХранилище());
	Оповещение = Новый ОписаниеОповещения("ПериодыРасходаЗавершение", ЭтотОбъект, ДополнительныеПараметры);
    ОткрытьФорму("Документ.ЗаявкаНаОбеспечение.Форма.ФормаВыбораПериодов",ДополнительныеПараметры,ЭтаФорма,истина,,,Оповещение);

КонецПроцедуры 

&НаСервере
Функция ТаблицаПериодовВХранилище()
	Возврат ПоместитьВоВременноеХранилище(Объект.Периоды.Выгрузить());
КонецФункции 

&НаКлиенте
Процедура ПериодыРасходаЗавершение(ВыбранноеЗначение, ДополнительныеПараметры) Экспорт
	
	ПериодыРасходаЗавершениеСервер(ВыбранноеЗначение, ДополнительныеПараметры)

КонецПроцедуры

&НаСервере
Процедура ПериодыРасходаЗавершениеСервер(ВыбранноеЗначение, ДополнительныеПараметры)
	
	Если ВыбранноеЗначение <> Неопределено Тогда
		ТаблицаПериодов = ПолучитьИзВременногоХранилища(ВыбранноеЗначение);
		Объект.Периоды.Загрузить(ТаблицаПериодов);
		ЭтаФорма.Модифицированность = Истина;
		УстановитьПериодыРасхода();
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТоварыРасход()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВР_Периоды.НомерСтроки КАК НомерСтроки,
		|	ВР_Периоды.ДатаНачала КАК ДатаНачала
		|ПОМЕСТИТЬ ВР_Периоды
		|ИЗ
		|	&ВР_Периоды КАК ВР_Периоды
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Выручка.АналитикаУчетаНоменклатуры.Номенклатура КАК Номенклатура,
		|	СУММА(Выручка.КоличествоОборот) КАК Количество,
		|	Выручка.Период КАК ДатаНачала,
		|	ВР_Периоды.НомерСтроки КАК КлючСвязи
		|ИЗ
		|	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(, , Месяц, АналитикаУчетаНоменклатуры.Номенклатура В (&МассивНоменклатуры)) КАК Выручка
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВР_Периоды КАК ВР_Периоды
		|		ПО Выручка.Период = ВР_Периоды.ДатаНачала
		|ГДЕ
		|	&Условие
		|
		|СГРУППИРОВАТЬ ПО
		|	Выручка.АналитикаУчетаНоменклатуры.Номенклатура,
		|	Выручка.Период,
		|	ВР_Периоды.НомерСтроки";
	
	Запрос.УстановитьПараметр("ВР_Периоды", Объект.Периоды.Выгрузить());
	Запрос.УстановитьПараметр("МассивНоменклатуры", Объект.Товары.Выгрузить().ВыгрузитьКолонку("Номенклатура"));
	ТекстУсловия = ""; ТекстПоля = "";
	Для Каждого стр Из Объект.Периоды Цикл
		ТекстУсловия = ТекстУсловия + ?(ТекстУсловия = "", "", " или ") + "
		| Выручка.Период МЕЖДУ датавремя(" + Стрзаменить(ГОД(стр.ДатаНачала), Символы.НПП, "") + "," + месяц(стр.ДатаНачала) + "," + День(стр.ДатаНачала) + ") и датавремя(" + стрзаменить(ГОД(стр.ДатаОкончания), символы.Нпп,"") + "," + месяц(стр.ДатаОкончания) + "," + День(стр.ДатаОкончания) + ")";
	КонецЦикла;	
	
	Запрос.Текст = стрзаменить(Запрос.Текст,"&Условие",ТекстУсловия);
	РезультатЗапроса = Запрос.Выполнить();
	Объект.ТоварыРасход.Загрузить(РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура Заполнить(Команда)
	
	ЗаполнитьТаблицуТоваров();
	ЗаполнитьТоварыРасход();
	ЗаполнитьПериодыРасхода();

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуТоваров ()
	
	Если Не значениезаполнено(Объект.РабочийФайл) Тогда
		Возврат;
	КонецЕсли;
	МассивНоменклатуры = Новый Массив;
	МассивСкладов = Новый Массив;
	
	Настройки = Объект.РабочийФайл.ХранилищеНастроек.получить();
	Если Настройки <> НЕОПРЕДЕЛЕНО Тогда
		Если Настройки.Свойство("МассивНоменклатуры") Тогда
			МассивНоменклатуры = Настройки.МассивНоменклатуры;
		КонецЕсли;
		Если Настройки.Свойство("СкладыОстатков") Тогда
			МассивСкладов = Настройки.СкладыОстатков.ВыгрузитьКолонку("СкладПолучатель");;
		КонецЕсли;	
	КонецЕсли;	
	ТипОбеспечения = Объект.РабочийФайл.ТипОбеспечения;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();

	Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры);
	Запрос.УстановитьПараметр("МассивСкладов", МассивСкладов);
	Запрос.УстановитьПараметр("ТипОбеспечения", ТипОбеспечения);
		
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВариантыОбеспеченияТоварами.Номенклатура КАК Номенклатура,
		|	ВариантыОбеспеченияТоварами.Характеристика КАК Характеристика,
		|	ВариантыОбеспеченияТоварами.Склад КАК Склад,
		|	ВариантыОбеспеченияТоварами.СпособОбеспеченияПотребностей КАК СпособОбеспечения
		|ПОМЕСТИТЬ ВтТовары
		|ИЗ
		|	РегистрСведений.ВариантыОбеспеченияТоварами КАК ВариантыОбеспеченияТоварами
		|ГДЕ
		|	ВариантыОбеспеченияТоварами.Номенклатура В ИЕРАРХИИ(&МассивНоменклатуры)
		|	И ВариантыОбеспеченияТоварами.СпособОбеспеченияПотребностей.ТипОбеспечения = &ТипОбеспечения
		|	И ВариантыОбеспеченияТоварами.Склад В(&МассивСкладов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Способы.СпособОбеспечения КАК СпособОбеспечения,
		|	Способы.СпособОбеспечения.ФормироватьПлановыеЗаказы КАК ФормироватьПлановыеЗаказы,
		|	NULL КАК ДатаПоставки
		|ПОМЕСТИТЬ ВтСпособыОбеспеченияПереопределенный
		|ИЗ
		|	ВтТовары КАК Способы";
	Запрос.Выполнить();
		
	Запрос = Обработки.ОбеспечениеПотребностей.ЗапросПоЗапасам(Запрос);
	РезультатЗапроса = Запрос.Выполнить();
	
	Объект.Товары.Загрузить(РезультатЗапроса.Выгрузить());

КонецПроцедуры

&НаКлиенте
Процедура Сформировать(Команда)
	
	ПараметрыКоманды = Новый Структура("Ссылка,Идентификатор,этоОтчет");
	ПараметрыКоманды.Идентификатор = Объект.Ссылка;	
	ПараметрыКоманды.Ссылка = ДопОбработка();
	ПараметрыКоманды.ЭтоОтчет = Ложь;	
	ДополнительныеОтчетыИОбработкиКлиент.ВыполнитьОткрытиеФормыОбработки(ПараметрыКоманды,ЭтаФорма,Новый Массив());
	Закрыть(); 
	
КонецПроцедуры

&НаСервере
Функция ДопОбработка()	
	Возврат Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Расчет потребности");	
КонецФункции

