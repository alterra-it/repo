    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЗаявкаНаОбеспечение.Номер КАК Номер,
	ЗаявкаНаОбеспечение.Дата КАК Дата,
	ЗаявкаНаОбеспечение.Сумма КАК Сумма,
	ЗаявкаНаОбеспечение.РабочийФайл КАК РабочийФайл,
	ЗаявкаНаОбеспечение.КатегорийныйМенеджер КАК КатегорийныйМенеджер,
	ЗаявкаНаОбеспечение.Статус КАК Статус,
	ЗаявкаНаОбеспечение.ВидЗаявки КАК ВидЗаявки,
	ЗаявкаНаОбеспечение.Подразделение КАК Подразделение,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) КАК ЗаказыПоставщикам,
	ВЫБОР
		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) > 4
			ТОГДА &quot; документов&quot;
		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) > 1
			ТОГДА &quot; документа&quot;
		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказПоставщику.Ссылка) = 1
			ТОГДА &quot; документ&quot;
		ИНАЧЕ &quot;&quot;
	КОНЕЦ КАК СтрДокументов,
	ЗаявкаНаОбеспечение.Ссылка КАК Ссылка,
	ЗаявкаНаОбеспечение.Вес КАК Вес,
	ЗаявкаНаОбеспечение.Объем КАК Объем
ИЗ
	Документ.ЗаявкаНаОбеспечение КАК ЗаявкаНаОбеспечение
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
		ПО ЗаявкаНаОбеспечение.Ссылка = ЗаказПоставщику.ДокументОснование

СГРУППИРОВАТЬ ПО
	ЗаявкаНаОбеспечение.Номер,
	ЗаявкаНаОбеспечение.Дата,
	ЗаявкаНаОбеспечение.Сумма,
	ЗаявкаНаОбеспечение.РабочийФайл,
	ЗаявкаНаОбеспечение.КатегорийныйМенеджер,
	ЗаявкаНаОбеспечение.Статус,
	ЗаявкаНаОбеспечение.ВидЗаявки,
	ЗаявкаНаОбеспечение.Подразделение,
	ЗаявкаНаОбеспечение.Ссылка</queryText>
      <mainTable>Document.ЗаявкаНаОбеспечение</mainTable>
