&НаСервере
Процедура ПослеЗагрузкиИзФайлаСервер(Результат, ДополнительныеПараметры)
	
	Если Не Результат = Неопределено Тогда
		ТаблицаДанных=ПолучитьИзВременногоХранилища(Результат);
		
		Если ТаблицаДанных<>Неопределено Тогда
			Объект.Товары.Загрузить(ТаблицаДанных);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	НовыйМассив = Новый Массив();
	НовыйПараметр = Новый ПараметрВыбора("Отбор.Статус", ПредопределенноеЗначение("Перечисление.СтатусыДействияВидовЦен.Действует"));
	НовыйМассив.Добавить(НовыйПараметр);
	НовыйПараметр2 = Новый ПараметрВыбора("Отбор.ИспользоватьПриПродаже", Ложь);
	НовыйМассив.Добавить(НовыйПараметр2);
	НовыеПараметры = Новый ФиксированныйМассив(НовыйМассив);
	Элементы.ВидЦены.ПараметрыВыбора = НовыеПараметры;  
	
	Если ЗначениеЗаполнено(Объект.СтатьяДоходов) И Не ЗначениеЗаполнено(Объект.АналитикаДоходов) И Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ДоходыИРасходыКлиентСервер.СтатьяПриИзменении(ЭтотОбъект, Элементы.СтатьяДоходов);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("АвтоТест") Тогда // Возврат при получении формы для анализа.
		Возврат;
	КонецЕсли;  
	
	Если Параметры.Свойство("Организация") Тогда 
		Объект.Организация = Параметры.Организация;
	КонецЕсли;
	
	Если Параметры.Свойство("Склад") Тогда 
		Объект.Склад = Параметры.Склад;
	КонецЕсли;
	
	Если Параметры.Свойство("Комментарий") Тогда 
		Объект.Комментарий = Параметры.Комментарий;
	КонецЕсли;
	
	Если Параметры.Свойство("СтатьяДоходов") Тогда 
		Объект.СтатьяДоходов = Параметры.СтатьяДоходов;
	КонецЕсли;
	
	Если Параметры.Свойство("Товары") И ЭтоАдресВременногоХранилища(Параметры.Товары) Тогда 
		Объект.Товары.Загрузить(ПолучитьИзВременногоХранилища(Параметры.Товары));
		УдалитьИзВременногоХранилища(Параметры.Товары);
	КонецЕсли;      
	
	Если ЗначениеЗаполнено(Объект.Подразделение) И Не ЗначениеЗаполнено(Объект.ВидЦены) И Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Объект.ВидЦены = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Подразделение, "ЦенаЗакупа").ЦенаЗакупа;                                           
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
Процедура Док_ИсточникИнформацииОЦенахДляПечатиПриИзмененииПослеНаСервере()
	ИсточникИнформацииОЦенахДляПечати = Объект.ИсточникИнформацииОЦенахДляПечати;
	УстановитьВидимостьВидЦены(ИсточникИнформацииОЦенахДляПечати);
	УстановитьЗначениеВидЦены(ИсточникИнформацииОЦенахДляПечати);
	ЗаполнитьЦеныПоИсточникИнформацииОЦенахДляПечати(ИсточникИнформацииОЦенахДляПечати);
КонецПроцедуры


