	|			ЗНАЧЕНИЕ(Документ.ЗаявкаНаВозвратТоваровОтКлиента.ПустаяСсылка))
	|	)
	|
	|"; 
	
	ТекстЗапросаДокумента = УстановитьУсловияПоРаздельнойЗакупке(ТекстЗапросаДокумента);
	
	#Вставка
	ТекстЗапросаДокумента = СтрЗаменить(ТекстЗапросаДокумента,
