
&НаСервере
&ИзменениеИКонтроль("РезультатОтправкиНаСервере")
Функция Док_РезультатОтправкиНаСервере()
	
	Если Модифицированность Тогда
		Записать();
	КонецЕсли;
	
	Результат = Истина;
	
	Если ИнформационнаяБазаФайловая
		И (Объект.ДатаКогдаОтправить = Дата(1,1,1) ИЛИ Объект.ДатаКогдаОтправить < ТекущаяДатаСеанса())
		И (Объект.ДатаАктуальностиОтправки = Дата(1,1,1) ИЛИ Объект.ДатаАктуальностиОтправки > ТекущаяДатаСеанса()) Тогда
		
		КоличествоОтправленных = Взаимодействия.ОтправкаSMSПоДокументу(Объект);
		Результат = КоличествоОтправленных > 0;
	Иначе
			
		#Удаление
		Взаимодействия.УстановитьСостояниеИсходящееДокументСообщениеSMS(Объект);
		#КонецУдаления
		#Вставка   
		ОтправитьSMS();
		#КонецВставки
		
	КонецЕсли;
	
	Записать();
	УправлениеДоступностью(ЭтотОбъект);
	
	Возврат Результат;
	
КонецФункции   

&НаСервере
Процедура ОтправитьSMS()  
	УстановитьПривилегированныйРежим(Истина);
	
	НомераТелефонов = Новый Массив;   
	Для Каждого ТекущийАдресат Из Объект.Адресаты Цикл
		НомерТелефона = ТекущийАдресат.КакСвязаться;  
		АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(НомерТелефона);
		НомераТелефонов.Добавить("7"+НомерТелефона);
	КонецЦикла;	
	
	РезультатОтправки = ОтправкаSMS.ОтправитьSMS(НомераТелефонов,Объект.ТекстСообщения,,);
	
	Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки,,);
		Возврат;
		Если Не ПустаяСтрока(РезультатОтправки.ОписаниеОшибки) Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки,,);
		КонецЕсли;
		
	КонецЕсли;
	
	Если РезультатОтправки.ОтправленныеСообщения.Количество() > 0 Тогда
		СтатусДоставкиСообщения = ОтправкаSMS.СтатусДоставки(РезультатОтправки.ОтправленныеСообщения[0].ИдентификаторСообщения);
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(РезультатОтправки.ОписаниеОшибки,,);
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры	
