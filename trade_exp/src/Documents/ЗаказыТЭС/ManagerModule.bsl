#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
// Печать 
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	ТабДок= Новый ТабличныйДокумент;
	Макет = ПолучитьМакет("Макет");
	
	Для Каждого Ссылка Из МассивОбъектов Цикл
		ДатаОтгрузкиМесяц=Месяц(Ссылка.Дата);
		ДатаОтгрузкиГод=Год(Ссылка.Дата);
		
		ТекущаяОбласть = Макет.ПолучитьОбласть("Шапка");              
		ТекущаяОбласть.Параметры.ДатаОтгрузкиЧисло = День(Ссылка.Дата);
		ТекущаяОбласть.Параметры.ДатаОтгрузкиМесяц = Месяц(Ссылка.Дата);
		ТекущаяОбласть.Параметры.ДатаОтгрузкиГод=Год(Ссылка.Дата);
		ТабДок.Вывести(ТекущаяОбласть);
		
		ТекущаяОбласть = Макет.ПолучитьОбласть("Раздел1");
		ТекущаяОбласть.Параметры.ГородОтправления=Ссылка.ГородОтправления;
		ТекущаяОбласть.Параметры.КонтактноеЛицо=Ссылка.КонтактноеЛицоЗаказчика;
		ТекущаяОбласть.Параметры.ТелефоныЗаказчика=Ссылка.ТелефоныЗаказчика;
		ТабДок.Вывести(ТекущаяОбласть);
		
		ТекущаяОбласть = Макет.ПолучитьОбласть("Раздел23");
		ТекущаяОбласть.Параметры.ГородОтправителя=Ссылка.ГородОтправления;
		ТекущаяОбласть.Параметры.Грузоотправитель=Ссылка.Грузоотправитель;
		ТекущаяОбласть.Параметры.АдресОфисаОтправителя=Ссылка.АдресОфисаОтправления;
		ТекущаяОбласть.Параметры.КонтактноеЛицоОтправителя=Ссылка.КонтактноеЛицоОтправителя;
		ТекущаяОбласть.Параметры.ТелефоныОтправителя=Ссылка.ТелефоныОтправителя;
		ТекущаяОбласть.Параметры.Самоподвоз=Ссылка.Самоподвоз;
		ТекущаяОбласть.Параметры.Автодоставка=Ссылка.АвтодоставкаСоСклада;
		ТекущаяОбласть.Параметры.ПунктНазначения=Ссылка.ПунктНазначения;
		ТекущаяОбласть.Параметры.Грузополучатель=Ссылка.Грузополучатель;
		ТекущаяОбласть.Параметры.АдресОфисаНазначения=Ссылка.АдресОфисаНазначения;
		ТекущаяОбласть.Параметры.КонтактноеЛицоНазначения=Ссылка.КонтактноеЛицоНазначения;
		ТекущаяОбласть.Параметры.ТелефоныНазначения=Ссылка.ТелефоныНазначения;
		ТекущаяОбласть.Параметры.Самовывоз=Ссылка.Самовывоз;
		ТекущаяОбласть.Параметры.АдресДоставки=Ссылка.АдресДоставки;
		ТекущаяОбласть.Параметры.АдресОтправления=Ссылка.АдресОтправления;
		ТабДок.Вывести(ТекущаяОбласть);
		
		ТекущаяОбласть = Макет.ПолучитьОбласть("Раздел4");
		ТекущаяОбласть.Параметры.Заполнить(Ссылка);
		ТабДок.Вывести(ТекущаяОбласть);
		
		ТекущаяОбласть = Макет.ПолучитьОбласть("Раздел5");
		ТекущаяОбласть.Параметры.Заполнить(Ссылка);
		ТекущаяОбласть.Параметры.ФИОПользователя=Ссылка.Автор.Наименование;
		ТабДок.Вывести(ТекущаяОбласть);
		
		ТекущаяОбласть = Макет.ПолучитьОбласть("Подвал");
		ТабДок.Вывести(ТекущаяОбласть);
		
	КонецЦикла;
	УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"Макет", НСтр("ru = 'Лист согласования'"), ТабДок);
КонецПроцедуры

Процедура ЗаполнитьДанныеПоОснованию(Основание, Объект)   Экспорт
	Объект.Основание= Основание;
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		
		КонтактноеЛицо= АльтерраОбщегоНазначения.ПулучитьКонтактноеЛицоПартнера(Основание.Партнер, Справочники.РолиКонтактныхЛицПартнеров.НайтиПоНаименованию("Менеджер/снабженец", Истина));
		
		КонтактыКонтактногоЛицаОтпровителя= АльтерраОбщегоНазначения.ПулучитьКонтактыКонтактногоЛица(КонтактноеЛицо);
		СведеньяОПартнере= ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Основание.Контрагент, ТекущаяДата());
		СведеньяОбОрганизации= ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Основание.Организация, ТекущаяДата());
		
		//Общие
		Объект.КонтактноеЛицоЗаказчика= Основание.Автор;
		
		//Пункт отправления
		Объект.КонтактноеЛицоОтправителя= Основание.КонтактноеЛицо;
		Объект.ТелефоныОтправителя= КонтактыКонтактногоЛицаОтпровителя[Справочники.ВидыКонтактнойИнформации.ТелефонКонтактногоЛица];
		
		Объект.Грузоотправитель= Основание.Контрагент;
		Объект.АдресОфисаОтправления=	ФормированиеПечатныхФорм.ОписаниеОрганизации(СведеньяОПартнере,"ФактическийАдрес");
		Объект.АдресОтправления= Объект.АдресОфисаОтправления;
		
		//ПунктНазначения
		Объект.Заказчик= Основание.Организация;
		Объект.ПунктНазначения= АльтерраОбщегоНазначения.ПолучитьДополнительныйРеквизит(Основание.Склад, "Город");
		Объект.Грузополучатель= Объект.Заказчик;
		Объект.АдресОфисаНазначения= АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформацию(Основание.Склад, Справочники.ВидыКонтактнойИнформации.АдресСклада);
		Объект.АдресДоставки= Объект.АдресОфисаНазначения;
		Объект.КонтактноеЛицоНазначения= Объект.КонтактноеЛицоЗаказчика;
		Объект.ТелефоныНазначения= АльтерраОбщегоНазначения.ПолучитьКонтактнуюИнформацию(Основание.Автор, Справочники.ВидыКонтактнойИнформации.ТелефонПользователя);
		
		//Подвал
		Объект.Грузополучатель2= Истина;
		Объект.Вагон= Истина;
		
		Товары= Основание.Товары.Выгрузить();
		СтрукВесОбъем= АльтерраОбщегоНазначения.ПолучитьВесОбъемТоваров(Товары);
		Объект.Вес1= СтрукВесОбъем.Вес; 
		Объект.Объем1=  СтрукВесОбъем.Объем;

		// Автор при создании
		Если Не ЗначениеЗаполнено(Объект.Автор) тогда
			Объект.Автор=ПараметрыСеанса.ТекущийПользователь;
			Объект.ДатаЗаявки=ТекущаяДата();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецЕсли