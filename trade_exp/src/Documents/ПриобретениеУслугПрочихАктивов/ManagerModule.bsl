Функция ОпределениеРеализацииПоЗаказу(Заказ) 
	Запрос = Новый запрос; 
	ЗАпрос.Текст = "ВЫБРАТЬ
	               |	РеализацияТоваровУслуг.Ссылка КАК Ссылка
	               |ИЗ
	               |	Документ.ЗаказКлиента КАК ДокЗаказ
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	               |		ПО ДокЗаказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	               |ГДЕ
	               |	ДокЗаказ.Ссылка = &Заказ";
	Запрос.УстановитьПараметр("Заказ", Заказ); 
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка; 
	Иначе
		Возврат Неопределено; 
	КонецЕслИ; 
КонецФункции

Функция ПолучитьДокументыПродажи(мРейсов, Организация = Неопределено) Экспорт
	
	Организация1СК = Справочники.Организации.НайтиПоНаименованию("1СК ООО", Истина);
	
	АвтоуслугиПоДоставкеТовараНаФилиалы = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("0А-000257");
	ДоставкаТовараПокупателямЧерез1СК   = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("0А-000667");
	ДоставкаТовараПокупателям           = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("0А-000256");
	
	Запрос = Новый Запрос;	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК ДокПродажи,
		|	ВЫБОР
		|		КОГДА ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи ССЫЛКА Документ.ОбращениеКлиента
		|			ТОГДА ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи
		|		ИНАЧЕ ЗНАЧЕНИЕ(Документ.ОбращениеКлиента.ПустаяСсылка)
		|	КОНЕЦ КАК ОбращениеКлиента,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ОплатаВодителю КАК ОплатаВодителю,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка КАК Рейс,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.Подразделение КАК Подразделение,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.ПеревозчикПартнер КАК ПеревозчикПартнер,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.Перевозчик КАК Перевозчик,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.СтавкаНДСПеревозчика КАК СтавкаНДС,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку.Партнер КАК АналитикаРасходовПеремещения,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку.АдресДоставки КАК АдресДоставки,
		|	ВЫБОР
		|		КОГДА ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку.СтоимостьДоставки > 0
		|			ТОГДА &Организация1СК
		|		ИНАЧЕ ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку.Организация
		|	КОНЕЦ КАК Организация
		|ПОМЕСТИТЬ ВТИтог
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.Проведен
		|	И ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка В(&мРейсов)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Итог.ДокПродажи КАК ДокПродажи, 
		|	МАКСИМУМ(Итог.ОбращениеКлиента) КАК ОбращениеКлиента,
		|	Итог.Рейс КАК Рейс,
		|	Итог.Подразделение КАК Подразделение,
		|	Итог.ПеревозчикПартнер КАК ПеревозчикПартнер,
		|	Итог.Перевозчик КАК Перевозчик,
		|	Итог.СтавкаНДС КАК СтавкаНДС,
		|	Итог.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|	СУММА(Итог.ОплатаВодителю) КАК ОплатаВодителю,
		|	Итог.АналитикаРасходовПеремещения КАК АналитикаРасходовПеремещения,
		|	Итог.АдресДоставки КАК АдресДоставки,
		|	Итог.Организация КАК Организация
		|ИЗ
		|	ВТИтог КАК Итог
		|ГДЕ
		|	Итог.Организация = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	Итог.ДокПродажи,
		|	Итог.Рейс,
		|	Итог.Подразделение,
		|	Итог.ПеревозчикПартнер,
		|	Итог.Перевозчик,
		|	Итог.СтавкаНДС,
		|	Итог.ЗаказНаДоставку,
		|	Итог.АналитикаРасходовПеремещения,
		|	Итог.АдресДоставки,
		|	Итог.Организация
		|ИТОГИ              
		|	МАКСИМУМ(ОбращениеКлиента),
		|	СУММА(ОплатаВодителю)
		|ПО
		|	Организация,
		|	ПеревозчикПартнер,
		|	Рейс,
		|	ЗаказНаДоставку";
	                               
	Если ЗначениеЗаполнено(Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Организация);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Итог.Организация = &Организация", "Истина");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("мРейсов", мРейсов);
	Запрос.УстановитьПараметр("Организация1СК", Организация1СК);
	
	МассивИтоговыхЗаписей = Новый Массив;
	
	ИтоговыеЗаписиОрганизация = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ИтоговыеЗаписиОрганизация.Следующий() Цикл	
		ЭтоОрганизация1СК = ИтоговыеЗаписиОрганизация.Организация = Организация1СК;

		ИтоговыеЗаписиПеревозчикПартнер = ИтоговыеЗаписиОрганизация.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);	
		Пока ИтоговыеЗаписиПеревозчикПартнер.Следующий() Цикл		
			
			ИтоговыеЗаписиРейсы = ИтоговыеЗаписиПеревозчикПартнер.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			
			Таб = Новый ТаблицаЗначений;  
			Таб.Колонки.Добавить("Организация");
		    Таб.Колонки.Добавить("Подразделение");
		    Таб.Колонки.Добавить("ПеревозчикПартнер");
			Таб.Колонки.Добавить("Перевозчик");
			Таб.Колонки.Добавить("ЗаказНаДоставку");
		    Таб.Колонки.Добавить("СтавкаНДС");
			Таб.Колонки.Добавить("СуммаНДС");
		    Таб.Колонки.Добавить("ОснованиеЗатрат");
			Таб.Колонки.Добавить("Рейсы");
			Таб.Колонки.Добавить("Содержание");
			Таб.Колонки.Добавить("Количество");	
			Таб.Колонки.Добавить("Цена");
			Таб.Колонки.Добавить("Сумма");
			Таб.Колонки.Добавить("СуммаСНДС");		
			Таб.Колонки.Добавить("СтатьяРасходов");
			Таб.Колонки.Добавить("СтатьяРасходовБУ");
			Таб.Колонки.Добавить("АналитикаРасходов");
			Таб.Колонки.Добавить("СкладОснованияЗатрат");
							
			Пока ИтоговыеЗаписиРейсы.Следующий() Цикл
				
				ИтоговыеЗаписиЗаказНаДоставку = ИтоговыеЗаписиРейсы.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);			
				Пока ИтоговыеЗаписиЗаказНаДоставку.Следующий() Цикл
					
					ДетальныеЗаписи = ИтоговыеЗаписиЗаказНаДоставку.Выбрать();
					КоличествоДетальныхЗаписей = ДетальныеЗаписи.Количество();
					
					Стр = Неопределено;
					Рейс = ИтоговыеЗаписиЗаказНаДоставку.Рейс;                                  
					                      
					СтруктураРезультат = Документы.ЗаданиеНаПеревозкуРейс.РасчетОплатыВодителю(Рейс, ИтоговыеЗаписиЗаказНаДоставку.ЗаказНаДоставку);
					Если СтруктураРезультат = Неопределено Тогда
						ОбщегоНазначения.СообщитьПользователю(
							"По Рейсу: '" + Рейс + 
							"', по заказу '" + ИтоговыеЗаписиЗаказНаДоставку.ЗаказНаДоставку + 
							"' происходит ошибка при расчете оплаты водителю!", Рейс);	
					Иначе
						ОплатаВодителю = Окр(СтруктураРезультат.ОплатаВодителю / КоличествоДетальныхЗаписей, 2);   
						ОплатаВодителюДельта = СтруктураРезультат.ОплатаВодителю - (ОплатаВодителю * КоличествоДетальныхЗаписей);
						
						СуммаДляКритериев = Цел(ОплатаВодителю);
						ОстатокОтДелНа10 = СуммаДляКритериев%10; 
						
						Если ОстатокОтДелНа10 >= 3 И ОстатокОтДелНа10 < 8 тогда
							НоваяОплата = Цел(СуммаДляКритериев/10)*10+5;
						ИначеЕсли ОстатокОтДелНа10 <3 Тогда
							НоваяОплата = Цел(СуммаДляКритериев/10)*10;
						ИначеЕсли ОстатокОтДелНа10 >= 8 Тогда
							НоваяОплата = Цел(СуммаДляКритериев/10)*10+10;
						КонецЕсли;
						
						
						СуммаНДС = Окр(СтруктураРезультат.СуммаНДС / КоличествоДетальныхЗаписей, 2);
						СуммаНДСДельта = СтруктураРезультат.СуммаНДС - (СуммаНДС * КоличествоДетальныхЗаписей);
						
						Пока ДетальныеЗаписи.Следующий() Цикл
							Стр = Таб.Добавить();       
							Стр.Организация = ДетальныеЗаписи.Организация;
						    Стр.Подразделение = ДетальныеЗаписи.Подразделение;
						    Стр.ПеревозчикПартнер = ДетальныеЗаписи.ПеревозчикПартнер;
							Стр.Перевозчик = ДетальныеЗаписи.Перевозчик;
							Стр.ЗаказНаДоставку = ДетальныеЗаписи.ЗаказНаДоставку;
							ПеремСтавкаНДС = ДетальныеЗаписи.СтавкаНДС;
							Если ТипЗнч(ПеремСтавкаНДС) = Тип("ПеречислениеСсылка.СтавкиНДС") Тогда 
								Стр.СтавкаНДС = Справочники.СтавкиНДС.НайтиПоРеквизиту("ПеречислениеСтавкаНДС", ПеремСтавкаНДС); 
							Иначе
								Стр.СтавкаНДС = ПеремСтавкаНДС; 
							КонецЕсли; 
							Стр.СуммаНДС = СуммаНДС;
							Стр.Цена = НоваяОплата;//ОплатаВодителю;
							Стр.Сумма = НоваяОплата;//ОплатаВодителю;
							Стр.СуммаСНДС = НоваяОплата;//ОплатаВодителю;  
							Если ТипЗнч(ДетальныеЗаписи.ДокПродажи) = Тип("ДокументСсылка.ЗаказКлиента") Тогда 
								Стр.ОснованиеЗатрат = ОпределениеРеализацииПоЗаказу(ДетальныеЗаписи.ДокПродажи)	
							Иначе
								Стр.ОснованиеЗатрат = ДетальныеЗаписи.ДокПродажи;
							КонецЕсли; 
							Стр.Рейсы = Рейс;
							Стр.Содержание = "Доставка груза " + ДетальныеЗаписи.АдресДоставки;
							Стр.Количество = 1;
							
							Если ТипЗнч(ДетальныеЗаписи.ДокПродажи) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
								Если ЗначениеЗаполнено(ИтоговыеЗаписиЗаказНаДоставку.ОбращениеКлиента) Тогда
									Стр.АналитикаРасходов = ДетальныеЗаписи.Подразделение;
								Иначе
									Стр.АналитикаРасходов = ДетальныеЗаписи.АналитикаРасходовПеремещения;
								КонецЕсли;
								
								Стр.СтатьяРасходов = АвтоуслугиПоДоставкеТовараНаФилиалы;
								Стр.СтатьяРасходовБУ = АвтоуслугиПоДоставкеТовараНаФилиалы;
								Стр.СкладОснованияЗатрат = ДетальныеЗаписи.ДокПродажи.СкладПолучатель;
							ИначеЕсли ТипЗнч(ДетальныеЗаписи.ДокПродажи) = Тип("ДокументСсылка.ОбращениеКлиента") И 
								ТипЗнч(ДетальныеЗаписи.ДокПродажи.ИсточникЗаполненияТоваровДляДовоза) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
								
								Стр.СтатьяРасходов = АвтоуслугиПоДоставкеТовараНаФилиалы;
								Стр.СтатьяРасходовБУ = АвтоуслугиПоДоставкеТовараНаФилиалы;
								Стр.АналитикаРасходов = ДетальныеЗаписи.АналитикаРасходовПеремещения;
								Стр.СкладОснованияЗатрат = ДетальныеЗаписи.ДокПродажи.ИсточникЗаполненияТоваровДляДовоза.СкладПолучатель;
							Иначе
								Если ЭтоОрганизация1СК Тогда  
									Стр.СтатьяРасходов = ДоставкаТовараПокупателямЧерез1СК;
									Стр.СтатьяРасходовБУ = ДоставкаТовараПокупателямЧерез1СК;
								Иначе
									Стр.СтатьяРасходов = ДоставкаТовараПокупателям;
									Стр.СтатьяРасходовБУ = ДоставкаТовараПокупателям;
								КонецЕсли;
								
								Стр.АналитикаРасходов = ДетальныеЗаписи.Подразделение;
								Если ТипЗнч(ДетальныеЗаписи.ДокПродажи) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
									Стр.СкладОснованияЗатрат = Документы.ОбращениеКлиента.ПолучитьСклад(ДетальныеЗаписи.ДокПродажи);
								Иначе
									Стр.СкладОснованияЗатрат = ДетальныеЗаписи.ДокПродажи.Склад;
								КонецЕсли;
							КонецЕсли;
						КонецЦикла;
						
						Если ЗначениеЗаполнено(Стр) Тогда
							Стр.Цена = Стр.Цена; // + ОплатаВодителюДельта;
							Стр.Сумма = Стр.Сумма; // + ОплатаВодителюДельта;
							Стр.СуммаСНДС = Стр.СуммаСНДС; // + ОплатаВодителюДельта;
							Стр.СуммаНДС = Стр.СуммаНДС + СуммаНДСДельта;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			
			Если ЗначениеЗаполнено(Таб) Тогда
				МассивИтоговыхЗаписей.Добавить(ПоместитьВоВременноеХранилище(Таб, Новый УникальныйИдентификатор));
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат МассивИтоговыхЗаписей;
КонецФункции

&После("ЗарегистрироватьУчетныеМеханизмы")
Процедура Док_ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента)
	МеханизмыДокумента.Добавить("РасходыПоОбъектам");
КонецПроцедуры

&ИзменениеИКонтроль("ДанныеДокументаДляПроведения")
Функция Док_ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ПриобретениеУслугПрочихАктивов") Тогда
		ДокументСсылка = Документ.Ссылка;
		ДокументОбъект = Документ;
	Иначе
		ДокументСсылка = Документ;
		ДокументОбъект = Документ.ПолучитьОбъект();
	КонецЕсли;
	
	Запрос			= Новый Запрос;
	ТекстыЗапроса	= Новый СписокЗначений;
	
	Если ДопПараметры <> Неопределено
		И ДопПараметры.Свойство("МенеджерВременныхТаблиц")
		И ДопПараметры.МенеджерВременныхТаблиц <> Неопределено Тогда
		Запрос.МенеджерВременныхТаблиц = ДопПараметры.МенеджерВременныхТаблиц;
	Иначе
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	КонецЕсли;
	
	ПолучитьДанныеДокумента(Запрос, ДокументСсылка);
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		СформироватьСуммыДокументаВВалютахУчета(Запрос, ТекстыЗапроса, Регистры);
		
		ТекстЗапросаТаблицаПрочиеРасходы(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаПартииПрочихРасходов(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаПрочиеДоходы(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаДвиженияКонтрагентДоходыРасходы(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаДенежныеСредстваУПодотчетныхЛиц(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаДвиженияДенежныеСредстваКонтрагент(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаДвиженияПоПрочимАктивамПассивам(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаПрочиеАктивыПассивы(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаРеестрДокументов(ТекстыЗапроса, Регистры, ДокументОбъект);
		#Вставка 
		ТекстЗапросаТаблицаРасходыПоОбъекты(Запрос, ТекстыЗапроса, Регистры);
		#КонецВставки
		
		ОтразитьВУчетеНДС(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		
		ПриобретениеУслугПрочихАктивовЛокализация.ДополнитьТекстыЗапросовПроведения(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	КонецЕсли;
	
	ДобавитьТекстыОтраженияВзаиморасчетов(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	

КонецФункции   

Функция ТекстЗапросаТаблицаРасходыПоОбъекты(Запрос, ТекстыЗапроса, Регистры)
	
	ИмяРегистра = "РасходыПоОбъектам";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли; 
	
	Если НЕ ПроведениеДокументов.ЕстьТаблицаЗапроса("втРасходы", ТекстыЗапроса) Тогда
		Документы.ПриобретениеУслугПрочихАктивов.ТекстЗапросаТаблицаВтРасходы(Запрос, ТекстыЗапроса);
	КонецЕсли; 
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	&Период КАК Период,
	               |	&Организация КАК Организация,
	               |	&Подразделение КАК Подразделение,
	               |	ТаблицаТовары.АналитикаРасходов КАК АналитикаРасходов,
	               |	ТаблицаТовары.СтатьяРасходов КАК СтатьяРасходов,
	               |	ТаблицаТовары.ОбъектРасходов КАК ОбъектРасходов,
	               |	ТаблицаТовары.АналитикаОбъекта КАК АналитикаОбъекта,
	               |	МИНИМУМ(ТаблицаТовары.НомерСтроки) КАК НомерСтроки,
	               |	СУММА(ТаблицаТовары.СуммаСНДС) КАК Сумма
	               |ИЗ
	               |	Документ.ПриобретениеУслугПрочихАктивов.Расходы КАК ТаблицаТовары
	               |ГДЕ
	               |	ТаблицаТовары.Ссылка = &Ссылка
	               |	И НЕ ТаблицаТовары.ОбъектРасходов = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	               |	И НЕ ТаблицаТовары.АналитикаОбъекта = ЗНАЧЕНИЕ(Справочник.АналитикаОбъекта.ПустаяСсылка)
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТаблицаТовары.АналитикаРасходов,
	               |	ТаблицаТовары.СтатьяРасходов,
	               |	ТаблицаТовары.ОбъектРасходов,
	               |	ТаблицаТовары.АналитикаОбъекта";
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	
	Возврат ТекстЗапроса;

	
КонецФункции

#КонецЕсли

