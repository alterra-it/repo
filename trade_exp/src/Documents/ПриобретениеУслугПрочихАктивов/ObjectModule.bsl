
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	если РольДоступна("_ЗапретПроведенияПриобретениеУслугПрочихАктивов") тогда
		Отказ=истина;
		Сообщить("У вас нет прав на проведение документа!");
	конецесли;	
	
	Если ЭтоЗатратыПоДоставке Тогда
		Для Каждого Расход Из Расходы Цикл
			Если ТипЗнч(Расход.ОснованиеЗатрат) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
				Движение = Движения.ЗатратыПоДоставкеОтПоставщика.Добавить();
				Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
				Движение.Период = Дата;
				Движение.Перевозчик = Контрагент;
				Движение.Документ = Расход.ОснованиеЗатрат;
				Движение.Сумма = Расход.СуммаСНДС;
			КонецЕсли;
		КонецЦикла;
		Движения.ЗатратыПоДоставкеОтПоставщика.Записывать= Истина; 
	
	КонецЕсли;

КонецПроцедуры

&После("ОбработкаУдаленияПроведения")
Процедура Док_ОбработкаУдаленияПроведения(Отказ)
		если РольДоступна("_ЗапретПроведенияПриобретениеУслугПрочихАктивов") тогда
		Отказ=истина;
		Сообщить("У вас нет прав на отмену проведение документа!");
	конецесли;	

КонецПроцедуры

&После("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Для каждого СтрокаТЧ из Расходы Цикл  
		
		Если НЕ СтрокаТЧ.ОбъектРасходов.Пустая() и СтрокаТЧ.АналитикаОбъекта.Пустая() Тогда
			ИндексМассива = СтрокаТЧ.НомерСтроки-1;
			ОбщегоНазначения.СообщитьПользователю("Нельзя по строке реквизит ""Объект расходов"" заполнить, а ""Аналитика объекта"" нет. Исправьте или очистите значения этих реквизитов в строке",, 
				"Объект.Расходы[" + ИндексМассива + "].АналитикаОбъекта");
			Отказ = Истина;
		ИначеЕсли СтрокаТЧ.ОбъектРасходов.Пустая() и НЕ СтрокаТЧ.АналитикаОбъекта.Пустая() Тогда
			ИндексМассива = СтрокаТЧ.НомерСтроки-1;
			ОбщегоНазначения.СообщитьПользователю("Нельзя по строке реквизит ""Аналитика объекта"" заполнить, а ""Объект расходов"" нет. Исправьте или очистите значения этих реквизитов в строке",, 
				"Объект.Расходы[" + ИндексМассива + "].ОбъектРасходов");
			Отказ = Истина;
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры
	
&После("ПередЗаписью")
Процедура Док_ПередЗаписью1(Отказ, РежимЗаписи, РежимПроведения)
	Если Не Отказ И Не ОбменДанными.Загрузка И Не ЭтоНовый() Тогда 
		Если ПометкаУдаления Тогда
			Если Не Ссылка.ПометкаУдаления Тогда
				ДополнительныеСвойства.Вставить("ИзменениеПриходныхДокументовВЗакрытомПериоде_ПометкаУдаления", "Удален документ " + Ссылка);
			КонецЕсли;	
		Иначе
			РеквизитыДляПроверки = Новый Массив; 
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Номер", "Номер"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Дата", "Дата"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Партнер", "Поставщик"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Контрагент", "Контрагент"));
			
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Соглашение", "Соглашение"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Организация", "Организация"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Договор", "Договор"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "Комментарий", "Комментарий"));
			
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "НомерВходящегоДокумента", "Номер входящего документа"));
			РеквизитыДляПроверки.Добавить(Новый Структура("Реквизит, ИмяРеквизита", "ДатаВходящегоДокумента", "Дата входящего документа"));
			
			ТЧДляПроверки = Новый Массив;
			ТЧДляПроверки.Добавить(Новый Структура("ТЧ, ИмяТЧ", "Расходы", "Таблица 'Расходы'"));
			
			Документы.КорректировкаПриобретения.ОбъектМодифицирован(Ссылка, ЭтотОбъект, РеквизитыДляПроверки, ТЧДляПроверки, ДополнительныеСвойства);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	Если Не Отказ И ДополнительныеСвойства.Свойство("ИзменениеПриходныхДокументовВЗакрытомПериоде_ПометкаУдаления") Тогда
		Документы.КорректировкаПриобретения.ОтправитьИнформациюВЧат_ИзменениеПриходныхДокументовВЗакрытомПериоде(
			Организация, 
			Дата, 
			ДополнительныеСвойства.ИзменениеПриходныхДокументовВЗакрытомПериоде_ПометкаУдаления);	
	КонецЕсли;
КонецПроцедуры

