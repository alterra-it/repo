

#Область ОбработчикиСобытийФормы
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(
		Неопределено,
		ЭтотОбъект,
		"СканерШтрихкода,ФискальныйРегистратор");
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
		// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			СтруктураДанных= МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
			Штрихкод= СокрЛП(СтруктураДанных.Штрихкод);
			ОбработатьШтрихкоды(Штрихкод);
	КонецЕсли;
	КонецЕсли;
	// Конец ПодключаемоеОборудование
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиКомандФормы


&НаКлиенте
Процедура ПоискПоШтрихкодуВыполнить(Команда)
	
	ОчиститьСообщения();
	Оповещение = Новый ОписаниеОповещения("ПоискПоШтрихкодуЗавершение", ЭтотОбъект);
	ШтрихкодированиеНоменклатурыКлиент.ПоказатьВводШтрихкода(Оповещение);
	
КонецПроцедуры



&НаКлиенте
Процедура ЗаполнитьПоОтбору(Команда)
	ЗаполнитьПоОтборуНаСервере();
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПоискПоШтрихкодуЗавершение(ДанныеШтрихкода, ДополнительныеПараметры) Экспорт
	
	ОбработатьШтрихкоды(ДанныеШтрихкода);
	
КонецПроцедуры


&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов)
	
	Если Не ШтрихкодированиеНоменклатурыКлиент.ШтрихкодыВалидны(ДанныеШтрихкодов) Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();

	ОбработатьШтрихкодыСервер(ДанныеШтрихкодов);
	
	//ШтрихкодированиеНоменклатурыКлиент.ОбработатьНеизвестныеШтрихкоды(СтруктураДействий,КэшированныеЗначения,ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьШтрихкодыСервер(ДанныеШтрихкодов)
	
	НайденнаяСтрока=Объект.Товары.НайтиСтроки(Новый Структура("КодМаркировки",ДанныеШтрихкодов.Штрихкод));
	если НайденнаяСтрока<>НЕОПРЕДЕЛЕНО тогда
		НайденнаяСтрока[0].ВНаличии=1;
	иначе
		//ОбщегоНазначения.СообщитьПользователю();
	конецесли;
	
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоОтборуНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Размещение.Ячейка КАК Ячейка,
		|	Движение.Штрихкод.Номенклатура КАК Номенклатура,
		|	1 КАК ПоУчету,
		|	-1 как Отклонение,
		|	Движение.Штрихкод.ЗначениеШтрихкода КАК КодМаркировки
		|ИЗ
		|	РегистрНакопления.ДвижениеМаркированногоТовара.Остатки(
		|			&Период,
		|			Организация = &Организация
		|				И Склад = &Склад) КАК Движение
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК Размещение
		|		ПО (Размещение.Номенклатура = Движение.Штрихкод.Номенклатура)
		|			И Движение.Склад = Размещение.Склад
		|			И (Размещение.ОсновнаяЯчейка)
		|
		|СГРУППИРОВАТЬ ПО
		|	Размещение.Ячейка,
		|	Движение.Штрихкод.Номенклатура,
		|	Движение.Штрихкод.ЗначениеШтрихкода";
	
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Период", Объект.Дата);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Объект.Товары.Загрузить(РезультатЗапроса.Выгрузить());
	
КонецПроцедуры
#КонецОбласти
