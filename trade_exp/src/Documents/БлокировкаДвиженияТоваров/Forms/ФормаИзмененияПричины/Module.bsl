&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
		
	Если Параметры.Свойство("ДокументБлокировки") Тогда
		
		 ДокументБлокировки = Параметры.ДокументБлокировки;
		 ТекущаяПричинаБлокировки = ДокументБлокировки.ПричинаБлокировки;
		 
		 ТЗ = Новый ТаблицаЗначений;
		 ТЗ = ДокументБлокировки.Товары.Выгрузить();
		 
		 ТЗ.Колонки.Добавить("ТекущаяПричина");
		 ТЗ.ЗаполнитьЗначения(ТекущаяПричинаБлокировки,"ТекущаяПричина");
		 
		 Товары.Загрузить(ТЗ);
		 
	 Иначе
		 
		 Отказ = Истина;
		 
	 КонецЕсли;
	 
	Если РольДоступна("МенеджерТорговогоЗала") Тогда
		ПараметрыВыбораМенеджера = Новый Массив;
		ПараметрыВыбораМенеджера.Добавить(Новый ПараметрВыбора("Отбор.ДоступностьДляМенеджераТорговогоЗала", Истина));
		Элементы.ПричинаБлокировки.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбораМенеджера);	
	КонецЕсли;	 
	 
КонецПроцедуры

&НаСервере
Процедура ИзменитьПричинуНаСервере()
	       
	ДатаДокумента = ТекущаяДата();
	
	ТЗ = Новый ТаблицаЗначений;	
	Структура = Новый Структура ("Выбрать",Истина);                       
    ТЗ = Товары.Выгрузить(Структура,"Номенклатура,Характеристика,Упаковка,Количество,КоличествоУпаковок");
	
	Если ТЗ.Количество() > 0 Тогда
		
		ДокументОбъект = ДокументБлокировки.ПолучитьОбъект();
		Запрос = ДокументОбъект.ПолучитьКоличествоДляРазблокировки(ДокументБлокировки.Ссылка);
		МассивРезультатов   = Запрос.ВыполнитьПакет();
		ТоварыДляРазблокировки = МассивРезультатов[МассивРезультатов.Количество() - 1].Выгрузить();
		
		Для Каждого Строка Из ТЗ Цикл
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Номенклатура", Строка.Номенклатура);
			СтруктураПоиска.Вставить("Характеристика", Строка.Характеристика);
			СтруктураПоиска.Вставить("Упаковка", Строка.Упаковка);
			НайденныйТоварДляРазблокировки = ТоварыДляРазблокировки.НайтиСтроки(СтруктураПоиска);
			
			Если НайденныйТоварДляРазблокировки.Количество() > 0 Тогда
				
				Если Строка.КоличествоУпаковок < НайденныйТоварДляРазблокировки[0].ИтогоКоличество Тогда
					 НайденныйТоварДляРазблокировки[0].ИтогоКоличество = НайденныйТоварДляРазблокировки[0].ИтогоКоличество - Строка.КоличествоУпаковок;
				 ИначеЕсли Строка.КоличествоУпаковок > НайденныйТоварДляРазблокировки[0].ИтогоКоличество Тогда
					 Строка.КоличествоУпаковок = НайденныйТоварДляРазблокировки[0].ИтогоКоличество;
				КонецЕсли;
				 
			Иначе
    			Сообщить("Разблокировать товар: " + Строка.Номенклатура + " в количестве " + Строка.КоличествоУпаковок + " невозможно. Уже разблокирован.");
				Возврат;
			КонецЕсли
			
		КонецЦикла;		
		
		
	
		НачатьТранзакцию();

		Попытка
			//Разблокировка
			ДокументРазблокировки = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
			ДокументРазблокировки.Дата = ДатаДокумента;
			ДокументРазблокировки.Склад = ДокументБлокировки.Склад;
			ДокументРазблокировки.ДокументОснование =  ДокументБлокировки.ДокументОснование;
			ДокументРазблокировки.Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Разблокировано;
			ДокументРазблокировки.БлокировкаОснование = ДокументБлокировки;
			ДокументРазблокировки.ПричинаБлокировки = ТекущаяПричинаБлокировки;
			ДокументРазблокировки.Ответственный = Пользователи.ТекущийПользователь();
			ДокументРазблокировки.Товары.Загрузить(ТЗ);
			ДокументРазблокировки.Записать(РежимЗаписиДокумента.Проведение);
			АльтерраОбщегоНазначения.СообщитьПользователю(ДокументРазблокировки.Ссылка, "Создан документ: "+ДокументРазблокировки.Ссылка);
			
			//Блокировка
			ДокументБлокировкиДвижения = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
			ДокументБлокировкиДвижения.Дата = ДатаДокумента+1;
			ДокументБлокировкиДвижения.Склад = ДокументБлокировки.Склад;
			ДокументБлокировкиДвижения.ДокументОснование =  ДокументБлокировки.ДокументОснование;
			ДокументБлокировкиДвижения.Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано;
			ДокументБлокировкиДвижения.БлокировкаОснование = ДокументБлокировки;
			ДокументБлокировкиДвижения.ПричинаБлокировки = ПричинаБлокировки;
			ДокументБлокировкиДвижения.Ответственный = Пользователи.ТекущийПользователь();
			ДокументБлокировкиДвижения.Товары.Загрузить(ТЗ);
			ДокументБлокировкиДвижения.Записать(РежимЗаписиДокумента.Проведение);
			АльтерраОбщегоНазначения.СообщитьПользователю(ДокументБлокировкиДвижения.Ссылка, "Создан документ: "+ДокументБлокировкиДвижения.Ссылка);
			
			ЗафиксироватьТранзакцию();
		
		Исключение
			
			ОтменитьТранзакцию();
			
			Сообщить("Не удалось создать документы блокировки!");
			Сообщить(ИнформацияОбОшибке().Описание);

		КонецПопытки;

	Иначе
		Сообщить("Не выбраны товары для разблокировки");	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьПричину(Команда)

	если ЗначениеЗаполнено(ПричинаБлокировки)=Ложь тогда
		сообщить("Необходимо выбрать причину блокировки");
		возврат;
	конецесли;
	ИзменитьПричинуНаСервере();
КонецПроцедуры


