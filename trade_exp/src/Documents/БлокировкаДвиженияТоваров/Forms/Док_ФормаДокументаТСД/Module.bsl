		Попытка
			глВКRSDriver.Отключить("Barcode");	
		Исключение
		КонецПопытки;	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура СчитатьШтрикодКамера(Команда) 
	
	#Если МобильныйКлиент Тогда
		Если СредстваМультимедиа.ПоддерживаетсяСканированиеШтрихКодов() Тогда
			ОповещениеСканирования = Новый ОписаниеОповещения("ОбработкаОтсканированногоШтрихкода",ЭтотОбъект);
			СредстваМультимедиа.ПоказатьСканированиеШтрихКодов("Scan code",ОповещениеСканирования,,ТипШтрихкода.Все);
		Иначе
			Сообщить("Сканирование не поддерживается!");
		КонецЕсли;
	#КонецЕсли

КонецПроцедуры 

&НаКлиенте
Процедура ОбработкаОтсканированногоШтрихкода(Штрихкод, Результат, Сообщение, ДопПараметры) Экспорт
	
	Если Результат И ЗначениеЗаполнено(Штрихкод) Тогда	
		#Если МобильныйКлиент Тогда
			СредстваМультимедиа.ЗакрытьСканированиеШтрихКодов();
		#КонецЕсли
		
		ДанныеСтруктура =  Новый Структура("Штрихкод, Количество", Штрихкод, 1);
		
		Данные = Новый Массив;
		Данные.Добавить(ДанныеСтруктура);		
		
		ОбработатьШтрихкоды(Данные);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов) 
	
	Штрихкод = ДанныеШтрихкодов[0].Штрихкод;
	
	// Штрихкод ячейки
	Если СтрДлина(Штрихкод) > 35   Тогда	
		Если Элементы.РедактированиеДокументаНаТСД.Видимость И НЕ Элементы.РедактированиеСтрокиНаТСД.Видимость Тогда	
			МассивСсылок = СсылкаНаЯчейкуПоШтрихкоду(Штрихкод);	
			// Ячейка найдена
			Если МассивСсылок.Количество() > 0 Тогда
				НайденнаяЯчейка = МассивСсылок[0];		
				ОбработатьОтсканированнуюЯчейку(НайденнаяЯчейка);
			Иначе
				Сообщить("Ячейка не найдена");
			КонецЕсли;
		КонецЕсли;
	Иначе   	
		ОбработатьТоварПоШтрихкоду(ДанныеШтрихкодов);	
	КонецЕсли;        

	ЭтаФорма.ОбновитьОтображениеДанных();   
	
КонецПроцедуры    

&НаКлиенте
Функция СсылкаНаЯчейкуПоШтрихкоду(Штрихкод) 
	
	Менеджеры = Новый Массив();
	Менеджеры.Добавить(ПредопределенноеЗначение("Справочник.СкладскиеЯчейки.ПустаяСсылка"));
	Возврат ШтрихкодированиеПечатныхФормКлиент.ПолучитьСсылкуПоШтрихкодуТабличногоДокумента(Штрихкод, Менеджеры); 
	
КонецФункции

&НаСервере
Процедура ОбработатьОтсканированнуюЯчейку(ОтсканированнаяЯчейка)
	
	Если Ячейка <> ОтсканированнаяЯчейка Тогда 	
		НоменклатураПоЯчейке.Очистить();
		ТоварыПоЯчейке = ПолучитьТоварыПоЯчейке(ОтсканированнаяЯчейка);
		НоменклатураПоЯчейке.Загрузить(ТоварыПоЯчейке);	  
		Ячейка = ОтсканированнаяЯчейка; 
	КонецЕсли;

	Если НоменклатураПоЯчейке.Количество()> 0 Тогда
		Элементы.РедактированиеДокументаНаТСД.Видимость = Ложь; 
		Элементы.РедактированиеСтрокиНаТСД.Видимость = Ложь;
		Элементы.ВыборНоменклатурыПоЯчейке.Видимость = Истина;
	КонецЕсли;
		
КонецПроцедуры  

&НаСервере
Функция ПолучитьТоварыПоЯчейке(ОтсканированнаяЯчейка);
	
	УстановитьПривилегированныйРежим(Истина);
	Если ОбеспечениеВДокументахСервер.ЭтоПроизводительныйРежим() Тогда  
		ТекстОстатки="
		|ВЫБРАТЬ
		|	ЗапасыИПотребностиОстатки.Номенклатура КАК Ссылка,
		|	ЗапасыИПотребностиОстатки.Номенклатура.Код КАК Код,
		|	ЗапасыИПотребностиОстатки.Характеристика КАК Характеристика
		|ИЗ
		|	РегистрНакопления.ЗапасыИПотребности.Остатки(
		|			,
		|			(Номенклатура, Склад) В
		|				(ВЫБРАТЬ
		|					ВТ_Номенклатура.Номенклатура,
		|					ВТ_Номенклатура.Склад
		|				ИЗ
		|					ВТ_Номенклатура КАК ВТ_Номенклатура)) КАК ЗапасыИПотребностиОстатки
		|ГДЕ
		|	ЗапасыИПотребностиОстатки.ВНаличииОстаток > 0";	
	иначе
		ТекстОстатки="
		|ВЫБРАТЬ
		|	РаспределениеЗапасов.Номенклатура КАК Ссылка,
		|	РаспределениеЗапасов.Номенклатура.Код КАК Код,
		|	РаспределениеЗапасов.Характеристика КАК Характеристика
		|ИЗ
		|	РегистрСведений.РаспределениеЗапасов КАК РаспределениеЗапасов
		|ГДЕ
		|	(РаспределениеЗапасов.Номенклатура, РаспределениеЗапасов.Склад) В
		|			(ВЫБРАТЬ
		|				ВТ_Номенклатура.Номенклатура,
		|				ВТ_Номенклатура.Склад
		|			ИЗ
		|				ВТ_Номенклатура КАК ВТ_Номенклатура)
		|	И РаспределениеЗапасов.Состояние = ЗНАЧЕНИЕ(Перечисление.РаспределениеЗапасовСостояния.ОстатокНаСкладе)
		|   И РаспределениеЗапасов.ВНаличии > 0";	
	конецесли;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура КАК Номенклатура,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад КАК Склад
	|ПОМЕСТИТЬ ВТ_Номенклатура
	|ИЗ
	|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|ГДЕ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
	|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА
	|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка = &Ячейка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////"+
