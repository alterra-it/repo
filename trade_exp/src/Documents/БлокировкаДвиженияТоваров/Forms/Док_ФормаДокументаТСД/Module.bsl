КонецФункции

&НаКлиенте
Процедура ОбработатьТоварПоШтрихкоду(ДанныеШтрихкодов)
	
	СтруктураДействий = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	
	СтруктураДействий.Штрихкоды = ДанныеШтрихкодов;
	СтруктураДействий.СтруктураДействийСДобавленнымиСтроками = Новый Структура;
	СтруктураДействий.СтруктураДействийСИзмененнымиСтроками  = Новый Структура;
	СтруктураДействий.ИзменятьКоличество = Истина;
	СтруктураДействий.ТолькоТовары = Истина;

	ОбработатьШтрихкодыСервер(СтруктураДействий, КэшированныеЗначения);
		
	Если СтруктураДействий.ТекущаяСтрока = Неопределено Тогда 
		#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
			Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
				СредстваМультимедиа.ВоспроизвестиТекст("Товар не найден!","ru-RU");	
			КонецЕсли; 
		#КонецЕсли
		Сообщить("Штрихкод не найден!");		
	Иначе	
		Элементы.Товары.ТекущаяСтрока = СтруктураДействий.ТекущаяСтрока; 
		ТекущаяСтрокаТСД = СтруктураДействий.ТекущаяСтрока;
		ЗаполнениеДанныхГруппыРедактированиеСтрокиНаТСД(ТекущаяСтрокаТСД);	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьШтрихкодыСервер(СтруктураПараметровДействия,КэшированныеЗначения)
	
	ШтрихкодированиеНоменклатурыСервер.ОбработатьШтрихкоды(ЭтаФорма, Объект, СтруктураПараметровДействия, КэшированныеЗначения);
	
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнениеДанныхГруппыРедактированиеСтрокиНаТСД(ТекущаяСтрока)
	
	ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	Номенклатура = "";
	Характеристика = "";
	Количество = 0;
	АдресКартинки = "";
	
	Если ЭлементСписка <> Неопределено Тогда
		Элементы.РедактированиеДокументаНаТСД.Видимость = Ложь;
		Элементы.РедактированиеСтрокиНаТСД.Видимость = Истина;
		Элементы.ВыборНоменклатурыПоЯчейке.Видимость = Ложь;
		Номенклатура = ЭлементСписка.Номенклатура;
		Характеристика = ЭлементСписка.Характеристика;
		Количество = ЭлементСписка.КоличествоУпаковок;
		ПолучитьАдресКартинки(Номенклатура);
	Конецесли;		
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьАдресКартинки(Номенклатура)
	
	ФайлКартинки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ФайлКартинки");
	Если ЗначениеЗаполнено(ФайлКартинки) Тогда
		АдресКартинки = РаботаСФайлами.ДанныеФайла(ФайлКартинки, ЭтотОбъект.УникальныйИдентификатор).СсылкаНаДвоичныеДанныеФайла;
	КонецЕсли;
	
КонецПроцедуры 


#Область ДобавлениеФото 

&НаКлиенте
Процедура ЗагрузитьФотоТовара(Команда)
	
	Если Объект.Ссылка.Пустая() Тогда
		ПоказатьПредупреждение(, "Данные не записаны!");
		Возврат;
	КонецЕсли; 
		
	Кнопки = КнопкиОповещения();
	ПоказатьВопрос(Новый ОписаниеОповещения("ВыбратьСпособДобавленияФото", Этаформа), "Загрузите фото.", Кнопки);
	
КонецПроцедуры

Функция КнопкиОповещения()
	
	Кнопки = Новый СписокЗначений;
	Кнопки.Добавить("Отмена");
	Кнопки.Добавить("С телефона");
	Кнопки.Добавить("Камера");
	
	Возврат Кнопки;
	
КонецФункции 

&НаКлиенте
Процедура ВыбратьСпособДобавленияФото(РезультатВопроса, ДополнительныеПараметры) Экспорт  
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		Если РезультатВопроса = "Камера" Тогда
			СделатьФотоКамерой();
		ИначеЕсли 
			РезультатВопроса = "С телефона" Тогда
			ДобавитьФотоИзГалереи();
		Иначе
			Возврат;
		КонецЕсли; 
	#КонецЕсли 
	
КонецПроцедуры

&НаКлиенте
Процедура СделатьФотоКамерой()
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда	
		ДанныеМультимедиа = Неопределено;
		Если СредстваМультимедиа.ПоддерживаетсяФотоснимок() Тогда	
			ДанныеМультимедиа = СредстваМультимедиа.СделатьФотоснимок(, Новый РазрешениеКамерыУстройства(1920, 2400) , 100, , ТипПодсветкиКамеры.Включена);	
		Иначе    
			Сообщить(НСтр("ru = 'Съемка фото не поддерживается.'", "ru"));
		КонецЕсли; 

		Если ДанныеМультимедиа <> Неопределено Тогда
			ФайлЗаписан = СоздатьНовыйФайл(ДанныеМультимедиа.ПолучитьДвоичныеДанные(), ДанныеМультимедиа.РасширениеФайла);
			Если ФайлЗаписан Тогда  
				ПоказатьВопрос(Новый ОписаниеОповещения("ЗагрузитьЗавершение", Этаформа), "Изображение успешно загружено." + Символы.ПС + "Добавить новый снимок?", РежимДиалогаВопрос.ДаНет, 0.1);
			КонецЕсли;
		КонецЕсли;
	#КонецЕсли

КонецПроцедуры 

&НаКлиенте
Процедура ЗагрузитьЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		СделатьФотоКамерой();
	Иначе
		Возврат;
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФотоИзГалереи()
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда	
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		Диалог.Фильтр = "Все картинки (*.jpg;*.jpeg;*.tif;*.png)"
		+ "|*.jpg;*.jpeg;*.tif;*.png|";
		Диалог.МножественныйВыбор = Истина;
			
		Если Диалог.Выбрать() Тогда
			МассивФайлов = Диалог.ВыбранныеФайлы;
			Сч = 0;      
			Для Каждого Файл Из МассивФайлов Цикл
				Фото = Новый Файл(Файл);
				Данные = Новый ДвоичныеДанные(Фото.ПолноеИмя);
				ПредставлениеФайла = Фото.ПолучитьПредставлениеФайлаБиблиотекиМобильногоУстройства();
				РасширениеФайла = СтрРазделить(ПредставлениеФайла, ".");
				Расширение = РасширениеФайла[РасширениеФайла.Количество() - 1];

				ФайлЗаписан = СоздатьНовыйФайл(Данные, Расширение);
				Если ФайлЗаписан Тогда 
					Сч = Сч + 1;
				КонецЕсли;	
			КонецЦикла;
			ПоказатьПредупреждение(, "Загружено " + Сч + " из " + МассивФайлов.Количество() + " файлов", 1);
		КонецЕсли;	
	#КонецЕсли

КонецПроцедуры

&НаСервере
Функция СоздатьНовыйФайл(Данные, Расширение)
	
	Если Объект.Склад = Справочники.Склады.НайтиПоНаименованию("Центральный склад", Истина) Тогда
		ПапкаСклада = "СП ЦБ\";  		
	ИначеЕсли Объект.Склад = Справочники.Склады.НайтиПоНаименованию("Склад (Барнаул)", Истина) Тогда
		ПапкаСклада = "СП Барнаул\";
	ИначеЕсли Объект.Склад = Справочники.Склады.НайтиПоНаименованию("Склад (Выбор)", Истина) Тогда
		ПапкаСклада = "СП Выбор\";
	ИначеЕсли Объект.Склад = Справочники.Склады.НайтиПоНаименованию("Склад (Бийск)", Истина) Тогда	
		ПапкаСклада = "СП Бийск\"; 
	Иначе 
		ПапкаСклада	= "";
	КонецЕсли; 
	
	СчетчикФото = СчетчикФото + 1; 
	Имя = "" + Объект.Номер + " (" + СчетчикФото + ")";

	ИмяФайла = "\\TG-Storage01\Склад\Общие\Отдел качества\" + ПапкаСклада + "Фото брака\" + Имя + ".png";
	
	Объект.Комментарий = Объект.Комментарий + Символы.ПС + ИмяФайла;
	 
    Попытка 
        Данные.Записать(ИмяФайла);  
		Возврат Истина;
    Исключение 
		Ошибка = ИнформацияОбОшибке();
		ПодробнаяОшибка = ПодробноеПредставлениеОшибки(Ошибка);
		Сообщить(ПодробнаяОшибка);
		Возврат Ложь;
    КонецПопытки;

КонецФункции

