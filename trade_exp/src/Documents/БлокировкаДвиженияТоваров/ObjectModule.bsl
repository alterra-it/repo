#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда	
	
&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(ЭтотОбъект);
	
	ПроведениеДокументов.ПередЗаписьюДокумента(ЭтотОбъект, РежимЗаписи, РежимПроведения);
	
	ЭтоНовыйДокумент = ЭтоНовый();
	ДополнительныеСвойства.Вставить("ЭтоНовый",    ЭтоНовыйДокумент);
	ДополнительныеСвойства.Вставить("РежимЗаписи", РежимЗаписи);
	Если ЭтоНовыйДокумент И НЕ ЗначениеЗаполнено(Номер) Тогда
		УстановитьНовыйНомер();
	КонецЕсли;
	
	Если ПометкаУдаления ИЛИ РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ЗапретРаспроведенияЗаблокированных(Отказ);		
	КонецЕсли;
	
	Если Не Отказ И ПометкаУдаления И Не Проведен Тогда
		БлокировкаОснование = Документы.БлокировкаДвиженияТоваров.ПустаяСсылка();		
	КонецЕсли;
	
КонецПроцедуры 

&Вместо("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ПроведениеДокументов.ПриЗаписиДокумента(ЭтотОбъект, Отказ);   	
КонецПроцедуры

&Вместо("ПередУдалением")
Процедура ПередУдалением(Отказ)
	ЗапретРаспроведенияЗаблокированных(Отказ);
КонецПроцедуры

&Вместо("ОбработкаПроведения")
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Если ЭтотОбъект.ДополнительныеСвойства.ЭтоНовый Тогда
		БылПроведен = Ложь;
	Иначе
		БылПроведен = Документы.БлокировкаДвиженияТоваров.ВыполнитьКонтрольБлокировкиПослеПроведения(Ссылка, Отказ);
	КонецЕсли;	
	
	ПроведениеДокументов.ОбработкаПроведенияДокумента(ЭтотОбъект, Отказ);
	
	Результат = Документы.БлокировкаДвиженияТоваров.ВыполнитьКонтрольБлокировкиПослеПроведения(Ссылка, Отказ);
	
	ПроводитьОрдера = Истина;    
	
	Если ДополнительныеСвойства.Свойство("ПроведениеИзПриходногоОрдера") Тогда 
		ПроводитьОрдера = Не ДополнительныеСвойства.ПроведениеИзПриходногоОрдера;
	КонецЕсли;
	
	Если ПроводитьОрдера Тогда
		Документы.БлокировкаДвиженияТоваров.ПерепровестиПриходныеОрдера(Ссылка,Отказ);
	КонецЕсли;
	
	Если ЭтотОбъект.Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Разблокировано И НЕ БылПроведен
		 И Результат Тогда
	ПричиныБлокировки = Новый Массив;
	ПричиныБлокировки.Добавить("Брак");
	ПричиныБлокировки.Добавить("Брак на складе");
	ПричиныБлокировки.Добавить("Брак от покупателей");
	ПричиныБлокировки.Добавить("Возврат поставщику");
	ПричиныБлокировки.Добавить("Для благотворительности");
	ПричиныБлокировки.Добавить("Сроки годности");
		Если ПричиныБлокировки.Найти(ЭтотОбъект.ПричинаБлокировки.Наименование) <> Неопределено Тогда
			
			ПараметрыСообщения = Новый Структура;
			Если ЭтотОбъект.БлокировкаОснование <> Документы.БлокировкаДвиженияТоваров.ПустаяСсылка() Тогда
				ПараметрыСообщения.Вставить("НомерБлокировки", ЭтотОбъект.БлокировкаОснование.Номер);
			КонецЕсли;
			ПараметрыСообщения.Вставить("АвторРазблокировки", ЭтотОбъект.Ответственный);
			параметрыСообщения.Вставить("Склад", ЭтотОбъект.Склад);
			ПараметрыСообщения.Вставить("РуководительСекции");
			ПараметрыСообщения.Вставить("СписокТоваров");
			     
			Если ЭтотОбъект.БлокировкаОснование <> Документы.БлокировкаДвиженияТоваров.ПустаяСсылка() И ЗначениеЗаполнено(ЭтотОбъект.БлокировкаОснование.Комментарий) Тогда
				ПараметрыСообщения.Вставить("Комментарий", ЭтотОбъект.БлокировкаОснование.Комментарий);
			ИначеЕсли ЗначениеЗаполнено(ЭтотОбъект.Комментарий) Тогда
				ПараметрыСообщения.Вставить("Комментарий", ЭтотОбъект.Комментарий); 
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ
							| 	ТЧДок.Номенклатура КАК Номенклатура,
							| 	ТЧДок.КоличествоУпаковок КАК Количество,
							| 	Секции.Руководитель КАК РуководительСекции
							| ИЗ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК Ячейки
							| 	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РабочиеУчастки КАК Секции
							| 		ПО Секции.Ссылка = Ячейки.Ячейка.РабочийУчасток
							| 	ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.БлокировкаДвиженияТоваров.Товары КАК ТЧДок
							| 		ПО ТЧДок.Номенклатура = Ячейки.Номенклатура
							| 		И ТЧДок.Ссылка.Склад = Ячейки.Склад
							| 		И ТЧДок.Ссылка = &Ссылка
							| СГРУППИРОВАТЬ ПО
							| 	ТЧДок.Номенклатура,
							| 	ТЧДок.КоличествоУпаковок,
							| 	Секции.Руководитель
							| ИТОГИ ПО
							| 	Секции.Руководитель";
			
			Запрос.УстановитьПараметр("Ссылка", ЭтотОбъект.Ссылка);
			ВыборкаЗапроса = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаЗапроса.Следующий() Цикл
				ВыборкаПоСекции = ВыборкаЗапроса.Выбрать();
				СписокТоваров = "";
				Пока ВыборкаПоСекции.Следующий() Цикл
					СписокТоваров = СписокТоваров + Символы.ПС + ВыборкаПоСекции.Номенклатура + Символы.Таб + " Кол-во " + ВыборкаПоСекции.Количество;
					РуководительСекции = ВыборкаПоСекции.РуководительСекции;
				КонецЦикла;
				ПараметрыСообщения.СписокТоваров = СписокТоваров;
				ПараметрыСообщения.РуководительСекции = РуководительСекции;
				ДопМодуль.ОтправитьСообщениеОРазблокировкеВБитрикс24(ПараметрыСообщения);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&Вместо("ОбработкаУдаленияПроведения")
Процедура ОбработкаУдаленияПроведения(Отказ)
	
	Если Не рольДоступна("ПолныеПрава") И Не ЭтотОбъект.ДополнительныеСвойства.Свойство("ОтключитьКонтроль") И 
		 Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано И	
		(ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") ИЛИ 
		ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.КорректировкаРеализации") ИЛИ
		ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ПеремещениеТоваров")) Тогда
		ПриходныеОрдера = Документы.БлокировкаДвиженияТоваров.ПолучитьПриходныеОрдераПоДокументуОснованию(ДокументОснование);
		Если ПриходныеОрдера.Количество()>0 Тогда
			Отказ = Истина;
			АльтерраОбщегоНазначения.СообщитьПользователю(,"По документу основанию созданы приходные ордера!",)
		КонецЕсли;
	КонецЕсли;
	
	Если Не Отказ И ПометкаУдаления И Проведен Тогда
		БлокировкаОснование = Документы.БлокировкаДвиженияТоваров.ПустаяСсылка();		
	КонецЕсли; 
	
КонецПроцедуры

&Вместо("ОбработкаЗаполнения")
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда 
		ЗаполнитьПоПриходномуОрдеру(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда	
		ЗаполнитьПоПеремещению(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.КорректировкаРеализации") Тогда	
		ЗаполнитьПоКорректировкеРеализации(ДанныеЗаполнения);
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда	
		ЗаполнитьПоВозвратуТоваров(ДанныеЗаполнения);	
	КонецЕсли;
	ИнициализироватьДокумент(ДанныеЗаполнения);  
	
КонецПроцедуры
	
Процедура ИнициализироватьДокумент(ДанныеЗаполнения = Неопределено)
	
	Ответственный = Пользователи.ТекущийПользователь();
	Если Не ЗначениеЗаполнено(Статус) тогда
		статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано;
	КонецЕсли;
		
КонецПроцедуры
	
Процедура ЗаполнитьПоПриходномуОрдеру(ДанныеЗаполнения)
		
	Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано;
	Склад = ДанныеЗаполнения.Склад;
	ДокументОснование = ДанныеЗаполнения;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПриходныйОрдерНаТоварыТовары.Номенклатура КАК Номенклатура,
	|	ПриходныйОрдерНаТоварыТовары.Характеристика КАК Характеристика,
	|	ПриходныйОрдерНаТоварыТовары.КоличествоУпаковок КАК Количество
	|ИЗ
	|	Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
	|ГДЕ
	|	ПриходныйОрдерНаТоварыТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	
	РезультатЗапроса = Запрос.Выполнить();
	Товары.Загрузить(РезультатЗапроса.Выгрузить());
			
КонецПроцедуры
	
Процедура ЗаполнитьПоПеремещению(ДанныеЗаполнения)
		
	Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано;
	Склад = ДанныеЗаполнения.СкладПолучатель;
	ДокументОснование = ДанныеЗаполнения;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура КАК Номенклатура,
	|	ПеремещениеТоваровТовары.Характеристика КАК Характеристика,
	|	ПеремещениеТоваровТовары.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	
	РезультатЗапроса = Запрос.Выполнить();
	Товары.Загрузить(РезультатЗапроса.Выгрузить());	
		
КонецПроцедуры

Процедура ЗаполнитьПоКорректировкеРеализации(ДанныеЗаполнения)
		
	Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано;
	ПричинаБлокировки = Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоКоду("000000007");
	Склад = ДанныеЗаполнения.Склад;
	ДокументОснование = ДанныеЗаполнения;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КорректировкаРеализацииРасхождения.Номенклатура КАК Номенклатура,
	|	КорректировкаРеализацииРасхождения.Характеристика КАК Характеристика,
	|	-1 * КорректировкаРеализацииРасхождения.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	Документ.КорректировкаРеализации.Расхождения КАК КорректировкаРеализацииРасхождения
	|ГДЕ
	|	КорректировкаРеализацииРасхождения.Ссылка = &Ссылка
	|	И КорректировкаРеализацииРасхождения.КоличествоУпаковок < 0";
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	
	РезультатЗапроса = Запрос.Выполнить();
	Товары.Загрузить(РезультатЗапроса.Выгрузить());	
		
КонецПроцедуры
	
Процедура ЗаполнитьПоВозвратуТоваров(ДанныеЗаполнения)
		
	Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано;
	ПричинаБлокировки = Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоКоду("000000011");
	Склад = ДанныеЗаполнения.Склад;
	ДокументОснование = ДанныеЗаполнения;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВозвратТоваровОтКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ВозвратТоваровОтКлиентаТовары.Характеристика КАК Характеристика,
	|	ВозвратТоваровОтКлиентаТовары.КоличествоУпаковок КАК КоличествоУпаковок
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
	|ГДЕ
	|	ВозвратТоваровОтКлиентаТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ДанныеЗаполнения);
	
	РезультатЗапроса = Запрос.Выполнить();
	Товары.Загрузить(РезультатЗапроса.Выгрузить());
		
КонецПроцедуры

Процедура ЗапретРаспроведенияЗаблокированных(Отказ)      	
	
	Если Не Отказ И Статус = Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано Тогда 
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПРЕДСТАВЛЕНИЕ(БлокировкаДвиженияТоваров.Ссылка) КАК Ссылка
			|ИЗ
			|	Документ.БлокировкаДвиженияТоваров КАК БлокировкаДвиженияТоваров
			|ГДЕ
			|	БлокировкаДвиженияТоваров.БлокировкаОснование = &БлокировкаОснование";
		
		Запрос.УстановитьПараметр("БлокировкаОснование", Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			ТекстОшибки = "Отмена проведения запрещена! Существуют созданные на этом основании документы:" + Символы.ПС + Символы.ПС;
			РезультатЗапроса = РезультатЗапроса.Выбрать();
			
			Пока РезультатЗапроса.Следующий() Цикл
				ТекстОшибки = ТекстОшибки + РезультатЗапроса.Ссылка + Символы.ПС;
			КонецЦикла;
			
			Сообщить(ТекстОшибки);
			Отказ = Истина;
		КонецЕсли;	
	КонецЕсли;  
	
КонецПроцедуры

Функция ПолучитьКоличествоДляРазблокировки(Ссылка) Экспорт 

	Запрос = Новый Запрос();
	Запрос.Текст = "
      	|ВЫБРАТЬ 
      	|	БлокировкаДвиженияТовары.Номенклатура, 
      	|	БлокировкаДвиженияТовары.Ссылка.Склад, 
      	|	БлокировкаДвиженияТовары.Характеристика, 
      	|	БлокировкаДвиженияТовары.Упаковка, 
      	|	Сумма(БлокировкаДвиженияТовары.КоличествоУпаковок) КАК Количество      	
      	|ПОМЕСТИТЬ 
      	|	ТоварыЗаблокировано
      	|ИЗ
      	|	Документ.БлокировкаДвиженияТоваров.Товары  КАК БлокировкаДвиженияТовары
      	|	
      	|ГДЕ 
      	|	БлокировкаДвиженияТовары.Ссылка = &Ссылка
      	|	И БлокировкаДвиженияТовары.Ссылка.Статус = Значение(Перечисление.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано)
      	|	И БлокировкаДвиженияТовары.Ссылка.Проведен
      	|СГРУППИРОВАТЬ ПО 
      	|	БлокировкаДвиженияТовары.Номенклатура, 
      	|	БлокировкаДвиженияТовары.Ссылка.Склад,	
      	|	БлокировкаДвиженияТовары.Характеристика,
      	|	БлокировкаДвиженияТовары.Упаковка 
      	|;
	  	|ВЫБРАТЬ 
      	|	БлокировкаДвиженияТовары.Номенклатура, 
		|	БлокировкаДвиженияТовары.Ссылка.Склад,       		
      	|	БлокировкаДвиженияТовары.Характеристика, 
      	|	БлокировкаДвиженияТовары.Упаковка,
      	|	Сумма(БлокировкаДвиженияТовары.КоличествоУпаковок) КАК Количество
      	|ПОМЕСТИТЬ 
      	|	ТоварыРазблокировано
      	|ИЗ
      	|	Документ.БлокировкаДвиженияТоваров.Товары  КАК БлокировкаДвиженияТовары
      	|	
      	|ГДЕ 
      	|	БлокировкаДвиженияТовары.Ссылка.БлокировкаОснование = &Ссылка
      	|	И БлокировкаДвиженияТовары.Ссылка.Статус = Значение(Перечисление.СтатусыБлокировкиДвиженияНоменклатуры.Разблокировано)
      	|	И БлокировкаДвиженияТовары.Ссылка.Проведен
      	|СГРУППИРОВАТЬ ПО 
      	|	БлокировкаДвиженияТовары.Номенклатура, 
      	|	БлокировкаДвиженияТовары.Ссылка.Склад,
      	|	БлокировкаДвиженияТовары.Характеристика, 
      	|	БлокировкаДвиженияТовары.Упаковка
      	|;
      	|ВЫБРАТЬ 
      	|	ТоварыЗаблокировано.Номенклатура,
      	|	ТоварыЗаблокировано.Склад,
      	|	ТоварыЗаблокировано.Характеристика,
      	|	ТоварыЗаблокировано.Упаковка,
      	|	ЕСТЬNULL(ТоварыЗаблокировано.Количество, 0) КАК ЗаблокированоКоличество,
      	|	ЕСТЬNULL(ТоварыРазблокировано.Количество, 0) КАК РазблокированоКоличество,
      	|	ЕСТЬNULL(ТоварыЗаблокировано.Количество, 0) - ЕСТЬNULL(ТоварыРазблокировано.Количество, 0) КАК ИтогоКоличество
      	|ИЗ 
      	|	ТоварыЗаблокировано 
      	|	ЛЕВОЕ СОЕДИНЕНИЕ 
      	|		ТоварыРазблокировано 
      	|	ПО
      	|		ТоварыЗаблокировано.Номенклатура = ТоварыРазблокировано.Номенклатура
      	|		И ТоварыЗаблокировано.Характеристика = ТоварыРазблокировано.Характеристика
      	|		И ТоварыЗаблокировано.Склад = ТоварыРазблокировано.Склад
		|ГДЕ ЕСТЬNULL(ТоварыЗаблокировано.Количество, 0) - ЕСТЬNULL(ТоварыРазблокировано.Количество, 0) > 0		
		|";
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Возврат Запрос;
	
КонецФункции

