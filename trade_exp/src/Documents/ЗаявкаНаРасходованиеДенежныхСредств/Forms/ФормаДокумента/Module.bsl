
&НаКлиенте
Процедура Док_КонтрагентПриИзмененииПосле(Элемент)
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Объект.ПолучательРучнойВвод = "";
		Элементы.ПолучательРучнойВвод.ТолькоПросмотр = Истина;
		Элементы.ПолучательРучнойВвод.Подсказка = "При заполненном получателе данное поле заполнять не требуется";
		Элементы.БанковскийСчетКонтрагента.АвтоОтметкаНезаполненного = Истина;
		ЗаполнитьЕдинственныйДоговор();
	Иначе
		Элементы.ПолучательРучнойВвод.ТолькоПросмотр = Ложь;
		Элементы.ПолучательРучнойВвод.Подсказка = "";
		Элементы.БанковскийСчетКонтрагента.АвтоОтметкаНезаполненного = Ложь;
	КонецЕсли;
КонецПроцедуры

&После ("СтатусПриИзмененииСервер")
Процедура Док_СтатусПриИзмененииСервер()
	если объект.Статус=Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате тогда
		Объект.Утверждающий=Пользователи.ТекущийПользователь();
	конецесли;		
	
	Если НЕ Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована") Тогда
		УстановитьДоступностьЭлементов(НЕ ЭтоКазначей());
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Док_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	Элементы.СогласованоЗакупВРамкахДоговораПодряда.Видимость = АльтерраОбщегоНазначения._РольДоступна("ЧтениеСогласованоЗакупВРамкахДоговораПодряда") ИЛИ АльтерраОбщегоНазначения._РольДоступна("ИзменениеСогласованоЗакупВРамкахДоговораПодряда");
	Элементы.СогласованоЗакупВРамкахДоговораПодряда.Доступность = АльтерраОбщегоНазначения._РольДоступна("ИзменениеСогласованоЗакупВРамкахДоговораПодряда");	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	Если НЕ ПолныеПрава() Тогда
		Элементы.ФормаЗапуститьБПБитрикс.Доступность = НЕ ЗначениеЗаполнено(Объект.ИДЭлементаВБитриксе);
	КонецЕсли;
	
	Если НЕ Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована") Тогда
		УстановитьДоступностьЭлементов(НЕ ЭтоКазначей());
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Объект.ПолучательРучнойВвод = "";
		Элементы.ПолучательРучнойВвод.ТолькоПросмотр = Истина;
		Элементы.ПолучательРучнойВвод.Подсказка = "При заполненном получателе данное поле заполнять не требуется";
		Элементы.БанковскийСчетКонтрагента.АвтоОтметкаНезаполненного = Истина;
	Иначе
		Элементы.ПолучательРучнойВвод.ТолькоПросмотр = Ложь;
		Элементы.ПолучательРучнойВвод.Подсказка = "";
		Элементы.БанковскийСчетКонтрагента.АвтоОтметкаНезаполненного = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолныеПрава()

	Если РольДоступна("ПолныеПрава") Тогда
		Возврат Истина;
	Иначе
		Возврат ложь;
	КонецЕсли;

КонецФункции 


&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		СФП_МаркерыКлиент.МаркерНачало("Заявка на расходование денежных средств: Проведение из формы", Объект.Номер);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ЗапуститьБПБитриксПосле(Команда)
	ОчиститьСообщения();
	УспешныйЗапуск = Ложь;                              
	Если НЕ Объект.Проведен Тогда
		Сообщить("Перед запуском БП документ нужно провести.");	
	ИначеЕсли Модифицированность Тогда
		Отказ = Истина;
		ТекстВопроса = НСтр("ru = 'Документ был изменен. Сохранить изменения?'");
		Оповещение = Новый ОписаниеОповещения("ВопросПередЗаписьюЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
	Иначе   
		УспешныйЗапуск = Док_ЗапуститьБПБитриксПослеНаСервере();
	КонецЕсли;
	Если УспешныйЗапуск Тогда
		Закрыть();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередЗаписьюЗавершение(Результат, ДополнительныеПараметры) Экспорт

	УспешныйЗапуск = Ложь;
	Если Результат = КодВозвратаДиалога.Да Тогда 
		Записать();	
		Если Объект.ИДЭлементаВБитриксе = "" Тогда  
			Если НЕ Объект.Проведен Тогда
				Сообщить("Перед запуском БП документ нужно провести.");
			Иначе	             
				УспешныйЗапуск = Док_ЗапуститьБПБитриксПослеНаСервере();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если УспешныйЗапуск Тогда
		Закрыть();
	КонецЕсли;
        
КонецПроцедуры

&НаСервере
Функция Док_ЗапуститьБПБитриксПослеНаСервере()
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	УспешныйЗапуск = Ложь;
	Если УтверждающиеКорректноЗаполнены() И 
		НаличиеПрикрепленныхФайлов(ТекущийПользователь)И
		ПолучательЗаполнен() Тогда
		УспешныйЗапуск = ОтправитьЗапросНаСозданиеБП();
		Элементы.ФормаЗапуститьБПБитрикс.Доступность = НЕ УспешныйЗапуск;
	КонецЕсли;
	Возврат УспешныйЗапуск;
КонецФункции

&НаСервере
Функция УтверждающиеКорректноЗаполнены()
	ПользователиЗаполненыКорректно = Истина;
	Если Объект.Утверждающий1 = Справочники.Пользователи.ПустаяСсылка() Тогда	
		Сообщить("Поле 'Утверждающий 1' должно быть обязательно заполнено!");
	ИначеЕсли АльтерраОбщегоНазначения.ПолучитьСотрудника(Объект.Утверждающий1)<>Справочники.Сотрудники.ПустаяСсылка() Тогда
		ЕстьВБитрикс24(Объект.Утверждающий1);
	Иначе
		Сообщить("Сотрудник "+Объект.Утверждающий1+" Помечен на удаление или уволен");
		ПользователиЗаполненыКорректно = Ложь;
	КонецЕсли;
	
	Если Не Объект.Утверждающий2 = Справочники.Пользователи.ПустаяСсылка() Тогда
		ЕстьВБитрикс24(Объект.Утверждающий2);
		Если АльтерраОбщегоНазначения.ПолучитьСотрудника(Объект.Утверждающий2)=Справочники.Сотрудники.ПустаяСсылка() Тогда
			Сообщить("Сотрудник "+Объект.Утверждающий2+" Помечен на удаление или уволен");
			ПользователиЗаполненыКорректно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если Не Объект.Утверждающий3 = Справочники.Пользователи.ПустаяСсылка() Тогда
		ЕстьВБитрикс24(Объект.Утверждающий3);
		Если АльтерраОбщегоНазначения.ПолучитьСотрудника(Объект.Утверждающий3)=Справочники.Сотрудники.ПустаяСсылка() Тогда
			Сообщить("Сотрудник "+Объект.Утверждающий3+" Помечен на удаление или уволен");
			ПользователиЗаполненыКорректно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Если Не Объект.Утверждающий4 = Справочники.Пользователи.ПустаяСсылка() Тогда
		ЕстьВБитрикс24(Объект.Утверждающий3);
		Если АльтерраОбщегоНазначения.ПолучитьСотрудника(Объект.Утверждающий3)=Справочники.Сотрудники.ПустаяСсылка() Тогда
			Сообщить("Сотрудник "+Объект.Утверждающий4+" Помечен на удаление или уволен");
			ПользователиЗаполненыКорректно = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ПользователиЗаполненыКорректно;
		
КонецФункции

&НаСервере
Функция ЕстьВБитрикс24(Пользователь)

	Если АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Пользователь) = "" Тогда
			Сообщить("Пользователя "+Пользователь+" нет в Битрикс24");
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;

КонецФункции 

&НаСервере
Функция НаличиеПрикрепленныхФайлов(Пользователь)

	Если НЕ СотрудникОтделаЛогистилиИлиПоставок(Пользователь) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка КАК Заявка,
			|	ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.Ссылка КАК Файл
			|ИЗ
			|	Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
			|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы КАК ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы
			|		ПО (ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.ВладелецФайла = ЗаявкаНаРасходованиеДенежныхСредств.Ссылка)
			|ГДЕ
			|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = &Ссылка 
			|	И не ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.Наименование есть null";
		
		Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() тогда
			Возврат Истина;
		КонецЕсли;
		
		Сообщить("Перед запуском БП необходимо приложить счет в поле ""Файлы""");
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;

КонецФункции 

&НаСервере
Функция СотрудникОтделаЛогистилиИлиПоставок(Пользователь)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Отдел КАК Отдел,
		|	Пользователи.Ссылка КАК Пользователь
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
		|		ПО Сотрудники.Пользователь = Пользователи.Ссылка
		|ГДЕ
		|	НЕ Сотрудники.Ссылка.Уволен
		|	И (Сотрудники.Отдел.Наименование ПОДОБНО ""Отдел поставок%""
		|			ИЛИ Сотрудники.Отдел.Наименование ПОДОБНО ""Отдел транспортной логистики%"")";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.Пользователь = Пользователь Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;

	Возврат Ложь;
КонецФункции

&НаСервере
Функция ПолучательЗаполнен()

	Если ЗначениеЗаполнено(Объект.ПолучательРучнойВвод) 
		или Объект.Контрагент <> Справочники.Организации.ПустаяСсылка() Тогда
		Возврат Истина;
	Иначе
		Сообщить("Поле 'Получатель' или 'Получатель, ИНН (руч. ввод)' должно быть заполнено");
		Возврат Ложь;
	КонецЕсли;

КонецФункции // ПолучательЗаполнен()

&НаСервере
Функция ОтправитьЗапросНаСозданиеБП()
	
	ИДТипаБлока = "bitrix_processes";
	ИДБлока = "106";
	КодЭлементаПроцесса = Формат(ТекущаяДата(), "ДФ=ггггММддЧЧммсс");
	
	ТекущийПользовательБитрикс = АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Пользователи.ТекущийПользователь());
	
	Поля = Новый Структура;
	Поля.Вставить("CREATED_BY", ТекущийПользовательБитрикс);
	Поля.Вставить("NAME", "Бюджетная заявка");
	Поля.Вставить("PROPERTY_676", Объект.СуммаДокумента);//Сумма								//Сумма платежа из ЗРДС
	Поля.Вставить("PROPERTY_3804", Строка(Объект.Валюта));	//Валюта взаиморасчетов (строка)
    Поля.Вставить("PROPERTY_687", "-"); //Поле НДС нужно обязательно заполнять из-за возможности ручного ввода
	Поля.Вставить("PROPERTY_3801", Строка(Объект.РасшифровкаПлатежа[0].СтавкаНДС)); //НДС (строка)
	Поля.Вставить("PROPERTY_688", "-"); //Поле Плательщик нужно обязательно заполнять из-за возможности ручного ввода
	Поля.Вставить("PROPERTY_3802", Строка(Объект.Организация)); //Плательщик-Организация (строка)
	Поля.Вставить("PROPERTY_1082", Объект.НазначениеПлатежа);//Назначение платежа				//Назначение платежа из ЗРДС
	Поля.Вставить("PROPERTY_690", Объект.Комментарий);//Развернутое описание					//Заметки(Комментарий) из ЗРДС
	Поля.Вставить("PROPERTY_3497", Строка(Формат(Объект.ЖелательнаяДатаПлатежа, "ДФ=dd.MM.yyyy")));// Дата платежа			//Дата платежа с ЗРДС
	Поля.Вставить("PROPERTY_691", 600);	
	Поля.Вставить("PROPERTY_3495", Строка(Объект.СтатьяСписания));
		
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Поля.Вставить("PROPERTY_692", Строка(Объект.Контрагент));
	Иначе
		Поля.Вставить("PROPERTY_692", строка(Объект.ПолучательРучнойВвод));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.БанковскийСчетКонтрагента) Тогда
		Поля.Вставить("PROPERTY_693", Строка(Объект.БанковскийСчетКонтрагента)+ " " + Строка(Объект.БанковскийСчетКонтрагента.НомерСчета));
	КонецЕсли;	
	Поля.Вставить("PROPERTY_684", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Утверждающий1));//Утверждающий 1
	Если ЗначениеЗаполнено(Объект.Утверждающий2) Тогда
		Поля.Вставить("PROPERTY_685", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Утверждающий2));//Утверждающий 2
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Утверждающий3) Тогда
		Поля.Вставить("PROPERTY_686", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Утверждающий3));//Утверждающий 3
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Утверждающий4) Тогда
		Поля.Вставить("PROPERTY_3458", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Утверждающий4));//Утверждающий 4
	КонецЕсли;
	Поля.Вставить("PROPERTY_3494", Строка(Объект.Номер));

	МассивИДФайлов = АльтерраВзаимодействиеСБитрикс24.ЗагрузитьФайлыВБитрикс("1116028", //Папка на общем диске
																			 ПолучитьМассивПрикрепленныхФайлов(), 
																			 ТекущийПользовательБитрикс, 
																			 КодЭлементаПроцесса);
																			 
																			 
	Поля.Вставить("PROPERTY_3493", МассивИДФайлов);//Копия счета (файл)										//Файлы, которые прикрепляют к ЗРДС
	
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовыйЭлементСписка(ИДТипаБлока, ИДБлока, КодЭлементаПроцесса, Поля);
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
		Возврат Ложь
	КонецЕсли;   	
	
	Если СтруктураОтвета.Свойство("Результат") Или СтруктураОтвета.Свойство("result") Тогда   	
		ИДЭлементаВБитриксе = СтруктураОтвета.result; 
		ИДЭлементаВБитриксе = СтрЗаменить(ИДЭлементаВБитриксе," ","");
		Объект.ИДЭлементаВБитриксе = ИДЭлементаВБитриксе; 
		Сообщить("В Битриксе успешно запущен БП " + ИДЭлементаВБитриксе); 
		Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КУтверждению;
		Объект.Комментарий = Объект.Комментарий+Символы.ПС+"Были внесены следующие изменения: ";
		Записать(); 
	КонецЕсли;
	
	Возврат Истина;

КонецФункции // Отправить ()

&НаСервере
Функция ПолучитьМассивПрикрепленныхФайлов()

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.Ссылка КАК Файл
		|ИЗ
		|	Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы КАК ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы
		|		ПО (ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.ВладелецФайла = ЗаявкаНаРасходованиеДенежныхСредств.Ссылка)
		|ГДЕ
		|	ЗаявкаНаРасходованиеДенежныхСредств.Ссылка = &Ссылка 
		|	И не ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.Наименование есть null
		|	И НЕ ЗаявкаНаРасходованиеДенежныхСредствПрисоединенныеФайлы.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	МассивФайлов = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивФайлов.Добавить(ВыборкаДетальныеЗаписи.Файл);
	КонецЦикла;

	Возврат МассивФайлов;
КонецФункции

&НаСервере
Функция ЭтоКазначей()
	//возврат истина;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ                                                       
		|	СпрПользователи.Ссылка КАК Сотрудник,                                                   
		|	ГруппыДоступаПользователи.Ссылка КАК ГруппаДоступа
		|ИЗ
		|	Справочник.ГруппыДоступа.Пользователи КАК ГруппыДоступаПользователи
		|		левое СОЕДИНЕНИЕ РегистрСведений.СоставыГруппПользователей КАК СоставыГруппПользователей
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК СпрПользователи     
		|			ПО СпрПользователи.Ссылка = СоставыГруппПользователей.Пользователь
		|		ПО (СоставыГруппПользователей.ГруппаПользователей = ГруппыДоступаПользователи.Пользователь)
		|			И (НЕ ГруппыДоступаПользователи.Ссылка.ПометкаУдаления)  
		|		ГДЕ
		|	НЕ СпрПользователи.Недействителен
		|	И НЕ СпрПользователи.ПометкаУдаления
		|	И СпрПользователи.Ссылка = &Ссылка
		|	И ГруппыДоступаПользователи.Ссылка.Наименование = ""Директбанк""";
	
	Запрос.УстановитьПараметр("Ссылка", Пользователи.ТекущийПользователь());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() ИЛИ РольДоступна("ПолныеПрава") ИЛИ Объект.ИДЭлементаВБитриксе = "" Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции

&НаСервере
&ИзменениеИКонтроль("УстановитьСписокСтатусов")
Процедура Док_УстановитьСписокСтатусов()

	СписокВыбора = Элементы.Статус.СписокВыбора;
	
	СписокВыбора.Очистить();
	
	Если Не Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате
		И Не Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована Тогда
		СписокВыбора.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована);
	КонецЕсли;
	
	Если (ПравоСогласования И Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована)
		Или Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована Тогда
		СписокВыбора.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована);
	КонецЕсли;
	
	#Вставка
	Если Не ПравоСогласования Или Не ПравоУтверждения Тогда
		СписокВыбора.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КУтверждению);
	КонецЕсли;
	#КонецВставки
	
	Если (ПравоУтверждения 
		И (Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована
		Или Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована))
		Или Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате Тогда
		СписокВыбора.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате);
	КонецЕсли;
	
	Если Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.НеСогласована
		Или Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Согласована
		Или (ПравоУтверждения И Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КОплате)
		Или Объект.Статус = Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена Тогда
		СписокВыбора.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.Отклонена);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Если Объект.Ссылка = Документы.ЗаявкаНаРасходованиеДенежныхСредств.ПустаяСсылка() Тогда
		Объект.ИДЭлементаВБитриксе = "";
	КонецЕсли;
	СписокВыбора = Элементы.Статус.СписокВыбора;
	СписокВыбора.Добавить(Перечисления.СтатусыЗаявокНаРасходованиеДенежныхСредств.КУтверждению);
	//Элементы.Статус.Доступность = ЭтоКазначей();
	Если ЗначениеЗаполнено(Объект.Контрагент) Тогда
		Объект.ПолучательРучнойВвод = "";
		Элементы.ПолучательРучнойВвод.ТолькоПросмотр = Истина;
		Элементы.ПолучательРучнойВвод.Подсказка = "При заполненном получателе данное поле заполнять не требуется";
		Элементы.БанковскийСчетКонтрагента.АвтоОтметкаНезаполненного = Истина;
	Иначе
		Элементы.ПолучательРучнойВвод.ТолькоПросмотр = Ложь;
		Элементы.ПолучательРучнойВвод.Подсказка = "";
		Элементы.БанковскийСчетКонтрагента.АвтоОтметкаНезаполненного = Ложь;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Док_ПередЗаписьюПослеНаСервере()
	Для каждого Строка Из Объект.РасшифровкаПлатежа Цикл
		Если Строка.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.ПустаяСсылка() Тогда
			Строка.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("0А-000103/01-000010", Истина);
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПосле(Отказ, ПараметрыЗаписи)
	Док_ПередЗаписьюПослеНаСервере();
КонецПроцедуры

