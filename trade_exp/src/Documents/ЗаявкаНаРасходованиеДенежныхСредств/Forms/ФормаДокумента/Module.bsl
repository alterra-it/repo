&НаСервере
Процедура УстановитьДоступностьЭлементов(Значение)

	Для каждого Элемент Из Элементы Цикл
		Если ТИПЗНЧ(Элемент)= Тип("ПолеФормы") Тогда
			Элемент.ТолькоПросмотр = Значение;
		КонецЕсли;
	КонецЦикла;
	Элементы.СтатьяСписания.ТолькоПросмотр = Ложь;
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьЕдинственныйДоговор()
	Для каждого Строка из Объект.РасшифровкаПлатежа Цикл
		Строка.ОбъектРасчетов = Справочники.ОбъектыРасчетов.ПустаяСсылка();
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ОбъектыРасчетов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбъектыРасчетов КАК ОбъектыРасчетов
		|		ПО ДоговорыКонтрагентов.Ссылка = ОбъектыРасчетов.Объект
		|ГДЕ
		|	ДоговорыКонтрагентов.Контрагент = &Контрагент
		|	И ДоговорыКонтрагентов.Статус = &Статус";
	
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыДоговоровКонтрагентов.Действует);
	Запрос.УстановитьПараметр("Контрагент", объект.Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	КоличествоЗаписей = ВыборкаДетальныеЗаписи.Количество();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Если КоличествоЗаписей = 1 Тогда
			Для каждого Строка из Объект.РасшифровкаПлатежа Цикл
				Строка.ОбъектРасчетов = ВыборкаДетальныеЗаписи.Ссылка;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
КонецПроцедуры
