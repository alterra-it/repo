&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Элементы._ПодтвержденСкладом.Доступность = РольДоступнаПодтверждениеСкладом();  
	//--Для склада доступ только к ПодтвержденСкладом 
	Если РольДоступна("ДобавлениеИзменениеБезУдаленияОрдеровНаОтражениеИзлишковНедостачПорчи") Тогда
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы Цикл    
			Если (ТипЗнч(ТекущийЭлемент) = Тип("ПолеФормы") И ТекущийЭлемент.ПутьКДанным <> "Объект.ПодтвержденСкладом") Или (ТипЗнч(ТекущийЭлемент) = Тип("ТаблицаФормы"))  Тогда
				ТекущийЭлемент.Доступность = Ложь;   
			КонецЕсли;	
		КонецЦикла; 
		ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.ГруппаИнформация;
	КонецЕсли;
	//--
КонецПроцедуры

Функция РольДоступнаПодтверждениеСкладом()
	Возврат АльтерраОбщегоНазначения._РольДоступна("ПодтверждениеСкладом") ИЛИ АльтерраОбщегоНазначения._РольДоступна("ПолныеПрава");
КонецФункции

	