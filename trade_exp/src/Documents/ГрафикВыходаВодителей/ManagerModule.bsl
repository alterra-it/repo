#Область Печать

Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.ГрафикВыходаВодителей";
	КомандаПечати.Идентификатор = "ГрафикВыходаВодителей";
	КомандаПечати.Представление = НСтр("ru = 'График выхода водителей'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Ложь;
	КомандаПечати.СразуНаПринтер = Ложь;
	КомандаПечати.Порядок = 1; 
	
КонецПроцедуры
	
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ТабДок = Новый ТабличныйДокумент;
	Для Каждого Ссылка Из МассивОбъектов Цикл
		СформироватьПечатнуюФорму(Ссылка, ТабДок);
	КонецЦикла;
	УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"ГрафикВыходаВодителей", НСтр("ru = 'График выхода водителей'"), ТабДок);

КонецПроцедуры
	
Процедура СформироватьПечатнуюФорму(Ссылка, ТабДок)
	
	Макет = ПолучитьМакет("ГрафикВыходаВодителей");
	КолДнейВМес = День(КонецМесяца(Ссылка.ПериодРегистрации));
	ГраницаДляОстальных = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 1);
	ГраницаДляПоследней = Новый Линия(ТипЛинииЯчейкиТабличногоДокумента.Сплошная, 2);
	
	ОбластьЗаголовокОсн = Макет.ПолучитьОбласть("Заголовок|Осн");
	ОбластьЗаголовокДень = Макет.ПолучитьОбласть("Заголовок|День");
	ОбластьЗаголовокИтогВертикальный = Макет.ПолучитьОбласть("Заголовок|ИтогВертикальный");
	
	ОбластьШапкаОсн = Макет.ПолучитьОбласть("Шапка|Осн");
	ОбластьШапкаДень = Макет.ПолучитьОбласть("Шапка|День");
	ОбластьШапкаИтогВертикальный = Макет.ПолучитьОбласть("Шапка|ИтогВертикальный");
	
	ОбластьСтрокаОсн = Макет.ПолучитьОбласть("Строка|Осн");
	ОбластьСтрокаДень = Макет.ПолучитьОбласть("Строка|День");
	ОбластьСтрокаИтогВертикальный = Макет.ПолучитьОбласть("Строка|ИтогВертикальный");
	
	ПоГрузоподъемностиОсн = Макет.ПолучитьОбласть("ПоГрузоподъемности|Осн");
	ПоГрузоподъемностиДень = Макет.ПолучитьОбласть("ПоГрузоподъемности|День");
	ПоГрузоподъемностиИтогВертикальный = Макет.ПолучитьОбласть("ПоГрузоподъемности|ИтогВертикальный");
	
	ОбластьЛинияОсн = Макет.ПолучитьОбласть("Линия|Осн");
	ОбластьЛинияДень = Макет.ПолучитьОбласть("Линия|День");
	ОбластьЛинияИтогВертикальный = Макет.ПолучитьОбласть("Линия|ИтогВертикальный");
	
	ОбластьПодвалОсн = Макет.ПолучитьОбласть("Подвал|Осн");
	ОбластьПодвалДень = Макет.ПолучитьОбласть("Подвал|День");
	ОбластьПодвалИтогВертикальный = Макет.ПолучитьОбласть("Подвал|ИтогВертикальный");
	
	РасшифровкаОсн = Макет.ПолучитьОбласть("Расшифровка|Осн");
	РасшифровкаДень = Макет.ПолучитьОбласть("Расшифровка|День");
	РасшифровкаИтогВертикальный = Макет.ПолучитьОбласть("Расшифровка|ИтогВертикальный");
	
	ВодителиСогласованоОсн = Макет.ПолучитьОбласть("ВодителиСогласовано|Осн");
	ВодителиСогласованоДень = Макет.ПолучитьОбласть("ВодителиСогласовано|День");
	ВодителиСогласованоИтогВертикальный = Макет.ПолучитьОбласть("ВодителиСогласовано|ИтогВертикальный");
	
	ВодителиСтрокаОсн = Макет.ПолучитьОбласть("ВодителиСтрока|Осн");
	ВодителиСтрокаДень = Макет.ПолучитьОбласть("ВодителиСтрока|День");
	ВодителиСтрокаИтогВертикальный = Макет.ПолучитьОбласть("ВодителиСтрока|ИтогВертикальный");
	
	//Заголовок
	ОбластьЗаголовокОсн.Параметры.ПериодРегистрации = Формат(Ссылка.ПериодРегистрации, "ДФ='ММММ гггг'");
	Если Ссылка.ПланФакт = Перечисления.ПланФакт.План Тогда
		ОбластьЗаголовокОсн.Параметры.ПланФакт = "Плановые показатели";
	Иначе
		ОбластьЗаголовокОсн.Параметры.ПланФакт = "Фактические данные";
	КонецЕсли;
	ТабДок.Вывести(ОбластьЗаголовокОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ОбластьЗаголовокДень);
	КонецЦикла;	
	ТабДок.Присоединить(ОбластьЗаголовокИтогВертикальный);
	
	//Шапка
	ТабДок.Вывести(ОбластьШапкаОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ОбластьШапкаДень.Параметры.День = НомерДня;
		ТабДок.Присоединить(ОбластьШапкаДень);
	КонецЦикла;
	ТабДок.Присоединить(ОбластьШапкаИтогВертикальный);
	
	//Строки
	Для Каждого стрДанные Из Ссылка.График Цикл
		Если ЗначениеЗаполнено(стрДанные.Водитель) Тогда
			ОбластьСтрокаОсн.Параметры.Водитель = стрДанные.Водитель;
			ОбластьСтрокаОсн.Параметры.Заполнить(стрДанные.Автомобиль);
			ОбластьСтрокаОсн.Параметры.Автомобиль = стрДанные.Автомобиль;	
			
			ТабДок.Вывести(ОбластьСтрокаОсн);
			
			Для НомерДня = 1 По КолДнейВМес Цикл
				ТекДата = Дата(Год(Ссылка.ПериодРегистрации),Месяц(Ссылка.ПериодРегистрации), НомерДня);
				ДеньНедели = ДеньНедели(ТекДата);
				
				ОбластьСтрокаДень.Параметры.Представление = стрДанные["Представление"+НомерДня];
				
				ТабДок.Присоединить(ОбластьСтрокаДень);
			КонецЦикла;
			ОбластьСтрокаИтогВертикальный.Параметры.Заполнить(стрДанные);
			ТабДок.Присоединить(ОбластьСтрокаИтогВертикальный);
		Иначе
			ПоГрузоподъемностиОсн.Параметры.ИтогиПоГрузоподъемности = стрДанные.Автомобиль;	
			ТабДок.Вывести(ПоГрузоподъемностиОсн);
			
			Для НомерДня = 1 По КолДнейВМес Цикл
				ПоГрузоподъемностиДень.Параметры.Представление = стрДанные["Представление"+НомерДня];
				ТабДок.Присоединить(ПоГрузоподъемностиДень);
			КонецЦикла;
			ТабДок.Присоединить(ПоГрузоподъемностиИтогВертикальный);
		КонецЕсли;
	КонецЦикла;
	
	//Линия
	ТабДок.Вывести(ОбластьЛинияОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ОбластьЛинияДень);
	КонецЦикла;
	ТабДок.Присоединить(ОбластьЛинияИтогВертикальный);
	
	//Расшифровка
	ТабДок.Вывести(РасшифровкаОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(РасшифровкаДень);
	КонецЦикла;
	ТабДок.Присоединить(РасшифровкаИтогВертикальный);
	
	//Водители
	ТабДок.Вывести(ВодителиСогласованоОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ВодителиСогласованоДень);
	КонецЦикла;
	ТабДок.Присоединить(ВодителиСогласованоИтогВертикальный);
	
	Для Каждого стрДанные Из Ссылка.График Цикл
		Если Не ЗначениеЗаполнено(стрДанные.Водитель) Тогда
			Продолжить;
		КонецЕсли;
		ВодителиСтрокаОсн.Параметры.Водитель= стрДанные.Водитель;
		ТабДок.Вывести(ВодителиСтрокаОсн);
		Для НомерДня = 1 По КолДнейВМес Цикл
			ТабДок.Присоединить(ВодителиСогласованоДень);
		КонецЦикла;
		ТабДок.Присоединить(ВодителиСогласованоИтогВертикальный);
	КонецЦикла;
	
	//Подвал
	ТабДок.Вывести(ОбластьПодвалОсн);
	Для НомерДня = 1 По КолДнейВМес Цикл
		ТабДок.Присоединить(ОбластьПодвалДень);
	КонецЦикла;
	ТабДок.Присоединить(ОбластьПодвалИтогВертикальный);
	
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ПолеСлева = 2;
	ТабДок.ПолеСправа = 2;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
		
КонецПроцедуры
	
#КонецОбласти

	
#Область Заполнение 

Процедура ЗаполнитьСтрокуДаннымиПоУмолчанию(Объект, НомСтроки) Экспорт 
	
	ТекущаяСтрока = Объект.График[НомСтроки];
	Автомобиль  = ПолучитьАвтомобиль(ТекущаяСтрока.Водитель);
	ТекущаяСтрока.Автомобиль = Автомобиль; 
	
КонецПроцедуры
	
Процедура ЗаполнитьВодителями(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Сотрудник,
	|	Сотрудники.Должность КАК Должность,
	|	Сотрудники.ФизическоеЛицо КАК Водитель,
	|	СвязьВодителейТСПартнеров.Автомобиль КАК Автомобиль,
	|	СвязьВодителейТСПартнеров.Автомобиль.ГрузоподъемностьВТоннах КАК ГрузоподъемностьВТоннах,
	|	СвязьВодителейТСПартнеров.Автомобиль.ВместимостьВКубическихМетрах КАК ВместимостьВКубическихМетрах,
	|	СвязьВодителейТСПартнеров.Автомобиль.МаксимальнаяДлинаГруза КАК МаксимальнаяДлинаГруза
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СвязьВодителейТСПартнеров КАК СвязьВодителейТСПартнеров
	|		ПО Сотрудники.ФизическоеЛицо = СвязьВодителейТСПартнеров.Водитель
	|ГДЕ
	|	Сотрудники.Должность = &Должность
	|	И Сотрудники.Уволен = ЛОЖЬ
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.Подразделение = &Подразделение
	|	И Сотрудники.ВГрафике";
	
	Запрос.УстановитьПараметр("Должность", АльтерраОбщегоНазначения.ПолучитьДолжностьВодителя() );
	Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = Объект.График.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
	КонецЦикла;  
	
КонецПроцедуры
	
Процедура ЗаполнитьПоФакту(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НАЧАЛОПЕРИОДА(ЗаданиеНаПеревозкуРейс.ВремяВыезда, ДЕНЬ) КАК Период,
	|	ЗаданиеНаПеревозкуРейс.Водитель КАК Водитель,
	|	1 КАК Выход
	|ПОМЕСТИТЬ ВТ_ВыходыВодителейФакт
	|ИЗ
	|	Документ.ЗаданиеНаПеревозкуРейс КАК ЗаданиеНаПеревозкуРейс
	|ГДЕ
	|	ЗаданиеНаПеревозкуРейс.ВремяВыезда МЕЖДУ &Дата1 И &Дата2
	|	И ЗаданиеНаПеревозкуРейс.Подразделение = &Подразделение
	|	И НЕ ЗаданиеНаПеревозкуРейс.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГрафикВыходаВодителейОбороты.Период КАК Период,
	|	ГрафикВыходаВодителейОбороты.Водитель КАК Водитель,
	|	ГрафикВыходаВодителейОбороты.ПлановыйВыходОборот КАК ПлановыйВыход,
	|	ГрафикВыходаВодителейОбороты.ВнеплановыйВыходОборот КАК ВнеплановыйВыход,
	|	ГрафикВыходаВодителейОбороты.ВыходнойОборот КАК Выходной,
	|	ГрафикВыходаВодителейОбороты.НеВыходОборот КАК НеВыход
	|ПОМЕСТИТЬ ВТ_ПланВыходов
	|ИЗ
	|	РегистрНакопления.ГрафикВыходаВодителей.Обороты(
	|			&Дата1,
	|			&Дата2,
	|			День,
	|			ПланФакт = &ПланФакт
	|				И Подразделение = &Подразделение) КАК ГрафикВыходаВодителейОбороты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_ПланВыходов.Период, ВТ_ВыходыВодителейФакт.Период) КАК Период,
	|	ЕСТЬNULL(ВТ_ПланВыходов.Водитель, ВТ_ВыходыВодителейФакт.Водитель) КАК Водитель,
	|	ЕСТЬNULL(ВТ_ВыходыВодителейФакт.Выход, 0) КАК ФактическийВыход,
	|	ЕСТЬNULL(ВТ_ПланВыходов.ПлановыйВыход, 0) КАК ПлановыйВыход,
	|	ЕСТЬNULL(ВТ_ПланВыходов.ВнеплановыйВыход, 0) КАК ВнеплановыйВыход,
	|	ЕСТЬNULL(ВТ_ПланВыходов.Выходной, 0) КАК Выходной,
	|	ЕСТЬNULL(ВТ_ПланВыходов.НеВыход, 0) КАК НеВыход
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	ВТ_ПланВыходов КАК ВТ_ПланВыходов
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ВыходыВодителейФакт КАК ВТ_ВыходыВодителейФакт
	|		ПО (ВТ_ВыходыВодителейФакт.Водитель = ВТ_ПланВыходов.Водитель)
	|			И (ВТ_ВыходыВодителейФакт.Период = ВТ_ПланВыходов.Период)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Период КАК Период,
	|	ВТ.Водитель КАК Водитель,
	|	ВТ.ФактическийВыход КАК ФактическийВыход,
	|	ВТ.ПлановыйВыход КАК ПлановыйВыход,
	|	ВТ.ВнеплановыйВыход КАК ВнеплановыйВыход,
	|	ВТ.Выходной КАК Выходной,
	|	ВТ.НеВыход КАК НеВыход,
	|	ВЫБОР
	|		КОГДА ВТ.ФактическийВыход = 1
	|			ТОГДА ВЫБОР
	|					КОГДА ВТ.ПлановыйВыход = 1
	|						ТОГДА ""1""
	|					ИНАЧЕ ""в1""
	|				КОНЕЦ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА ВТ.ПлановыйВыход = 1
	|						ИЛИ ВТ.ВнеплановыйВыход = 1
	|					ТОГДА ""н""
	|				ИНАЧЕ ""в""
	|			КОНЕЦ
	|	КОНЕЦ КАК стрВыход
	|ИЗ
	|	ВТ КАК ВТ";
	
	Запрос.УстановитьПараметр("Дата1", НачалоМесяца(Объект.ПериодРегистрации));
	Запрос.УстановитьПараметр("Дата2", КонецМесяца(Объект.ПериодРегистрации));
	Запрос.УстановитьПараметр("ПланФакт", Перечисления.ПланФакт.План);
	Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение);
	Запрос.УстановитьПараметр("СтатусГотов", Перечисления.СтатусыВодителей.Готов);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		День = День(Выборка.Период);
		
		НайденыеСтроки = Объект.График.НайтиСтроки(Новый Структура("Водитель", Выборка.Водитель));
		Если НайденыеСтроки.Количество() = 0 Тогда
			НоваяСтрока = Объект.График.Добавить();
			НоваяСтрока.Водитель = Выборка.Водитель;
		Иначе
			НоваяСтрока = НайденыеСтроки[0];
		КонецЕсли;
			
		НоваяСтрока["Представление" + День] = Выборка.стрВыход;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти


#Область Вспомогательные

Функция ПолучитьАвтомобиль(Водитель) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СвязьВодителейТСПартнеров.Автомобиль КАК Автомобиль
	|ИЗ
	|	РегистрСведений.СвязьВодителейТСПартнеров КАК СвязьВодителейТСПартнеров
	|ГДЕ
	|	СвязьВодителейТСПартнеров.Водитель = &Водитель";
	
	Запрос.УстановитьПараметр("Водитель", Водитель);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат  ВыборкаДетальныеЗаписи.Автомобиль;
	Иначе
		Возврат Справочники.ТранспортныеСредства.ПустаяСсылка();
	КонецЕсли; 
	
КонецФункции

