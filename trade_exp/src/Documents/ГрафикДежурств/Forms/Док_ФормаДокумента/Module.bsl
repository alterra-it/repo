	         |	И УчетРабочегоВремениСотрудников.Период МЕЖДУ &нПериода И &кПериода
	         |
	         |СГРУППИРОВАТЬ ПО
	         |	УчетРабочегоВремениСотрудников.Сотрудник,
	         |	УчетРабочегоВремениСотрудников.Подразделение,
	         |	НАЧАЛОПЕРИОДА(УчетРабочегоВремениСотрудников.Период, ДЕНЬ)
	         |;
	         |
	         |////////////////////////////////////////////////////////////////////////////////
	         |ВЫБРАТЬ
	         |	ВТ_ТаблицаДат.Период КАК Дата,
	         |	ВременнаяТаблица.Сотрудник КАК Сотрудник,
	         |	ВременнаяТаблица.Подразделение КАК Подразделение,
	         |	МАКСИМУМ(ВЫБОР
	         |			КОГДА ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
	         |				ТОГДА ВременнаяТаблица.ДатаНачалаРаботы
	         |		КОНЕЦ) КАК ДатаНачалаРаботы,
	         |	МАКСИМУМ(ВЫБОР
	         |			КОГДА ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
	         |				ТОГДА ВременнаяТаблица.ДатаОкончанияРаботы
	         |		КОНЕЦ) КАК ДатаОкончанияРаботы,
	         |	МАКСИМУМ(ВЫБОР
	         |			КОГДА ВТ_ТаблицаДат.Период = ВременнаяТаблица.Период
	         |				ТОГДА ВЫБОР
	         |						КОГДА ВременнаяТаблица.ДатаНачалаРаботы ЕСТЬ NULL
	         |								ИЛИ ВременнаяТаблица.ДатаОкончанияРаботы ЕСТЬ NULL
	         |							ТОГДА 0
	         |						ИНАЧЕ ВЫРАЗИТЬ((РАЗНОСТЬДАТ(ВременнаяТаблица.ДатаНачалаРаботы, ВременнаяТаблица.ДатаОкончанияРаботы, МИНУТА) - 60) / 60 - 0.49 КАК ЧИСЛО(10, 0))
	         |					КОНЕЦ
	         |			ИНАЧЕ 0
	         |		КОНЕЦ) КАК Часы
	         |ИЗ
	         |	ВременнаяТаблица КАК ВременнаяТаблица,
	         |	ВТ_ТаблицаДат КАК ВТ_ТаблицаДат
	         |ГДЕ
	         |	ВТ_ТаблицаДат.Период >= ВременнаяТаблица.Сотрудник.ДатаПриема
	         |
	         |СГРУППИРОВАТЬ ПО
	         |	ВТ_ТаблицаДат.Период,
	         |	ВременнаяТаблица.Сотрудник,
	         |	ВременнаяТаблица.Подразделение";

	лЗапрос = Новый Запрос(лТекст);
	лЗапрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;

	лЗапрос.УстановитьПараметр("кПериода", ДатаОкончанияРасчета);
	лЗапрос.УстановитьПараметр("нПериода", НачалоМесяцаРегистрации);
	лЗапрос.УстановитьПараметр("Сотрудник", СписокСотрудников);

	Возврат лЗапрос.Выполнить().Выбрать();
	
КонецФункции

&НаСервере
Функция ПолучитьНормуЧасовНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст =      
	"ВЫБРАТЬ
	| СУММА(ВЫБОР
	| КОГДА ДанныеПроизводственногоКалендаря.ВидДня = ЗНАЧЕНИЕ(Перечисление.ВидыДнейПроизводственногоКалендаря.Рабочий)
	| ТОГДА 8
	| КОГДА ДанныеПроизводственногоКалендаря.ВидДня = ЗНАЧЕНИЕ(Перечисление.ВидыДнейПроизводственногоКалендаря.Предпраздничный)
	| ТОГДА 7
	| ИНАЧЕ 0
	| КОНЕЦ) КАК Часов
	| ИЗ
	| РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	| ГДЕ
	| ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	
	Запрос.Параметры.Вставить("ДатаНачала",НачалоМесяца(Объект.Месяц));   
	Запрос.Параметры.Вставить("ДатаОкончания",КонецМесяца(Объект.Месяц));  
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Часов;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции	

&НаКлиенте
Процедура ДанныеОВремениПланОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка) 

	ТекущиеЧасы = УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(Текст);   
	ДанныеТекущейСтроки = ЭтаФорма.Элементы.ДанныеОВремени.ТекущиеДанные;
	Если ТекущиеЧасы <> Неопределено Тогда  
		Если ТекущиеЧасы.Часы > 14 Тогда
			Сообщить("Ограничение по вводу количества часов: не более 14!"); 
			Текст = "14";
		КонецЕсли;
	ДанныеТекущейСтроки[СтрЗаменить(Элемент.Имя,"ДанныеОВремени","")] = Текст;
	КонецЕсли;
	
	ДанныеОВремени = Объект.ДанныеОВремени[ДанныеТекущейСтроки.НомерСтроки-1];
	КолЧасов = 0;
	Для сч = 1 По 31 Цикл  
		Если ЗначениеЗаполнено(ДанныеОВремени["План" + сч]) Тогда
			Часов= УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(ДанныеОВремени["План" + сч]).Часы;
			КолЧасов=КолЧасов+Часов;   
		КонецЕсли;	
	КонецЦикла;
	ДанныеОВремени.ИтогоЧасовПлан = Строка(КолЧасов);  
	Если КолЧасов > НормаЧасов Тогда  
		Сообщить(СтрШаблон("По сотруднику превышена норма на %1ч.!",Строка(КолЧасов-НормаЧасов)));
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ПроверитьГрафик(Команда)
	
	ОчиститьСообщения();
	
	//проверить дни для логистов 
	СтрокаОшибокПоКоличеству = ""; 
	МассивФилиалов = Новый Массив;
	Для Сч = 1 По КолДнейВМес Цикл 
		МассивФилиалов.Очистить();
		КоличествоСотрудников = 0;    
		// проверить не менее 2-х дежурных по филиалам
		Для Каждого СтрокаДанныхОВремени Из Объект.ДанныеОВремени Цикл
			Если ЗначениеЗаполнено(СтрокаДанныхОВремени["План"+сч]) Тогда
				Если УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(СтрокаДанныхОВремени["План"+сч]).Часы > 0 
					И ( СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"а") > 0 
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"б") > 0
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"с") > 0
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"д") > 0 
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"м") > 0	)  Тогда   
					КоличествоСотрудников = КоличествоСотрудников + 1;	
				КонецЕсли;	
			КонецЕсли;
			
			СтрокаПримечания = СтрокаДанныхОВремени["Примечание"+сч];
			Для Сч1 = 1 По СтрДлина(СтрокаПримечания) Цикл   
				ТекущийСимвол = Сред(НРег(СтрокаДанныхОВремени["Примечание"+сч]),Сч1,1); 
				Если ТекущийСимвол = "а" Тогда  
					МассивФилиалов.Добавить("а"); 
				ИначеЕсли ТекущийСимвол = "б" Тогда 
					МассивФилиалов.Добавить("б");
				ИначеЕсли ТекущийСимвол = "с" Тогда   
					МассивФилиалов.Добавить("с");
				ИначеЕсли ТекущийСимвол = "д" Тогда  
					МассивФилиалов.Добавить("д"); 
				ИначеЕсли ТекущийСимвол = "м" Тогда  
					МассивФилиалов.Добавить("м");
				КонецЕсли;	
			КонецЦикла;	
		КонецЦикла;  
		
		// проверить дежурных на всех филиалах
		ДежурныхФилиал1 = 0;  
		ДежурныхФилиал2 = 0;
		ДежурныхФилиал3 = 0;
		ДежурныхФилиал4 = 0;
		ДежурныхФилиал5 = 0;
		Для Каждого ЭлементМассива Из МассивФилиалов Цикл   
			Если ЭлементМассива = "а" Тогда  
				ДежурныхФилиал1 = ДежурныхФилиал1 + 1;
			КонецЕсли;
			Если ЭлементМассива = "б" Тогда  
				ДежурныхФилиал2 = ДежурныхФилиал2 + 1;
			КонецЕсли;
			Если ЭлементМассива = "с" Тогда  
				ДежурныхФилиал3 = ДежурныхФилиал3 + 1;
			КонецЕсли;
			Если ЭлементМассива = "д" Тогда  
				ДежурныхФилиал4 = ДежурныхФилиал4 + 1;
			КонецЕсли;
			Если ЭлементМассива = "м" Тогда  
				ДежурныхФилиал5 = ДежурныхФилиал5 + 1;
			КонецЕсли;
		КонецЦикла;      
		СтрокаСообщения = "по филиалу";
		Если ДежурныхФилиал1 <> 1 Тогда  
			СтрокаСообщения = СтрокаСообщения + "  Центральная база(а) дежурных - " + Строка(ДежурныхФилиал1);	
		КонецЕсли;	
		Если ДежурныхФилиал2 <> 1 Тогда  
			СтрокаСообщения = СтрокаСообщения + "  Выбор(б) дежурных - " + Строка(ДежурныхФилиал2);	
		КонецЕсли;	
		Если ДежурныхФилиал3 <> 1 Тогда  
			СтрокаСообщения = СтрокаСообщения + "  Барнаул(с) дежурных - " + Строка(ДежурныхФилиал3);	
		КонецЕсли;	
		Если ДежурныхФилиал4 <> 1 Тогда  
			СтрокаСообщения = СтрокаСообщения + "  Бийск(д) дежурных - " + Строка(ДежурныхФилиал4);	
		КонецЕсли;
		Если ДежурныхФилиал5 <> 1 Тогда  
			СтрокаСообщения = СтрокаСообщения + "  Майма(м) дежурных - " + Строка(ДежурныхФилиал5);	
		КонецЕсли;
		Если СтрокаСообщения <> "по филиалу" Тогда
			Сообщить(СтрШаблон("%1-го числа %2",сч,СтрокаСообщения));
		КонецЕсли;	
			
		Если КоличествоСотрудников < 2 Тогда  
			СтрокаОшибокПоКоличеству = СтрокаОшибокПоКоличеству+" "+сч;
		КонецЕсли;
	КонецЦикла;	
	Если СтрокаОшибокПоКоличеству <> "" Тогда
		Сообщить(СтрШаблон("Работает меньше 2 дежурных - %1",СтрокаОшибокПоКоличеству)); 
	КонецЕсли; 
	
КонецПроцедуры

