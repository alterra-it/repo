
&НаКлиенте
Процедура МесяцНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если Объект.ДанныеОВремени.Количество() > 0 Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса",
	      ЭтотОбъект);	
	 
	    ПоказатьВопрос(Оповещение,
	        "При смене месяца произойдет очистка данных по сотрудникам!!! Продолжить?",
	        РежимДиалогаВопрос.ДаНет,
	        0, 
	        КодВозвратаДиалога.Да, 
	        "Внимание" ); 
	Иначе   
		ВыбратьМесяц();	
	КонецЕсли;	
	
КонецПроцедуры   

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
 
	Если Результат = КодВозвратаДиалога.Да Тогда  
		ЗаполнитьСотрудниковПоОтделуНаСервере();	
    	ВыбратьМесяц();
	КонецЕсли;	
 
КонецПроцедуры   

&НаКлиенте
Процедура ВыбратьМесяц()   
	
	Объект.ПериодРегистрации = НачалоМесяца(Объект.Месяц);
	
	ОповещениеЗавершения = Новый ОписаниеОповещения("ПериодРегистрацииНачалоВыбораЗавершение", ЭтаФорма);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Форма", ЭтаФорма);
	ДополнительныеПараметры.Вставить("РедактируемыйОбъект", ЭтаФорма);
	ДополнительныеПараметры.Вставить("ПутьРеквизита", "Объект.Месяц");
	ДополнительныеПараметры.Вставить("ПутьРеквизитаПредставления", "МесяцРегистрацииСтрокой");
	ДополнительныеПараметры.Вставить("ИзменитьМодифицированность", Истина);
	ДополнительныеПараметры.Вставить("ОповещениеЗавершения", ОповещениеЗавершения);
	
	Значение = ОбщегоНазначенияКлиентСервер.ПолучитьРеквизитФормыПоПути(ЭтаФорма, "Объект.Месяц");
	
	ОткрытьФорму("ОбщаяФорма.ВыборПериода", 
	Новый Структура("Значение,РежимВыбораПериода,ЗапрашиватьРежимВыбораПериодаУВладельца", Значение, "Месяц", Ложь),
	ЭтаФорма, , , ,ОповещениеЗавершения , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры	

&НаКлиенте
Процедура ПериодРегистрацииНачалоВыбораЗавершение(ЗначениеВыбрано, ДополнительныеПараметры) Экспорт
	
	Объект.Месяц = ЗначениеВыбрано;
	МесяцРегистрацииСтрокой = УчетРабочегоВремениКлиент.ПолучитьПредставлениеМесяца(Объект.Месяц);
	КолДнейВМес = День(КонецМесяца(Объект.Месяц));
	ПриОткрытии(Ложь);  
	НормаЧасов = ПолучитьНормуЧасовНаСервере(); 
	
	//Скроем не нужные
	Для сч = 1 По 31 Цикл
		Элемент = ЭтаФорма.Элементы["ДанныеОВремениПредставление" + сч];	
		Элемент2 = ЭтаФорма.Элементы["ДанныеОВремениПримечание" + сч];
		Элемент3 = ЭтаФорма.Элементы["ДанныеОВремениПлан" + сч];   
		Если КолДнейВМес >= сч Тогда
			Элемент.Видимость= Истина;
			Элемент2.Видимость = Истина; 
			Элемент3.Видимость = Истина;   
		Иначе  
			Элемент.Видимость = Ложь;
			Элемент2.Видимость = Ложь; 
			Элемент3.Видимость = Ложь;
		КонецЕсли;	
	КонецЦикла;   
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Для сч = 1 По КолДнейВМес Цикл
		Элемент = ЭтаФорма.Элементы["ДанныеОВремениПредставление"+сч];  
		Элемент2 = ЭтаФорма.Элементы["ДанныеОВремениПримечание"+сч];
		Элемент3 = ЭтаФорма.Элементы["ДанныеОВремениПлан"+сч];
		ДанныеВыбора = УчетРабочегоВремениСервер.ПолучитьСписокВидовВремениСтруктурой("");
		Элемент.Заголовок = Строка(сч);
		Для Каждого ВидВремени Из ДанныеВыбора Цикл
			Элемент.СписокВыбора.Добавить(ВидВремени.Значение, ВидВремени.Представление);
		КонецЦикла;
		Элемент.КнопкаСпискаВыбора = Истина;
		
		ТекДата = Дата(Год(Объект.Месяц),Месяц(Объект.Месяц), сч);
		ВидДня = УчетРабочегоВремениСервер.ПолучитьВидДня(ТекДата);
		
		Если ВидДня = Неопределено Тогда  
			ЦветВидДня = Новый Цвет(100, 100, 100); 
			Элемент.ЦветФонаЗаголовка = ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня;  
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Рабочий") Тогда 
			ЦветВидДня = Новый Цвет(0, 0, 0);
			Элемент.ЦветТекстаЗаголовка = ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня;
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Суббота") Тогда
			ЦветВидДня = Новый Цвет(0, 0, 255);
			Элемент.ЦветТекстаЗаголовка = ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня; 
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Воскресенье") Тогда 
			ЦветВидДня = Новый Цвет(255, 0, 0);
			Элемент.ЦветТекстаЗаголовка = ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня;	
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Праздник") Тогда   
			ЦветВидДня = Новый Цвет(255, 0, 255);
			Элемент.ЦветТекстаЗаголовка= ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня;  
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Предпраздничный") Тогда  
			ЦветВидДня = Новый Цвет(0, 0, 128);
			Элемент.ЦветТекстаЗаголовка = ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня;  
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		ИначеЕсли ВидДня = ПредопределенноеЗначение("Перечисление.ВидыДнейПроизводственногоКалендаря.Нерабочий") Тогда 
			ЦветВидДня = Новый Цвет(255, 0, 0);
			Элемент.ЦветТекстаЗаголовка = ЦветВидДня;
			Элемент.ЦветТекста = ЦветВидДня;
			Элемент2.ЦветТекста = ЦветВидДня;
			Элемент3.ЦветТекста = ЦветВидДня;
		КонецЕсли;
				
	КонецЦикла;
	//Скроем не нужные
	Для сч = КолДнейВМес + 1 По 31 Цикл
		Элемент= ЭтаФорма.Элементы["ДанныеОВремениПредставление" + сч];	
		Элемент2= ЭтаФорма.Элементы["ДанныеОВремениПримечание" + сч];
		Элемент3= ЭтаФорма.Элементы["ДанныеОВремениПлан" + сч];
		Элемент.Видимость = Ложь;
		Элемент2.Видимость = Ложь; 
		Элемент3.Видимость = Ложь;
	КонецЦикла;
    НормаЧасов = ПолучитьНормуЧасовНаСервере(); 
	Элементы.ЛогистыПримечание.Видимость = ВидимостьПримечания();    
	ЗаполнитьПодвал(1, КолДнейВМес); 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСотрудниковПоОтделуНаСервере()

	Объект.ДанныеОВремени.Очистить();
	
	мСотрудников = УчетРабочегоВремениСервер.ПолучитьРаботающихСотрудников(Объект.Отдел, Объект.Месяц);
	Для Каждого ТекущийСотрудник Из мСотрудников Цикл
			НоваяСтрока= Объект.ДанныеОВремени.Добавить();
			НоваяСтрока.Сотрудник= ТекущийСотрудник.Сотрудник;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСотрудниковПоОтделу(Команда)
	ЗаполнитьСотрудниковПоОтделуНаСервере();
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Объект.ПериодРегистрации) Тогда  
		Если ЗначениеЗаполнено(Объект.Месяц) Тогда
			Объект.ПериодРегистрации = НачалоМесяца(Объект.Месяц); 
		Иначе 
			Объект.ПериодРегистрации = НачалоМесяца(Объект.Дата);
		КонецЕсли;	
	КонецЕсли;
		
	СписокВидовВремени = УчетРабочегоВремениСервер.ПолучитьСписокВидовВремениБуквенныйКод();
	Если Не ЗначениеЗаполнено(Объект.Месяц) Тогда
		Объект.Месяц = НачалоМесяца(ТекущаяДата());
	КонецЕсли;
	
	МесяцРегистрацииСтрокой = УчетРабочегоВремениСервер.ПолучитьПредставлениеМесяца(Объект.Месяц);
	КолДнейВМес = День(КонецМесяца(Объект.Месяц));

КонецПроцедуры

&НаКлиенте
Процедура ДанныеОВремениВремяПредставлениеОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	ДанныеОВремени= УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(Текст);
	Если ДанныеОВремени <> Неопределено Тогда
		Если ДанныеОВремени.Часы <= 14 Тогда
			УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, ДанныеОВремени.ВидВремени, ДанныеОВремени.Часы, ДанныеОВремени.БуквенноеОбозначение);
		Иначе
			Сообщить("Ограничение по вводу количества часов: не более 14!");
		    УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, Неопределено, Неопределено, Неопределено);
		КонецЕсли;
	Иначе
		УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, Неопределено, Неопределено, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ДанныеОВремениВремяПредставлениеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ДанныеВыбора = УчетРабочегоВремениСервер.ПолучитьСписокВидовВремениСтруктурой("");
КонецПроцедуры

&НаКлиенте
Процедура ДанныеОВремениВремяПредставлениеОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	УчетРабочегоВремениКлиент.ЗаполнитьДанныеОВремени(Объект, ЭтаФорма, Элемент.Имя, ВыбранноеЗначение.ВидВремени, 0, ВыбранноеЗначение.БуквенноеОбозначение);

КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВремяПоФакту(Команда)
	
	Если Не ШапкаЗаполнена() Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ДанныеОВремени.Количество() > 0 Тогда
		ЗаполнитьВремяПоДанным1СНаСервере(Истина, Ложь);
	КонецЕсли;
	
	ОчиститьСообщения();
	// проверить факт/план
	Для Каждого СтрокаДанныхОВремени Из Объект.ДанныеОВремени Цикл  
		СтрокаОшибокПоДням = "";
		Для Сч = 1 По КолДнейВМес Цикл   
			Если ЗначениеЗаполнено(СтрокаДанныхОВремени["План" + сч]) Тогда
				ЧасовПлан = УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(СтрокаДанныхОВремени["План" + сч]).Часы;
			Иначе   
				ЧасовПлан = 0;
			КонецЕсли;	
			Если ЧасовПлан <> СтрокаДанныхОВремени["Часов" + сч] Тогда  
				СтрокаОшибокПоДням = СтрокаОшибокПоДням + " " + сч;
			КонецЕсли;
		КонецЦикла;	 
		Если СтрокаОшибокПоДням <> "" Тогда
			Сообщить(СтрШаблон("По сотруднику - %1 расхождения факт/план в датах%2", СтрокаДанныхОВремени.Сотрудник, СтрокаОшибокПоДням)); 
		КонецЕсли;   
	КонецЦикла;	 

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВремяПоДанным1СНаСервере(НаТекущуюДату = Ложь, ПоГрафику = Ложь)
	
	ДатаОкончанияРасчета = "";
	
	ТекущаяДатаРасчета = ТекущаяДата();
	НачалоМесяцаРегистрации = НачалоМесяца(Объект.Месяц);
	ОкончаниеМесяцаРегистрации = КонецМесяца(Объект.Месяц);
	
	Если НаТекущуюДату Тогда
		Если (ТекущаяДатаРасчета >= ОкончаниеМесяцаРегистрации) ИЛИ (ТекущаяДатаРасчета < НачалоМесяцаРегистрации) Тогда
			ДатаОкончанияРасчета = ОкончаниеМесяцаРегистрации;
		Иначе
			ДатаОкончанияРасчета = КонецДня(ТекущаяДатаРасчета - 86400);
		КонецЕсли;
	Иначе
		ДатаОкончанияРасчета = ОкончаниеМесяцаРегистрации;	
	КонецЕсли;
	
	Если Объект.ДанныеОВремени.Количество() > 0 Тогда
		СтрокиПоСотрудникам = Новый Соответствие;
		СотрудникиДокумента = Новый Массив;
		
		Для Каждого СтрокаДанныхОВремени Из Объект.ДанныеОВремени Цикл
			МассивСтрокПоСотруднику = Объект.ДанныеОВремени.НайтиСтроки(Новый Структура("Сотрудник",СтрокаДанныхОВремени.Сотрудник));
			СотрудникиДокумента.Добавить(СтрокаДанныхОВремени.Сотрудник);
			СтрокиПоСотрудникам.Вставить(СтрокаДанныхОВремени.Сотрудник, МассивСтрокПоСотруднику);				
		КонецЦикла;	
		ВысотаСтроки = 1;      
		
		УчетРабочегоВремениСервер.ТабельЗаполнитьДанныеПоСотрудникам(Объект,СотрудникиДокумента,СтрокиПоСотрудникам,ДатаОкончанияРасчета,Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ШапкаЗаполнена()
	
	РезультатПроверки = Истина;
	Если Не ЗначениеЗаполнено(МесяцРегистрацииСтрокой) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен Месяц!");
		РезультатПроверки = Ложь;
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Отдел) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнены Отдел!",,"Отдел", "Объект");		
		РезультатПроверки = Ложь;
	КонецЕсли;
	
	Возврат РезультатПроверки; 
	
КонецФункции 

