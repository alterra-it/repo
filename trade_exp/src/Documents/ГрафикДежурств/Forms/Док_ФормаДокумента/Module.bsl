Процедура ВставитьСтроки(Команда)
	
	Если ЗначениеЗаполнено(Объект.Месяц) Тогда
		КоличествоДоВставки = Объект.ДанныеОВремени.Количество();
		
		ПолучитьСтрокиИзБуфераОбмена();
		
		КоличествоВставленных = Объект.ДанныеОВремени.Количество()-КоличествоДоВставки;
		КопированиеСтрокКлиент.ОповеститьПользователяОВставкеСтрок(КоличествоВставленных); 
	Иначе   
		Сообщить("Необходимо выбрать месяц!!!");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьСтрокиИзБуфераОбмена()
	
	КолДнейВМес = День(КонецМесяца(Объект.Месяц));
	
	ТаблицаДанныхОВремени = КопированиеСтрокСервер.ПолучитьСтрокиИзБуфераОбмена();
	
	Для Каждого Строка Из ТаблицаДанныхОВремени Цикл
		ТекущаяСтрока = Объект.ДанныеОВремени.Добавить();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, Строка); 
		Если КолДнейВМес < 31 Тогда
			КолЧасов = 0;
			Для Н = 1 По 31 Цикл  
				Если Н > КолДнейВМес Тогда
					ТекущаяСтрока["План" + Н] = ""; 
					ТекущаяСтрока["Представление" + Н] = "";
					ТекущаяСтрока["Примечание" + Н] = "";   
				Иначе      
					Попытка
						Часов = Число(ТекущаяСтрока["План" + Н]); 
					Исключение  
						Часов = 0;
					КонецПопытки;	
					КолЧасов = КолЧасов + Часов;  	
				КонецЕсли;	
			КонецЦикла;
			ТекущаяСтрока.ИтогоЧасовПлан = КолЧасов;
		КонецЕсли;	
	КонецЦикла; 
	
КонецПроцедуры

Процедура ПоместитьВыделенныеСтрокиВБуферОбмена(ВыделенныеСтроки, ТабЧасть) 
	
	ТаблицаБуфераОбмена = ИнициализироватьТаблицуБуфераОбмена();
	
	ВыделенныеСтрокиТЧ = Новый Массив;
	Если ВыделенныеСтроки <> Неопределено Тогда
		
		Для Каждого ТекСтрока Из ВыделенныеСтроки Цикл
			СтрокаТаблицы = ТабЧасть.НайтиПоИдентификатору(ТекСтрока);
			ВыделенныеСтрокиТЧ.Добавить(СтрокаТаблицы);
		КонецЦикла;
		
		НаборыВызовСервера.ДополнитьДоПолногоНабора(ТабЧасть, ВыделенныеСтрокиТЧ);
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВыделенныеСтрокиТЧ) Тогда
		Для каждого СтрокаТаблицы Из ВыделенныеСтрокиТЧ Цикл
			
			НоваяСтрока = ТаблицаБуфераОбмена.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			
		КонецЦикла;
	Иначе
		Для каждого СтрокаТаблицы Из ТабЧасть Цикл
			
			НоваяСтрока = ТаблицаБуфераОбмена.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
			
		КонецЦикла;
	КонецЕсли;
	
	СкопироватьТаблицуВБуферОбмена(ТаблицаБуфераОбмена, "Строки");
	
КонецПроцедуры         

Процедура СкопироватьТаблицуВБуферОбмена(Таблица, Источник = Неопределено)
	
	ТекущийБуферОбмена = ПараметрыСеанса.БуферОбмена;
	
	Если ЗначениеЗаполнено(ТекущийБуферОбмена.Данные) Тогда
		Адрес = ТекущийБуферОбмена.Данные;
	Иначе
		Адрес = Новый УникальныйИдентификатор;
	КонецЕсли;
	
	ДанныеВХранилище = ПоместитьВоВременноеХранилище(Таблица, Адрес);
	
	СтруктураБуфераОбмена = Новый Структура;
	СтруктураБуфераОбмена.Вставить("Источник", Источник);
	СтруктураБуфераОбмена.Вставить("Данные", ДанныеВХранилище);
	
	ПараметрыСеанса.БуферОбмена = Новый ФиксированнаяСтруктура(СтруктураБуфераОбмена);
	
КонецПроцедуры

Функция ИнициализироватьТаблицуБуфераОбмена()
	
	ТаблицаСтрок = Новый ТаблицаЗначений();
	ТаблицаСтрок.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаСтрок.Колонки.Добавить("ИтогоЧасовПлан", Новый ОписаниеТипов("Число"));
    ТаблицаСтрок.Колонки.Добавить("ИтогоЧасов", Новый ОписаниеТипов("Число"));
	Для Инд=1 по 31 Цикл
		ТаблицаСтрок.Колонки.Добавить("Часов"+Строка(Инд), Новый ОписаниеТипов("Число"));
        ТаблицаСтрок.Колонки.Добавить("ВидВремени"+Строка(Инд), Новый ОписаниеТипов("СправочникСсылка.ВидыИспользованияРабочегоВремени"));
		ТаблицаСтрок.Колонки.Добавить("Представление"+Строка(Инд), Новый ОписаниеТипов("Строка"));
        ТаблицаСтрок.Колонки.Добавить("Примечание"+Строка(Инд), Новый ОписаниеТипов("Строка,Число")); 
		ТаблицаСтрок.Колонки.Добавить("План"+Строка(Инд), Новый ОписаниеТипов("Число"));
	КонецЦикла;	
	Возврат ТаблицаСтрок;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПодвал(Первый,Последний)
	
	Для Сч = Первый По Последний Цикл  
		КоличествоСотрудников = 0;    
		Для Каждого СтрокаДанныхОВремени Из Объект.ДанныеОВремени Цикл
			Если ЗначениеЗаполнено(СтрокаДанныхОВремени["План"+сч]) Тогда
				Если УчетРабочегоВремениКлиент.ТабельРазобратьСтрокуВремени(СтрокаДанныхОВремени["План"+сч]).Часы > 0 
					И ( СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"а") > 0 
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"б") > 0
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"с") > 0
						Или СтрНайти(НРег(СтрокаДанныхОВремени["Примечание"+сч]),"д") > 0 )  Тогда   
					КоличествоСотрудников = КоличествоСотрудников + 1;	
				КонецЕсли;	
			КонецЕсли;   
		КонецЦикла;	
		Элементы["ДанныеОВремениПримечание"+сч].ТекстПодвала = Строка(КоличествоСотрудников);
	КонецЦикла;
	
КонецПроцедуры	

&НаКлиенте
Процедура ДанныеОВремениПримечаниеПриИзменении(Элемент) 
	
	Номер = Число(СтрЗаменить(Элемент.Имя,"ДанныеОВремениПримечание",""));
	ЗаполнитьПодвал(Номер,Номер); 
	
КонецПроцедуры

