&НаСервере
Процедура Док_ПередЗаписьюНаСервереПосле(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	ЧекККМ = ТекущийОбъект.ЧекККМ;
	Если Не Отказ И 
		ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И
		ЗначениеЗаполнено(ЧекККМ) Тогда
				
		ТЗТовары = ТекущийОбъект.Товары.Выгрузить( , "Номенклатура, Количество");
		ТЗТовары.Свернуть("Номенклатура", "Количество");	
		
		АльтерраОбщегоНазначения.НаличиеЗаказаНаДоставкуПриПолномВозврате(Отказ, ТЗТовары, ТекущийОбъект.Ссылка, ЧекККМ);
	КонецЕсли;
КонецПроцедуры

Функция КассаККМОтличаетсяОтОснования()
	
	ИспользоватьДопПроверку = ДопМодуль.ПолучитьНастройкиХранилища("ВключитьДопПроверкиПоКассовымСменам").ВключитьДополнительныйПроверкиПоКассовымСменам;
	
	Если Не ИспользоватьДопПроверку Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.ЧекККМ) Тогда
	     Возврат Ложь;
    КонецЕсли;
	
	КассаККМТекущегоПользователя = РозничныеПродажи.ПолучитьКассуККМТекущегоПользователя();
	
	Если Объект.ЧекККМ.КассаККМ <> КассаККМТекущегоПользователя Тогда
		Сообщить("Текущая касса не соответствует кассе документа! Необходимо перейти на кассу - " + Строка(Объект.ЧекККМ.КассаККМ));
		Возврат Истина;
	Иначе
		Возврат Ложь;
    КонецЕсли;

КонецФункции

