&Вместо("ИнформацияОбОплате")
Функция Док_ИнформацияОбОплате(Форма)
	
	// Альтерра Устинов В.А. оплата картой ЧекККМНаВозврат 27.07.2017 14:42:01
	Если Форма.Объект.ОплатаПлатежнымиКартами.Итог("Сумма") > Форма.Объект.Товары.Итог("Сумма") Тогда 
		Если Форма.Объект.ОплатаПлатежнымиКартами.Количество() = 1 Тогда
			Форма.Объект.ОплатаПлатежнымиКартами[0].Сумма= Форма.Объект.Товары.Итог("Сумма");
		КонецЕсли;	
	КонецЕсли;	
	//-
	
	Возврат ПродолжитьВызов(Форма);
	
КонецФункции




