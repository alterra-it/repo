&НаСервере
&ИзменениеИКонтроль("НастроитьРМКЛокализация")
Процедура Док_НастроитьРМКЛокализация(ДоступныеВидыОплаты, ЭлементыНаПерегруппировку)

	//++ Локализация 
	#Удаление
	Элементы.ОплатитьСБП.Видимость       = ДоступныеВидыОплаты.СБП И ОбщаяСуммаОплатыСБП > 0
	ИЛИ ДоступныеВидыОплаты.СБП И Не ЗначениеЗаполнено(Объект.ЧекККМ);
    #КонецУдаления
	#Вставка
	Элементы.ОплатитьСБП.Видимость = Ложь; 
	Элементы.ОплатитьНаличными.Видимость = Элементы.ОплатитьНаличными.Видимость И ОбщаяСуммаОплатыЭСФСС = 0 и ОбщаяСуммаОплатыСБП = 0;
	#КонецВставки
	Элементы.ОплатитьНаличными.Видимость = Элементы.ОплатитьНаличными.Видимость И ОбщаяСуммаОплатыЭСФСС = 0
	ИЛИ Элементы.ОплатитьСБП.Видимость;

	Элементы.ОплатитьКартой.Видимость    = Элементы.ОплатитьКартой.Видимость И ОбщаяСуммаОплатыЭСФСС = 0;
	Элементы.ОплатитьСБП.Видимость       = Элементы.ОплатитьСБП.Видимость И ОбщаяСуммаОплатыЭСФСС = 0; 
	#Удаление
	Элементы.СмешаннаяОплата.Видимость   = Элементы.СмешаннаяОплата.Видимость
											ИЛИ (Элементы.ОплатитьСБП.Видимость И ОбщаяСуммаОплатыЭСФСС = 0 И СуммаДокумента <> ОбщаяСуммаОплатыСБП); 
	#КонецУдаления
	#Вставка
	Элементы.СмешаннаяОплата.Видимость       = Элементы.СмешаннаяОплата.Видимость ИЛИ (ДоступныеВидыОплаты.СБП И ОбщаяСуммаОплатыСБП > 0);
	#КонецВставки
   	Элементы.ОплатитьЭСФСС.Видимость = ДоступныеВидыОплаты.ЭСФСС И ОбщаяСуммаОплатыЭСФСС > 0;
	ЭлементыНаПерегруппировку.Добавить(Элементы.ОплатитьЭСФСС);

	ЭлементыНаПерегруппировку.Добавить(Элементы.ОплатитьСБП);

	Элементы.ДекоративноеПолеГруппаСуммаКВозврату2.Видимость = Не Элементы.ОплатитьСБП.Видимость;
	Элементы.СуммаКВозвратуСБП.Видимость = Элементы.ОплатитьСБП.Видимость;
	#Вставка
	//Проверить работоспособность СБП при обновлении, заглушка типовой кнопки
	//Элементы.СмешаннаяОплата.Видимость       = ДоступныеВидыОплаты.СБП И ОбщаяСуммаОплатыСБП > 0;

	
	Элементы.СуммаКВозвратуСБП.Видимость = ДоступныеВидыОплаты.СБП И ОбщаяСуммаОплатыСБП > 0;
	#КонецВставки
	//-- Локализация

КонецПроцедуры


&НаКлиенте
&ИзменениеИКонтроль("ОткрытьФормуСмешаннойОплаты")
Процедура Док_ОткрытьФормуСмешаннойОплаты(ИзмененныеДанныеЗаписаны, ДополнительныеПараметры)

	Если Не ИзмененныеДанныеЗаписаны Тогда
		РозничныеПродажиКлиент.РазблокироватьФорму(Этотобъект);
		Возврат;
	КонецЕсли;

	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("ИнформацияОбОплате",     ИнформацияОбОплате(ЭтотОбъект));
	ПараметрыОткрытияФормы.Вставить("Партнер",                Объект.Партнер);
	ПараметрыОткрытияФормы.Вставить("ДоступнаПередачаДанных", ПараметрыКассыККМ.ДоступнаПередачаДанных);
	#Удаление
	ПараметрыОткрытияФормы.Вставить("ЭтоПолныйВозвратВСменуПродажи", ЭтоПолныйВозвратВСменуПродажи);
	#КонецУдаления
	#Вставка
	Если ЗначениеЗаполнено(_ИДТранзакции) и _ИДТранзакции <> "Не найден лог" и _ИДТранзакции <> "ID not found" Тогда
		ПараметрыОткрытияФормы.Вставить("Идентификатор", _ИДТранзакции);
	КонецЕсли;
    #КонецВставки
	ПараметрыОткрытияФормы.Вставить("СтатусОплатыСБПЧекаПродажи", СтатусОплатыСБПЧекаПродажи);

	ОткрытьФорму(
	"Документ.ЧекККМ.Форма.ФормаСмешаннойОплаты",
	ПараметрыОткрытияФормы,
	ЭтотОбъект,,,,
	Новый ОписаниеОповещения("ЗавершениеОплаты", ЭтотОбъект));

КонецПроцедуры

&НаКлиенте
Процедура Док_ОбработатьРезультатОплатыСБП(РезультатВыполнения, ДополнительныеПараметры) Экспорт
			
	Док_ОбработатьРезультатОплатыСБПСервер(РезультатВыполнения);	
	
КонецПроцедуры

&НаСервере
Процедура Док_ОбработатьРезультатОплатыСБПСервер(РезультатВыполнения)
			
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	ИнтеграцияСБПГазпромбанк.ОбработатьОплатуВЧекККМНаВозврат(РезультатВыполнения, ДокОбъект);
	ЗначениеВРеквизитФормы(ДокОбъект, "Объект");  
	
 КонецПроцедуры

&НаКлиенте
Процедура Док_ОбновитьФормуСБП(Результат, ДополнительныеПараметры) Экспорт
	
	ПересчитатьДокументНаКлиенте();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
&ИзменениеИКонтроль("УстановитьДоступностьЭлементовРМКЛокализация")
Процедура Док_УстановитьДоступностьЭлементовРМКЛокализация(Форма, ДоступныеВидыОплаты)

	//++ Локализация
	#Удаление
	ЕстьВозвращаемыеПозиции = (Форма.Объект.Товары.Количество() > 0);
	Форма.Элементы.ОплатитьЭСФСС.Доступность = ЕстьВозвращаемыеПозиции;

	#КонецУдаления
	#Вставка
	Форма.Элементы.ОплатитьЭСФСС.Доступность = Истина;
    #КонецВставки
	Если ДоступныеВидыОплаты.ЭСФСС Тогда
		ОплатыЭСФСС = ОплатыЭСФСС(Форма.Объект.ОплатаПлатежнымиКартами);
		Если (ОплатыЭСФСС.Количество() > 0 И ОплатыЭСФСС[0].ОплатаОтменена = Истина)
			Или Форма.ОбщаяСуммаОплатыЭСФСС > Форма.СуммаДокумента Тогда
			Форма.Элементы.ОплатитьЭСФСС.Доступность = Ложь;
		КонецЕсли;
	КонецЕсли;

	Если Форма.СтатусОплатыСБПЧекаПродажи = ПредопределенноеЗначение("Перечисление.ТипыСтатусовОплатыСБП.ОжидаетПодтверждение") Тогда
		Форма.Элементы.ОплатитьСБП.Видимость = Ложь;
		Форма.ИспользоватьОплатуСБП = Ложь;
	Иначе
    #Удаление
		Форма.Элементы.ОплатитьСБП.Доступность = ЕстьВозвращаемыеПозиции;
		Форма.Элементы.ОплатитьСБП.Видимость = (ДоступныеВидыОплаты.СБП И Форма.ОбщаяСуммаОплатыСБП > 0)
													ИЛИ ДоступныеВидыОплаты.СБП И НЕ ЗначениеЗаполнено(Форма.Объект.ЧекККМ);
	#КонецУдаления
	КонецЕсли;
	
	#Удаление
	Если Форма.ОбщаяСуммаОплатыЭСФСС > 0
		ИЛИ Форма.СтатусОплатыСБПЧекаПродажи = ПредопределенноеЗначение("Перечисление.ТипыСтатусовОплатыСБП.ОжидаетПодтверждение") Тогда
		Форма.Элементы.Товары.ТолькоПросмотр = Истина;
	КонецЕсли;
	#КонецУдаления
	
	//-- Локализация

КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПеред(Отказ, СтандартнаяОбработка)
		
	Если ЗначениеЗаполнено(Объект.ЧекККМ) Тогда 
		Отказ = Не Документы.ЧекККМВозврат.МожноСоздатьЧекВозврат(Объект.ЧекККМ);
	КонецЕсли;	

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("ЗаполнитьДанныеНеотмененныхОплатПлатежнымиКартамиПоЧекуККМ")
Процедура Док_ЗаполнитьДанныеНеотмененныхОплатПлатежнымиКартамиПоЧекуККМ()

	ДанныеПоЧекуККМ.Вставить("КомбинацииСуммНеотмененныхОплатПлатежнымиКартами", Новый Массив);
	ДанныеПоЧекуККМ.Вставить("НаименьшаяСуммаНеотмененнойОплатыПлатежнойКартой", 0);
	ДанныеПоЧекуККМ.Вставить("КоличествоНеотмененныхОплатПлатежнымиКартами", 0);
	ДанныеПоЧекуККМ.Вставить("ДанныеПервойНеотмененнойОплатыПлатежнымиКартами", Неопределено);
	ДанныеПоЧекуККМ.Вставить("НомераСтрокОтменяемыхОплатПлатежнойКартой", Новый Соответствие);

	Если ЗначениеЗаполнено(Объект.ЧекККМ) Тогда

		МассивВидовОплат = Новый Массив;
		МассивВидовОплат.Добавить(Перечисления.ТипыПлатежнойСистемыККТ.ПлатежнаяКарта);
		
		#Удаление
		Запрос = Новый Запрос(Документы.ЧекККМ.ТекстЗапросаДляПолученияНеотмененныхОплатПоЧекуККМ(Истина, Ложь));
		#КонецУдаления
		#Вставка
		//Запрос изменен, чтобы была возможность сделать несколько отмен по одному чеку
        Запрос = Новый Запрос (ИзмененныйТекстЗапросаДляПолученияНеотмененныхОплатПоЧекуККМ());
        #КонецВставки
		Запрос.УстановитьПараметр("Ссылка", Объект.ЧекККМ);
		Запрос.УстановитьПараметр("ВидыОплат", МассивВидовОплат);

		ТаблицаНеотмененныхОплатПлатежнымиКартами = Запрос.Выполнить().Выгрузить();

		// Проверка, что настроены эквайринговые терминалы, использованные при оплате по чеку продажи.
		НастроенныеЭквайринговыеТерминалы = Новый Соответствие;
		Для Каждого Терминал Из ЭквайринговыеТерминалы Цикл
			ТерминалЗначение = Терминал.Значение; // Структура
			НастроенныеЭквайринговыеТерминалы.Вставить(ТерминалЗначение.Ссылка, Терминал.Значение);
		КонецЦикла;
		МассивСтрокДляУдаления = Новый Массив;
		Для Каждого НеотмененнаяОплатаПлатежнойКартой Из ТаблицаНеотмененныхОплатПлатежнымиКартами Цикл
			#Удаление
			Если НеотмененнаяОплатаПлатежнойКартой.Сумма > Объект.СуммаДокумента 
				Или НастроенныеЭквайринговыеТерминалы[НеотмененнаяОплатаПлатежнойКартой.ЭквайринговыйТерминал] = Неопределено Тогда
			#КонецУдаления
			#Вставка
			Если НастроенныеЭквайринговыеТерминалы[НеотмененнаяОплатаПлатежнойКартой.ЭквайринговыйТерминал] = Неопределено Тогда
			#КонецВставки
				МассивСтрокДляУдаления.Добавить(НеотмененнаяОплатаПлатежнойКартой);
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаДляУдаления Из МассивСтрокДляУдаления Цикл
			ТаблицаНеотмененныхОплатПлатежнымиКартами.Удалить(СтрокаДляУдаления);
		КонецЦикла;

		ТаблицаНеотмененныхОплатПлатежнымиКартами.Колонки.Добавить("НомерСтроки");
		НомерСтрокиНеотмененнойОплаты = 0;
		Для Каждого СтрокаНеотмененныхОплат Из ТаблицаНеотмененныхОплатПлатежнымиКартами Цикл
			СтрокаНеотмененныхОплат.НомерСтроки = НомерСтрокиНеотмененнойОплаты;
			НомерСтрокиНеотмененнойОплаты = НомерСтрокиНеотмененнойОплаты + 1;
		КонецЦикла;

		ДанныеПоЧекуККМ.АдресТаблицыНеотмененныхОплатПлатежнымиКартами = ПоместитьВоВременноеХранилище(ТаблицаНеотмененныхОплатПлатежнымиКартами, УникальныйИдентификатор);

		РезультатПересчета = РозничныеПродажиВызовСервера.ПересчитатьДанныеНеотмененныхОплатПлатежнымиКартами(ДанныеПоЧекуККМ.АдресТаблицыНеотмененныхОплатПлатежнымиКартами);
		ДанныеПоЧекуККМ.ДанныеПервойНеотмененнойОплатыПлатежнымиКартами = РезультатПересчета.ДанныеПервойНеотмененнойОплатыПлатежнымиКартами;
		ДанныеПоЧекуККМ.КоличествоНеотмененныхОплатПлатежнымиКартами = РезультатПересчета.КоличествоНеотмененныхОплатПлатежнымиКартами;
		ДанныеПоЧекуККМ.КомбинацииСуммНеотмененныхОплатПлатежнымиКартами = РезультатПересчета.КомбинацииСуммНеотмененныхОплатПлатежнымиКартами;
		ДанныеПоЧекуККМ.НаименьшаяСуммаНеотмененнойОплатыПлатежнойКартой = РезультатПересчета.НаименьшаяСуммаНеотмененнойОплатыПлатежнойКартой;
		#Вставка
		Если ДанныеПоЧекуККМ.ДанныеПервойНеотмененнойОплатыПлатежнымиКартами = Неопределено И Объект.ЧекККМ.ФормаОплаты = Перечисления.ТипыПлатежнойСистемыККТ.ПлатежнаяКарта Тогда
			АльтерраОбщегоНазначения.СообщитьПользователю(Объект.ЧекККМ, "Отмена оплаты платежными картами по " + Объект.ЧекККМ + " недоступна."); 
		КонецЕсли;
		#КонецВставки	
	КонецЕсли;

КонецПроцедуры

//Измененный текст запроса позволяет получить данные о строчках безналичной оплаты из чека-основания
//даже если эти строчки уже были частично отменены. 
Функция ИзмененныйТекстЗапросаДляПолученияНеотмененныхОплатПоЧекуККМ()
	ТекстЗапроса = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОплатыПлатежнымиКартами.ВидОплаты КАК ВидОплаты,
	|	ОплатыПлатежнымиКартами.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	ОплатыПлатежнымиКартами.КодАвторизации КАК КодАвторизации,
	|	ОплатыПлатежнымиКартами.НомерПлатежнойКарты КАК НомерПлатежнойКарты,
	|	СУММА(ОплатыПлатежнымиКартами.Сумма) КАК Сумма,
	|	ОплатыПлатежнымиКартами.ОплатаОтменена КАК ОплатаОтменена
	|ПОМЕСТИТЬ ВозвратОплатыПлатежнымиКартамиПоЧеку
	|ИЗ
	|	Документ.ЧекККМВозврат КАК ЧекККМВозврат
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМВозврат.ОплатаПлатежнымиКартами КАК ОплатыПлатежнымиКартами
	|		ПО (ОплатыПлатежнымиКартами.Ссылка = ЧекККМВозврат.Ссылка)
	|ГДЕ
	|	ЧекККМВозврат.ЧекККМ = &Ссылка
	|	И ЧекККМВозврат.Проведен
	|	И ЧекККМВозврат.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|	И ОплатыПлатежнымиКартами.ВидОплаты В(&ВидыОплат)
	|
	|СГРУППИРОВАТЬ ПО
	|	ОплатыПлатежнымиКартами.ВидОплаты,
	|	ОплатыПлатежнымиКартами.ЭквайринговыйТерминал,
	|	ОплатыПлатежнымиКартами.КодАвторизации,
	|	ОплатыПлатежнымиКартами.НомерПлатежнойКарты,
	|	ОплатыПлатежнымиКартами.ОплатаОтменена
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОплатыПлатежнымиКартами.ВидОплаты КАК ВидОплаты,
	|	ОплатыПлатежнымиКартами.ЭквайринговыйТерминал КАК ЭквайринговыйТерминал,
	|	ОплатыПлатежнымиКартами.КодАвторизации КАК КодАвторизации,
	|	ОплатыПлатежнымиКартами.НомерПлатежнойКарты КАК НомерПлатежнойКарты,
	|	ОплатыПлатежнымиКартами.Сумма - ЕСТЬNULL(ВозвратОплатыПлатежнымиКартамиПоЧеку.Сумма, 0) КАК Сумма,
	|	ОплатыПлатежнымиКартами.ИдентификаторКорзины КАК ИдентификаторКорзины,
	|	ОплатыПлатежнымиКартами.СсылочныйНомер КАК СсылочныйНомер,
	|	ОплатыПлатежнымиКартами.ДоговорПодключения КАК ДоговорПодключения,
	|	ОплатыПлатежнымиКартами.ИдентификаторПлатежнойСистемы КАК ИдентификаторПлатежнойСистемы,
	|	ОплатыПлатежнымиКартами.НомерЧекаЭТ КАК НомерЧекаЭТ
	|ИЗ
	|	Документ.ЧекККМ.ОплатаПлатежнымиКартами КАК ОплатыПлатежнымиКартами
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВозвратОплатыПлатежнымиКартамиПоЧеку КАК ВозвратОплатыПлатежнымиКартамиПоЧеку
	|		ПО (ВозвратОплатыПлатежнымиКартамиПоЧеку.ВидОплаты = ОплатыПлатежнымиКартами.ВидОплаты)
	|			И (ВозвратОплатыПлатежнымиКартамиПоЧеку.ЭквайринговыйТерминал = ОплатыПлатежнымиКартами.ЭквайринговыйТерминал)
	|			И (ВозвратОплатыПлатежнымиКартамиПоЧеку.КодАвторизации = ОплатыПлатежнымиКартами.КодАвторизации)
	|			И (ВозвратОплатыПлатежнымиКартамиПоЧеку.НомерПлатежнойКарты = ОплатыПлатежнымиКартами.НомерПлатежнойКарты)
	|			И (ВозвратОплатыПлатежнымиКартамиПоЧеку.ОплатаОтменена = ИСТИНА)
	|ГДЕ
	|	ОплатыПлатежнымиКартами.Ссылка = &Ссылка
	|	И ОплатыПлатежнымиКартами.ВидОплаты В(&ВидыОплат)
	|	И ОплатыПлатежнымиКартами.Сумма - ЕСТЬNULL(ВозвратОплатыПлатежнымиКартамиПоЧеку.Сумма, 0) > 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВидОплаты,
	|	ЭквайринговыйТерминал,
	|	НомерПлатежнойКарты,
	|	КодАвторизации,
	|	ИдентификаторКорзины,
	|	ДоговорПодключения,
	|	НомерЧекаЭТ";
	Возврат ТекстЗапроса;
КонецФункции




