#Область ЗаполнениеОстаткамиНаСкладе
&НаКлиенте
Процедура Док_ЗаполнитьОстаткамиНаСкладеПосле(Команда)
	
	Если Не ЭтоТорговыйСклад(Объект.Склад) Тогда
		ЗаполнитьОстаткамиПоСкладу(Объект.Склад);
	Конецесли;
	
КонецПроцедуры

Функция ЭтоТорговыйСклад(ТекСклад)
	 Возврат ТекСклад.СкладПродажи;
КонецФункции 

&НаКлиенте
Процедура Док_СкладПриИзмененииПосле(Элемент)
	ВидимостьКнопкиЗаполненияОстатками(Объект.Склад);
	УведомленияПодрядчику_ИнициализацияЗначений();
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ВидимостьКнопкиЗаполненияОстатками(Объект.Склад);
	УведомленияПодрядчику_ИнициализацияЗначений();
КонецПроцедуры

&НаСервере
Процедура ВидимостьКнопкиЗаполненияОстатками(Склад)
	
	Если Не Склад.Пустая() Тогда
    	Элементы.ЗаполнитьОстатками.Доступность = Не ЭтоТорговыйСклад(Склад);
	Иначе
    	Элементы.ЗаполнитьОстатками.Доступность = Ложь;
	Конецесли
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОстаткамиПоСкладу(Склад)
		
	Результат = АльтерраОбщегоНазначения.ПолучитьОстаткиПоСкладу(Склад);
		
	Если Результат.Пустой() Тогда
		ОбщегоНазначения.СообщитьПользователю("На данном складе нет доступных остатков");
	Иначе
		Объект.Товары.Загрузить(Результат.Выгрузить());
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область Зеленение

&После("УстановитьУсловноеОформление")
Процедура Спр_УстановитьУсловноеОформление()
	АльтерраОбщегоНазначения.УстановитьОформлениеЗеленениеСтрокТабличныхЧастей(ЭтаФорма,"Товары");
КонецПроцедуры

&НаСервере
Процедура СКПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ЭтаФорма.Элементы._ГруппаСекции.Видимость=рольДоступна("ПолныеПрава") или рольДоступна("СнятьЗеленение");
	ЭтаФорма.Элементы.Кладовщик.Доступность=рольДоступна("ПолныеПрава") или рольДоступна("СнятьЗеленение");
КонецПроцедуры 

&НаКлиенте
Процедура СброситьПоСекции(Команда)
	
	МассивВыдСтрок = Элементы.Товары.ВыделенныеСтроки;
	Если МассивВыдСтрок.Количество() <> 0 Тогда
		Для Каждого ТекСтрока Из МассивВыдСтрок Цикл
			СтрокаКоллекции = Объект.Товары.НайтиПоИдентификатору(ТекСтрока);
			СтрокаКоллекции.Кладовщик = "";
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СКТоварыПередУдалениемПосле(Элемент, Отказ)
	
	Если ЗначениеЗаполнено(Элементы.товары.ТекущиеДанные.Кладовщик) Тогда
		Предупреждение("Товар выдан со склада. Удаление строки запрещено!!!");
		Отказ = Истина;
	КонецЕсли;	

КонецПроцедуры

&НаКлиенте
Процедура СКТоварыПередНачаломИзмененияПосле(Элемент, Отказ)
	
	Если ЗначениеЗаполнено(Элементы.товары.ТекущиеДанные.Кладовщик) тогда
		Предупреждение("Товар выдан со склада. Изменение строки запрещено!!!");
		Отказ = Истина;
	КонецЕсли;	

КонецПроцедуры

#КонецОбласти


#Область СтатьяРасходовБУ

&НаКлиенте
Процедура Док_ТоварыСтатьяРасходовБУНачалоВыбораПосле(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИдентификаторСтроки", Элементы.Товары.ТекущаяСтрока);
	ОписаниеОповещения = Новый ОписаниеОповещения("СтатьяРасходовБУВыборЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Статья", Элементы.Товары.ТекущиеДанные.СтатьяРасходовБУ);
	ПараметрыФормы.Вставить("ПараметрыВыбора", Элемент.ПараметрыВыбора);
	
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораСтатьи", ПараметрыФормы, ЭтаФорма, , , , ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура СтатьяРасходовБУВыборЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Строка = Объект.Товары.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
	Строка.СтатьяРасходовБУ = Результат; 
	
КонецПроцедуры

&НаКлиенте
Процедура Док__ЗаполнитьСтатьюРасходовБУПосле(Команда)
	
	ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	
	Если Объект.Товары.Количество() = 0 Тогда
		ПоказатьПредупреждение( , НСтр("ru = 'В список ""Товары"" не введено ни одной строки.'"));
		Возврат;
	ИначеЕсли ВыделенныеСтроки.Количество() = 0 Тогда
		ПоказатьПредупреждение( , НСтр("ru = 'В списке ""Товары"" не выделено ни одной строки.'"));
		Возврат;
	КонецЕсли;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("СтатьяРасходовБУВыборДляЗаполненияЗавершение", ЭтотОбъект);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Статья", Элементы.Товары.ТекущиеДанные.СтатьяРасходовБУ);
	ПараметрыФормы.Вставить("ПараметрыВыбора", Элементы.ТоварыСтатьяРасходовБУ.ПараметрыВыбора);
	
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораСтатьи", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура СтатьяРасходовБУВыборДляЗаполненияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВыделенныеСтроки = ОбщегоНазначенияКлиентСервер.СкопироватьМассив(Элементы.Товары.ВыделенныеСтроки);
	Для Каждого Строка Из ВыделенныеСтроки Цикл
		ДанныеСтроки = Объект.Товары.НайтиПоИдентификатору(Строка);
		ДанныеСтроки.СтатьяРасходовБУ = Результат;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыСтатьяРасходовПриИзмененииПосле(Элемент)
	
	СтрокаТаблицы = Элементы.Товары.ТекущиеДанные;
	Если Не значениезаполнено(СтрокаТаблицы.СтатьяРасходовБУ) Тогда
		СтрокаТаблицы.СтатьяРасходовБУ = СтрокаТаблицы.СтатьяРасходов;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область УведомленияПодрядчику

&НаСервере
Процедура УведомленияПодрядчику_ИнициализацияЗначений()
	
	Запрос = Новый Запрос; 
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	СобытияДокументовАльтерраСрезПоследних.Документ КАК Документ,
	               |	СобытияДокументовАльтерраСрезПоследних.Событие КАК Событие
	               |ИЗ
	               |	РегистрСведений.СобытияДокументовАльтерра.СрезПоследних КАК СобытияДокументовАльтерраСрезПоследних
	               |ГДЕ
	               |	СобытияДокументовАльтерраСрезПоследних.Документ = &Документ
	               |	И СобытияДокументовАльтерраСрезПоследних.Событие = &Событие";
	Запрос.УстановитьПараметр("Документ",объект.Ссылка);
	Запрос.УстановитьПараметр("Событие",Перечисления.СобытияДокументов.УведомлениеПодрядчику); 
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		ДокументОтправлен = Истина; 
	Иначе
		 ДокументОтправлен = ложь; 
	КонецЕсли; 

	СправочникСклады_ГруппаПодрядчики = Справочники.Склады.НайтиПоНаименованию("Подрядчики");
	Если (ЗначениеЗаполнено(Объект.Склад) И 
		ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И 
		Объект.Склад.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики) И
		Объект.Склад.ОтправкаУведомлений = Истина И
		Объект.Склад.ТипСкладаПодрядчика = Истина)
	Тогда  
		Элементы.УведомленияПодрядчику.Видимость = ИСТИНА;
		УведомленияПодрядчикуТелефон = Объект.Склад.ТелефонПодрядчика; 
		УведомленияПодрядчикуПочта = Объект.Склад.EMAILподрядчика;
	Иначе
		Элементы.УведомленияПодрядчику.Видимость = ЛОЖЬ;
	КонецЕсли;
		
КонецПроцедуры       

&НаКлиенте
Процедура ПослеЗакрытияВопросаПовторный(Результат, Параметры) Экспорт
 
    Если Результат = КодВозвратаДиалога.Да Тогда
		 ПроверкаНастроекСклада("3");
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияВопросаПервичный(Результат, Параметры) Экспорт
 
	Если Результат = КодВозвратаДиалога.Да Тогда
		 ПроверкаНастроекСклада("2");
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура ПроверкаНастроекСклада(Код)
	
	Если Код = "2" Тогда 
		Если Объект.Склад.ОтправкаУведомлений ТОгда 
			 ОтправкаУведомленийПодрядчику("2");
		Иначе
			 Сообщить("У подрядчика не настроенно получение уведомлений"); 
		КонецЕсли;
	КонецЕсли;
	 
	Если Код = "3" Тогда 
		Если Объект.Склад.ПовторноеУведомление ТОгда 
			 ОтправкаУведомленийПодрядчику("3");
		Иначе
			 Сообщить("У подрядчика не настроенно получение повторных уведомлений"); 
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры
 
&НаКлиенте
Процедура Док_ОтправитьУведомлениеПодрядчикуПосле(Команда)
	
	Если ДокументОТправлен Тогда
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПовторный",
		      ЭтотОбъект);	
		 
		    ПоказатьВопрос(Оповещение,
		        "Повторно уведомить подрядчика о списание товаров с его склада?",
		        РежимДиалогаВопрос.ДаНетОтмена,
		        0);   
	КонецЕсли;		
	 
	Если Не ДокументОТправлен Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопросаПервичный",
		  ЭтотОбъект);	
	 
	    ПоказатьВопрос(Оповещение,
	        "Уведомить подрядчика о списании товаров с его склада? ",
	        РежимДиалогаВопрос.ДаНетОтмена,
	        0);

	КонецЕсли; 
	
КонецПроцедуры
	
Процедура ОтправкаУведомленийПодрядчику(Код)
	
	СправочникСклады_ГруппаПодрядчики = Справочники.Склады.НайтиПоНаименованию("Подрядчики");
	Если ЗначениеЗаполнено(Объект.Склад) И 
		ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И 
		Объект.Склад.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики) И
		Объект.Склад.ОтправкаУведомлений = Истина И
		Объект.Склад.ТипСкладаПодрядчика = Истина 
	Тогда 
		ОтправитьСМСиEmail(Код);
	КонецЕсли;
		
КонецПроцедуры

Процедура ОтправитьСМСиEmail(Код)

	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОбщегоНазначения.СообщитьПользователю("Документ должен быть записан!");
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Номер) Тогда
		ОбщегоНазначения.СообщитьПользователю("Номер документа должен быть указан!");
		Возврат;
	КонецЕсли;
	
	ФайлОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Печатные формы списания", Истина);

	ФайлОбработка2 = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Печатные формы списания", Истина);

	Если Не ЗначениеЗаполнено(ФайлОбработка2) Тогда
		ОбщегоНазначения.СообщитьПользователю("Ошибка! Не найдена доп. обработка 'Печатные формы списания'..");
		Возврат;
	КонецЕсли;
	МассивСкладов = Новый Массив; 
	УведомленияПодрядчикуПочта = Объект.Склад.EMAILподрядчика;
	УведомленияПодрядчикуТелефон = Объект.Склад.ТелефонПодрядчика;
	ДопПочта = Объект.Склад.ДопEMAILподрядчика; 
	МассивСкладов.Добавить(Объект.Склад); 
	МассивСкладов.Добавить(Объект.Склад.ДопСкладПодрядчика);
	
	
	ПараметрыПечати = Новый Структура;
	ПараметрыПечати.Вставить("ВыводитьСумму", Истина);
	
	МассивДокументов = Новый Массив;
	МассивДокументов.Добавить(Объект.Ссылка);
	
	ОбъектыПечати = Новый СписокЗначений;
	ОбъектыПечати.Добавить(Объект.Ссылка);
	
	ДвоичныеДанные = ФайлОбработка.ХранилищеОбработки.Получить();
	ФайлОбработка = ПолучитьИмяВременногоФайла();
	ДвоичныеДанные.Записать(ФайлОбработка);
	
	ДвоичныеДанные2 = ФайлОбработка2.ХранилищеОбработки.Получить();
	ФайлОбработка2 = ПолучитьИмяВременногоФайла();
	ДвоичныеДанные2.Записать(ФайлОбработка2);

	
	СуммаИтог = 0;
	ТабличныйДокумент = ВнешниеОбработки.Создать(ФайлОбработка).СформироватьПечатнуюФормуНакладнаяНаПеремещениеПодрядчику(МассивДокументов, ОбъектыПечати, ПараметрыПечати, СуммаИтог);
	ФайлТабДок = ПолучитьИмяВременногоФайла();
	ТабличныйДокумент.Записать(ФайлТабДок, ТипФайлаТабличногоДокумента.XLSX);
	АдресВХ = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ФайлТабДок));
	
	ТабличныйДокумент2 = ВнешниеОбработки.Создать(ФайлОбработка2).СформироватьПечатнуюФормуВедомостьОстатковНаСкладах(Объект.Ссылка, МассивСкладов);
	ФайлТабДок2 = ПолучитьИмяВременногоФайла();
	ТабличныйДокумент2.Записать(ФайлТабДок2, ТипФайлаТабличногоДокумента.XLSX);
	АдресВХ2 = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ФайлТабДок2));

		
	МассивФайлов = Новый Массив;
	МассивФайлов.Добавить(Новый Структура("Представление, АдресВоВременномХранилище","Ведомость по остаткам на складе" + ".xlsx", АдресВХ2));
	МассивФайлов.Добавить(Новый Структура("Представление, АдресВоВременномХранилище", "Списание ТМЦ на " +  ".xlsx", АдресВХ));
	
	ПараметрыОтправки = Новый Структура;
	ПараметрыОтправки.Вставить("Кому", УведомленияПодрядчикуПочта);
	Если код = "2" Тогда //1 Списание с договорного поставщика
		ПараметрыОтправки.Вставить("Тема", "Альтерра списание ТМЦ на " + Объект.Склад);
		ПараметрыОтправки.Вставить("Тело", "С вашего склада '" + Объект.Склад + " от " +ТекущаяДата() + "' списаны ТМЦ .№" + Объект.Номер + ". Документы прилагаются.");
	КонецЕсли;
	Если код = "3" Тогда //Повторное списание с договорного поставщика
		ПараметрыОтправки.Вставить("Тема", "Альтерра изменение списания ТМЦ на " + Объект.Склад);
		ПараметрыОтправки.Вставить("Тело", "На вашем складе '" + Объект.Склад + "' " + ТекущаяДата() +  " изменился состав списания ТМЦ №" + объект.Номер + " . Документы прилагаются.");
	КонецЕсли;
	
	ПараметрыОтправки.Вставить("Кодировка", КодировкаТекста.UTF8);
	ПараметрыОтправки.Вставить("ТипТекста", Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст);
	ПараметрыОтправки.Вставить("Вложения", МассивФайлов);
	
	РезультатОтправкиEmail = РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты, ПараметрыОтправки);		
	
	Если ЗначениеЗАполнено(ДопПочта) Тогда 
		ПараметрыОтправки.Кому = ДопПочта; 
		РезультатОтправкиEmail = РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты, ПараметрыОтправки);		
	КонецЕслИ; 
	

	Если ЗначениеЗаполнено(РезультатОтправкиEmail) И ТипЗнч(РезультатОтправкиEmail) = Тип("Строка") Тогда	
		НомерТелефонаПартнера = АльтерраОбщегоНазначения.ПолчитьТелефонБезКода(УведомленияПодрядчикуТелефон);
		Если СтрДлина(НомерТелефонаПартнера) = 10 Тогда
			СтрокаНомерТелефона = "+7" + Строка(НомерТелефонаПартнера);
			СтатусОшибки = Ложь;
			Если код = "2" Тогда //1 Перемещение с договорного поставщика
				АльтерраОбщегоНазначения.ОтправитьСМС(СтрокаНомерТелефона, "Со скл '" + объект.Склад + " списаны ТМЦ по док " + объект.Номер + " на сум."+ СуммаИтог + "р. Отпр.'" + УведомленияПодрядчикуПочта + "'", СтатусОшибки);
			КонецЕсли;
			Если код = "3" Тогда //Повторное перемещение с договорного поставщика
				АльтерраОбщегоНазначения.ОтправитьСМС(СтрокаНомерТелефона, "Изм. в списании " +объект.Номер + " на скл '" + объект.Склад + "' Нов. сумма " +СуммаИтог + "р. Отпр. '" + УведомленияПодрядчикуПочта + "'", СтатусОшибки);
			КонецЕсли;

	
			Если Не СтатусОшибки Тогда
				ОбщегоНазначения.СообщитьПользователю("Сообщения на E-mail адрес и телефон успешно отправлены!");	
			Иначе 
				ОбщегоНазначения.СообщитьПользователю("Не удалось отправить сообщение на телефон. На E-mail адрес сообщение успешно отправлено!");
			КонецЕсли;
		Иначе 
			ОбщегоНазначения.СообщитьПользователю("Не удалось отправить сообщение на телефон. На E-mail адрес сообщение успешно отправлено!");
		КонецЕсли;
	Иначе
		ОбщегоНазначения.СообщитьПользователю("Не удалось отправить сообщение на E-mail адрес..");
	КонецЕсли;
	
	УдалитьФайлы(ФайлОбработка2);
	УдалитьФайлы(ФайлТабДок2);
	УдалитьИзВременногоХранилища(АдресВХ2);
	Если КОД = "2" Тогда 
		События = РегистрыСведений.СобытияДокументовАльтерра.СоздатьНаборЗаписей();
		События.Отбор.Документ.Установить(объект.Ссылка); 
		События.Отбор.Событие.Установить(Перечисления.СобытияДокументов.УведомлениеПодрядчику); 
		
		НовоеСобытие = События.Добавить();
		НовоеСобытие.Документ = объект.Ссылка;
		НовоеСобытие.Событие = Перечисления.СобытияДокументов.УведомлениеПодрядчику;
		НовоеСобытие.Период = ТекущаяДата(); 
		События.Записать();
	КонецЕсли;
	
	Если Код = "3" Тогда 
		  		  
		События = РегистрыСведений.СобытияДокументовАльтерра.СоздатьНаборЗаписей();
		События.Отбор.Документ.Установить(объект.Ссылка); 
		События.Отбор.Событие.Установить(Перечисления.СобытияДокументов.УведомлениеПодрядчикуВысланоПовторно); 
		
	    НовоеСобытие = События.Добавить();
		НовоеСобытие.Документ = объект.Ссылка;
		НовоеСобытие.Событие = Перечисления.СобытияДокументов.УведомлениеПодрядчикуВысланоПовторно;
		НовоеСобытие.Период = ТекущаяДата(); 
		События.Записать();

	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
Процедура Док_УстановитьОбъектРасходовПосле(Команда)

	ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки;
	
	Если Объект.Товары.Количество() = 0 ИЛИ НЕ ЗначениеЗаполнено(ВыделенныеСтроки) Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("ru = 'Для выполнения команды требуется выделить строки табличной части.'"));
		Возврат;
	КонецЕсли;
	
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("ХозяйственнаяОперация", Объект.ХозяйственнаяОперация);
	
	ВыбранноеЗначение = Неопределено;
	
	ОткрытьФорму(
		"Общаяформа.ФормаВыбораОбъектовАналитики", 
		СтруктураПараметры,
		ЭтаФорма,,,, Новый ОписаниеОповещения("УстановитьОбъектРасходовЗавершение", ЭтотОбъект, Новый Структура("ВыделенныеСтроки", ВыделенныеСтроки)), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьОбъектРасходовЗавершение(Результат, ДополнительныеПараметры) Экспорт
    
    ВыделенныеСтроки = ДополнительныеПараметры.ВыделенныеСтроки;
    
    ВыбранноеЗначение = Результат;
    
    Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
        
        Для Каждого Строка Из ВыделенныеСтроки Цикл
            
            СтрокаТаблицы = Объект.Товары.НайтиПоИдентификатору(Строка);
            Если СтрокаТаблицы <> Неопределено Тогда
                СтрокаТаблицы.ОбъектРасходов = ВыбранноеЗначение.ОбъектРасходов;
                СтрокаТаблицы.АналитикаОбъекта = ВыбранноеЗначение.АналитикаОбъекта;
            КонецЕсли;
            
        КонецЦикла;
        
    КонецЕсли;

КонецПроцедуры

#КонецОбласти

