&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполненияПосле(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Перем РеквизитыШапки;
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		Если ДанныеЗаполнения.Свойство("МассивЗаказов") И ДанныеЗаполнения.МассивЗаказов.Количество() > 0 Тогда
			Комментарий= ДанныеЗаполнения.МассивЗаказов[0].Комментарий;
		КонецЕсли; 

		Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") И ДанныеЗаполнения.Свойство("ПутевыеЛисты") Тогда
			ДанныеЗаполнения.Свойство("РеквизитыШапки", РеквизитыШапки);
			ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыШапки);
			Товары.Загрузить(ТаблЧастьТоваров(ДанныеЗаполнения.ПутевыеЛисты)[0].Выгрузить());
			ПутевыеЛисты.Загрузить(ТаблЧастьТоваров(ДанныеЗаполнения.ПутевыеЛисты)[1].Выгрузить());
		КонецЕсли;
	КонецЕсли;	
	
КонецПроцедуры   

Функция ТаблЧастьТоваров(МассивДокументов)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПутевойЛист.Топливо КАК Номенклатура,
		|	СУММА(ПутевойЛист.РасходФактический) КАК Количество,
		|	СУММА(ПутевойЛист.РасходФактический) КАК КоличествоУпаковок,
		|	ПутевойЛист.ТранспортноеСредство.СтатьяРасходов КАК СтатьяРасходов,
		|	ПутевойЛист.ТранспортноеСредство.АналитикаРасходов КАК АналитикаРасходов
		|ИЗ
		|	Документ.ПутевойЛист КАК ПутевойЛист
		|ГДЕ
		|	ПутевойЛист.Ссылка В(&МассивДокументов)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПутевойЛист.Топливо,
		|	ПутевойЛист.ТранспортноеСредство.СтатьяРасходов,
		|	ПутевойЛист.ТранспортноеСредство.АналитикаРасходов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПутевойЛист.Ссылка КАК ПутевойЛист
		|ИЗ
		|	Документ.ПутевойЛист КАК ПутевойЛист
		|ГДЕ
		|	ПутевойЛист.Ссылка В(&МассивДокументов)";

	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);

	Результат = Запрос.ВыполнитьПакет();

    Возврат Результат;
	
КонецФункции

&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
        |	ТаблицаТовары.АналитикаРасходов КАК АналитикаРасходов,
        |	ТаблицаТовары.СтатьяРасходов КАК СтатьяРасходов,
        |	ТаблицаТовары.ОбъектРасходов КАК ОбъектРасходов,
        |	ТаблицаТовары.АналитикаОбъекта КАК АналитикаОбъекта,
        |	СУММА(ВЫБОР
		|			КОГДА СебестоимостьТоваровОбороты.КоличествоРасход <> 0
		|				ТОГДА ТаблицаТовары.КоличествоУпаковок * (СебестоимостьТоваровОбороты.ДопРасходыПриход + СебестоимостьТоваровОбороты.СтоимостьРасход) / СебестоимостьТоваровОбороты.КоличествоРасход
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Сумма
        |ИЗ
        |	Документ.ВнутреннееПотребление.Товары КАК ТаблицаТовары
        |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров.Обороты(, , Регистратор, ) КАК СебестоимостьТоваровОбороты
        |		ПО ТаблицаТовары.Ссылка = СебестоимостьТоваровОбороты.Регистратор
        |			И  ТаблицаТовары.Номенклатура = СебестоимостьТоваровОбороты.АналитикаУчетаНоменклатуры.Номенклатура
        |ГДЕ
        |	ТаблицаТовары.Ссылка = &Ссылка
        |	И НЕ ТаблицаТовары.ОбъектРасходов = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
        |	И НЕ ТаблицаТовары.АналитикаОбъекта = ЗНАЧЕНИЕ(Справочник.АналитикаОбъекта.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
        |	ТаблицаТовары.АналитикаРасходов,
        |	ТаблицаТовары.СтатьяРасходов,
        |	ТаблицаТовары.ОбъектРасходов,
        |	ТаблицаТовары.АналитикаОбъекта";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Движение = Движения.РасходыПоОбъектам.Добавить();
		Движение.Период = Дата;
		Движение.Организация = Организация;
		Движение.Подразделение = Подразделение;
		Движение.АналитикаРасходов = ВыборкаДетальныеЗаписи.АналитикаРасходов;
		Движение.СтатьяРасходов = ВыборкаДетальныеЗаписи.СтатьяРасходов;
		Движение.ОбъектРасходов = ВыборкаДетальныеЗаписи.ОбъектРасходов;
		Движение.АналитикаОбъекта = ВыборкаДетальныеЗаписи.АналитикаОбъекта;
		Движение.Сумма = ВыборкаДетальныеЗаписи.Сумма;
	КонецЦикла;
	Движения.РасходыПоОбъектам.Записывать = Истина; 
	
КонецПроцедуры

&После("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Для Каждого СтрокаТЧ Из Товары Цикл  
		
		Если НЕ СтрокаТЧ.ОбъектРасходов.Пустая() и СтрокаТЧ.АналитикаОбъекта.Пустая() Тогда
			ИндексМассива = СтрокаТЧ.НомерСтроки-1;
			ОбщегоНазначения.СообщитьПользователю("Нельзя по строке реквизит ""Объект расходов"" заполнить, а ""Аналитика объекта"" нет. Исправьте или очистите значения этих реквизитов в строке",, 
				"Объект.Товары[" + ИндексМассива + "].АналитикаОбъекта");
			Отказ = Истина;
		ИначеЕсли СтрокаТЧ.ОбъектРасходов.Пустая() и НЕ СтрокаТЧ.АналитикаОбъекта.Пустая() Тогда
			ИндексМассива = СтрокаТЧ.НомерСтроки-1;
			ОбщегоНазначения.СообщитьПользователю("Нельзя по строке реквизит ""Аналитика объекта"" заполнить, а ""Объект расходов"" нет. Исправьте или очистите значения этих реквизитов в строке",, 
				"Объект.Товары[" + ИндексМассива + "].ОбъектРасходов");
			Отказ = Истина;
		КонецЕсли;
	
	КонецЦикла;
	
КонецПроцедуры

&После("ПередУдалением")
Процедура Док_ПередУдалением(Отказ)
	ДопМодульСервер.ПроверитьНаличиеРасходногоОрдераНаТовары(Ссылка, Отказ);
КонецПроцедуры     

