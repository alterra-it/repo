&После ("УстановитьУсловноеОформление")
&НаСервере
Процедура Док_УстановитьУсловноеОформление()
	
	ЗаказыСервер.УстановитьОформлениеОтмененнойСтроки(УсловноеОформление,
		Элементы.Товары,
		Элементы.ТоварыОтменено.Имя,
		Элементы.ТоварыПричинаОтмены.Имя);
		
	УстановитьСостояниеЗаказа();
	
КонецПроцедуры

&НаСервере
Функция УстановитьСостояниеЗаказа()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА НЕ ДокументЗаказНаПеремещение.Проведен
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.СостоянияВнутреннихЗаказов.ПустаяСсылка)
	|		ИНАЧЕ ЕСТЬNULL(СостоянияВнутреннихЗаказов.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияВнутреннихЗаказов.Закрыт))
	|	КОНЕЦ КАК Состояние,
	|	ЕСТЬNULL(СостоянияВнутреннихЗаказов.ЕстьРасхожденияОрдерНакладная, ЛОЖЬ) КАК ЕстьРасхожденияОрдерНакладная
	|ИЗ
	|	Документ.ЗаказНаПеремещение КАК ДокументЗаказНаПеремещение
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВнутреннихЗаказов КАК СостоянияВнутреннихЗаказов
	|		ПО (СостоянияВнутреннихЗаказов.Заказ = ДокументЗаказНаПеремещение.Ссылка)
	|ГДЕ
	|	ДокументЗаказНаПеремещение.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	
	Состояние = Выборка.Состояние;
	Если Выборка.ЕстьРасхожденияОрдерНакладная = Истина Тогда 
		Элементы.ЕстьРасхожденияОрдерНакладная.Видимость = Истина;
	КонецЕсли;

КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("ОтменитьВыделенныеСтроки")
Процедура Док_ОтменитьВыделенныеСтроки(Команда)
	// &ЗамерПроизводительности
	ОценкаПроизводительностиКлиент.НачатьЗамерВремени(Истина,
	"Документ.ЗаказНаПеремещение.ФормаДокумента.Команда.ОтменитьВыделенныеСтроки");
	
	#Вставка
	Если Объект.Товары.Количество() = 0 Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("ru='Таблица товаров не заполнена.'"));
		Возврат;
	ИначеЕсли Элементы.Товары.ВыделенныеСтроки.Количество() = 0 Тогда
		ПоказатьПредупреждение(Неопределено, НСтр("ru='В таблице товаров отсутствуют выделенные строки.'"));
		Возврат;
	КонецЕсли;
	
	ПричинаОтмены = ПредопределенноеЗначение("Справочник.ПричиныОтменыЗаказовНаПеремещения.ПустаяСсылка");
	ОткрытьФорму("Справочник.ПричиныОтменыЗаказовНаПеремещения.ФормаВыбора",,,,,, Новый ОписаниеОповещения("ОтменитьВыделенныеСтрокиЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Возврат;
	#КонецВставки
	
	#Удаление
	ОтменитьВыделенныеСтрокиСервер();
	ОбеспечениеВДокументахКлиентСервер.ЗаполнитьСлужебныеРеквизиты(Объект.Товары, ДатаОтгрузкиОбязательна, СкладОбязателен);
	
	ПоказатьОповещениеПользователя(НСтр("ru = 'Отмена выделенных строк'"), , НСтр("ru = 'Выделенные строки отменены'"));
	#КонецУдаления
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВыделенныеСтрокиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ПричинаОтмены = Результат;
    Если ПричинаОтмены = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    ОтменитьВыделенныеСтрокиФрагмент(ПричинаОтмены);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВыделенныеСтрокиФрагмент(Знач ПричинаОтмены)
	
	Для Каждого ТекСтрока Из Элементы.Товары.ВыделенныеСтроки Цикл
        СтрокаТаблицы = Объект.Товары.НайтиПоИдентификатору(ТекСтрока);
        
        Если СтрокаТаблицы <> Неопределено Тогда
            
            СтрокаТаблицы.ПричинаОтмены = ПричинаОтмены;
            
            Если Не СтрокаТаблицы.Отменено Тогда
                СтрокаТаблицы.Отменено = Истина;
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    
    ПоказатьОповещениеПользователя(
    НСтр("ru = 'Выделенные строки отменены'"),
    ,
    НСтр("ru='Выделенные строки заказа отменены.'"),
    БиблиотекаКартинок.Информация32);
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыОтмененоПриИзмененииПосле(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;

	Если Не ТекущаяСтрока.Отменено Тогда
		ТекущаяСтрока.ПричинаОтмены = ПредопределенноеЗначение("Справочник.ПричиныОтменыЗаказовНаПеремещения.ПустаяСсылка");
	КонецЕсли;

КонецПроцедуры

&НаКлиенте 
&ИзменениеИКонтроль("ОтменитьНеотработанные")
Процедура Док_ОтменитьНеотработанные(Команда)
	
	#Удаление
	// &ЗамерПроизводительности
	ОценкаПроизводительностиКлиент.НачатьЗамерВремени(Истина,
		"Документ.ЗаказНаПеремещение.ФормаДокумента.Команда.ОтменитьНеотработанные");
	
	РезультатОтмены = ОтменитьНеотработанныеСервер();
	ПоказатьОповещениеПользователя(НСтр("ru = 'Отмена неотработанных строк'"), , РезультатОтмены.Оповещение);
	#КонецУдаления

	#Вставка
	ПричинаОтмены = ПредопределенноеЗначение("Справочник.ПричиныОтменыЗаказовНаПеремещения.ПустаяСсылка");
	ОткрытьФорму("Справочник.ПричиныОтменыЗаказовНаПеремещения.ФормаВыбора",,,,,, Новый ОписаниеОповещения("ОтменитьНеотработанныеСтрокиЗавершение", ЭтотОбъект), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	#КонецВставки
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьНеотработанныеСтрокиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	ПричинаОтменыПустая = ПредопределенноеЗначение("Справочник.ПричиныОтменыЗаказовНаПеремещения.ПустаяСсылка");
    ПричинаОтмены = Результат;
    Если ПричинаОтмены = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
 	РезультатОтмены = ОтменитьНеотработанныеСервер();
	Для Каждого ТекСтрока Из Объект.Товары Цикл
		
		Если ТекСтрока.Отменено Тогда
			ТекСтрока.ПричинаОтмены = ПричинаОтмены;
		иначе
			ТекСтрока.ПричинаОтмены = ПричинаОтменыПустая; 
		КонецЕсли;
		
	КонецЦикла;
	
	ПоказатьОповещениеПользователя(НСтр("ru = 'Отмена неотработанных строк'"), , РезультатОтмены.Оповещение);

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("СкорректироватьСтрокиЗаказа")
Функция Док_СкорректироватьСтрокиЗаказа(СтруктураДополнительныхПараметров)

	ЗаказОбъект = РеквизитФормыВЗначение("Объект");

	СтруктураДополнительныхПараметров.ПроверятьОстатки = Истина;

	СтруктураРезультата = ЗаказОбъект.СкорректироватьСтрокиЗаказа(СтруктураДополнительныхПараметров);

	Если СтруктураДополнительныхПараметров.ЗакрыватьЗаказы Тогда
		ЗаказОбъект.Статус = Перечисления.СтатусыВнутреннихЗаказов.Закрыт;
	КонецЕсли;

	ЗначениеВРеквизитФормы(ЗаказОбъект, "Объект");

	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	ЗаполнитьСлужебныеРеквизитыФормыДокумента();
	ОбновитьКолонкуДоступноСервер();

	Модифицированность = Истина;
	
#Вставка
	ПричинаОтменыПустая = ПредопределенноеЗначение("Справочник.ПричиныОтменыЗаказовНаПеремещения.ПустаяСсылка");
    ПричинаОтмены = СтруктураДополнительныхПараметров.ПричинаОтмены;
	
	Если ПричинаОтмены = Неопределено Тогда
        Возврат СтруктураРезультата;
	КонецЕсли;
	
	Для Каждого ТекСтрока Из Объект.Товары Цикл
		Если ТекСтрока.Отменено Тогда
			ТекСтрока.ПричинаОтмены = ПричинаОтмены;
		иначе
			ТекСтрока.ПричинаОтмены = ПричинаОтменыПустая; 
		КонецЕсли;
	КонецЦикла;
#КонецВставки

	Возврат СтруктураРезультата;

КонецФункции

