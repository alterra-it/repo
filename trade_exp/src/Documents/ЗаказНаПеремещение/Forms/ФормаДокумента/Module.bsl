КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	ВидимостьКнопкиЗаполненияОстатками(Объект.СкладОтправитель);
	
	Для Каждого Команда_СоздатьНаОсновании Из Этаформа.Команды Цикл
		Если Команда_СоздатьНаОсновании.Действие = "Подключаемый_ВыполнитьКоманду"
			И Команда_СоздатьНаОсновании.Заголовок = "Перемещение товаров" Тогда
			ИмяКнопкиСоздатьПеремещение = Команда_СоздатьНаОсновании.Имя;
		КонецЕсли;
	КонецЦикла;
	
	Объект.СтатусОтображение = Объект.Статус;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	
	ИнициализацияДляСкладовПодрядчика();
		
КонецПроцедуры


&НаСервере
Процедура ИнициализацияДляСкладовПодрядчика()
	
	СправочникСклады_ГруппаПодрядчики = Справочники.Склады.НайтиПоНаименованию("Подрядчики");
	Если (ЗначениеЗаполнено(Объект.СкладПолучатель) И
       ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И
       Объект.СкладПолучатель.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики) И
       Объект.СкладПолучатель.ОтправкаУведомлений = Истина)
       ИЛИ
       (ЗначениеЗаполнено(Объект.СкладОтправитель) И
       ЗначениеЗаполнено(СправочникСклады_ГруппаПодрядчики) И
       Объект.СкладОтправитель.ПринадлежитЭлементу(СправочникСклады_ГруппаПодрядчики) И
       Объект.СкладОтправитель.ОтправкаУведомлений = Истина)	
	Тогда  
		нЭлемент = Элементы.Добавить("КомментарийОтИнженера", Тип("ПолеФормы"), Элементы.Товары); 
		нЭлемент.Вид = ВидПоляФормы.ПолеВвода; 
		нЭлемент.ПутьКДанным = "Объект.Товары.КомментарийОтИнженера";  	
	КонецЕсли;   
	
КонецПроцедуры

&НаКлиенте
Процедура ВВводНаОснованииЗаявкаНаТранспорт(Команда)
	
	ИмяДокумента= "ЗаявкиНаТранспорт";
	ФормаДок = ПолучитьФорму("Документ."+ИмяДокумента+".ФормаОбъекта");
	
	//Далее мы получаем объект только, что созданной формы и помещаем её в переменную
	//В объекте содержатся все реквизиты (элементы) формы
	ДанныеФормы = ФормаДок.Объект;
	
	Если Объект.Ссылка.Пустая() Тогда
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Данные еще не записаны.
		|Выполнение действия ""%1"" возможно только после записи данных.'"),
		"Заявка на доставку");
		
		ПоказатьПредупреждение(,ТекстВопроса);
		возврат;	
	КонецЕсли;
	
	//Мы помещаем объект формы в переменную,
	//так как должны передать её в процедуру на сервере,
	//где нельзя изменять объект формы, зато можно править переменную содержащую его
	СоздатьНовыйДокумент(ИмяДокумента, ДанныеФормы);
	
	//После выполнения процедуры на сервере мы получаем изменную переменную ДанныеФормы,
	//которую необходимо передать в уже созданную нами форму
	КопироватьДанныеФормы(ДанныеФормы, ФормаДок.Объект);
	
	//Открываем результат выполнения обработки
	ФормаДок.Открыть();
	
КонецПроцедуры

&НаСервере
Процедура СоздатьНовыйДокумент(ИмяДокумента, НовыйОбъект)
	Документы[ИмяДокумента].ЗаполнитьДанныеПоОснованию(Объект.Ссылка, НовыйОбъект);
КонецПроцедуры

