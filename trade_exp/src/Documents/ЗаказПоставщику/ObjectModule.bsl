&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
		
		Если ТипДанныхЗаполнения = Тип("Структура") Тогда
			Если ДанныеЗаполнения.Свойство("Основание") Тогда
				Основание = ДанныеЗаполнения.Основание;
			Иначе
				Основание= Неопределено;
			КонецЕсли;
		Иначе
			Основание = ДанныеЗаполнения;
		КонецЕсли;
		
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			КроссДокинг = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание, "КроссДокинг");
		КонецЕсли;   
		ДанныеЗаполнения.Свойство("Менеджер", Менеджер);
	КонецЕсли;
КонецПроцедуры

&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если(ПометкаУдаления) И (НЕ Ссылка.ПометкаУдаления) Тогда
		Если ЕстьРейсОтПоставщика(Ссылка) Тогда
			ОбщегоНазначения.СообщитьПользователю("У заказа есть проведенный Рейс от поставщика",); 
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
//	ВариантПриемкиПоЗаказам = Перечисления.ВариантыПриемкиТоваров.РазделенаПоЗаказамИНакладным;
	
	//Если ВариантПриемкиТоваров <> ВариантПриемкиПоЗаказам Тогда
	//	ВариантПриемкиТоваров = ВариантПриемкиПоЗаказам;
	//КонецЕсли;
	
	Если ВесПоставки=0 ИЛИ ВесПоставки<>0 И ТипЗнч(ОбщегоНазначенияУТ.СравнитьТаблицыЗначений(Товары.Выгрузить(), Ссылка.Товары.Выгрузить()))=Тип("ТаблицаЗначений") Тогда
		РассчитатьВесОбъемСтрок(); 
	КонецЕсли;
	
	Если НЕ АльтерраОбщегоНазначения.ДействующийПоставщик(Контрагент) Тогда
	
		Отказ = Истина; 
		Сообщить("Данный контрагент не включен в реестр поставщиков", СтатусСообщения.Важное);
	
	КонецЕсли;
	
	Если Не ОтключитьКонтрольЗаписи
		И  Альтерра_СеткаПоставок.ЕстьСекцииУСклада(Склад)
		И (Статус = Перечисления.СтатусыЗаказовПоставщикам.Согласован
		ИЛИ Статус = Перечисления.СтатусыЗаказовПоставщикам.Подтвержден)
		И Норматив = Справочники.НормативыПриемкиПоставкиНаСклад.ПустаяСсылка()
		И НЕ Склад.ТорговыйЗал
	Тогда
		Если Не РольДоступна("ПолныеПрава") Тогда
			Отказ = Истина;
		КонецЕсли;
		Сообщить("Необходимо заполнить норматив и секцию на вкладке ""Поставка""", СтатусСообщения.Важное);
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения ИЛИ ПометкаУдаления = Истина Тогда
		Если ДатаПоступления <> '00010101' Тогда			
			Альтерра_СеткаПоставок.ИзменитьДанныеСеткиПоставок(Ссылка, "Удаление");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если QRкод = "" Тогда  
		QRкод = ГенерацияШтрихкода.СформироватьQRКод(Ссылка);
		
		Если ДополнительныеСвойства.Свойство("ПроведениеДокументов")
			И ДополнительныеСвойства.ПроведениеДокументов.Свойство("СвойстваДокумента")
			И ДополнительныеСвойства.ПроведениеДокументов.СвойстваДокумента.Свойство("РежимЗаписи") 
			И ДополнительныеСвойства.ПроведениеДокументов.СвойстваДокумента.РежимЗаписи = РежимЗаписиДокумента.Запись
		Тогда 
			Записать(РежимЗаписиДокумента.Запись);   
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры



