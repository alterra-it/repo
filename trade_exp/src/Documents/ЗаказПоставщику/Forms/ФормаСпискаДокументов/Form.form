  <showCloseButton>true</showCloseButton>
  <attributes>
    <name>Список</name>
    <id>1000001</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <main>true</main>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	ДокументЗаказПоставщику.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА НЕ ДокументЗаказПоставщику.Проведен
			ТОГДА ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказовПоставщикам.ПустаяСсылка)
		ИНАЧЕ ЕСТЬNULL(СостоянияЗаказовПоставщикам.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияЗаказовПоставщикам.Закрыт))
	КОНЕЦ КАК Состояние,
	ВЫБОР
		КОГДА НЕ ДокументЗаказПоставщику.Проведен
			ТОГДА ЛОЖЬ
		КОГДА ДокументЗаказПоставщику.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовПоставщикам.Закрыт)
				И &amp;ИспользоватьСтатусы
			ТОГДА ЛОЖЬ
		ИНАЧЕ СостоянияЗаказовПоставщикам.ДатаСобытия &lt;> ДАТАВРЕМЯ(1, 1, 1)
				И &amp;ДатаАктуальности > СостоянияЗаказовПоставщикам.ДатаСобытия
	КОНЕЦ КАК Просрочен,
	ВЫБОР
		КОГДА ДокументЗаказПоставщику.Приоритет = &amp;НизшийПриоритет
			ТОГДА 0
		КОГДА ДокументЗаказПоставщику.Приоритет = &amp;ВысшийПриоритет
			ТОГДА 2
		ИНАЧЕ 1
	КОНЕЦ КАК КартинкаПриоритета,
	ЕСТЬNULL(СостоянияЗаказовПоставщикам.СуммаОплаты, 0) КАК СуммаОплаты,
	ЕСТЬNULL(СостоянияЗаказовПоставщикам.ПроцентОплаты, 0) КАК ПроцентОплаты,
	ЕСТЬNULL(СостоянияЗаказовПоставщикам.СуммаПоступления, 0) КАК СуммаПоступления,
	ЕСТЬNULL(СостоянияЗаказовПоставщикам.ПроцентПоступления, 0) КАК ПроцентПоступления,
	ВЫБОР
		КОГДА ЕСТЬNULL(СостоянияЗаказовПоставщикам.СуммаДолга, 0) > 0
			ТОГДА СостоянияЗаказовПоставщикам.СуммаДолга
		ИНАЧЕ 0
	КОНЕЦ КАК ДолгПоставщика,
	ВЫБОР
		КОГДА ЕСТЬNULL(СостоянияЗаказовПоставщикам.СуммаДолга, 0) &lt; 0
			ТОГДА -СостоянияЗаказовПоставщикам.СуммаДолга
		ИНАЧЕ 0
	КОНЕЦ КАК НашДолг,
	ЕСТЬNULL(СостоянияЗаказовПоставщикам.ПроцентДолга, 0) КАК ПроцентДолга,
	ЕСТЬNULL(СостоянияЗаказовПоставщикам.ДатаСобытия, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаСобытия,
	СостоянияЭД.СостояниеЭДО КАК СостояниеВерсииЭД,
	СостоянияЭД.ПредставлениеСостояния КАК ПредставлениеСостояния,
	&amp;ДополнительныеПоляСостояниеEDI КАК ДополнительныеПоляСостояниеEDI
ПОМЕСТИТЬ втСписок
ИЗ
	Документ.ЗаказПоставщику КАК ДокументЗаказПоставщику
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияЗаказовПоставщикам КАК СостоянияЗаказовПоставщикам
		ПО (СостоянияЗаказовПоставщикам.Заказ = ДокументЗаказПоставщику.Ссылка)
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияПоОбъектамУчетаЭДО КАК СостоянияЭД
		ПО (СостоянияЭД.СсылкаНаОбъект = ДокументЗаказПоставщику.Ссылка)}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Итог.Документ КАК Документ,
	МИНИМУМ(Итог.ВремяВъезд) КАК ВремяВъезд,
	МАКСИМУМ(Итог.ВремяВыезд) КАК ВремяВыезд
ПОМЕСТИТЬ втОтметкиКПП
ИЗ
	(ВЫБРАТЬ
		СостояниеОтгрузкиДокумента.Документ КАК Документ,
		ВЫБОР
			КОГДА СостояниеОтгрузкиДокумента.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Заехал)
				ТОГДА МИНИМУМ(СостояниеОтгрузкиДокумента.Период)
		КОНЕЦ КАК ВремяВъезд,
		ВЫБОР
			КОГДА СостояниеОтгрузкиДокумента.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияОтгрузкиДокумента.Выехал)
				ТОГДА МАКСИМУМ(СостояниеОтгрузкиДокумента.Период)
		КОНЕЦ КАК ВремяВыезд
	ИЗ
		РегистрСведений.СостояниеОтгрузкиДокумента КАК СостояниеОтгрузкиДокумента
	ГДЕ
		СостояниеОтгрузкиДокумента.Документ В
				(ВЫБРАТЬ
					втСписок.Ссылка
				ИЗ
					втСписок КАК втСписок)
		И СостояниеОтгрузкиДокумента.Состояние В(&amp;СтатусыДоставки)
	
	СГРУППИРОВАТЬ ПО
		СостояниеОтгрузкиДокумента.Документ,
		СостояниеОтгрузкиДокумента.Состояние) КАК Итог

СГРУППИРОВАТЬ ПО
	Итог.Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	втСписок.Ссылка КАК Заказ,
	&quot;Прибыл&quot; КАК Состояние,
	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяПриездаФакт КАК ДатаСостояния,
	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК ДатаВремяРазгрузкиПлан
ПОМЕСТИТЬ втЗаездыФакт
ИЗ
	втСписок КАК втСписок
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних КАК ГрафикПоставокНаСкладСрезПоследних
		ПО втСписок.Ссылка = ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗЛИЧНЫЕ
	втЗаездыФакт.Заказ КАК Заказ,
	ВЫБОР
		КОГДА ЕСТЬNULL(втОтметкиКПП.ВремяВыезд, ДАТАВРЕМЯ(1, 1, 1)) &lt;> ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА &quot;Выехал&quot;
		ИНАЧЕ ВЫБОР
				КОГДА ЕСТЬNULL(втОтметкиКПП.ВремяВъезд, ДАТАВРЕМЯ(1, 1, 1)) &lt;> ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА &quot;Заехал&quot;
				ИНАЧЕ ВЫБОР
						КОГДА ЕСТЬNULL(втЗаездыФакт.ДатаСостояния, ДАТАВРЕМЯ(1, 1, 1)) &lt;> ДАТАВРЕМЯ(1, 1, 1)
							ТОГДА &quot;Прибыл&quot;
						ИНАЧЕ ВЫБОР
								КОГДА ЕСТЬNULL(втЗаездыФакт.ДатаВремяРазгрузкиПлан, ДАТАВРЕМЯ(1, 1, 1)) &lt;> ДАТАВРЕМЯ(1, 1, 1)
									ТОГДА &quot;Запланирована&quot;
								ИНАЧЕ &quot;Не запланирована&quot;
							КОНЕЦ
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК ТекущееСостояние,
	ЕСТЬNULL(втЗаездыФакт.ДатаСостояния, ДАТАВРЕМЯ(1, 1, 1)) КАК ВремяПрибытие,
	ЕСТЬNULL(втОтметкиКПП.ВремяВъезд, ДАТАВРЕМЯ(1, 1, 1)) КАК ВремяВъезд,
	ЕСТЬNULL(втОтметкиКПП.ВремяВыезд, ДАТАВРЕМЯ(1, 1, 1)) КАК ВремяВыезд
ПОМЕСТИТЬ втИтог
ИЗ
	втЗаездыФакт КАК втЗаездыФакт
		ЛЕВОЕ СОЕДИНЕНИЕ втОтметкиКПП КАК втОтметкиКПП
		ПО втЗаездыФакт.Заказ = втОтметкиКПП.Документ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	МАКСИМУМ(РейсОтПоставщикаРасчетДоставки.Ссылка.ДатаПрибытияНаСклад) КАК ДатаПрибытияНаСклад,
	втИтог.Заказ КАК Заказ
ПОМЕСТИТЬ втПоследнийРейсЗаказа
ИЗ
	втИтог КАК втИтог
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		ПО втИтог.Заказ = РейсОтПоставщикаРасчетДоставки.ДокументОснование
ГДЕ
	РейсОтПоставщикаРасчетДоставки.Ссылка.ПометкаУдаления = ЛОЖЬ

СГРУППИРОВАТЬ ПО
	втИтог.Заказ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	МАКСИМУМ(ЗаявкаНаРасходованиеДенежныхСредств.Ссылка) КАК Ссылка,
	ЗаявкаНаРасходованиеДенежныхСредств.ДокументОснование КАК ДокументОснование
ПОМЕСТИТЬ ВТЗРДС
ИЗ
	Документ.ЗаявкаНаРасходованиеДенежныхСредств КАК ЗаявкаНаРасходованиеДенежныхСредств
ГДЕ
	ЗаявкаНаРасходованиеДенежныхСредств.ДокументОснование В
			(ВЫБРАТЬ
				втСписок.Ссылка
			ИЗ
				втСписок КАК втСписок)
	И ЗаявкаНаРасходованиеДенежныхСредств.Проведен

СГРУППИРОВАТЬ ПО
	ЗаявкаНаРасходованиеДенежныхСредств.ДокументОснование
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КОЛИЧЕСТВО(ПриобретениеТоваровУслугТовары.АналитикаРасходов) КАК АналитикаРасходов,
	ПриобретениеТоваровУслуг.ЗаказПоставщику КАК ЗаказПоставщикуТранспортные
ПОМЕСТИТЬ ВТТранспортные
ИЗ
	Документ.ПриобретениеТоваровУслуг.Товары КАК ПриобретениеТоваровУслугТовары
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
		ПО ПриобретениеТоваровУслугТовары.АналитикаРасходов = ПриобретениеТоваровУслуг.Ссылка
ГДЕ
	ПриобретениеТоваровУслуг.Проведен
	И ПриобретениеТоваровУслугТовары.Ссылка.Проведен
	И ПриобретениеТоваровУслуг.ЗаказПоставщику В
			(ВЫБРАТЬ
				втСписок.Ссылка
			ИЗ
				втСписок КАК втСписок)
	И ПриобретениеТоваровУслугТовары.Ссылка.Партнер = &amp;Партнер
	И ПриобретениеТоваровУслугТовары.Ссылка.Контрагент = &amp;Контрагент

СГРУППИРОВАТЬ ПО
	ПриобретениеТоваровУслуг.ЗаказПоставщику
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	втСписок.Ссылка КАК Ссылка,
	ЗаказПоставщику.ПометкаУдаления КАК ПометкаУдаления,
	ЗаказПоставщику.Номер КАК Номер,
	ЗаказПоставщику.Дата КАК Дата,
	ЗаказПоставщику.Проведен КАК Проведен,
	ЗаказПоставщику.Партнер КАК Партнер,
	ЗаказПоставщику.Контрагент КАК Контрагент,
	ЗаказПоставщику.Организация КАК Организация,
	ЗаказПоставщику.Соглашение КАК Соглашение,
	ЗаказПоставщику.Договор КАК Договор,
	ЗаказПоставщику.ПорядокРасчетов КАК ПорядокРасчетов,
	ЗаказПоставщику.Склад КАК Склад,
	ЗаказПоставщику.Валюта КАК Валюта,
	ЗаказПоставщику.Менеджер КАК Менеджер,
	ЗаказПоставщику.СуммаДокумента КАК СуммаДокумента,
	ЗаказПоставщику.СуммаВозвратнойТары КАК СуммаВозвратнойТары,
	ЗаказПоставщику.Приоритет КАК Приоритет,
	ЗаказПоставщику.ДополнительнаяИнформация КАК ДополнительнаяИнформация,
	ЗаказПоставщику.ЖелаемаяДатаПоступления КАК ЖелаемаяДатаПоступления,
	ЗаказПоставщику.ДатаПервогоПоступления КАК ДатаПервогоПоступления,
	ЗаказПоставщику.СуммаПредоплатыДоПоступления КАК СуммаПредоплатыДоПоступления,
	ЗаказПоставщику.СуммаАвансаДоПодтверждения КАК СуммаАвансаДоПодтверждения,
	ЗаказПоставщику.ХозяйственнаяОперация КАК ХозяйственнаяОперация,
	ЗаказПоставщику.Комментарий КАК Комментарий,
	ЗаказПоставщику.НомерПоДаннымПоставщика КАК НомерПоДаннымПоставщика,
	ЗаказПоставщику.ДатаПоДаннымПоставщика КАК ДатаПоДаннымПоставщика,
	втСписок.Состояние КАК Состояние,
	втСписок.Просрочен КАК Просрочен,
	втСписок.КартинкаПриоритета КАК КартинкаПриоритета,
	втСписок.СуммаОплаты КАК СуммаОплаты,
	втСписок.ПроцентОплаты КАК ПроцентОплаты,
	втСписок.СуммаПоступления КАК СуммаПоступления,
	втСписок.ПроцентПоступления КАК ПроцентПоступления,
	втСписок.ДолгПоставщика КАК ДолгПоставщика,
	втСписок.НашДолг КАК НашДолг,
	втСписок.ПроцентДолга КАК ПроцентДолга,
	втСписок.ДатаСобытия КАК ДатаСобытия,
	втСписок.СостояниеВерсииЭД КАК СостояниеВерсииЭД,
	втСписок.ПредставлениеСостояния КАК ПредставлениеСостояния,
	втСписок.ДополнительныеПоляСостояниеEDI КАК ДополнительныеПоляСостояниеEDI,
	втИтог.ТекущееСостояние КАК СостояниеПоставки,
	ВЫБОР
		КОГДА втИтог.ВремяВыезд &lt;> ДАТАВРЕМЯ(1, 1, 1)
			ТОГДА втИтог.ВремяВыезд
		ИНАЧЕ ВЫБОР
				КОГДА втИтог.ВремяВъезд &lt;> ДАТАВРЕМЯ(1, 1, 1)
					ТОГДА втИтог.ВремяВъезд
				ИНАЧЕ ВЫБОР
						КОГДА втИтог.ВремяПрибытие &lt;> ДАТАВРЕМЯ(1, 1, 1)
							ТОГДА втИтог.ВремяПрибытие
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК ВремяИзмененияСостояния,
	втПоследнийРейсЗаказа.ДатаПрибытияНаСклад КАК ДатаПрибытияНаСклад,
	ЗаказПоставщику.Статус КАК Статус,
	ЗаказПоставщику.ДокументыОтСкладаПолучены КАК ДокументыОтСкладаПолучены, 
	ВЫБОР
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ЕСТЬ NULL ТОГДА
			1
		КОГДА НаличиеПрисоединенныхФайлов.ЕстьФайлы ТОГДА
			0
		ИНАЧЕ
			1
	КОНЕЦ КАК ЕстьФайлы,
	ВТЗРДС.Ссылка КАК ЗРДССсылка,
	ВЫБОР
		КОГДА ВТТранспортные.АналитикаРасходов ЕСТЬ NULL
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК Транспортные
ИЗ
	втИтог КАК втИтог
		ЛЕВОЕ СОЕДИНЕНИЕ втСписок КАК втСписок
		ПО втИтог.Заказ = втСписок.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
		ПО втИтог.Заказ = ЗаказПоставщику.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ втПоследнийРейсЗаказа КАК втПоследнийРейсЗаказа
		ПО втИтог.Заказ = втПоследнийРейсЗаказа.Заказ
		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗРДС КАК ВТЗРДС
		ПО (ВТЗРДС.ДокументОснование = втИтог.Заказ)
		ЛЕВОЕ СОЕДИНЕНИЕ ВТТранспортные КАК ВТТранспортные
		ПО (ВТТранспортные.ЗаказПоставщикуТранспортные = втИтог.Заказ)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеПрисоединенныхФайлов
		ПО (втИтог.Заказ = НаличиеПрисоединенныхФайлов.ОбъектСФайлами)</queryText>
