#Область ОтправкаСообщенияПоставщику

&НаКлиенте
Процедура Док_ОтправитьПисьмоПоставщикуПосле(Команда)
	Если Объект.Проведен = Ложь Тогда
		Сообщить("Невозможно отправить письмо по непроведённому заказу!", СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;
	
	Если ВремяПоступления = '00010101' Тогда
		Сообщить("Невозможно отправить письмо без запланированного времени поступления!", СтатусСообщения.Важное);
		Возврат;
	КонецЕсли;
	
	ДатаВремяПоставки = Строка(Формат(ДатаРазгрузки + Час(ВремяПоступления)*3600+Минута(ВремяПоступления)*60, "ДФ=DD.MM.yyyy HH:mm"));
	ДатаВремяПоставки = Лев(ДатаВремяПоставки, СтрДлина(ДатаВремяПоставки)-3);
	
	//параметры текста шаблона
	ПараметрыШаблона = Новый Структура;
	ПараметрыШаблона.Вставить("ДатаРазгрузки", ДатаВремяПоставки);
	ПараметрыШаблона.Вставить("НомерЗаказаПоставщику", Объект.Номер);
	ПараметрыШаблона.Вставить("АдресСклада", ПолучитьАдресСклада());
	
	ДопПараметрыЗакрытия = Новый Структура;
	ДопПараметрыЗакрытия.Вставить("Ссылка");
	ОписаниеОповещенияЗакрытия = Новый ОписаниеОповещения("ПослеЗакрытияФормыПисьма", ЭтотОбъект, ДопПараметрыЗакрытия); 
	ПараметрыСообщения = ПараметрыШаблона;
	Шаблон = ПолучитьШаблонСообщения();
	ПараметрыОтправки = КонструкторПараметровОтправки(Шаблон, ПараметрыСообщения);
	ПараметрыОтправки.ДополнительныеПараметры.ПреобразовыватьHTMLДляФорматированногоДокумента = Истина;
	ПараметрыОтправки.ДополнительныеПараметры.ПараметрыСообщения = ПараметрыСообщения;
	
	АдресВременногоХранилища = Неопределено;
	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	
	АдресРезультата = СформироватьСообщениеНаСервере(АдресВременногоХранилища, ПараметрыОтправки, "Письмо");
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	СписокПолучателей =  СформироватьСписокПолучателей();
	Результат.Получатель = СписокПолучателей;
	Результат.Отправитель = "";
	Результат.Вставить("Предмет", "Документ.ЗаказПоставщику");
	Результат.Вставить("Шаблон",  ПараметрыОтправки.Шаблон);
	Результат.Вставить("ДатаРазгрузки", ПараметрыШаблона.ДатаРазгрузки);
	Результат.Вставить("НомерЗаказаПоставщику",  ПараметрыШаблона.НомерЗаказаПоставщику);
	Результат.Вставить("АдресСклада", ПараметрыШаблона.АдресСклада);
	Если ПараметрыОтправки.ДополнительныеПараметры.Свойство("ПараметрыСообщения")
		И ТипЗнч(ПараметрыОтправки.ДополнительныеПараметры.ПараметрыСообщения) = Тип("Структура") Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Результат, ПараметрыСообщения, Ложь);
	КонецЕсли;
	
	Сообщение =  Результат;
	Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("СтандартныеПодсистемы.РаботаСПочтовымиСообщениями") Тогда
		МодульРаботаСПочтовымиСообщениямиКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("РаботаСПочтовымиСообщениямиКлиент");
		МодульРаботаСПочтовымиСообщениямиКлиент.СоздатьНовоеПисьмо(Сообщение, ОписаниеОповещенияЗакрытия);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьАдресСклада()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладыКонтактнаяИнформация.Представление КАК Представление
	|ИЗ
	|	Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяИнформация
	|ГДЕ
	|	СкладыКонтактнаяИнформация.Ссылка = &Ссылка
	|	И СкладыКонтактнаяИнформация.Тип = Значение(Перечисление.ТипыКонтактнойИнформации.Адрес)";
	Запрос.УстановитьПараметр("Ссылка", Объект.Склад);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Выборка = Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Представление;
	Иначе
		Возврат "";
	КонецЕсли; 
	
КонецФункции 

