&НаКлиенте
Процедура Док_ПродолжительностьРазгрузкиПриИзмененииВместо(Элемент)
	ДанныеПоставкиИзменились = Истина;
	Модифицированность = Истина;
	//тут тоже сделать проверку потом, помещается интервал или нет
	РезультатПроверки =  ПроверитьТекущийИнтервалНаДоступность();
	Если Не РезультатПроверки.ИнтервалДоступен Тогда
		Сообщить("Время на разгрузку превышает ранее установленное и поставка перекрывает другой заказ, назначенный на это время или попадает в неустановленное по расписанию время.", СтатусСообщения.ОченьВажное);
		СогласованоСоСкладом = Ложь;
		Если РезультатПроверки.СброситьВремя Тогда
			ВремяПоступления = '00010101000000';
			Поток = ПредопределенноеЗначение("Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

