#Область СверкаСчетаСПоставщиком
&НаКлиенте
Процедура Док__ЗагрузитьСчетОтПоставщика(Команда)
	ПараметрыФормы= Новый  Структура;
	ПараметрыФормы.Вставить("Поставщик", Объект.Партнер);
	ПараметрыФормы.Вставить("Товар", Объект.Товары);
	ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
	
	Оповещение= Новый ОписаниеОповещения("ПослеЗагрузкиСчетаОтПоставщика", ЭтотОбъект);
	ОткрытьФорму("Документ.ЗаказПоставщику.Форма.Док_ЗагрузитьСчетОтПоставщика", ПараметрыФормы, ЭтаФорма, Истина,,,Оповещение,РежимОткрытияОкнаФормы.Независимый);
КонецПроцедуры
//Осн
&НаКлиенте
Процедура ПослеЗагрузкиСчетаОтПоставщика(Результат, ДопПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	
	Если Объект.ТоварыИсходная.Количество() = 0 Тогда
		ЗагрузитьИсходныеТовары();
	КонецЕсли;
	
	если ДопМодуль.НовоеЦенообразованиеЗакупа(Объект.Дата) тогда
	ВидЦеныПоставщика=ПолучитьЦенуПоставщикаНаСервере();	
		иначе
	ВидЦеныПоставщика= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Соглашение, "ВидЦеныПоставщика");
	конецесли;
	ПричинаОтмены = ПолучитьПричинуОтмены();
	
	Для Каждого стрРезультат Из Результат Цикл  
			
		стрТовар = ПолучитьСтрокуИзТоваров(стрРезультат.Номенклатура);
		стрТоварИсход = ПолучитьСтрокуИзТоваровИсходных(стрРезультат.Номенклатура);
		
		Если  Не (стрРезультат.НетВЗаказе ИЛИ стрРезультат.НетВСчете) Тогда
			//1. Количество и сумма равны
			Если стрТовар.Количество =  стрРезультат.СчетКоличество И стрТовар.Сумма =  стрРезультат.СчетСумма Тогда
				стрТовар.НоменклатураПартнера= стрРезультат.НоменклатураПоставщика;
				стрТовар.ВидЦеныПоставщика = ВидЦеныПоставщика;
				Продолжить;
			КонецЕсли;
			
			//2. Количества ровны, а суммы нет
			Если стрТовар.Количество =  стрРезультат.СчетКоличество И стрТовар.Сумма <> стрРезультат.СчетСумма Тогда
				стрТовар.Сумма = стрРезультат.СчетСумма;
				стрТовар.НоменклатураПартнера = стрРезультат.НоменклатураПоставщика;
				стрТовар.ВидЦеныПоставщика = ВидЦеныПоставщика;
				ПересчитатьЦенуВСтроке(стрТовар);
			КонецЕсли;
			
			//3. Не равны количества
			//1)  Количество в заказе больше чем в счете - отменяем строку и добавляем новую
			Если стрТовар.Количество >  стрРезультат.СчетКоличество Тогда
				стрТовар.Количество=  стрРезультат.СчетКоличество;
				стрТовар.КоличествоУпаковок = стрТовар.Количество;
				стрТовар.Сумма =  стрРезультат.СчетСумма;
				стрТовар.НоменклатураПартнера = стрРезультат.НоменклатураПоставщика;
				стрТовар.ВидЦеныПоставщика = ВидЦеныПоставщика;
				ПересчитатьЦенуВСтроке(стрТовар);
				
				НоваяСтрока = Объект.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, стрРезультат);
				НоваяСтрока.Количество = стрРезультат.ЗаказКоличество-стрРезультат.СчетКоличество;
				НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
				НоваяСтрока.Сумма = НоваяСтрока.Количество*стрРезультат.СчетСумма/стрРезультат.СчетКоличество;
				НоваяСтрока.Склад = Объект.Склад;
				НоваяСтрока.ВидЦеныПоставщика = ВидЦеныПоставщика;
				НоваяСтрока.Отменено = Истина;
				НоваяСтрока.ПричинаОтмены = ПричинаОтмены;
				ПересчитатьЦенуВСтроке(НоваяСтрока);
			КонецЕсли;
			
			//2)  Количество в заказе меньше в заказе количество заменяем количеством по счету
			Если стрТовар.Количество < стрРезультат.СчетКоличество Тогда
				стрТовар.Количество = стрРезультат.СчетКоличество;
				стрТовар.КоличествоУпаковок = стрТовар.Количество;
				стрТовар.НоменклатураПартнера = стрРезультат.НоменклатураПоставщика;
				стрТовар.ВидЦеныПоставщика = ВидЦеныПоставщика;
				стрТовар.Сумма = стрРезультат.СчетСумма;
				ПересчитатьЦенуВСтроке(стрТовар);
			КонецЕсли;
			
		Иначе
			//3) Нет в счете - отменяем
			Если стрРезультат.НетВСчете Тогда
				стрТовар.Отменено = Истина;
				стрТовар.ПричинаОтмены = ПричинаОтмены;
				ПересчитатьЦенуВСтроке(стрТовар);
			КонецЕсли;
			//4) Нет в заказе - добавляем					
			Если стрРезультат.НетВЗаказе Тогда
				НоваяСтрока = Объект.Товары.Добавить();
				НоваяСтрока.НоменклатураПартнера = стрРезультат.НоменклатураПоставщика;
				НоваяСтрока.ВидЦеныПоставщика = ВидЦеныПоставщика;
				НоваяСтрока.Номенклатура = стрРезультат.Номенклатура;
				НоваяСтрока.Количество = стрРезультат.СчетКоличество;
				НоваяСтрока.КоличествоУпаковок = НоваяСтрока.Количество;
				НоваяСтрока.Сумма = стрРезультат.СчетСумма; 
				НоваяСтрока.Склад = Объект.Склад; 
				ПересчитатьЦенуВСтроке(НоваяСтрока);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	РасчетыНаСервере();
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры        

&НаСервере
Функция ПолучитьЦенуПоставщикаНаСервере()

	возврат ЦеныПредприятияЗаполнениеСервер.ПолучитьЦенуПартнера(Объект);

КонецФункции // ()


&НаКлиенте
Процедура ПересчитатьЦенуВСтроке(ТекущаяСтрока)
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьЦенуСкидкуПоСуммеВЗакупках", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруПересчетаЦеныСкидкиВЗакупкахВТЧ(Объект, Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПриемНаКомиссию")));
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ЗаполнитьПризнакБезВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействий.Вставить("ЗаполнитьПризнакОтмененоБезВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
	СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС",  Новый Структура("НалогообложениеНДС, Дата, Организация", Объект.НалогообложениеНДС, Объект.Дата, Объект.Организация));
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);

КонецПроцедуры 

&НаСервере
Функция ПолучитьПричинуОтмены()
	Возврат Справочники.ПричиныОтменыЗаказовПоставщикам.НайтиПоНаименованию("Не отработано поставщиком", Истина);
КонецФункции

&НаКлиенте  
Функция ПолучитьСтрокуИзТоваров(Номенклатура) 
	
	Отбор = Новый Структура("Номенклатура", Номенклатура);	 
	
	НайденыеСтроки = Объект.Товары.НайтиСтроки(Отбор);
	Если НайденыеСтроки.Количество() > 0 Тогда
		Возврат НайденыеСтроки[0];
	Иначе
		Возврат Неопределено;
	КонецЕсли; 
	
КонецФункции 

&НаКлиенте
Функция ПолучитьСтрокуИзТоваровИсходных(Номенклатура) 
		
	Отбор = Новый Структура("Номенклатура", Номенклатура);	  
	
	НайденыеСтроки= Объект.ТоварыИсходная.НайтиСтроки(Отбор);
	Если НайденыеСтроки.Количество() > 0 Тогда
		Возврат НайденыеСтроки[0];
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции 

