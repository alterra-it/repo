&НаКлиенте
Процедура Док_СкладПриИзмененииПосле(Элемент)
	
	Объект.Подразделение = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Подразделение");
	ОбновитьПараметрыВыбораЦен();	
	ЗаполнитьЦеныПоСоглашениюСервер(истина);	
	СообщениеПоПоставке = "";
	Если ВРег(СостояниеПоставки) <> ВРег("Не запланирована") И ВРег(СостояниеПоставки) <> "" Тогда
		СообщениеПоПоставке = "Поставка запланирована";
	КонецЕсли;
	Если ЕстьРейсПоПоставке() Тогда
		СообщениеПоПоставке = СообщениеПоПоставке + " и по ней есть рейс!";
	КонецЕсли;
	
	Если СообщениеПоПоставке <> "" Тогда
		Сообщить(СообщениеПоПоставке, СтатусСообщения.Важное);
	КонецЕсли;
		
	Если НЕ Элементы._ГруппаПоставки.ТолькоПросмотр Тогда
		ВремяПоступления = '00010101000000';
		Поток = ПредопределенноеЗначение("Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка");
		Объект.Секция = ПредопределенноеЗначение("Справочник.РабочиеУчастки.ПустаяСсылка");
		Элементы._ГруппаПоставки.Видимость = Альтерра_СеткаПоставок.ЕстьСекцииУСклада(Объект.Склад);
		Элементы.ГруппаСостояниеПоставки.Видимость = Элементы._ГруппаПоставки.Видимость;
	КонецЕсли; 
	
КонецПроцедуры

