&НаКлиенте
Процедура Док_НормативПриИзмененииВместо(Элемент)
	ПриемлимоеЗначениеНорматива = ПроверкаКорректностиНорматива(Объект.Норматив);
	Если Объект.Норматив <> ПриемлимоеЗначениеНорматива Тогда
		Объект.Норматив = ПриемлимоеЗначениеНорматива;
		Сообщить("Обнуление норматива невозможно!", СтатусСообщения.ОченьВажное);
	Иначе
		ДанныеПоставкиИзменились = Истина;
		ВремяПоступления = '00010101000000';
		
		Поток = ПредопределенноеЗначение("Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка");
		ЗаполнитьПоНормативу(Истина);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
    Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		СФП_МаркерыКлиент.МаркерНачало("Заказ поставщику: Проведение из формы");
	КонецЕсли;
	Если Элементы._ГруппаПоставки.Видимость Тогда
		Если Не ПоставкаПрибыла Тогда
			Если Альтерра_СеткаПоставок.ЕстьСекцииУСклада(Объект.Склад) И НЕ ЭтоТорговыйЗал() Тогда
				Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.Подтвержден") И Объект.Секция = ПредопределенноеЗначение("Справочник.РабочиеУчастки.ПустаяСсылка") Тогда
					Если Не ЕстьПолныеПрава() Тогда
						Отказ = Истина;
					КонецЕсли;
					Сообщить("В данном статусе секция на вкладке поставки должна быть заполнена!");
					Возврат;
				КонецЕсли;
			КонецЕсли;
			Если ДанныеПоставкиИзменились ИЛИ ТоварыИзменено Тогда	
				Если НЕ Элементы._ГруппаПоставки.ТолькоПросмотр Тогда
					Если ТоварыИзменено Тогда
						//ПоказатьОповещениеПользователя("Сетка поставок учла изменение табличной части товаров",,);
						ТекСекция = Объект.Секция;
						ТекДлительность = ПродолжительностьРазгрузки;
						
						ПараметрыПересчета = Новый Структура;
						ПараметрыПересчета.Вставить("ПроверкаПередПроведением", Ложь);
						ПересчитатьСекцию(,ПараметрыПересчета);
						Отказ = ПараметрыПересчета.ПроверкаПередПроведением;
						Если Отказ Тогда
							ПараметрыЗаписи.ПринудительноЗакрытьФорму = Ложь;
							ДанныеПоставкиИзменились = Истина;
							ТоварыИзменено = Истина;
							Возврат;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ПродолжительностьРазгрузки=0 Тогда
					ПересчитатьПоНормативу();
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура Док_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)
	
