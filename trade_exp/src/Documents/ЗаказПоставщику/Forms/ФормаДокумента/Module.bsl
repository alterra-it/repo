&НаСервере
Процедура ВыборСкладаКроссДокингаЗавершение(СкладПеремещения, ДопПараметры) Экспорт
	
	Отказ = Ложь;
	Если ЗначениеЗаполнено(СкладПеремещения) Тогда
		НачатьТранзакцию();
		
		ЗаказНаПеремещение = Документы.ЗаказНаПеремещение.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(ЗаказНаПеремещение, Объект,,"Номер,Дата,Проведен,Комментарий,ДокументОснование");
		ЗаказНаПеремещение.Дата = ТекущаяДата();
		ЗаказНаПеремещение.СкладОтправитель = СкладПеремещения;
		ЗаказНаПеремещение.СкладПолучатель = Объект.Склад;
		ЗаказНаПеремещение.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПеремещениеТоваров;
		ЗаказНаПеремещение.Ответственный = Пользователи.ТекущийПользователь();
		ЗаказНаПеремещение.Статус = Перечисления.СтатусыВнутреннихЗаказов.КВыполнению;
		ЗаказНаПеремещение.ОрганизацияПолучатель = ЗаказНаПеремещение.Организация;
		ЗаказНаПеремещение.ЖелаемаяДатаПоступления = ?(ЗначениеЗаполнено(Объект.ДатаПоступления), Объект.ДатаПоступления, ТекущаяДата());
		ЗаказНаПеремещение.СпособДоставки = Перечисления.СпособыДоставки.Самовывоз;
		
		Для Каждого ТоварИсточника Из Объект.Товары Цикл
			Если Не ТоварИсточника.Отменено Тогда
				НоваяСтрока = ЗаказНаПеремещение.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, ТоварИсточника);
				НоваяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению; 
				НоваяСтрока.Обособленно = Истина;
				НоваяСтрока.НачалоОтгрузки = ЗаказНаПеремещение.ЖелаемаяДатаПоступления;
			КонецЕсли;
		КонецЦикла;
		Попытка
			ЗаказНаПеремещение.Записать(РежимЗаписиДокумента.Проведение);
			
			АльтерраОбщегоНазначения.СообщитьПользователю(ЗаказНаПеремещение.Ссылка, "Создан: "+ЗаказНаПеремещение.Ссылка);
			
			//Корректируем заказ поставщику
			Объект.Склад = СкладПеремещения;
			Объект.ДокументОснование = ЗаказНаПеремещение.Ссылка;
			ПараметрыТаблицыТовары = ОбеспечениеСервер.ПараметрыТаблицыОстатковПоЗаказу();
			ТаблицаТовары = ОбеспечениеСервер.ТаблицаОстатковКЗаказу(ЗаказНаПеремещение.Ссылка, ПараметрыТаблицыТовары);
			Если ТаблицаТовары.Количество() > 0 Тогда
				Для Каждого стрТовар Из Объект.Товары Цикл
					стрТовар.Склад = Объект.Склад;
					стрТовар.Назначение = ТаблицаТовары[0].Назначение;
				КонецЦикла;
			Иначе 
				Сообщить("Нет товаров к перемещению!", СтатусСообщения.ОченьВажное);
			КонецЕсли;
			
			ЭтаФорма.Модифицированность = Истина;
		Исключение
			Отказ = Истина;
			Сообщить("Не удалось создать перемещение", СтатусСообщения.ОченьВажное);
		КонецПопытки;
	
		Если Не Отказ Тогда
			ЗафиксироватьТранзакцию();
		Иначе
			ОтменитьТранзакцию();
		КонецЕсли;
		
	КонецЕсли; 

КонецПроцедуры
#КонецОбласти

&НаКлиенте
Процедура Расш1__ОформлениеРасхождений(Команда)
	Оповещение = Новый ОписаниеОповещения("ОформлениеРасхожденийЗавершение",ЭтотОбъект); 
	ПараметрыП = Новый Структура("Документ",Объект.Ссылка);
	ОткрытьФорму("ОбщаяФорма.Док_ОформлениеРасхождений",ПараметрыП,ЭтаФорма,,,,Оповещение,);
КонецПроцедуры

&НаКлиенте
Процедура ОформлениеРасхожденийЗавершение(Результат, ДопПараметры) Экспорт
	
	Если Результат = Истина Тогда
		
		Если Объект.Товары.Количество() = 0 Тогда
			ПоказатьПредупреждение(Неопределено, НСтр("ru='Таблица товаров не заполнена.'"));
			Возврат;
		КонецЕсли;
		
		ЕстьНеотмененныеСтроки = Ложь;
		Для Каждого ТекСтрока Из Объект.Товары Цикл
			Если Не ТекСтрока.Отменено Тогда
				ЕстьНеотмененныеСтроки = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если Не ЕстьНеотмененныеСтроки Тогда
			ПоказатьПредупреждение(Неопределено, НСтр("ru='Все строки отменены.'"));
			Возврат;
		КонецЕсли;
		
		ПроверятьОстатки = Истина;
		
		Если Не Объект.Проведен Тогда
			ПроверятьОстатки = Ложь;
		ИначеЕсли Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.НеСогласован")
			Или Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.Согласован")
			Или Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовПоставщикам.Подтвержден") Тогда
			ПроверятьОстатки = Истина;
		КонецЕсли;
		
		ПричинаОтмены = ПредопределенноеЗначение("Справочник.ПричиныОтменыЗаказовПоставщикам.ПустаяСсылка");
		Если ИспользоватьПричиныОтменыЗаказовПоставщикам Тогда
			ОткрытьФорму("Справочник.ПричиныОтменыЗаказовПоставщикам.ФормаВыбора",,,,,, Новый ОписаниеОповещения("ОтменитьНепоставленныеСтрокиЗавершение", ЭтотОбъект, Новый Структура("ПроверятьОстатки", ПроверятьОстатки)), РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
			Возврат;
		КонецЕсли;
		
		ОтменитьНепоставленныеСтрокиФрагмент(ПричинаОтмены, ПроверятьОстатки);
		
	КонецЕсли;  
	
КонецПроцедуры



