&НаСервере
Функция СформироватьСообщениеНаСервере(АдресВременногоХранилища, ПараметрыОтправки, ВидСообщения)
	
	ПараметрыВызоваСервера = Новый Структура();
	ПараметрыВызоваСервера.Вставить("ПараметрыОтправки", ПараметрыОтправки);
	ПараметрыВызоваСервера.Вставить("ВидСообщения",      ВидСообщения);
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.Взаимодействия") Тогда
		МодульВзаимодействия = ОбщегоНазначения.ОбщийМодуль("Взаимодействия");
		ПараметрыОтправки.ДополнительныеПараметры.Вставить("РасширенныйСписокПолучателей", МодульВзаимодействия.ИспользуетсяПрочиеВзаимодействия());
	КонецЕсли;
	СформироватьИОтправить = ПараметрыОтправки.ДополнительныеПараметры.ОтправитьСразу;
	ПроизвольныеПараметры = Новый Соответствие;
	ПараметрыСообщения = ПараметрыОтправки.ДополнительныеПараметры.ПараметрыСообщения;
	ПроизвольныеПараметры.Вставить("ДатаРазгрузки", ПараметрыСообщения.ДатаРазгрузки);
	ПроизвольныеПараметры.Вставить("НомерЗаказаПоставщику", ПараметрыСообщения.НомерЗаказаПоставщику);
	ПроизвольныеПараметры.Вставить("АдресСклада", ПараметрыСообщения.АдресСклада); 
	ПараметрыОтправки.ДополнительныеПараметры.ПроизвольныеПараметры = ПроизвольныеПараметры;
	УстановитьПривилегированныйРежим(Истина);
	ШаблоныСообщенийСлужебный.СформироватьСообщениеВФоне(ПараметрыВызоваСервера, АдресВременногоХранилища, СформироватьИОтправить);
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат АдресВременногоХранилища; 
	
КонецФункции

&НаСервере
Функция СформироватьСписокПолучателей()
	
	МассивКонтакты = Новый Массив;
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ИсточникКонтактнойИнформации");
	СтруктураПараметров.Вставить("Представление");
	СтруктураПараметров.Вставить("Адрес");
	
	СтруктураПараметров.ИсточникКонтактнойИнформации = Объект.Контрагент;
	СтруктураПараметров.Адрес = ПолучитьПочтуКонтрагента(Объект.Контрагент);
	Если СтруктураПараметров.Адрес = "" Тогда
		СтруктураПараметров.ИсточникКонтактнойИнформации = Объект.Партнер;
		СтруктураПараметров.Адрес = АльтерраОбщегоНазначения.ПолучитьПочтуПартнера(Объект.Партнер);
	КонецЕсли;
	СтруктураПараметров.Представление = Строка(Объект.Партнер) + "<" + СтруктураПараметров.Адрес + ">";
	МассивКонтакты.Добавить(СтруктураПараметров);
	
	Возврат МассивКонтакты;
	
КонецФункции 

&НаСервереБезКонтекста
Функция ПолучитьПочтуКонтрагента(Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтрагентыКонтактнаяИнформация.Представление КАК Представление
	|ИЗ
	|	Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|ГДЕ
	|	КонтрагентыКонтактнаяИнформация.Ссылка = &Контрагент
	|	И КонтрагентыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты)";
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Представление;
	КонецЕсли;
	
	Возврат ""; 
	
КонецФункции 
