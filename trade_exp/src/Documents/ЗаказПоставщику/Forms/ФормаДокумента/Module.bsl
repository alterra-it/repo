&НаСервере
Функция ТекстЗапросаПолученияСвязанныхДокументов()
	
	ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СвязанныеДокументы.Ссылка КАК ПриходныйОрдерНаТовары,
		|	ПРЕДСТАВЛЕНИЕ(СвязанныеДокументы.Ссылка) КАК ПредставлениеПриходногоОрдераНаТовары
		|ИЗ
		|	КритерийОтбора.СвязанныеДокументы(&ЗначениеКритерияОтбора) КАК СвязанныеДокументы
		|ГДЕ
		|	СвязанныеДокументы.Ссылка ССЫЛКА Документ.ПриходныйОрдерНаТовары
		|	И СвязанныеДокументы.Ссылка.Проведен";
	
	Возврат ТекстЗапроса;  
	
КонецФункции	

&НаСервере
Функция ПроверитьДоступностьОбновленияБлокировки()
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаПолученияСвязанныхДокументов();  
	Запрос.УстановитьПараметр("ЗначениеКритерияОтбора", Объект.Ссылка);	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Результат = Ложь;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Запрос.УстановитьПараметр("ЗначениеКритерияОтбора", ВыборкаДетальныеЗаписи.ПриходныйОрдерНаТовары);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Документ.ПриходныйОрдерНаТовары", "Документ.БлокировкаДвиженияТоваров");
		Если НЕ Запрос.Выполнить().Пустой() Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции 

