КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСекцию(Результат="Пересчитать", Параметры=Неопределено)  Экспорт
	ТоварыИзменено = Ложь;
	Если Результат <>"НичегоНеДелать" Тогда
		ТекПоток = Поток;
		СекцияИзменилась = Ложь;
		ОпределитьСекциюАвтоматически(ТекПоток, СекцияИзменилась);
		Если СекцияИзменилась Тогда 
			ПредупредитьПользователя("Секция изменилась. Запланируйте новое время в сетке");
			ДанныеПоставкиИзменились = Истина;
		КонецЕсли;
		Если Параметры<>Неопределено и Параметры.Свойство("ПроверкаПередПроведением") ИЛИ Параметры=Неопределено Тогда
			Если Параметры<>Неопределено и Параметры.Свойство("ПроверкаПередПроведением") Тогда
				ПересчитатьПоНормативу(Параметры.ПроверкаПередПроведением);
			Иначе
				ПересчитатьПоНормативу();
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьПоНормативу(ИнтервалНедоступен=Ложь)
	ТекДлительность = ПродолжительностьРазгрузки;
	ЗаполнитьПоНормативу();
	ДанныеПоставкиИзменились = Истина;
	Если ТекДлительность < ПродолжительностьРазгрузки И  ВремяПоступления <> '00010101000000' и ПродолжительностьРазгрузки<>0 Тогда
		//Проверить интервал может ли располагаться в текущих границах
		РезультатПроверки =  ПроверитьТекущийИнтервалНаДоступность();
		Если НЕ РезультатПроверки.ИнтервалДоступен Тогда
			Сообщить("Из-за изменения таблицы товаров, интервал был увеличен. Необходимо выбрать время начала разгрузки вручную");
			Если РезультатПроверки.СброситьВремя Тогда
				ВремяПоступления = '00010101000000';
				Поток = ПредопределенноеЗначение("Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры // ПересчитатьПоНормативу()

//возвращает структуру с полями  ИнтервалДоступен и  СброситьВремя
&НаСервере
Функция ПроверитьТекущийИнтервалНаДоступность()
	
	РезультатПроверки = Новый Структура;
	РезультатПроверки.Вставить("ИнтервалДоступен", Истина);
	РезультатПроверки.Вставить("СброситьВремя", Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЧ.Ресурс КАК Оборудование,
	|	ТЧ.ТребуемоеКоличество КАК ТребуемоеКоличество
	|ПОМЕСТИТЬ втРесурсыДокумента
	|ИЗ
	|	&СписокОборудования КАК ТЧ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК НачалоИнтервала,
	|	ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки) КАК КонецИнтервала,
	|	ЕСТЬNULL(ГрафикПоставокНаСкладСрезПоследних.КоличествоИспользуется, 0) КАК КоличествоИспользуется,
	|	ГрафикПоставокНаСкладСрезПоследних.Оборудование КАК Оборудование,
	|	ЕСТЬNULL(ТехническиеРесурсыСкладов.ДопустимоеКоличество, 0) КАК ДопустимоеКоличество,
	|	ЕСТЬNULL(втРесурсыДокумента.ТребуемоеКоличество, 0) КАК ТребуемоеКоличество,
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику КАК ЗаказПоставщику
	|ПОМЕСТИТЬ втИнтервалыЗакрытияОборудование
	|ИЗ
	|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних(
	|			,
	|			Оборудование В (&СписокОборудования)
	|				И ЗаказПоставщику.Склад = &Склад
	|				И ( НачалоПериода(ДатаВремяРазгрузкиПлан, День) = &Период) 
	|				И ПродолжительностьРазгрузки > 0) КАК ГрафикПоставокНаСкладСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТехническиеРесурсыСкладов КАК ТехническиеРесурсыСкладов
	|		ПО ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику.Склад = ТехническиеРесурсыСкладов.Склад
	|			И ГрафикПоставокНаСкладСрезПоследних.Оборудование = ТехническиеРесурсыСкладов.Оборудование
	|		ЛЕВОЕ СОЕДИНЕНИЕ втРесурсыДокумента КАК втРесурсыДокумента
	|		ПО ГрафикПоставокНаСкладСрезПоследних.Оборудование = втРесурсыДокумента.Оборудование
	|ГДЕ
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику <> &ЗаказПоставщику
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику  КАК ЗаказПоставщику, ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан Как НачалоИнтервала, ДОБАВИТЬКДАТЕ( ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, Минута, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки)  как КонецИнтервала
	|ИЗ
	|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних(
	|			,
	|			 ( НачалоПериода(ДатаВремяРазгрузкиПлан, День) = &Период)
	|				И НАЧАЛОПЕРИОДА(ДатаВремяРазгрузкиПлан, ДЕНЬ) = &ДатаРазгрузки
	|				И Поток = &Поток И ЗаказПоставщику <> &ЗаказПоставщику) КАК ГрафикПоставокНаСкладСрезПоследних
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	втИнтервалыЗакрытияОборудование.ЗаказПоставщику, втИнтервалыЗакрытияОборудование.НачалоИнтервала,  втИнтервалыЗакрытияОборудование.КонецИнтервала
	|ИЗ
	|	втИнтервалыЗакрытияОборудование КАК втИнтервалыЗакрытияОборудование
	|ГДЕ
	|	 НАЧАЛОПЕРИОДА(втИнтервалыЗакрытияОборудование.НачалоИнтервала, ДЕНЬ) = &ДатаРазгрузки";
	
	Запрос.УстановитьПараметр("ДатаРазгрузки", ДатаРазгрузки);
	Запрос.УстановитьПараметр("Период", ДатаРазгрузки);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("СписокОборудования", ТребуемоеОборудование.Выгрузить());
	Запрос.УстановитьПараметр("ЗаказПоставщику", Объект.Ссылка);
	Запрос.УстановитьПараметр("Поток", Поток);
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	НачалоИнтервала = ДатаРазгрузки + (Час(ВремяПоступления)*3600+ Минута(ВремяПоступления)*60);
	КонецИнтервала = ДатаРазгрузки + (Час(ВремяПоступления)*3600+ Минута(ВремяПоступления)*60+ПродолжительностьРазгрузки*60); 
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ПроверкиАльтерраСервер.ИнтервалПопалВПромежуток(НачалоИнтервала, КонецИнтервала, ВыборкаДетальныеЗаписи.НачалоИнтервала, ВыборкаДетальныеЗаписи.КонецИнтервала) ИЛИ ПроверкиАльтерраСервер.ИнтервалПопалВПромежуток(ВыборкаДетальныеЗаписи.НачалоИнтервала, ВыборкаДетальныеЗаписи.КонецИнтервала, НачалоИнтервала, КонецИнтервала) Тогда
			РезультатПроверки.ИнтервалДоступен = Ложь;
			РезультатПроверки.СброситьВремя = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	 ДобавитьКДате(ДобавитьКДате(РасписаниеСкладскихПотоковСрезПоследних.ДатаДоставки, час, Час(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)), минута, минута(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)) КАК НачалоИнтервала,
	|	ДобавитьКДате(ДобавитьКДате(РасписаниеСкладскихПотоковСрезПоследних.ДатаДоставки, час, Час(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)), минута, минута(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)+ РасписаниеСкладскихПотоковСрезПоследних.ПродолжительностьИнтервала) как КонецИнтервала 
	|ИЗ
	|	РегистрСведений.РасписаниеСкладскихПотоков.СрезПоследних(
	|			,
	|			ДатаДоставки = &Период
	|				И Поток = &Поток) КАК РасписаниеСкладскихПотоковСрезПоследних";
	Запрос.УстановитьПараметр("Поток", Поток);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаИнтервалов = Результат.Выбрать();
	
	НачалоЗакрытогоИнтервала = НачалоДня(ДатаРазгрузки);
	КонецЗакрытогоИнтервала = НачалоЗакрытогоИнтервала;
	Пока ВыборкаИнтервалов.Следующий() Цикл 
		Если НачалоЗакрытогоИнтервала = КонецЗакрытогоИнтервала Тогда
			КонецЗакрытогоИнтервала = ВыборкаИнтервалов.НачалоИнтервала;
		КонецЕсли;
		Если ПроверкиАльтерраСервер.ИнтервалПопалВПромежуток(НачалоИнтервала, КонецИнтервала, НачалоЗакрытогоИнтервала, КонецЗакрытогоИнтервала) ИЛИ ПроверкиАльтерраСервер.ИнтервалПопалВПромежуток(НачалоЗакрытогоИнтервала, КонецЗакрытогоИнтервала, НачалоИнтервала, КонецИнтервала) Тогда
			РезультатПроверки.ИнтервалДоступен = Ложь;
		КонецЕсли;
		НачалоЗакрытогоИнтервала = ВыборкаИнтервалов.КонецИнтервала;
		КонецЗакрытогоИнтервала = НачалоЗакрытогоИнтервала;
	КонецЦикла;
	
	КонецЗакрытогоИнтервала = КонецДня(НачалоЗакрытогоИнтервала);
	Если ПроверкиАльтерраСервер.ИнтервалПопалВПромежуток(НачалоИнтервала, КонецИнтервала, НачалоЗакрытогоИнтервала, КонецЗакрытогоИнтервала) ИЛИ ПроверкиАльтерраСервер.ИнтервалПопалВПромежуток(НачалоЗакрытогоИнтервала, КонецЗакрытогоИнтервала, НачалоИнтервала, КонецИнтервала) Тогда
		РезультатПроверки.ИнтервалДоступен = Ложь;
	КонецЕсли;
	
	Возврат РезультатПроверки; 
	
КонецФункции 

&НаСервере
Процедура СформироватьЗапросДляРасчетаСекцииИВремениПоНормативу()
	АдресЗапросаКоэффициентыТоваров = Альтерра_СеткаПоставок.ЗапросПоТЗВесОбъем(Объект.Товары.Выгрузить(), Объект.Ссылка);
КонецПроцедуры 

&НаСервере
Процедура ОпределитьСекциюАвтоматически(ТекПоток, СекцияИзменилась=Ложь)
	
	Если АдресЗапросаКоэффициентыТоваров = "" Тогда
		СформироватьЗапросДляРасчетаСекцииИВремениПоНормативу();
	КонецЕсли;
	Запрос = ПолучитьИзВременногоХранилища(АдресЗапросаКоэффициентыТоваров).Запрос;
	
	Если СтрНайти(Запрос.Текст, "втНоменклатураПоСекциям") = 0 Тогда
		Запрос.Текст =  Запрос.Текст + 
		"; ВЫБРАТЬ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура КАК Номенклатура,
		|	СкладскиеЯчейки.РабочийУчасток КАК Секция
		|ПОМЕСТИТЬ втНоменклатураПоСекциям
		|ИЗ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
		|		ПО РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка = СкладскиеЯчейки.Ссылка
		|ГДЕ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура В
		|			(ВЫБРАТЬ
		|				втНоменклатураДокумента.Номенклатура
		|			ИЗ
		|				втНоменклатураДокумента КАК втНоменклатураДокумента)
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
		|";
	КонецЕсли;
		Запрос.Текст =  Запрос.Текст + 
		";
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Итог.Секция КАК Секция,
		|	Итог.ОбъемПоСекции КАК ОбъемПоСекции
		|ИЗ
		|	(ВЫБРАТЬ
		|		втНоменклатураПоСекциям.Секция КАК Секция,
		|		СУММА(втНоменклатураДокумента.КоличествоУпаковок * втНоменклатураДокумента.ОбъемКоэффициентНоменклатура) КАК ОбъемПоСекции
		|	ИЗ
		|		втНоменклатураДокумента КАК втНоменклатураДокумента
		|			ЛЕВОЕ СОЕДИНЕНИЕ втНоменклатураПоСекциям КАК втНоменклатураПоСекциям
		|			ПО втНоменклатураДокумента.Номенклатура = втНоменклатураПоСекциям.Номенклатура
		|	 	ГДЕ
		|	НЕ втНоменклатураПоСекциям.Секция ЕСТЬ NULL
		|	СГРУППИРОВАТЬ ПО
		|		втНоменклатураПоСекциям.Секция) КАК Итог
		|ИТОГИ
		|	МАКСИМУМ(ОбъемПоСекции) 
		|ПО
		|	ОБЩИЕ";
		Запрос.УстановитьПараметр("Склад", Объект.Склад);
		УстановитьПривилегированныйРежим(Истина);
		Результат = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
	 ВыборкаИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	 
	 Если ВыборкаИтог.Следующий() Тогда
		 Выборка = ВыборкаИтог.Выбрать();
		 Пока  Выборка.Следующий() Цикл
			 Если ВыборкаИтог.ОбъемПоСекции = Выборка.ОбъемПоСекции Тогда
				 СекцияБыла = Объект.Секция;
				 Объект.Секция = Выборка.Секция;
				 
				 Если СекцияБыла <> Объект.Секция И ТекПоток.Секции.Найти(Объект.Секция) = Неопределено Тогда
					 Поток = Справочники.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка(); 		
					 ВремяПоступления = '00010101000000';
					 СекцияИзменилась = Истина;
				 КонецЕсли;
				 
				 Модифицированность = Истина;
				 Прервать;	 
			 КонецЕсли;
		 КонецЦикла;
	 КонецЕсли;
	 
КонецПроцедуры // ОпределитьСекциюАвтоматически()

&НаСервере
Процедура ЗаписатьИнтервалДоставкиСервер()
	
	Если ДанныеПоставкиИзменились И Альтерра_СеткаПоставок.ЕстьСекцииУСклада(Объект.Склад) И НЕ ЭтоТорговыйЗал() Тогда
		ПараметрыЗаписи = Новый Соответствие;
		ЗначениеПараметров = Новый Структура;
		ЗначениеПараметров.Вставить("Поток", Поток);
		ЗначениеПараметров.Вставить("ДатаВремяРазгрузкиПлан", ДатаРазгрузки + Минута(ВремяПоступления)*60 + Час(ВремяПоступления)*3600);
		ЗначениеПараметров.Вставить("ПродолжительностьРазгрузки", ПродолжительностьРазгрузки);
		ЗначениеПараметров.Вставить("СогласованоСоСкладом", СогласованоСоСкладом);
		ЗначениеПараметров.Вставить("ТекстПоставки", ПримечаниеКПоставке);
		Если ТребуемоеОборудование.Количество() > 0 Тогда
			ПараметрыОборудования = Новый Соответствие;
			Для каждого СтрОборудования из ТребуемоеОборудование Цикл
				ПараметрыОборудования.Вставить(СтрОборудования.Ресурс, СтрОборудования.ТребуемоеКоличество);
			КонецЦикла;
			ЗначениеПараметров.Вставить("Оборудование", ПараметрыОборудования);
		КонецЕсли;
		ПараметрыЗаписи.Вставить(Объект.Ссылка, ЗначениеПараметров);
		Альтерра_СеткаПоставок.ИзменитьДанныеСеткиПоставок(Объект.Ссылка, "Новое",  ПараметрыЗаписи, Истина);
	КонецЕсли; 
	
КонецПроцедуры 

&НаКлиенте
Процедура ОбновитьДанныеПоставкиПослеЗакрытияПланировщика(Результат=Неопределено, ДополнительныеПараметры=Неопределено) Экспорт
	 ОбновитьВремяИИнтервалПоставки();
КонецПроцедуры

&НаСервере
Процедура ОбновитьВремяИИнтервалПоставки() 
	
	Если  ЗначениеЗаполнено(Параметры.Ключ) Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки КАК ПродолжительностьРазгрузки,
		|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК ДатаВремяРазгрузкиПлан,
		|	ГрафикПоставокНаСкладСрезПоследних.Оборудование КАК Ресурс,
		|	ГрафикПоставокНаСкладСрезПоследних.СогласованоСоСкладом КАК СогласованоСоСкладом,
		|	ГрафикПоставокНаСкладСрезПоследних.КоличествоИспользуется КАК ТребуемоеКоличество,
		|	ГрафикПоставокНаСкладСрезПоследних.ТекстПоставки КАК ТекстПоставки,
		|	ГрафикПоставокНаСкладСрезПоследних.Поток КАК Поток
		|ИЗ
		|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних(, ЗаказПоставщику = &ЗаказПоставщику) КАК ГрафикПоставокНаСкладСрезПоследних";
		Запрос.УстановитьПараметр("ЗаказПоставщику", Объект.Ссылка);
		УстановитьПривилегированныйРежим(Истина);
		Результат = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
		Выборка = Результат.Выбрать();
		ТребуемоеОборудование.Очистить();
		Пока Выборка.Следующий() Цикл
			ДатаРазгрузки = Выборка.ДатаВремяРазгрузкиПлан;
			ПродолжительностьРазгрузки = Выборка.ПродолжительностьРазгрузки;
			ВремяПоступления = Выборка.ДатаВремяРазгрузкиПлан;
			Поток = Выборка.Поток;
			ПримечаниеКПоставке = Выборка.ТекстПоставки;
			Если  ЗначениеЗаполнено(Выборка.Ресурс) Тогда
				СтрОборудования = ТребуемоеОборудование.Добавить();
				ЗаполнитьЗначенияСвойств(СтрОборудования, Выборка);
			КонецЕсли;
			СогласованоСоСкладом = Выборка.СогласованоСоСкладом;
		КонецЦикла;
	КонецЕсли;
	
	Если ДатаРазгрузки = '00010101' Тогда
		ВремяПрибытияРейса = ДатаРазгрузки; 
		Если ЕстьРейсПоПоставке(ВремяПрибытияРейса) Тогда
			ДатаРазгрузки = ВремяПрибытияРейса;
		Иначе
			ДатаРазгрузки = Объект.ДатаПоступления;
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура РассчитатьВремяАвтоматически()
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПотокиТранспортныхСредствПоставкиНаСкладСекции.Ссылка КАК Ссылка,
	|	ВЫБОР
	|		КОГДА ПотокиТранспортныхСредствПоставкиНаСкладСекции.Секция = &Секция
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ПотокСекции
	|ПОМЕСТИТЬ втДоступныеПотоки
	|ИЗ
	|	Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.Секции КАК ПотокиТранспортныхСредствПоставкиНаСкладСекции
	|ГДЕ
	|	ПотокиТранспортныхСредствПоставкиНаСкладСекции.Секция.Владелец = &Склад
	|	И ПотокиТранспортныхСредствПоставкиНаСкладСекции.Ссылка.ПотокАктивный = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НормыВремени.НачалоИнтервала КАК НачалоИнтервала,
	|	ДОБАВИТЬКДАТЕ(НормыВремени.НачалоИнтервала, МИНУТА, НормыВремени.ПродолжительностьИнтервала) КАК КонецИнтервала,
	|	НормыВремени.Поток КАК Поток
	|ПОМЕСТИТЬ втНормыВремени
	|ИЗ
	|	(ВЫБРАТЬ
	|		ДОБАВИТЬКДАТЕ(ДОБАВИТЬКДАТЕ(&Период, ЧАС, ЧАС(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)), МИНУТА, МИНУТА(РасписаниеСкладскихПотоковСрезПоследних.НачалоИнтервала)) КАК НачалоИнтервала,
	|		РасписаниеСкладскихПотоковСрезПоследних.ПродолжительностьИнтервала КАК ПродолжительностьИнтервала,
	|		РасписаниеСкладскихПотоковСрезПоследних.Поток КАК Поток
	|	ИЗ
	|		РегистрСведений.РасписаниеСкладскихПотоков.СрезПоследних(
	|				,
	|				ДатаДоставки = &Период
	|					И Поток В
	|						(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|							втДоступныеПотоки.Ссылка КАК Ссылка
	|						ИЗ
	|							втДоступныеПотоки КАК втДоступныеПотоки)) КАК РасписаниеСкладскихПотоковСрезПоследних) КАК НормыВремени
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ГрафикПоставокНаСкладСрезПоследних.ДатаВремяПриездаФакт <> ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан
	|			ТОГДА ГрафикПоставокНаСкладСрезПоследних.ДатаВремяПриездаФакт
	|		ИНАЧЕ ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан
	|	КОНЕЦ КАК ВремяНачалаПлан,
	|	ВЫБОР
	|		КОГДА ГрафикПоставокНаСкладСрезПоследних.ДатаВремяПриездаФакт <> ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан
	|			ТОГДА ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяПриездаФакт, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки)
	|		ИНАЧЕ ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки)
	|	КОНЕЦ КАК ВремяКонцаПлан,
	|	втНормыВремени.Поток КАК Поток,
	|	втНормыВремени.НачалоИнтервала КАК НачалоИнтервала,
	|	втНормыВремени.КонецИнтервала КАК КонецИнтервала,
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику КАК ЗаказПоставщику,
	|	ГрафикПоставокНаСкладСрезПоследних.Оборудование КАК Оборудование,
	|	ГрафикПоставокНаСкладСрезПоследних.КоличествоИспользуется КАК КоличествоИспользуется
	|ПОМЕСТИТЬ втВремяНормФакт
	|ИЗ
	|	втНормыВремени КАК втНормыВремени
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних(
	|				,
	|				Поток.Секция.Владелец = &Склад
	|					И ЗаказПоставщику <> &ЗаказПоставщику
	|					И НАЧАЛОПЕРИОДА(ДатаВремяРазгрузкиПлан, ДЕНЬ) = &Период) КАК ГрафикПоставокНаСкладСрезПоследних
	|		ПО (ГрафикПоставокНаСкладСрезПоследних.Поток = втНормыВремени.Поток)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втВремяНормФакт.ЗаказПоставщику КАК ЗаказПоставщику,
	|	втВремяНормФакт.Оборудование КАК Оборудование,
	|	втВремяНормФакт.КоличествоИспользуется КАК КоличествоИспользуется,
	|	втВремяНормФакт.ЗаказПоставщику.Склад КАК ЗаказПоставщикуСклад,
	|	втВремяНормФакт.Поток КАК Поток
	|ПОМЕСТИТЬ втДоступноеОборудованиеНаСкладе
	|ИЗ
	|	втВремяНормФакт КАК втВремяНормФакт
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЕСТЬNULL(втВремяНормФакт.ВремяНачалаПлан, втВремяНормФакт.НачалоИнтервала) КАК ВремяНачала,
	|	ЕСТЬNULL(втВремяНормФакт.ВремяКонцаПлан, втВремяНормФакт.НачалоИнтервала) КАК ВремяКонца,
	|	втДоступныеПотоки.Ссылка КАК Поток,
	|	втВремяНормФакт.ВремяНачалаПлан КАК ВремяНачалаПлан,
	|	втВремяНормФакт.НачалоИнтервала КАК НачалоИнтервала,
	|	втВремяНормФакт.КонецИнтервала КАК КонецИнтервала,
	|	МАКСИМУМ(втДоступныеПотоки.ПотокСекции) КАК ПотокСекции,
	|	втВремяНормФакт.ЗаказПоставщику КАК ЗаказПоставщику
	|ПОМЕСТИТЬ втИтогПоПотокам
	|ИЗ
	|	втДоступныеПотоки КАК втДоступныеПотоки
	|		ЛЕВОЕ СОЕДИНЕНИЕ втВремяНормФакт КАК втВремяНормФакт
	|		ПО втДоступныеПотоки.Ссылка = втВремяНормФакт.Поток
	|ГДЕ
	|	ЕСТЬNULL(втВремяНормФакт.ВремяКонцаПлан, втВремяНормФакт.НачалоИнтервала) >= втВремяНормФакт.НачалоИнтервала
	|	И ЕСТЬNULL(втВремяНормФакт.ВремяНачалаПлан, втВремяНормФакт.НачалоИнтервала) <= втВремяНормФакт.КонецИнтервала
	|
	|СГРУППИРОВАТЬ ПО
	|	втДоступныеПотоки.Ссылка,
	|	втВремяНормФакт.ВремяНачалаПлан,
	|	втВремяНормФакт.НачалоИнтервала,
	|	втВремяНормФакт.КонецИнтервала,
	|	ЕСТЬNULL(втВремяНормФакт.ВремяКонцаПлан, втВремяНормФакт.НачалоИнтервала),
	|	втВремяНормФакт.ЗаказПоставщику
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втИтогПоПотокам.ВремяНачала КАК ВремяНачала,
	|	втИтогПоПотокам.ВремяКонца КАК ВремяКонца,
	|	втИтогПоПотокам.Поток КАК Поток,
	|	втИтогПоПотокам.ВремяНачалаПлан КАК ВремяНачалаПлан,
	|	втИтогПоПотокам.НачалоИнтервала КАК НачалоИнтервала,
	|	втИтогПоПотокам.КонецИнтервала КАК КонецИнтервала,
	|	втИтогПоПотокам.ПотокСекции КАК ПотокСекции
	|ИЗ
	|	втИтогПоПотокам КАК втИтогПоПотокам
	|
	|УПОРЯДОЧИТЬ ПО
	|	втИтогПоПотокам.ПотокСекции Убыв,
	|	втИтогПоПотокам.Поток,
	|	втИтогПоПотокам.НачалоИнтервала,
	|	втИтогПоПотокам.ВремяНачалаПлан
	|ИТОГИ
	|	МИНИМУМ(ВремяНачала),
	|	МАКСИМУМ(ВремяКонца),
	|	МИНИМУМ(ВремяНачалаПлан),
	|	МАКСИМУМ(НачалоИнтервала),
	|	МАКСИМУМ(КонецИнтервала),
	|	МАКСИМУМ(ПотокСекции)
	|ПО
	|	Поток" ;
	
	Запрос.УстановитьПараметр("Период", Объект.ДатаПоступления);
	Запрос.УстановитьПараметр("ЗаказПоставщику", Объект.Ссылка);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Секция", Объект.Секция);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаПоток = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Поток");
	
	ПредыдущийПоток = Неопределено;
	Поток = Справочники.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка();
	СогласованоСоСкладом = Истина;
	
	ТЗЗанятыеИнтервалы = Новый ТаблицаЗначений;
	ТЗЗанятыеИнтервалы.Колонки.Добавить("ВремяНачала", Новый ОписаниеТипов("Дата"));
	ТЗЗанятыеИнтервалы.Колонки.Добавить("ВремяКонца", Новый ОписаниеТипов("Дата"));
	ТЗЗанятыеИнтервалы.Колонки.Добавить("Поток", Новый ОписаниеТипов("СправочникСсылка.ПотокиТранспортныхСредствПоставкиНаСклад"));
	ТЗЗанятыеИнтервалы.Колонки.Добавить("НачалоИнтервала", Новый ОписаниеТипов("Дата"));
	ТЗЗанятыеИнтервалы.Колонки.Добавить("КонецИнтервала", Новый ОписаниеТипов("Дата"));
	
	ИзмененныйРесурс = Неопределено;
	ИзмененноеКоличествоРесурса = Неопределено;
	Если АдресИзмененнойСтрокиТребуемогоОборудования <> "" Тогда 
		ИзмененныеДанныеРесурса = ПолучитьИзВременногоХранилища(АдресИзмененнойСтрокиТребуемогоОборудования);
		ИзмененныйРесурс = ИзмененныеДанныеРесурса.Ресурс;
		ИзмененноеКоличествоРесурса = ИзмененныеДанныеРесурса.КоличествоТекущее;
		АдресИзмененнойСтрокиТребуемогоОборудования = "";
	КонецЕсли;
	//формируем неупорядоченную таблицу занятых интервалов
	МассивПотоковСекции = Новый Массив;
	Пока ВыборкаПоток.Следующий() Цикл
		//занятые интервалы по времени и потокам
		ВыборкаДетали = ВыборкаПоток.Выбрать();
		Пока ВыборкаДетали.Следующий() Цикл
			Если ВыборкаПоток.ПотокСекции = 1 Тогда
				Стр = ТЗЗанятыеИнтервалы.Добавить();
				ЗаполнитьЗначенияСвойств(Стр, ВыборкаДетали);
			КонецЕсли;
		КонецЦикла;
		Если ВыборкаПоток.ПотокСекции=1 Тогда
			ДанныеПотока = Новый Структура;
			ДанныеПотока.Вставить("Поток", ВыборкаПоток.Поток);
			ДанныеПотока.Вставить("НачалоИнтервала", ВыборкаПоток.НачалоИнтервала);
			ДанныеПотока.Вставить("КонецИнтервала", ВыборкаПоток.КонецИнтервала);
			МассивПотоковСекции.Добавить(ДанныеПотока);
		КонецЕсли;
		
		//проверка на ресурсы -------
		РезультатЗапросаПоРесурсам = Неопределено;
		Если ТребуемоеОборудование.Количество() > 0 Тогда
			РезультатЗапросаПоРесурсам = ПолучитьИзВременногоХранилища(ПолучитьТаблицуИнтерваловЗанятогоПоСкладуОборудования(ВыборкаПоток.НачалоИнтервала, ВыборкаПоток.КонецИнтервала)).Результат; 
		КонецЕсли;
		Если РезультатЗапросаПоРесурсам<>Неопределено Тогда
			ВыборкаОборудование = РезультатЗапросаПоРесурсам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Оборудование");
			//к занятым интервалам добавляем занятые по складу интервалы
			ПредыдущийИнтервал =Неопределено; 				
			Пока ВыборкаОборудование.Следующий() Цикл			
				ВыборкаДеталиОборудование = ВыборкаОборудование.Выбрать();
				Пока ВыборкаДеталиОборудование.Следующий() Цикл 
					Если ПредыдущийИнтервал = Неопределено Тогда
						ПредыдущийИнтервал = Новый Структура;
						ПредыдущийИнтервал.Вставить("Начало", ВыборкаДеталиОборудование.НачалоИнтервала);
						ПредыдущийИнтервал.Вставить("Конец", ВыборкаДеталиОборудование.КонецИнтервала);
						ПредыдущийИнтервал.Вставить("Количество", ВыборкаДеталиОборудование.КоличествоИспользуется);
					Иначе
						//вносим интервал в таблицу
						
						//учем, если была изменена ТЧ ресурсов
						Если ИзмененноеКоличествоРесурса <> Неопределено И ИзмененныйРесурс = ВыборкаОборудование.Оборудование Тогда
							ТребуемоеКоличество = ИзмененноеКоличествоРесурса;
						Иначе
							ТребуемоеКоличество = ВыборкаОборудование.ТребуемоеКоличество;
						КонецЕсли;
						
						//2 ситуации:
						Если ПредыдущийИнтервал.Начало < ВыборкаДеталиОборудование.НачалоИнтервала И ПредыдущийИнтервал.Конец < ВыборкаДеталиОборудование.КонецИнтервала Тогда   
							//предыдущий интервал и текущий не пересекаются
							//если количество по предыдущему интервалу позволяет задействовать ещё один ресурс, то интервал считается свободным и не вносится в таблицу
							//иначе интервал вносится в заблокированные
							Если (ВыборкаОборудование.ДопустимоеКоличество - ПредыдущийИнтервал.Количество - ТребуемоеКоличество) < 0 Тогда
								Для каждого ПотокСекции из МассивПотоковСекции Цикл
									ЗанятыйИнтервал = ТЗЗанятыеИнтервалы.Добавить();
									ЗанятыйИнтервал.Поток = ПотокСекции.Поток; 
									ЗанятыйИнтервал.НачалоИнтервала =  ПотокСекции.НачалоИнтервала;
									ЗанятыйИнтервал.КонецИнтервала =  ПотокСекции.КонецИнтервала;
									ЗанятыйИнтервал.ВремяНачала = ПредыдущийИнтервал.Начало;
									ЗанятыйИнтервал.ВремяКонца = ПредыдущийИнтервал.Конец;
								КонецЦикла;
							КонецЕсли;
							ПредыдущийИнтервал = Новый Структура;
							ПредыдущийИнтервал.Вставить("Начало", ВыборкаДеталиОборудование.НачалоИнтервала);
							ПредыдущийИнтервал.Вставить("Конец", ВыборкаДеталиОборудование.КонецИнтервала);
							ПредыдущийИнтервал.Вставить("Количество", ВыборкаДеталиОборудование.КоличествоИспользуется);
						Иначе
							//предыдущий интервал пересекает текущий
							//любое пересечение разбивает два интервала на 2-3 подинтервала. Необходимо рассматривать их как отдельные интервалы 
							
							//Первый подинтервал
							НачалоПервогоИнтервала = ПредыдущийИнтервал.Начало; //т.к. у нас шло упорядочевание по возрастанию даты начала, а затем даты конца, то минимальное значение будет таким
							Если  НачалоПервогоИнтервала <> ВыборкаДеталиОборудование.НачалоИнтервала Тогда 
								КонецПервогоИнтервала = Мин(ВыборкаДеталиОборудование.НачалоИнтервала, ПредыдущийИнтервал.Конец);
							Иначе
								КонецПервогоИнтервала = Мин(ВыборкаДеталиОборудование.КонецИнтервала, ПредыдущийИнтервал.Конец);
							КонецЕсли;
							
							//определяем степень пересечения
							Если НачалоПервогоИнтервала = ВыборкаДеталиОборудование.НачалоИнтервала Тогда
								КоличествоВПервомИнтервале = ПредыдущийИнтервал.Количество + ВыборкаДеталиОборудование.КоличествоИспользуется;
							Иначе
								КоличествоВПервомИнтервале = ПредыдущийИнтервал.Количество;
							КонецЕсли;
							
							Если  (ВыборкаОборудование.ДопустимоеКоличество - КоличествоВПервомИнтервале - ТребуемоеКоличество) < 0 Тогда
								Для каждого ПотокСекции из МассивПотоковСекции Цикл
									ЗанятыйИнтервал = ТЗЗанятыеИнтервалы.Добавить();
									ЗанятыйИнтервал.Поток = ПотокСекции.Поток; 
									ЗанятыйИнтервал.НачалоИнтервала =  ПотокСекции.НачалоИнтервала;
									ЗанятыйИнтервал.КонецИнтервала =  ПотокСекции.КонецИнтервала;
									ЗанятыйИнтервал.ВремяНачала = НачалоПервогоИнтервала;
									ЗанятыйИнтервал.ВремяКонца = КонецПервогоИнтервала;
								КонецЦикла;
							КонецЕсли;
							
							//Второй подинтервал
							НачалоВторогоИнтервала = КонецПервогоИнтервала;
							КонецВторогоИнтервала = Мин(ПредыдущийИнтервал.Конец, ВыборкаДеталиОборудование.КонецИнтервала);
							Если НачалоВторогоИнтервала = ВыборкаДеталиОборудование.КонецИнтервала Тогда
								КоличествоВоВторомИнтервале = ПредыдущийИнтервал.Количество; 
							Иначе
								КоличествоВоВторомИнтервале = ПредыдущийИнтервал.Количество + ВыборкаДеталиОборудование.КоличествоИспользуется;
							КонецЕсли;
							
							Если (ВыборкаОборудование.ДопустимоеКоличество - КоличествоВоВторомИнтервале - ТребуемоеКоличество) < 0 Тогда
								Для каждого ПотокСекции из МассивПотоковСекции Цикл
									ЗанятыйИнтервал = ТЗЗанятыеИнтервалы.Добавить();
									ЗанятыйИнтервал.Поток = ПотокСекции.Поток; 
									ЗанятыйИнтервал.НачалоИнтервала =  ПотокСекции.НачалоИнтервала;
									ЗанятыйИнтервал.КонецИнтервала =  ПотокСекции.КонецИнтервала;
									ЗанятыйИнтервал.ВремяНачала = НачалоВторогоИнтервала;
									ЗанятыйИнтервал.ВремяКонца = КонецВторогоИнтервала;
								КонецЦикла;
							КонецЕсли;
							
							//Третий подинтервал (которого может и не быть)
							Если  НачалоВторогоИнтервала <> ВыборкаДеталиОборудование.КонецИнтервала Тогда
								НачалоТретьегоИнтервала = КонецВторогоИнтервала; 
								КонецТретьегоИнтервала = Макс(ПредыдущийИнтервал.Конец, ВыборкаДеталиОборудование.КонецИнтервала);
								Если КонецВторогоИнтервала = ВыборкаДеталиОборудование.КонецИнтервала Тогда
									КоличествоВТретьемИнтервале = ПредыдущийИнтервал.Количество;
								Иначе
									КоличествоВТретьемИнтервале = ВыборкаДеталиОборудование.КоличествоИспользуется;
								КонецЕсли;
								
								Если  (ВыборкаОборудование.ДопустимоеКоличество - КоличествоВТретьемИнтервале - ТребуемоеКоличество) < 0 Тогда
									Для каждого ПотокСекции из МассивПотоковСекции Цикл
										ЗанятыйИнтервал = ТЗЗанятыеИнтервалы.Добавить();
										ЗанятыйИнтервал.Поток = ПотокСекции.Поток; 
										ЗанятыйИнтервал.НачалоИнтервала =  ПотокСекции.НачалоИнтервала;
										ЗанятыйИнтервал.КонецИнтервала =  ПотокСекции.КонецИнтервала;
										ЗанятыйИнтервал.ВремяНачала = НачалоТретьегоИнтервала;
										ЗанятыйИнтервал.ВремяКонца = КонецТретьегоИнтервала;
									КонецЦикла;	
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;	
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		// ------- проверка на ресурсы
	КонецЦикла;
	
	//убираем повторяющиеся строки
	//упорядочеваем таблицу в запросе, пересекаем интервалы алгоритмом
	ЗапросТЗ = Новый Запрос;
	ЗапросТЗ.Текст = 
	"ВЫБРАТЬ
	|	втТЗ.ВремяНачала КАК ВремяНачала,
	|	втТЗ.ВремяКонца КАК ВремяКонца,
	|	втТЗ.Поток КАК Поток,
	|	втТЗ.НачалоИнтервала КАК НачалоИнтервала,
	|	втТЗ.КонецИнтервала КАК КонецИнтервала
	|ПОМЕСТИТЬ втТЗ
	|ИЗ
	|	&ТЗ КАК втТЗ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	втТЗ.ВремяНачала КАК ВремяНачала,
	|	втТЗ.ВремяКонца КАК ВремяКонца,
	|	втТЗ.Поток КАК Поток,
	|	втТЗ.НачалоИнтервала КАК НачалоИнтервала,
	|	втТЗ.КонецИнтервала КАК КонецИнтервала
	|ИЗ
	|	втТЗ КАК втТЗ
	|где втТЗ.ВремяНачала<> втТЗ.ВремяКонца
	|УПОРЯДОЧИТЬ ПО
	|	втТЗ.Поток,
	|	втТЗ.ВремяНачала,
	|	втТЗ.ВремяКонца";
	ЗапросТЗ.УстановитьПараметр("ТЗ", ТЗЗанятыеИнтервалы);
	ТЗЗанятыеИнтервалы = ЗапросТЗ.Выполнить().Выгрузить();
		
	//из полученной таблицы извлекаем доступные интервалы открытого промежутка расписания
	Если ТЗЗанятыеИнтервалы.Количество()=0 Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ
		|втНормыВремени.НачалоИнтервала КАК НачалоИнтервала,
		|втНормыВремени.КонецИнтервала КАК КонецИнтервала,
		|втНормыВремени.Поток КАК Поток
		|ИЗ
		|	втНормыВремени КАК втНормыВремени
		|	левое соединение
		|	втДоступныеПотоки КАК втДоступныеПотоки
		|по втНормыВремени.Поток=втДоступныеПотоки.Ссылка	
		|где 
		|втДоступныеПотоки.ПотокСекции = 1";
		УстановитьПривилегированныйРежим(Истина);
		Результат = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
		Выборка = Результат.Выбрать();
		Если Выборка.Следующий() Тогда
			ВремяПоступления = Выборка.НачалоИнтервала;
			Поток = Выборка.Поток;
		КонецЕсли;
	Иначе
		НачалоСвободногоИнтервала = Неопределено;
		ВыбранныйПоток = Неопределено;
		Для каждого Интервал из ТЗЗанятыеИнтервалы Цикл
			Если ВыбранныйПоток <> Интервал.Поток Тогда
				ВыбранныйПоток = Интервал.Поток;
				НачалоСвободногоИнтервала = Неопределено;
			КонецЕсли;
			Если НачалоСвободногоИнтервала = Неопределено Тогда
				НачалоСвободногоИнтервала = Интервал.НачалоИнтервала;
			КонецЕсли;
			
			СвободныйИнтервал = (Интервал.ВремяНачала - НачалоСвободногоИнтервала)/60;
			Если СвободныйИнтервал >= ПродолжительностьРазгрузки И НачалоСвободногоИнтервала < Интервал.КонецИнтервала Тогда
				ВремяПоступления = НачалоСвободногоИнтервала;
				Поток = Интервал.Поток;
				Прервать;
			КонецЕсли;
			НачалоСвободногоИнтервала = Интервал.ВремяКонца;
		КонецЦикла;
	КонецЕсли;
	
	Если Поток = Справочники.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка()  Тогда
		ВремяПоступления = '00010101';
		Сообщить("Невозможно для данной секции определить автоматически время поставки. Воспользуйтесь ручным механизмом или измените параметры поставки.");
	Иначе
		
	КонецЕсли;
		
КонецПроцедуры // РассчитатьВремяАвтоматически()

&НаСервере
Процедура ЗаполнитьПоНормативу(РучнойПересчет=Ложь)
	
	Если ПродолжительностьРазгрузки = 0 Тогда
		РучнойПересчет = Истина;
	КонецЕсли;
	
	ПродолжительностьРазгрузки = 0;
	ТабОборудования = ТребуемоеОборудование;
	ТабОборудования.Очистить();
	Если Объект.Норматив <> Справочники.НормативыПриемкиПоставкиНаСклад.ПустаяСсылка() Тогда
		Норматив = Объект.Норматив;
		Если РучнойПересчет Тогда 
			//таблица оборудования
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	НормативыПриемкиПоставкиНаСкладДополнительноеОборудование.Ресурс КАК Ресурс,
			|	НормативыПриемкиПоставкиНаСкладДополнительноеОборудование.ТребуемоеКоличество КАК ТребуемоеКоличество,
			|	ТехническиеРесурсыСкладов.ДопустимоеКоличество КАК ДопустимоеКоличество, 
			|	ВЫБОР
			|		КОГДА ТехническиеРесурсыСкладов.ДопустимоеКоличество < НормативыПриемкиПоставкиНаСкладДополнительноеОборудование.ТребуемоеКоличество
			|			ТОГДА ИСТИНА
			|		ИНАЧЕ ЛОЖЬ
			|	КОНЕЦ КАК СкладНеМожетОбеспечитьМощность
			|ИЗ
			|	Справочник.НормативыПриемкиПоставкиНаСклад.ДополнительноеОборудование КАК НормативыПриемкиПоставкиНаСкладДополнительноеОборудование
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТехническиеРесурсыСкладов КАК ТехническиеРесурсыСкладов
			|		ПО НормативыПриемкиПоставкиНаСкладДополнительноеОборудование.Ресурс = ТехническиеРесурсыСкладов.Оборудование
			|ГДЕ
			|	НормативыПриемкиПоставкиНаСкладДополнительноеОборудование.Ссылка = &Норматив
			|	И ТехническиеРесурсыСкладов.Склад = &Склад";
			Запрос.УстановитьПараметр("Норматив", Объект.Норматив);
			Запрос.УстановитьПараметр("Склад", Объект.Склад);
			УстановитьПривилегированныйРежим(Истина);
			РезультатЗапроса = Запрос.Выполнить();
			УстановитьПривилегированныйРежим(Ложь);
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				СтрОборудованиеЗаказ = ТабОборудования.Добавить();
				СтрОборудованиеЗаказ.Ресурс = ВыборкаДетальныеЗаписи.Ресурс;
				СтрОборудованиеЗаказ.ТребуемоеКоличество = ВыборкаДетальныеЗаписи.ТребуемоеКоличество;
				Если ВыборкаДетальныеЗаписи.СкладНеМожетОбеспечитьМощность Тогда
					Сообщить("Обратите внимание, что текущий склад не может обеспечить требуемое количество ресурсов для отгрузки (допустимое количество ресурса " + ВыборкаДетальныеЗаписи.Ресурс + " " + ВыборкаДетальныеЗаписи.ДопустимоеКоличество + ")", СтатусСообщения.Важное);
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;
		Если АдресЗапросаКоэффициентыТоваров = "" Тогда
			СформироватьЗапросДляРасчетаСекцииИВремениПоНормативу();
		КонецЕсли;
		Запрос = ПолучитьИзВременногоХранилища(АдресЗапросаКоэффициентыТоваров).Запрос;
		
		Если СтрНайти(Запрос.Текст, "втИтогДляВремени") = 0 Тогда
			Запрос.Текст = Запрос.Текст +
			"; ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	втНоменклатураДокумента.Номенклатура КАК Номенклатура,
			|	втНоменклатураДокумента.Упаковка КАК Упаковка,
			|	втНоменклатураДокумента.КоличествоУпаковок КАК КоличествоУпаковок,
			|	втНоменклатураДокумента.ЗаказПоставщику КАК Ссылка,
			|	ВЫБОР
			|		КОГДА &НуженВес
			|			ТОГДА втНоменклатураДокумента.НоменклатураВесЕдиницаИзмерения
			|		ИНАЧЕ втНоменклатураДокумента.НоменклатураОбъемЕдиницаИзмерения
			|	КОНЕЦ КАК НоменклатураЕдиницаИзмерения,
			|	ВЫБОР
			|		КОГДА &НуженВес
			|			ТОГДА втНоменклатураДокумента.ВесКоэффициентНоменклатура
			|		ИНАЧЕ втНоменклатураДокумента.ОбъемКоэффициентНоменклатура
			|	КОНЕЦ КАК НоменклатураКоэффициент,
			|	НормативыПриемкиПоставкиНаСклад.Норматив КАК Норматив,
			|	НормативыПриемкиПоставкиНаСклад.ЕдИзмеренияЗнаменателя КАК ЕдИзмеренияЗнаменателя,
			|	НормативыПриемкиПоставкиНаСклад.МинимальноеВремя КАК МинимальноеВремя,
			|	НормативыПриемкиПоставкиНаСклад.МаксимальноеВремя КАК МаксимальноеВремя
			|ПОМЕСТИТЬ втИтогДляВремени
			|ИЗ
			|	Справочник.НормативыПриемкиПоставкиНаСклад КАК НормативыПриемкиПоставкиНаСклад,
			|	втНоменклатураДокумента КАК втНоменклатураДокумента
			|ГДЕ
			|	НормативыПриемкиПоставкиНаСклад.Ссылка = &Норматив
			|	И НормативыПриемкиПоставкиНаСклад.ЕдИзмеренияЗнаменателя.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Вес) = &НуженВес
			|";
		КонецЕсли;
		Запрос.Текст = Запрос.Текст +
		";
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Итог.Упаковка КАК Упаковка, (Итог.КоличествоУпаковок), (Итог.НоменклатураКоэффициент), (Итог.НоменклатураЕдиницаИзмерения.Числитель),  (Итог.НоменклатураЕдиницаИзмерения.Знаменатель),  (Итог.ЕдИзмеренияЗнаменателя.Числитель),   (Итог.Норматив),
		|	isnull((Итог.КоличествоУпаковок * Итог.НоменклатураКоэффициент * Итог.НоменклатураЕдиницаИзмерения.Числитель / Итог.НоменклатураЕдиницаИзмерения.Знаменатель * Итог.ЕдИзмеренияЗнаменателя.Знаменатель / Итог.ЕдИзмеренияЗнаменателя.Числитель) * Итог.Норматив,0) КАК ВремяРассчитанное,
		|	Итог.Ссылка КАК Ссылка,
		|	Итог.МинимальноеВремя КАК МинимальноеВремя,
		|	Итог.МаксимальноеВремя КАК МаксимальноеВремя
		|ИЗ
		|	втИтогДляВремени КАК Итог
		|
		|ИТОГИ
		|	Максимум(МинимальноеВремя),
		|	Максимум(МаксимальноеВремя)
		|ПО
		|	ОБЩИЕ";
		Запрос.УстановитьПараметр("НуженВес", Объект.Норматив.ЕдИзмеренияЗнаменателя.ТипИзмеряемойВеличины=Перечисления.ТипыИзмеряемыхВеличин.Вес);
		Запрос.УстановитьПараметр("Норматив", Объект.Норматив);
		УстановитьПривилегированныйРежим(Истина);
		Результат = Запрос.Выполнить();
		УстановитьПривилегированныйРежим(Ложь);
		ВыборкаИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВремяРазгрузки = 0;
		Если ВыборкаИтог.Следующий() Тогда 
			ВыборкаДетальные = ВыборкаИтог.Выбрать();
			Пока ВыборкаДетальные.Следующий() Цикл
				ВремяРазгрузки = ВремяРазгрузки + ВыборкаДетальные.ВремяРассчитанное;
			КонецЦикла;
			ПродолжительностьРазгрузки = Мин(Макс(ВремяРазгрузки, ВыборкаИтог.МинимальноеВремя), ВыборкаИтог.МаксимальноеВремя);
			ОкрПродолжительностьРазгрузки = Окр(ПродолжительностьРазгрузки, -1, РежимОкругления.Окр15как20);
			Если ОкрПродолжительностьРазгрузки < ПродолжительностьРазгрузки Тогда
				ПродолжительностьРазгрузки = ОкрПродолжительностьРазгрузки+5;
			КонецЕсли;
		КонецЕсли;	
		
		Если ПродолжительностьРазгрузки = 0 Тогда
			ПродолжительностьРазгрузки = Норматив.МинимальноеВремя;
		КонецЕсли;
		
		Модифицированность = Истина;
		
	КонецЕсли;
	
КонецПроцедуры // ЗаполнитьПоНормативу()

&НаКлиенте
Процедура Док_ТребуемоеОборудованиеТребуемоеКоличествоОкончаниеВводаТекстаВместо(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	Если ТребуемоеОборудование.Количество() > 0  Тогда
		РедактируемаяСтрока = Элементы.ТребуемоеОборудование.ТекущиеДанные;
		КоличествоТекущее = Число(Текст);
		КоличествоИсходное =  РедактируемаяСтрока.ТребуемоеКоличество;
		РедактируемаяСтрока.ТребуемоеКоличество = ПроверитьДопустимоеКоличествоОборудования(РедактируемаяСтрока.Ресурс, КоличествоТекущее);
		Если КоличествоТекущее > КоличествоИсходное Тогда
			ИзмененноеКоличество = Новый Структура;
			ИзмененноеКоличество.Вставить("Ресурс", РедактируемаяСтрока.Ресурс);
			ИзмененноеКоличество.Вставить("КоличествоТекущее", КоличествоТекущее);
			АдресИзмененнойСтрокиТребуемогоОборудования = ПоместитьВоВременноеХранилище(ИзмененноеКоличество, Новый УникальныйИдентификатор);
			
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ПересчетСекцииНеНужен", Истина);
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры

//проверка оборудования по нормативу для секции
&НаСервере
Функция ПроверитьДопустимоеКоличествоОборудования(Ресурс, ТребуемоеКоличество)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТехническиеРесурсыСкладов.ДопустимоеКоличество КАК ДопустимоеКоличество
	|ИЗ
	|	РегистрСведений.ТехническиеРесурсыСкладов КАК ТехническиеРесурсыСкладов
	|ГДЕ
	|	ТехническиеРесурсыСкладов.Оборудование = &Оборудование
	|	И ТехническиеРесурсыСкладов.Склад = &Склад И ТехническиеРесурсыСкладов.ДопустимоеКоличество < &ТребуемоеКоличество";
	Запрос.УстановитьПараметр("Оборудование",  Ресурс);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("ТребуемоеКоличество", ТребуемоеКоличество);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	Выборка = Результат.Выбрать();
	Если Выборка.Следующий() Тогда
		Сообщить("Вы пытаетесь указать количество ресурса по данному складу, превышающее количество из норматива!");
		Возврат Выборка.ДопустимоеКоличество;
	Иначе
		Возврат ТребуемоеКоличество;
	КонецЕсли;
		
КонецФункции // ПроверитьДопустимоеКоличествоОборудования()

&НаСервере
Функция ПолучитьТаблицуИнтерваловЗанятогоПоСкладуОборудования(НачалоПериода, КонецПериода)
	
	ТабИнтервалов = Новый ТаблицаЗначений;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТЧ.Ресурс КАК Оборудование,
	|	ТЧ.ТребуемоеКоличество КАК ТребуемоеКоличество
	|ПОМЕСТИТЬ втРесурсыДокумента
	|ИЗ
	|	&ТЧ КАК ТЧ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК НачалоИнтервала,
	|	ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки) КАК КонецИнтервала,
	|	ГрафикПоставокНаСкладСрезПоследних.КоличествоИспользуется КАК КоличествоИспользуется,
	|	ГрафикПоставокНаСкладСрезПоследних.Оборудование КАК Оборудование,
	|	ТехническиеРесурсыСкладов.ДопустимоеКоличество КАК ДопустимоеКоличество,
	|	втРесурсыДокумента.ТребуемоеКоличество КАК ТребуемоеКоличество
	|ИЗ
	|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних(
	|			&Период,
	|			Оборудование В (&СписокРесурсов)
	|				И ЗаказПоставщику.Склад = &Склад
	|				И (ДатаВремяРазгрузкиПлан МЕЖДУ &НачалоПериода И &КонецПериода)
	|				И ПродолжительностьРазгрузки > 0) КАК ГрафикПоставокНаСкладСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТехническиеРесурсыСкладов КАК ТехническиеРесурсыСкладов
	|		ПО ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику.Склад = ТехническиеРесурсыСкладов.Склад
	|			И ГрафикПоставокНаСкладСрезПоследних.Оборудование = ТехническиеРесурсыСкладов.Оборудование
	|		ЛЕВОЕ СОЕДИНЕНИЕ втРесурсыДокумента КАК втРесурсыДокумента
	|		ПО ГрафикПоставокНаСкладСрезПоследних.Оборудование = втРесурсыДокумента.Оборудование
	|УПОРЯДОЧИТЬ ПО
	|НачалоИнтервала,
	|КонецИнтервала
	|ИТОГИ
	|	СУММА(КоличествоИспользуется),
	|	МАКСИМУМ(ДопустимоеКоличество),
	|	МАКСИМУМ(ТребуемоеКоличество)
	|ПО
	|	Оборудование";
	Запрос.УстановитьПараметр("Период", КонецДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("ТЧ", ТребуемоеОборудование.Выгрузить());
	Запрос.УстановитьПараметр("СписокРесурсов", ТребуемоеОборудование.Выгрузить(,"Ресурс"));
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	СтруктураРезультатаЗапроса = Новый Структура;
	СтруктураРезультатаЗапроса.Вставить("Результат", Результат);

	Возврат ПоместитьВоВременноеХранилище(СтруктураРезультатаЗапроса, Новый УникальныйИдентификатор);
	  
КонецФункции 

