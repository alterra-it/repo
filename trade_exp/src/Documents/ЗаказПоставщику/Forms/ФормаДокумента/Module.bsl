
&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Элементы.ФормаКроссДокингЧерез.Видимость= Объект.КроссДокинг;
	ОбновитьПараметрыВыбораЦен();
	//Сетка поставок {
	Если Объект.Склад<>Справочники.Склады.ПустаяСсылка() И Альтерра_СеткаПоставок.ЕстьСекцииУСклада(Объект.Склад) Тогда
		//Поставка
		Элементы.ГруппаСостояниеПоставки.Видимость = Истина;
		Если ЗначениеЗаполнено(Параметры.Ключ) Тогда
			ВремяИСостояниеПоставки = Альтерра_СеткаПоставок.ПолучитьТекущееСостояниеПоставки(Объект.Ссылка)[0];
			Если (СтрНайти(ВремяИСостояниеПоставки.СостояниеПоставки, "Запланирована") = 0 И СтрНайти(ВремяИСостояниеПоставки.СостояниеПоставки, "запланирована") = 0 ) И ВремяИСостояниеПоставки.СостояниеПоставки<>"" И (Объект.Статус= Перечисления.СтатусыЗаказовПоставщикам.Подтвержден ИЛИ Объект.Статус= Перечисления.СтатусыЗаказовПоставщикам.Закрыт) Тогда
				ПоставкаПрибыла = Истина;
				Элементы._ГруппаПоставки.ТолькоПросмотр = Истина;
				Элементы.ПересчитатьПоНормативу.Видимость  = Ложь;
				Элементы.ПересчитатьСекциюПоТоварам.Видимость = Ложь;
				Элементы._ВыборВремениВручную.Видимость = Ложь;
				Элементы.НадписьПредупрежедниеИзмененДокумент.Видимость = Ложь;
			КонецЕсли;
			ВремяСостоянияПоставки = ВремяИСостояниеПоставки.ВремяИзмененияСостоянияПоставки;
			СостояниеПоставки = ВремяИСостояниеПоставки.СостояниеПоставки + " " + ?(ВремяСостоянияПоставки<>'00010101', Лев(Строка(ВремяСостоянияПоставки), СтрДлина(Строка(ВремяСостоянияПоставки))-3), "");
			
			//таблица состояний
			ДатыСменыСостоянийПоставки = Альтерра_СеткаПоставок.ПолучитьТекущееСостояниеПоставки(Объект.Ссылка, Ложь)[0];
			ДатаВремяПрибытияФакт = ДатыСменыСостоянийПоставки.ВремяПрибытие;
			ДатаВремяЗаезда = ДатыСменыСостоянийПоставки.ВремяВъезд;
			ДатаВремяВыезда = ДатыСменыСостоянийПоставки.ВремяВыезд;
		КонецЕсли;
		
		//доступность согласования
		Если РольДоступна("СогласованиеВремениПоставки") ИЛИ РольДоступна("ПолныеПрава") Тогда
			Элементы.СогласованоСоСкладом.Доступность = Истина;
		Иначе
			Элементы.СогласованоСоСкладом.Доступность = Ложь;
		КонецЕсли;
		
		Элементы.ГруппаОтправкаПисьма.Видимость = РольДоступна("ОтправкаПисьмаПоставщику") ИЛИ РольДоступна("ПолныеПрава"); 
	Иначе
		Элементы._ГруппаПоставки.Видимость = Ложь;
	КонецЕсли;
	//} Сетка поставок

КонецПроцедуры

&НаСервере
Процедура СоздатьНовыйДокумент(ИмяДокумента, НовыйОбъект)
	Документы[ИмяДокумента].ЗаполнитьДанныеПоОснованию(Объект.Ссылка, НовыйОбъект);
КонецПроцедуры

&НаКлиенте
Процедура В_ВводНаОснованииЗаказыТЭС(Команда)
	ИмяДокумента= "ЗаказыТЭС";
	ФормаДок = ПолучитьФорму("Документ."+ИмяДокумента+".ФормаОбъекта");
	
	//Далее мы получаем объект только, что созданной формы и помещаем её в переменную
	//В объекте содержатся все реквизиты (элементы) формы
	ДанныеФормы = ФормаДок.Объект;
	
	Если Объект.Ссылка.Пустая() Тогда
		ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = 'Данные еще не записаны.
		|Выполнение действия ""%1"" возможно только после записи данных.'"),
		"Заявка на доставку");
		
		ПоказатьПредупреждение(,ТекстВопроса);
		возврат;	
	КонецЕсли;
	
	//Мы помещаем объект формы в переменную,
	//так как должны передать её в процедуру на сервере,
	//где нельзя изменять объект формы, зато можно править переменную содержащую его
	СоздатьНовыйДокумент(ИмяДокумента, ДанныеФормы);
	
	//После выполнения процедуры на сервере мы получаем изменную переменную ДанныеФормы,
	//которую необходимо передать в уже созданную нами форму
	КопироватьДанныеФормы(ДанныеФормы, ФормаДок.Объект);
	
	//Открываем результат выполнения обработки
	ФормаДок.Открыть();
КонецПроцедуры

