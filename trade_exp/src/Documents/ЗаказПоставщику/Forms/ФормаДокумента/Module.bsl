&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	
	Если Не ЗначениеЗаполнено(Параметры.Ключ) Тогда
		ПримечаниеКПоставке = "";
		ПродолжительностьРазгрузки = 0;
		ТребуемоеОборудование.Очистить();

		Если Объект.Товары.Количество() > 0 Тогда
			ТоварыИзменено = Истина;
		КонецЕсли;
	КонецЕсли;
	ОбновитьВремяИИнтервалПоставки();
	
	Элементы.ФормаОбновитьБлокировки.Доступность = ПроверитьДоступностьОбновленияБлокировки();

КонецПроцедуры

&После("ДатаОтгрузкиПриИзменении")
&НаКлиенте
Процедура Док_ДатаОтгрузкиПриИзменении(Элемент) 
	
	Если Не ПоставкаПрибыла И Объект.ДатаОтгрузки >= НачалоДня(ТекущаяДата()) Тогда
		Если Не ЗначениеЗаполнено(Объект.Ссылка) ИЛИ НЕ ЕстьРейсПоПоставке() Тогда
			ДатаРазгрузки = Объект.ДатаПоступления;
			ДанныеПоставкиИзменились = Истина;
			ВремяПоступления = '00010101000000';
			Поток = ПредопределенноеЗначение("Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка");	
		КонецЕсли;
	КонецЕсли; 
	
		
	Если Объект.ДатаОтгрузки < НачалоДня(ТекущаяДата())Тогда 
		Объект.ДатаОтгрузки = НачалоДня(ТекущаяДата()); 
		Объект.ДатаПоступления = НачалоДня(ТекущаяДата());
		Сообщить("Не рекомендуется ставить дату отгрузки на прошлый период!");
	КонецЕсли;

КонецПроцедуры

