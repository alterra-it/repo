	Элементы.ФормаОбновитьБлокировки.Доступность = ПроверитьДоступностьОбновленияБлокировки();

КонецПроцедуры

&НаКлиенте
Процедура Док_ПартнерПриИзмененииПосле(Элемент)
	
	Объект.Норматив = ПолучитьНормативПоУмолчанию();
	ОбновитьПараметрыВыбораЦен();
	ПодставитьВидЦены();
КонецПроцедуры

&НаСервере
Процедура ОбновитьПараметрыВыбораЦен()
	Если ДопМодуль.НовоеЦенообразованиеЗакупа(Объект.Дата) тогда   
		Элементы.ТоварыВидЦеныПоставщика.ПараметрыВыбора = Новый ФиксированныйМассив(Новый Массив);
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.Подразделение", Объект.Подразделение );
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.ДатаОтбора", Объект.Дата );  
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.ГруппаВидовЦен", Объект.соглашение.ГруппаВидовЦен );
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.ТоварыВидЦеныПоставщика, "Отбор.Владелец", Объект.Партнер );
	КонецЕсли;    
КонецПроцедуры

#КонецОбласти

#Область Команды
&НаКлиенте
Процедура Док__ВыборВремениВручнуюВместо(Команда)
	СФП_МаркерыКлиент.МаркерНачало("Заказ поставщику: Выбор времени вручную");
	Если ПродолжительностьРазгрузки = 0 Тогда
		Сообщить("Укажите ненулевую длительность погрузки!");
		Возврат;
	КонецЕсли;
	
	Если ДатаРазгрузки='00010101' Тогда
		Сообщить("Заполните дату! Это можно сделать на вкладке товаров");
		Возврат;
	КонецЕсли;
	
	//записать изменения
	Если Модифицированность Тогда
		//Предупреждение("Документ будет записан!",2,"Изменения в поставке");
		Если Объект.Проведен Тогда
			ЭтотОбъект.Записать();
		Иначе
			Сообщить("Документ требуется провести!");
			Возврат;
		КонецЕсли;
		ЗаписатьИнтервалДоставкиСервер();
	КонецЕсли;
	Если Объект.Секция <> ПредопределенноеЗначение("Справочник.РабочиеУчастки.ПустаяСсылка") Тогда
		ПараметрыОткрытияФормыПодбора = Новый Структура;
		ПараметрыОткрытияФормыПодбора.Вставить("Период", ДатаРазгрузки);
		ПараметрыОткрытияФормыПодбора.Вставить("Секция", Объект.Секция);
		ПараметрыОткрытияФормыПодбора.Вставить("ИзФормыЗаказа", Истина);
		ПараметрыОткрытияФормыПодбора.Вставить("ПродолжительностьРазгрузки", ПродолжительностьРазгрузки);
		ПараметрыОткрытияФормыПодбора.Вставить("ЗаказПоставщику", Объект.Ссылка);
		ПараметрыОткрытияФормыПодбора.Вставить("КомментарийКПоставке", ПримечаниеКПоставке);
		СписокДопРесурсов = Новый СписокЗначений;
		Для Каждого СтрТЧДопРесурсы Из ТребуемоеОборудование Цикл
			СтрокаСписка = Новый Структура;
			СтрокаСписка.Вставить("Ресурс", СтрТЧДопРесурсы.Ресурс);
			СтрокаСписка.Вставить("ТребуемоеКоличество", СтрТЧДопРесурсы.ТребуемоеКоличество);
			СписокДопРесурсов.Добавить(СтрокаСписка);
		КонецЦикла;
		ПараметрыОткрытияФормыПодбора.Вставить("ДополнительныеРесурсы", СписокДопРесурсов); 
		ПараметрыОткрытияФормыПодбора.Вставить("НельзяВыбиратьДату", ЕстьРейсПоПоставке());
		
		ОткрытьФорму("Обработка.ПланировщикПоставокНаСклад.Форма", ПараметрыОткрытияФормыПодбора, ЭтаФорма,,,,Новый ОписаниеОповещения("ОбновитьДанныеПоставкиПослеЗакрытияПланировщика", ЭтотОбъект));
		ОчиститьСообщения();
	КонецЕсли;
КонецПроцедуры

