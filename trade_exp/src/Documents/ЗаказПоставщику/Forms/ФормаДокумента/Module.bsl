&НаСервере
Процедура ОбновитьБлокировкиПослеНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаПолученияСвязанныхДокументов();  
	Запрос.УстановитьПараметр("ЗначениеКритерияОтбора", Объект.Ссылка);	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ПриходныйОрдерНаТовары = ВыборкаДетальныеЗаписи.ПриходныйОрдерНаТовары;
		Если ПриходныйОрдерНаТовары.Распоряжение = Объект.Ссылка Тогда
			УстановитьПривилегированныйРежим(Истина);
			ПриходныйОрдерНаТоварыОбъект = ПриходныйОрдерНаТовары.ПолучитьОбъект();
			ПриходныйОрдерНаТоварыОбъект.Записать(РежимЗаписиДокумента.Проведение);
			УстановитьПривилегированныйРежим(Ложь); 
			
			АльтерраОбщегоНазначения.СообщитьПользователю(ПриходныйОрдерНаТовары, "Перепроведен документ: " + ВыборкаДетальныеЗаписи.ПредставлениеПриходногоОрдераНаТовары);
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ОбновитьБлокировкиПосле(Команда)
	ОбновитьБлокировкиПослеНаСервере();
КонецПроцедуры


