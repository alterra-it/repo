&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Поставщик = Параметры.Поставщик;
	Ссылка = Параметры.Ссылка;
	Товары.Загрузить(Параметры.Товар.Выгрузить());
	
	Инициализация();
	
КонецПроцедуры

&НаСервере
Процедура Инициализация()
	
	ТабличныйДокумент.Очистить();
	
	Макет = Документы.ЗаказПоставщику.ПолучитьМакет("Док_ЗагрузитьСчетОтПоставщика");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	
	ТабличныйДокумент.Вывести(ОбластьШапка);
	ТабличныйДокумент.ФиксацияСверху = 1;
	ТабличныйДокумент.ТолькоПросмотр = Ложь;
	ТабличныйДокумент.ОтображатьЗаголовки = Истина;
	
	Элементы.СтраницаПроверитьСчет.Видимость = Истина;
	Элементы.СтраницаНоваяНоменклатура.Видимость = Ложь;
	Элементы.СтраницаСозданиеНоменклатурыПоставщика.Видимость = Ложь;
	Элементы.СтраницаСверкаСчета.Видимость = Ложь;     
	
КонецПроцедуры


&НаКлиенте
Процедура ПроверитьСчет(Команда)
	
	ПроверитьСчетНаСервере();
	
	Если СозданиеНоменклатурыПоставщика.Количество() > 0 Тогда 
		Элементы.СтраницаПроверитьСчет.Видимость = Ложь;
		Элементы.СтраницаНоваяНоменклатура.Видимость = Истина;
	Иначе
		Элементы.СтраницаПроверитьСчет.Видимость = Ложь;
		Элементы.СтраницаСверкаСчета.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры 

//Главный цикл
&НаСервере
Процедура ПроверитьСчетНаСервере()
	
	СверкаСчета.Очистить();
	СозданиеНоменклатурыПоставщика.Очистить();
	
	НомерСтроки = 2;
	
	Пока Истина Цикл
		стрНомерСтроки = XMLСтрока(НомерСтроки);
		
		Артикул = СокрЛП(ТабличныйДокумент.Область("R" + Строка(стрНомерСтроки) + "C1").Текст);
		НаименованиеПоставщика = СокрЛП(ТабличныйДокумент.Область("R" + Строка(стрНомерСтроки) + "C2").Текст);
		СчетКоличество = СокрЛП(ТабличныйДокумент.Область("R" + Строка(стрНомерСтроки) + "C3").Текст);
		СчетЦена = СокрЛП(ТабличныйДокумент.Область("R" + Строка(стрНомерСтроки) + "C4").Текст);
		СчетСумма = СокрЛП(ТабличныйДокумент.Область("R" + Строка(стрНомерСтроки) + "C5").Текст);
		ЕдИзм = СокрЛП(ТабличныйДокумент.Область("R" + Строка(стрНомерСтроки) + "C6").Текст);
		
		Если ПустаяСтрока(НаименованиеПоставщика) Тогда 
			Прервать;
		КонецЕсли;
		
		Попытка
			СчетКоличество = Число(СчетКоличество);
		Исключение
			СчетКоличество = 0;
			Сообщить("Не удалось определить количество по строке: "+НомерСтроки);
		КонецПопытки;
		
		Если ПустаяСтрока(СчетЦена) Тогда
			СчетЦена= 0;
		Иначе
			Попытка
				СчетЦена= Число(СчетЦена);
			Исключение
				СчетЦена = 0;
				Сообщить("Не удалось определить цену по строке: "+НомерСтроки);
			КонецПопытки;
		КонецЕсли;
		
		Если ПустаяСтрока(СчетСумма) Тогда
			СчетСумма = 0;
		Иначе
			Попытка
				СчетСумма = Число(СчетСумма);
			Исключение
				СчетСумма = 0;
				Сообщить("Не удалось определить сумму по строке: "+НомерСтроки);
			КонецПопытки;
		КонецЕсли;
		
		ЕдиницаПоставщика = Неопределено;
		
		НоменклатураПоставщика = Неопределено;
		
		Если Не ПустаяСтрока(НаименованиеПоставщика) Тогда
			
			НоменклатураПоставщика = НайтиДействительнуюНоменклатуруПоставщика(Поставщик, Артикул, НаименованиеПоставщика);
			
			Если Не ЗначениеЗаполнено(НоменклатураПоставщика) Тогда
				НоваяСтрока = СозданиеНоменклатурыПоставщика.Добавить();
				НоваяСтрока.Артикул = Артикул;
				НоваяСтрока.НаименованиеПоставщика = НаименованиеПоставщика;
				Если Не ПустаяСтрока(ЕдИзм) Тогда
					НоваяСтрока.ЕдиницаПоставщика = Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию(ЕдИзм);
				КонецЕсли;
			Иначе
				НоваяСтрока = СверкаСчета.Добавить();
				НоваяСтрока.НоменклатураПоставщика = НоменклатураПоставщика;
				НоваяСтрока.Номенклатура = НоменклатураПоставщика.Номенклатура;
				Если Не ЗначениеЗаполнено(НоменклатураПоставщика.ЕдиницаПоставщика) Тогда
					Если Не ПустаяСтрока(ЕдИзм) Тогда
						НоваяСтрока.ЕдиницаПоставщика = Справочники.УпаковкиЕдиницыИзмерения.НайтиПоНаименованию(ЕдИзм);
					Иначе
						НоваяСтрока.ЕдиницаПоставщика = НоваяСтрока.Номенклатура.ЕдиницаИзмерения;
					КонецЕсли;
				Иначе
					НоваяСтрока.ЕдиницаПоставщика = НоменклатураПоставщика.ЕдиницаПоставщика;
				КонецЕсли;
				
				//Расчет Количества по ед. зм
				РасчетноеКоличество = 0;
				Если НоваяСтрока.Номенклатура.ЕдиницаИзмерения = НоваяСтрока.ЕдиницаПоставщика Тогда
					НоваяСтрока.СчетКоличество = СчетКоличество;
				Иначе
					//Объем
					Если НоваяСтрока.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияОбъема.Получить() И НоваяСтрока.Номенклатура.ОбъемИспользовать Тогда
						РасчетноеКоличество = НоваяСтрока.Номенклатура.ОбъемЗнаменатель * СчетКоличество / НоваяСтрока.Номенклатура.ОбъемЧислитель;
					КонецЕсли;
					//Вес
					Если НоваяСтрока.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияВеса.Получить() И НоваяСтрока.Номенклатура.ВесИспользовать Тогда
						РасчетноеКоличество = НоваяСтрока.Номенклатура.ВесЗнаменатель * СчетКоличество / НоваяСтрока.Номенклатура.ВесЧислитель;
					КонецЕсли;
					//Площадь
					Если НоваяСтрока.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияПлощади.Получить() И НоваяСтрока.Номенклатура.ПлощадьИспользовать Тогда
						РасчетноеКоличество = НоваяСтрока.Номенклатура.ПлощадьЗнаменатель*СчетКоличество/НоваяСтрока.Номенклатура.ПлощадьЧислитель;
					КонецЕсли;
					//Длинна
					Если НоваяСтрока.ЕдиницаПоставщика = Константы.ЕдиницаИзмеренияДлины.Получить() И НоваяСтрока.Номенклатура.ДлинаИспользовать Тогда
						РасчетноеКоличество = НоваяСтрока.Номенклатура.ДлинаЗнаменатель * СчетКоличество / НоваяСтрока.Номенклатура.ДлинаЧислитель;
					КонецЕсли;
					//Либо расчетное либо равно СчетКоличество
					НоваяСтрока.СчетКоличество = ?(РасчетноеКоличество = 0, СчетКоличество, РасчетноеКоличество);
				КонецЕсли;		
										
					//СчетСумма
					//СчетКоличество - исходное количество
					 //НоваяСтрока.СчетКоличество - уже пересчитанное количество
					Если НоваяСтрока.СчетКоличество > 0 Тогда
						Если СчетСумма = 0 Тогда
							НоваяСтрока.СчетЦена = СчетЦена * СчетКоличество / НоваяСтрока.СчетКоличество;
							НоваяСтрока.СчетСумма = НоваяСтрока.СчетКоличество * НоваяСтрока.СчетЦена;
						Иначе
							НоваяСтрока.СчетСумма = СчетСумма * СчетКоличество / НоваяСтрока.СчетКоличество;
							НоваяСтрока.СчетЦена = НоваяСтрока.СчетСумма / СчетКоличество;
						КонецЕсли;
					Иначе
						НоваяСтрока.СчетСумма = 0;
						НоваяСтрока.СчетЦена = 0;
					КонецЕсли;
					
				КонецЕсли;
		Иначе
			Сообщить("Пустое наименование поставщика в строке: "+НомерСтроки);
		КонецЕсли;
		
		НомерСтроки = НомерСтроки+1;
	КонецЦикла;
	
	ПолучитьСверкуСчета();
	
КонецПроцедуры

&НаСервере
Функция НайтиДействительнуюНоменклатуруПоставщика(Поставщик, Артикул, НаименованиеПоставщика)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	НоменклатураКонтрагентов.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.НоменклатураКонтрагентов КАК НоменклатураКонтрагентов
		|ГДЕ
		|	НоменклатураКонтрагентов.Владелец = &Владелец
		|	И НоменклатураКонтрагентов.Недействителен = ЛОЖЬ
		|	И (&Артикул
		|			ИЛИ НоменклатураКонтрагентов.Наименование = &Наименование
		|			ИЛИ НоменклатураКонтрагентов.НаименованиеПолное = &НаименованиеПолное)
		|	И НоменклатураКонтрагентов.ПометкаУдаления = ЛОЖЬ
		|	И НоменклатураКонтрагентов.Номенклатура.ПометкаУдаления = ЛОЖЬ";
	
	Если ЗначениеЗаполнено(Артикул) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Артикул", "НоменклатураКонтрагентов.Артикул = &Артикул");
		Запрос.УстановитьПараметр("Артикул", Артикул);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Артикул", "ЛОЖЬ");
	КонецЕсли;
	Запрос.УстановитьПараметр("Владелец", Поставщик);
	Запрос.УстановитьПараметр("Наименование", НаименованиеПоставщика);
	Запрос.УстановитьПараметр("НаименованиеПолное", НаименованиеПоставщика);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

//Запрос
&НаСервере
Процедура ПолучитьСверкуСчета()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
"ВЫБРАТЬ
	|	ТоварИзСчета.НоменклатураПоставщика КАК НоменклатураПоставщика,
	|	ТоварИзСчета.СчетКоличество КАК СчетКоличество,
	|	ТоварИзСчета.СчетЦена КАК СчетЦена,
	|	ТоварИзСчета.СчетСумма КАК СчетСумма,
	|	ТоварИзСчета.Номенклатура КАК Номенклатура
	|ПОМЕСТИТЬ ВТ_ТоварСчета
	|ИЗ
	|	&ТоварИзСчета КАК ТоварИзСчета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТоварИзЗаказа.Номенклатура КАК Номенклатура,
	|	ТоварИзЗаказа.Количество КАК Количество,
	|	ТоварИзЗаказа.Цена КАК Цена,
	|	ТоварИзЗаказа.Сумма КАК Сумма,
	|	ТоварИзЗаказа.Отменено КАК Отменено
	|ПОМЕСТИТЬ ВТ_ТоварИзЗаказа
	|ИЗ
	|	&ТоварИзЗаказа КАК ТоварИзЗаказа
	|ГДЕ
	|	ТоварИзЗаказа.Отменено = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ВТ_ТоварИзЗаказа.Номенклатура, ВТ_ТоварСчета.Номенклатура) КАК Номенклатура,
	|	ВТ_ТоварИзЗаказа.Количество КАК ЗаказКоличество,
	|	ВТ_ТоварИзЗаказа.Цена КАК ЗаказЦена,
	|	ВТ_ТоварСчета.НоменклатураПоставщика КАК НоменклатураПоставщика,
	|	ВТ_ТоварСчета.СчетКоличество КАК СчетКоличество,
	|	ВТ_ТоварСчета.СчетЦена КАК СчетЦена,
	|	ВТ_ТоварИзЗаказа.Количество - ВТ_ТоварСчета.СчетКоличество КАК РазницаКоличество,
	|	ВТ_ТоварИзЗаказа.Цена - ВТ_ТоварСчета.СчетЦена КАК РазницаЦена,
	|	ВТ_ТоварИзЗаказа.Сумма КАК ЗаказСумма,
	|	ВТ_ТоварСчета.СчетСумма КАК СчетСумма,
	|	ЕСТЬNULL(ВТ_ТоварИзЗаказа.Номенклатура, ИСТИНА) КАК НетВЗаказе,
	|	ЕСТЬNULL(ВТ_ТоварСчета.Номенклатура, ИСТИНА) КАК НетВСчете
	|ИЗ
	|	ВТ_ТоварИзЗаказа КАК ВТ_ТоварИзЗаказа
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТ_ТоварСчета КАК ВТ_ТоварСчета
	|		ПО ВТ_ТоварИзЗаказа.Номенклатура = ВТ_ТоварСчета.Номенклатура"; 
	
	Запрос.УстановитьПараметр("ТоварИзСчета", СверкаСчета.Выгрузить());
	Запрос.УстановитьПараметр("ТоварИзЗаказа", Товары.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	СверкаСчета.Загрузить(РезультатЗапроса.Выгрузить()); 
	
КонецПроцедуры

&НаКлиенте
Процедура НоваяНоменклатура_да(Команда)
	Элементы.СтраницаНоваяНоменклатура.Видимость = Ложь;
	Элементы.СтраницаСозданиеНоменклатурыПоставщика.Видимость = Истина;
КонецПроцедуры

&НаКлиенте
Процедура НоваяНоменклатура_Назад(Команда)
	Элементы.СтраницаПроверитьСчет.Видимость = Истина;
	Элементы.СтраницаНоваяНоменклатура.Видимость = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура НоваяНоменклатура_Пропустить(Команда)
	Элементы.СтраницаНоваяНоменклатура.Видимость = Ложь;
	Элементы.СтраницаСверкаСчета.Видимость = Истина;
КонецПроцедуры

&НаКлиенте
Процедура СозданиеНоменклатурыПоставщика_Создать(Команда)
	СозданиеНоменклатурыПоставщика_СоздатьНаСервере();
КонецПроцедуры 

&НаСервере
Процедура СозданиеНоменклатурыПоставщика_СоздатьНаСервере()
	
	Для Каждого стрНовая Из СозданиеНоменклатурыПоставщика Цикл
		Если Не ЗначениеЗаполнено(стрНовая.НоменклатураПоставщика) И ЗначениеЗаполнено(стрНовая.Номенклатура) Тогда
			Если Не ПустаяСтрока(стрНовая.НаименованиеПоставщика) Тогда
				НоменклатураПоставщикаОбъект = Справочники.НоменклатураКонтрагентов.СоздатьЭлемент();
				ЗаполнитьЗначенияСвойств(НоменклатураПоставщикаОбъект, стрНовая);
				НоменклатураПоставщикаОбъект.Наименование = стрНовая.НаименованиеПоставщика;
				НоменклатураПоставщикаОбъект.НаименованиеНоменклатуры = стрНовая.НаименованиеПоставщика;
				НоменклатураПоставщикаОбъект.Владелец = Поставщик;
				НоменклатураПоставщикаОбъект.УстановитьНовыйКод();
				
				Попытка
					НоменклатураПоставщикаОбъект.Записать();
					стрНовая.НоменклатураПоставщика= НоменклатураПоставщикаОбъект.Ссылка;
				Исключение         
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
						ОписаниеОшибки(),
						?(НоменклатураПоставщикаОбъект.ДополнительныеСвойства.Свойство("ОбнаруженоДублированиеКлючевыхЗначений"), НоменклатураПоставщикаОбъект.ДополнительныеСвойства.ОбнаруженоДублированиеКлючевыхЗначений, Неопределено));
				КонецПопытки;
			Иначе
				Сообщить("Выявлено пустое наименование поставщика для номенклатуры: "+стрНовая.Номенклатура);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры  

&НаКлиенте
Процедура СозданиеНоменклатурыПоставщикаНоменклатураПриИзменении(Элемент)
	
	ТекущаяСтрока = Элементы.СозданиеНоменклатурыПоставщика.ТекущиеДанные;
	Если Не ЗначениеЗаполнено(ТекущаяСтрока.ЕдиницаПоставщика) Тогда
		ТекущаяСтрока.ЕдиницаПоставщика = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущаяСтрока.Номенклатура, "ЕдиницаИзмерения");
	КонецЕсли;  
		 
КонецПроцедуры

&НаКлиенте
