&НаКлиенте
Процедура ПечатьСравнения(Команда) 
	
	КоллекцияПечатныхФорм = УправлениеПечатьюКлиент.НоваяКоллекцияПечатныхФорм("Док_СравнениеСоСчетом");
	ТабДок = СформироватьПечатьСравненияНаСервере(КоллекцияПечатныхФорм);
	КоллекцияПечатныхФорм[0].ТабличныйДокумент = ТабДок;
	УправлениеПечатьюКлиент.ПечатьДокументов(КоллекцияПечатныхФорм);
	
КонецПроцедуры 

&НаСервере
Функция СформироватьПечатьСравненияНаСервере(КоллекцияПечатныхФорм)
	
	Макет = Документы.ЗаказПоставщику.ПолучитьМакет("Док_СравнениеСоСчетом");
	ТабДок = Новый ТабличныйДокумент;
	Шапка = Макет.ПолучитьОбласть("Шапка");
	Строка = Макет.ПолучитьОбласть("Строка");
	
	Шапка.Параметры.Ссылка = Ссылка;
	ТабДок.Вывести(Шапка);
	
	Для Каждого стрСверки Из СверкаСчета Цикл
		Строка.Параметры.Артикул = стрСверки.НоменклатураПоставщика.Артикул;
		Строка.Параметры.НоменклатураПоставщика = стрСверки.НоменклатураПоставщика;
		Строка.Параметры.Код = стрСверки.Номенклатура.Код;
		Строка.Параметры.Номенклатура = стрСверки.Номенклатура;
		Строка.Параметры.ЗаказКоличество = стрСверки.ЗаказКоличество;
		Строка.Параметры.СчетКоличество = стрСверки.СчетКоличество;
		Строка.Параметры.РазницаКоличество = стрСверки.РазницаКоличество;
		Строка.Параметры.ЗаказЦена = стрСверки.ЗаказЦена;
		Строка.Параметры.СчетЦена = стрСверки.СчетЦена;
		Строка.Параметры.РазницаЦена = стрСверки.РазницаЦена;
		
		ТабДок.Вывести(Строка);
	КонецЦикла;
	
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабДок.ПолеСверху = 5;
	ТабДок.ПолеСлева = 5;
	ТабДок.ПолеСнизу = 5;
	ТабДок.ПолеСправа = 5;
	
	Возврат ТабДок; 
	
КонецФункции


