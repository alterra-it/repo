#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&Вместо("РазбитьПоУпаковкамСправочно")
Процедура Док_РазбитьПоУпаковкамСправочно(Объект) Экспорт
	//Не разбиваем по упаковкам
КонецПроцедуры

&После("ЗарегистрироватьУчетныеМеханизмы")
Процедура Док_ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента)
	МеханизмыДокумента.Добавить("ОтгрузкаПоНакладным");    
	МеханизмыДокумента.Добавить("ДвижениеМаркированногоТовара"); 
КонецПроцедуры

&ИзменениеИКонтроль("ДанныеДокументаДляПроведения")
Функция Док_ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.РасходныйОрдерНаТовары") Тогда
		ДокументОбъект = Документ;
		ДокументСсылка = Документ.Ссылка;
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.РасходныйОрдерНаТовары") Тогда
		ДокументОбъект = Документ.ПолучитьОбъект();
		ДокументСсылка = Документ;
	Иначе
		ДокументОбъект = Неопределено;
		ДокументСсылка = Неопределено;
	КонецЕсли;

	Запрос = Новый Запрос;
	ТекстыЗапроса	= Новый СписокЗначений;
	
	ПолучитьДанныеДокумента(Запрос, ДокументСсылка);
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		
		ТекстЗапросаТаблицаДвиженияСерийТоваров(Запрос, ТекстыЗапроса, Регистры);
		#Вставка 
		ТекстЗапросаТаблицаКОтгрузкеПоНакладным(Запрос, ТекстыЗапроса, Регистры, Документ);  
		ТекстЗапросаТаблицаДвижениеМаркированногоТовара(Запрос, ТекстыЗапроса, Регистры, ДокументСсылка);
		#КонецВставки
	КонецЕсли;
	
	ОтгрузитьТоварСоСклада(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);

КонецФункции               

Функция ТекстЗапросаТаблицаДвижениеМаркированногоТовара(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект) экспорт
	ИмяРегистра = "ДвижениеМаркированногоТовара";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Штрихкоды.Ссылка.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	Штрихкоды.Ссылка.Склад КАК Склад,
	|	Штрихкоды.Ссылка.Накладная.Организация КАК Организация,
	|	Штрихкоды.ШтрихкодУпаковки КАК Штрихкод,
	|	ШтрихкодыУпаковка.Ссылка КАК ШтрихкодУпаковки,
	|	1 КАК Количество
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары.ШтрихкодыУпаковок КАК Штрихкоды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковка
	|		ПО Штрихкоды.ШтрихкодУпаковки = ШтрихкодыУпаковка.Штрихкод
	|ГДЕ
	|	Штрихкоды.Ссылка = &Ссылка  
	|   И Штрихкоды.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Отгружен)
	|	И ВЫБОР
	|			КОГДА Штрихкоды.Ссылка.Склад.ИспользоватьОрдернуюСхемуПриОтгрузке
	|					И Штрихкоды.Ссылка.Дата >= Штрихкоды.Ссылка.Склад.ДатаНачалаОрдернойСхемыПриОтгрузке
	|				ТОГДА истина
	|			ИНАЧЕ ложь
	|		КОНЕЦ";	
	
  	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	
	Возврат ТекстЗапроса;

КонецФункции

Функция ТекстЗапросаТаблицаКОтгрузкеПоНакладным(Запрос, ТекстыЗапроса, Регистры, Документ)
	
	ИмяРегистра = "ТоварыКОтгрузкеПоНакладным";
	
	Накладная = Неопределено;	
	Накладная = Документ.Накладная;
	
	Если Накладная = Неопределено Тогда
		Возврат "";
	КонецЕсли;	
		
	Если НЕ (ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) 
		И АльтерраОбщегоНазначения.ОтгрузкаПоНакладным(Накладная.Дата,Документ.Склад)) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса = 
	
	"ВЫБРАТЬ
	|	ДанныеШапки.Ссылка КАК Ссылка,
	|	ДанныеШапки.ДатаОтгрузки КАК Период,
	|	ДанныеШапки.Накладная КАК Документ,
	|	ДанныеШапки.Получатель КАК Получатель,
	|	ДанныеШапки.Склад КАК Склад,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Подготовлен)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК КСборке,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.КОтбору), ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.КПроверке))
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Собирается,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.Статус В (ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Проверен), ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.КОтгрузке))
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Собрано,
	|	ВЫБОР
	|		КОГДА ДанныеШапки.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.Отгружен)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК КОтгрузке
	|ПОМЕСТИТЬ ДанныеШапки
	|ИЗ
	|	Документ.РасходныйОрдерНаТовары КАК ДанныеШапки
	|ГДЕ
	|	ДанныеШапки.Ссылка В(&Ссылка)
	|	И ДанныеШапки.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыРасходныхОрдеров.ПустаяСсылка)
	|	И ДанныеШапки.Накладная <> НЕОПРЕДЕЛЕНО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДанныеШапки.Ссылка КАК Ссылка,
	|	ДанныеШапки.Период КАК Период,
	|	ДанныеШапки.Документ КАК Документ,
	|	ДанныеШапки.Получатель КАК Получатель,
	|	ДанныеШапки.Склад КАК Склад,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК РабочийУчасток,
	|	ДанныеШапки.КСборке КАК КСборке,
	|	ДанныеШапки.Собирается КАК Собирается,
	|	ДанныеШапки.Собрано КАК Собрано,
	|	ДанныеШапки.КОтгрузке КАК КОтгрузке,
	|	ВЫБОР
	|		КОГДА ТИПЗНАЧЕНИЯ(ТаблицаТовары.Распоряжение) В (Тип(Документ.ЗаказКлиента),Тип(Документ.ЗаказНаСборку),
	|              Тип(Документ.ЗаказНаПеремещение),Тип(Документ.ЗаказНаВнутреннееПотребление))
	|			ТОГДА ТаблицаТовары.Распоряжение
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Заказ,
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ТаблицаТовары.Назначение КАК Назначение,
	|	ТаблицаТовары.Количество КАК Количество
	|ПОМЕСТИТЬ ВтТаблицаТоваров
	|ИЗ
	|	ДанныеШапки КАК ДанныеШапки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК ТаблицаТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|			ПО ТаблицаТовары.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
	|				И ТаблицаТовары.Ссылка.Склад = РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад
	|				И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|		ПО ДанныеШапки.Ссылка = ТаблицаТовары.Ссылка
	|ГДЕ
	|	ТаблицаТовары.Номенклатура.ТипНоменклатуры В (ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар), ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.МногооборотнаяТара))
	|	И ТаблицаТовары.Ссылка В(&Ссылка)
	|	И ТаблицаТовары.Количество <> 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ДанныеДокумента.Ссылка				КАК Регистратор,
	|	ДанныеДокумента.Период				КАК Период,
	|	ДанныеДокумента.Склад				КАК Склад,
	|   ДанныеДокумента.РабочийУчасток      КАК РабочийУчасток,
	|	ДанныеДокумента.Получатель			КАК Получатель,
	|	ДанныеДокумента.Документ			КАК Накладная,
	|	ДанныеДокумента.Заказ			    КАК Заказ,
	|	ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|	ДанныеДокумента.Характеристика		КАК Характеристика,
	|	ДанныеДокумента.Назначение			КАК Назначение,
	|	ДанныеДокумента.Количество			КАК КСборке,
	|	0									КАК Собирается,
	|	0									КАК Собрано,
	|	0									КАК КОтгрузке
	|ИЗ
	|	ВтТаблицаТоваров КАК ДанныеДокумента
	|
	|ГДЕ
	|	ДанныеДокумента.КСборке
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ДанныеДокумента.Ссылка				КАК Регистратор,
	|	ДанныеДокумента.Период				КАК Период,
	|	ДанныеДокумента.Склад				КАК Склад,
	|   ДанныеДокумента.РабочийУчасток      КАК РабочийУчасток,
	|	ДанныеДокумента.Получатель			КАК Получатель,
	|	ДанныеДокумента.Документ			КАК Накладная,
	|	ДанныеДокумента.Заказ			    КАК Заказ,
	|	ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|	ДанныеДокумента.Характеристика		КАК Характеристика,
	|	ДанныеДокумента.Назначение			КАК Назначение,
	|	0									КАК КСборке,
	|	ДанныеДокумента.Количество			КАК Собирается,
	|	0									КАК Собрано,
	|	0									КАК КОтгрузке
	|ИЗ
	|	ВтТаблицаТоваров КАК ДанныеДокумента
	|
	|ГДЕ
	|	ДанныеДокумента.Собирается
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	ДанныеДокумента.Ссылка				КАК Регистратор,
	|	ДанныеДокумента.Период				КАК Период,
	|	ДанныеДокумента.Склад				КАК Склад,
	|   ДанныеДокумента.РабочийУчасток      КАК РабочийУчасток,
	|	ДанныеДокумента.Получатель			КАК Получатель,
	|	ДанныеДокумента.Документ			КАК Накладная,
	|	ДанныеДокумента.Заказ			    КАК Заказ,
	|	ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|	ДанныеДокумента.Характеристика		КАК Характеристика,
	|	ДанныеДокумента.Назначение			КАК Назначение,
	|	0									КАК КСборке,
	|	0									КАК Собирается,
	|	ДанныеДокумента.Количество			КАК Собрано,
	|	0									КАК КОтгрузке
	|ИЗ
	|	ВтТаблицаТоваров КАК ДанныеДокумента
	|
	|ГДЕ
	|	ДанныеДокумента.Собрано
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) КАК ВидДвижения,
	|	ДанныеДокумента.Ссылка				КАК Регистратор,
	|	ДанныеДокумента.Период				КАК Период,
	|	ДанныеДокумента.Склад				КАК Склад,
	|   ДанныеДокумента.РабочийУчасток      КАК РабочийУчасток,
	|	ДанныеДокумента.Получатель			КАК Получатель,
	|	ДанныеДокумента.Документ			КАК Накладная,
	|	ДанныеДокумента.Заказ			    КАК Заказ,
	|	ДанныеДокумента.Номенклатура		КАК Номенклатура,
	|	ДанныеДокумента.Характеристика		КАК Характеристика,
	|	ДанныеДокумента.Назначение			КАК Назначение,
	|	0									КАК КСборке,
	|	0									КАК Собирается,
	|	0									КАК Собрано,
	|	ДанныеДокумента.Количество			КАК КОтгрузке
	|ИЗ
	|	ВтТаблицаТоваров КАК ДанныеДокумента
	|
	|ГДЕ
	|	ДанныеДокумента.КОтгрузке";
	
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	// -
	
	Возврат ТекстЗапроса;

	
КонецФункции
     
Функция ПолучитьТоварыДляЗаполнения(Накладная,РабочийУчасток,Склад) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	
	"ВЫБРАТЬ 
	|	ВЫБОР
	|		КОГДА ТоварыКОтгрузкеПоНакладнымОстатки.Заказ = НЕОПРЕДЕЛЕНО
	|			ТОГДА ТоварыКОтгрузкеПоНакладнымОстатки.Накладная
	|		ИНАЧЕ ТоварыКОтгрузкеПоНакладнымОстатки.Заказ
	|	КОНЕЦ КАК Распоряжение,
	|	ЗНАЧЕНИЕ(Перечисление.ДействияСоСтрокамиОрдеровНаОтгрузку.Отобрать) КАК Действие,
	|	ТоварыКОтгрузкеПоНакладнымОстатки.Номенклатура КАК Номенклатура,
	|	ТоварыКОтгрузкеПоНакладнымОстатки.Характеристика КАК Характеристика,
	|	ТоварыКОтгрузкеПоНакладнымОстатки.Назначение КАК Назначение,
	|	ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток КАК Количество,
	|	ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток КАК КоличествоУпаковок
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузкеПоНакладным.Остатки КАК ТоварыКОтгрузкеПоНакладнымОстатки
	|ГДЕ
	|	ТоварыКОтгрузкеПоНакладнымОстатки.Накладная = &Накладная
	|	И ТоварыКОтгрузкеПоНакладнымОстатки.РабочийУчасток = &РабочийУчасток
	|	И ТоварыКОтгрузкеПоНакладнымОстатки.Склад = &Склад
	|   И ТоварыКОтгрузкеПоНакладнымОстатки.КОтгрузкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.КСборкеОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобираетсяОстаток - ТоварыКОтгрузкеПоНакладнымОстатки.СобраноОстаток > 0";
	
	
	Запрос.УстановитьПараметр("Накладная", Накладная);
	Запрос.УстановитьПараметр("РабочийУчасток", РабочийУчасток);
	Запрос.УстановитьПараметр("Склад", Склад);

	РезультатЗапроса = Запрос.Выполнить().Выгрузить();	
	
	УстановитьПривилегированныйРежим(Ложь); 
	
	Возврат РезультатЗапроса;
	
КонецФункции

