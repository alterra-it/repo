&НаСервере
Процедура СортировкаПоЯчейке()
	
	Если Объект.ОтгружаемыеТовары.Количество()>0 Тогда
		
		Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
					|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
					|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
					|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
					|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
					|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
					|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
					|	ВнешняяТаблицаНоменклатуры.Действие КАК Действие,
					|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
					|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
					|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
					|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
					|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
					|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
					|ИЗ
					|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
					|
					|ИНДЕКСИРОВАТЬ ПО
					|	Номенклатура
					|;
					|
					|////////////////////////////////////////////////////////////////////////////////
					|ВЫБРАТЬ
					|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
					|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
					|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
					|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
					|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Наименование КАК ЯчейкаНаименование,
					|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
					|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
					|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
					|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
					|	ВнешняяТаблицаНоменклатуры.Действие КАК Действие,
					|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
					|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
					|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
					|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
					|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
					|ИЗ
					|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
					|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
					|		ПО ВнешняяТаблицаНоменклатуры.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
					|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
					|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
					|
					|УПОРЯДОЧИТЬ ПО
					|	ЯчейкаНаименование";
					
					Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры",Объект.ОтгружаемыеТовары.Выгрузить());
					Запрос.УстановитьПараметр("Склад",Объект.Склад);
					
					Объект.ОтгружаемыеТовары.Очистить();
					Объект.ОтгружаемыеТовары.Загрузить(Запрос.Выполнить().Выгрузить());

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док__СортировкаПоЯчейкеПосле(Команда)
	СортировкаПоЯчейке();
КонецПроцедуры

Функция ПолучитьНомерВерсииПеремещения()
	Возврат АльтерраОбщегоНазначения.ПолучитьКоличествоЗаписейВРегистреСобытияДокументов(ПолучитьПеремещениеПоЗаказам(),Перечисления.СобытияДокументов.ИзменениеТабличнойЧасти);
КонецФункции

Функция ПолучитьПеремещениеПоЗаказам()
	
	СсылкаНаПеремещение = Документы.ПеремещениеТоваров.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение КАК Распоряжение
		|ПОМЕСТИТЬ ВТ_Распоряжения
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары.ТоварыПоРаспоряжениям КАК РасходныйОрдерНаТоварыТоварыПоРаспоряжениям
		|ГДЕ
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходныйОрдерНаТоварыТоварыПоРаспоряжениям.Распоряжение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.Ссылка КАК Ссылка
		|ИЗ
		|	ВТ_Распоряжения КАК ВТ_Распоряжения
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|		ПО (ПеремещениеТоваровТовары.Ссылка = ВТ_Распоряжения.Распоряжение
		|				ИЛИ ПеремещениеТоваровТовары.ЗаказНаПеремещение = ВТ_Распоряжения.Распоряжение)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПеремещениеТоваровТовары.Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СсылкаНаПеремещение = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат СсылкаНаПеремещение;
КонецФункции

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	ПосчитатьИтогПоВесу();
КонецПроцедуры

&НаКлиенте
Процедура Док_ОтгружаемыеТоварыКоличествоУпаковокПриИзмененииПосле(Элемент)
	ПосчитатьИтогПоВесу();
КонецПроцедуры

&НаКлиенте
Процедура ПосчитатьИтогПоВесу()
	
	ВесВсего = 0;
    
    Для Каждого Строка Из Объект.ОтгружаемыеТовары Цикл
		//Если Элементы.ОтгружаемыеТовары.ПроверитьСтроку(Строка) тогда
            ВесВсего = ВесВсего+Строка.Вес;
		//КонецЕсли;  
	КонецЦикла;
	
    Элементы.ОтгружаемыеТоварыВес.ТекстПодвала = ВесВсего;
	
КонецПроцедуры

#КонецОбласти   

#Область ИнициализацияЯПХ

&НаКлиенте
Процедура ЯчейкаПромежуточногоХраненияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ПараметрыОткрытияФормы = ПараметрыОткрытияФормы_СкладскиеЯчейки(СтандартнаяОбработка);
	
	Если СтандартнаяОбработка Тогда
		СтандартнаяОбработка = Ложь;
	Иначе
		Возврат;
	КонецЕсли;
	
	ОткрытьФорму("Справочник.СкладскиеЯчейки.Форма.ФормаВыбора", 
		ПараметрыОткрытияФормы,
		ЭтаФорма, 
		, 
		, 
		,
		Новый ОписаниеОповещения("ЯчейкаПромежуточногоХраненияНачалоВыбора_Завершение", ЭтаФорма), 
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);   
				
КонецПроцедуры        
	
&НаКлиенте
Процедура ЯчейкаПромежуточногоХраненияНачалоВыбора_Завершение(НовоеЗначение, ДополнительныеПараметры) Экспорт
	Если НовоеЗначение <> Неопределено Тогда
		Объект.ЯчейкаПромежуточногоХранения = НовоеЗначение;
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыРасходныхОрдеров.КОтгрузке");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПараметрыОткрытияФормы_СкладскиеЯчейки(СтандартнаяОбработка)     
	
	СекцииСотрудника = Справочники.Сотрудники.НайтиПоРеквизиту("Пользователь", Пользователи.ТекущийПользователь()).РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток");
	
	МассивСсылокИерархия = Новый Массив;     
	РабочийУчасток = Справочники.РабочиеУчастки.ПустаяСсылка();         
	
	Если СекцииСотрудника.Количество() > 0 Тогда
		Для Каждого Строка Из СекцииСотрудника.ВыгрузитьЗначения() Цикл
			МассивСсылокИерархия.Добавить(Строка.ГруппаСкладскихЯчеекХраненияПриОтгрузке);		
		КонецЦикла;                   
	ИначеЕсли ЗначениеЗаполнено(Объект.РабочийУчасток) Тогда
		Если ЗначениеЗаполнено(Объект.РабочийУчасток.ГруппаСкладскихЯчеекХраненияПриОтгрузке) Тогда
			МассивСсылокИерархия.Добавить(Объект.РабочийУчасток.ГруппаСкладскихЯчеекХраненияПриОтгрузке);
		Иначе       
			РабочиеУчастки = Объект.РабочийУчасток;
		КонецЕсли;	  
	Иначе
		СтандартнаяОбработка = Ложь;
		ОбщегоНазначения.СообщитьПользователю("Необходимо сначала указать рабочий участок!");
	КонецЕсли;  
	
	Возврат Новый Структура("МассивСсылокИерархия, РабочийУчасток", МассивСсылокИерархия, РабочийУчасток);

КонецФункции 

#КонецОбласти

&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		СФП_МаркерыКлиент.МаркерНачало("Расходный ордер на товары: проведение из формы", Объект.Номер);
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция Док_ЗаполнитьПоРегиструМППослеНаСервере(Отработаные) 
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	БылиИзменения = ОбменУТМПСервер.ЗаполнитьОрдер(ДокОбъект, "ОтгружаемыеТовары", Отработаные); 
	ЗначениеВРеквизитФормы(ДокОбъект, "Объект"); 
	Возврат БылиИзменения;
КонецФункции

&НаКлиенте
Процедура Док_ЗаполнитьПоРегиструМППосле(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьОтветЗаполнениеПоРегистру", ЭтаФорма);
	ТекстВопроса = "Дозаполнить только необработанные строки?";
   	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
КонецПроцедуры 

&НаКлиенте
Процедура ОбработатьОтветЗаполнениеПоРегистру(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отработаные = Ложь;
	Иначе
		Отработаные = Истина;	
	КонецЕсли;
	БылиИзменения = Док_ЗаполнитьПоРегиструМППослеНаСервере(Отработаные);
	Если БылиИзменения Тогда
		ЭтаФорма.Модифицированность = Истина;
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьОтветОчисткаПустыхСтрок", ЭтаФорма);
		ТекстВопроса = "Очистить неотработанные строки?";
	   	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
КонецПроцедуры 

&НаКлиенте
Процедура ОбработатьОтветОчисткаПустыхСтрок(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработатьОтветОчисткаПустыхСтрокНаСервере();
	КонецЕсли;	 	
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьОтветОчисткаПустыхСтрокНаСервере() 
	
	МассивСтрок = Объект.ОтгружаемыеТовары.НайтиСтроки(Новый Структура("КоличествоУпаковок",0));
	Для Каждого Строка Из МассивСтрок Цикл
		Объект.ОтгружаемыеТовары.Удалить(Строка);
	КонецЦикла;	
	ПерезаполнитьОтгружаемымиТоварамиСервер();
	
КонецПроцедуры	






