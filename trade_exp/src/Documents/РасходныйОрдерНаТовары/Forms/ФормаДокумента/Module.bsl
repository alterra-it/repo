#Область Доработки_по_ордерной_схеме

&НаСервере
&ИзменениеИКонтроль("ЗаполнитьПоРаспоряжению")
Процедура Док_ЗаполнитьПоРаспоряжению()
	
	#Вставка
		Если Не ЗначениеЗаполнено(Объект.Накладная) Тогда
			ОбщегоНазначения.СообщитьПользователю("Необходимо указать накладную!");
			Возврат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.РабочийУчасток) Тогда
			ОбщегоНазначения.СообщитьПользователю("Необходимо указать рабочий участок!");
			Возврат;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
			ОбщегоНазначения.СообщитьПользователю("Необходимо сначала записать документ!");
			Возврат;
		КонецЕсли;
		
		ЗаполнитьПоНакладной();
	#КонецВставки
	
	#Удаление
	Документы.РасходныйОрдерНаТовары.ЗаполнитьОтгружаемыеТоварыПоТоварамПоРаспоряжениям(Объект); 
	РасходныйОрдерНаТоварыЛокализация.УстановитьПризнакИспользованияМаркируемойПродукции(ЭтотОбъект);
	УстановитьВидимостьЭлементовУпаковкиПриМаркировке();
	
	УпаковочныеЛистыСервер.ПриЧтенииСозданииФормыСУпаковочнымиЛистами(ЭтотОбъект,
																Объект.ОтгружаемыеТовары,
																Объект.Ссылка.Метаданные().ПредставлениеОбъекта);
	#КонецУдаления   
	
	ЗаполнитьСлужебныеРеквизитыТЧТовары("ОтгружаемыеТовары", Истина);
	НоменклатураСервер.ЗаполнитьСерииПоFEFO(Объект,ПараметрыУказанияСерий.ОтгружаемыеТовары, Ложь);	
	
	#Удаление
	Если Не СкладыСервер.ИспользоватьАдресноеХранение(Объект.Склад, Объект.Помещение, Объект.ДатаОтгрузки)
		И ПолучитьФункциональнуюОпцию("ИспользоватьУпаковкиНоменклатуры") Тогда
		Документы.РасходныйОрдерНаТовары.РазбитьПоУпаковкамСправочно(Объект);
	КонецЕсли;
	#КонецУдаления

	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект,ПараметрыУказанияСерий.ОтгружаемыеТовары);
	
	ОтобразитьИнформациюПоНеотгружаемымТоварам();
	
	ЗаполнитьСлужебныеРеквизитыТЧТовары("ОтгружаемыеТовары", Ложь);

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоНакладной()
	
	Объект.ОтгружаемыеТовары.Очистить();
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьСтатусыРасходныхОрдеров", Новый Структура("Склад", Объект.Склад)) Тогда
		Действие = Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку.Отобрать;
	Иначе
		Действие = Перечисления.ДействияСоСтрокамиОрдеровНаОтгрузку.Отгрузить;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыКОтгрузкеПоНакладным.Регистратор КАК Регистратор,
		|	ТоварыКОтгрузкеПоНакладным.Накладная КАК Накладная,
		|	ТоварыКОтгрузкеПоНакладным.Номенклатура КАК Номенклатура,
		|	ТоварыКОтгрузкеПоНакладным.Характеристика КАК Характеристика,
		|	ТоварыКОтгрузкеПоНакладным.Назначение КАК Назначение,
		|	ТоварыКОтгрузкеПоНакладным.Серия КАК Серия,
		|	СУММА(ТоварыКОтгрузкеПоНакладным.КОтгрузке + ТоварыКОтгрузкеПоНакладным.КСборке + ТоварыКОтгрузкеПоНакладным.Собирается + ТоварыКОтгрузкеПоНакладным.Собрано) КАК Количество
		|ПОМЕСТИТЬ ВТДанные
		|ИЗ
		|	РегистрНакопления.ТоварыКОтгрузкеПоНакладным КАК ТоварыКОтгрузкеПоНакладным
		|ГДЕ
		|	ТоварыКОтгрузкеПоНакладным.РабочийУчасток = &РабочийУчасток
		|	И ТоварыКОтгрузкеПоНакладным.Накладная = &Накладная
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКОтгрузкеПоНакладным.Регистратор,
		|	ТоварыКОтгрузкеПоНакладным.Накладная,
		|	ТоварыКОтгрузкеПоНакладным.Номенклатура,
		|	ТоварыКОтгрузкеПоНакладным.Характеристика,
		|	ТоварыКОтгрузкеПоНакладным.Назначение,
		|	ТоварыКОтгрузкеПоНакладным.Серия
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Данные.Номенклатура КАК Номенклатура,
		|	Данные.Характеристика КАК Характеристика,
		|	Данные.Назначение КАК Назначение,
		|	Данные.Серия КАК Серия
		|ПОМЕСТИТЬ ВТДанныеПоДругимРасходнымОрдерам
		|ИЗ
		|	ВТДанные КАК Данные
		|ГДЕ
		|	Данные.Регистратор <> &Накладная
		|	И Данные.Регистратор <> &ТекущийРасходныйОрдерНаТовары
		|	И Данные.Регистратор ССЫЛКА Документ.РасходныйОрдерНаТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Данные.Номенклатура КАК Номенклатура,
		|	Данные.Характеристика КАК Характеристика,
		|	Данные.Назначение КАК Назначение,
		|	Данные.Серия КАК Серия,
		|	Данные.Количество КАК Количество
		|ИЗ
		|	ВТДанные КАК Данные
		|ГДЕ
		|	Данные.Регистратор = &Накладная
		|	И НЕ (Данные.Номенклатура, Данные.Характеристика, Данные.Назначение, Данные.Серия) В
		|				(ВЫБРАТЬ
		|					ВТДанныеПоДругимРасходнымОрдерам.Номенклатура,
		|					ВТДанныеПоДругимРасходнымОрдерам.Характеристика,
		|					ВТДанныеПоДругимРасходнымОрдерам.Назначение,
		|					ВТДанныеПоДругимРасходнымОрдерам.Серия
		|				ИЗ
		|					ВТДанныеПоДругимРасходнымОрдерам)";
	
	Запрос.УстановитьПараметр("Накладная", Объект.Накладная);
	Запрос.УстановитьПараметр("РабочийУчасток", Объект.РабочийУчасток);
	Запрос.УстановитьПараметр("ТекущийРасходныйОрдерНаТовары", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Пока РезультатЗапроса.Следующий() Цикл
		НоваяСтрока = Объект.ОтгружаемыеТовары.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, РезультатЗапроса);
		
		НоваяСтрока.КоличествоУпаковок = РезультатЗапроса.Количество;
		НоваяСтрока.Действие = Действие;
	КонецЦикла;
	
	Объект.ВсегоМест = УпаковочныеЛистыСервер.КоличествоМестВТЧ(Объект.ОтгружаемыеТовары);

КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	Элементы.ТоварыПоРаспоряжениям.Видимость = РольДоступна("ПолныеПрава");

	Если Объект.СкладскаяОперация = Перечисления.СкладскиеОперации.ОтгрузкаПоПеремещению Тогда
		_НомерВерсииПеремещения = ПолучитьНомерВерсииПеремещения();
	КонецЕсли; 
	
	ОграничитьДоступность();  
	
	Если ОбменУТМПСервер.ОрдерЗаполнялсяВМП(Объект.Ссылка, Объект.Накладная) Тогда
		Элементы.ОтгружаемыеТоварыЗаполнитьПоРегиструМП.Видимость = Истина;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_ПередЗаписьюНаСервереПеред(Отказ, ТекущийОбъект, ПараметрыЗаписи)
КонецПроцедуры

&НаСервере
Процедура Док_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)
КонецПроцедуры

&НаСервере
Процедура ОграничитьДоступность()       
	
	Если РольДоступна("МенеджерТорговогоЗала") Или РольДоступна("СотрудникМД") Тогда
		ЭтаФорма.ТолькоПросмотр = Истина;
		// Расширяемые элементы
		Элементы.ПроверитьКоличество.Доступность = Ложь;
		Элементы.ИсправитьКоличество.Доступность = Ложь;
		Элементы.ТоварыПоРаспоряжениямПерезаполнитьОтгружаемымиТоварами.Доступность = Ложь;
		Элементы.ТипОтгрузки.Доступность = Ложь;
	КонецЕсли; 
	
КонецПроцедуры	

&НаКлиенте
Процедура Док_ОтгружаемыеТоварыПриИзмененииПосле(Элемент)
	 ПерезаполнитьОтгружаемымиТоварамиСервер();
	 ОчиститьСообщения();
КонецПроцедуры

