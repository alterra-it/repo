#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью1(Отказ, РежимЗаписи, РежимПроведения)
	
	Если Не Отказ И
		Не ЗначениеЗаполнено(ЯчейкаПромежуточногоХранения) И 
		Статус = Перечисления.СтатусыРасходныхОрдеров.КОтгрузке Тогда
		
		Отказ = Истина;
		ОбщегоНазначения.СообщитьПользователю("Необходимо заполнить реквизит 'Ячейка промежуточного хранения'");
	КонецЕсли;
		
КонецПроцедуры
	
&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если Не Отказ И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		ДополнительныеСвойства.Вставить("ЗначениеСтатуса", Ссылка.Статус);
		
		Если Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
			Дата = ДатаОтгрузки;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
	
&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);
	
	Если Не Проведен Тогда
		РегистрыСведений.ТоварыВЯчейкеПромежуточногоХранения.ОбновитьЗаписьВРегистре(Ссылка);
		РегистрыСведений.ЭлектроннаяОчередьКлиентов.ОбновитьСостояниеДокумента(Ссылка);
		РегистрыСведений.СостоянияОтгрузкиНакладных.ОбновитьСостояниеОтгрузкиНакладной(Накладная,Склад,РабочийУчасток);
    КонецЕсли;
	
	Если Альтерра_СкладСервер.ПоДокументуЕстьАктПоРасхождениям(ЭтотОбъект.Накладная) И не АльтерраОбщегоНазначения._РольДоступна("ПолныеПрава") Тогда
		 Отказ = Истина;
		 Сообщить("По документу основанию есть акт по расхождениям, редактирование заблокировано!");
	КонецЕсли;
		
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ДополнительныеСвойства.Свойство("ЗначениеСтатуса") И ДополнительныеСвойства.ЗначениеСтатуса <> Ссылка.Статус Тогда
		
		Дата = ?(ДополнительныеСвойства.ЗначениеСтатуса = Перечисления.СтатусыРасходныхОрдеров.Подготовлен, ТекущаяДата()+ 1, ТекущаяДата());
		НаборЗаписей = РегистрыСведений.СтатусыОрдеров.СоздатьНаборЗаписей();
		Запись = НаборЗаписей.Добавить();
		Запись.Период = Дата;
		Запись.Документ = Ссылка;
		Запись.Статус = Ссылка.Статус;
		Запись.Пользователь = Пользователи.ТекущийПользователь();  
		Запись.Сотрудник  = Альтерра_СкладСервер.ТекущийСотрудник();
		НаборЗаписей.Записать(Ложь);
		
	КонецЕсли;
	
	РегистрыСведений.СостоянияОтгрузкиНакладных.ОбновитьСостояниеОтгрузкиНакладной(Накладная,Склад,РабочийУчасток);

	РегистрыСведений.ЭлектроннаяОчередьКлиентов.ОбновитьСостояниеДокумента(Ссылка); 
	
	РегистрыСведений.ТоварыВЯчейкеПромежуточногоХранения.ОбновитьЗаписьВРегистре(Ссылка); 
	//Обновляем необходимость оповещени
	Очередь	= РегистрыСведений.ЭлектроннаяОчередьКлиентов;
	НаборЗаписей = Очередь.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Документ.Установить(Ссылка.Накладная); 
	НаборЗаписей.Отбор.Склад.Установить(Ссылка.Склад);
	НаборЗаписей.Отбор.Секция.Установить(Ссылка.РабочийУчасток);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() <> 0 Тогда
		МассивСтрокДляУдаления = Новый Массив;
		Для Индекс = 1 - НаборЗаписей.Количество() По 0 Цикл
			
			Запись = НаборЗаписей[-Индекс];
			
			Если Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.КОтбору Тогда
				Если Запись.ПолучательУведомления = РабочийУчасток Тогда  //взят в работу после оповещения
					Запись.ПолучательУведомления = Сотрудник;
				КонецЕсли; 
				Запись.Состояние = Перечисления.СтатусыЭлектроннойОчереди.Набирается;
				Прервать;
			КонецЕсли;
			
			Если Ссылка.Статус = Перечисления.СтатусыРасходныхОрдеров.Отгружен Тогда
					Запись.ТребуетсяОповещениеКладовщику = Ложь;
					Запись.ПолучательУведомления = Неопределено;
			КонецЕсли;
			
		КонецЦикла;
		
		НаборЗаписей.Записать();
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&После("ОбработкаУдаленияПроведения")
Процедура Док_ОбработкаУдаленияПроведения(Отказ)
		РегистрыСведений.ЭлектроннаяОчередьКлиентов.ОбновитьСостояниеДокумента(Ссылка);
		РегистрыСведений.СостоянияОтгрузкиНакладных.ОбновитьСостояниеОтгрузкиНакладной(Накладная,Склад,РабочийУчасток);
		ОбменУТМПСервер.УдалитьСвязанныеЗаписиОбменМП(Ссылка);
КонецПроцедуры

#КонецЕсли

