Функция ДокументыПродажиБылиИзменены() Экспорт
	ТЧДок = РасчетДоставки.Выгрузить();
	Запрос = Новый Запрос;
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ТЧДок.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|	ТЧДок.ДокументПродажи КАК ДокументПродажи
		|ПОМЕСТИТЬ втТЧДок
		|ИЗ &ТЧДок КАК ТЧДок;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыПродажи.Документ КАК Документ
		|ПОМЕСТИТЬ ВтДокументыПродажиИзОснований
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ДокументыПродажи
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втТЧДок КАК втТЧДок
		|		ПО ДокументыПродажи.Ссылка = втТЧДок.ЗаказНаДоставку;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВтДокументыПродажиИзОснований.Документ КАК Документ
		|ИЗ
		|	ВтДокументыПродажиИзОснований КАК ВтДокументыПродажиИзОснований
		|		ЛЕВОЕ СОЕДИНЕНИЕ втТЧДок КАК втТЧДок
		|		ПО (втТЧДок.ДокументПродажи = ВтДокументыПродажиИзОснований.Документ)
		|ГДЕ
		|	втТЧДок.ДокументПродажи ЕСТЬ NULL
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	втТЧДок.ДокументПродажи
		|ИЗ
		|	ВтДокументыПродажиИзОснований КАК ВтДокументыПродажиИзОснований
		|		ПРАВОЕ СОЕДИНЕНИЕ втТЧДок КАК втТЧДок
		|		ПО (втТЧДок.ДокументПродажи = ВтДокументыПродажиИзОснований.Документ)
		|ГДЕ
		|	ВтДокументыПродажиИзОснований.Документ ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("ТЧДок", ТЧДок);
	Результат = Запрос.Выполнить().Выгрузить();
	Результат = Результат.ВыгрузитьКолонку("Документ");
	
	Если Результат.Количество() <> 0 Тогда
		Возврат Истина
	КонецЕсли;

	Возврат Ложь
КонецФункции

//Восстанавливает регистрации расходов при снятии пометки удаления
Процедура ПересчитатьДокумент()
	Если  (ЭтотОбъект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя ИЛИ 
		  ЭтотОбъект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная) Тогда
		Документы.ЗаданиеНаПеревозкуРейс.СформироватьЗатраты(ЭтотОбъект, Ложь);
	КонецЕсли;  	
КонецПроцедуры
#КонецЕсли
