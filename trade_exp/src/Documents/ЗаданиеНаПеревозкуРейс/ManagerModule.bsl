#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область Заполнение 

Процедура ЗаполнитьДанныеПоОснованию(ДанныеЗаполнения, Объект)   Экспорт
	
	КомментарийПоЗаказам = "";
	
	Если ЗначениеЗаполнено(ДанныеЗаполнения) Тогда
		Если ТипЗнч(ДанныеЗаполнения) = Тип("Массив") Тогда
			мОснований = ДанныеЗаполнения;
		Иначе
			мОснований = Новый Массив();
			мОснований.Добавить(ДанныеЗаполнения);
		КонецЕсли;
		
		Для Каждого  Основание Из мОснований Цикл  
			НоваяСтрока = Объект.Основания.Найти(Основание, "Документ");
			Если НоваяСтрока = Неопределено Тогда 
				НоваяСтрока = Объект.Основания.Добавить();
				НоваяСтрока.Документ = Основание;
			КонецЕсли;
			Если Не Объект.Экспресс Тогда
				Объект.Экспресс = Основание.ЭкспрессДоставка;
			КонецЕсли;
			Если Не Объект.ЕстьВнеЗоны Тогда
				Объект.ЕстьВнеЗоны = Основание.ЗонаДоставкиДляВодителя.Наименование = "Вне зоны";
			КонецЕсли;
		КонецЦикла;
		
		ЗаполнитьЗначенияСвойств(Объект, мОснований[0],,"Дата,Номер,Проведен");
		Объект.Автор = Пользователи.ТекущийПользователь();
		Объект.Дата = ТекущаяДата();
	КонецЕсли;
	
	Для каждого Основание из Объект.Основания Цикл
		КомментарийПоЗаказам = КомментарийПоЗаказам + Основание.Документ.Комментарий + "; ";
	КонецЦикла;
		
	ПерезаписатьЗаказыНаДоставку(Объект);
	ЗаполнитьРасчетДоставки(Объект);
	ЗаполнитьРасчетныеДанныеВШапке(Объект);//нельзя уже нужен водитель и автомобиль
	РасчетОплатыВодителю(Объект);
	РассчитатьСтроки(Объект);
	
	Объект.Комментарий = КомментарийПоЗаказам;
	Объект.Вес = Объект.РасчетДоставки.Итог("Вес");
	УстановитьОбъемы(Объект);
КонецПроцедуры
Процедура ЗаполнитьРасчетДоставки(Объект) Экспорт
	
	Для Каждого стрОснование Из Объект.Основания Цикл  
		ЗаказНаДоставку = стрОснование.Документ;
		мДокПродажи = ЗаказНаДоставку.Основания.ВыгрузитьКолонку("Документ");
		
		//Удаляем если нет док продажи в основании
		мСтрокРасчетаДоставки= Объект.РасчетДоставки.НайтиСтроки(Новый Структура("ЗаказНаДоставку", ЗаказНаДоставку));
		Для Каждого стрРасчетДоставки Из мСтрокРасчетаДоставки Цикл
			Если мДокПродажи.Найти(стрРасчетДоставки.ДокументПродажи) = Неопределено Тогда
				Объект.РасчетДоставки.Удалить(стрРасчетДоставки);
			КонецЕсли;
		КонецЦикла;	
		
		//Добавляем документы продажи в расчет доставки если нет		
		Для Каждого стрДокПродажи Из ЗаказНаДоставку.Основания Цикл
			мСтрок= Объект.РасчетДоставки.НайтиСтроки(Новый Структура("ДокументПродажи", стрДокПродажи.Документ));
			Если мСтрок.Количество() = 0 Тогда 
				НоваяСтрока = Объект.РасчетДоставки.Добавить();
				НоваяСтрока.ЗаказНаДоставку = ЗаказНаДоставку;
				НоваяСтрока.ДокументПродажи = стрДокПродажи.Документ;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
КонецПроцедуры

// Запросы
Функция ПолучитьОбщийПакетЗапросов()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Основания.Документ КАК Документ
		|ПОМЕСТИТЬ Основания
		|ИЗ
		|	&Основания КАК Основания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(СтоимостьДоставкиПоЗонам.Период) КАК Период,
		|	СтоимостьДоставкиПоЗонам.ЗонаДоставки КАК ЗонаДоставки,
		|	СтоимостьДоставкиПоЗонам.Тариф КАК Тариф,
		|	СтоимостьДоставкиПоЗонам.Филиал КАК Филиал,
		|	ЗаказНаДоставкуКлиенту.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ВТ_ДатыИзРегистра
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтоимостьДоставкиПоЗонам КАК СтоимостьДоставкиПоЗонам
		|		ПО (СтоимостьДоставкиПоЗонам.Период <= ЗаказНаДоставкуКлиенту.Дата)
		|			И (СтоимостьДоставкиПоЗонам.ЗонаДоставки = ЗаказНаДоставкуКлиенту.ЗонаДоставкиДляВодителя)
		|			И (СтоимостьДоставкиПоЗонам.Тариф = ЗаказНаДоставкуКлиенту.Тариф)
		|			И (СтоимостьДоставкиПоЗонам.Филиал = ЗаказНаДоставкуКлиенту.Подразделение)
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|
		|СГРУППИРОВАТЬ ПО
		|	СтоимостьДоставкиПоЗонам.ЗонаДоставки,
		|	СтоимостьДоставкиПоЗонам.Тариф,
		|	СтоимостьДоставкиПоЗонам.Филиал,
		|	ЗаказНаДоставкуКлиенту.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СтоимостьДоставкиПоЗонам.Период КАК Период,
		|	СтоимостьДоставкиПоЗонам.ЗонаДоставки КАК ЗонаДоставки,
		|	СтоимостьДоставкиПоЗонам.Тариф КАК Тариф,
		|	СтоимостьДоставкиПоЗонам.Филиал КАК Филиал,
		|	СтоимостьДоставкиПоЗонам.СтоимостьДляВодителя КАК СтоимостьДляВодителя,
		|	СтоимостьДоставкиПоЗонам.СтоимостьДляКлиента КАК СтоимостьДляКлиента,
		|	СтоимостьДоставкиПоЗонам.МинимальнаяСтоимость КАК МинимальнаяСтоимость
		|ПОМЕСТИТЬ ВТ_СрезПоследних
		|ИЗ
		|	ВТ_ДатыИзРегистра КАК ВТ_ДатыИзРегистра
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтоимостьДоставкиПоЗонам КАК СтоимостьДоставкиПоЗонам
		|		ПО ВТ_ДатыИзРегистра.Период = СтоимостьДоставкиПоЗонам.Период
		|			И ВТ_ДатыИзРегистра.ЗонаДоставки = СтоимостьДоставкиПоЗонам.ЗонаДоставки
		|			И ВТ_ДатыИзРегистра.Тариф = СтоимостьДоставкиПоЗонам.Тариф
		|			И ВТ_ДатыИзРегистра.Филиал = СтоимостьДоставкиПоЗонам.Филиал
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиенту.Ссылка КАК Заказ,
		|	МАКСИМУМ(ЗаказНаДоставкуКлиенту.СтоимостьДоставки) КАК СтоимостьДоставки,
		|	МАКСИМУМ(ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС / &СтавкаНДС) КАК СтоимостьДоставкиСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0)) КАК СтоимостьДляВодителя,
		|	МАКСИМУМ(ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента, 0)) КАК СтоимостьДляКлиента,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставки > 0
		|				ТОГДА ВЫБОР
		|						КОГДА ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0) <= 1
		|							ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставки
		|						ИНАЧЕ ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0)
		|					КОНЕЦ
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьДляВодителяБезНДС,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС > 0
		|				ТОГДА ВЫБОР
		|						КОГДА ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0) <= 1
		|							ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС / &СтавкаНДС
		|						ИНАЧЕ ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0)
		|					КОНЕЦ
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьДляВодителяСНДС,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставки > 0
		|				ТОГДА ВЫБОР
		|						КОГДА ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента, 0) <= 1
		|							ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставки
		|						ИНАЧЕ ВЫБОР
		|								КОГДА ЗаказНаДоставкуКлиенту.Тариф.ПоТарифуВодителя
		|									ТОГДА ВЫБОР
		|											КОГДА ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0) <= 1
		|												ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставки
		|											ИНАЧЕ ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя, 0)
		|										КОНЕЦ
		|								ИНАЧЕ ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента, 0)
		|							КОНЕЦ
		|					КОНЕЦ
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьДляКлиентаБезНДС,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС > 0
		|				ТОГДА ЕСТЬNULL(СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента, 0)
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьДляКлиентаСНДС
		|ПОМЕСТИТЬ ВТ_Максимум
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СрезПоследних КАК СтоимостьДоставкиПоЗонамСрезПоследних
		|		ПО ЗаказНаДоставкуКлиенту.ЗонаДоставкиДляВодителя = СтоимостьДоставкиПоЗонамСрезПоследних.ЗонаДоставки
		|			И ЗаказНаДоставкуКлиенту.Тариф = СтоимостьДоставкиПоЗонамСрезПоследних.Тариф
		|			И ЗаказНаДоставкуКлиенту.Подразделение = СтоимостьДоставкиПоЗонамСрезПоследних.Филиал
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказНаДоставкуКлиенту.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(МАКСИМУМ(ВЫБОР
		|				КОГДА ВТ_Максимум.СтоимостьДляВодителяБезНДС <= 1
		|					ТОГДА ВТ_Максимум.СтоимостьДоставки
		|				ИНАЧЕ ВТ_Максимум.СтоимостьДляВодителяБезНДС
		|			КОНЕЦ), 0) КАК МаксимальнаяСтоимостьДляВодителяБезНДС,
		|	ЕСТЬNULL(МАКСИМУМ(ВЫБОР
		|				КОГДА ВТ_Максимум.СтоимостьДляВодителяСНДС <= 1
		|					ТОГДА ВТ_Максимум.СтоимостьДоставкиСНДС
		|				ИНАЧЕ ВТ_Максимум.СтоимостьДляВодителяСНДС
		|			КОНЕЦ), 0) КАК МаксимальнаяСтоимостьДляВодителяСНДС
		|ИЗ
		|	ВТ_Максимум КАК ВТ_Максимум" + ";"; 
	
	Возврат Запрос;
КонецФункции
Функция ПолучитьПакетЗапросов(Объект, СтавкаНДС, ДопТочка)
	Запрос = ПолучитьОбщийПакетЗапросов();
	Запрос.Текст = Запрос.Текст +
		"ВЫБРАТЬ
		|	СУММА(ЗаказНаДоставкуКлиенту.Вес) КАК Вес,
		|	СУММА(ЗаказНаДоставкуКлиенту.Объем) КАК Объем,
		|	СУММА(ЗаказНаДоставкуКлиенту.СтоимостьДоставки) КАК СтоимостьДоставок,
		|	МАКСИМУМ(ЗаказНаДоставкуКлиенту.МаксимальнаяДлина) КАК МаксимальнаяДлина,
		|	СУММА(ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС) КАК СтоимостьДоставокСНДС,
		|	СУММА(ЗаказНаДоставкуКлиенту.СтоимостьТовара) КАК СтоимостьТовара,
		|	МАКСИМУМ(ЗаказНаДоставкуКлиенту.ЭкспрессДоставка) КАК Экспресс,
		|	СУММА(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.ЗонаДоставкиДляВодителя.Наименование = ""Вне зоны""
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ЕстьВнеЗоны,
		|	МАКСИМУМ(ЗаказНаДоставкуКлиенту.НужнаИнкассация) КАК НужнаИнкассация,
		|	МАКСИМУМ(ЗаказНаДоставкуКлиенту.ОплатаБанковскойКартой) КАК ОплатаБанковскойКартой,
		|	СУММА(ЗаказНаДоставкуКлиенту.Разгрузка) КАК Разгрузка,
		|	СУММА(ЗаказНаДоставкуКлиенту.РазгрузкаСНДС) КАК РазгрузкаСНДС,
		|	СУММА(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.Разгрузка > 0
		|				ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьРазгрузкиДляВодителя
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьРазгрузокДляВодителя,
		|	СУММА(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.РазгрузкаСНДС > 0
		|				ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьРазгрузкиДляВодителя
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьРазгрузокДляВодителяСНДС,
		|	СУММА(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.Разгрузка > 0
		|				ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьРазгрузкиДляКлиента
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьРазгрузокДляКлиента,
		|	СУММА(ВЫБОР
		|			КОГДА ЗаказНаДоставкуКлиенту.РазгрузкаСНДС > 0
		|				ТОГДА ЗаказНаДоставкуКлиенту.СтоимостьРазгрузкиДляКлиента
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СтоимостьРазгрузокДляКлиентаСНДС
		|ПОМЕСТИТЬ ВТ_Итоги
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Итоги.Вес КАК Вес,
		|	ВТ_Итоги.Объем КАК Объем,
		|	ВТ_Итоги.СтоимостьДоставок КАК СтоимостьДоставок,
		|	ВТ_Итоги.МаксимальнаяДлина КАК МаксимальнаяДлина,
		|	ВТ_Итоги.СтоимостьДоставокСНДС КАК СтоимостьДоставокСНДС,
		|	ВТ_Итоги.СтоимостьТовара КАК СтоимостьТовара,
		|	ВТ_Итоги.Экспресс КАК Экспресс,
		|	ВТ_Итоги.ЕстьВнеЗоны КАК ЕстьВнеЗоны,
		|	ВТ_Итоги.НужнаИнкассация КАК НужнаИнкассация,
		|	ВТ_Итоги.ОплатаБанковскойКартой КАК ОплатаБанковскойКартой,
		|	ВТ_Итоги.Разгрузка КАК СтоимостьРазгрузок,
		|	ВТ_Итоги.РазгрузкаСНДС КАК СтоимостьРазгрузокСНДС,
		|	ВТ_Итоги.СтоимостьРазгрузокДляВодителя КАК СтоимостьРазгрузокДляВодителя,
		|	ВТ_Итоги.СтоимостьРазгрузокДляВодителяСНДС КАК СтоимостьРазгрузокДляВодителяСНДС,
		|	ВТ_Итоги.СтоимостьРазгрузокДляКлиента КАК СтоимостьРазгрузокДляКлиента,
		|	ВТ_Итоги.СтоимостьРазгрузокДляКлиентаСНДС КАК СтоимостьРазгрузокДляКлиентаСНДС
		|ИЗ
		|	ВТ_Итоги КАК ВТ_Итоги
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаказНаДоставкуКлиенту.ВидДоставки КАК ВидДоставки
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказНаДоставкуКлиенту.Ссылка) КАК КолЗаказов
		|ПОМЕСТИТЬ ВТ_КолЗаказов
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|	И ЗаказНаДоставкуКлиенту.СтоимостьДоставки > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказНаДоставкуКлиенту.Ссылка) КАК КолЗаказовСНДС
		|ПОМЕСТИТЬ ВТ_КолЗаказовСНДС
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|	И ЗаказНаДоставкуКлиенту.СтоимостьДоставкиСНДС > 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.СтоимостьДоставок, 0)) КАК СтоимостьДоставок,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.СтоимостьДоставокСНДС, 0)) КАК СтоимостьДоставокСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.Разгрузка, 0)) КАК СтоимостьРазгрузок,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.РазгрузкаСНДС, 0)) КАК СтоимостьРазгрузокСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.СтоимостьРазгрузокДляВодителя, 0)) КАК СтоимостьРазгрузокДляВодителя,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.СтоимостьРазгрузокДляВодителяСНДС, 0)) КАК СтоимостьРазгрузокДляВодителяСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.СтоимостьРазгрузокДляКлиента, 0)) КАК СтоимостьРазгрузокДляКлиента,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Итоги.СтоимостьРазгрузокДляКлиентаСНДС, 0)) КАК СтоимостьРазгрузокДляКлиентаСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_КолЗаказов.КолЗаказов, 0)) КАК КолЗаказов,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_КолЗаказовСНДС.КолЗаказовСНДС, 0)) КАК КолЗаказовСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Максимум.СтоимостьДоставки, 0)) КАК СтоимостьДоставки,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Максимум.СтоимостьДоставкиСНДС, 0)) КАК СтоимостьДоставкиСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Максимум.СтоимостьДляВодителяБезНДС, 0)) КАК СтоимостьДляВодителяБезНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Максимум.СтоимостьДляВодителяСНДС, 0)) КАК СтоимостьДляВодителяСНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Максимум.СтоимостьДляКлиентаБезНДС, 0)) КАК СтоимостьДляКлиентаБезНДС,
		|	МАКСИМУМ(ЕСТЬNULL(ВТ_Максимум.СтоимостьДляКлиентаСНДС, 0)) КАК СтоимостьДляКлиентаСНДС
		|ИЗ
		|	ВТ_Итоги КАК ВТ_Итоги,
		|	ВТ_КолЗаказов КАК ВТ_КолЗаказов,
		|	ВТ_КолЗаказовСНДС КАК ВТ_КолЗаказовСНДС,
		|	ВТ_Максимум КАК ВТ_Максимум
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(ТарифыПеревозчиков.СтоимостьЗаЧас, 0)) КАК СтоимостьЗаЧас
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ТарифыПеревозчиков КАК ТарифыПеревозчиков
		|		ПО ЗаказНаДоставкуКлиенту.Тариф = ТарифыПеревозчиков.Ссылка
		|			И ЗаказНаДоставкуКлиенту.ВидДоставки = ТарифыПеревозчиков.ВидДоставки
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)";
	
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	Запрос.УстановитьПараметр("СтавкаНДС", СтавкаНДС);
	Запрос.УстановитьПараметр("ДопТочка", ДопТочка); 
	
	Возврат Запрос.ВыполнитьПакет();
КонецФункции
Функция ПолучитьПакетЗапросовДляАкта(Объект)
	Запрос = ПолучитьОбщийПакетЗапросов();
	Запрос.Текст = Запрос.Текст + 
		"ВЫБРАТЬ
		|	ВТ_Максимум.Заказ КАК Заказ,
		|	ЕСТЬNULL(ВТ_Максимум.СтоимостьДляКлиентаБезНДС, 0) КАК СтоимостьДляКлиентаБезНДС
		|ИЗ
		|	ВТ_Максимум КАК ВТ_Максимум
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТ_Максимум.СтоимостьДляКлиентаБезНДС УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Максимум.Заказ КАК Заказ,
		|	ЕСТЬNULL(ВТ_Максимум.СтоимостьДляВодителяСНДС, 0) КАК СтоимостьДляВодителяСНДС
		|ИЗ
		|	ВТ_Максимум КАК ВТ_Максимум
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВТ_Максимум.СтоимостьДляВодителяСНДС УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказНаДоставкуКлиенту.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка В
		|			(ВЫБРАТЬ
		|				Основания.Документ
		|			ИЗ
		|				Основания КАК Основания)
		|	И ЗаказНаДоставкуКлиенту.СтоимостьДоставки > 0";

  	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	Запрос.УстановитьПараметр("СтавкаНДС", ЦенообразованиеКлиентСервер.ПолучитьСтавкуНДСЧислом(УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата)) / 100 + 1);  

	Возврат Запрос.ВыполнитьПакет();
КонецФункции

Функция Док_ЗаказПеревозчикаДальнейТочки(Объект, ДляАкта = Ложь, ДальнийЗаказНаДоставку) Экспорт
	СуммаДальнегоЗаказа = 0;
	СуммаОсновногоДальнегоЗаказа = ДальнийЗаказНаДоставку.Документ.СтоимостьДляВодителя;
	СуммаДальнегоЗаказаОплатаВодителю = Документы.ЗаказНаДоставкуКлиенту.ПолучитьСтоимостьПоТарифуИЗоне(Объект.ТарифыДальнегоЗаказаНаДоставку, ДальнийЗаказНаДоставку.Документ.ЗонаДоставкиДляВодителя, ДальнийЗаказНаДоставку.Документ.Подразделение,ДальнийЗаказНаДоставку.Документ.Дата).СтоимостьДляВодителя;
	СуммаДальнегоЗаказаОплатаКлиента = Документы.ЗаказНаДоставкуКлиенту.ПолучитьСтоимостьПоТарифуИЗоне(Объект.ТарифыДальнегоЗаказаНаДоставку, ДальнийЗаказНаДоставку.Документ.ЗонаДоставкиДляВодителя, ДальнийЗаказНаДоставку.Документ.Подразделение,ДальнийЗаказНаДоставку.Документ.Дата).СтоимостьДляКлиента;	
	Если ДальнийЗаказНаДоставку.Документ.Тариф <> Справочники.ТарифыПеревозчиков.НайтиПоНаименованию("Вне зоны") Тогда
		Если НЕ ДляАкта Тогда
			СуммаДальнегоЗаказа = СуммаДальнегоЗаказаОплатаВодителю;
		Иначе
			СуммаДальнегоЗаказа = новый Структура;
			СуммаДальнегоЗаказа.Вставить("ОплатаВодителю", СуммаДальнегоЗаказаОплатаВодителю);
			СуммаДальнегоЗаказа.Вставить("ОплатаКлиента", СуммаДальнегоЗаказаОплатаКлиента);
			СуммаДальнегоЗаказа.Вставить("ДальнийЗаказНаДоставку", ДальнийЗаказНаДоставку);
		КонецЕсли;
	КонецЕсли;
	Возврат СуммаДальнегоЗаказа;
КонецФункции

// Расчеты
Процедура ЗаполнитьРасчетныеДанныеВШапке(Объект) Экспорт
УстановитьПривилегированныйРежим(истина);
	РазницаСумм = 0;
	Если ЗначениеЗаполнено(Объект.ТарифыДальнегоЗаказаНаДоставку) Тогда
		ДальнийЗаказНаДоставку = Объект.Основания[Объект.Основания.Количество()-1];
		РазницаСумм = Док_ЗаказПеревозчикаДальнейТочки(Объект, , ДальнийЗаказНаДоставку);
		Если ДальнийЗаказНаДоставку.Документ.СтоимостьДоставки > ДальнийЗаказНаДоставку.Документ.СтоимостьДоставкиСНДС Тогда
			ДальнийЗаказНаДоставкуБезНДС = Истина;
		Иначе
			ДальнийЗаказНаДоставкуБезНДС = Ложь;
		КонецЕсли;	
	КонецЕсли;
	Если Не ЗначениеЗаполнено(Объект.Основания) Тогда 
		Возврат;
	КонецЕсли;
	
	КомпенсацияЗаПростой = 0;
	Компенсация = 0;
	КомпенсацияСНДС = 0;
	ОплатаВодителю = 0;
	ОплатаВодителюСНДС = 0;	  
	Вознаграждение = 0;
	ВознаграждениеСНДС = 0; 
	
	СтавкаНДССправочник = (УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата));
	
	СтавкаНДС = СтавкаНДССправочник.Ставка / 100 + 1;
	//--ДопТочка = Константы.ДоплатаЗаДопТочку.Получить();
	ДопТочка = РегистрыСведений.ДоплатаЗаДополнительнуюТочку.ПолучитьПоследнее(Объект.Дата,).Доплата;
	Пакет = ПолучитьПакетЗапросов(Объект, СтавкаНДС, ДопТочка);
	
	Выборка = Пакет[6].Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Объект, Выборка);
	КонецЕсли;                             
				
	ТЗВидДоставки = Пакет[7].Выгрузить();
  	ТЗВидДоставки.Свернуть("ВидДоставки");
	Если ТЗВидДоставки.Количество() = 1 Тогда
		Объект.ВидДоставки = ТЗВидДоставки[0].ВидДоставки;
	Иначе
		Если ТЗВидДоставки.Найти(Перечисления.ВидыДоставокДоКлиента.Розничная, "ВидДоставки") <> Неопределено Тогда
			Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
		КонецЕсли;
	КонецЕсли;    
	
	Объект.ДоплатыПоВнутреннимЗатратом = Объект.ВнутренниеДоплаты.Итог("СуммаДоплаты");
	
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная ИЛИ 
		Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
		
		Объект.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС;
		
		Выборка = Пакет[4].Выбрать();
		Если Выборка.Следующий() Тогда
			БезНДСБольшеЧемСНДС = Выборка.МаксимальнаяСтоимостьДляВодителяБезНДС >= Выборка.МаксимальнаяСтоимостьДляВодителяСНДС;
			Выборка = Пакет[10].Выбрать();
			Если Выборка.Следующий() Тогда       
				Если Объект.РазгрузкаСиламиВодителя Тогда
					Если БезНДСБольшеЧемСНДС Тогда
						Компенсация = Выборка.СтоимостьДляВодителяБезНДС - Выборка.СтоимостьДляКлиентаБезНДС;
						КомпенсацияСНДС = 0;
						ОплатаВодителю = Выборка.СтоимостьДляКлиентаБезНДС + ДопТочка * (Выборка.КолЗаказов - 1) + Компенсация;
						ОплатаВодителюСНДС = ДопТочка * Выборка.КолЗаказовСНДС;	  
						Вознаграждение = Выборка.СтоимостьДоставок - (Выборка.СтоимостьДляКлиентаБезНДС + ДопТочка * (Выборка.КолЗаказов - 1));
						ВознаграждениеСНДС = Выборка.СтоимостьДоставокСНДС / СтавкаНДС - ДопТочка * Выборка.КолЗаказовСНДС;
						
						ОплатаВодителю = ОплатаВодителю + Выборка.СтоимостьРазгрузокДляВодителя;
						ОплатаВодителюСНДС = ОплатаВодителюСНДС + Выборка.СтоимостьРазгрузокДляВодителяСНДС;
						Вознаграждение = Вознаграждение + Выборка.СтоимостьРазгрузок - Выборка.СтоимостьРазгрузокДляКлиента;
			    		ВознаграждениеСНДС = ВознаграждениеСНДС + Выборка.СтоимостьРазгрузокСНДС - Выборка.СтоимостьРазгрузокДляВодителяСНДС; 
			            Компенсация = Компенсация + (Выборка.СтоимостьРазгрузокДляВодителя - Выборка.СтоимостьРазгрузокДляКлиента);  
						КомпенсацияСНДС = Выборка.СтоимостьРазгрузокДляВодителяСНДС - Выборка.СтоимостьРазгрузокДляКлиентаСНДС;
					Иначе
						КомпенсацияСНДС = Выборка.СтоимостьДляВодителяСНДС - Выборка.СтоимостьДоставкиСНДС;
						Компенсация = 0;
						ОплатаВодителюСНДС = Выборка.СтоимостьДоставкиСНДС + ДопТочка * (Выборка.КолЗаказовСНДС - 1) + КомпенсацияСНДС;
						ОплатаВодителю = ДопТочка * Выборка.КолЗаказов;
						ВознаграждениеСНДС = Выборка.СтоимостьДоставокСНДС / СтавкаНДС - (Выборка.СтоимостьДляВодителяСНДС + ДопТочка * (Выборка.КолЗаказовСНДС - 1));	
						Вознаграждение = Выборка.СтоимостьДоставок - ОплатаВодителю;
						
						ОплатаВодителю = ОплатаВодителю + Выборка.СтоимостьРазгрузокДляВодителя;
						ОплатаВодителюСНДС = ОплатаВодителюСНДС + Выборка.СтоимостьРазгрузокДляВодителяСНДС;
						Вознаграждение = Вознаграждение + Выборка.СтоимостьРазгрузок - Выборка.СтоимостьРазгрузокДляКлиента;
			    		ВознаграждениеСНДС = ВознаграждениеСНДС + Выборка.СтоимостьРазгрузокСНДС - Выборка.СтоимостьРазгрузокДляВодителяСНДС;
						Компенсация = Выборка.СтоимостьРазгрузокДляВодителя - Выборка.СтоимостьРазгрузокДляКлиента;  
						КомпенсацияСНДС = КомпенсацияСНДС + (Выборка.СтоимостьРазгрузокДляВодителяСНДС - Выборка.СтоимостьРазгрузокДляКлиентаСНДС);
					КонецЕсли;
				Иначе
					Если БезНДСБольшеЧемСНДС Тогда
						Компенсация = Выборка.СтоимостьДляВодителяБезНДС - Выборка.СтоимостьДляКлиентаБезНДС;
						КомпенсацияСНДС = 0;
						ОплатаВодителю = Выборка.СтоимостьДляКлиентаБезНДС + ДопТочка * (Выборка.КолЗаказов - 1) + Компенсация;
						ОплатаВодителюСНДС = ДопТочка * Выборка.КолЗаказовСНДС;	  
						Вознаграждение = Выборка.СтоимостьДоставок - (Выборка.СтоимостьДляКлиентаБезНДС + ДопТочка * (Выборка.КолЗаказов - 1));
						ВознаграждениеСНДС = Выборка.СтоимостьДоставокСНДС / СтавкаНДС - ДопТочка * Выборка.КолЗаказовСНДС;
					Иначе
						КомпенсацияСНДС = Выборка.СтоимостьДляВодителяСНДС - Выборка.СтоимостьДоставкиСНДС;
						Компенсация = 0;
						ОплатаВодителюСНДС = Выборка.СтоимостьДоставкиСНДС + ДопТочка * (Выборка.КолЗаказовСНДС - 1) + КомпенсацияСНДС;
						ОплатаВодителю = ДопТочка * Выборка.КолЗаказов;
						ВознаграждениеСНДС = Выборка.СтоимостьДоставокСНДС / СтавкаНДС - (Выборка.СтоимостьДляВодителяСНДС + ДопТочка * (Выборка.КолЗаказовСНДС - 1));	
						Вознаграждение = Выборка.СтоимостьДоставок - ОплатаВодителю; 
					КонецЕсли;
				КонецЕсли;   
				
				Если Объект.ВремяПростоя <> 0 Тогда
					ВыборкаДляКомпенсацииЗаПростой = Пакет[11].Выбрать();
					Если ВыборкаДляКомпенсацииЗаПростой.Следующий() Тогда                        
							КомпенсацияЗаПростой = РассчитатьСтоимостьКомпенсации(ВыборкаДляКомпенсацииЗаПростой.СтоимостьЗаЧас, Объект.ВремяПростоя);
						Если Выборка.КолЗаказов > 0 Тогда
							Компенсация = Компенсация + КомпенсацияЗаПростой; 
							ОплатаВодителю = ОплатаВодителю + КомпенсацияЗаПростой;
						ИначеЕсли Выборка.КолЗаказовСНДС > 0 Тогда
							КомпенсацияСНДС = КомпенсацияСНДС + КомпенсацияЗаПростой; 
							ОплатаВодителюСНДС = ОплатаВодителюСНДС + КомпенсацияЗаПростой;
						КонецЕсли;					
					КонецЕсли;
				КонецЕсли;
				
				Если Объект.КомпенсацияВручную Тогда
					Если Выборка.КолЗаказов > 0 Тогда
						Компенсация = Компенсация + Объект.КорректировкаКомпенсации ;     
						ОплатаВодителю = ОплатаВодителю + Объект.КорректировкаКомпенсации;
					ИначеЕсли Выборка.КолЗаказовСНДС > 0 Тогда
						КомпенсацияСНДС = КомпенсацияСНДС + Объект.КорректировкаКомпенсацииСНДС;
						ОплатаВодителюСНДС = ОплатаВодителюСНДС + Объект.КорректировкаКомпенсацииСНДС;
					КонецЕсли;
				КонецЕсли;
				Если ЗначениеЗаполнено(Объект.ДоплатыПоВнутреннимЗатратом) Тогда
					Если Выборка.КолЗаказов > 0 Тогда
						Компенсация = Компенсация + Объект.ДоплатыПоВнутреннимЗатратом;     
						ОплатаВодителю = ОплатаВодителю + Объект.ДоплатыПоВнутреннимЗатратом;
					ИначеЕсли Выборка.КолЗаказовСНДС > 0 Тогда
						КомпенсацияСНДС = КомпенсацияСНДС + Объект.ДоплатыПоВнутреннимЗатратом;
						ОплатаВодителюСНДС = ОплатаВодителюСНДС + Объект.ДоплатыПоВнутреннимЗатратом;
					КонецЕсли;
				КонецЕсли;
				
				//https://bitrix.tg-alterra.ru/company/personal/user/4492/tasks/task/view/161322/
				Если ЗначениеЗаполнено(Объект.ТарифыДальнегоЗаказаНаДоставку) Тогда 
					ОплатаВодителюБезДальнегоЗаказа = ОплатаВодителю;
					ОплатаВодителюБезДальнегоЗаказаСНДС = ОплатаВодителюСНДС;
					Если ДальнийЗаказНаДоставкуБезНДС Тогда
						Если Выборка.КолЗаказов = 1 Тогда
							ОплатаВодителю = РазницаСумм + Объект.ДоплатыПоВнутреннимЗатратом;
						Иначе
							ОплатаВодителю = РазницаСумм + ДопТочка * (Выборка.КолЗаказов - 1) + Объект.ДоплатыПоВнутреннимЗатратом;
						КонецЕсли;
						Если Объект.РазгрузкаСиламиВодителя Тогда
							ОплатаВодителю = ОплатаВодителю + Выборка.СтоимостьРазгрузокДляВодителя;
						КонецЕсли;
						Если Объект.ВремяПростоя <> 0 Тогда
							ОплатаВодителю = ОплатаВодителю + КомпенсацияЗаПростой;
						КонецЕсли;
						ОплатаВодителю = ОплатаВодителю + Объект.КорректировкаКомпенсации;
						Компенсация = Компенсация + (ОплатаВодителю - ОплатаВодителюБезДальнегоЗаказа);	
					Иначе
						Если Выборка.КолЗаказовСНДС = 1 Тогда
							ОплатаВодителюСНДС = РазницаСумм + Объект.ДоплатыПоВнутреннимЗатратом;
						Иначе
							ОплатаВодителюСНДС = РазницаСумм + ДопТочка * (Выборка.КолЗаказовСНДС - 1) + Объект.ДоплатыПоВнутреннимЗатратом;
						КонецЕсли;
						Если Объект.РазгрузкаСиламиВодителя Тогда
							ОплатаВодителюСНДС = ОплатаВодителюСНДС + Выборка.СтоимостьРазгрузокДляВодителяСНДС;
						КонецЕсли;
						Если Объект.ВремяПростоя <> 0 Тогда
							ОплатаВодителюСНДС = ОплатаВодителюСНДС + КомпенсацияЗаПростой;
						КонецЕсли;
						ОплатаВодителюСНДС = ОплатаВодителюСНДС + Объект.КорректировкаКомпенсацииСНДС;
						КомпенсацияСНДС = КомпенсацияСНДС + (ОплатаВодителюСНДС - ОплатаВодителюБезДальнегоЗаказаСНДС);
					КонецЕсли;
				КонецЕсли;
				//КонецОшибки
				
			КонецЕсли;	
		КонецЕсли; 
		
	ИначеЕсли Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда  
		СтавкаНДССправочник = УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата);
		Если ЗначениеЗаполнено(СтавкаНДССправочник) Тогда
			Объект.СтавкаНДС = СтавкаНДССправочник.ПеречислениеСтавкаНДС;
		КонецЕсли; 	
	КонецЕсли; 
	
	Объект.КомпенсацияЗаПростой = КомпенсацияЗаПростой;
	Объект.Компенсация = Компенсация;
	Объект.КомпенсацияСНДС = КомпенсацияСНДС;
	Объект.ОплатаВодителю = ОплатаВодителю;
	Объект.ОплатаВодителюСНДС = ОплатаВодителюСНДС;	  
	Объект.Вознаграждение = Вознаграждение;
	Объект.ВознаграждениеСНДС = ВознаграждениеСНДС; 
	
	Объект.ПроцентТранспортныхДляКлиента = Объект.РасчетДоставки.Итог("ПроцентТранспортныхДляКлиента"); 
	
КонецПроцедуры 

Функция РассчитатьСтоимостьКомпенсации(Стоимость, Минуты); 
	
	ЦелаяЧасть = Цел(Стоимость/60*Минуты/5);
	ОстатокОтДеления = Стоимость/60*Минуты - ЦелаяЧасть*5;
	
	ЛеваяГраница = 5*ЦелаяЧасть;
	ПраваяГраница = 5*(ЦелаяЧасть+1);
	
	Если ОстатокОтДеления > 2.5 Тогда
		Возврат ПраваяГраница;
	Иначе
		Возврат ЛеваяГраница;
	КонецЕсли;
		
КонецФункции

Функция РасчетОплатыВодителю(Рейс, ЗаказНаДоставкуКлиенту = Неопределено) Экспорт
	
	ДальнийЗаказ = 0;
	Если ЗначениеЗаполнено(Рейс.ТарифыДальнегоЗаказаНаДоставку) Тогда
		ДальнийЗаказНаДоставку = Рейс.Основания[рейс.Основания.Количество()-1];
		ДальнийЗаказ = Док_ЗаказПеревозчикаДальнейТочки(Рейс, Истина, ДальнийЗаказНаДоставку);
		Если ДальнийЗаказНаДоставку.Документ.СтоимостьДоставки > ДальнийЗаказНаДоставку.Документ.СтоимостьДоставкиСНДС Тогда
			ДальнийЗаказНаДоставкуБезНДС = Истина;
		Иначе
			ДальнийЗаказНаДоставкуБезНДС = Ложь;
		КонецЕсли;	
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Рейс.Основания) Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ВидДоставки = Рейс.ВидДоставки;
	СтавкаНДСПеревозчика = Рейс.СтавкаНДСПеревозчика;

	Если ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная ИЛИ 
		ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
	
		Пакет = ПолучитьПакетЗапросовДляАкта(Рейс);
   		Выборка = Пакет[4].Выбрать();
		Если Выборка.Следующий() Тогда
			БезНДСБольшеЧемСНДС = Выборка.МаксимальнаяСтоимостьДляВодителяБезНДС >= Выборка.МаксимальнаяСтоимостьДляВодителяСНДС;
			Если БезНДСБольшеЧемСНДС Тогда
				Выборка = Пакет[5].Выбрать(); 
				РучнаяКомпенсацияИКомпенсацияЗаПростой = Рейс.КорректировкаКомпенсации + Рейс.КомпенсацияЗаПростой + Рейс.ДоплатыПоВнутреннимЗатратом;
			Иначе
				Выборка = Пакет[6].Выбрать();
				РучнаяКомпенсацияИКомпенсацияЗаПростой = Рейс.КорректировкаКомпенсацииСНДС + Рейс.КомпенсацияЗаПростой + Рейс.ДоплатыПоВнутреннимЗатратом;
			КонецЕсли;
			              			
			ЕстьРазгрузка = Рейс.РазгрузкаСиламиВодителя;
			ДоплатаЗаДопТочку = РегистрыСведений.ДоплатаЗаДополнительнуюТочку.ПолучитьПоследнее(Рейс.Дата,).Доплата;
			НаличиеЗаказовСБезНДС = Пакет[7].Выбрать();
			НаличиеЗаказовСБезНДС = НаличиеЗаказовСБезНДС.Следующий();

			ЭтоМакимальныйЗаказ = Истина;	
			Пока Выборка.Следующий() Цикл
				Заказ = Выборка.Заказ;          
				Организация1СК = Заказ.СтоимостьДоставки > 0;
				
				ОплатаВодителюДоставка = 0;
				ОплатаВодителюРазгрузка = 0; 
				ОплатаВодителю = 0;
				РаздельнаяЗаписьДоставкиИРазгрузки = Ложь;
				
				Если ЕстьРазгрузка Тогда
					Если БезНДСБольшеЧемСНДС Тогда
						Если Организация1СК Тогда
							Если ЭтоМакимальныйЗаказ Тогда
								ОплатаВодителюДоставка = Выборка.СтоимостьДляКлиентаБезНДС;
								ОплатаВодителюРазгрузка = Заказ.СтоимостьРазгрузкиДляКлиента; 
								ОплатаВодителю = ОплатаВодителюДоставка + ОплатаВодителюРазгрузка;
								РаздельнаяЗаписьДоставкиИРазгрузки = ОплатаВодителюДоставка <> 0 И ОплатаВодителюРазгрузка <> 0; 
							Иначе
								ОплатаВодителюДоставка = ДоплатаЗаДопТочку;
								ОплатаВодителюРазгрузка = Заказ.СтоимостьРазгрузкиДляКлиента; 
								ОплатаВодителю = ОплатаВодителюДоставка + ОплатаВодителюРазгрузка;
								РаздельнаяЗаписьДоставкиИРазгрузки = ОплатаВодителюДоставка <> 0 И ОплатаВодителюРазгрузка <> 0;
							КонецЕсли;
						Иначе
							ОплатаВодителю = ДоплатаЗаДопТочку + Заказ.СтоимостьРазгрузкиДляВодителя;  
						КонецЕсли;		
					Иначе
						Если Организация1СК Тогда
							ОплатаВодителюДоставка = ДоплатаЗаДопТочку;
							ОплатаВодителюРазгрузка = Заказ.СтоимостьРазгрузкиДляКлиента; 
							ОплатаВодителю = ОплатаВодителюДоставка + ОплатаВодителюРазгрузка;
							РаздельнаяЗаписьДоставкиИРазгрузки = ОплатаВодителюДоставка <> 0 И ОплатаВодителюРазгрузка <> 0;
						Иначе        
							Если НаличиеЗаказовСБезНДС Тогда
								Если ЭтоМакимальныйЗаказ Тогда
									Если ЗначениеЗаполнено(Рейс.ТарифыДальнегоЗаказаНаДоставку) Тогда
										ОплатаВодителюДоставка = ДальнийЗаказ.ОплатаВодителю + Заказ.СтоимостьРазгрузкиДляВодителя;
									Иначе
										ОплатаВодителю = Выборка.СтоимостьДляВодителяСНДС + Заказ.СтоимостьРазгрузкиДляВодителя;
									КонецЕсли;	
								Иначе
									ОплатаВодителю = ДоплатаЗаДопТочку + Заказ.СтоимостьРазгрузкиДляВодителя;
								КонецЕсли;
							Иначе
								Если ЭтоМакимальныйЗаказ Тогда
									Если ЗначениеЗаполнено(Рейс.ТарифыДальнегоЗаказаНаДоставку) Тогда 
										ОплатаВодителю = ДальнийЗаказ.ОплатаВодителю + Заказ.СтоимостьРазгрузкиДляВодителя + РучнаяКомпенсацияИКомпенсацияЗаПростой;
									Иначе
										ОплатаВодителю = Выборка.СтоимостьДляВодителяСНДС + Заказ.СтоимостьРазгрузкиДляВодителя + РучнаяКомпенсацияИКомпенсацияЗаПростой;
									КонецЕсли;									
								Иначе
									ОплатаВодителю = ДоплатаЗаДопТочку + Заказ.СтоимостьРазгрузкиДляВодителя;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				Иначе
					Если БезНДСБольшеЧемСНДС Тогда
						Если Организация1СК Тогда
							Если ЭтоМакимальныйЗаказ Тогда
								ОплатаВодителю = Выборка.СтоимостьДляКлиентаБезНДС;
							Иначе
								ОплатаВодителю = ДоплатаЗаДопТочку;
							КонецЕсли;
						Иначе                  
							ОплатаВодителю = ДоплатаЗаДопТочку;
						КонецЕсли;		
					Иначе
						Если Организация1СК Тогда
							ОплатаВодителю = ДоплатаЗаДопТочку;
						Иначе        
							Если НаличиеЗаказовСБезНДС Тогда
								Если ЭтоМакимальныйЗаказ Тогда						
									ОплатаВодителю = Выборка.СтоимостьДляВодителяСНДС;
								Иначе
									ОплатаВодителю = ДоплатаЗаДопТочку;
								КонецЕсли;
							Иначе
								Если ЭтоМакимальныйЗаказ Тогда
									Если ЗначениеЗаполнено(Рейс.ТарифыДальнегоЗаказаНаДоставку) Тогда
										ОплатаВодителю = ДальнийЗаказ.ОплатаВодителю + РучнаяКомпенсацияИКомпенсацияЗаПростой;
									Иначе	
										ОплатаВодителю = Выборка.СтоимостьДляВодителяСНДС + РучнаяКомпенсацияИКомпенсацияЗаПростой;
									КонецЕсли;
								Иначе
									ОплатаВодителю = ДоплатаЗаДопТочку;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ЗаказНаДоставкуКлиенту = Заказ Тогда // Функция вызывается для печати Акта
					СтавкаНДСЧислом = УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтавкаНДСПеревозчика);
					СуммаНДС = УчетНДСКлиентСервер.РассчитатьСуммуНДС(ОплатаВодителю, Истина, СтавкаНДСЧислом);
	
					Структура = Новый Структура;
					Структура.Вставить("ОплатаВодителюДоставка", ОплатаВодителюДоставка);
					Структура.Вставить("ОплатаВодителюРазгрузка", ОплатаВодителюРазгрузка);
					Структура.Вставить("ОплатаВодителю", ОплатаВодителю);
					Структура.Вставить("РаздельнаяЗаписьДоставкиИРазгрузки", РаздельнаяЗаписьДоставкиИРазгрузки);
					Структура.Вставить("СтавкаНДСПеревозчика", СтавкаНДСПеревозчика);
					Структура.Вставить("СуммаНДС", СуммаНДС);
					Возврат Структура;
				ИначеЕсли ЗаказНаДоставкуКлиенту = Неопределено Тогда
					ЗаписатьОплатуВодителяВРасчетДоставки(Рейс, Заказ, ОплатаВодителю);
				КонецЕсли;
				
				ЭтоМакимальныйЗаказ = Ложь;
			КонецЦикла;
		КонецЕсли;
	ИначеЕсли ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Или ВидДоставки = Перечисления.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы Тогда
		ФактическаяСтоимостьРейса = Рейс.ФактическаяСтоимостьРейсаСУчетомУдержанийПоПретензиям;
		ОплатаВодителю = Окр(ФактическаяСтоимостьРейса / Рейс.Основания.Количество(), 0);
		Для Каждого стрОснования Из Рейс.Основания Цикл
			Заказ = стрОснования.Документ;		
			Если ЗаказНаДоставкуКлиенту = Заказ Тогда // Функция вызывается для печати Акта
				ОплатаВодителю = Окр(Документы.РейсОтПоставщика.СкорректироватьСуммуПоСтавкеНДС(Рейс, ОплатаВодителю, СтавкаНДСПеревозчика), 0);
	            СтавкаНДСЧислом = УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтавкаНДСПеревозчика);
				СуммаНДС = УчетНДСКлиентСервер.РассчитатьСуммуНДС(ОплатаВодителю, Истина, СтавкаНДСЧислом);
				
				Структура = Новый Структура;
				Структура.Вставить("ОплатаВодителюДоставка", 0);
				Структура.Вставить("ОплатаВодителюРазгрузка", 0);
				Структура.Вставить("ОплатаВодителю", ОплатаВодителю);
				Структура.Вставить("РаздельнаяЗаписьДоставкиИРазгрузки", Ложь);
				Структура.Вставить("СтавкаНДСПеревозчика", СтавкаНДСПеревозчика); 
				Структура.Вставить("СуммаНДС", СуммаНДС);
				Возврат Структура;
			ИначеЕсли ЗаказНаДоставкуКлиенту = Неопределено Тогда
				ЗаписатьОплатуВодителяВРасчетДоставки(Рейс, Заказ, ОплатаВодителю);
			КонецЕсли;
		КонецЦикла;
		
		Если ЗаказНаДоставкуКлиенту = Неопределено Тогда
			Погрешность = ФактическаяСтоимостьРейса - Рейс.РасчетДоставки.Итог("ОплатаВодителю");
			Рейс.РасчетДоставки[0].ОплатаВодителю = Рейс.РасчетДоставки[0].ОплатаВодителю + Погрешность;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;   
	
КонецФункции

Процедура ЗаписатьОплатуВодителяВРасчетДоставки(Рейс, Заказ, ОплатаВодителю)
	
	СтрокиТЧ = Рейс.РасчетДоставки.НайтиСтроки(Новый Структура("ЗаказНаДоставку", Заказ));
	Если ЗначениеЗаполнено(СтрокиТЧ) Тогда
		КоличествоСтрок = СтрокиТЧ.Количество();
		СреднееЗначение = Окр(ОплатаВодителю / КоличествоСтрок, 2);
		Дельта = ОплатаВодителю - СреднееЗначение * КоличествоСтрок;
		
		Для Каждого стрРасчетДоставки Из СтрокиТЧ Цикл
			стрРасчетДоставки.ОплатаВодителю = СреднееЗначение;
		КонецЦикла;
		стрРасчетДоставки.ОплатаВодителю = стрРасчетДоставки.ОплатаВодителю + Дельта;
	КонецЕсли;
	
	Заказ = Заказ.ПолучитьОбъект();
	Заказ.ОплатаВодителю = ОплатаВодителю; 
	Заказ.Записать();  
	
КонецПроцедуры

Процедура РассчитатьСтроки(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого  ТекущаяСтрока Из Объект.РасчетДоставки Цикл
		РассчитатьСтроку(ТекущаяСтрока.НомерСтроки-1, Объект);
	КонецЦикла;
	
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
		Для Каждого  ТекущаяСтрока Из Объект.РасчетДоставки Цикл
			РасччитатьСтрокуТранспортныхДляОРК(ТекущаяСтрока, Объект);
		КонецЦикла;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура РассчитатьСтроку(НомерСтроки, Объект) Экспорт
	
	ТекущаяСтрока = Объект.РасчетДоставки[НомерСтроки];
	
	ПараметрыДоставки = ПолучитьПараметрыДоставкиИзДокумента(ТекущаяСтрока.ДокументПродажи);
	СтоимостиДоставки = Документы.ЗаказНаДоставкуКлиенту.ПолучитьСтоимостьПоТарифуИЗоне(ТекущаяСтрока.ЗаказНаДоставку.Тариф, ТекущаяСтрока.ЗаказНаДоставку.ЗонаДоставкиДляВодителя, ТекущаяСтрока.ЗаказНаДоставку.Подразделение, ТекущаяСтрока.ЗаказНаДоставку.Дата);
	
	ТекущаяСтрока.Вес = ПараметрыДоставки.Вес;
	ТекущаяСтрока.Объем = ПараметрыДоставки.Объем;
	
	ЭтолонныйВес = Константы.ЭталонныйВес.Получить();
	ОбъемныйВес = ЭтолонныйВес * ТекущаяСтрока.Объем;
	Если ОбъемныйВес > ТекущаяСтрока.Вес Тогда 
		ТекущаяСтрока.ОбъемныйВес = ОбъемныйВес;
	Иначе
		ТекущаяСтрока.ОбъемныйВес = ТекущаяСтрока.Вес;
	КонецЕсли;
	
	ТекущаяСтрока.МинимальнаяСтоимостьДляЗоны = СтоимостиДоставки.МинимальнаяСтоимость;
	ТекущаяСтрока.ПлатаЗаДоставку = ПараметрыДоставки.СтоимостьУслуги;

	ТекущаяСтрока.СуммаДокумента = ПараметрыДоставки.СуммаДокумента;
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда
		Если ТекущаяСтрока.ЗаказНаДоставку.НужнаИнкассация Тогда 
			ТекущаяСтрока.Инкассация = ТекущаяСтрока.ЗаказНаДоставку.Инкассация;
		Иначе
			ТекущаяСтрока.Инкассация = 0;
		КонецЕсли;
	Иначе
		Если ТекущаяСтрока.ЗаказНаДоставку.НужнаИнкассация Тогда 
			ТекущаяСтрока.Инкассация = ПараметрыДоставки.СуммаДокумента;
		Иначе
			ТекущаяСтрока.Инкассация = 0;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.ДокументПродажи) Тогда
		ТекущаяСтрока.НомерДокументаПродажи = ТекущаяСтрока.ДокументПродажи.Номер;
	КонецЕсли;
	
	Если Объект.Вес <> 0 Тогда
		ТекущаяСтрока.СтоимостьДоставкиПоТоннажу = (Объект.ФактическаяСтоимостьРейса/Объект.Вес*ТекущаяСтрока.ЗаказНаДоставку.Вес)-ТекущаяСтрока.ПлатнаяДоставка;
	Иначе
		ТекущаяСтрока.СтоимостьДоставкиПоТоннажу = 0;
	КонецЕсли;
	
	ДанныеРасчетаСебестоимости = ПолучитьДанныеПоСебестоимости(ТекущаяСтрока.ДокументПродажи);
	ТекущаяСтрока.ЧистыйДоход = ДанныеРасчетаСебестоимости.Наценка;
	ТекущаяСтрока.Себестоимость = ДанныеРасчетаСебестоимости.Себестоимость;
	Если ТекущаяСтрока.Себестоимость > 0 Тогда
		ТекущаяСтрока.ЧистыДоходПроцент = 100 * ТекущаяСтрока.ЧистыйДоход / ТекущаяСтрока.Себестоимость;
	Иначе
		ТекущаяСтрока.ЧистыДоходПроцент = 0;
	КонецЕсли;
	
	Если ТекущаяСтрока.ЧистыйДоход <> 0 Тогда
		ТекущаяСтрока.ДоставкаДоход = 100 * ТекущаяСтрока.СтоимостьДоставкиПоТоннажу / ТекущаяСтрока.ЧистыйДоход;
	Иначе
		ТекущаяСтрока.ДоставкаДоход = 0;
	КонецЕсли;
	
	ТекущаяСтрока.Доплатить = ТекущаяСтрока.СтоимостьДоставкиПоТоннажу - ТекущаяСтрока.ЧистыйДоход * 0.2;
	ТекущаяСтрока.Доплатить = ?(ТекущаяСтрока.Доплатить <= 0, 0, ТекущаяСтрока.Доплатить);
	
	Если ТекущаяСтрока.СуммаДокумента <> 0 Тогда
		ТекущаяСтрока.ПроцентТранспортныхДляКлиента = 100*ТекущаяСтрока.ПлатнаяДоставка / ТекущаяСтрока.СуммаДокумента;
	Иначе
		ТекущаяСтрока.ПроцентТранспортныхДляКлиента = 0;
	КонецЕсли;
	
	Если Объект.СтоимостьТовара <> 0 Тогда
		ТекущаяСтрока.СтоимостьДоставкиПоСуммамДокументов = (Объект.ФактическаяСтоимостьРейса*ТекущаяСтрока.СуммаДокумента)/Объект.СтоимостьТовара;
	Иначе
		ТекущаяСтрока.СтоимостьДоставкиПоСуммамДокументов = 0;
	КонецЕсли; 
	
КонецПроцедуры
//ОРК
Процедура РасччитатьСтрокуТранспортныхДляОРК(ТекущаяСтрока, Объект)
	
	ОбъемныйВесИтог = Объект.РасчетДоставки.Итог("ОбъемныйВес");
	
	//РасчетнаяРекомендованнаяСтоимость
	Если ОбъемныйВесИтог <> 0 Тогда 
		РасчетнаяРекомендованнаяСтоимость = ТекущаяСтрока.ОбъемныйВес*Объект.ФактическаяСтоимостьРейса/ОбъемныйВесИтог;
	Иначе
		РасчетнаяРекомендованнаяСтоимость = 0;
	КонецЕсли;
	
	Если РасчетнаяРекомендованнаяСтоимость < ТекущаяСтрока.МинимальнаяСтоимостьДляЗоны Тогда 
		ТекущаяСтрока.РасчетнаяРекомендованнаяСтоимость = ТекущаяСтрока.МинимальнаяСтоимостьДляЗоны;
	Иначе
		ТекущаяСтрока.РасчетнаяРекомендованнаяСтоимость = РасчетнаяРекомендованнаяСтоимость;
	КонецЕсли;
	
	//ПроцентТранспортныхДляКлиента
	Если (ТекущаяСтрока.ОплатаКлиентомФакт + ТекущаяСтрока.Компенсация) > 0 Тогда
		Расчет = ТекущаяСтрока.СуммаДокумента + ТекущаяСтрока.КомпенсацияИзНаценки-ТекущаяСтрока.Компенсация;
		Если Расчет <> 0 Тогда 
			ТекущаяСтрока.ПроцентТранспортныхДляКлиента = 100 * ТекущаяСтрока.ПлатаЗаДоставку / Расчет;
		Иначе
			ТекущаяСтрока.ПроцентТранспортныхДляКлиента = 0;
		КонецЕсли;
	Иначе
		Если ТекущаяСтрока.СуммаДокумента <> 0 Тогда 
			ТекущаяСтрока.ПроцентТранспортныхДляКлиента = 100 *(ТекущаяСтрока.ПлатаЗаДоставку - ТекущаяСтрока.Компенсация) / ТекущаяСтрока.СуммаДокумента;
		Иначе
			ТекущаяСтрока.ПроцентТранспортныхДляКлиента = 0;
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбновитьПараметрыПриОткрытииРейса(Объект) Экспорт
	
	Для Каждого  ТекущаяСтрока Из Объект.РасчетДоставки Цикл
		ПолучитьРасчетныеПоляИзДокПродажи(ТекущаяСтрока);
	КонецЦикла; 
	
КонецПроцедуры

Процедура ПолучитьРасчетныеПоляИзДокПродажи(ТекущаяСтрока)
	
	ОтметкаКассы = Ложь;
	ДокументПродажи = ТекущаяСтрока.ДокументПродажи;
	
	Если Не ЗначениеЗаполнено(ДокументПродажи) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЧекККМ") Тогда
		Если ДокументПродажи.Статус = Перечисления.СтатусыЧековККМ.Пробит Тогда
			ОтметкаКассы = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		ОтметкаКассы = ЗначениеЗаполнено(ДокументПродажи.Кассир);
	КонецЕсли;
	
	Если ТипЗнч(ДокументПродажи) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
		мРеализаций = АльтерраОбщегоНазначения.ПолучитьРеализацииПоЗаказу(ДокументПродажи);
		Для Каждого Реализ Из мРеализаций Цикл
			Если ЗначениеЗаполнено(Реализ.Кассир) Тогда
				ОтметкаКассы = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	ТекущаяСтрока.ОтметкаКассы = ОтметкаКассы;
	
	ПараметрыДоставки = ПолучитьПараметрыДоставкиИзДокумента(ДокументПродажи) ;
	
	//ТекущаяСтрока.ИтоговаяСтоимостьДляКлиента= ПараметрыДоставки.СтоимостьУслуги-ПараметрыДоставки.СуммаРучнойСкидки;
	ТекущаяСтрока.КомпенсацияИзНаценки = ПараметрыДоставки.СуммаРучнойСкидки;
	ТекущаяСтрока.Компенсация = ТекущаяСтрока.КомпенсацияИзНаценки;
	
	ТекущаяСтрока.ПлатаЗаДоставку = ПараметрыДоставки.СтоимостьУслуги;
	ТекущаяСтрока.ОплатаКлиентомФакт = ТекущаяСтрока.ПлатаЗаДоставку-ТекущаяСтрока.Компенсация;
	
	Если ТипЗнч(ДокументПродажи) <> Тип("ДокументСсылка.ПеремещениеТоваров")
		И ТипЗнч(ДокументПродажи) <> Тип("ДокументСсылка.ВозвратТоваровОтКлиента")
		И ТипЗнч(ДокументПродажи) <> Тип("ДокументСсылка.ОбращениеКлиента") Тогда
		ТекущаяСтрока.Распределять = ДокументПродажи.РаспределитьТранспортные;
	КонецЕсли;  
	
КонецПроцедуры 

