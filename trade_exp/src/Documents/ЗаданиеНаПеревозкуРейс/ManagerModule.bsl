Функция ПолучитьВесОбъемСтоимостьТоваров(Ссылка) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.Сумма КАК Сумма,
	|	РеализацияТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоСтрокВДокументе,
	|	РеализацияТоваровУслугТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки
	|ПОМЕСТИТЬ Товар
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка В(&Ссылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Номенклатура,
	|	ЧекККМТовары.Сумма,
	|	ЧекККМТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ЧекККМТовары.СуммаРучнойСкидки
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|ГДЕ
	|	ЧекККМТовары.Ссылка В(&Ссылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура,
	|	ЗаказКлиентаТовары.Сумма,
	|	ЗаказКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ЗаказКлиентаТовары.СуммаРучнойСкидки
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка В(&Ссылка)
	|	И ЗаказКлиентаТовары.Отменено = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиентаТовары.Номенклатура,
	|	ВозвратТоваровОтКлиентаТовары.Сумма,
	|	-ВозвратТоваровОтКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ВозвратТоваровОтКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
	|ГДЕ
	|	ВозвратТоваровОтКлиентаТовары.ДокументРеализации В(&Ссылка)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозвратТовары.Номенклатура,
	|	ЧекККМВозвратТовары.Сумма,
	|	-ЧекККМВозвратТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЧекККМВозвратТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ЧекККМВозврат.Товары КАК ЧекККМВозвратТовары
	|ГДЕ
	|	ЧекККМВозвратТовары.Ссылка.ЧекККМ В(&Ссылка)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товар.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВТ_СтоимостьУслуги
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиДоставки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Товар.Сумма) КАК СтоимостьТовара,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры) КАК Вес,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры) КАК Объем,
	|	СУММА(Товар.СуммаРучнойСкидки) КАК СуммаРучнойСкидки
	|ПОМЕСТИТЬ ВТ_Итоги
	|ИЗ
	|	Товар КАК Товар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Итоги.СтоимостьТовара КАК СтоимостьТовара,
	|	ВТ_Итоги.Вес КАК Вес,
	|	ВТ_Итоги.Объем КАК Объем,
	|	ВТ_Итоги.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	ЕСТЬNULL(ВТ_СтоимостьУслуги.Сумма, 0) КАК СтоимостьУслуги
	|ИЗ
	|	ВТ_Итоги КАК ВТ_Итоги
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостьУслуги КАК ВТ_СтоимостьУслуги
	|		ПО (ИСТИНА)" ;
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ГруппаУслугиДоставки", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую());
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	
	Рез = Новый Структура("Вес,Объем,СтоимостьТовара",0,0);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, Выборка);
	КонецЕсли;
	
	Возврат Рез;
	
КонецФункции   

Функция ПолучитьУслугуДоставкиИзДокумента(Товары, ГруппаУслугиДоставки)  Экспорт//уд
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	Товары.СуммаСНДС КАК СуммаСНДС
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	ВТ_Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВТ_Товары.СуммаСНДС КАК СтоимостьТовара
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ГДЕ
	|	ВТ_Товары.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиДоставки)" ;
	
	Запрос.УстановитьПараметр("Товары", Товары);
	Запрос.УстановитьПараметр("ГруппаУслугиДоставки", ГруппаУслугиДоставки);
	
	Выборка= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Номенклатура;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
КонецФункции

Функция ПолучитьПараметрыДоставкиИзДокумента(МассивСсылок) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ДокументыПродажи
	|ИЗ
	|	Документ.ЧекККМ КАК ЧекККМ
	|ГДЕ
	|	ЧекККМ.Ссылка В(&МассивСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка В(&МассивСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(РеализацияТоваровУслуг.Ссылка, Заказ.Ссылка)
	|ИЗ
	|	Документ.ЗаказКлиента КАК Заказ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|			И (РеализацияТоваровУслуг.ПометкаУдаления = ЛОЖЬ)
	|ГДЕ
	|	Заказ.Ссылка В(&МассивСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОбращениеКлиента.Ссылка
	|ИЗ
	|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
	|ГДЕ
	|	ОбращениеКлиента.Ссылка В(&МассивСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиента.Ссылка
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваровОтКлиента
	|ГДЕ
	|	ВозвратТоваровОтКлиента.Ссылка В(&МассивСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваров.Ссылка
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|ГДЕ
	|	ПеремещениеТоваров.Ссылка В(&МассивСсылок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.Сумма КАК Сумма,
	|	РеализацияТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоСтрокВДокументе,
	|	РеализацияТоваровУслугТовары.СуммаРучнойСкидки КАК СуммаРучнойСкидки
	|ПОМЕСТИТЬ Товар
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокументыПродажи.Ссылка КАК Ссылка
	|			ИЗ
	|				ДокументыПродажи КАК ДокументыПродажи)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Номенклатура,
	|	ЧекККМТовары.Сумма,
	|	ЧекККМТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ЧекККМТовары.СуммаРучнойСкидки
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|ГДЕ
	|	ЧекККМТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокументыПродажи.Ссылка КАК Ссылка
	|			ИЗ
	|				ДокументыПродажи КАК ДокументыПродажи)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура,
	|	ЗаказКлиентаТовары.Сумма,
	|	ЗаказКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ЗаказКлиентаТовары.СуммаРучнойСкидки
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокументыПродажи.Ссылка КАК Ссылка
	|			ИЗ
	|				ДокументыПродажи КАК ДокументыПродажи)
	|	И ЗаказКлиентаТовары.Отменено = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	СУММА(ЕСТЬNULL(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы, 0)),
	|	ПеремещениеТоваровТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
	|		ПО ПеремещениеТоваровТовары.Ссылка = СебестоимостьТоваров.Регистратор 
	|			И ПеремещениеТоваровТовары.Ссылка.СкладОтправитель = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.МестоХранения
	|			И ПеремещениеТоваровТовары.Номенклатура = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура 
	|
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокументыПродажи.Ссылка КАК Ссылка
	|			ИЗ
	|				ДокументыПродажи КАК ДокументыПродажи)
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.КоличествоУпаковок	
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТоварыДляДовоза.Номенклатура,
	|	ТоварыДляДовоза.Сумма,
	|   ВЫБОР
	|       КОГДА ТоварыДляДовоза.Количество < 0
	|			ТОГДА -ТоварыДляДовоза.Количество
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА ТоварыДляДовоза.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ТоварыДляДовоза
	|ГДЕ
	|	ТоварыДляДовоза.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокументыПродажи.Ссылка КАК Ссылка
	|			ИЗ
	|				ДокументыПродажи КАК ДокументыПродажи)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиента.Номенклатура,
	|	ВозвратТоваровОтКлиента.Сумма,
	|	ВозвратТоваровОтКлиента.Количество,
	|	ВЫБОР
	|		КОГДА ВозвратТоваровОтКлиента.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиента
	|ГДЕ
	|	ВозвратТоваровОтКлиента.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокументыПродажи.Ссылка КАК Ссылка
	|			ИЗ
	|				ДокументыПродажи КАК ДокументыПродажи)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Товар.Сумма) КАК Сумма,
	|	Товар.Номенклатура.СтавкаНДС КАК УслугаСтавкаНДС
	|ПОМЕСТИТЬ ВТ_СтоимостьУслуги
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиДоставки)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товар.Номенклатура.СтавкаНДС
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Товар.Сумма) КАК СтоимостьТовара,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры) КАК Вес,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры) КАК Объем,
	|	СУММА(Товар.СуммаРучнойСкидки) КАК СуммаРучнойСкидки
	|ПОМЕСТИТЬ ВТ_Итоги
	|ИЗ
	|	Товар КАК Товар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Итоги.СтоимостьТовара КАК СуммаДокумента,
	|	ВТ_Итоги.Вес КАК Вес,
	|	ВТ_Итоги.Объем КАК Объем,
	|	ВТ_Итоги.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	ЕСТЬNULL(ВТ_СтоимостьУслуги.Сумма, 0) КАК СтоимостьУслуги,
	|	ВТ_СтоимостьУслуги.УслугаСтавкаНДС КАК УслугаСтавкаНДС
	|ИЗ
	|	ВТ_Итоги КАК ВТ_Итоги
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СтоимостьУслуги КАК ВТ_СтоимостьУслуги
	|		ПО (ИСТИНА)" ;
	
	Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
	Запрос.УстановитьПараметр("ГруппаУслугиДоставки", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую());
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",    
	"Товар.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	
	Рез = Новый Структура("Вес,Объем,СтоимостьТовара,СуммаДокумента,СуммаРучнойСкидки,СтоимостьУслуги,УслугаСтавкаНДС",0,0,0,0,0,0,Неопределено);
	
	Выборка= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, Выборка);
	КонецЕсли;
	
	Возврат Рез;

КонецФункции 

