Процедура РасчитатьНачалоРазгрузки(Объект) Экспорт
	
	ТЗВремени = Новый ТаблицаЗначений;
	ТЗВремени.Колонки.Добавить("ВремяДоставкиС");
	ТЗВремени.Колонки.Добавить("ВремяДоставкиПо");
	ТЗВремени.Колонки.Добавить("ПрибытиеНаОтгрузку");
	
	Для Каждого Основание Из Объект.Основания Цикл
		ЗаказНаДоставку = Основание.Документ;
		НоваяСтрока = ТЗВремени.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ЗаказНаДоставку);
	КонецЦикла;
	
	ТЗВремени.Сортировать("ВремяДоставкиПо Возр");
	
	Если ТЗВремени.Количество() > 0 Тогда 
		МаксимальнаяСтрока = ТЗВремени[0];
		
		ДатаСтрока = Формат(МаксимальнаяСтрока.ПрибытиеНаОтгрузку, "ДФ=""ггггММдд""");
		ВремяСтрока = Формат(МаксимальнаяСтрока.ВремяДоставкиПо, "ДФ=""ЧЧммсс""");
		РезультатСложения = Дата(ДатаСтрока + ВремяСтрока);
		
		Объект.НачалоРазгрузки = РезультатСложения;
	КонецЕсли;
	
