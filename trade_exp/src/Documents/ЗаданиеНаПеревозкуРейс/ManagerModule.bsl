	Объект.Объем = Объект.РасчетДоставки.Итог("Объем");
	//Товары = ПолучитьТоварыПоДокПродажи(Объект.РасчетДоставки.Выгрузить());
	//Объект.ОбъемСУчетомСкрутокПоликарбоната = УправлениеЛогистикойСервер.ПолучитьОбъемСУчетомСкрутокПоликарбоната(Товары);
