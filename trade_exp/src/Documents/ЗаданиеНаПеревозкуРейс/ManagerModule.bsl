Функция ПолучитьПараметрыЗаполненияПоВодителю(Водитель) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СвязьВодителейТСПартнеров.Водитель,
	|	СвязьВодителейТСПартнеров.Автомобиль,
	|	СвязьВодителейТСПартнеров.ПеревозчикПартнер,
	|	СвязьВодителейТСПартнеров.ПеревозчикКонтрагент КАК Перевозчик
	|ИЗ
	|	РегистрСведений.СвязьВодителейТСПартнеров КАК СвязьВодителейТСПартнеров
	|ГДЕ
	|	СвязьВодителейТСПартнеров.Водитель = &Водитель";
	
	Запрос.УстановитьПараметр("Водитель", Водитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции 

Функция ПолучитьДокументыПродажи(Объект)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК Документ
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&ЗаданиеНаПеревозкуРейсРасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
	|		ПО ВТ_Основания.Документ = ЧекККМ.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслуг.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваров.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|		ПО ВТ_Основания.Документ = ПеремещениеТоваров.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиента.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваровОтКлиента
	|		ПО ВТ_Основания.Документ = ВозвратТоваровОтКлиента.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОбращениеКлиента.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОбращениеКлиента КАК ОбращениеКлиента
	|		ПО ВТ_Основания.Документ = ОбращениеКлиента.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОбращениеКлиента.ДополнительнаяРеализация
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОбращениеКлиента КАК ОбращениеКлиента
	|		ПО ВТ_Основания.Документ = ОбращениеКлиента.Ссылка
	|		
	|	ГДЕ
	|		ОбращениеКлиента.ДополнительнаяРеализация <> ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)";
	
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозкуРейсРасчетДоставки", Объект.РасчетДоставки.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ.ВыгрузитьКолонку("Ссылка");
	
