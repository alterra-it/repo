Функция ПолучитьДокументыКОбработке(Рейс)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК Документ,
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ОплатаКлиентомФакт + ЗаданиеНаПеревозкуРейсРасчетДоставки.Компенсация КАК НовоеКоличество,
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Компенсация КАК Компенсация,
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Распределять КАК Распределять
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&ЗаданиеНаПеревозкуРейсРасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМТовары.Номенклатура КАК Номенклатура,
	|	ЧекККМТовары.Ссылка КАК Док1,
	|	ЧекККМТовары.НомерСтроки КАК НомерСтроки1,
	|	ЕСТЬNULL(ОтчетОРозничныхПродажахТовары.Ссылка, """") КАК Док2,
	|	ЕСТЬNULL(ОтчетОРозничныхПродажахТовары.НомерСтроки, 0) КАК НомерСтроки2,
	|	ЧекККМТовары.Количество КАК Количество,
	|	ВТ_Основания.НовоеКоличество КАК НовоеКоличество,
	|	ВТ_Основания.Компенсация КАК Компенсация,
	|	ЧекККМТовары.Номенклатура.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_Основания.Распределять КАК Распределять,
	|	ИСТИНА КАК ОтметкаКассы
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах.Товары КАК ОтчетОРозничныхПродажахТовары
	|			ПО ЧекККМТовары.Номенклатура = ОтчетОРозничныхПродажахТовары.Номенклатура
	|				И ЧекККМТовары.Ссылка.КассоваяСмена = ОтчетОРозничныхПродажахТовары.Ссылка.КассоваяСмена
	|				И ЧекККМТовары.Ссылка.Партнер = ОтчетОРозничныхПродажахТовары.Партнер
	|				И ЧекККМТовары.КоличествоУпаковок = ОтчетОРозничныхПродажахТовары.КоличествоУпаковок
	|		ПО ВТ_Основания.Документ = ЧекККМТовары.Ссылка
	|ГДЕ
	|	ЧекККМТовары.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|	И ЧекККМТовары.Номенклатура В ИЕРАРХИИ(&ГруппаУслугДоставки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.Ссылка КАК Док1,
	|	РеализацияТоваровУслугТовары.НомерСтроки КАК НомерСтроки1,
	|	РеализацияТоваровУслугТовары.Количество КАК Количество,
	|	ВТ_Основания.НовоеКоличество КАК НовоеКоличество,
	|	ВТ_Основания.Компенсация КАК Компенсация,
	|	РеализацияТоваровУслугТовары.КодСтроки КАК КодСтроки,
	|	РеализацияТоваровУслугТовары.Номенклатура.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_Основания.Распределять КАК Распределять,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(РеализацияТоваровУслугТовары.Ссылка, 0) = 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РеализацияТоваровУслугТовары.Ссылка.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.Пустаяссылка)
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|	КОНЕЦ КАК ОтметкаКассы,
	|	ЕСТЬNULL(ЗаказКлиентаТовары.Ссылка, """") КАК Док2,
	|	ЕСТЬNULL(ЗаказКлиентаТовары.НомерСтроки, 0) КАК НомерСтроки2
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|			ПО РеализацияТоваровУслугТовары.Номенклатура = ЗаказКлиентаТовары.Номенклатура
	|				И РеализацияТоваровУслугТовары.КодСтроки = ЗаказКлиентаТовары.КодСтроки
	|				И РеализацияТоваровУслугТовары.Ссылка.ЗаказКлиента = ЗаказКлиентаТовары.Ссылка
	|				И (ЛОЖЬ = ЗаказКлиентаТовары.Ссылка.ПометкаУдаления)
	|				И (ЛОЖЬ = ЗаказКлиентаТовары.Отменено)
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслугТовары.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Номенклатура В ИЕРАРХИИ(&ГруппаУслугДоставки)
	|	И РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Ссылка КАК Док1,
	|	ЗаказКлиентаТовары.НомерСтроки КАК НомерСтроки1,
	|	ЗаказКлиентаТовары.КодСтроки КАК КодСтроки,
	|	ЕСТЬNULL(РеализацияТоваровУслугТовары.Ссылка, """") КАК Док2,
	|	ЕСТЬNULL(РеализацияТоваровУслугТовары.НомерСтроки, 0) КАК НомерСтроки2,
	|	ЗаказКлиентаТовары.Номенклатура.СтавкаНДС КАК СтавкаНДС,
	|	ВТ_Основания.НовоеКоличество КАК НовоеКоличество,
	|	ВТ_Основания.Компенсация КАК Компенсация,
	|	ЗаказКлиентаТовары.Количество КАК Количество,
	|	ВТ_Основания.Распределять КАК Распределять,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(РеализацияТоваровУслугТовары.Ссылка, 0) = 0
	|			ТОГДА ЛОЖЬ
	|		ИНАЧЕ ВЫБОР
	|				КОГДА РеализацияТоваровУслугТовары.Ссылка.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.Пустаяссылка)
	|					ТОГДА ЛОЖЬ
	|				ИНАЧЕ ИСТИНА
	|			КОНЕЦ
	|	КОНЕЦ КАК ОтметкаКассы
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|			ПО ЗаказКлиентаТовары.Номенклатура = РеализацияТоваровУслугТовары.Номенклатура
	|				И ЗаказКлиентаТовары.КодСтроки = РеализацияТоваровУслугТовары.КодСтроки
	|				И ЗаказКлиентаТовары.Ссылка = РеализацияТоваровУслугТовары.Ссылка.ЗаказКлиента
	|				И (ЛОЖЬ = РеализацияТоваровУслугТовары.Ссылка.ПометкаУдаления)
	|		ПО ВТ_Основания.Документ = ЗаказКлиентаТовары.Ссылка
	|ГДЕ
	|	ЗаказКлиентаТовары.Номенклатура В ИЕРАРХИИ(&ГруппаУслугДоставки)
	|	И ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|	И ЗаказКлиентаТовары.Отменено = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозкуРейсРасчетДоставки", Рейс.РасчетДоставки.Выгрузить());
	Запрос.УстановитьПараметр("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Услуга);
	Запрос.УстановитьПараметр("ГруппаУслугДоставки", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую());
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Возврат  РезультатЗапроса; 
	
КонецФункции


//Замены
Процедура ВыполнитьЗаменуКоличествоУслуг(Рейс, Отказ) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПакетЗапросов = ПолучитьДокументыКОбработке(Рейс);
	Если Рейс.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
		УслугаПеревозчика = ПолучитьУслугуДоставкиПеревозчика(Рейс.Перевозчик, АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиБезНДСОРК());
	Иначе
		УслугаПеревозчика = АльтерраОбщегоНазначения.УслугаДоставкиСНДС();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УслугаПеревозчика) Тогда
		Сообщить("Не задана услуга для перевозчика!");
		Отказ = Истина;
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		
		Для Инд = 1 По 3 Цикл
			Если Отказ Тогда
				Прервать;
			КонецЕсли;
			
			ВыборкаДокументов = ПакетЗапросов[Инд].Выбрать();
			
			Пока ВыборкаДокументов.Следующий() Цикл
				Док1 = "";
				Док2 = "";
				
				Если ВыборкаДокументов.ОтметкаКассы И Рейс.СтавкаНДС <> Перечисления.СтавкиНДС.БезНДС Тогда 
					АльтерраОбщегоНазначения.СообщитьПользователю(ВыборкаДокументов.Док1, "По: " + ВыборкаДокументов.Док1 + " уже стоит отметка кассы!");
					Продолжить;
				КонецЕсли;
								
				Док1 =  ВыборкаДокументов.Док1.ПолучитьОбъект();					
				Док1.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
				Если Инд = 3 Тогда //Заказы потом реализации
					Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
						Док2=  ВыборкаДокументов.Док2.ПолучитьОбъект();
						Док2.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
						Док2.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					КонецЕсли;
				ИначеЕсли Инд = 2 Тогда //Реализации				
					Док1.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
						Док2=  ВыборкаДокументов.Док2.ПолучитьОбъект();
						Док2.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
					КонецЕсли;
				ИначеЕсли Инд = 1 Тогда//Чеки				
					Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
						Док2=  ВыборкаДокументов.Док2.ПолучитьОбъект();
						Док2.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
					КонецЕсли;
				КонецЕсли;
				
				ЗаменитьКоличествоВУслугеДоставки(Док1, ВыборкаДокументов.НомерСтроки1-1, ВыборкаДокументов.НовоеКоличество);
				ЗаменитьКоличествоВУслугеДоставки(Док2, ВыборкаДокументов.НомерСтроки2-1, ВыборкаДокументов.НовоеКоличество);
				УстановитьСкидкуКомпенсацией(Док1, ВыборкаДокументов.Компенсация);
				УстановитьСкидкуКомпенсацией(Док2, ВыборкаДокументов.Компенсация);

				УстановитьРаспределениеТранспортных(Док1, ВыборкаДокументов.Распределять);
				УстановитьРаспределениеТранспортных(Док2, ВыборкаДокументов.Распределять);
			
				Если Инд = 3 Тогда //Заказы потом реализации
					Если Не ПустаяСтрока(ВыборкаДокументов.Док1) Тогда
						Док1.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
					Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
						Док2.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
				Иначе //Чеки и Реализации
					Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
						Док2.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
					Если Не ПустаяСтрока(ВыборкаДокументов.Док1) Тогда
						Док1.Записать(РежимЗаписиДокумента.Проведение);
					КонецЕсли;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла; //по пакету запросов
		
	Исключение
		Сообщить(ИнформацияОбОшибке().Описание);
		Отказ = Истина;
	КонецПопытки;
	
	Если Отказ Тогда
		ОтменитьТранзакцию();
		Сообщить("ОТМЕНА ТРАНЗАКЦИИ! Не удалось выполнить замену!!!");
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры 

Процедура ВыполнитьЗаменуУслугБезНДС(Рейс, Отказ) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	ПакетЗапросов= ПолучитьДокументыКОбработке(Рейс);
	УслугаПеревозчика= ПолучитьУслугуДоставкиПеревозчика(Рейс.Перевозчик, АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиБезНДС());
	
	НачатьТранзакцию();
	Попытка
		
		//1 - чеки; 2-реализации; 3-заказы
		Для Инд = 1 По 3 Цикл
			Если Отказ Тогда
				Прервать;
			КонецЕсли;
			
			ВыборкаДокументов =  ПакетЗапросов[Инд].Выбрать();
			
			Пока ВыборкаДокументов.Следующий() Цикл
				Док1 = "";
				Док2 = "";
				
				Если ВыборкаДокументов.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС Тогда
					Если Не ЗначениеЗаполнено(УслугаПеревозчика) Тогда
						Сообщить("Не задана услуга для перевозчика!");
						Отказ = Истина;
						Продолжить;
					КонецЕсли;
					
					УслугаКЗамене = Справочники.Номенклатура.ПустаяСсылка();
					стрТоваров = ВыборкаДокументов.Док1.Товары.Получить(ВыборкаДокументов.НомерСтроки1-1);
					Если стрТоваров = Неопределено Тогда
						Сообщить("Не удалось определить строку с услугой доставки!");
						Отказ = Истина;
						Продолжить;
					КонецЕсли;
					УслугаКЗамене = стрТоваров.Номенклатура;
					Если УслугаКЗамене = УслугаПеревозчика Тогда
						Продолжить;
					КонецЕсли;
					
					Док1 =  ВыборкаДокументов.Док1.ПолучитьОбъект();					
					Док1.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
					Если Инд = 3 Тогда //Заказы потом реализации
						Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
							Док2= ВыборкаДокументов.Док2.ПолучитьОбъект();
							Док2.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
							Док2.Записать(РежимЗаписиДокумента.ОтменаПроведения);
						КонецЕсли;
					ИначеЕсли Инд = 2 Тогда//Реализации				
						Док1.Записать(РежимЗаписиДокумента.ОтменаПроведения);
						Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
							Док2 = ВыборкаДокументов.Док2.ПолучитьОбъект();
							Док2.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
						КонецЕсли;
					ИначеЕсли Инд = 1 Тогда//Чеки				
						Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
							Док2 = ВыборкаДокументов.Док2.ПолучитьОбъект();
							Док2.ДополнительныеСвойства.Вставить("ОтключитьКонтроль");
						КонецЕсли;
					КонецЕсли;
					
					ЗаменитьУслугуДоставки(Док1, ВыборкаДокументов.НомерСтроки1 - 1, УслугаПеревозчика);
					ЗаменитьУслугуДоставки(Док2, ВыборкаДокументов.НомерСтроки2 - 1, УслугаПеревозчика);
					
					Если Инд = 3 Тогда //Заказы потом реализации
						Если Не ПустаяСтрока(ВыборкаДокументов.Док1) Тогда
							Док1.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
						Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
							Док2.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
					Иначе //Чеки и Реализации
						Если Не ПустаяСтрока(ВыборкаДокументов.Док2) Тогда
							Док2.Записать(РежимЗаписиДокумента.Проведение);
							//АльтерраОбщегоНазначения.СообщитьПользователю(Док2.Ссылка, "Заменилик услугу доставки в: "+Док2.Ссылка);
						КонецЕсли;
						Если Не ПустаяСтрока(ВыборкаДокументов.Док1) Тогда
							Док1.Записать(РежимЗаписиДокумента.Проведение);
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла; //по пакету запросов
		
	Исключение
		Сообщить(ИнформацияОбОшибке().Описание);
		Отказ = Истина;
	КонецПопытки;
	
	Если Отказ Тогда
		ОтменитьТранзакцию();
		Сообщить("ОТМЕНА ТРАНЗАКЦИИ! Не удалось обработать заказ!");
	Иначе
		ЗафиксироватьТранзакцию();
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь); 
	
КонецПроцедуры


//Вспомогательные 
Процедура ЗаменитьКоличествоВУслугеДоставки(Объект, НомерПозицииУслуги, НовоеКоличество) 
	
	Если Не ПустаяСтрока(Объект) Тогда
		стрТоваров = Объект.Товары.Получить(НомерПозицииУслуги);
		Если стрТоваров <> Неопределено Тогда
			стрТоваров.КоличествоУпаковок = НовоеКоличество;
			стрТоваров.Количество = НовоеКоличество;
			стрТоваров.Сумма = стрТоваров.Количество * стрТоваров.Цена;
			стрТоваров.СуммаНДС = ЦенообразованиеКлиентСервер.РассчитатьСуммуНДС(стрТоваров.Сумма, стрТоваров.СтавкаНДС, Истина);
			стрТоваров.СуммаСНДС = стрТоваров.Сумма+стрТоваров.СуммаНДС;	
			
			СтруктураЗаполненияЦены = Новый Структура;
			СтруктураЗаполненияЦены.Вставить("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС);
			
			СтруктураДействий = Новый Структура();			
			СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
			СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураЗаполненияЦены);
			СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураЗаполненияЦены);
			СтруктураДействий.Вставить("ПересчитатьСумму");
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
			СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
			СтруктураДействий.Вставить("ЦенаВключаетНДС", Объект.ЦенаВключаетНДС);
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда 
				СтруктураДействий.Вставить("ОчиститьСуммуВзаиморасчетов");
			КонецЕсли;
			СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", Новый Структура("Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки") );
			ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(стрТоваров, СтруктураДействий, Неопределено);
			
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
				Объект.СуммаДокумента = Объект.ПолучитьСуммуЗаказанныхСтрок();
				ОбновитьЭтапыОплатыВЗаказе(Объект, Объект.СуммаДокумента);
			КонецЕсли;
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.РеализацияТоваровУслуг") Тогда
				Объект.СуммаДокумента = Объект.ПолучитьСуммуДокумента();
			КонецЕсли;
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЧекККМ") ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.ОтчетОРозничныхПродажах") Тогда
				Объект.СуммаДокумента = ЦенообразованиеКлиентСервер.ПолучитьСуммуДокумента(Объект.Товары, Объект.ЦенаВключаетНДС);
			КонецЕсли;
			
			АльтерраОбщегоНазначения.СообщитьПользователю(Объект.Ссылка, "Заменили количество услуг в: "+Объект.Ссылка);
		КонецЕсли;
	КонецЕсли;   
	
КонецПроцедуры

Функция ПолучитьУслугуДоставкиПеревозчика(ПеревозчикКонтрагент, ГруппаУслуг) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Контрагент = &Контрагент
	|	И Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|	И Номенклатура.ПометкаУдаления = ЛОЖЬ
	|	И Номенклатура.Ссылка В ИЕРАРХИИ(&ГруппаУслуг)";
	
	Запрос.УстановитьПараметр("Контрагент", ПеревозчикКонтрагент);
	Запрос.УстановитьПараметр("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Услуга);
	Запрос.УстановитьПараметр("ГруппаУслуг", ГруппаУслуг);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат  ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат  Неопределено;
	КонецЕсли;
	
КонецФункции

Процедура ЗаменитьУслугуДоставки(Объект, НомерПозицииУслуги, УслугаПеревозчика)  Экспорт
	
	Если Не ПустаяСтрока(Объект) И УслугаПеревозчика <> Неопределено Тогда
		стрТоваров = Объект.Товары.Получить(НомерПозицииУслуги);
		Если стрТоваров <> Неопределено Тогда
			стрТоваров.Номенклатура = УслугаПеревозчика;
			стрТоваров.СтавкаНДС = УслугаПеревозчика.СтавкаНДС;
			АльтерраОбщегоНазначения.СообщитьПользователю(Объект.Ссылка, "Выполнели замену услуги на: " + УслугаПеревозчика + " в документе "+Объект.Ссылка);			
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

Процедура УстановитьРаспределениеТранспортных(Объект, Значение)
	
	Если Не ПустаяСтрока(Объект) Тогда
		Для Каждого стрТовар Из Объект.Товары Цикл
			Если стрТовар.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар Тогда
				стрТовар.Распределять= Значение;
				Объект.РаспределитьТранспортные=  Значение;
			КонецЕсли;
		КонецЦикла;
		АльтерраОбщегоНазначения.СообщитьПользователю(Объект.Ссылка, "Выполнели распределение транспортных: "+Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьСкидкуКомпенсацией(Объект, Знач Компенсация) 
	
	Если Не ПустаяСтрока(Объект) Тогда
		стрФорма= Новый Структура("Объект", Объект);
		
		АдресВоВременномХранилище = АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилище(стрФорма, "Товары", "", Ложь);
		
		ПараметрыСкидки = Новый Структура();
		ПараметрыСкидки.Вставить("ИспользуютсяАвтоматическиеСкидки", Истина);
		ПараметрыСкидки.Вставить("ТолькоДляАктивныхСтрок", Ложь);
		ПараметрыСкидки.Вставить("РассчитыватьСуммуСНДС", Истина);
		ПараметрыСкидки.Вставить("ВыделенныеСтроки", Неопределено);
		ПараметрыСкидки.Вставить("АдресВоВременномХранилище", АдресВоВременномХранилище);
		
		НазначитьРучнуюСкидку(Объект, "Товары", Компенсация, ПараметрыСкидки);
			
		АльтерраОбщегоНазначения.СообщитьПользователю(Объект.Ссылка, "Назначили скидку в документе: "+Объект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры  

Функция ЗависимыеРеквизиты()
	
	Возврат Новый Структура(
	"БезВозвратнойТары,ОтмененоБезВозвратнойТары,Отменено",
	"Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки",
	"Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки",
	"Сумма,СуммаНДС,СуммаСНДС,СуммаАвтоматическойСкидки,СуммаРучнойСкидки");
	
КонецФункции

Процедура ОбновитьЭтапыОплатыВЗаказе(Заказ, Сумма)
	
	Заказ.ЭтапыГрафикаОплаты.Очистить();
	
	стрЭтапОплаты = Заказ.ЭтапыГрафикаОплаты.Добавить();
	стрЭтапОплаты.ВариантОплаты = Перечисления.ВариантыОплатыКлиентом.КредитПослеОтгрузки;
	стрЭтапОплаты.ДатаПлатежа = Заказ.Дата;
	стрЭтапОплаты.ПроцентПлатежа = 100;
	стрЭтапОплаты.СуммаПлатежа = Сумма;
	
КонецПроцедуры


//Расчет скидок

//Изменение вставлен фильтр к таблице товаров - только товары
Функция АдресДанныхДляРасчетаРучныхСкидокВоВременномХранилище(Форма, ИмяТаблицы, УникальныйИдентификатор, ТолькоДляВыделенныхСтрок,
	
	ИмяТаблицыВыделенныхСтрок = Неопределено, ТолькоАктивныеСтроки = Ложь,
	ИспользоватьОграничения = Истина, РеализацияСверхЗаказа = Ложь) Экспорт
	
	СоглашениеСКлиентом = Неопределено;
	Если ОбщегоНазначенияУТКлиентСервер.ЕстьРеквизитОбъекта(Форма.Объект, "Соглашение") Тогда
		СоглашениеСКлиентом = Форма.Объект.Соглашение;
	КонецЕсли;
	
	ИспользоватьРучныеСкидки                     = ПолучитьФункциональнуюОпцию("ИспользоватьРучныеСкидкиВПродажах");
	ИспользоватьОграниченияРучныхСкидокВПродажах = ПолучитьФункциональнуюОпцию("ИспользоватьОграниченияРучныхСкидокВПродажахПоПользователям");
	
	Если ЗначениеЗаполнено(СоглашениеСКлиентом) Тогда
		ИспользоватьОграниченияПоСоглашениям = ПолучитьФункциональнуюОпцию("ИспользоватьОграниченияРучныхСкидокВПродажахПоСоглашениям");
	Иначе
		ИспользоватьОграниченияПоСоглашениям = Ложь;
	КонецЕсли;
	
	ИспользоватьОграниченияРучныхСкидок = ИспользоватьОграничения И ИспользоватьРучныеСкидки И (ИспользоватьОграниченияРучныхСкидокВПродажах ИЛИ ИспользоватьОграниченияПоСоглашениям);
	
	Если ИмяТаблицы = "Услуги" Тогда
		ИмяКоличества = "Количество";
	Иначе
		ИмяКоличества = "КоличествоУпаковок";
	КонецЕсли;
	
	Товары = Новый ТаблицаЗначений;
	Товары.Колонки.Добавить("Номенклатура",              Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	Товары.Колонки.Добавить(ИмяКоличества,               Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,3)));
	Товары.Колонки.Добавить("Цена",                      Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
	Товары.Колонки.Добавить("СуммаАвтоматическойСкидки", Новый ОписаниеТипов("Число"));
	Товары.Колонки.Добавить("СуммаРучнойСкидки",         Новый ОписаниеТипов("Число"));
	
	Если ТолькоДляВыделенныхСтрок Тогда
		
		Для Каждого ТекСтрока Из Форма.Элементы[?(ИмяТаблицыВыделенныхСтрок = Неопределено, ИмяТаблицы, ИмяТаблицыВыделенныхСтрок)].ВыделенныеСтроки Цикл
			
			СтрокаКоллекции = Форма.Объект[ИмяТаблицы].НайтиПоИдентификатору(ТекСтрока);
			
			Если ?(РеализацияСверхЗаказа, СтрокаКоллекции = Неопределено ИЛИ СтрокаКоллекции.КодСтроки > 0, СтрокаКоллекции = Неопределено) Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаКоллекции);
			
		КонецЦикла;
	Иначе
		Если РеализацияСверхЗаказа Тогда
			НайденныеСтроки = Форма.Объект[ИмяТаблицы].НайтиСтроки(Новый Структура("КодСтроки", 0));
			Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
				НоваяСтрока = Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;
		ИначеЕсли ТолькоАктивныеСтроки Тогда
			НайденныеСтроки = Форма.Объект[ИмяТаблицы].НайтиСтроки(Новый Структура("Активность", Истина));
			Для Каждого СтрокаТЧ Из НайденныеСтроки Цикл
				НоваяСтрока = Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
			КонецЦикла;
		Иначе
			Для Каждого СтрокаТЧ Из Форма.Объект[ИмяТаблицы] Цикл
				Если СтрокаТЧ.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар Тогда
					Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "Отменено") Тогда
						Если Не СтрокаТЧ.Отменено Тогда
							НоваяСтрока = Товары.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
						КонецЕсли;
					Иначе
						НоваяСтрока = Товары.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЧ);
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	Если ИспользоватьОграниченияРучныхСкидок Тогда	
		ОграниченияРучныхСкидок = НастройкиПродажДляПользователейСервер.ОграниченияСкидокНаценок(СоглашениеСКлиентом, Пользователи.ТекущийПользователь());
		ЦеновыеГруппы = ОграниченияРучныхСкидок.ВыгрузитьКолонку("ЦеноваяГруппа");	
	Иначе	
		ОграниченияРучныхСкидок = Новый ТаблицаЗначений;
		ОграниченияРучныхСкидок.Колонки.Добавить("ЦеноваяГруппа", Новый ОписаниеТипов("СправочникСсылка.ЦеновыеГруппы"));
		ОграниченияРучныхСкидок.Колонки.Добавить("МаксимальныйПроцентРучнойСкидки",  Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
		ОграниченияРучныхСкидок.Колонки.Добавить("МаксимальныйПроцентРучнойНаценки", Новый ОписаниеТипов("Число",,,Новый КвалификаторыЧисла(15,2)));
		
		Ограничение = ОграниченияРучныхСкидок.Добавить();
		Ограничение.ЦеноваяГруппа = Справочники.ЦеновыеГруппы.ПустаяСсылка();
		Ограничение.МаксимальныйПроцентРучнойСкидки  = 999.99;
		Ограничение.МаксимальныйПроцентРучнойНаценки = 999.99;
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары." + ИмяКоличества + " " + "КАК КоличествоУпаковок,
	|	Товары.Цена КАК ЦенаЗаУпаковку,
	|	Товары.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
	|	Товары.СуммаРучнойСкидки КАК СуммаРучнойСкидки
	|ПОМЕСТИТЬ ВременнаяТаблица
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СправочникНоменклатура.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	Товары.ЦенаЗаУпаковку КАК ЦенаЗаУпаковку,
	|	Товары.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
	|	Товары.СуммаРучнойСкидки КАК СуммаРучнойСкидки
	|ПОМЕСТИТЬ ВременнаяТаблицаТовары
	|ИЗ
	|	ВременнаяТаблица КАК Товары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
	|		ПО (СправочникНоменклатура.Ссылка = Товары.Номенклатура)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ОграниченияРучныхСкидок.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	ОграниченияРучныхСкидок.МаксимальныйПроцентРучнойСкидки КАК МаксимальныйПроцентРучнойСкидки,
	|	ОграниченияРучныхСкидок.МаксимальныйПроцентРучнойНаценки КАК МаксимальныйПроцентРучнойНаценки
	|ПОМЕСТИТЬ ОграниченияРучныхСкидок
	|ИЗ
	|	&ОграниченияРучныхСкидок КАК ОграниченияРучныхСкидок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Т.ЦеноваяГруппа КАК ЦеноваяГруппа,
	|	Т.СуммаБезСкидки КАК СуммаБезСкидки,
	|	Т.СуммаАвтоматическойСкидки КАК СуммаАвтоматическойСкидки,
	|	Т.СуммаРучнойСкидки КАК СуммаРучнойСкидки,
	|	ОграниченияРучныхСкидок.МаксимальныйПроцентРучнойСкидки КАК МаксимальныйПроцентРучнойСкидки,
	|	ОграниченияРучныхСкидок.МаксимальныйПроцентРучнойНаценки КАК МаксимальныйПроцентРучнойНаценки,
	|	ВЫРАЗИТЬ(ОграниченияРучныхСкидок.МаксимальныйПроцентРучнойСкидки / 100 * Т.СуммаБезСкидки КАК ЧИСЛО(15, 2)) КАК МаксимальнаяСуммаРучнойСкидки,
	|	ВЫРАЗИТЬ(ОграниченияРучныхСкидок.МаксимальныйПроцентРучнойНаценки / 100 * Т.СуммаБезСкидки КАК ЧИСЛО(15, 2)) КАК МаксимальнаяСуммаРучнойНаценки
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВЫБОР
	|			КОГДА ВременнаяТаблицаТовары.ЦеноваяГруппа В (&ЦеновыеГруппы)
	|				ТОГДА ВременнаяТаблицаТовары.ЦеноваяГруппа
	|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЦеновыеГруппы.ПустаяСсылка)
	|		КОНЕЦ КАК ЦеноваяГруппа,
	|		СУММА(ВЫРАЗИТЬ(ВременнаяТаблицаТовары.КоличествоУпаковок * ВременнаяТаблицаТовары.ЦенаЗаУпаковку КАК ЧИСЛО(15, 2))) КАК СуммаБезСкидки,
	|		СУММА(ВременнаяТаблицаТовары.СуммаАвтоматическойСкидки) КАК СуммаАвтоматическойСкидки,
	|		СУММА(ВременнаяТаблицаТовары.СуммаРучнойСкидки) КАК СуммаРучнойСкидки
	|	ИЗ
	|		ВременнаяТаблицаТовары КАК ВременнаяТаблицаТовары
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ВЫБОР
	|			КОГДА ВременнаяТаблицаТовары.ЦеноваяГруппа В (&ЦеновыеГруппы)
	|				ТОГДА ВременнаяТаблицаТовары.ЦеноваяГруппа
	|			ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ЦеновыеГруппы.ПустаяСсылка)
	|		КОНЕЦ) КАК Т
	|		ЛЕВОЕ СОЕДИНЕНИЕ ОграниченияРучныхСкидок КАК ОграниченияРучныхСкидок
	|		ПО (ОграниченияРучныхСкидок.ЦеноваяГруппа = Т.ЦеноваяГруппа)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВременнаяТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ВременнаяТаблицаТовары.ЦеноваяГруппа КАК ЦеноваяГруппа
	|ИЗ
	|	ВременнаяТаблицаТовары КАК ВременнаяТаблицаТовары";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.Параметры.Вставить("Товары", Товары);
	Запрос.Параметры.Вставить("ОграниченияРучныхСкидок", ОграниченияРучныхСкидок);
	Запрос.Параметры.Вставить("ЦеновыеГруппы", ЦеновыеГруппы);
	
	Результат = Запрос.ВыполнитьПакет();
	
	Ограничения = Результат[5].Выгрузить();
	Ограничения.Индексы.Добавить("ЦеноваяГруппа");
	
	Товары = Результат[6].Выгрузить();
	Товары.Индексы.Добавить("Номенклатура");
	
	Возврат ПоместитьВоВременноеХранилище(Новый Структура("Ограничения, Товары, ИспользоватьОграниченияРучныхСкидок", Ограничения, Товары, ИспользоватьОграниченияРучныхСкидок), УникальныйИдентификатор);
	
КонецФункции 

// Процедура назначает ручные скидки в табичной части
//
Процедура НазначитьРучнуюСкидку(Объект, ИмяТЧ, СуммаСкидкиКРаспределению, ВходныеПараметры) Экспорт
	
	ПараметрыСкидки = Новый Структура();
	ПараметрыСкидки.Вставить("ИспользуютсяАвтоматическиеСкидки", Ложь);
	ПараметрыСкидки.Вставить("ТолькоДляАктивныхСтрок", Ложь);
	ПараметрыСкидки.Вставить("РассчитыватьСуммуСНДС", Ложь);
	ПараметрыСкидки.Вставить("РассчитыватьСуммуВзаиморасчетов", Ложь);
	ПараметрыСкидки.Вставить("ВыделенныеСтроки", Неопределено);
	ПараметрыСкидки.Вставить("АдресВоВременномХранилище", Неопределено);
	ПараметрыСкидки.Вставить("РеализацияСверхЗаказа", Ложь);
	
	ЗаполнитьЗначенияСвойств(ПараметрыСкидки, ВходныеПараметры);
	
	Если ИмяТЧ = "Услуги" Тогда
		ИмяКоличества = "Количество";
	Иначе
		ИмяКоличества = "КоличествоУпаковок";
	КонецЕсли;
	
	Если ПараметрыСкидки.ВыделенныеСтроки <> Неопределено Тогда
		СтрокиТабличнойЧасти = Новый Массив();
		
		Для Каждого ТекСтрока Из ПараметрыСкидки.ВыделенныеСтроки Цикл
			НайденнаяСтрока = Объект[ИмяТЧ].НайтиПоИдентификатору(ТекСтрока);
			Если ?(ПараметрыСкидки.РеализацияСверхЗаказа, НайденнаяСтрока.КодСтроки = 0, Истина) Тогда
				СтрокиТабличнойЧасти.Добавить(НайденнаяСтрока);
			КонецЕсли;
		КонецЦикла;
		
	Иначе
		Если ПараметрыСкидки.ТолькоДляАктивныхСтрок Тогда
			СтрокиТабличнойЧасти = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("Активность", Истина));
		ИначеЕсли ПараметрыСкидки.РеализацияСверхЗаказа Тогда
			СтрокиТабличнойЧасти = Объект[ИмяТЧ].НайтиСтроки(Новый Структура("КодСтроки", 0));
		Иначе
			СтрокиТабличнойЧасти = Объект[ИмяТЧ];
		КонецЕсли;
	КонецЕсли;
	
	Данные = ПолучитьИзВременногоХранилища(ПараметрыСкидки.АдресВоВременномХранилище);
	Данные.Ограничения.Колонки.Добавить("СуммаСкидкиКРаспределению", Новый ОписаниеТипов("Число"));
	
	Режим0Суммы = Ложь;
	
	Если СуммаСкидкиКРаспределению >= 0 Тогда
		МаксимальнаяСуммаСкидкиНаценки = Данные.Ограничения.Итог("МаксимальнаяСуммаРучнойСкидки");
	Иначе
		МаксимальнаяСуммаСкидкиНаценки = Данные.Ограничения.Итог("МаксимальнаяСуммаРучнойНаценки");
	КонецЕсли;
	Если МаксимальнаяСуммаСкидкиНаценки = 0 Тогда
		Режим0Суммы = Истина;
	КонецЕсли;
	Если Режим0Суммы Тогда
		МаксимальнаяСуммаСкидкиНаценки = Данные.Ограничения.Итог("СуммаБезСкидки");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(МаксимальнаяСуммаСкидкиНаценки) Тогда
		МаксимальнаяСуммаСкидкиНаценки = 0;
	КонецЕсли;
	
	мСуммаСкидкиКРаспределению = СуммаСкидкиКРаспределению;
	Для Каждого Ограничение Из Данные.Ограничения Цикл
		
		Если мСуммаСкидкиКРаспределению >= 0 Тогда
			МаксимальнаяСуммаСкидкиНаценкиОграничения = Ограничение.МаксимальнаяСуммаРучнойСкидки;
		Иначе
			МаксимальнаяСуммаСкидкиНаценкиОграничения = Ограничение.МаксимальнаяСуммаРучнойНаценки;
		КонецЕсли;
		Если Режим0Суммы Тогда
			МаксимальнаяСуммаСкидкиНаценкиОграничения = Ограничение.СуммаБезСкидки;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(МаксимальнаяСуммаСкидкиНаценкиОграничения) Тогда
			МаксимальнаяСуммаСкидкиНаценкиОграничения = 0;
		КонецЕсли;
		
		Если МаксимальнаяСуммаСкидкиНаценки <> 0 Тогда
			
			Ограничение.СуммаСкидкиКРаспределению = мСуммаСкидкиКРаспределению * (МаксимальнаяСуммаСкидкиНаценкиОграничения / МаксимальнаяСуммаСкидкиНаценки);
			
			мСуммаСкидкиКРаспределению = мСуммаСкидкиКРаспределению - Ограничение.СуммаСкидкиКРаспределению;
			МаксимальнаяСуммаСкидкиНаценки = МаксимальнаяСуммаСкидкиНаценки - МаксимальнаяСуммаСкидкиНаценкиОграничения;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Для каждого СтрокаТЧ Из СтрокиТабличнойЧасти Цикл	
		Если СтрокаТЧ.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Товар Тогда
			Продолжить;
		КонецЕсли;
		Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(СтрокаТЧ, "Отменено") И СтрокаТЧ.Отменено Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеНоменклатуры = Данные.Товары.Найти(СтрокаТЧ.Номенклатура, "Номенклатура");
		
		Для Каждого Ограничение Из Данные.Ограничения Цикл
			
			Если  НЕ (ДанныеНоменклатуры.ЦеноваяГруппа = Ограничение.ЦеноваяГруппа
				ИЛИ (Данные.Ограничения.Найти(ДанныеНоменклатуры.ЦеноваяГруппа, "ЦеноваяГруппа") = Неопределено
				И Ограничение.ЦеноваяГруппа = Справочники.ЦеновыеГруппы.ПустаяСсылка())) Тогда
				Продолжить;
			КонецЕсли;
			
			СуммаБезСкидки = СтрокаТЧ[ИмяКоличества] * СтрокаТЧ.Цена;
			СуммаАвтоматическойСкидки = ?(ПараметрыСкидки.ИспользуютсяАвтоматическиеСкидки, СтрокаТЧ.СуммаАвтоматическойСкидки, 0);
			
			Если Ограничение.СуммаБезСкидки <> 0 Тогда
				СтрокаТЧ.СуммаРучнойСкидки = (СуммаБезСкидки) * (Ограничение.СуммаСкидкиКРаспределению / Ограничение.СуммаБезСкидки);
			Иначе
				СтрокаТЧ.СуммаРучнойСкидки = 0;
			КонецЕсли;
			Ограничение.СуммаСкидкиКРаспределению = Ограничение.СуммаСкидкиКРаспределению - СтрокаТЧ.СуммаРучнойСкидки;
			Ограничение.СуммаБезСкидки = Ограничение.СуммаБезСкидки - СуммаБезСкидки;
			
			Если СуммаБезСкидки <> 0 Тогда
				СтрокаТЧ.ПроцентРучнойСкидки = 100 * СтрокаТЧ.СуммаРучнойСкидки / СуммаБезСкидки;
			Иначе
				СтрокаТЧ.ПроцентРучнойСкидки = 0;
			КонецЕсли;
			
			СуммаСкидки = СуммаАвтоматическойСкидки + СтрокаТЧ.СуммаРучнойСкидки;
			
			Если ПараметрыСкидки.ИспользуютсяАвтоматическиеСкидки Тогда
				Если СуммаБезСкидки <> 0 Тогда
					СтрокаТЧ.ПроцентАвтоматическойСкидки = ?(СуммаБезСкидки = 0, 0 , 100 * СуммаАвтоматическойСкидки / СуммаБезСкидки);
				Иначе
					СтрокаТЧ.ПроцентАвтоматическойСкидки = 0;
				КонецЕсли;
			КонецЕсли;
			
			СтрокаТЧ.Сумма    = СуммаБезСкидки - ?(СуммаСкидки > СуммаБезСкидки, СуммаБезСкидки, СуммаСкидки);
			СтрокаТЧ.СуммаНДС = РассчитатьСуммуНДС(СтрокаТЧ.Сумма, СтрокаТЧ.СтавкаНДС, Объект.ЦенаВключаетНДС);
			
			Если ПараметрыСкидки.РассчитыватьСуммуСНДС Тогда
				СтрокаТЧ.СуммаСНДС = СтрокаТЧ.Сумма + ?(Объект.ЦенаВключаетНДС, 0, СтрокаТЧ.СуммаНДС);
			КонецЕсли;
			
			Если ПараметрыСкидки.РассчитыватьСуммуВзаиморасчетов Тогда
				СтрокаТЧ.СуммаВзаиморасчетов = 0;
			КонецЕсли;
			
		КонецЦикла;
	КонецЦикла;
	
	Объект.СуммаДокумента = ЦенообразованиеКлиентСервер.ПолучитьСуммуДокумента(Объект[ИмяТЧ], Объект.ЦенаВключаетНДС);
	
КонецПроцедуры  

Функция РассчитатьСуммуНДС(Сумма, СтавкаНДС, ЦенаВключаетНДС = Истина)
	
	ПроцентНДС = ЦенообразованиеКлиентСервер.ПолучитьСтавкуНДСЧислом(СтавкаНДС)/100;
	
	Если ЦенаВключаетНДС Тогда
		СуммаНДС = Сумма * ПроцентНДС / (ПроцентНДС + 1);
	Иначе
		СуммаНДС = Сумма * ПроцентНДС;
	КонецЕсли;
	
	Возврат СуммаНДС;
	
КонецФункции  

#КонецОбласти

#Область СозданиеНаОсновании     

Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСоздатьНаОсновании) Экспорт
	
	ИмяДокумента = "ЗаданиеНаПеревозкуРейс";
	Если ПравоДоступа("Добавление", Метаданные.Документы[ИмяДокумента]) Тогда
		КомандаСоздатьНаОсновании = КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Идентификатор = Метаданные.Документы[ИмяДокумента].ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление = ОбщегоНазначенияУТ.ПредставлениеОбъекта(Метаданные.Документы[ИмяДокумента]);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;  
	
КонецФункции

#КонецОбласти 

#Область Проверки

Процедура ПроверитьЧтоПоЗаказамЕстьДругиеРейсы(Объект, Отказ) Экспорт
	
	ВыборкаРейсов= ЗапросКДругимРейсамРейсы(Объект);
	Пока ВыборкаРейсов.Следующий() Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ: " + ВыборкаРейсов.ЗаказНаДоставку + " присутствует в другом рейсе: " + ВыборкаРейсов.Рейс, Объект.Ссылка, "ОснованияДокумент", "Основания.Документ");
		Отказ = Истина;
	КонецЦикла;
	
КонецПроцедуры 

Функция ЗапросКДругимРейсамРейсы(Объект)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказыНаДоставку.Документ КАК Документ
	|ПОМЕСТИТЬ ЗаказыНаДоставку
	|ИЗ
	|	&Основания КАК ЗаказыНаДоставку
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку,
	|	ЗаказыКДоставке.ДокументПродажи КАК ДокументПродажи,
	|	ЗаказыКДоставке.Рейс КАК Рейс
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
	|ГДЕ
	|	ЗаказыКДоставке.ЗаказНаДоставку В
	|			(ВЫБРАТЬ
	|				ЗаказыНаДоставку.Документ КАК Документ
	|			ИЗ
	|				ЗаказыНаДоставку КАК ЗаказыНаДоставку)
	|	И ЗаказыКДоставке.Рейс <> &Ссылка
	|	И ЗаказыКДоставке.ВидДвижения = &ВидДвижения";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	Запрос.УстановитьПараметр("ВидДвижения", ВидДвиженияНакопления.Расход);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи; 
	
КонецФункции

Процедура ПроверитьЧтоПоЗаказамСозданыРеализации(Объект, Отказ, ПроверятьРеализации = Истина, ПроверятьОтметкуКассы = Истина)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК Документ
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&ЗаданиеНаПеревозкуРейсРасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	0 КАК Заказ,
	|	РеализацияТоваровУслуг.Ссылка КАК Реализация,
	|	РеализацияТоваровУслуг.Кассир КАК Кассир
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслуг.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заказ.Ссылка,
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.Кассир
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|				И (ЛОЖЬ = РеализацияТоваровУслуг.ПометкаУдаления)
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка";
	
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозкуРейсРасчетДоставки", Объект.РасчетДоставки.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Выборка= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если ПроверятьРеализации Тогда 
			Если Не ЗначениеЗаполнено(Выборка.Реализация) Тогда
				АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Заказ, "По " + Выборка.Заказ + " нет созданных реализаций!");
				Отказ = Истина;
			КонецЕсли;
			Если Не Отказ И Не АльтерраОбщегоНазначения.ЕстьУслугиДоставки(Выборка.Реализация) Тогда
				АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Реализация, "В докумене " + Выборка.Реализация + " нет услуги доставки!");
			КонецЕсли;
		КонецЕсли;
		Если Не Отказ И ПроверятьОтметкуКассы И Не ЗначениеЗаполнено(Выборка.Кассир) Тогда
			АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Реализация, "У " + Выборка.Реализация + " нет отметки кассы!");
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры 

Процедура ПроверитьЧтоНетРейсовИлиЗаказовНаДоставку(Объект, Отказ) Экспорт
	
	Если РольДоступна("ПропуститьПроверкиПоЛогистике") Тогда
		Возврат;
	КонецЕсли;
	Если РольДоступна("ПолныеПрава") И Не Объект.ДополнительныеСвойства.Свойство("ОтключитьКонтроль") Тогда
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказыКДоставке.Регистратор КАК Регистратор
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
	|ГДЕ
	|	ЗаказыКДоставке.ДокументПродажи = &ДокументПродажи";
	
	Запрос.УстановитьПараметр("ДокументПродажи", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда 
		Сообщить("По документу существуют Заказы на доставку или Рейсы. Отмена проведения не возможна!");
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Регистратор, Строка(Выборка.Регистратор));
		Отказ = Истина;
	КонецЦикла;
	
КонецПроцедуры

Функция ПроверитьДублиСкладОтправитьСкладПолучатель(МассивДокументов) Экспорт

	Если МассивДокументов.Количество() > 1 Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =  
			"ВЫБРАТЬ
			|	ТЧОснования.Ссылка КАК ЗаказНаДоставку,
			|	ТЧОснования.Документ КАК ДокументПродажи
			|ПОМЕСТИТЬ ВТЗаказы
			|ИЗ
			|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ТЧОснования
			|ГДЕ
			|	ТЧОснования.Ссылка В(&МассивДокументов)
			|	И ТЧОснования.Документ ССЫЛКА Документ.ПеремещениеТоваров
			|	И ТЧОснования.Ссылка.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Внутренняя)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Заказы.ЗаказНаДоставку) КАК ЗаказНаДоставку,
			|	Заказы.ДокументПродажи.СкладОтправитель КАК ДокументПродажиСкладОтправитель,
			|	Заказы.ДокументПродажи.СкладПолучатель КАК ДокументПродажиСкладПолучатель
			|ПОМЕСТИТЬ ВТИтог
			|ИЗ
			|	ВТЗаказы КАК Заказы
			|
			|СГРУППИРОВАТЬ ПО
			|	Заказы.ДокументПродажи.СкладОтправитель,
			|	Заказы.ДокументПродажи.СкладПолучатель
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	ИСТИНА КАК УсловиеВыполняется
			|ИЗ
			|	ВТИтог КАК ВТИтог
			|ГДЕ
			|	ВТИтог.ЗаказНаДоставку > 1";
		
		Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);	
		
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			ОбщегоНазначения.СообщитьПользователю("Объедините перемещения с одинаковыми складами в один документ 'Заказ на доставку'!");
			Возврат Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ложь; 
	
КонецФункции

//Проверка наличия товара и заявки Егаис Лес (Задача № 49625)
Процедура ПроверитьЗаявкиЕГАИСЛес(Объект, Отказ) Экспорт
	
	ТекстПроверкиЕгаис = ПроверитьНаличиеТовараИЗаявкиЕГАИСЛес(Объект, Отказ);
	Если Не ПустаяСтрока(ТекстПроверкиЕгаис) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстПроверкиЕгаис);
		Отказ = Истина;	
	КонецЕсли;
	
КонецПроцедуры 

Функция ПолучитьЗаявкиВЕгаисЛес(СсылкиНаОбъекты) Экспорт	
	
	МассивЗаявокЕгаисЛес = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаявкаВЕГАИСЛес.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаявкаВЕГАИСЛес КАК ЗаявкаВЕГАИСЛес
	|ГДЕ
	|	ЗаявкаВЕГАИСЛес.Основание В(&Основание)
	|	И ЗаявкаВЕГАИСЛес.ПометкаУдаления = ЛОЖЬ
	|	И ЗаявкаВЕГАИСЛес.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("Основание", СсылкиНаОбъекты);
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ.ВыгрузитьКолонку("Ссылка");
	
КонецФункции 

Функция ПроверитьНаличиеТовараИЗаявкиЕГАИСЛес(Объект, Отказ) Экспорт	
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ГруппыЕГАИС
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа = ИСТИНА
	|	И Номенклатура.ЕГАИСЛес = ИСТИНА
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК Документ
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&ДокументДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ДокументьПродажиНаличиеТовара
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|			ПО ЧекККМ.Ссылка = ЧекККМТовары.Ссылка
	|		ПО ВТ_Основания.Документ = ЧекККМ.Ссылка
	|ГДЕ
	|	ЧекККМТовары.Номенклатура.Родитель В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				Номенклатура.Ссылка КАК Ссылка
	|			ИЗ
	|				ВТ_ГруппыЕГАИС КАК Номенклатура)
	|	И НЕ ЧекККМ.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|			ПО РеализацияТоваровУслуг.Ссылка = РеализацияТоваровУслугТовары.Ссылка
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслуг.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Номенклатура.Родитель В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				Номенклатура.Ссылка КАК Ссылка
	|			ИЗ
	|				ВТ_ГруппыЕГАИС КАК Номенклатура)
	|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|				ПО РеализацияТоваровУслуг.Ссылка = РеализацияТоваровУслугТовары.Ссылка
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Номенклатура.Родитель В ИЕРАРХИИ
	|			(ВЫБРАТЬ
	|				Номенклатура.Ссылка КАК Ссылка
	|			ИЗ
	|				ВТ_ГруппыЕГАИС КАК Номенклатура)
	|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ДокументьПродажиНаличиеТовара.Ссылка КАК Ссылка,
	|	ЗаявкаВЕГАИСЛес.Ссылка КАК ЗаявкаВЕГАИСЛес,
	|	ВЫБОР
	|		КОГДА НЕ ЗаявкаВЕГАИСЛес.Ссылка ЕСТЬ NULL
	|				И ЗаявкаВЕГАИСЛес.ПометкаУдаления = ЛОЖЬ
	|				И ЗаявкаВЕГАИСЛес.Проведен = ИСТИНА
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НаличиеЗаявки,
	|	ВЫБОР
	|		КОГДА НЕ ЗаявкаВЕГАИСЛес.Ссылка ЕСТЬ NULL
	|				И ЗаявкаВЕГАИСЛес.ПометкаУдаления = ЛОЖЬ
	|				И ЗаявкаВЕГАИСЛес.Проведен = ИСТИНА
	|			ТОГДА ЗаявкаВЕГАИСЛес.НомерДекларацииЮЛ
	|	КОНЕЦ КАК НомерДекларации,
	|	ЗаявкаВЕГАИСЛес.ТипКлиента КАК ТипКлиента
	|ИЗ
	|	ВТ_ДокументьПродажиНаличиеТовара КАК ВТ_ДокументьПродажиНаличиеТовара
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаявкаВЕГАИСЛес КАК ЗаявкаВЕГАИСЛес
	|		ПО ВТ_ДокументьПродажиНаличиеТовара.Ссылка = ЗаявкаВЕГАИСЛес.Основание";
	
	Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказНаДоставкуКлиенту") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,
		"ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи",
		"ЗаказНаДоставкуКлиентуОснования.Документ");
		Запрос.Текст = СтрЗаменить(Запрос.Текст,
		"ЗаданиеНаПеревозкуРейсРасчетДоставки",
		"ЗаказНаДоставкуКлиентуОснования");
		Запрос.УстановитьПараметр("ДокументДоставки", Объект.Основания.Выгрузить());
	ИначеЕсли ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.ЗаданиеНаПеревозкуРейс") Тогда
		Запрос.УстановитьПараметр("ДокументДоставки", Объект.РасчетДоставки.Выгрузить());
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Ссылка", Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Пиломатериал"));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	ТекстВозврата = "";
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.НаличиеЗаявки = Ложь Тогда
			ТекстВозврата = ТекстВозврата + Строка(ВыборкаДетальныеЗаписи.Ссылка) + " - нет заявки в ЕГАИС Лес!" +Символы.ПС;
		ИначеЕсли ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаданиеНаПеревозкуРейс") Тогда
			Если ВыборкаДетальныеЗаписи.ТипКлиента = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда
				Если Не ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.НомерДекларации)  Тогда
					ТекстВозврата = ТекстВозврата + Строка(ВыборкаДетальныеЗаписи.ЗаявкаВЕГАИСЛес) + " - не заполнен Номер декларации!" + Символы.ПС;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТекстВозврата; 
	
КонецФункции

Процедура ПроверкаОтметкиКассы(Объект, Отказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ДокументПродажи КАК Документ,
	|	ЗаданиеНаПеревозкуРейсРасчетДоставки.НужнаИнкассация КАК НужнаИнкассация
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&ЗаданиеНаПеревозкуРейсРасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка,
	|	ВТ_Основания.НужнаИнкассация КАК НужнаИнкассация
	|ПОМЕСТИТЬ ВТ_Результат1
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
	|		ПО ВТ_Основания.Документ = ЧекККМ.Ссылка
	|ГДЕ
	|	ЧекККМ.Статус <> ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	ВТ_Основания.НужнаИнкассация
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслуг.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|	И РеализацияТоваровУслуг.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	ВТ_Основания.НужнаИнкассация
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Кассир = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)
	|	И РеализацияТоваровУслуг.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Результат1.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(ЛистСогласования.Согласован, ЛОЖЬ) КАК Согласован,
	|	ВТ_Результат1.НужнаИнкассация КАК НужнаИнкассация
	|ИЗ
	|	ВТ_Результат1 КАК ВТ_Результат1
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЛистСогласования КАК ЛистСогласования
	|		ПО ВТ_Результат1.Ссылка = ЛистСогласования.Основание
	|			И (ИСТИНА = ЛистСогласования.Проведен)
	|			И (ЛОЖЬ = ЛистСогласования.Аннулирован)";
	
	ТЗ = Объект.РасчетДоставки.Выгрузить();
	ТЗ.Колонки.Добавить("НужнаИнкассация", Новый ОписаниеТипов("Булево"));
	Для Каждого стрТЗ Из ТЗ Цикл
		стрТЗ.НужнаИнкассация = стрТЗ.ЗаказНаДоставку.НужнаИнкассация;
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ЗаданиеНаПеревозкуРейсРасчетДоставки", ТЗ);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.НужнаИнкассация Тогда
			Если Не Выборка.Согласован Тогда
				АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Ссылка, "Нет листа согласования по документу с инкасацией!");
				Отказ = Истина;
			КонецЕсли;
		Иначе
			АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.Ссылка, "Нет отметки кассы у документа");
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры

Процедура ПроверитьОграничениеПоТранспорту(Объект, Отказ)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	мЗаказов.Документ КАК Ссылка
	|ПОМЕСТИТЬ ВТЗаказы
	|ИЗ
	|	&мЗаказов КАК мЗаказов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(МАКСИМУМ(ЗаданиеНаПеревозкуРейсОснования.Документ.ЗонаДоставкиДляВодителя.ГрузоподъемностьВТоннах), 0) КАК ГрузоподъемностьВТоннах,
	|	ЕСТЬNULL(МАКСИМУМ(ЗаданиеНаПеревозкуРейсОснования.Документ.ЗонаДоставкиДляВодителя.МаксимальнаяДлинаГруза), 0) КАК МаксимальнаяДлинаГруза
	|ИЗ
	|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
	|ГДЕ
	|	ЗаданиеНаПеревозкуРейсОснования.Документ В
	|			(ВЫБРАТЬ
	|				ВТЗаказы.Ссылка КАК Ссылка
	|			ИЗ
	|				ВТЗаказы КАК ВТЗаказы)";
	
	Запрос.УстановитьПараметр("мЗаказов", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Если (Выборка.ГрузоподъемностьВТоннах + Выборка.МаксимальнаяДлинаГруза) > 0 Тогда
			Если Выборка.ГрузоподъемностьВТоннах < Объект.Автомобиль.ГрузоподъемностьВТоннах ИЛИ
				Выборка.МаксимальнаяДлинаГруза < Объект.Автомобиль.МаксимальнаяДлинаГруза Тогда
				Сообщить("По зоне доставки действует ограничение по автомобилю (грузоподъемности или длине груза)!");
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверкаНаБезНДСныеУслугиВНДСомРейсе(Объект, Отказ) Экспорт
	
	Если Объект.СтавкаНДС <> Перечисления.СтавкиНДС.БезНДС Тогда
		Для Каждого стрРасчетДоставки Из Объект.РасчетДоставки Цикл
			Если стрРасчетДоставки.ОтметкаКассы И стрРасчетДоставки.ЗаказНаДоставку.СтоимостьДоставки > 0 Тогда 
				Отказ = Истина;
				АльтерраОбщегоНазначения.СообщитьПользователю(стрРасчетДоставки.ЗаказНаДоставку, "В рейсе присутствует заказ на доставку с НДС. Отправка такого рейса запрещена!");
			КонецЕсли;
		КонецЦикла;
	КонецЕсли; 
	
КонецПроцедуры

//При отметки кассы
Функция ПроверитьЕстьРейсыПоДокументу(ДокументПродажи) Экспорт
	
	Если РольДоступна("ПропуститьПроверкиПоЛогистике") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Рейс = ПолучитьРейсПоДокументуПродажи(ДокументПродажи);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ЗначениеЗаполнено(Рейс) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Существует "+Рейс, Рейс);
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ЕстьНеСогласованныйРейс(ДокументПродажи) Экспорт
	//Рейс= ПолучитьРейсПоДокументуПродажи(ДокументПродажи);
	//Если ЗначениеЗаполнено(Рейс) И Рейс.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
	//	Если Не Рейс.Согласован Тогда
	//		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Существует не согласованный "+Рейс, Рейс);
