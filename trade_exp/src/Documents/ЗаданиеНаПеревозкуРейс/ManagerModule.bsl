Функция ПечатьКомплектаДопланирования(Рейс) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ 
		|	ОснованияРейса.ИтерацияДопланирования,
		|	ОснованияРейса.НужнаПечать
		|ПОМЕСТИТЬ
		|	втОсновванияРейса
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс КАК Рейс
		|	СОЕДИНЕНИЕ Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ОснованияРейса
		|		ПО Рейс.Ссылка = ОснованияРейса.Ссылка
		|ГДЕ 
		|	Рейс.Ссылка = &Рейс                        
		|	И Рейс.Проведен
		|	И Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыРейсов.Допланирование)	                       
		|	И ОснованияРейса.ИтерацияДопланирования > 0
		|;
		|////////////////////////////////////////////////////
		|ВЫБРАТЬ 
		|	КОЛИЧЕСТВО(*) КАК Количество
		|ПОМЕСТИТЬ
		|	втНужнаПечать	
		|ИЗ
		|	втОсновванияРейса	
		|ГДЕ
		|	НужнаПечать		
		|;
		|////////////////////////////////////////////////////	
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	втОсновванияРейса.ИтерацияДопланирования
		|ИЗ 	 
		|	втОсновванияРейса
		|	СОЕДИНЕНИЕ втНужнаПечать
		|		ПО втНужнаПечать.Количество > 0
		|ГДЕ
		|	втОсновванияРейса.НужнаПечать	
		|		
		|ОБЪЕДИНИТЬ ВСЕ		 

		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	втОсновванияРейса.ИтерацияДопланирования
		|ИЗ 	 
		|	втОсновванияРейса
		|	СОЕДИНЕНИЕ втНужнаПечать
		|		ПО втНужнаПечать.Количество = 0
		|УПОРЯДОЧИТЬ ПО 
		|	1 УБЫВ";
	
	Запрос.УстановитьПараметр("Рейс", Рейс);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ИтерацияДопланирования");
	
КонецФункции	

Процедура ЗаписатьСобытиеПечатиКомплекта(Рейс, Допланирование = Ложь) Экспорт
	
	НаборЗаписей = РегистрыСведений.СобытияДокументовАльтерра.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Документ.Установить(Рейс);
	НаборЗаписей.Прочитать();
	
	НовоеСобытие = НаборЗаписей.Добавить();   
	НовоеСобытие.Период = ТекущаяДата();
	НовоеСобытие.Документ = Рейс;
	НовоеСобытие.Событие = ?(Не Допланирование, 
		ПредопределенноеЗначение("Перечисление.СобытияДокументов.ПечатьКомплектаДокументовРейса"),
		ПредопределенноеЗначение("Перечисление.СобытияДокументов.ПечатьДокументовДопланированияРейса"));
	НовоеСобытие.Пользователь = Пользователи.ТекущийПользователь();
	
	НаборЗаписей.Записать(Истина);        
	
КонецПроцедуры
	
