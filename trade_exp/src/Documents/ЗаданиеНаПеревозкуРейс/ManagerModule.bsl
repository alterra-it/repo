	Возврат Ложь;
КонецФункции

Процедура ПроверитьРасхожденияРасчетныхИФактическихДаныхВРасчетеДоставки(Объект, Отказ) Экспорт
	
	Для Каждого стрРасчетДоставки Из Объект.РасчетДоставки Цикл
		Если стрРасчетДоставки.ОплатаКлиентомФакт <> (стрРасчетДоставки.ПлатаЗаДоставку-стрРасчетДоставки.КомпенсацияИзНаценки) Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке: " + стрРасчетДоставки.НомерСтроки + " не совпадают фактические и расчетные значения!", Объект.Ссылка, "РасчетДоставкиПлатаЗаДоставку", "РасчетДоставки.ПлатаЗаДоставку");
			Сообщить("Выполните передачу данных в документы");
		КонецЕсли;
		Если стрРасчетДоставки.Компенсация <> стрРасчетДоставки.КомпенсацияИзНаценки Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В строке: " + стрРасчетДоставки.НомерСтроки + " не совпадают фактические и расчетные значения!", Объект.Ссылка, "РасчетДоставкиКомпенсацияИзНаценки", "РасчетДоставки.КомпенсацияИзНаценки");
			Сообщить("Выполните передачу данных в документы");
			Отказ = Истина;
		КонецЕсли;
	КонецЦикла; 
	
КонецПроцедуры 

#КонецОбласти

#Область ЗатратыНовое


Процедура СформироватьЗатраты(Объект, Отказ) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ЗначениеЗаполнено(Объект.Автомобиль) Тогда
		ОбщегоНазначения.СообщитьПользователю("Не заполнен автомобиль", Объект.Ссылка, "Автомобиль");
		Возврат;
	КонецЕсли;
	
	ПроцентТранспортных = Константы.ПроцентСкладскогоОбслуживания.Получить();
	Если ТипЗнч(Объект.Автомобиль) = Тип("СправочникСсылка.ТранспортныеСредства") И ЗначениеЗаполнено(Объект.Автомобиль.СтатьяРасходов) Тогда
		СтатьяРасходовТранспорт= Объект.Автомобиль.СтатьяРасходов;
	Иначе
		СтатьяРасходовТранспорт= ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Доставка на филиалы - Сторонний автотранспорт", Истина)
	КонецЕсли;
	СтатьяРасходовСклад = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Доставка на филиалы - Складское обслуживание (3%)", Истина);
	СтатьяАктивовИПассивов =  ПланыВидовХарактеристик.СтатьиАктивовПассивов.НайтиПоНаименованию("ТЗР по перемещениям на филиалы", Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсОснования.Документ КАК Документ
		|ПОМЕСТИТЬ ВТ_Заказы
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейсОснования.Ссылка = &Рейс
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Заказы.Документ КАК ЗаказНаДоставку,
		|	ЗаказНаДоставку.СтоимостьДоставкиСНДС КАК СтоимостьДоставки,
		|	ЗаказНаДоставкуКлиентуОснования.Документ КАК Перемещение
		|ПОМЕСТИТЬ ВнутренняяДоставка
		|ИЗ
		|	ВТ_Заказы КАК ВТ_Заказы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставку
		|		ПО ВТ_Заказы.Документ = ЗаказНаДоставку.Ссылка
		|			И (ЗаказНаДоставку.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Внутренняя))
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|		ПО ВТ_Заказы.Документ = ЗаказНаДоставкуКлиентуОснования.Ссылка
		|			И (ЗаказНаДоставкуКлиентуОснования.Документ ССЫЛКА Документ.ПеремещениеТоваров)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ШапкаПрочиеРасходы._ДокументОснование КАК ДокументОснование,
		|	ВнутренняяДоставка.Перемещение КАК Перемещение,
		|	Максимум(ЕСТЬNULL(ПрочиеРасходыАналитика.Ссылка, ЗНАЧЕНИЕ(Документ.ПрочиеДоходыРасходы.ПустаяСсылка))) КАК ДокРасходов,   
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВсеРасходы.НомерСтроки) КАК КоличествоСтрок
		|ПОМЕСТИТЬ ВТ_РегистрацияРасходов
		|ИЗ
		|	Документ.ПрочиеДоходыРасходы.ПрочиеРасходы КАК ПрочиеРасходыАналитика
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПрочиеДоходыРасходы КАК ШапкаПрочиеРасходы
		|		ПО ПрочиеРасходыАналитика.Ссылка = ШапкаПрочиеРасходы.Ссылка
		|			И (ШапкаПрочиеРасходы._ДокументОснование = &Рейс)
		|		ПРАВОЕ СОЕДИНЕНИЕ ВнутренняяДоставка КАК ВнутренняяДоставка
		|		ПО (ВнутренняяДоставка.Перемещение = ПрочиеРасходыАналитика.АналитикаРасходов)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПрочиеДоходыРасходы.ПрочиеРасходы КАК ВсеРасходы
		|		ПО ПрочиеРасходыАналитика.Ссылка = ВсеРасходы.Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ШапкаПрочиеРасходы._ДокументОснование,
		|	ВнутренняяДоставка.Перемещение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПрочиеДоходыРасходы.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПрочиеДоходыРасходы КАК ПрочиеДоходыРасходы
		|ГДЕ
		|	ПрочиеДоходыРасходы._ДокументОснование = &Рейс
		|	И НЕ ПрочиеДоходыРасходы.ПометкаУдаления
		|	И НЕ ПрочиеДоходыРасходы.Ссылка В
		|				(ВЫБРАТЬ
		|					Расходы.ДокРасходов
		|				ИЗ
		|					ВТ_РегистрацияРасходов КАК Расходы)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнутренняяДоставка.ЗаказНаДоставку КАК ЗаказНаДоставку,
		|	ВнутренняяДоставка.СтоимостьДоставки КАК СтоимостьДоставки,
		|	СебестоимостьТоваров.Регистратор КАК Перемещение,
		|	ВТ_РегистрацияРасходов.ДокРасходов КАК ПрочиеРасходы,
		|	ЕСТЬNULL(ВТ_РегистрацияРасходов.КоличествоСтрок, 0) КАК КоличествоСтрок,
		|	СУММА(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) КАК Себестоимость
		|ИЗ
		|	ВнутренняяДоставка КАК ВнутренняяДоставка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
		|		ПО (СебестоимостьТоваров.Регистратор = ВнутренняяДоставка.Перемещение)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_РегистрацияРасходов КАК ВТ_РегистрацияРасходов
		|		ПО ВнутренняяДоставка.Перемещение = ВТ_РегистрацияРасходов.Перемещение
		|ГДЕ
		|	СебестоимостьТоваров.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВнутренняяДоставка.ЗаказНаДоставку,
		|	ВнутренняяДоставка.СтоимостьДоставки,
		|	СебестоимостьТоваров.Регистратор,
		|	ВТ_РегистрацияРасходов.ДокРасходов,
		|	ВТ_РегистрацияРасходов.КоличествоСтрок
		|ИТОГИ ПО
		|	ЗаказНаДоставку";
	Запрос.УстановитьПараметр("Рейс", Объект.Ссылка);
	
	Результаты = Запрос.ВыполнитьПакет();
	МаксИндекс = Результаты.ВГраница();
	ВыборкаЗаказНаДоставку = Результаты[МаксИндекс].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаЗаказНаДоставку.Следующий() Цикл
		
		СуммаСебестоимость = ВыборкаЗаказНаДоставку.Себестоимость;
		Если СуммаСебестоимость <> 0 Тогда 
			СуммаРасходовПоДокументам = 0;
			
			ВыборкаДетальныеЗаписи = ВыборкаЗаказНаДоставку.Выбрать();
		
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ПрочиеРасходы) Тогда 
					Если ВыборкаДетальныеЗаписи.КоличествоСтрок = 2 Тогда  
						НовыйДокумент = ВыборкаДетальныеЗаписи.ПрочиеРасходы.ПолучитьОбъект();
					Иначе
						СтарыйДокумент = ВыборкаДетальныеЗаписи.ПрочиеРасходы.ПолучитьОбъект();
						Если НЕ СтарыйДокумент.ПометкаУдаления Тогда
							СтарыйДокумент.ПрочиеРасходы.Очистить();  	
							СтарыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
							СтарыйДокумент.УстановитьПометкуУдаления(Истина);
						КонецЕсли;
						НовыйДокумент= Документы.ПрочиеДоходыРасходы.СоздатьДокумент();
					КонецЕсли;
				Иначе
					НовыйДокумент= Документы.ПрочиеДоходыРасходы.СоздатьДокумент();
				КонецЕсли;
				
				
				ЗаполнитьДокументЗатрат(НовыйДокумент, ВыборкаДетальныеЗаписи.Перемещение, ВыборкаДетальныеЗаписи.ЗаказНаДоставку, Объект.Ссылка);
				
				Коэффициент = ВыборкаДетальныеЗаписи.СтоимостьДоставки/СуммаСебестоимость;
				НоваяСтрока = НовыйДокумент.ПрочиеРасходы.Добавить();
				НоваяСтрока.СтатьяРасходов = СтатьяРасходовТранспорт;
				НоваяСтрока.АналитикаРасходов = ВыборкаДетальныеЗаписи.Перемещение;
				НоваяСтрока.Сумма = Окр(Коэффициент*ВыборкаДетальныеЗаписи.Себестоимость,2);
				НоваяСтрока.Подразделение = ВыборкаДетальныеЗаписи.Перемещение.СкладОтправитель.Подразделение;
				НоваяСтрока.СтатьяАктивовПассивов = СтатьяАктивовИПассивов;
				НоваяСтрока.АналитикаАктивовПассивов =ВыборкаДетальныеЗаписи.Перемещение.СкладПолучатель.Подразделение;
				
				СуммаРасходовПоДокументам = СуммаРасходовПоДокументам + НоваяСтрока.Сумма;
				
				НоваяСтрока = НовыйДокумент.ПрочиеРасходы.Добавить();
				НоваяСтрока.СтатьяРасходов = СтатьяРасходовСклад;
				НоваяСтрока.АналитикаРасходов = ВыборкаДетальныеЗаписи.Перемещение;
				НоваяСтрока.Сумма = Окр((ПроцентТранспортных*ВыборкаДетальныеЗаписи.Себестоимость)/100,2);
				НоваяСтрока.Подразделение = ВыборкаДетальныеЗаписи.Перемещение.СкладОтправитель.Подразделение;
				НоваяСтрока.СтатьяАктивовПассивов = СтатьяАктивовИПассивов;
				НоваяСтрока.АналитикаАктивовПассивов =ВыборкаДетальныеЗаписи.Перемещение.СкладПолучатель.Подразделение; 
				
				Если НовыйДокумент.ПрочиеРасходы.Количество() > 0 Тогда
				
					НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
					АльтерраОбщегоНазначения.СообщитьПользователю(НовыйДокумент.Ссылка, "Создан/Изменен : "+НовыйДокумент.Ссылка);
					
				Иначе
					НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
					НовыйДокумент.УстановитьПометкуУдаления(Истина);
			    КонецЕсли;
				
				ПоследнийДокумент = НовыйДокумент.Ссылка;
			КонецЦикла;
			Если ВыборкаЗаказНаДоставку.ЗаказНаДоставку.СтоимостьДоставкиСНДС <> СуммаРасходовПоДокументам Тогда
				Если ЗначениеЗаполнено(ПоследнийДокумент)Тогда
					Док = ПоследнийДокумент.ПолучитьОбъект();
					НоваяСтрока = Док.ПрочиеРасходы[0];
					НоваяСтрока.Сумма = НоваяСтрока.Сумма + (ВыборкаЗаказНаДоставку.ЗаказНаДоставку.СтоимостьДоставкиСНДС - СуммаРасходовПоДокументам);
					Док.Записать(РежимЗаписиДокумента.Проведение);
				Иначе
					ОбщегоНазначения.СообщитьПользователю("Не распределено расходов на сумму " + Строка(ВыборкаЗаказНаДоставку.ЗаказНаДоставку.СтоимостьДоставкиСНДС - СуммаРасходовПоДокументам));
				КонецЕсли;
			КонецЕсли;
		Иначе
			ОбщегоНазначения.СообщитьПользователю("Не расчитана себестоимость по товарам. Создать затраты невозможно.");
		КонецЕсли;
		
	КонецЦикла;
	
	ВыборкаНеобработанныеРасходы = Результаты[МаксИндекс-1].Выбрать();
	
	Пока ВыборкаНеобработанныеРасходы.Следующий() Цикл
		ДокОбъект = ВыборкаНеобработанныеРасходы.Ссылка.ПолучитьОбъект();
		ДокОбъект.УстановитьПометкуУдаления(Истина);
	КонецЦикла;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры   

Процедура ЗаполнитьДокументЗатрат(ДокументРасходов, Перемещение, ЗаказНаДоставку, Рейс)
	ДокументРасходов.ПометкаУдаления = Ложь;
	ДокументРасходов.Дата = Перемещение.Дата+1;
	ДокументРасходов._ДокументОснование= Рейс.Ссылка;
	ДокументРасходов.Организация= ЗаказНаДоставку.Организация;
	ДокументРасходов.Ответственный= Пользователи.ТекущийПользователь();
	ДокументРасходов.ХозяйственнаяОперация= Перечисления.ХозяйственныеОперации.ПрочиеРасходы;
	ДокументРасходов.РаспределитьРасходыУпр= Ложь;
	ДокументРасходов.Валюта= Константы.ВалютаРегламентированногоУчета.Получить();	
	ДокументРасходов.ПрочиеРасходы.Очистить();
КонецПроцедуры

Процедура УдалитьДокументЗатрат(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПрочиеДоходыРасходы.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПрочиеДоходыРасходы КАК ПрочиеДоходыРасходы
		|ГДЕ
		|	ПрочиеДоходыРасходы._ДокументОснование = &Рейс
		|	И НЕ ПрочиеДоходыРасходы.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Рейс", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Документ = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		Документ.УстановитьПометкуУдаления(Истина);
		АльтерраОбщегоНазначения.СообщитьПользователю(Документ.Ссылка, "Удален: " + Документ.Ссылка);
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры


#КонецОбласти

#Область Затраты 

Процедура СформироватьЗатратыСтар(Объект, Отказ) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ЗначениеЗаполнено(Объект.Автомобиль) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен автомобиль", Объект.Ссылка, "Автомобиль");
		Возврат;
	КонецЕсли;
	
	ПроцентТранспортных = Константы.ПроцентСкладскогоОбслуживания.Получить();
	Если ТипЗнч(Объект.Автомобиль) = Тип("СправочникСсылка.ТранспортныеСредства") И ЗначениеЗаполнено(Объект.Автомобиль.СтатьяРасходов) Тогда
		СтатьяРасходовТранспорт= Объект.Автомобиль.СтатьяРасходов;
	Иначе
		СтатьяРасходовТранспорт= ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Доставка на филиалы - Сторонний автотранспорт", Истина)
	КонецЕсли;
	СтатьяРасходовСклад = ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Доставка на филиалы - Складское обслуживание (3%)", Истина);
	СтатьяАктивовИПассивов =  ПланыВидовХарактеристик.СтатьиАктивовПассивов.НайтиПоНаименованию("ТЗР по перемещениям на филиалы", Истина);
	
	мЗаказов= ПолучитьЗаказыДляЗатрат(Объект);
	
	Для Каждого стрДанные Из мЗаказов Цикл
		
		ДокСсылка= ПолучитьДокументЗатрат(Объект.Ссылка, стрДанные.Организация);
		Если ЗначениеЗаполнено(ДокСсылка) Тогда
			НовыйДокумент= ДокСсылка.ПолучитьОбъект();
			НовыйДокумент.УстановитьПометкуУдаления(Ложь);
		Иначе
			НовыйДокумент= Документы.ПрочиеДоходыРасходы.СоздатьДокумент();
			НовыйДокумент.Дата = ТекущаяДата();
		КонецЕсли;
		
		НовыйДокумент._ДокументОснование= Объект.Ссылка;
		НовыйДокумент.Организация= стрДанные.Организация;
		НовыйДокумент.Ответственный= Пользователи.ТекущийПользователь();
		НовыйДокумент.ХозяйственнаяОперация= Перечисления.ХозяйственныеОперации.ПрочиеРасходы;
		НовыйДокумент.РаспределитьРасходыУпр= Ложь;
		НовыйДокумент.Валюта= Константы.ВалютаРегламентированногоУчета.Получить();
		
		НовыйДокумент.ПрочиеРасходы.Очистить();
		
		Для каждого стрЗаказ из стрДанные.мДокументов Цикл
			
			ТЗСебестоимость = ПолучитьСебестоимостьПоДокументамПродажи(стрЗаказ);
			
			Если ТЗСебестоимость.Количество() > 0 И ТЗСебестоимость.Итог("СуммаДокумента") > 0 Тогда
				
				СуммаСебестоимость = ТЗСебестоимость.Итог("СуммаДокумента");
				СтоимостьДоставки = стрЗаказ.СтоимостьДоставкиСНДС;
				
				Коэффициент = СтоимостьДоставки / СуммаСебестоимость;
				
				НомерДокумента=0;
				СуммаРасходовПоДокументам = 0;
				Для каждого стрДокумент из ТЗСебестоимость Цикл
					НоваяСтрока = НовыйДокумент.ПрочиеРасходы.Добавить();
					НоваяСтрока.СтатьяРасходов = СтатьяРасходовТранспорт;
					НоваяСтрока.АналитикаРасходов = стрДокумент.Документ;
					НоваяСтрока.Сумма = Окр(Коэффициент*стрДокумент.СуммаДокумента,2);
					НоваяСтрока.Подразделение = стрДокумент.Документ.СкладОтправитель.Подразделение;
					НоваяСтрока.СтатьяАктивовПассивов = СтатьяАктивовИПассивов;
					НоваяСтрока.АналитикаАктивовПассивов =стрДокумент.Документ.СкладПолучатель.Подразделение;
					
					СуммаРасходовПоДокументам = СуммаРасходовПоДокументам + НоваяСтрока.Сумма;
					
					НомерДокумента = НомерДокумента + 1;
					Если НомерДокумента = ТЗСебестоимость.Количество() Тогда
						НоваяСтрока.Сумма = НоваяСтрока.Сумма + (СтоимостьДоставки - СуммаРасходовПоДокументам);
					КонецЕсли;
				КонецЦикла;
				
				Для каждого стрДокумент из ТЗСебестоимость Цикл
					НоваяСтрока = НовыйДокумент.ПрочиеРасходы.Добавить();
					НоваяСтрока.СтатьяРасходов = СтатьяРасходовСклад;
					НоваяСтрока.АналитикаРасходов = стрДокумент.Документ;
					НоваяСтрока.Сумма = Окр((ПроцентТранспортных*стрДокумент.СуммаДокумента)/100,2);
					НоваяСтрока.Подразделение = стрДокумент.Документ.СкладОтправитель.Подразделение;
					НоваяСтрока.СтатьяАктивовПассивов = СтатьяАктивовИПассивов;
					НоваяСтрока.АналитикаАктивовПассивов =стрДокумент.Документ.СкладПолучатель.Подразделение;
				КонецЦикла;
			Иначе
				Сообщить("Не расчитана себестоимость по товарам. Создать затраты невозможно.");
			КонецЕсли;
			
		КонецЦикла;
		
		Если НовыйДокумент.ПрочиеРасходы.Количество() > 0 Тогда
			
			НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
			АльтерраОбщегоНазначения.СообщитьПользователю(НовыйДокумент.Ссылка, "Создан: "+НовыйДокумент.Ссылка);
			
		Иначе
			НовыйДокумент.Записать(РежимЗаписиДокумента.Проведение);
			НовыйДокумент.УстановитьПометкуУдаления(Истина);
	    КонецЕсли;
	
	КонецЦикла;

	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Функция ПолучитьЗатраты(Объект, ЗаказыНаДоставку)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) КАК СтоимостьВсего
		|ПОМЕСТИТЬ Всего_Сумма
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
		|ГДЕ
		|	СебестоимостьТоваров.Регистратор В(&ДокументыПродажи)
		|	И СебестоимостьТоваров.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	&СтатьяРасходовТранспорт КАК СтатьяРасходов,
		|	СебестоимостьТоваров.Регистратор КАК АналитикаРасходов,
		|	ВЫРАЗИТЬ(&СуммаРаспределения * (СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) / Всего_Сумма.СтоимостьВсего КАК ЧИСЛО(15, 2)) КАК СУММА,
		|	СебестоимостьТоваров.Регистратор.СкладОтправитель.Подразделение КАК Подразделение,
		|	&СтатьяАктивовИПассивов КАК СтатьяАктивовПассивов,
		|	СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы КАК СуммаДокумента,
		|	СебестоимостьТоваров.Регистратор.СкладПолучатель.Подразделение КАК АналитикаАктивовПассивов
		|ПОМЕСТИТЬ Результат1
		|ИЗ
		|	Всего_Сумма КАК Всего_Сумма,
		|	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
		|ГДЕ
		|	СебестоимостьТоваров.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И СебестоимостьТоваров.Регистратор В(&ДокументыПродажи)
		|	И (ВЫРАЗИТЬ(&СуммаРаспределения * (СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) / Всего_Сумма.СтоимостьВсего КАК ЧИСЛО(15, 2))) <> 0
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	&СтатьяРасходовСклад,
		|	СебестоимостьТоваров.Регистратор,
		|	ВЫРАЗИТЬ((СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) * &ПроцентТранспортных / 100 КАК ЧИСЛО(15, 2)),
		|	СебестоимостьТоваров.Регистратор.СкладОтправитель.Подразделение,
		|	&СтатьяАктивовИПассивов,
		|	СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы,
		|	СебестоимостьТоваров.Регистратор.СкладПолучатель.Подразделение
		|ИЗ
		|	Всего_Сумма КАК Всего_Сумма,
		|	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
		|ГДЕ
		|	СебестоимостьТоваров.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И СебестоимостьТоваров.Регистратор В(&ДокументыПродажи)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Результат1.СтатьяРасходов КАК СтатьяРасходов,
		|	Результат1.АналитикаРасходов КАК АналитикаРасходов,
		|	СУММА(Результат1.СУММА) КАК Сумма,
		|	Результат1.Подразделение КАК Подразделение,
		|	Результат1.СтатьяАктивовПассивов КАК СтатьяАктивовПассивов,
		|	СУММА(Результат1.СуммаДокумента) КАК СуммаДокумента,
		|	Результат1.АналитикаАктивовПассивов КАК АналитикаАктивовПассивов
		|ИЗ
		|	Результат1 КАК Результат1
		|
		|СГРУППИРОВАТЬ ПО
		|	Результат1.СтатьяРасходов,
		|	Результат1.АналитикаРасходов,
		|	Результат1.Подразделение,
		|	Результат1.СтатьяАктивовПассивов,
		|	Результат1.АналитикаАктивовПассивов";
	
	
	Запрос.УстановитьПараметр("ДокументыПродажи", ПолучитьДокументыПеремещения(ЗаказыНаДоставку));
	Запрос.УстановитьПараметр("ПроцентТранспортных", Константы.ПроцентСкладскогоОбслуживания.Получить());
	
	Если ТипЗнч(Объект.Автомобиль) = Тип("СправочникСсылка.ТранспортныеСредства") И ЗначениеЗаполнено(Объект.Автомобиль.СтатьяРасходов) Тогда
		СтатьяРасходовТранспорт= Объект.Автомобиль.СтатьяРасходов;
	Иначе
		СтатьяРасходовТранспорт= ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Доставка на филиалы - Сторонний автотранспорт", Истина)
	КонецЕсли;
	Запрос.УстановитьПараметр("СтатьяРасходовТранспорт", СтатьяРасходовТранспорт);
	Запрос.УстановитьПараметр("СтатьяРасходовСклад",ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоНаименованию("Доставка на филиалы - Складское обслуживание (3%)", Истина));
	Запрос.УстановитьПараметр("СтатьяАктивовИПассивов", ПланыВидовХарактеристик.СтатьиАктивовПассивов.НайтиПоНаименованию("ТЗР по перемещениям на филиалы", Истина));
	Запрос.УстановитьПараметр("СуммаРаспределения", ПолучитьСуммаРаспределения(Объект));

	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ;
	
КонецФункции

Функция ПолучитьСуммаРаспределения(Объект)
	
	СтавкаНДС = УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата);
	СтавкаНДСЧислом = ЦенообразованиеКлиентСервер.ПолучитьСтавкуНДСЧислом(СтавкаНДС) / 100 + 1;
	СуммаРаспределения = 0;
	Для Каждого стрОснование Из Объект.Основания Цикл
		Если стрОснование.Документ.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
			СуммаРаспределения = СуммаРаспределения+стрОснование.Документ.СтоимостьДОставки+стрОснование.Документ.СтоимостьДОставкиСНДС+Объект.КорректировкаКомпенсации+Объект.КорректировкаКомпенсацииСНДС*СтавкаНДСЧислом;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СуммаРаспределения;
	
КонецФункции

Функция ПолучитьДокументЗатрат(Основание, Организация) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрочиеДоходыРасходы.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПрочиеДоходыРасходы КАК ПрочиеДоходыРасходы
	|ГДЕ
	|	ПрочиеДоходыРасходы._ДокументОснование = &_ДокументОснование
	|	И ПрочиеДоходыРасходы.Организация = &Организация";
	
	Запрос.УстановитьПараметр("_ДокументОснование", Основание);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;
	
	Возврат Неопределено; 
	
КонецФункции

Процедура УдалитьДокументЗатратСтар(Объект) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	мЗаказов = ПолучитьЗаказыДляЗатрат(Объект);
	Для Каждого стрДанные Из мЗаказов Цикл
		
		ДокСсылка = ПолучитьДокументЗатрат(Объект.Ссылка, стрДанные.Организация);
		Если ЗначениеЗаполнено(ДокСсылка) Тогда
			Документ = ДокСсылка.ПолучитьОбъект();
			Документ.УстановитьПометкуУдаления(Истина);
			АльтерраОбщегоНазначения.СообщитьПользователю(Документ.Ссылка, "Удален: " + Документ.Ссылка);
		КонецЕсли;
	КонецЦикла;

	УстановитьПривилегированныйРежим(Ложь);  
	
КонецПроцедуры

Функция ПолучитьЗаказыДляЗатрат(Объект)
	
	мДанные= Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаданиеНаПеревозкуРейсОснования.Документ КАК Документ
	|ПОМЕСТИТЬ ВТ_Заказы
	|ИЗ
	|	&Основания КАК ЗаданиеНаПеревозкуРейсОснования
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Заказы.Документ КАК ЗаказНаДоставку,
	|	ВТ_Заказы.Документ.Организация КАК Организация
	|ИЗ
	|	ВТ_Заказы КАК ВТ_Заказы
	|ИТОГИ ПО
	|	Организация";
	
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаОрганизация = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаОрганизация.Следующий() Цикл
		Рез= Новый Структура;
		Рез.Вставить("Организация", ВыборкаОрганизация.Организация);
		
		мДокументов= Новый Массив;
		ВыборкаДетальныеЗаписи = ВыборкаОрганизация.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			мДокументов.Добавить(ВыборкаДетальныеЗаписи.ЗаказНаДоставку);
		КонецЦикла;
		Рез.Вставить("мДокументов", мДокументов);
		
		мДанные.Добавить(Рез);
	КонецЦикла;
	
	Возврат мДанные;  
	
КонецФункции

Функция ПолучитьСебестоимостьПоДокументамПродажи(ЗаказыНаДоставку)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СебестоимостьТоваров.Регистратор КАК Документ,
		|	СУММА(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы) КАК СуммаДокумента
		|ИЗ
		|	РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
		|ГДЕ
		|	СебестоимостьТоваров.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход)
		|	И СебестоимостьТоваров.Регистратор В(&ДокументыПродажи)
		|
		|СГРУППИРОВАТЬ ПО
		|	СебестоимостьТоваров.Регистратор";
	
	Запрос.УстановитьПараметр("ДокументыПродажи", ПолучитьДокументыПеремещения(ЗаказыНаДоставку));
		
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ;

КонецФункции 

#КонецОбласти

#Область Экспортные

Функция ПроверитьНачальныйЭтапРейса(Статус) Экспорт
	
	Если Не ЗначениеЗаполнено(Статус) ИЛИ
		Статус = Перечисления.СтатусыРейсов.ПредварительнаяКомплектация ИЛИ
		Статус = Перечисления.СтатусыРейсов.РейсСогласованПоискТС ИЛИ
		Статус = Перечисления.СтатусыРейсов.ДокументыНаПогрузкуГотовы
		Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли; 
	
КонецФункции 

Функция ПолучитьмЗаказовПоКоторымНетРейсов() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаданиеНаПеревозкуРейсОснования.Документ КАК Документ
	|ПОМЕСТИТЬ ЗаказыНаДоставку
	|ИЗ
	|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
	|ГДЕ
	|	ЗаданиеНаПеревозкуРейсОснования.Ссылка.ПометкаУдаления = ЛОЖЬ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказНаДоставкуКлиенту.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
	|ГДЕ
	|	НЕ ЗаказНаДоставкуКлиенту.Ссылка В
	|				(ВЫБРАТЬ
	|					ЗаказыНаДоставку.Документ
	|				ИЗ
	|					ЗаказыНаДоставку КАК ЗаказыНаДоставку)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ = РезультатЗапроса.Выгрузить();
	мЗаказов = ТЗ.ВыгрузитьКолонку("Ссылка");
	
	Возврат мЗаказов; 
	
