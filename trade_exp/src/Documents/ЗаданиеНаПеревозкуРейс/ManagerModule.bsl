Процедура СнятьСогласование(ДокументПродажи) Экспорт
	
	Если ЗначениеЗаполнено(ДокументПродажи) Тогда
		Рейс = ПолучитьРейсПоДокументуПродажи(ДокументПродажи);
		Если ЗначениеЗаполнено(Рейс) Тогда
			Если Рейс.Согласован Тогда
				РейсОбъект = Рейс.ПолучитьОбъект();
				РейсОбъект.Согласован= Ложь;
				РейсОбъект.Записать();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В "+Рейс+" снято согласование", Рейс);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли; 
	
