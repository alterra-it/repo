Процедура ПересчитатьОплатуСУчетомРазгрузки(Объект,МаксимальнаяСтоимостьБезНДС=Ложь) Экспорт 
	
	РасчетРазгрузки = УправлениеЛогистикойСервер.РасчетРазгрузкиДействуетНаДату(Объект.Дата);
	СтавкаНДСЧислом= ЦенообразованиеКлиентСервер.ПолучитьСтавкуНДСЧислом(УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата))/100+1;
	
	Если Объект.РазгрузкаСиламиВодителя Тогда
		Если РасчетРазгрузки Тогда
			
			Объект.ОплатаВодителю = Объект.ОплатаВодителю + Объект.СтоимостьРазгрузокДляВодителя;
			Объект.ОплатаВодителюСНДС = Объект.ОплатаВодителюСНДС + Объект.СтоимостьРазгрузокДляВодителяСНДС;
			
			РазницаМеждуСтоимостьюКлиентаИВодителя = Объект.СтоимостьРазгрузокДляВодителя - Объект.СтоимостьРазгрузокДляКлиента;
			РазницаМеждуСтоимостьюКлиентаИВодителяСНДС = Объект.СтоимостьРазгрузокДляВодителяСНДС - Объект.СтоимостьРазгрузокДляКлиентаСНДС;
						
			Если МаксимальнаяСтоимостьБезНДС Тогда
				Объект.Компенсация = Объект.Компенсация + РазницаМеждуСтоимостьюКлиентаИВодителя;
				Объект.Вознаграждение = Объект.Вознаграждение + Объект.СтоимостьРазгрузок - Объект.СтоимостьРазгрузокДляВодителя + РазницаМеждуСтоимостьюКлиентаИВодителя;
			    Объект.ВознаграждениеСНДС = Объект.ВознаграждениеСНДС + Объект.СтоимостьРазгрузокСНДС/СтавкаНДСЧислом - Объект.СтоимостьРазгрузокДляВодителяСНДС; 
			Иначе
				Объект.Компенсация = РазницаМеждуСтоимостьюКлиентаИВодителя;	
				Объект.Вознаграждение = Объект.Вознаграждение + Объект.СтоимостьРазгрузок - Объект.СтоимостьРазгрузокДляВодителя + РазницаМеждуСтоимостьюКлиентаИВодителя;
			    Объект.ВознаграждениеСНДС = Объект.ВознаграждениеСНДС + Объект.СтоимостьРазгрузокСНДС/СтавкаНДСЧислом - Объект.СтоимостьРазгрузокДляВодителяСНДС; 
			КонецЕсли;	
			
			Объект.КомпенсацияСНДС = Объект.КомпенсацияСНДС + РазницаМеждуСтоимостьюКлиентаИВодителяСНДС;
		Иначе
			Объект.ОплатаВодителю = Объект.ОплатаВодителю + Объект.СтоимостьРазгрузок;
			Объект.ОплатаВодителюСНДС = Объект.ОплатаВодителюСНДС + Объект.СтоимостьРазгрузокСНДС/СтавкаНДСЧислом;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция ПроверитьДублированиеЗаказовНаДоставкуВДругихРейсах(Рейс) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка КАК Ссылка,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку КАК ЗаказНаДоставку
		|ПОМЕСТИТЬ ВТРейс
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
		|ГДЕ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка = &Рейс
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка КАК Ссылка,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку КАК ЗаказНаДоставку
		|ИЗ
		|	Документ.ЗаданиеНаПеревозкуРейс.РасчетДоставки КАК ЗаданиеНаПеревозкуРейсРасчетДоставки
		|ГДЕ
		|	НЕ ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка.ПометкаУдаления
		|	И ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку В
		|			(ВЫБРАТЬ
		|				ВТРейс.ЗаказНаДоставку
		|			ИЗ
		|				ВТРейс)
		|	И НЕ ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка В
		|				(ВЫБРАТЬ
		|					ВТРейс.Ссылка
		|				ИЗ
		|					ВТРейс)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.ЗаказНаДоставку,
		|	ЗаданиеНаПеревозкуРейсРасчетДоставки.Ссылка";  
	
	Запрос.УстановитьПараметр("Рейс", Рейс);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Ложь;
	Иначе
		Результат = Результат.Выбрать(); 
		Пока Результат.Следующий() Цикл
			ОбщегоНазначения.СообщитьПользователю("Заказ '" + Результат.ЗаказНаДоставку + "' присутствует в рейсе '" + Результат.Ссылка + "'", Результат.Ссылка);
		КонецЦикла;   
		Возврат Истина;
	КонецЕсли;
КонецФункции 

