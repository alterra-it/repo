#Область События 

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("ДоговорЗаявка") И ЗначениеЗаполнено(Параметры.ДоговорЗаявка) Тогда
		Договор = Параметры.ДоговорЗаявка;
		Партнер = Параметры.ДоговорЗаявка.ПеревозчикПартнер;
	КонецЕсли;
	Заказчики = "0";
	
	
КонецПроцедуры 

#КонецОбласти

#Область ФормированиеДоговоров  

&НаКлиенте
Процедура ПечатьДоговорЗаявка(Команда)
	
	Если ТипЗнч(Договор) = Тип("ДокументСсылка.РейсОтПоставщика") Тогда 
		МассивДанныхДляПечати = ПолучитьОбщиеДанныеНаСервереРейсОтПоставщика();
	ИначеЕсли ТипЗнч(Договор) = Тип("ДокументСсылка.ЗаданиеНаПеревозкуРейс") Тогда
		МассивДанныхДляПечати = ПолучитьОбщиеДанныеНаСервереЗаданиеНАПеревозкуРейс();
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю("Тип договора не определен!");
		Возврат;
	КонецЕсли;
		
	Макет = ПолучитьМакетСервер();
	
	
	
	Для каждого ДанныеДляПечати из МассивДанныхДляПечати Цикл 
		ВремФайл = ПолучитьИмяВременногоФайла("doc");
		Ворд = УправлениеПечатьюMSWordКлиент.ПолучитьМакетMSWord(Макет, ВремФайл);
		ActiveDocument = Ворд.COMСоединение.ActiveDocument;
		Для Каждого стрДанные Из ДанныеДляПечати Цикл
			ЗаменитьВWord(ActiveDocument, стрДанные.Ключ, стрДанные.Значение);
		КонецЦикла; 
		УправлениеПечатьюMSWordКлиент.ПоказатьДокументMSWord(Ворд); 
	КонецЦикла;
	
	  
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаменитьВWord(Object, Знач СтрокаПоиска, Знач СтрокаЗамены) Экспорт
	
	СтрокаПоиска = "{" + СтрокаПоиска + "}";
	Object.Select();
	Selection = Object.Application.Selection;
	
	FindObject = Selection.Find;
	FindObject.ClearFormatting();
	Пока FindObject.Execute(СтрокаПоиска) Цикл
		Если ПустаяСтрока(СтрокаЗамены) Тогда
			Selection.Delete();
		ИначеЕсли СтрокаПоиска = "{Рисунок}" Тогда
			Selection.Delete();
			ВременныйКаталог = КаталогВременныхФайлов();
#Если ВебКлиент Тогда
			ИмяВременногоФайла = ВременныйКаталог + Строка(Новый УникальныйИдентификатор) + ".tmp";
#Иначе
			ИмяВременногоФайла = ПолучитьИмяВременногоФайла("jpg");
#КонецЕсли
			
			ДвоичнаяКартинка = ДвоичныеДанныеФайла(СтрокаЗамены);
			Картинка = Новый Картинка(ДвоичнаяКартинка);
			Картинка.Записать(ИмяВременногоФайла);
			КартинкаВДокументе = Selection.Range.InlineShapes.AddPicture(ИмяВременногоФайла);
			Фигура = КартинкаВДокументе.ConvertToShape();
			Фигура.ZOrder(5);  //ZOrder = 5 - картинка находится под текстом
			Попытка
				УдалитьФайлы(ИмяВременногоФайла);
			Исключение
				
			КонецПопытки;
		Иначе 
			СтрокаЗамены = Строка(СтрокаЗамены);
			Selection.TypeText(СтрокаЗамены);
		КонецЕсли;
	КонецЦикла;
	
	Selection.Collapse();	
КонецПроцедуры

&НаСервере
Функция ДвоичныеДанныеФайла(Рисунок) 
	возврат РаботаСФайлами.ДвоичныеДанныеФайла(Рисунок);	
КонецФункции

#КонецОбласти


#Область ПолучитьДанные

&НаСервере
Функция ПолучитьОбщиеДанныеНаСервереРейсОтПоставщика()
	
	МассивДанных = Новый Массив;
	Данные = Новый Структура;

	Запрос = Новый Запрос; 
	Запрос.Текст =
	"ВЫБРАТЬ
	|	РейсОтПоставщика.Номер КАК Номер,
	|	РейсОтПоставщика.Дата КАК Дата,
	|	РейсОтПоставщика.Водитель КАК Водитель,
	|	РейсОтПоставщика.Водитель.ДатаРождения КАК ВодительДатаРождения,
	|	РейсОтПоставщика.Автомобиль.Наименование КАК Автомобиль,
	|	РейсОтПоставщика.Автомобиль.ГосударственныйНомерПрицепа КАК ГосНомерПрицеп,
	|	РейсОтПоставщика.Автор КАК Менеджер,
	|	РейсОтПоставщика.ДатаПрибытияНаСклад КАК ДатаПрибытияНаСклад,
	|	РейсОтПоставщика.Перевозчик КАК Перевозчик,
	|	РейсОтПоставщика.ПеревозчикПартнер КАК ПеревозчикПартнер,
	|	РейсОтПоставщика.Вес КАК Масса,
	|	РейсОтПоставщика.Объем КАК Объем,
	|	РейсОтПоставщика.МаксимальнаяДлина КАК Габариты,
	|	РейсОтПоставщика.ФактическаяСтоимостьДоставки КАК ВознаграждениеПеревозчика,
	|	РейсОтПоставщика.СтавкаНДС КАК НДС,
	|	РейсОтПоставщика.РасчетДоставки.(
	|		ЗаказНаДоставку КАК ЗаказНаДоставку
	|	) КАК РасчетДоставки,
	|	РейсОтПоставщикаРасчетДоставки.ДокументОснование.Номер как Пропуск,
	|	ЗаказНаДоставкуОтПоставщика.Ссылка КАК Ссылка,
	|	ЗаказНаДоставкуОтПоставщика.Номер КАК НомерЗаказа,
	|	ЗаказНаДоставкуОтПоставщика.Организация КАК Организация,
	|	ЗаказНаДоставкуОтПоставщика.АдресНаВыгрузке КАК АдресНаВыгрузке,
	|	ЗаказНаДоставкуОтПоставщика.ПрибытиеНаВыгрузку КАК ПрибытиеНаВыгрузку,
	|	ЗаказНаДоставкуОтПоставщика.ПрибытиеНаПогрузку КАК ПрибытиеНаПогрузку,
	|	ЗаказНаДоставкуОтПоставщика.АдресНаПогрузке КАК АдресНаПогрузке,
	|	ЗаказНаДоставкуОтПоставщика.ТелефонНаПогрузке КАК ТелефонНаПогрузке,
	|	ЗаказНаДоставкуОтПоставщика.ТелефонНаВыгрузке КАК ТелефонНаВыгрузке,
	|	ЗаказНаДоставкуОтПоставщика.Партнер КАК Партнер,
	|	ЗаказНаДоставкуОтПоставщика.НаименованиеГруза КАК НаименованиеГруза,
	|	//ЗаказНаДоставкуОтПоставщика.Организация.ОГРН КАК ОГРН,
	|	&КонтактноеЛицоОтПартнера КАК ПредставительПеревозчика
	|ИЗ
	|	Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика КАК РейсОтПоставщика
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
	|			ПО (РейсОтПоставщика.ПеревозчикПартнер = КонтактныеЛицаПартнеров.Владелец)
	|		ПО (РейсОтПоставщикаРасчетДоставки.Ссылка = РейсОтПоставщика.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуОтПоставщика КАК ЗаказНаДоставкуОтПоставщика
	|		ПО (РейсОтПоставщикаРасчетДоставки.ЗаказНаДоставку = ЗаказНаДоставкуОтПоставщика.Ссылка)
	|ГДЕ
	|	РейсОтПоставщика.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Договор);
	Запрос.УстановитьПараметр("КонтактноеЛицоОтПартнера", КонтактноеЛицоОтПартнера);
	Результат = Запрос.Выполнить();
	Выборка2 = Результат.Выбрать();
	Выборка2.Следующий();

	//запрос контактная информация водителя
	Запрос1 = Новый Запрос; 
	Запрос1.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ФизическиеЛицаКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
	|		ПОЛНОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|		ПО (ФизическиеЛицаКонтактнаяИнформация.Ссылка = ФизическиеЛица.Ссылка)
	|ГДЕ
	|	 ФизическиеЛица.Ссылка = &Водитель";
	
	Запрос1.УстановитьПараметр("Водитель", Выборка2.Водитель);
    Результат1 = Запрос1.Выполнить();
	Выборка1 = Результат1.Выбрать();
	Выборка1.Следующий(); 
	
	ЗапросАдресРазгрузка = Новый Запрос;
	ЗапросАдресРазгрузка.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаДоставкуОтПоставщика.АдресНаВыгрузке КАК АдресНаВыгрузке,
		|	МИНИМУМ(ЕСТЬNULL(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, ДАТАВРЕМЯ(1, 1, 1))) КАК МинВремя
		|ПОМЕСТИТЬ ВТ_МинВремя
		|ИЗ
		|	Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика КАК РейсОтПоставщика
		|		ПО РейсОтПоставщикаРасчетДоставки.Ссылка = РейсОтПоставщика.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних КАК ГрафикПоставокНаСкладСрезПоследних
		|		ПО (ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику = РейсОтПоставщикаРасчетДоставки.ДокументОснование)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуОтПоставщика КАК ЗаказНаДоставкуОтПоставщика
		|		ПО РейсОтПоставщикаРасчетДоставки.ЗаказНаДоставку = ЗаказНаДоставкуОтПоставщика.Ссылка
		|ГДЕ
		|	РейсОтПоставщика.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказНаДоставкуОтПоставщика.АдресНаВыгрузке
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_МинВремя.АдресНаВыгрузке КАК АдресНаВыгрузке,
		|	МАКСИМУМ(ЗаказНаДоставкуОтПоставщика.ТелефонНаВыгрузке) КАК ТелефонНаВыгрузке,
		|	МАКСИМУМ(РейсОтПоставщика.ДатаПрибытияНаСклад) КАК ПрибытиеНаВыгрузку,
		|	ВТ_МинВремя.МинВремя КАК НачалоРазгрузки,
		|	МАКСИМУМ(РейсОтПоставщикаРасчетДоставки.ДокументОснование.Номер) КАК Пропуск
		|ИЗ
		|	ВТ_МинВремя КАК ВТ_МинВремя
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика КАК РейсОтПоставщика
		|			ПО РейсОтПоставщикаРасчетДоставки.Ссылка = РейсОтПоставщика.Ссылка
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних КАК ГрафикПоставокНаСкладСрезПоследних
		|			ПО (ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику = РейсОтПоставщикаРасчетДоставки.ДокументОснование)
		|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуОтПоставщика КАК ЗаказНаДоставкуОтПоставщика
		|			ПО РейсОтПоставщикаРасчетДоставки.ЗаказНаДоставку = ЗаказНаДоставкуОтПоставщика.Ссылка
		|		ПО (ВТ_МинВремя.АдресНаВыгрузке = ЗаказНаДоставкуОтПоставщика.АдресНаВыгрузке)
		|			И (ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан = ВТ_МинВремя.МинВремя
		|				ИЛИ ВТ_МинВремя.МинВремя = ДАТАВРЕМЯ(1, 1, 1)
		|					И ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан ЕСТЬ NULL)
		|ГДЕ
		|	РейсОтПоставщика.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_МинВремя.АдресНаВыгрузке,
		|	ВТ_МинВремя.МинВремя";
	ЗапросАдресРазгрузка.УстановитьПараметр("Ссылка", Договор);
	РезультатЗапросаАдресРазгрузка = ЗапросАдресРазгрузка.Выполнить();
	Выборка3 = РезультатЗапросаАдресРазгрузка.Выбрать();

	ЗапросАдресПогрузка = Новый Запрос;
	ЗапросАдресПогрузка.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗаказНаДоставкуОтПоставщика.АдресНаПогрузке КАК АдресНаПогрузке,
		|	ЗаказНаДоставкуОтПоставщика.ТелефонНаПогрузке КАК ТелефонНаПогрузке,
		|	РейсОтПоставщика.НачалоВыполнения КАК ПрибытиеНаПогрузку,
		|	ЗаказНаДоставкуОтПоставщика.Партнер КАК Партнер
		|ИЗ
		|	Документ.РейсОтПоставщика.РасчетДоставки КАК РейсОтПоставщикаРасчетДоставки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика КАК РейсОтПоставщика
		|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
		|			ПО РейсОтПоставщика.ПеревозчикПартнер = КонтактныеЛицаПартнеров.Владелец
		|		ПО РейсОтПоставщикаРасчетДоставки.Ссылка = РейсОтПоставщика.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуОтПоставщика КАК ЗаказНаДоставкуОтПоставщика
		|		ПО РейсОтПоставщикаРасчетДоставки.ЗаказНаДоставку = ЗаказНаДоставкуОтПоставщика.Ссылка
		|ГДЕ
		|	РейсОтПоставщика.Ссылка = &Ссылка";
	
	ЗапросАдресПогрузка.УстановитьПараметр("Ссылка", Договор);
	РезультатЗапросаАдресПогрузка = ЗапросАдресПогрузка.Выполнить();
	Выборка4 = РезультатЗапросаАдресПогрузка.Выбрать();
		
	БанковскийСчет = неопределено;
	БанковскийСчетКонтрагента = неопределено;
	АдресРазгрузка = "";
	АдресПогрузка = ""; 
	Сч = 1;
	
	//Организация
	СведенияОбОрганизации= ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка2.Организация, Выборка2.Дата, , БанковскийСчет);

	//Партнер
	СведенияОПартнере= ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка2.Перевозчик, Договор.Дата, Истина, БанковскийСчетКонтрагента);
	ПаспортныеДанные= АльтерраОбщегоНазначения.ПолучитьПастпортныеДанные(Договор.Водитель);
	ПеревозчикКраткоеНаименование= СокрЛП(СтрЗаменить(Выборка2.Перевозчик, "ИП", ""));
	//Щапка договора
	Данные.Вставить("НомерДоговора", Выборка2.Номер);
	Данные.Вставить("ДатаДоговора", Формат(Выборка2.Дата, "ДФ=dd.MM.yyyy"));
	Данные.Вставить("Менеджер", Выборка2.Менеджер);
	Данные.Вставить("ТелефонМенеджер", УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(Выборка2.Менеджер, "Телефон", ",",)); 

	//Основная таблица
	//Данные.Вставить("Заказчик", Выборка2.Организация);
	Данные.Вставить("Перевозчик", Выборка2.Перевозчик);
	Данные.Вставить("Грузоотправитель", Выборка2.Организация); 
	Данные.Вставить("Грузополучатель", Выборка2.Организация);
	Данные.Вставить("НаименованиеГруза", Выборка2.НаименованиеГруза);
	Данные.Вставить("МассаГруза", Выборка2.Масса);
	Данные.Вставить("ОбъемГруза", Выборка2.Объем);
	Данные.Вставить("ГабаритыГруза", Выборка2.Габариты);
	Данные.Вставить("ТипКузова", ТипКузова);
	Данные.Вставить("ТипПогрузки", ТипПогрузки);
	Если Выборка2.НДС = Перечисления.СтавкиНДС.БезНДС Тогда 
		Данные.Вставить("ВознаграждениеПеревозчика", Выборка2.ВознаграждениеПеревозчика/1.22);
		Данные.Вставить("НДС", "Без НДС"); 
	Иначе
		Данные.Вставить("ВознаграждениеПеревозчика", Выборка2.ВознаграждениеПеревозчика);
		Данные.Вставить("НДС", "С НДС"); 
	КонецЕсли; 
	Данные.Вставить("МаркаТС", Выборка2.Автомобиль);
	Данные.Вставить("ГосНомерПрицеп", Выборка2.ГосНомерПрицеп);
	Данные.Вставить("Водитель", Выборка2.Водитель);
