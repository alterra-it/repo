		МассивОрганизаций.Добавить(Справочники.Организации.НайтиПоНаименованию("1СК"));
	ИначеЕсли Заказчики = "2" Тогда 
		МассивОрганизаций.Добавить(АльтерраОбщегоНазначения.ПолучитьАльтерра());
		МассивОрганизаций.Добавить(Справочники.Организации.НайтиПоНаименованию("1СК"));
		
	КонецЕсли;
	Для каждого организация из МассивОрганизаций Цикл
		ЗаполнитьДанныеПоОрганизации(Организация,Данные, МассивДанных);
	КонецЦикла;
	
	Возврат МассивДанных;
	
КонецФункции

&НаСервере
Процедура ЗаполнитьДанныеПоОрганизации(Организация, Данные, МассивДанных) 
	СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Организация, Договор.Дата, , Неопределено); 
	Рисунок = ОпределитьФаксимиле(Организация);
	
	Данные.Вставить("ЮрАдресЗаказчика", СведенияОбОрганизации.ЮридическийАдрес);
	Данные.Вставить("ИНН", СведенияОбОрганизации.ИНН);
	Данные.Вставить("КПП", СведенияОбОрганизации.КПП);
	Данные.Вставить("ОГРН", Организация.ОГРН);
	Данные.Вставить("Рисунок", Рисунок);
    Данные.Вставить("Заказчик", Организация);
	Данные.Вставить("ПредставительЗаказчика", Справочники.Сотрудники.НайтиПоНаименованию("Матюшев Сергей Борисович"));
	Если ТипЗнч(Договор) = Тип("ДокументСсылка.ЗаданиеНаПеревозкуРейс")   Тогда
		Данные.Вставить("Грузоотправитель", Организация);
	КонецЕсли;
	ДанныеКопия = Новый ФиксированнаяСтруктура(Данные); 
	МассивДанных.Добавить(ДанныеКопия);		
КонецПроцедуры

&НаСервере
Функция ОпределитьФаксимиле(Организация)
	 	
	Запрос = Новый Запрос;
	Запрос.Текст =	"ВЫБРАТЬ ПЕРВЫЕ 1
	              	|	ДополнительныеСведения.Объект КАК Объект,
	              	|	ДополнительныеСведения.Свойство КАК Свойство,
	              	|	ДополнительныеСведения.Значение КАК Значение
	              	|ИЗ
	              	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	              	|ГДЕ
	              	|	ДополнительныеСведения.Свойство.Наименование = &НаименованиеДопРеквизита
	              	|	И ДополнительныеСведения.Объект = &Объект";
	
	Запрос.УстановитьПараметр("Объект", Организация);
	Запрос.УстановитьПараметр("НаименованиеДопРеквизита", "ФаксимилеРейс");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Количество() = 0 Тогда
		Возврат Справочники.Файлы.ПустаяСсылка();
	КонецЕсли;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Значение
	КонецЦикла;
	
КонецФункции

#КонецОбласти

#Область Вспомогательные

Функция ТолькоНомер(ВхНомер)
	
	Рез = СокрЛП(ВхНомер);
    Ном = СтрДлина(Рез);
    Пока Ном > 0 Цикл
        Если Найти("0123456789", Сред(Рез,Ном,1)) = 0 Тогда
            прервать;
        Иначе
            Ном = Ном - 1;
        КонецЕсли; 
    КонецЦикла; 
    Возврат "" + Число(Сред(Рез,Ном+1));  
	
КонецФункции

&НаСервере
Функция ПолучитьМакетСервер()
	Возврат Документы.ЗаданиеНаПеревозкуРейс.ПолучитьМакет("ДоговорЗаявка");
КонецФункции 

