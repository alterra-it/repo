&После ("ДобавитьКомандыСозданияНаОсновании")
Процедура Док_ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры) Экспорт
	
	Документы.БлокировкаДвиженияТоваров.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании);
	
КонецПроцедуры

&После("ЗаполнитьПараметрыИнициализации")
Процедура Док_ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка)
	
	Запрос.УстановитьПараметр("ПериодОстатки",  Новый МоментВремени(ДокументСсылка.Дата,ДокументСсылка));
	
КонецПроцедуры

&Вместо("ТекстЗапросаТаблицаДвиженияСерийТоваров")
Функция Док_ТекстЗапросаТаблицаДвиженияСерийТоваров(Запрос, ТекстыЗапроса, Регистры)
	ИмяРегистра = "ДвиженияСерийТоваров";
	
	Если Не ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	Если НЕ ПроведениеДокументов.ЕстьТаблицаЗапроса("ВтТаблицаТовары", ТекстыЗапроса) Тогда
		ТекстЗапросаВтТаблицаТовары(Запрос, ТекстыЗапроса);
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ТаблицаТовары.Номенклатура КАК Номенклатура,
	|	ТаблицаТовары.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТаблицаТовары.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
	|			ТОГДА ТаблицаТовары.Назначение
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|	КОНЕЦ КАК Назначение,
	|	ТаблицаТовары.Серия КАК Серия,
	|	ТаблицаТовары.Количество КАК Количество,
	|	&Склад КАК Получатель,
	|	&Помещение КАК ПомещениеПолучателя,
	|	&Отправитель КАК Отправитель,
	|	&СкладскаяОперация КАК СкладскаяОперация,
	|	&Ссылка КАК Документ,
	|	&Период КАК Период,
	|	ИСТИНА КАК ЭтоСкладскоеДвижение
	|ИЗ
	|	ВтТаблицаТовары КАК ТаблицаТовары
	|ГДЕ
	|	ТаблицаТовары.Серия <> ЗНАЧЕНИЕ(Справочник.СерииНоменклатуры.ПустаяСсылка)";
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);  
	
	// + Альтерра
	ИмяРегистра = "БлокировкаДвиженияТоваров";
	
	ТекстЗапроса =
	"ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
		|	&Период КАК Период,
		|	&Склад КАК Склад,
		|	ТаблицаТовары.Номенклатура КАК Номенклатура,
		|	ТаблицаТовары.Характеристика КАК Характеристика,
		|	ВложенныйЗапрос.ПричинаБлокировки КАК ПричинаБлокировки,
		|	ВЫБОР
		|		КОГДА ТаблицаТовары.Количество > ВложенныйЗапрос.КоличествоПланКонечныйОстаток
		|			ТОГДА ВложенныйЗапрос.КоличествоПланКонечныйОстаток
		|		ИНАЧЕ ТаблицаТовары.Количество
		|	КОНЕЦ КАК Количество,
		|	ВЫБОР
		|		КОГДА ТаблицаТовары.Количество > ВложенныйЗапрос.КоличествоПланКонечныйОстаток
		|			ТОГДА -ВложенныйЗапрос.КоличествоПланКонечныйОстаток
		|		ИНАЧЕ -ТаблицаТовары.Количество
		|	КОНЕЦ КАК КоличествоПлан
		|ИЗ
		|	ВтТаблицаТовары КАК ТаблицаТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			БлокировкаДвиженияТоваровОстаткиИОбороты.Номенклатура КАК Номенклатура,
		|			БлокировкаДвиженияТоваровОстаткиИОбороты.Характеристика КАК Характеристика,
		|			БлокировкаДвиженияТоваровОстаткиИОбороты.ПричинаБлокировки КАК ПричинаБлокировки,
		|			БлокировкаДвиженияТоваровОстаткиИОбороты.КоличествоПланНачальныйОстаток КАК КоличествоПланНачальныйОстаток,
		|			БлокировкаДвиженияТоваровОстаткиИОбороты.КоличествоПланКонечныйОстаток КАК КоличествоПланКонечныйОстаток
		|		ИЗ
		|			РегистрНакопления.БлокировкаДвиженияТоваров.ОстаткиИОбороты(, &ПериодОстатки, Регистратор, , ) КАК БлокировкаДвиженияТоваровОстаткиИОбороты
		|		ГДЕ
		|			БлокировкаДвиженияТоваровОстаткиИОбороты.Регистратор.ДокументОснование = &Распоряжение) КАК ВложенныйЗапрос
		|		ПО (ВложенныйЗапрос.Номенклатура = ТаблицаТовары.Номенклатура)
		|			И (ВложенныйЗапрос.Характеристика = ТаблицаТовары.Характеристика)
		|ГДЕ
		|	&Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПриходныхОрдеров.Принят)
		|   И ВложенныйЗапрос.КоличествоПланКонечныйОстаток > 0
		|	И (ТаблицаТовары.Ссылка.Распоряжение ССЫЛКА Документ.ВозвратТоваровОтКлиента
		|			ИЛИ ТаблицаТовары.Ссылка.Распоряжение ССЫЛКА Документ.ПеремещениеТоваров
		|			ИЛИ ТаблицаТовары.Ссылка.Распоряжение ССЫЛКА Документ.КорректировкаРеализации)";
		
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	// -

	
	Возврат ТекстЗапроса;
КонецФункции

&После("ЗарегистрироватьУчетныеМеханизмы")
Процедура Док_ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента)
	МеханизмыДокумента.Добавить("БлокировкаДвиженияТоваров");   
	МеханизмыДокумента.Добавить("ДвижениеМаркированногоТовара"); 
	
КонецПроцедуры                            

&ИзменениеИКонтроль ("ДанныеДокументаДляПроведения")
Функция Док_ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ПриходныйОрдерНаТовары") Тогда
		ДокументОбъект = Документ;
		ДокументСсылка = Документ.Ссылка;
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ПриходныйОрдерНаТовары") Тогда
		ДокументОбъект = Документ.ПолучитьОбъект();
		ДокументСсылка = Документ;
	Иначе
		ДокументОбъект = Неопределено;
		ДокументСсылка = Неопределено;
	КонецЕсли;

	Запрос			= Новый Запрос;
	ТекстыЗапроса	= Новый СписокЗначений;
	
	ПолучитьДанныеДокумента(Запрос, ДокументСсылка);
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		
		ТекстЗапросаТаблицаДвиженияСерийТоваров(Запрос, ТекстыЗапроса, Регистры); 
		#Вставка 
		ТекстЗапросаТаблицаДвижениеМаркированногоТовара(Запрос, ТекстыЗапроса, Регистры, ДокументСсылка);
		#КонецВставки
		
	КонецЕсли;
	
	ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	ПринятьТоварНаСклад(Запрос, ТекстыЗапроса, Регистры);
	ЗарегистрироватьИзлишкиНедостачиНаСкладе(Запрос, ТекстыЗапроса, Регистры);
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	
КонецФункции


&После("ОтразитьРаспределениеЗапасовДвижения")
Процедура Док_ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект)
	
	Если НЕ ПроведениеДокументов.ЕстьТаблицаЗапроса("ВтТаблицаБлокировок", ТекстыЗапроса) Тогда
		ТекстЗапросаВтТаблицаБлокировок(Запрос, ТекстыЗапроса);
	КонецЕсли;
	
	ТекстЗапросаТабЧасть =
	"ВЫБРАТЬ
	|	ТабЧасть.Ссылка 		КАК Ссылка,
	|	&Период 				КАК Период,
	|	ТабЧасть.Номенклатура 	КАК Номенклатура,
	|	ТабЧасть.Характеристика КАК Характеристика,
	|	&Склад 					КАК Склад,
	|	ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)  	КАК Назначение,
	|	ВЫБОР
	|		КОГДА ТабЧасть.Количество > ВтТаблицаБлокировок.КоличествоПланКонечныйОстаток
	|			ТОГДА ВтТаблицаБлокировок.КоличествоПланКонечныйОстаток
	|		ИНАЧЕ ТабЧасть.Количество
	|	КОНЕЦ 					КАК Количество,
	|	НЕОПРЕДЕЛЕНО 			КАК ЗапланированныйРасходРаспределенногоЗапаса,
	|	ИСТИНА 					КАК КонтрольСвободногоОстатка,
	|	ЛОЖЬ 					КАК ИгнорироватьРезервыПриКонтролеОстатков
	|ИЗ
	|	Документ.ПриходныйОрдерНаТовары.Товары КАК ТабЧасть
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВтТаблицаБлокировок КАК ВтТаблицаБлокировок
	|		ПО (ВтТаблицаБлокировок.Номенклатура = ТабЧасть.Номенклатура)
	|			И (ВтТаблицаБлокировок.Характеристика = ТабЧасть.Характеристика)
	|ГДЕ
	|	&Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПриходныхОрдеров.Принят)
	|	И ВтТаблицаБлокировок.КоличествоПланКонечныйОстаток > 0
	|	И (ТабЧасть.Ссылка.Распоряжение ССЫЛКА Документ.ВозвратТоваровОтКлиента
	|			ИЛИ ТабЧасть.Ссылка.Распоряжение ССЫЛКА Документ.ПеремещениеТоваров
	|			ИЛИ ТабЧасть.Ссылка.Распоряжение ССЫЛКА Документ.КорректировкаРеализации)";
	
	РаспределениеЗапасовДвижения.РасходЗапаса(Запрос, ТекстыЗапроса, Регистры, ТекстЗапросаТабЧасть); 
			
КонецПроцедуры

Функция ТекстЗапросаВтТаблицаБлокировок(Запрос, ТекстыЗапроса)
	
	ИмяРегистра = "ВтТаблицаБлокировок"; 
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	БлокировкаДвиженияТоваровОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	БлокировкаДвиженияТоваровОстаткиИОбороты.Характеристика КАК Характеристика,
	|	БлокировкаДвиженияТоваровОстаткиИОбороты.ПричинаБлокировки КАК ПричинаБлокировки,
	|	БлокировкаДвиженияТоваровОстаткиИОбороты.КоличествоПланНачальныйОстаток КАК КоличествоПланНачальныйОстаток,
	|	БлокировкаДвиженияТоваровОстаткиИОбороты.КоличествоПланКонечныйОстаток КАК КоличествоПланКонечныйОстаток
	|ПОМЕСТИТЬ ВтТаблицаБлокировок
	|ИЗ
	|	РегистрНакопления.БлокировкаДвиженияТоваров.ОстаткиИОбороты(, &ПериодОстатки, Регистратор, , ) КАК БлокировкаДвиженияТоваровОстаткиИОбороты
	|ГДЕ
	|	БлокировкаДвиженияТоваровОстаткиИОбороты.Регистратор.ДокументОснование = &Распоряжение";
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаТаблицаДвижениеМаркированногоТовара(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект) экспорт
	ИмяРегистра = "ДвижениеМаркированногоТовара";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Штрихкоды.Ссылка.Дата КАК Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход) КАК ВидДвижения,
	|	Штрихкоды.Ссылка.Склад КАК Склад,
	|	Штрихкоды.Ссылка.Распоряжение.Организация КАК Организация,
	|	Штрихкоды.ШтрихкодУпаковки КАК Штрихкод,
	|	ШтрихкодыУпаковка.Ссылка КАК ШтрихкодУпаковки,
	|	1 КАК Количество
	|ИЗ
	|	Документ.ПриходныйОрдерНаТовары.ШтрихкодыУпаковок КАК Штрихкоды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтрихкодыУпаковокТоваров.ВложенныеШтрихкоды КАК ШтрихкодыУпаковка
	|		ПО Штрихкоды.ШтрихкодУпаковки = ШтрихкодыУпаковка.Штрихкод
	|ГДЕ
	|	Штрихкоды.Ссылка = &Ссылка
	|	И Штрихкоды.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыПриходныхОрдеров.Принят)
	|	И ВЫБОР
	|			КОГДА Штрихкоды.Ссылка.Склад.ИспользоватьОрдернуюСхемуПриПоступлении
	|					И Штрихкоды.Ссылка.Дата >= Штрихкоды.Ссылка.Склад.ДатаНачалаОрдернойСхемыПриПоступлении
	|				ТОГДА ИСТИНА
	|			ИНАЧЕ ЛОЖЬ
	|		КОНЕЦ";	
	
  	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	
	Возврат ТекстЗапроса;

КонецФункции

#Область ОбщиеМетодыДляФормПриходныхОрдеровТСД

Процедура ПолучитьЯчейку(Номенклатура, Склад, Ячейка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка
		|ИЗ
		|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|ГДЕ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура = &Номенклатура
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
		|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		Ячейка = РезультатЗапроса.Ячейка;
	КонецЕсли;
	
КонецПроцедуры

Функция ИзменитьЯчейку(Номенклатура, Склад, Ячейка, НоваяЯчейка) Экспорт
	
	Записано = Ложь;
	
	Попытка
		НачатьТранзакцию();
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьНаборЗаписей(); 
		НаборЗаписей.Отбор.Номенклатура.Установить(Номенклатура);
		НаборЗаписей.Отбор.Склад.Установить(Склад);
		НаборЗаписей.Отбор.Ячейка.Установить(Ячейка);
		НаборЗаписей.Записать();
		
		МенеджерЗаписи = РегистрыСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам.СоздатьМенеджерЗаписи();
		
		МенеджерЗаписи.Склад = Склад;
		МенеджерЗаписи.Ячейка = НоваяЯчейка;
		МенеджерЗаписи.Номенклатура = Номенклатура;
		МенеджерЗаписи.ОсновнаяЯчейка=Истина;
		
		МенеджерЗаписи.Записать();
		
		Записано = Истина;
		УстановитьПривилегированныйРежим(Ложь);
		ЗафиксироватьТранзакцию();
	Исключение      
		Сообщить("Ошибка записи!");
		Записано = Ложь;
		ОтменитьТранзакцию();
	КонецПопытки;
	
	Возврат Записано;	
	
КонецФункции

Процедура ПолучитьАдресКартинки(Номенклатура, УникальныйИдентификатор, АдресКартинки) Экспорт

	Попытка
		ФайлКартинки = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Номенклатура, "ФайлКартинки");
		Если ЗначениеЗаполнено(ФайлКартинки) тогда
			АдресКартинки = РаботаСФайлами.ДанныеФайла(ФайлКартинки, УникальныйИдентификатор).СсылкаНаДвоичныеДанныеФайла;
			Возврат;
		КонецЕсли;  
	Исключение    
		ОбщегоНазначения.СообщитьПользователю("Не удалось найти изображение номенклатуры..");
	КонецПопытки;
	
	АдресКартинки = "";
	
КонецПроцедуры

Функция ПолучитьНеопознанныйТовар(Склад, Номер) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	НеопНоменклатура.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Номенклатура КАК НеопНоменклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
		|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК ВНаличииОстаток,
		|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Свободно,
		|			СУММА(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Резерв
		|		ИЗ
		|			РегистрНакопления.ЗапасыИПотребности.Остатки(
		|					,
		|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки
		|		
		|		СГРУППИРОВАТЬ ПО
		|			ЗапасыИПотребностиОстатки.Номенклатура) КАК СвободныеОстаткиОстатки
		|		ПО (СвободныеОстаткиОстатки.Номенклатура = НеопНоменклатура.Ссылка)
		|ГДЕ
		|	НеопНоменклатура.НеопознанныйТовар = ИСТИНА
		|	И НеопНоменклатура.ПометкаУдаления = ЛОЖЬ
		|	И ЕСТЬNULL(СвободныеОстаткиОстатки.ВНаличииОстаток, 0) = 0";

	Запрос.УстановитьПараметр("Склад", Склад);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;
	
	Возврат СоздатьНовуюНеопознаннуюНоменклатуру(Номер);
	
КонецФункции

Функция СоздатьНовуюНеопознаннуюНоменклатуру(Номер)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		НачатьТранзакцию();
		
		НоваяНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();	
		СсылкаНового = Справочники.Номенклатура.ПолучитьСсылку();
		НоваяНоменклатура.УстановитьСсылкуНового(СсылкаНового);
		СсылкаНовойНоменклатуры = НоваяНоменклатура.ПолучитьСсылкуНового();
		
		НоваяНоменклатура.Наименование = "Неопознанная номенклатура (" + Строка(Номер) + " " + Строка(ТекущаяДата()) + ")"; 
		НоваяНоменклатура.Родитель = Справочники.Номенклатура.НайтиПоНаименованию("Неопознанно");
		НоваяНоменклатура.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Новый товар");
		НоваяНоменклатура.НеопознанныйТовар = ИСТИНА;
		НоваяНоменклатура.Качество = Перечисления.ГрадацииКачества.Новый;
		
		Справочники.Номенклатура.ЗаполнитьРеквизитыПоВидуНоменклатуры(НоваяНоменклатура);
		
		НоваяНоменклатура.Записать();
		
		ЗафиксироватьТранзакцию();
		
		Возврат СсылкаНовойНоменклатуры;
	Исключение
		ОтменитьТранзакцию();
	КонецПопытки;
	
	Возврат Неопределено;  
	
КонецФункции

Функция ПроверитьНеобходимостьЗапускаБП(Ссылка) Экспорт
	
	Запрос = Новый Запрос; 
	Запрос.Текст = 
    "ВЫБРАТЬ
    |	ПриходныйОрдерНаТоварыТовары.Номенклатура КАК Номенклатура
    |ИЗ
    |	Документ.ПриходныйОрдерНаТовары.Товары КАК ПриходныйОрдерНаТоварыТовары
    |ГДЕ
    |	ПриходныйОрдерНаТоварыТовары.Ссылка = &Ссылка
    |	И ПриходныйОрдерНаТоварыТовары.Номенклатура.НеопознанныйТовар";
	Запрос.УстановитьПараметр("Ссылка", Ссылка); 
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Ложь; 
	КонецЕсли;
	
	// Проверяем был ли уже запущен БП по этому ордеру.
	НаборЗаписей = РегистрыСведений.СобытияОбъектовАльтерра.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Установить(Ссылка);
	НаборЗаписей.Отбор.Событие.Установить(Справочники.СобытияОбъектовАльтерра.ЗапущенБППоНеопознаннойНоменклатуре);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Процедура ЗапуститьБпПоНеопознаннойНоменклатуре(Ссылка, Распоряжение, РабочийУчасток) Экспорт
	
    УстановитьПривилегированныйРежим(Истина);
	
	ИДТипаБлока = "lists_socnet";
	ИДБлока = "208";
	КодЭлемента =  СтрЗаменить(Строка(Ссылка.УникальныйИдентификатор()), "-", ""); 
		
	РеквизитыЗаказа = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Распоряжение, "Дата, Номер, Менеджер"); 
	РуководительСекции = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РабочийУчасток, "Руководитель");
	
	СтруктураПараметров = Новый Структура;  
	СтруктураПараметров.Вставить("NAME", "Неопознанная номенклатура");
	СтруктураПараметров.Вставить("PROPERTY_3937", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(РеквизитыЗаказа.Менеджер));
	СтруктураПараметров.Вставить("PROPERTY_3938", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(РуководительСекции));
	СтруктураПараметров.Вставить("PROPERTY_3939", Строка(Формат(РеквизитыЗаказа.Дата, "ДФ=dd.MM.yyyy")));
    СтруктураПараметров.Вставить("PROPERTY_3940", РеквизитыЗаказа.Номер);
			
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовыйЭлементСписка(ИДТипаБлока, ИДБлока, КодЭлемента, СтруктураПараметров, Истина);
	
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
	КонецЕсли;
	
	Если СтруктураОтвета.Свойство("Результат") Или СтруктураОтвета.Свойство("result") Тогда
		Запись = РегистрыСведений.СобытияОбъектовАльтерра.СоздатьМенеджерЗаписи();
		Запись.Период = ТекущаяДата();
		Запись.Объект = Ссылка; 
		Запись.Событие = Справочники.СобытияОбъектовАльтерра.ЗапущенБППоНеопознаннойНоменклатуре; 
		Запись.Записать(); 
		Сообщить("БП запущен");
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

 Процедура ЗапуститьБпПоОтсутствиюКодаМаркировки(Ссылка,Распоряжение,РабочийУчасток, БлокировкаКМ) Экспорт
	
    УстановитьПривилегированныйРежим(Истина);

	ИДТипаБлока = "lists_socnet";
