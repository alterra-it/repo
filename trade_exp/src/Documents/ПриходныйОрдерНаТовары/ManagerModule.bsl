	КонецЕсли;
	
	Если СтруктураОтвета.Свойство("Результат") Или СтруктураОтвета.Свойство("result") Тогда
		Запись = РегистрыСведений.СобытияОбъектовАльтерра.СоздатьМенеджерЗаписи();
		Запись.Период = ТекущаяДата();
		Запись.Объект = Ссылка; 
		Запись.Событие = Справочники.СобытияОбъектовАльтерра.ЗапущенБППоОтсутствиюКодаМаркировки; 
		Запись.Записать(); 
		Сообщить("БП запущен");
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь);

	
КонецПроцедуры 

Функция ПолучитьБлокировкуРасхождениеКМ(Основание) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	БлокировкаДвиженияТоваров.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.БлокировкаДвиженияТоваров КАК БлокировкаДвиженияТоваров
		|ГДЕ
		|	БлокировкаДвиженияТоваров.ДокументОснование = &ДокументОснование
		|   И БлокировкаДвиженияТоваров.ПричинаБлокировки = &ПричинаРасхождениеКМ
		|	И БлокировкаДвиженияТоваров.Проведен = ИСТИНА";
	
	Запрос.УстановитьПараметр("ДокументОснование", Основание);
	Запрос.УстановитьПараметр("ПричинаРасхождениеКМ",Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию("Расхождения при поступлении (нет кода маркировки)"));

	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
 КонецФункции
