&НаКлиенте
Процедура ЗаполнитьПлановоеКоличествоВТаблице()
	
	Для каждого Строка из ТоварыПоРаспоряжению Цикл
		МассивСтрок = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура,Характеристика,Назначение",Строка.Номенклатура,Строка.Характеристика,Строка.Назначение));
		Для каждого СтрокаМассив из МассивСтрок Цикл
			СтрокаМассив.КоличествоПлан = Строка.КоличествоПлан;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОжидание() Экспорт
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.Принят") Тогда
		Возврат;
	КонецЕсли;
	
	АктивнаСтрокаРедактирования = Элементы._РедактированиеСтрокиНаТСД.Видимость;
	
	Если АктивнаСтрокаРедактирования Тогда
		НомерСтроки = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД).НомерСтроки;
	КонецЕсли;
	
	Если ИзменениеТабличнойЧасти() Тогда
		
		ЭтаФорма.Прочитать();
		ЗаполнитьПлановоеКоличествоВТаблице();
		ЗаполнитьПризнакРасхождение();
		ЗаполнитьТоварыЯчейка();
		
		Если АктивнаСтрокаРедактирования Тогда
			ТекущаяСтрокаТСД = Объект.Товары[НомерСтроки-1].ПолучитьИдентификатор();
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ИзменениеТабличнойЧасти()
	
	Попытка
		Если Не Объект.Ссылка.Пустая()Тогда
			Если АльтерраОбщегоНазначения.ТабличнаяЧастьИзменилась(Объект.Ссылка.Товары.Выгрузить(),Объект.Товары.Выгрузить()) Тогда
				ДокументОбъект = Объект.Ссылка.ПолучитьОбъект();
				ДокументОбъект.Товары.Загрузить(Объект.Товары.Выгрузить());
				//Маркировка
				ДокументОбъект.ШтрихкодыУпаковок.Загрузить(Объект.ШтрихкодыУпаковок.Выгрузить());
				//Маркировка -
				УстановитьПривилегированныйРежим(Истина);
				ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект,истина);
				Возврат Истина;
			КонецЕсли;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции

