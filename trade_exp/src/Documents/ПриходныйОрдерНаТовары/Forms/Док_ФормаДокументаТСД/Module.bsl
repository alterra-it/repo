#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьОформлениеФормыДокумента()
	
	СтатусПриемки = Объект.Статус;
	
	Если СтатусПриемки = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.КПоступлению") Тогда
		
		УстановитьДоступность(Истина,Ложь,Ложь,Ложь,Ложь);
		
	ИначеЕсли СтатусПриемки = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.ВРаботе") Тогда
		
		УстановитьДоступность(Ложь,Истина,Истина,Истина,Ложь);
		
	ИначеЕсли СтатусПриемки = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.ТребуетсяОбработка") Тогда
		
		УстановитьДоступность(Истина,Ложь,Ложь,Ложь,Ложь);
		
	ИначеЕсли СтатусПриемки = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.Принят") Тогда
		
		УстановитьДоступность(Ложь,Ложь,Ложь,Ложь,Истина);			
	КонецЕсли;
	
	Элементы.ТоварыХарактеристика.Видимость = ОтображатьХарактеристики;
	
	ЭтаФорма.ОбновитьОтображениеДанных();
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьДоступность(КнопкаВзятьВРаботу,КнопкаОтложить,КнопкаОтменить, КнопкаЗавершить,КнопкаВернуть)
	Элементы.ВзятьВРаботу.Видимость=КнопкаВзятьВРаботу;
	Элементы.СообщитьОбОшибке.Видимость=КнопкаВзятьВРаботу;
	Элементы.Отложить.Видимость=КнопкаОтложить;
	Элементы.Отменить.Видимость=КнопкаОтменить;
	Элементы.ВернутьНаДоработку.Видимость=КнопкаВернуть;
	Элементы.Завершить.Видимость=КнопкаЗавершить;
КонецПроцедуры

#Область ЗаполнениеИИнициализация

&НаСервере
Процедура ЗаполнитьСлужебныеРеквизитыТЧТовары(Перенумеровать = Истина, КэшированныеЗначения = Неопределено)
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьВесОбъем");
	СтруктураДействий.Вставить("ЗаполнитьПризнакХарактеристикиИспользуются",
	Новый Структура("Номенклатура", "ХарактеристикиИспользуются"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры",
	Новый Структура("Номенклатура", "ТипНоменклатуры"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул",
	Новый Структура("Номенклатура", "Артикул"));
	СтруктураДействий.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
	СтруктураДействий.Вставить("ЗаполнитьВесУпаковки",Новый Структура("Номенклатура, Упаковка", "ВесУпаковки"));
	СтруктураДействий.Вставить("ЗаполнитьОбъемУпаковки",Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки"));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияВеса",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса"));
	СтруктураДействий.Вставить("ЗаполнитьЕдиницуИзмеренияОбъема",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема"));
	
	// Для заполнения признака ШтрихкодНеОпределен получим данные по штрихкодам
	ТЗШтрихкоды = Объект.Товары.Выгрузить(,"Штрихкод");
	ТЗШтрихкоды.Свернуть("Штрихкод");
	МассивШтрихкодов = ТЗШтрихкоды.ВыгрузитьКолонку("Штрихкод");
	
	КешированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	РегистрыСведений.ШтрихкодыНоменклатуры.ПолучитьДанныеПоШтрихкодам(КешированныеЗначения, МассивШтрихкодов);
	
	Если Объект.Товары.НайтиСтроки(Новый Структура("ЭтоУпаковочныйЛист", Истина)).Количество() > 0 Тогда
		Документы.УпаковочныйЛист.ДополнитьДанныеПоШтрихкодам(КешированныеЗначения, МассивШтрихкодов);
	КонецЕсли;
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьПризнакТовМестаТребуетсяОбработка");
	
	Для Каждого СтрокаТЧ Из Объект.Товары Цикл
		Если Не ЗначениеЗаполнено(СтрокаТЧ.Штрихкод)
			Или ЗначениеЗаполнено(КешированныеЗначения.Штрихкоды[СтрокаТЧ.Штрихкод])
			И КешированныеЗначения.Штрихкоды[СтрокаТЧ.Штрихкод].Количество() > 0 Тогда
			СтрокаТЧ.ШтрихкодНеОпределен = 0;
		Иначе
			СтрокаТЧ.ШтрихкодНеОпределен = 1;
		КонецЕсли;
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТЧ, СтруктураДействий, Неопределено);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьПлановоеКоличество()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Распоряжение", Объект.Распоряжение);
	Запрос.УстановитьПараметр("Отправитель", Объект.Отправитель);
	Запрос.УстановитьПараметр("РабочийУчасток", Объект.РабочийУчасток);
	
	Если ЗначениеЗаполнено(Объект.Дата) Тогда
		Запрос.УстановитьПараметр("ДатаОстатков", КонецДня(Объект.Дата));
	Иначе
		Запрос.УстановитьПараметр("ДатаОстатков", ТекущаяДата());
	КонецЕсли;
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ТоварыКПоступлению.Номенклатура КАК Номенклатура,
	|	ТоварыКПоступлению.Характеристика КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТоварыКПоступлению.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
	|			ТОГДА ТоварыКПоступлению.Назначение
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|	КОНЕЦ КАК Назначение,
	|	СУММА(ТоварыКПоступлению.Количество) КАК КоличествоПлан
	|ИЗ
	|	(ВЫБРАТЬ
	|		ТоварыКПоступлению.Номенклатура КАК Номенклатура,
	|		ТоварыКПоступлению.Характеристика КАК Характеристика,
	|		ТоварыКПоступлению.Назначение КАК Назначение,
	|		ТоварыКПоступлению.КОформлениюОрдеровОстаток - ТоварыКПоступлению.ПринимаетсяОстаток КАК Количество
	|	ИЗ
	|		РегистрНакопления.ТоварыКПоступлению.Остатки(
	|				&ДатаОстатков,
	|				ДокументПоступления = &Распоряжение
	|					И Отправитель = &Отправитель
	|					И Склад = &Склад) КАК ТоварыКПоступлению
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ТоварыКПоступлению.Номенклатура,
	|		ТоварыКПоступлению.Характеристика,
	|		ТоварыКПоступлению.Назначение,
	|		ВЫБОР
	|			КОГДА ТоварыКПоступлению.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА -ТоварыКПоступлению.КОформлениюОрдеров
	|			ИНАЧЕ ТоварыКПоступлению.КОформлениюОрдеров
	|		КОНЕЦ - ВЫБОР
	|			КОГДА ТоварыКПоступлению.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
	|				ТОГДА -ТоварыКПоступлению.Принимается
	|			ИНАЧЕ ТоварыКПоступлению.Принимается
	|		КОНЕЦ
	|	ИЗ
	|		РегистрНакопления.ТоварыКПоступлению КАК ТоварыКПоступлению
	|	ГДЕ
	|		ТоварыКПоступлению.Регистратор = &Ссылка
	|		И ТоварыКПоступлению.Активность
	|		И ТоварыКПоступлению.Склад = &Склад
	|		И ТоварыКПоступлению.ДокументПоступления = &Распоряжение) КАК ТоварыКПоступлению
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|		ПО (ТоварыКПоступлению.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
	|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
	|ГДЕ
	|	ВЫБОР
	|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
	|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочийУчасток
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|
	|СГРУППИРОВАТЬ ПО
	|	ТоварыКПоступлению.Номенклатура,
	|	ТоварыКПоступлению.Характеристика,
	|	ТоварыКПоступлению.Назначение,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ТоварыКПоступлению.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
	|			ТОГДА ТоварыКПоступлению.Назначение
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|	КОНЕЦ
	|
	|ИМЕЮЩИЕ
	|	СУММА(ТоварыКПоступлению.Количество) > 0";
	
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.Выполнить();
	ТоварыПоРаспоряжению.Загрузить(Результат.Выгрузить());
	
КонецПроцедуры

#КонецОбласти

#Область ШтрихкодыИТорговоеОборудование

&НаКлиенте
Процедура ОбработатьШтрихкоды(ДанныеШтрихкодов,СтруктураКодаМаркировки = Неопределено)
	
	СтруктураДействийСДобавленнымиСтроками = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ЭтотОбъект, СтруктураДействийСДобавленнымиСтроками);
	
	СтруктураДействийСИзмененнымиСтроками = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ЭтотОбъект, СтруктураДействийСИзмененнымиСтроками);
	
	СтруктураДействийСоСтрокамиИзУпаковочныхЛистов = Новый Структура;
	
	СтруктураДействий = ШтрихкодированиеНоменклатурыКлиент.ПараметрыОбработкиШтрихкодов();
	
	СтруктураДействий.Штрихкоды                              = ДанныеШтрихкодов;
	СтруктураДействий.СтруктураДействийСДобавленнымиСтроками = СтруктураДействийСДобавленнымиСтроками;
	СтруктураДействий.СтруктураДействийСИзмененнымиСтроками  = СтруктураДействийСИзмененнымиСтроками;
	//СтруктураДействий.ПараметрыУказанияСерий                 = ПараметрыУказанияСерий;
	СтруктураДействий.ТолькоТовары                           = Истина;
	СтруктураДействий.ШтрихкодыВТЧ                           = Истина;
	//СтруктураДействий.УчитыватьУпаковочныеЛисты              = ИспользоватьУпаковочныеЛисты;
	СтруктураДействий.ДействияСНеизвестнымиШтрихкодами       = "НетДействий";
	СтруктураДействий.СтруктураДействийСоСтрокамиИзУпаковочныхЛистов = СтруктураДействийСоСтрокамиИзУпаковочныхЛистов;
	СтруктураДействий.ОтработатьИзменениеУпаковочныхЛистов   = Истина;
	//СтруктураДействий.ТекущийУпаковочныйЛист                 = УпаковочныйЛистРодитель;
	ЭтоВозвратНепринятых = (Объект.СкладскаяОперация = ПредопределенноеЗначение("Перечисление.СкладскиеОперации.ВозвратНепринятыхТоваров"));
	СтруктураДействий.ЗаполнятьНазначения                    = Не ЭтоВозвратНепринятых;  
	
	СтароеКоличествоСтрок = Объект.Товары.Количество();
	
	ОбработатьШтрихкодыСервер(СтруктураДействий,КэшированныеЗначения);
	ШтрихкодированиеНоменклатурыКлиент.ОбработатьНеизвестныеШтрихкоды(СтруктураДействий,КэшированныеЗначения,ЭтаФорма);
	
	//Маркировка + 
	СтруктураДействий.Вставить("СтруктураКодаМаркировки",СтруктураКодаМаркировки); 
	//Маркировка -   
	Если СтароеКоличествоСтрок <> Объект.Товары.Количество() Тогда    
		Если  Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость  Тогда 
			//Сообщить("Товар не присутствует в ордере");
			ОбработатьШтрихкодыИтог(СтруктураДействий);	
			Возврат;
		КонецЕсли;
   		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОбработатьШтрихкодыДалее", ЭтотОбъект, СтруктураДействий), 
			"Выбранный товар не найден в ордере. Добавить его?", 
			РежимДиалогаВопрос.ДаНет);
	Иначе
		ОбработатьШтрихкодыИтог(СтруктураДействий);		
	КонецЕсли;
	
КонецПроцедуры  


&НаКлиенте
Процедура ОбработатьШтрихкодыДалее(Результат, СтруктураДействий) Экспорт 

	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработатьШтрихкодыИтог(СтруктураДействий); 
	Иначе
		Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
			Объект.Товары.Удалить(Объект.Товары.НайтиПоИдентификатору(СтруктураДействий.ТекущаяСтрока));
		КонецЕсли;
	КонецЕсли;	
 
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкодыИтог(СтруктураДействий)
	 
	
	Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
		Элементы.Товары.ТекущаяСтрока = СтруктураДействий.ТекущаяСтрока;
	КонецЕсли;
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		ТекущаяСтрокаТСД = СтруктураДействий.ТекущаяСтрока; 

		ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
	    ИндексСтроки = Объект.Товары.Индекс(ЭлементСписка);
                                                         		
		Если типзнч(ЭлементСписка) <> Тип("Неопределено") Тогда 	
			//Маркировка +	
			ЭлементСписка.Маркировка = Ложь;
			СтруктураКодаМаркировки = СтруктураДействий.СтруктураКодаМаркировки;
			
			Если СтруктураКодаМаркировки = Неопределено Тогда  
				
				Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(ЭлементСписка.Номенклатура) Тогда
					ЭлементСписка.Маркировка = Истина;
					
					ПоказатьВопрос(Новый ОписаниеОповещения("ВопросСканированияКМ", ЭтотОбъект, ЭлементСписка), 
			       "Отсканировать код маркировки?",РежимДиалогаВопрос.ДаНет);   
					
  				КонецЕсли;
		    Иначе  	
				  ЭлементСписка.Маркировка = Истина; 
				
				   СтруктураНоменклатуры = Новый Структура("Номенклатура,Серия,Характеристика", ЭлементСписка.Номенклатура,ЭлементСписка.Серия,ЭлементСписка.Характеристика); 
				   СсылкаНаШтрихкодМаркировки = МаркировкаАльтерра.ПолучитьСсылкуНаШтрихкодМаркируемогоТовара(СтруктураКодаМаркировки,СтруктураНоменклатуры);
				   ИдентификаторСтрокиМаркировка =  ПолучитьСтрокуШтрихкодыУпаковок(СсылкаНаШтрихкодМаркировки); 	
				  
				   ВидПродукции = МаркировкаАльтерра.ОпределитьВидПродукции(ЭлементСписка.Номенклатура,СтруктураКодаМаркировки.ВидыПродукции);
               
			       ДанныеСтрокиМаркировки = Новый Структура("ЭлементСписка,СсылкаНаШтрихкодМаркировки,ИдентификаторСтрокиМаркировка,МассивКодовМаркировкиЧЗ,ВидПродукции",
			       ЭлементСписка,СсылкаНаШтрихкодМаркировки,ИдентификаторСтрокиМаркировка,СтруктураКодаМаркировки.МассивКодовМаркировкиЧЗ,ВидПродукции);  
				   
			       	Если  Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость Тогда 
			       			
                	  Если ИдентификаторСтрокиМаркировка  = Неопределено   Тогда
	  		              Сообщить("Код маркировки не найден в документе");
		                  ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоУпаковок - 1; 
		                  ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;  
		                  Если ЭлементСписка.КоличествоУпаковок = 0 Тогда 
		              	    Объект.Товары.Удалить(ИндексСтроки);
		                  КонецЕсли; 
		                  Возврат;
                	  Иначе	 
		                 ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоУпаковок - 2; 
		                 ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;
		                 Если ЭлементСписка.КоличествоУпаковок = 0 Тогда 
			                Объект.Товары.Удалить(ИндексСтроки);
		                 КонецЕсли;
		                 Объект.ШтрихкодыУпаковок.Удалить(ДанныеСтрокиМаркировки.ИдентификаторСтрокиМаркировка); 
		                 Сообщить("Код маркировки успешно удален из ордера!");
		                 Возврат;
                	  КонецЕсли;
                	  
				   КонецЕсли;

		           ОбработатьСтрокуСМаркировкой(ДанныеСтрокиМаркировки);
		           ЗаполнитьПризнакРасхождение();
		КонецЕсли;
				
			//Маркировка -
			
			Если ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоПлан Тогда
				
				Элементы._РедактированиеДокументаНаТСД.Видимость=Истина;
				Элементы._РедактированиеСтрокиНаТСД.Видимость=Ложь;
				
				ЗаполнитьПризнакРасхождение();
				
			ИначеЕсли НЕ Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость Тогда 
				
				Элементы._РедактированиеДокументаНаТСД.Видимость=Ложь;
				Элементы._РедактированиеСтрокиНаТСД.Видимость=Истина;
				Элементы.ПоФакту.ТолькоПросмотр = ЭлементСписка.Маркировка;
				
				Номенклатура = ЭлементСписка.Номенклатура;
				Характеристика = ЭлементСписка.Характеристика;
				Количество = ЭлементСписка.КоличествоУпаковок;
				ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;
				ПоУчету = ЭлементСписка.КоличествоПлан;
				Комментарий = ЭлементСписка.Комментарий;
				ПолучитьЯчейку(Номенклатура, Объект.Склад);
				ПолучитьАдресКартинки(Номенклатура);
				
				НоваяЯчейка = "";
				НовыйШтрихкод = "";
				
			КонецЕсли;
		Иначе
			Если СредстваМультимедиа.ПоддерживаетсяВоспроизведениеТекста() Тогда
				СредстваМультимедиа.ВоспроизвестиТекст("Товар не найден!","ru-RU");	
			КонецЕсли;
			Сообщить("Штрихкод не найден!");
		КонецЕсли;
		
	#КонецЕсли	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкод(ШтрихКод1) 
	
	СсылкаНаЯчейку = ПолучитьЯчейкуПоШтрихкоду(ШтрихКод1); 
	Если СсылкаНаЯчейку <> Неопределено Тогда
		ДоступныеЯчейки.Отбор.Элементы.Очистить();
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ДоступныеЯчейки, "Ссылка", СсылкаНаЯчейку, ВидСравненияКомпоновкиДанных.Равно,,Истина);
	Иначе
		Сообщить("Ячейка не найдена!");
	КонецЕсли;
КонецПроцедуры
&НаСервере
Функция ПолучитьЯчейкуПоШтрихкоду(ШтрихКод1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладскиеЯчейки.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СкладскиеЯчейки КАК СкладскиеЯчейки
	|ГДЕ
	|	СкладскиеЯчейки.Штрихкод = &Штрихкод";
	
	Запрос.УстановитьПараметр("Штрихкод", Штрихкод1);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда	
		Возврат ВыборкаДетальныеЗаписи.Ссылка;   
	Иначе 
		Возврат Неопределено; 
	КонецЕсли;
КонецФункции

&НаСервере
Процедура ОбработатьШтрихкодыСервер(СтруктураДействий,КэшированныеЗначения)
	
	ШтрихкодированиеНоменклатурыСервер.ОбработатьШтрихкоды(ЭтаФорма,Объект,СтруктураДействий,КэшированныеЗначения);
	
	Если СтруктураДействий.ТекущаяСтрока <> Неопределено Тогда
		СтруктураДействийСТекущейСтрокой = Новый Структура;
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьПризнакТипИзмеряемойВеличины", Новый Структура("Номенклатура", "ТипИзмеряемойВеличины"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьВесУпаковки",Новый Структура("Номенклатура, Упаковка", "ВесУпаковки"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьОбъемУпаковки",Новый Структура("Номенклатура, Упаковка", "ОбъемУпаковки"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьЕдиницуИзмеренияВеса",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияВеса"));
		СтруктураДействийСТекущейСтрокой.Вставить("ЗаполнитьЕдиницуИзмеренияОбъема",Новый Структура("Номенклатура, Упаковка", "ЕдиницаИзмеренияОбъема"));
		СтруктураДействийСТекущейСтрокой.Вставить("ПересчитатьВесОбъем");
		
		ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(СтруктураДействий.ТекущаяСтрока);
		
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействийСТекущейСтрокой, КэшированныеЗначения);
	КонецЕсли;
	
	
	ПересчитатьКоличествоМест();
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область Прочее

&НаКлиентеНаСервереБезКонтекста
Функция ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(Форма, Действия)
	
	Действия.Вставить("ПересчитатьКоличествоЕдиниц");
	
КонецФункции

&НаСервере
Процедура ПересчитатьКоличествоМест()
	
	УпаковочныеЛистыСервер.ПересчитатьКоличествоМест(ЭтаФорма, Объект.Товары)
	
КонецПроцедуры

Процедура ПолучитьЯчейку(НоменклатураСсылка, СкладСсылка)
	Документы.ПриходныйОрдерНаТовары.ПолучитьЯчейку(НоменклатураСсылка, СкладСсылка, Ячейка);	
КонецПроцедуры

&НаКлиенте
Процедура ПоФактуПриИзменении(Элемент) 
		
	ИзменитьКоличествоВСтрокеПоИдентификатору(ТекущаяСтрокаТСД,Количество,Комментарий);
	
	ТекущаяСтрока = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД); 

	Если МаркировкаАльтерра.НоменклатураПодлежитМаркировке(ТекущаяСтрока.Номенклатура) Тогда    
		
	  КоличествоКМ = ПолучитьКоличествоКодовМаркировки(ТекущаяСтрока.Номенклатура);  
	  
	  Если  КоличествоКМ > Количество Тогда 
	    Количество  = КоличествоКМ;
		ТекущаяСтрока.КоличествоУпаковок = КоличествоКМ; 
		ТекущаяСтрока.Количество = КоличествоКМ;
	  КонецЕсли;
	  
    КонецЕсли;
		
	СтруктураДействий = Новый Структура;
	
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(ЭтотОбъект,СтруктураДействий);
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	
