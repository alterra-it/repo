		Элементы._ВыборНоменклатуры.Видимость = Истина;
		
	#КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТекущаяСтрокаТСД = Элементы.Товары.ТекущаяСтрока;	
	ТоварыВыбор_Обработка(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор_Обработка(ВызовИзОбработчика)
	
	Если типзнч(ТекущаяСтрокаТСД) <> Тип("Неопределено") Тогда
		
		ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрокаТСД);
		ЭлементСписка.Маркировка = МаркировкаАльтерра.НоменклатураПодлежитМаркировке(ЭлементСписка.Номенклатура);
		
		Номенклатура = "";
		Характеристика = "";
		Количество = 0;
		ПоУчету = 0;
		Комментарий = "";
		Ячейка = "";
		НоваяЯчейка = "";
		НовыйШтрихкод = "";
		АдресКартинки="";
		
		Если ЭлементСписка <> Неопределено Тогда
			Если ВызовИзОбработчика Тогда
				Элементы._РедактированиеДокументаНаТСД.Видимость=Ложь; 
			Иначе   
				Элементы._ВыборНоменклатуры.Видимость = Ложь;
			Конецесли; 
			
			Элементы._РедактированиеСтрокиНаТСД.Видимость = Истина;
			
			Номенклатура = ЭлементСписка.Номенклатура;
			Характеристика = ЭлементСписка.Характеристика;
			Количество = ЭлементСписка.КоличествоУпаковок;
			ПоУчету = ЭлементСписка.КоличествоПлан;
			Комментарий = ЭлементСписка.Комментарий;
			ПолучитьЯчейку(Номенклатура, Объект.Склад);
			ПолучитьАдресКартинки(Номенклатура);
			//Маркировка+
			Элементы.ПоФакту.ТолькоПросмотр = ЭлементСписка.Маркировка;
			//Маркировка-
		Конецесли;
		
	Иначе
		Сообщить("Штрихкод не найден!");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура _ВернутьсяКТЧ(Команда)
	
	ЗаполнитьПризнакРасхождение();
	
	Элементы._РедактированиеДокументаНаТСД.Видимость=Истина;
	Элементы._РедактированиеСтрокиНаТСД.Видимость=Ложь;
	Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость = Ложь;
	
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаКлиенте
Процедура ВзятьВРаботу(Команда)
	Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.ВРаботе"); 
	ОбщегоНазначенияУТКлиент.Провести(ЭтаФорма, Истина);
	
	Если Не Объект.Проведен Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.КПоступлению");
	КонецЕсли;
	
	УстановитьОформлениеФормыДокумента();
	ЗаполнитьПлановоеКоличествоВТаблице();
	ЗаполнитьТоварыЯчейка();
	
	ТолькоРасхождения = Истина;
	
	ЗаполнитьПризнакРасхождение();
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		ПроверкаФайловЗаказа();
	#КонецЕсли 
	
	Альтерра_СкладСервер.ЗаписьВРегистрЖурналРаботыТСД(ПредопределенноеЗначение("Перечисление.СобытияРаботыТСД.Документ"),,Объект.Ссылка);
	
	Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость = Ложь;
КонецПроцедуры

&НаКлиенте
Процедура Завершить(Команда)	
	
	Если ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		
		ЕстьСкан = ПроверитьПрикрепленныеФайлыПоПрефиксу("Scan_");
		
		Если Не ЕстьСкан И Объект.НомерВходящегоДокумента = "" Тогда
			Сообщить("Заполните номер, дату вх документа и загрузите скан вх документа");
			Возврат;
		ИначеЕсли Не ЕстьСкан Тогда
			Сообщить("Загрузите скан вх. документа");
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Объект.НомерВходящегоДокумента = "" Тогда
		Сообщить("Заполните номер и дату вх. документа");
		Возврат;
	КонецЕсли;
	
	Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.Принят");
	ОбщегоНазначенияУТКлиент.ПровестиИЗакрыть(ЭтаФорма);
