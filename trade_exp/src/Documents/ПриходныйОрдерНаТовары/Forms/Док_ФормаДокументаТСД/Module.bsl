&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	ВремяСохраненияДокументов=Константы.ВремяСохраненияДокументов.Получить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ОбновлениеИнформационнойБазы.ПроверитьОбъектОбработан(Объект, ЭтотОбъект);
	
	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);
	
	// Обработчик механизма "ВерсионированиеОбъектов"
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	
	СобытияФорм.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	
	Если Параметры.Свойство("Секции") Тогда
		СекцииСотрудника.ЗагрузитьЗначения(Параметры.Секции);
	КонецЕсли;
	
	Если Параметры.Свойство("ТекущийСотрудникТСД") Тогда
		ТекущийСотрудникТСД = Параметры.ТекущийСотрудникТСД;
	КонецЕсли;
	
	ДоступныеЯчейкиНастройкаСписка();
	
	Если ЗначениеЗаполнено(Объект.Распоряжение) Тогда
		
		ТипРаспоряжения = ТипЗнч(Объект.Распоряжение); 
		
		Элементы._ЗаблокироватьВсёНаПересортицу.Видимость = ?(ТипРаспоряжения = Тип("ДокументСсылка.ПеремещениеТоваров") ИЛИ ТипРаспоряжения = Тип("ДокументСсылка.ЗаказНаПеремещение"),Истина,Ложь);
		
		Элементы._ЗаблокироватьВсёНаБракОтПокупателей.Видимость = ?(ТипРаспоряжения = Тип("ДокументСсылка.ЧекККМВозврат") ИЛИ ТипРаспоряжения = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") ИЛИ ТипРаспоряжения = Тип("ДокументСсылка.КорректировкаРеализации"),Истина,Ложь);
		
	КонецЕсли;
	
	ЗаполнитьПлановоеКоличество();
	
	ЗаполнитьТоварыЯчейка();  
	
	//Подключение оповещений из очереди 
	СообщениеОбработано = Истина;
	Если ЭлектроннаяОчередьНаСекции() Тогда //Если у секции нет флага ЭлектроннаяОчередь, то ее подключение на ТСД не нужно 
		Если Не ПолучитьСостояниеОповещений() Тогда
			ОповещенияИзОчереди = Истина;
		Иначе
			ОповещенияИзОчереди = Объект.Сотрудник.ОповещенияИзОчереди; 
		КонецЕсли;
	Иначе 
		ОповещенияИзОчереди = Ложь; 	
	КонецЕсли; 
	Инт = 60;
	Для каждого Стр Из СекцииСотрудника Цикл
		ЗнчИнтервала = Стр.Значение.ИнтервалОповещений;
		Если ЗнчИнтервала <> 0 И Инт > ЗнчИнтервала Тогда
			Инт = ЗнчИнтервала;
		КонецЕсли; 
	КонецЦикла; 
	ИнтервалОповещений = Инт;   
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	
	ИнициализироватьСканер();
	
	УстановитьОформлениеФормыДокумента();
	ЗаполнитьПлановоеКоличествоВТаблице();
	
	ОтображатьХарактеристики = Ложь;
	
	УстановитьВидимостьХарактеристик();
	
	Если ВремяСохраненияДокументов > 0 Тогда
		ПодключитьОбработчикОжидания("ОбработатьОжидание", ВремяСохраненияДокументов, Ложь);
	КонецЕсли;
	
	Если ОповещенияИзОчереди Тогда 
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);
		ПроверкаЭлектроннойОчереди(); 
	Иначе 
		Элементы.ГруппаСписокОчереди.Видимость = Ложь;	
	КонецЕсли; 
			
	//Маркировка + 
	АктуализироватьМаркировку();
	//Маркировка -
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		МодульУправлениеДоступом = ОбщегоНазначения.ОбщийМодуль("УправлениеДоступом");
		МодульУправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	// Обработчик механизма "ДатыЗапретаИзменения"
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
	МодификацияКонфигурацииПереопределяемый.ПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)	
	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		//+Альтерра
		Если (ИмяСобытия = "ScanData" ИЛИ ИмяСобытия = "Barcode") И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			Если ТипЗнч(Параметр) = Тип("Массив") Тогда
				Штрихкод1 =  Параметр;
			иначе
				Штрихкод1 = Новый Массив;
				Штрихкод1.Добавить(Параметр);
				Штрихкод1.Добавить(Неопределено);
			конецесли;
			
			Если ЭтаФорма.ТекущийЭлемент = ЭтаФорма.Элементы.НовыйШтрихкод Тогда
				НовыйШтрихкод = "";
				Если ТипЗнч(Параметр) = Тип("Строка") Тогда
					НовыйШтрихкод = Параметр;
				КонецЕсли;
			ИначеЕсли Элементы._РедактированиеСтрокиНаТСД.Видимость=Ложь И Элементы._ВыборЯчейки.Видимость = Истина Тогда
				
				ОбработатьШтрихкод(ШтрихКод1[0]);
			Иначе 
				//Маркировка +	   
				//ПроверитьУпаковку(ШтрихКод1);
				СтруктураКодаМаркировки = Неопределено;
				ЭтоКодМаркировки = МаркировкаАльтерра.ЭтоКодМаркировки(ШтрихКод1);
				Если  Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость = Истина И  Не ЭтоКодМаркировки Тогда     					
					Сообщить("Отсканированный код не является кодом маркировки!");
					Возврат;
				КонецЕсли;	                       
				Если ЭтоКодМаркировки Тогда 
					СтруктураКодаМаркировки = МаркировкаАльтерра.ПолучитьСтруктуруКодаМаркировки(ШтрихКод1[0]);
					Штрихкод1[0] = СтруктураКодаМаркировки.СоставКодаМаркировки.EAN; 
				КонецЕсли; 
				ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(Штрихкод1),СтруктураКодаМаркировки);
			КонецЕсли;
			//Маркировка -	
			
		КонецЕсли;
		//-
	КонецЕсли;
	// Конец ПодключаемоеОборудование  
КонецПроцедуры

