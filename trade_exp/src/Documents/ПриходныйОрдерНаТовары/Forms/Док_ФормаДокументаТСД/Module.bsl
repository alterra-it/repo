&НаСервере
Процедура ЗаполнитьТоварыЯчейка()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура КАК Номенклатура
	|ИЗ
	|	РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
	|ГДЕ
	|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура В(&Номенклатура)
	|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад
	|	И РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА";
	
	Запрос.УстановитьПараметр("Номенклатура", Объект.Товары.Выгрузить(,"Номенклатура"));
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Для каждого Строка Из Объект.Товары Цикл
			Если Строка.Номенклатура = ВыборкаДетальныеЗаписи.Номенклатура Тогда
				Строка.Ячейка = ВыборкаДетальныеЗаписи.Ячейка;
			КонецЕсли; 
		КонецЦикла; 
	КонецЦикла;
	
КонецПроцедуры


#Область ДобавлениеФото
Функция КнопкиОповещения()
	
	Кнопки = Новый СписокЗначений;
	Кнопки.Добавить("Отмена");
	Кнопки.Добавить("С телефона");
	Кнопки.Добавить("Камера");
	
	Возврат Кнопки;
	
КонецФункции 

&НаКлиенте
Процедура ПроверкаФайловЗаказа()
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		Если ЭтаФорма.ВводДоступен() Тогда
			Если ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда //И Не ПроверитьПрикрепленныеФайлыПоПрефиксу("ФотоТС_") _____ Проверка убрана по задаче
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ИмяКоманды", "ДобавитьФотоТС");
				
				Кнопки = КнопкиОповещения();
				
				ПоказатьВопрос(Новый ОписаниеОповещения("ВыбратьСпособДобавленияФото", Этаформа, ДополнительныеПараметры), "Загрузите фото транспортного средства перед выгрузкой.", Кнопки);
				
			КонецЕсли;
		КонецЕсли;
	#КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьСпособДобавленияФото(РезультатВопроса, ДополнительныеПараметры) Экспорт
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		Если РезультатВопроса = "Камера" Тогда
			Если ДополнительныеПараметры.ИмяКоманды =  "ДобавитьФотоТС" Тогда 
				СделатьФотоКамерой(ДополнительныеПараметры.ИмяКоманды);
			Иначе
				СделатьФотоКамерой(ДополнительныеПараметры.ИмяКоманды);
			КонецЕсли;
		ИначеЕсли 
			РезультатВопроса = "С телефона" Тогда
			ДобавитьФотоИзГалереи(ДополнительныеПараметры.ИмяКоманды);
		Иначе
			Если ДополнительныеПараметры.ИмяКоманды = "ДобавитьФотоТС" Тогда
				ЭтаФорма.Закрыть();
			Иначе
				Возврат;
			КонецЕсли; 
		КонецЕсли;
	#КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура Загрузить(Команда)
	
	Если ТипЗнч(Объект.Распоряжение) <> Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Сообщить("Ордер создан не на основании заказа");
		Возврат;
	КонецЕсли; 
	
	Если Объект.Ссылка.Пустая() Тогда
		ПоказатьПредупреждение(, "Данные не записаны!");
		Возврат;
	КонецЕсли;
	
	Если Команда.Имя = "ДобавитьСканДокумента" 
		И (Объект.НомерВходящегоДокумента = "" Или Объект.ДатаВходящегоДокумента = Дата("00010101")) Тогда
		Сообщить("Заполните номер и дату вх. документа");
		Возврат;
	КонецЕсли; 
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяКоманды", Команда.Имя);
	
	Кнопки = КнопкиОповещения();
	
	ПоказатьВопрос(Новый ОписаниеОповещения("ВыбратьСпособДобавленияФото", Этаформа, ДополнительныеПараметры), "Загрузите фото.", Кнопки);
	
КонецПроцедуры

&НаКлиенте
Процедура СделатьФотоКамерой(ИмяКоманды)
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда	
		ДанныеМультимедиа = Неопределено;
		Если СредстваМультимедиа.ПоддерживаетсяФотоснимок() Тогда	
			ДанныеМультимедиа = СредстваМультимедиа.СделатьФотоснимок(,, 100,,ТипПодсветкиКамеры.Включена);
		Иначе    
			Сообщить(НСтр("ru = 'Съемка фото не поддерживается.'", "ru"));
		КонецЕсли; 
		
		
		Если ДанныеМультимедиа <> Неопределено Тогда
			Попытка
				СоздатьНовыйФайл(ДанныеМультимедиа.ПолучитьДвоичныеДанные(), ДанныеМультимедиа.РасширениеФайла, ИмяКоманды);
				ДополнительныеПараметры = Новый Структура;
				ДополнительныеПараметры.Вставить("ИмяКоманды", ИмяКоманды); 
				ПоказатьВопрос(Новый ОписаниеОповещения("ЗагрузитьЗавершение", Этаформа, ДополнительныеПараметры), "Изображение успешно загружено." + Символы.ПС + "Добавить новый снимок?", РежимДиалогаВопрос.ДаНет, 0.1);
			Исключение
				Ошибка = ИнформацияОбОшибке();
				ПодробнаяОшибка = ПодробноеПредставлениеОшибки(Ошибка);
				Сообщить(ПодробнаяОшибка);
			КонецПопытки;
		КонецЕсли;
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьФотоИзГалереи(ИмяКоманды)
	
	#Если МобильноеПриложениеКлиент ИЛИ МобильныйКлиент Тогда
		
		Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
		Диалог.Фильтр = "Все картинки (*.jpg;*.jpeg;*.tif;*.png)"
		+ "|*.jpg;*.jpeg;*.tif;*.png|";
		Диалог.МножественныйВыбор = Истина;
		// Диалог.Каталог = КаталогБиблиотекиМобильногоУстройства(ТипКаталогаБиблиотекиМобильногоУстройства.Картинки);
		
		Если Диалог.Выбрать() Тогда
			МассивФайлов = Диалог.ВыбранныеФайлы;
			Сч = 0;
			Для каждого Файл Из МассивФайлов Цикл
				Фото = Новый Файл(Файл); 
				Данные = Новый ДвоичныеДанные(Фото.ПолноеИмя);
				ПредставлениеФайла = Фото.ПолучитьПредставлениеФайлаБиблиотекиМобильногоУстройства();
				РасширениеФайла = СтрРазделить(ПредставлениеФайла, ".");
				Расширение = РасширениеФайла[РасширениеФайла.Количество()-1];
				Попытка
					СоздатьНовыйФайл(Данные,Расширение,ИмяКоманды);
					Сч = Сч + 1;
				Исключение
				КонецПопытки;
				
			КонецЦикла;
			ПоказатьПредупреждение(, "Загружено " + Сч + " из " + МассивФайлов.Количество() + " файлов", 1);
		Иначе
			ПроверкаФайловЗаказа();
		КонецЕсли;
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		СделатьФотоКамерой(ДополнительныеПараметры.ИмяКоманды);
	Иначе
		Возврат;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция СоздатьНовыйФайл(Данные,Расширение,Команда)
	УстановитьПривилегированныйРежим(Истина);
	
	ИмяПапки =  СтрЗаменить(СтрЗаменить(Строка(Объект.Ссылка), ":", "_"), " ", "_");
	
	Если Не ЗначениеЗаполнено(Справочники.ЗаказПоставщикуПрисоединенныеФайлы.НайтиПоНаименованию(ИмяПапки, Истина)) Тогда
		ГруппаОрдера = Справочники["ЗаказПоставщикуПрисоединенныеФайлы"].СоздатьГруппу();
		ГруппаОрдера.ВладелецФайла = Объект.Распоряжение;
		ГруппаОрдера.Наименование = ИмяПапки;
		ГруппаОрдера.Записать();
	КонецЕсли;
	ИмяПапкиОрдера = Справочники.ЗаказПоставщикуПрисоединенныеФайлы.НайтиПоНаименованию(ИмяПапки, Истина);
	
	Имя = ПолучитьИмяФайла();
	
	Если Команда = "ДобавитьСканДокумента" Тогда
		ИмяФайла = "Scan_" + Имя;
	КонецЕсли;
	
	Если Команда = "ДобавитьФотоТовара" Тогда
		Наименование = СтрРазделить(Строка(Номенклатура), " ");
		ЭлементМассива = 0;
		НоваяСтрока = "";
		Пока ЭлементМассива < 4 Цикл
			НоваяСтрока = НоваяСтрока + Наименование[ЭлементМассива] + "_";
			ЭлементМассива = ЭлементМассива + 1;
		КонецЦикла;
		ИмяФайла = Имя + "_"
		+ СтрЗаменить(НоваяСтрока, ",", "")
		+ Строка(Формат(ТекущаяДата(),"ДФ=dd.MM.yy"));
	КонецЕсли;
	
	Если Команда = "ДобавитьФотоТС" Тогда
		ИмяФайла  = "ФотоТС_" + Имя;
	КонецЕсли; 
	
	
	АдресВХранилище = ПоместитьВоВременноеХранилище(Данные);
	ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
	ПараметрыФайла.Автор = ПараметрыСеанса.ТекущийПользователь.Наименование;
	ПараметрыФайла.ВладелецФайлов = Объект.Распоряжение;
	ПараметрыФайла.ГруппаФайлов = ИмяПапкиОрдера; 
	ПараметрыФайла.ИмяБезРасширения = ИмяФайла;
	ПараметрыФайла.РасширениеБезТочки = Расширение;
	РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, АдресВХранилище);
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецФункции

Функция ПолучитьИмяФайла()
	Имя = СтрЗаменить(Строка(Объект.Склад), " ", "_") + "_" 
	+ СтрЗаменить(Строка(Объект.Отправитель), " ", "_") + "_" 
	+ СтрЗаменить(Строка(Объект.ДатаВходящегоДокумента), ":", "_") + "_" 
	+ Объект.НомерВходящегоДокумента;
	
	ЗапрещенныеСимволы = "/\[]:;|=?*<>" + Символ(34);
	Для Сч=1 По СтрДлина(Имя) Цикл
		Символ = Сред(Имя, Сч, 1);
		Если СтрНайти(ЗапрещенныеСимволы, Символ) Тогда 
			Имя = СтрЗаменить(Имя,Символ,"");
		КонецЕсли;
	КонецЦикла; 
	
	Возврат Имя;
Конецфункции

Функция ПроверитьПрикрепленныеФайлыПоПрефиксу(Префикс)
	Если ЗначениеЗаполнено(Справочники.ЗаказПоставщикуПрисоединенныеФайлы.НайтиПоНаименованию(Префикс + ПолучитьИмяФайла(), Истина)) Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции
#КонецОбласти

#КонецОбласти


#Область Оповещения 
&НаКлиенте
Процедура Оповещения(Команда)
	Если ОповещенияИзОчереди Тогда
		ПричинаОтказа = "";
		ОповещенияПоСекцииПодключены = ПолучитьСостояниеОповещений();
		
		Если ПричинаОтказа = "" Тогда
			ОповещенияИзОчереди = Ложь;
			Сообщить("Оповещения отключены");
			Элементы.ГруппаСписокОчереди.Видимость = Ложь;
			ОтключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди");  
		Иначе
			Сообщить(ПричинаОтказа);
		КонецЕсли;
	Иначе
		ОповещенияИзОчереди = Истина;
		Сообщить("Оповещения подключены");
		Элементы.ГруппаСписокОчереди.Видимость = Истина; 
		ПодключитьОбработчикОжидания("ПроверкаЭлектроннойОчереди", 10, Ложь);  
		ПроверкаЭлектроннойОчереди(); 
	КонецЕсли;
	ЗаписатьЗначениеОповещения();
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСписокОчереди(Команда)
	Если КлиентовВОчереди > 0 Тогда   
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.ТребуетсяОбработка");     
		ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма, Истина); 
		ОбработатьОжидание();
		ОткрытьФорму("Обработка.РабочееМестоКладовщикаАльтерра.Форма.Форма", Новый Структура("Сотрудник,ИмяКоманды, ОткрытьОчередь",Объект.Сотрудник,"Отгрузка", Истина),ЭтотОбъект);  
	Иначе
		Сообщить("Список очереди пуст");
	КонецЕСли;	
КонецПроцедуры  

&НаСервере
Функция ЭлектроннаяОчередьНаСекции()
	Запрос = Новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ
	|	РабочиеУчастки.Ссылка КАК Ссылка,
	|	РабочиеУчастки.ЭлектроннаяОчередь КАК ЭлектроннаяОчередь
	|ИЗ
	|	Справочник.РабочиеУчастки КАК РабочиеУчастки
	|ГДЕ
	|	РабочиеУчастки.Ссылка В(&Секции)
	|	И РабочиеУчастки.ЭлектроннаяОчередь = Истина" ;
	Запрос.УстановитьПараметр("Секции", СекцииСотрудника()); 
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 
		Возврат Истина; 
	Иначе 
		Возврат Ложь; 
	КонецЕсли;
	
КонецФункции 

&НаСервере
Функция ПолучитьСостояниеОповещений()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СотрудникиРабочиеУчастки.Ссылка.ОповещенияИзОчереди КАК ОповещенияИзОчереди
	|ИЗ
	|	Справочник.Сотрудники.РабочиеУчастки КАК СотрудникиРабочиеУчастки
	|ГДЕ
	|	СотрудникиРабочиеУчастки.РабочийУчасток В(&РабочийУчасток)
	|	И СотрудникиРабочиеУчастки.Ссылка <> &Сотрудник
	|
	|СГРУППИРОВАТЬ ПО
	|	СотрудникиРабочиеУчастки.Ссылка.ОповещенияИзОчереди";
	
	Запрос.УстановитьПараметр("РабочийУчасток", СекцииСотрудника());
	Запрос.УстановитьПараметр("Сотрудник", Объект.Сотрудник);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Если Результат.Количество() = 1 И Результат.Найти(Истина, "ОповещенияИзОчереди") = Неопределено Тогда
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции 


&НаКлиенте
Процедура ПроверкаЭлектроннойОчереди() Экспорт
	ОбновитьСписокОчереди();  
КонецПроцедуры   

&НаСервере
Процедура ОбновитьСписокОчереди() 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЭлектроннаяОчередьКлиентов.Документ КАК Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления КАК Получатель
	|ИЗ
	|	РегистрСведений.ЭлектроннаяОчередьКлиентов КАК ЭлектроннаяОчередьКлиентов 
	|ГДЕ
	|   ЭлектроннаяОчередьКлиентов.ТребуетсяОповещениеКладовщику = Истина 
	|	И ЭлектроннаяОчередьКлиентов.ПолучательУведомления В (&Секции)   
	|	И не ЭлектроннаяОчередьКлиентов.Состояние = &Статус
	|
	|
	|СГРУППИРОВАТЬ ПО
	|	ЭлектроннаяОчередьКлиентов.Документ,
	|	ЭлектроннаяОчередьКлиентов.ПолучательУведомления";
	
	Запрос.УстановитьПараметр("Секции", СекцииСотрудника());
	Запрос.УстановитьПараметр("Статус", Перечисления.СтатусыЭлектроннойОчереди.Выдан);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если не РезультатЗапроса.Пустой() Тогда
		КлиентовВОчереди = РезультатЗапроса.Выбрать().Количество(); 
	Иначе
		КлиентовВОчереди = 0;
	КонецЕсли;  
КонецПроцедуры 	

&НаСервере
Процедура ЗаписатьЗначениеОповещения() 
	УстановитьПривилегированныйРежим(Истина);
	ОбъектСотрудник = Объект.Сотрудник.ПолучитьОбъект();
	ОбъектСотрудник.ОповещенияИзОчереди = ОповещенияИзОчереди;
	ОбъектСотрудник.Записать();
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры 

Функция СекцииСотрудника()
	Возврат Объект.Сотрудник.РабочиеУчастки.ВыгрузитьКолонку("РабочийУчасток");
КонецФункции

#КонецОбласти 

&НаКлиенте
Процедура СчитатьШтрикодКамера(Команда)
	#Если МобильныйКлиент Тогда
		Если СредстваМультимедиа.ПоддерживаетсяСканированиеШтрихКодов() Тогда
			ОповещениеСканирования = Новый ОписаниеОповещения("ОбработкаОтсканированногоШтрихкода",ЭтотОбъект);
			СредстваМультимедиа.ПоказатьСканированиеШтрихКодов("Scan code",ОповещениеСканирования,,ТипШтрихкода.Все);
		Иначе
			Сообщить("Сканирование не поддерживается!");
		КонецЕсли;
	#КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОтсканированногоШтрихкода(Штрихкод,Результат,Сообщение,ДопПараметры) Экспорт
	
	Если Результат и ЗначениеЗаполнено(Штрихкод) Тогда
		
		#Если МобильныйКлиент Тогда
			СредстваМультимедиа.ЗакрытьСканированиеШтрихКодов();
		#КонецЕсли
		
		МассивСсылок = Новый Массив;
		МассивСсылок.Добавить(Штрихкод); 
		МассивСсылок.Добавить(Неопределено);
		ОбработатьШтрихкоды(МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВМассив(МассивСсылок));		

	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СообщитьОбОшибке(Команда)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		СообщитьОбОшибке_ПослеЗакрытияВопроса(КодВозвратаДиалога.Да, Истина);
	Иначе
    	ПоказатьВопрос(
			Новый ОписаниеОповещения("СообщитьОбОшибке_ПослеЗакрытияВопроса", ЭтотОбъект), 
			"Записать документ?", 
			РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СообщитьОбОшибке_ПослеЗакрытияВопроса(Результат, ОбъектЗаписан) Экспорт
 
	Если Результат = КодВозвратаДиалога.Да Тогда
		Если ОбъектЗаписан <> Истина Тогда 
			Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.ТребуетсяОбработка");
			Попытка
				ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма, Истина);
			Исключение   
				Возврат;
			КонецПопытки;
		КонецЕсли;
		
		СписокОрдеров = Новый Массив;
		СписокОрдеров.Добавить(Объект.Ссылка);
		
		ОткрытьФорму(
			"Обработка.РабочееМестоКладовщикаАльтерра.Форма.ФормаПриемПоРейсу_СообщитьОбОшибке", 
			Новый Структура("СписокОрдеров, ТекущийСотрудникТСД", СписокОрдеров, ТекущийСотрудникТСД), 
			ЭтаФорма,
			,
			,
			, 
			Новый ОписаниеОповещения("СообщитьОбОшибкеЗавершение", ЭтаФорма), 
			РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	КонецЕсли;	
 
КонецПроцедуры
	
&НаКлиенте 
Процедура СообщитьОбОшибкеЗавершение(Результат, ДополнительныеПараметры) Экспорт 
	Если ТипЗнч(Результат) = Тип("Строка") И ЗначениеЗаполнено(Результат) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Результат);
	КонецЕсли;
КонецПроцедуры

#Область Маркировка   

 &НаСервере
 Функция ПолучитьСтрокуШтрихкодыУпаковок(CcылкаНаШтрихкод) 
	
	Строка = Объект.ШтрихкодыУпаковок.Выгрузить().Найти(CcылкаНаШтрихкод,"ШтрихкодУпаковки");
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	Иначе                                   
		Возврат Строка.НомерСтроки - 1;
	КонецЕсли;
	
КонецФункции  

 &НаСервере
 Процедура АктуализироватьМаркировку()
	
    ОбработанныеТовары = МаркировкаАльтерра.АктуализироватьМаркировку(Объект.Товары);
    Если ОбработанныеТовары = Неопределено Тогда
    	Возврат;
    КонецЕсли;
    
	Объект.Товары.Загрузить(ОбработанныеТовары);
	 
 КонецПроцедуры 

 &НаКлиенте
 Процедура ТоварыПередУдалением(Элемент,Отказ) 

	 ТекущаяСтрока = Элементы.Товары.ТекущаяСтрока;
	 ЭлементСписка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	 ЭлементСписка.Маркировка = МаркировкаАльтерра.НоменклатураПодлежитМаркировке(ЭлементСписка.Номенклатура);
	 Если ЭлементСписка.Маркировка и ЭлементСписка.КоличествоУпаковок > 0 Тогда                                                        
		 КоличествоКМ =  ПолучитьКоличествоКодовМаркировки(ЭлементСписка.Номенклатура);  
		 Если КоличествоКМ > 0 Тогда  
			 //ЭлементСписка.КоличествоУпаковок = КоличествоКМ; 
			 Отказ = Истина;
			 Элементы.ГруппаУдалениеТовараСМаркировкой.Видимость = Истина; 
			 Элементы._РедактированиеДокументаНаТСД.Видимость=Ложь;
		 КонецЕсли;
	 КонецЕсли;
	 
 КонецПроцедуры  
 
&НаКлиенте
Процедура ОбработатьСтрокуСМаркировкой(ДанныеСтрокиМаркировки)
	
	ЭлементСписка = ДанныеСтрокиМаркировки.ЭлементСписка;
	ИндексСтроки = Объект.Товары.Индекс(ЭлементСписка);	
	
	Если ДанныеСтрокиМаркировки.ИдентификаторСтрокиМаркировка  = Неопределено Тогда  
				
		Операция = ПредопределенноеЗначение("Перечисление.ВидыОперацийИСМП.Приемка");  
		
		РезультатПроверки = МаркировкаАльтерра.ПроверкаЧЗ(ДанныеСтрокиМаркировки.МассивКодовМаркировкиЧЗ,ДанныеСтрокиМаркировки.ВидПродукции,Операция);
		СообщениеОбОшибках = РезультатПроверки.СообщениеОбОшибках;
 
		Если РезультатПроверки.КодВалидный Тогда
			НС = Объект.ШтрихкодыУпаковок.Добавить();
			НС.ШтрихкодУпаковки = ДанныеСтрокиМаркировки.СсылкаНаШтрихкодМаркировки;
		Иначе
			СообщениеОбОшибках = СообщениеОбОшибках + "
			|Товар будет добавлен без КМ!";
		КонецЕсли;
		
		Если СообщениеОбОшибках  <> "" Тогда  
			Сообщить(СообщениеОбОшибках);
		КонецЕсли;
	
	Иначе 
		ПоказатьВопрос(Новый ОписаниеОповещения("ВопросУдаленияКМ", ЭтотОбъект, ДанныеСтрокиМаркировки), 
		"Код маркировки уже присутствует в документе. Удалить КМ?",РежимДиалогаВопрос.ДаНет); 	
	КонецЕсли;  				
	
КонецПроцедуры	

&НаКлиенте
Процедура ВопросСканированияКМ(Результат, ЭлементСписка) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда  
		ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоУпаковок - 1;
		ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;
		Маркировка = Истина;
	Иначе 
	    Маркировка = Ложь;	
	КонецЕсли;
	
	Если Элементы._РедактированиеСтрокиНаТСД.Видимость  Тогда
		Элементы.ПоФакту.ТолькоПросмотр = Маркировка; 
		Количество = ЭлементСписка.КоличествоУпаковок;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере 
Функция ПолучитьКоличествоКодовМаркировки(Номенклатура)  
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(ШтрихкодыУпаковокТоваров.Ссылка) КАК КоличествоКМ,
		|	ШтрихкодыУпаковокТоваров.Номенклатура КАК Номенклатура
		|ИЗ
		|	Справочник.ШтрихкодыУпаковокТоваров КАК ШтрихкодыУпаковокТоваров
		|ГДЕ
		|	ШтрихкодыУпаковокТоваров.Номенклатура = &Номенклатура
		|	И ШтрихкодыУпаковокТоваров.Ссылка В(&ШтрихкодыУпаковок)
		|
		|СГРУППИРОВАТЬ ПО
		|	ШтрихкодыУпаковокТоваров.Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ШтрихкодыУпаковок", Объект.ШтрихкодыУпаковок.Выгрузить(,"ШтрихкодУпаковки"));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.КоличествоКМ;
	Иначе  
		Возврат 0;
	КонецЕсли;
	

КонецФункции

&НаСервере
Функция  ПроверитьУпаковку(ШтрихкодыМассив)  
	
	Штрихкоды = Новый Массив;
	
	Штрихкоды.Добавить(Новый Структура("Штрихкод",ШтрихкодыМассив[0])); 
	
		
	ДанныеДляТСД = Новый Структура;
	ДанныеДляТСД.Вставить("Штрихкоды",                         Штрихкоды);
	ДанныеДляТСД.Вставить("ПараметрыСканирования",             (Новый Структура("ДопустимыеВидыПродукции,СохранятьКодыМаркировкиВПулИСМП",Неопределено, Ложь)));
	ДанныеДляТСД.Вставить("СоответствиеШтрихкодовСтрокДерева", неопределено);
	ДанныеДляТСД.Вставить("ДополнительныеПараметры",           неопределено);
	
  	
	ПараметрыЛогирования = ЛогированиеЗапросовИСМП.ПараметрыЛогированияЗапросов();
	ЛогированиеЗапросовИС.ВключитьЛогированиеЗапросов(ПараметрыЛогирования,, Истина);
	ЛогированиеЗапросовИСМП.УстановитьПараметрыЛогированияЗапросов(ПараметрыЛогирования);
	
	Результат = ГрупповаяОбработкаШтрихкодовИС.РезультатЗагрузкиШтрихкодовИзТСД();
	
	ГрупповаяОбработкаШтрихкодовИС.ДополнитьУпорядочитьДанныеТСД(ДанныеДляТСД.Штрихкоды);
	
	ДанныеШтрихкодов            = Новый Массив();
	КешДанныхРазбора            = Новый Соответствие();
	МассивПропущенныхШтрихкодов = Новый Массив();
	
	ПользовательскиеПараметрыРазбораКодаМаркировки = РазборКодаМаркировкиИССлужебныйКлиентСервер.ПользовательскиеПараметрыРазбораКодаМаркировки();
	ПользовательскиеПараметрыРазбораКодаМаркировки.РасширеннаяДетализация = ДанныеДляТСД.ПараметрыСканирования.СохранятьКодыМаркировкиВПулИСМП;
	
	ОбщиеНастройкиРазбора = РазборКодаМаркировкиИССлужебный.НастройкиРазбораКодаМаркировки(
		ДанныеДляТСД.ПараметрыСканирования.ДопустимыеВидыПродукции, Ложь);
	
	НастройкиРазбораКодаМаркировки = Новый Структура;
	НастройкиРазбораКодаМаркировки.Вставить("Кеш",              РазборКодаМаркировкиИССлужебныйКлиентСервер.ИнициализироватьНастройкиИспользующиеРезультатыПредыдущихРазборов());
	НастройкиРазбораКодаМаркировки.Вставить("Общие",            ОбщиеНастройкиРазбора);
	НастройкиРазбораКодаМаркировки.Вставить("Пользовательские", ПользовательскиеПараметрыРазбораКодаМаркировки);
	
	Для Каждого СтрокаДанныхТСД Из ДанныеДляТСД.Штрихкоды Цикл
		
		СтрокаДанныхТСД.Вставить("ШтрихкодСОшибкой",        Ложь);
		СтрокаДанныхТСД.Вставить("НормализованныйШтрихкод", СтрокаДанныхТСД.Штрихкод);
		СтрокаДанныхТСД.Вставить("Уровень",                 0);
		
		Штрихкод      = ШтрихкодированиеОбщегоНазначенияИСКлиентСервер.Base64ВШтрихкод(СтрокаДанныхТСД.Штрихкод);
		ДанныеРазбора = ГрупповаяОбработкаШтрихкодовИС.ВидУпаковкиИПредставлениеШтрихкодаУпрощенныйРазбор(
			Штрихкод,
			ДанныеДляТСД.ПараметрыСканирования.ДопустимыеВидыПродукции,
			КешДанныхРазбора,
			НастройкиРазбораКодаМаркировки);
		
		Если ДанныеРазбора.ВидУпаковки = Неопределено И Не ДанныеРазбора.КодМаркировкиСоответствуетНесколькимШаблонам Тогда
			
			Штрихкод = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыXML(Штрихкод, "");
			
			ОбщегоНазначенияИС.СообщитьПользователюВФорму(
				УникальныйИдентификатор,
				СтрШаблон(
					НСтр("ru = 'Код %1 не является штрихкодом потребительской, групповой или логистической
					           |упаковки продукции, поддерживаемой ГИС МТ.'"),
					Штрихкод));
			
			МассивПропущенныхШтрихкодов.Добавить(СтрокаДанныхТСД);
			Продолжить;
			
		КонецЕсли;
	КонецЦикла;	

КонецФункции

&НаКлиенте
Процедура ВопросУдаленияКМ(Результат, ДанныеСтрокиМаркировки) Экспорт
	ЭлементСписка = ДанныеСтрокиМаркировки.ЭлементСписка;
	Если Результат = КодВозвратаДиалога.Да Тогда 
		Объект.ШтрихкодыУпаковок.Удалить(ДанныеСтрокиМаркировки.ИдентификаторСтрокиМаркировка); 
		ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоУпаковок - 2;
		ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;
		Сообщить("Код маркировки успешно удален из ордера!");
	Иначе 
		ЭлементСписка.КоличествоУпаковок = ЭлементСписка.КоличествоУпаковок - 1;   
		ЭлементСписка.Количество = ЭлементСписка.КоличествоУпаковок;	  
	КонецЕсли;
	Если Элементы._РедактированиеСтрокиНаТСД.Видимость Тогда
		Количество = ЭлементСписка.КоличествоУпаковок;
	КонецЕсли;	
КонецПроцедуры

 #КонецОбласти
