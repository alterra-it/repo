КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
 
	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗапуститьБпПоНеопознаннойНоменклатуре(Объект.Ссылка, Объект.Распоряжение, Объект.РабочийУчасток);	
	КонецЕсли;	
 
КонецПроцедуры 

&НаСервереБезКонтекста 
Процедура ЗапуститьБпПоНеопознаннойНоменклатуре(Ссылка, Распоряжение, РабочийУчасток)
	
	Документы.ПриходныйОрдерНаТовары.ЗапуститьБпПоНеопознаннойНоменклатуре(Ссылка, Распоряжение, РабочийУчасток);  
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ЗаполнитьПоРегиструМППосле(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьОтветЗаполнениеПоРегистру", ЭтаФорма);
	ТекстВопроса = "Дозаполнить только необработанные строки?";
   	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Если ОбменУТМПСервер.ОрдерЗаполнялсяВМП(Объект.Ссылка, Объект.Распоряжение) Тогда
		Элементы.ТоварыЗаполнитьПоРегиструМП.Видимость = Истина;	
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОтветЗаполнениеПоРегистру(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		Отработаные = Ложь;
	Иначе
		Отработаные = Истина;	
	КонецЕсли;
	БылиИзменения = Док_ЗаполнитьПоРегиструМППослеНаСервере(Отработаные);
	Если БылиИзменения Тогда
		ЭтаФорма.Модифицированность = Истина;
		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьОтветОчисткаПустыхСтрок", ЭтаФорма);
		ТекстВопроса = "Очистить неотработанные строки?";
	   	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция Док_ЗаполнитьПоРегиструМППослеНаСервере(Отработаные) 
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	БылиИзменения = ОбменУТМПСервер.ЗаполнитьОрдер(ДокОбъект, "Товары", Отработаные); 
	ЗначениеВРеквизитФормы(ДокОбъект, "Объект"); 
	Возврат БылиИзменения;
КонецФункции 

&НаКлиенте
Процедура ОбработатьОтветОчисткаПустыхСтрок(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОбработатьОтветОчисткаПустыхСтрокНаСервере();
	КонецЕсли;	 	
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьОтветОчисткаПустыхСтрокНаСервере() 
	
	МассивСтрок = Объект.Товары.НайтиСтроки(Новый Структура("КоличествоУпаковок",0));
	Для Каждого Строка Из МассивСтрок Цикл
		Объект.Товары.Удалить(Строка);
	КонецЦикла;	
	
КонецПроцедуры


#КонецОбласти 
