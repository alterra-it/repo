#Область Доработки_по_ордерной_схеме

&НаСервере
&ИзменениеИКонтроль("ПриЧтенииСозданииНаСервере")
Процедура Док_ПриЧтенииСозданииНаСервере()
	
	Если ЗначениеЗаполнено(Объект.Распоряжение) Тогда
		ОбщегоНазначенияУТКлиентСервер.ДобавитьПараметрВыбора(Элементы.Склад, "Ссылка", Документы.ПриходныйОрдерНаТовары.ОрдерныеСклады(Объект));
	КонецЕсли;
	
	УстановитьПараметрыФункциональныхОпцийФормы(Новый Структура("Склад, Помещение",Объект.Склад, Объект.Помещение));
	
	РозничныйВидЦены        = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "РозничныйВидЦены");
	
	УстановитьПривилегированныйРежим(Истина);
	Если ЗначениеЗаполнено(Объект.Распоряжение) Тогда 
		ОрганизацияРаспоряжения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Распоряжение, "Организация");
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	ПараметрыУказанияСерий = Новый ФиксированнаяСтруктура(НоменклатураСервер.ПараметрыУказанияСерий(Объект, Документы.ПриходныйОрдерНаТовары));
	
	УстановитьЗависимыеОтАдресногоХранения();
	
	Элементы.ГруппаИнформация.Картинка = ОбщегоНазначенияКлиентСервер.КартинкаКомментария(Объект.Комментарий);
	
	Элементы.Помещение.Видимость = СкладыСервер.ИспользоватьСкладскиеПомещения(Объект.Склад,Объект.Дата);
	
	Если Объект.СкладскаяОперация = Перечисления.СкладскиеОперации.ВозвратНепринятыхТоваров
		Или Объект.СкладскаяОперация = Перечисления.СкладскиеОперации.ВозвратНепринятыхТоваровУстарел Тогда
		Элементы.ДатаВходящегоДокумента.Видимость  = Ложь;
		Элементы.НомерВходящегоДокумента.Видимость = Ложь;
		
		Элементы.ЗаполнитьВозвращаемоеКоличество.Видимость    = Истина;
		Элементы.ЗаполнитьТолькоКоличество.Видимость          = Ложь;
		Элементы.ЗаполнитьТолькоНоменклатуру.Видимость        = Ложь;
		Элементы.ЗаполнитьНоменклатуруИКоличество.Видимость   = Ложь;
		Элементы.ТоварыЗаполнитьСерииПоРаспоряжению.Видимость = Ложь;
		Элементы.ТоварыПроверитьКоличество.Видимость          = Ложь;
		Элементы.РаспоряжениеПредставление.Видимость          = Ложь;
	Иначе
		Элементы.РаспоряжениеПредставление.Видимость = Истина;
		Элементы.ТоварыДокументОтгрузки.Видимость    = Ложь;
		
		Элементы.ЗаполнитьВозвращаемоеКоличество.Видимость    = Ложь;
		
		Элементы.ТоварыДобавитьИзДокументовОтгрузки.Видимость = Ложь;
	КонецЕсли;
	
	#Удаление 
	ИспользоватьУпаковки              = ПолучитьФункциональнуюОпцию("ИспользоватьУпаковкиНоменклатуры");
	#КонецУдаления
	#Вставка
	ИспользоватьУпаковки = Ложь;
	 
	Если ЗначениеЗаполнено(Объект.Распоряжение) Тогда
		 
		ТипРаспоряжения = ТипЗнч(Объект.Распоряжение); 
		 
		Элементы.Товары_ЗаблокироватьВсёНаБракОтПокупателей.Видимость = ?(ТипРаспоряжения = Тип("ДокументСсылка.ЧекККМВозврат") ИЛИ ТипРаспоряжения = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") ИЛИ ТипРаспоряжения = Тип("ДокументСсылка.КорректировкаРеализации"),Истина,Ложь);
		 
	КонецЕсли;
	 
	Элементы.Форма_ИзменитьРаспоряжение.Видимость = АльтерраОбщегоНазначения._РольДоступна("ИзменениеРаспоряженияВПриходныхОрдерахНаТовары");
	#КонецВставки
	Элементы.СписокУпаковок.Видимость = ИспользоватьУпаковки;
	Элементы.НаборУпаковок.Видимость  = ИспользоватьУпаковки;
	
	Элементы.СписокШтрихКодовСоздатьШтрихКод.Видимость = ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ШтрихкодыНоменклатуры);
	Элементы.СписокШтрихКодовПечать.Видимость = ПравоДоступа("Просмотр", Метаданные.Обработки.ПечатьЭтикетокИЦенников);
	
	УпаковочныеЛистыСервер.ПриЧтенииСозданииФормыСУпаковочнымиЛистами(ЭтаФорма, Объект.Товары,
		Объект.Ссылка.Метаданные().ПредставлениеОбъекта);
	ЗаполнитьСлужебныеРеквизитыТЧТовары(Ложь);
	
	ОтобразитьСтраницуФильтраСнятьОтборПриНеобходимости();
	
	ВозможноЗаполнениеСерийПоРаспоряжению = Документы.ПриходныйОрдерНаТовары.ВозможноЗаполнениеСерийПоРаспоряжению(Объект, Ложь);
	
	ПоказатьПредставлениеРаспоряжения(РаспоряжениеПредставление, Объект.Распоряжение);
	
	РаботаСТабличнымиЧастями.ИнициализироватьКэшСтрок(Элементы.Товары);
КонецПроцедуры

&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	
	Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыПриходныхОрдеров.Принят") Тогда
		Результат = ПроверитьНеобходимостьЗапускаБП(Объект.Ссылка);
		Если Результат Тогда  
			Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);	
    		ПоказатьВопрос(Оповещение, "В документе присутствует ""Неопознанная номенклатура"", запустить БП в Битриксе?", РежимДиалогаВопрос.ДаНет);
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("Автотест_ЗаполнитьПоРаспоряжениюФрагмент")
Процедура Док_Автотест_ЗаполнитьПоРаспоряжениюФрагмент(Знач ВидЗаполнения)
	
	#Удаление
	ПараметрыФормыВыбораДаты = Новый Структура;
	ПараметрыФормыВыбораДаты.Вставить("ТекущийДокумент",	Объект.Ссылка);
	ПараметрыФормыВыбораДаты.Вставить("Распоряжение",		Объект.Распоряжение);
	ПараметрыФормыВыбораДаты.Вставить("Склад",				Объект.Склад);
	
	ПараметрыОповещения	= Новый Структура("ВидЗаполнения", ВидЗаполнения);
	ОписаниеОповещения	= Новый ОписаниеОповещения("Автотест_ЗаполнитьПоРаспоряжениюЗавершение",
	ЭтотОбъект,
	ПараметрыОповещения);
	
	ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.ФормаВыбораДатыПоступления",
	ПараметрыФормыВыбораДаты,
	,
	,
	,
	,
	ОписаниеОповещения,
	РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	#КонецУдаления
	
	#Вставка
	ДатаПоступления = ТекущаяДата();
	
	ЗаполнитьНаСервере(ВидЗаполнения,ДатаПоступления,КэшированныеЗначения);
	#КонецВставки
КонецПроцедуры

#Область НеопознанныйТовар  

&НаКлиенте
Процедура Док__ДобавитьНеопознанныйТоварПосле(Команда)
	
	НеопознанныйТовар = ПолучитьНеопознанныйТовар();
		
	Если ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
		Оповещение = Новый ОписаниеОповещения("ДобавитьНеопознанныйТоварЗавершение", ЭтотОбъект);
		
		ПараметрыФормы = Новый Структура();
		ПараметрыФормы.Вставить("Номенклатура", НеопознанныйТовар);
		ПараметрыФормы.Вставить("ЗаказПоставщику", Объект.Распоряжение); 
		ПараметрыФормы.Вставить("ПриходныйОрдерНаТовары", Объект.Ссылка);
		
		ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.Док_НеопознаннаяНоменклатура", ПараметрыФормы, ЭтаФорма, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		ДобавитьНеопознанныйТоварЗавершение(НеопознанныйТовар, Неопределено);
	КонецЕсли; 
	
КонецПроцедуры  

&НаСервере
Функция ПолучитьНеопознанныйТовар()
	
	НоменклатураНеопознанная = Справочники.Номенклатура.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	НеопНоменклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК НеопНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапасыИПотребностиОстатки.Номенклатура КАК Номенклатура,
	|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток) КАК ВНаличииОстаток,
	|			СУММА(ЗапасыИПотребностиОстатки.ВНаличииОстаток - ЗапасыИПотребностиОстатки.РезервироватьПоМереПоступленияОстаток - ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Свободно,
	|			СУММА(ЗапасыИПотребностиОстатки.РезервироватьНаСкладеОстаток) КАК Резерв
	|		ИЗ
	|			РегистрНакопления.ЗапасыИПотребности.Остатки(
	|					,
	|					Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|						И Склад = &Склад) КАК ЗапасыИПотребностиОстатки
	|		ГДЕ
	|			ЗапасыИПотребностиОстатки.Назначение = ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
	|			И ЗапасыИПотребностиОстатки.Склад = &Склад
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗапасыИПотребностиОстатки.Номенклатура) КАК СвободныеОстаткиОстатки
	|		ПО (СвободныеОстаткиОстатки.Номенклатура = НеопНоменклатура.Ссылка)
	|ГДЕ
	|	НеопНоменклатура.НеопознанныйТовар = ИСТИНА
	|	И НеопНоменклатура.ПометкаУдаления = ЛОЖЬ
	|	И ЕСТЬNULL(СвободныеОстаткиОстатки.ВНаличииОстаток, 0) = 0";
	
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоменклатураНеопознанная = ВыборкаДетальныеЗаписи.Ссылка;
	КонецЦикла;

	Если НоменклатураНеопознанная.Пустая() Тогда
		НоменклатураНеопознанная = СоздатьНовуюНеопознаннуюНоменклатуру();
	КонецЕсли;
	
	Возврат НоменклатураНеопознанная;
	
КонецФункции

Функция СоздатьНовуюНеопознаннуюНоменклатуру()

	УстановитьПривилегированныйРежим(Истина);

	Попытка
		НачатьТранзакцию();
		
		НоваяНоменклатура = Справочники.Номенклатура.СоздатьЭлемент();	
		СсылкаНового = Справочники.Номенклатура.ПолучитьСсылку();
		НоваяНоменклатура.УстановитьСсылкуНового(СсылкаНового);
		СсылкаНовойНоменклатуры = НоваяНоменклатура.ПолучитьСсылкуНового();

		НоваяНоменклатура.Наименование = "Неопознанная номенклатура (" + Строка(Объект.Номер) + " " + Строка(ТекущаяДата()) + ")"; 
		НоваяНоменклатура.Родитель = Справочники.Номенклатура.НайтиПоНаименованию("Неопознанно");
	    НоваяНоменклатура.ВидНоменклатуры = Справочники.ВидыНоменклатуры.НайтиПоНаименованию("Новый товар");
		НоваяНоменклатура.НеопознанныйТовар = ИСТИНА;
		НоваяНоменклатура.Качество = Перечисления.ГрадацииКачества.Новый;
		
		Справочники.Номенклатура.ЗаполнитьРеквизитыПоВидуНоменклатуры(НоваяНоменклатура);

	    НоваяНоменклатура.Записать();

        ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат СсылкаНовойНоменклатуры;  
	
КонецФункции

&НаКлиенте
Процедура ДобавитьНеопознанныйТоварЗавершение(НеопознанныйТовар, ДопПараметры) Экспорт 
	
	Если НеопознанныйТовар <> Неопределено Тогда 
		НоваяСтрока = Объект.Товары.Добавить();
		НоваяСтрока.Номенклатура = НеопознанныйТовар; 
		НоменклатураПриИзмененииСервер(КэшированныеЗначения);
	КонецЕсли;
	
КонецПроцедуры 

#КонецОбласти 

&НаКлиенте
Процедура Док__ПодобратьТоварыПосле(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда
		
		ОчиститьСообщения();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Поле ""Склад"" не заполнено'"), Объект.Ссылка, "Объект.СкладОтправитель");
		Возврат;
		
	КонецЕсли;

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Склад",                                     Объект.Склад);
	ПараметрыФормы.Вставить("РежимПодбораБезСуммовыхПараметров",         Истина);
	ПараметрыФормы.Вставить("СкрыватьКолонкуВидЦены",                    Истина);
	ПараметрыФормы.Вставить("СкрыватьКомандуЦеныНоменклатуры",           Истина);
	ПараметрыФормы.Вставить("ОтборПоТипуНоменклатуры",                   Новый ФиксированныйМассив(НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТаре(Ложь)));
	ПараметрыФормы.Вставить("Заголовок",                                 НСтр("ru = 'Подбор товаров'"));
	ПараметрыФормы.Вставить("Дата",                                      Объект.Дата);
	ПараметрыФормы.Вставить("Документ",                                  Объект.Ссылка);
	ПараметрыФормы.Вставить("ПараметрыУказанияСерий",                    ПараметрыУказанияСерий);
	
	ОткрытьФорму("Обработка.ПодборТоваровВДокументПродажи.Форма", ПараметрыФормы, ЭтаФорма, УникальныйИдентификатор);

КонецПроцедуры

&НаКлиенте
Процедура Док_ОбработкаВыбораПосле(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ИсточникВыбора.ИмяФормы = "Обработка.ПодборТоваровВДокументПродажи.Форма.Форма" Тогда

		ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение);

	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораПодборНаСервере(ВыбранноеЗначение)

	ТаблицаТоваров = ПолучитьИзВременногоХранилища(ВыбранноеЗначение.АдресТоваровВХранилище);
	
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
	//СтруктураДействий.Вставить("ЗаполнитьПризнакАртикул", Новый Структура("Номенклатура", "Артикул"));
	//СтруктураДействий.Вставить("ЗаполнитьПризнакТипНоменклатуры", Новый Структура("Номенклатура", "ТипНоменклатуры"));
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	Для Каждого СтрокаТовара Из ТаблицаТоваров Цикл
		
		ТекущаяСтрока = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(ТекущаяСтрока, СтрокаТовара, "Номенклатура, Характеристика, ХарактеристикиИспользуются, Упаковка, КоличествоУпаковок,Количество");
		//ОбновитьОтклоненияОтЗаказаВСтроке(ТекущаяСтрока, Объект.ПеремещениеПоЗаказам);
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
		//ТекущаяСтрока.ЗаказНаПеремещение = ЗаказВСтрокеСверхЗаказа(Объект.ПеремещениеПоЗаказам, Объект.ЗаказНаПеремещение);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Док__ЗаполнитьПоРаспоряжениюПосле(Команда)
	ЗаполнитьПоРаспоряжениюБезУчетаДанныхПоОтгрузки();
КонецПроцедуры

Процедура ЗаполнитьПоРаспоряжениюБезУчетаДанныхПоОтгрузки()
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Склад", Объект.Склад);
	Запрос.УстановитьПараметр("Распоряжение", Объект.Распоряжение);
	Запрос.УстановитьПараметр("Отправитель", Объект.Отправитель);
	Запрос.УстановитьПараметр("РабочийУчасток", Объект.РабочийУчасток);
	
	Если ЗначениеЗаполнено(Объект.Дата) Тогда
		Запрос.УстановитьПараметр("ДатаОстатков", КонецДня(Объект.Дата));
	Иначе
		Запрос.УстановитьПараметр("ДатаОстатков", Объект.Дата);
	КонецЕсли;
	
	Объект.Товары.Очистить();
	
	ТекстЗапроса =
	    "ВЫБРАТЬ
		|	ТоварыКПоступлению.Номенклатура КАК Номенклатура,
		|	ТоварыКПоступлению.Характеристика КАК Характеристика,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ТоварыКПоступлению.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ТоварыКПоступлению.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ КАК Назначение,
		|	СУММА(ТоварыКПоступлению.Количество) КАК Количество,
		|	СУММА(ТоварыКПоступлению.Количество) КАК КоличествоУпаковок
		|ИЗ
		|	(ВЫБРАТЬ
		|		ТоварыКПоступлению.Номенклатура КАК Номенклатура,
		|		ТоварыКПоступлению.Характеристика КАК Характеристика,
		|		ТоварыКПоступлению.Назначение КАК Назначение,
		|		ТоварыКПоступлению.КОформлениюОрдеровОстаток - ТоварыКПоступлению.ПринимаетсяОстаток КАК Количество
		|	ИЗ
		|		РегистрНакопления.ТоварыКПоступлению.Остатки(
		|				&ДатаОстатков,
		|				ДокументПоступления = &Распоряжение
		|					И Отправитель = &Отправитель
		|					И Склад = &Склад) КАК ТоварыКПоступлению
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ТоварыКПоступлению.Номенклатура,
		|		ТоварыКПоступлению.Характеристика,
		|		ТоварыКПоступлению.Назначение,
		|		ВЫБОР
		|			КОГДА ТоварыКПоступлению.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|				ТОГДА -ТоварыКПоступлению.КОформлениюОрдеров
		|			ИНАЧЕ ТоварыКПоступлению.КОформлениюОрдеров
		|		КОНЕЦ - ВЫБОР
		|			КОГДА ТоварыКПоступлению.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|				ТОГДА -ТоварыКПоступлению.Принимается
		|			ИНАЧЕ ТоварыКПоступлению.Принимается
		|		КОНЕЦ
		|	ИЗ
		|		РегистрНакопления.ТоварыКПоступлению КАК ТоварыКПоступлению
		|	ГДЕ
		|		ТоварыКПоступлению.Регистратор = &Ссылка
		|		И ТоварыКПоступлению.Активность
		|		И ТоварыКПоступлению.Склад = &Склад
		|		И ТоварыКПоступлению.ДокументПоступления = &Распоряжение) КАК ТоварыКПоступлению
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО (ТоварыКПоступлению.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|ГДЕ
		|	ВЫБОР
		|			КОГДА НЕ РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка ЕСТЬ NULL
		|				ТОГДА РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток = &РабочийУчасток
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыКПоступлению.Номенклатура,
		|	ТоварыКПоступлению.Характеристика,
		|	ТоварыКПоступлению.Назначение,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ТоварыКПоступлению.Назначение.ДвиженияПоСкладскимРегистрам, ЛОЖЬ)
		|			ТОГДА ТоварыКПоступлению.Назначение
		|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.Назначения.ПустаяСсылка)
		|	КОНЕЦ
		|
		|ИМЕЮЩИЕ
		|	СУММА(ТоварыКПоступлению.Количество) > 0";
	
	Запрос.Текст = ТекстЗапроса;
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		
		Объект.Товары.Загрузить(Результат.Выгрузить());
		НоменклатураСервер.РазбитьТоварыПоТоварнымМестам(Объект.Товары);
		
	Иначе
		
		ТекстСообщения = НСтр("ru = 'Нет товаров для заполнения по распоряжению ""%Распоряжение%"" от отправителя %Отправитель%.'");
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Распоряжение%", Объект.Распоряжение);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%Отправитель%", Объект.Отправитель);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, ЭтотОбъект, "Распоряжение");
		
	КонецЕсли;
	
	ВсегоМест = УпаковочныеЛистыСервер.КоличествоМестВТЧ(Объект.Товары);
	

КонецПроцедуры

&НаСервере
Процедура ЗаблокироватьВсёНаСервере(ПричинаБлокировки)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Объект.Проведен Тогда
		
		БлокировкиПоПриходномуОрдеру = Альтерра_СкладСервер.ПолучитьБлокировкиПоОснования(Объект.Ссылка).Выгрузить();
		
		Если БлокировкиПоПриходномуОрдеру.Количество() = 0 Тогда
			
			ДокументБлокировки = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
			
			ПараметрыЗаполнения = Новый Структура();
			ПараметрыЗаполнения.Вставить("Дата", Объект.Дата);
			ПараметрыЗаполнения.Вставить("Склад",Объект.Склад);
			ПараметрыЗаполнения.Вставить("ДокументОснование",Объект.Ссылка);
			ПараметрыЗаполнения.Вставить("Статус",Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано);
			ПараметрыЗаполнения.Вставить("ПричинаБлокировки",Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию(ПричинаБлокировки));
			ПараметрыЗаполнения.Вставить("Комментарий","Создан по кнопке 'Заблокировать всё на брак'");
			ПараметрыЗаполнения.Вставить("Товары",Объект.Товары);
			
			Альтерра_СкладСервер.СоздатьИзменитьБлокировкуДвиженияТоваров(ДокументБлокировки,ПараметрыЗаполнения);
			
		Иначе
			Сообщить("По данному основанию уже созданы блокировки движения товаров!");
		КонецЕсли;
		
	Иначе
		Сообщить("Документ не проведен!");
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&НаКлиенте
Процедура Док__ЗаблокироватьВсёНаБракОтПокупателейПосле(Команда)
	ЗаблокироватьВсёНаСервере("Брак от покупателей");
КонецПроцедуры


&НаКлиенте
Процедура Док__СортировкаПоЯчейкеПосле(Команда)
	СортировкаПоЯчейке();
КонецПроцедуры

&НаСервере
Процедура СортировкаПоЯчейке()
	
	Если Объект.Товары.Количество()>0 Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
		|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
		|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
		|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
		|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	ВнешняяТаблицаНоменклатуры.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
		|	ВнешняяТаблицаНоменклатуры.Штрихкод КАК Штрихкод,
		|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
		|	ВнешняяТаблицаНоменклатуры.Комментарий КАК Комментарий,
		|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
		|ПОМЕСТИТЬ ВнешняяТаблицаНоменклатуры
		|ИЗ
		|	&ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВнешняяТаблицаНоменклатуры.Номенклатура КАК Номенклатура,
		|	ВнешняяТаблицаНоменклатуры.Характеристика КАК Характеристика,
		|	ВнешняяТаблицаНоменклатуры.Количество КАК Количество,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.Наименование КАК ЯчейкаНаименование,
		|	ВнешняяТаблицаНоменклатуры.Назначение КАК Назначение,
		|	ВнешняяТаблицаНоменклатуры.Упаковка КАК Упаковка,
		|	ВнешняяТаблицаНоменклатуры.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВнешняяТаблицаНоменклатуры.СтатусУказанияСерий КАК СтатусУказанияСерий,
		|	ВнешняяТаблицаНоменклатуры.ДокументОтгрузки КАК ДокументОтгрузки,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛист КАК УпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.УпаковочныйЛистРодитель КАК УпаковочныйЛистРодитель,
		|	ВнешняяТаблицаНоменклатуры.Штрихкод КАК Штрихкод,
		|	ВнешняяТаблицаНоменклатуры.ЭтоУпаковочныйЛист КАК ЭтоУпаковочныйЛист,
		|	ВнешняяТаблицаНоменклатуры.ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста КАК ЭтоСлужебнаяСтрокаПустогоУпаковочногоЛиста,
		|	ВнешняяТаблицаНоменклатуры.Комментарий КАК Комментарий,
		|	ВнешняяТаблицаНоменклатуры.Серия КАК Серия
		|ИЗ
		|	ВнешняяТаблицаНоменклатуры КАК ВнешняяТаблицаНоменклатуры
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО ВнешняяТаблицаНоменклатуры.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЯчейкаНаименование";
		
		Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры",Объект.Товары.Выгрузить());
		Запрос.УстановитьПараметр("Склад",Объект.Склад);
				
		Объект.Товары.Очистить();
        Объект.Товары.Загрузить(Запрос.Выполнить().Выгрузить());

	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

&НаКлиенте
Процедура Док__ИзменитьРаспоряжениеПослеНаКлиенте(ВыбранноеЗначение, Параметры) Экспорт
	Док__ИзменитьРаспоряжениеПослеНаСервере(ВыбранноеЗначение,Параметры);
КонецПроцедуры

&НаСервере
Процедура Док__ИзменитьРаспоряжениеПослеНаСервере(ВыбранноеЗначение, Параметры) 
	УстановитьПривилегированныйРежим(Истина);
	Если ВыбранноеЗначение <> Неопределено Тогда
		
		ДокументОбъект = Объект.Ссылка.ПолучитьОбъект();
		
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ВыбранноеЗначение);
		
		СкладскаяОперация = СкладыКлиентСервер.СкладскаяОперацияПриемкиПоХозяйственнойОперации(ДокументОбъект.ХозяйственнаяОперация);
		
		Если СкладскаяОперация <> Объект.СкладскаяОперация Тогда
			ДокументОбъект.СкладскаяОперация = СкладскаяОперация;
		КонецЕсли;
		
		ДокументОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры


&НаКлиенте
Процедура Док__ИзменитьРаспоряжениеПосле(Команда)
	ПараметрыФормыВыбораРаспоряжения = Новый Структура;
	ПараметрыФормыВыбораРаспоряжения.Вставить("Склад", Объект.Склад);
	ПараметрыФормыВыбораРаспоряжения.Вставить("Отправитель", Объект.Отправитель);
	ПараметрыФормыВыбораРаспоряжения.Вставить("ХозяйственнаяОперация", Объект.ХозяйственнаяОперация);
		
	ОписаниеОповещения = Новый ОписаниеОповещения("Док__ИзменитьРаспоряжениеПослеНаКлиенте", ЭтотОбъект);
		
	ОткрытьФорму("Документ.ПриходныйОрдерНаТовары.Форма.ВыборРаспоряжения",
						ПараметрыФормыВыбораРаспоряжения,
						ЭтотОбъект,
						,
						,
						,
						ОписаниеОповещения,
						РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	ЭтаФорма.ОбновитьОтображениеДанных();
КонецПроцедуры

&НаКлиенте
&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, ПараметрыЗаписи)
	Объект.СостояниеЗаполненияМногооборотнойТары=ПредопределенноеЗначение("Перечисление.СостоянияЗаполненияМногооборотнойТары.НеПредлагатьЗаполнить");
конецПроцедуры

&НаКлиенте
&Перед("ИзменитьКачествоНоменклатурыЗавершение")
Процедура Док_ИзменитьКачествоНоменклатурыЗавершение(Результат, ДополнительныеПараметры)
	Если ЗначениеЗаполнено(Результат.Назначение) И СтрНайти(Строка(Результат.Номенклатура), "н/к") > 0 Тогда
		Результат.Назначение = Неопределено;
	КонецЕсли;
КонецПроцедуры

#Область Блокировка

&НаСервере
Функция СозданНаОсновеПеремещенияТоваров()
    Если ТипЗнч(Объект.Распоряжение) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
        Возврат Истина;
    Иначе 
        Возврат Ложь;
    КонецЕсли
КонецФункции

&НаСервере
Процедура СоздатьБлокировку(ПричинаБлокировки, Комментарий)
	УстановитьПривилегированныйРежим(Истина);

	ДокументБлокировки = Документы.БлокировкаДвиженияТоваров.СоздатьДокумент();
	
	ПараметрыЗаполнения = Новый Структура();
	ПараметрыЗаполнения.Вставить("Дата", ТекущаяДата());
	ПараметрыЗаполнения.Вставить("Склад",Объект.Склад);
	ПараметрыЗаполнения.Вставить("ДокументОснование",Объект.Ссылка);
	ПараметрыЗаполнения.Вставить("Статус",Перечисления.СтатусыБлокировкиДвиженияНоменклатуры.Заблокировано);
	ПараметрыЗаполнения.Вставить("ПричинаБлокировки",Справочники.ПричиныБлокировкиДвиженияТоваров.НайтиПоНаименованию(ПричинаБлокировки));
	ПараметрыЗаполнения.Вставить("Комментарий", Комментарий);
  
	ПараметрыЗаполнения.Вставить("Товары", ПолучитьТЗТовары(Элементы.Товары.ВыделенныеСтроки));
	
	Альтерра_СкладСервер.СоздатьИзменитьБлокировкуДвиженияТоваров(ДокументБлокировки,ПараметрыЗаполнения, Истина);
	
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

&НаСервере
Функция ПолучитьТЗТовары(мТовары)
	ТЗ = Новый ТаблицаЗначений;
	ТЗ.Колонки.Добавить("Номенклатура");
	ТЗ.Колонки.Добавить("Характеристика");
	ТЗ.Колонки.Добавить("КоличествоУпаковок");
    Для Каждого стр Из мТовары Цикл         
         Остатки = Альтерра_СкладСервер.ПолучитьОстатки(Объект.Товары[стр].Номенклатура, Объект.Товары[стр].Характеристика, Объект.Склад);
         Разница = Остатки - Объект.Товары[стр].КоличествоУпаковок;
         Если Разница > 0 Тогда
            ЗаполнитьЗначенияСвойств(ТЗ.Добавить(), Объект.Товары[стр]);
         Иначе   
            НС = ТЗ.Добавить();
            ЗаполнитьЗначенияСвойств(НС, Объект.Товары[стр]);
            НС.КоличествоУпаковок = Остатки;   
         КонецЕсли;	 
	КонецЦикла;
	Возврат ТЗ;
КонецФункции

#КонецОбласти  

