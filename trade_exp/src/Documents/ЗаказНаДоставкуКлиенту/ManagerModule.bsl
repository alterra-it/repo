	ИспользуетсяРеглУчет = ПолучитьФункциональнуюОпцию("ИспользоватьРеглУчет");

ТекстЗапроса = 
    "ВЫБРАТЬ
    |	ЗаданиеНаПеревозкуРейсОснования.Ссылка.Ссылка КАК Рейс,
    |	ЗаданиеНаПеревозкуРейсОснования.Ссылка.Перевозчик КАК Перевозчик,
    |	ЗаданиеНаПеревозкуРейсОснования.Ссылка.Водитель КАК Водитель
    |ИЗ
    |	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК ЗаданиеНаПеревозкуРейсОснования
    |ГДЕ
    |	ЗаданиеНаПеревозкуРейсОснования.Документ В (&МассивОбъектов)";
     Запрос = Новый Запрос(ТекстЗапроса);
     Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
     Результат = Запрос.Выполнить();
	 ФИОПолучателя = Результат.Выгрузить()[0].Водитель;
	 
	 ДокументыПолучателя = Новый Структура;
	 ДокументыПолучателя.Вставить("ВидДокумента","");
	 ДокументыПолучателя.Вставить("КодМВД","");
	 ДокументыПолучателя.Вставить("Серия","");
	 ДокументыПолучателя.Вставить("Номер","");
	 ДокументыПолучателя.Вставить("ДатаВыдачи","");
	 ДокументыПолучателя.Вставить("КемВыдан","");
	 ДокументыПолучателя.Вставить("КодПодразделения","");
	 ДокументыПолучателя.Вставить("ЯвляетсяДокументомУдостоверяющимЛичность","");
	 ДокументыПолучателя.Вставить("Представление","");
	 ФизическиеЛицаЛокализация.ЗаполнитьДокументФизическогоЛицаПоУмолчанию(ФИОПолучателя,ДокументыПолучателя,,);
	 
	 
	
		ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ДанныеДокумента.Ссылка КАК Ссылка,
	|	ДанныеДокумента.Дата КАК ДатаДокумента,
	|	"" __ "" КАК Номер,
	|	""__"" КАК Организация,
	|	ДанныеДокумента.Организация.Наименование КАК НаименованиеОрганизации,
	|	ДанныеДокумента.Организация.НаименованиеСокращенное КАК НаименованиеОрганизацииСокращенное,
	|	ДанныеДокумента.Организация.Префикс КАК Префикс,
	|	ВЫБОР 
	|		КОГДА ДанныеДокумента.Валюта = ДанныеДокумента.Организация.ВалютаРегламентированногоУчета
	|			ТОГДА ""50.01""
	|		ИНАЧЕ ""50.21""
	|	КОНЕЦ КАК КредитСубсчет,
	|	ДанныеДокумента.Подразделение КАК ПредставлениеПодразделения,
	|	ДанныеДокумента.Контрагент КАК Контрагент,
	|	ДанныеДокумента.Контрагент.Представление КАК КонтрагентПредставление,
	|	&ДокументыПолучателя КАК РеквизитыДокументаУдостоверяющегоЛичность,
	|	ДанныеДокумента.Ссылка КАК Основание,
	|	"" "" КАК Приложение,
	|	ДанныеДокумента.Сдача КАК Сумма,
	|	ДанныеДокумента.Валюта КАК Валюта,
	|	ДанныеДокумента.Организация.ВалютаРегламентированногоУчета КАК ВалютаРегламентированногоУчета,
	|	ДанныеДокумента.Валюта.Представление КАК ВалютаПредставление,
	|	ДанныеДокумента.Организация.КодПоОКПО КАК ОрганизацияПоОКПО,
	|	ДанныеДокумента.Автор.ФизическоеЛицо  КАК Кассир,
	|	""__"" КАК Руководитель,
	|	""__"" КАК ДолжностьРуководителя,
	|	""__"" КАК ГлавныйБухгалтер,
	|	&ФИОПолучателя КАК ФИОПолучателя,
	|	""Выдача денежных средств подотчетнику"" КАК ХозяйственнаяОперация,
	|	""Выдача в подотчет Ст.ДДС"" КАК СтатьяДвиженияДенежныхСредств
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту КАК ДанныеДокумента
	|ГДЕ
	|	ДанныеДокумента.Ссылка В(&МассивДокументов)
	| И ДанныеДокумента.Сдача>0
	|УПОРЯДОЧИТЬ ПО
	|	Номер
	|;";



    Запрос = Новый Запрос(ТекстЗапроса);
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ОтветственныеЛицаСервер.СформироватьВременнуюТаблицуОтветственныхЛицДокументов(МассивОбъектов, МенеджерВременныхТаблиц,,,"ТаблицаОтветственныеЛица");
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	Запрос.УстановитьПараметр("ФИОПолучателя",ФИОПолучателя);
	Запрос.УстановитьПараметр("ДокументыПолучателя","_"); //ДокументыПолучателя.Представление
	МассивРезультатов = Запрос.ВыполнитьПакет();
	Выборка           = МассивРезультатов[0].Выбрать();
	
    ПервыйДокумент = Истина;
	Пока Выборка.Следующий() Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
		//ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьМакета, Выборка.Ссылка);
		ОбластьМакета.Параметры.Заполнить(Выборка);
		
		Если Не ПустаяСтрока(Выборка.НаименованиеОрганизацииСокращенное) Тогда
			ОбластьМакета.Параметры.ПредставлениеОрганизации = ""; //Выборка.НаименованиеОрганизацииСокращенное;
		Иначе
			ОбластьМакета.Параметры.ПредставлениеОрганизации = ""; //Выборка.НаименованиеОрганизации;
		КонецЕсли;
		
		ОбластьМакета.Параметры.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(
			Выборка.Номер,
			Ложь,
			Истина);
		ОбластьМакета.Параметры.ДебетСубсчет = ""; //КорреспондирующийСчет(Выборка, КорСчета, ИспользуетсяРеглУчет);
		
		Сумма = Формат(Выборка.Сумма, "ЧДЦ=2");
		Если Выборка.ВалютаРегламентированногоУчета <> Выборка.Валюта Тогда
			Сумма = Сумма + " " + СокрЛП(Выборка.ВалютаПредставление);
		КонецЕсли;
		ОбластьМакета.Параметры.Сумма = Сумма;
		ОбластьМакета.Параметры.СуммаПрописью = РаботаСКурсамиВалютУТ.СформироватьСуммуПрописью(
			Выборка.Сумма, 
			Выборка.Валюта, 
			Ложь); // ВыводитьСуммуБезКопеек
		
		ОбластьМакета.Параметры.ФИОРуководителя = Выборка.Руководитель;
		ОбластьМакета.Параметры.ФИОГлавногоБухгалтера = Выборка.ГлавныйБухгалтер;
		ОбластьМакета.Параметры.ФИОКассира = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(Выборка.Кассир, Выборка.ДатаДокумента);
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(
			ТабличныйДокумент,
			НомерСтрокиНачало,
			ОбъектыПечати,
			Выборка.Ссылка);
	    Прервать;	
	КонецЦикла;
	
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
КонецФункции


