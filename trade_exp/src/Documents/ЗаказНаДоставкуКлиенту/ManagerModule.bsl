Функция ЕстьУслугиДоставки(ЗаказНаДоставку) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ
	|ПОМЕСТИТЬ ДокПродажи
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
	|ГДЕ
	|	ЗаказНаДоставкуКлиентуОснования.Ссылка = &ЗаказНаДоставку
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.Упаковка КАК Упаковка,
	|	РеализацияТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	РеализацияТоваровУслугТовары.Количество КАК Количество,
	|	РеализацияТоваровУслугТовары.Цена КАК Цена,
	|	РеализацияТоваровУслугТовары.Сумма КАК Сумма,
	|	РеализацияТоваровУслугТовары.Склад КАК Склад,
	|	РеализацияТоваровУслугТовары.Характеристика КАК Характеристика,
	|	РеализацияТоваровУслугТовары.Ссылка КАК ДокПродажи
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокПродажи.Документ КАК Документ
	|			ИЗ
	|				ДокПродажи КАК ДокПродажи)
	|	И РеализацияТоваровУслугТовары.Номенклатура В ИЕРАРХИИ(&грУслугДоставки)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Номенклатура,
	|	ЧекККМТовары.Упаковка,
	|	ЧекККМТовары.КоличествоУпаковок,
	|	ЧекККМТовары.Количество,
	|	ЧекККМТовары.Цена,
	|	ЧекККМТовары.Сумма,
	|	ЧекККМТовары.Ссылка.Склад,
	|	ЧекККМТовары.Характеристика,
	|	ЧекККМТовары.Ссылка
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|ГДЕ
	|	ЧекККМТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокПродажи.Документ КАК Документ
	|			ИЗ
	|				ДокПродажи КАК ДокПродажи)
	|	И ЧекККМТовары.Номенклатура В ИЕРАРХИИ(&грУслугДоставки)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура,
	|	РеализацияТоваровУслугТовары.Упаковка,
	|	РеализацияТоваровУслугТовары.КоличествоУпаковок,
	|	РеализацияТоваровУслугТовары.Количество,
	|	РеализацияТоваровУслугТовары.Цена,
	|	РеализацияТоваровУслугТовары.Сумма,
	|	РеализацияТоваровУслугТовары.Склад,
	|	РеализацияТоваровУслугТовары.Характеристика,
	|	РеализацияТоваровУслугТовары.Ссылка
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Номенклатура В ИЕРАРХИИ(&грУслугДоставки)
	|	И РеализацияТоваровУслугТовары.Ссылка.ЗаказКлиента В
	|			(ВЫБРАТЬ
	|				ДокПродажи.Документ КАК Документ
	|			ИЗ
	|				ДокПродажи КАК ДокПродажи)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура,
	|	ЗаказКлиентаТовары.Упаковка,
	|	ЗаказКлиентаТовары.КоличествоУпаковок,
	|	ЗаказКлиентаТовары.Количество,
	|	ЗаказКлиентаТовары.Цена,
	|	ЗаказКлиентаТовары.Сумма,
	|	ЗаказКлиентаТовары.Склад,
	|	ЗаказКлиентаТовары.Характеристика,
	|	ЗаказКлиентаТовары.Ссылка
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Номенклатура В ИЕРАРХИИ(&грУслугДоставки)
	|	И ЗаказКлиентаТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				ДокПродажи.Документ КАК Документ
	|			ИЗ
	|				ДокПродажи КАК ДокПродажи)";
	
	Запрос.УстановитьПараметр("грУслугДоставки", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую());
	Запрос.УстановитьПараметр("ЗаказНаДоставку", ЗаказНаДоставку);
	
	РезультатЗапроса = Запрос.Выполнить();
	
		УстановитьПривилегированныйРежим(Ложь);
		
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции  

//Перед записью
Процедура ПроверитьНаДублиОснований(Объект, Отказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ,
		|	1 КАК Количество
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	&Основания КАК ЗаказНаДоставкуКлиентуОснования
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Документ КАК Документ,
		|	СУММА(1) КАК Количество
		|ПОМЕСТИТЬ ВТ2
		|ИЗ
		|	ВТ КАК ВТ
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ.Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ2.Документ КАК Документ,
		|	ВТ2.Количество КАК Количество
		|ИЗ
		|	ВТ2 КАК ВТ2
		|ГДЕ
		|	ВТ2.Количество > 1";
	
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Отказ= Истина;
		Сообщить("В документе есть дубли оснований! "+ВыборкаДетальныеЗаписи.Документ);
		
	КонецЦикла;
	
КонецПроцедуры
	
Процедура ПроверитьНаТипыДокументов(Объект, Отказ)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Основания.Документ КАК Документ
		|ПОМЕСТИТЬ ВТОснования
		|ИЗ
		|	&Основания КАК Основания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВЫБОР
		|			КОГДА Основания.Документ ССЫЛКА Документ.ПеремещениеТоваров
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК КоличествоПеремещений,
		|	СУММА(ВЫБОР
		|			КОГДА Основания.Документ ССЫЛКА Документ.ОбращениеКлиента
		|				ТОГДА 1
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК КоличествоОбращений,
		|	КОЛИЧЕСТВО(Основания.Документ) КАК КоличествоДокументов
		|ИЗ
		|	ВТОснования КАК Основания";
	
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	Если РезультатЗапроса.Следующий() Тогда
		Если РезультатЗапроса.КоличествоОбращений = 0 Тогда
			Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя И 
				РезультатЗапроса.КоличествоПеремещений <> РезультатЗапроса.КоличествоДокументов Тогда
				
				ОбщегоНазначения.СообщитьПользователю("Во внутренней доставке запрещено использовать документы продажи");
				Отказ = Истина;
			ИначеЕсли (Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная ИЛИ 
				Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК) И
				РезультатЗапроса.КоличествоПеремещений <> 0 Тогда
				
				ОбщегоНазначения.СообщитьПользователю("В доставке клиентам запрещено использовать перемещения");
				Отказ = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;  
	
КонецПроцедуры  

#КонецОбласти 

#Область СозданиеНаОсновании
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСоздатьНаОсновании) Экспорт
	
	ИмяДокумента= "ЗаказНаДоставкуКлиенту";
	Если ПравоДоступа("Добавление", Метаданные.Документы[ИмяДокумента]) Тогда
		КомандаСоздатьНаОсновании = КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Менеджер = Метаданные.Документы[ИмяДокумента].ПолноеИмя();
		КомандаСоздатьНаОсновании.Идентификатор = Метаданные.Документы[ИмяДокумента].ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление = ОбщегоНазначенияУТ.ПредставлениеОбъекта(Метаданные.Документы[ИмяДокумента]);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";
		КомандаСоздатьНаОсновании.Важность = "Важное";
		
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;  
	
КонецФункции

#КонецОбласти 

#Область АвтоопределениеДистрибуция
Процедура УстановитьСтоимостьПоДокументуПродажи(Объект)Экспорт
	
	Если ЗначениеЗаполнено(Объект.СтоимостьДляКлиента) Тогда
		ДокументОснование = Объект.Основания[0].Документ;// для вида ДистрибуцияСборныеГрузы только одно основание 
		Результат = УправлениеЛогистикойСервер.РаспределениеСтоимостиДоставкиДистрибуция(Объект,ДокументОснование.Товары.Выгрузить(),Истина,ДокументОснование.Склад,Объект.СтоимостьДляКлиента);
		Объект.СтоимостьДоставкиПоДокументуПродажи = Результат.СтоимостьДоставки;
	Иначе
		Объект.СтоимостьДоставкиПоДокументуПродажи = 0;
	КонецЕсли;

КонецПроцедуры
