Функция ПолучитьТоварОснований(мОснований) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Ссылка КАК Документ,
		|	РеализацияТоваровУслугТовары.Ссылка.Контрагент КАК Контрагент,
		|	РеализацияТоваровУслугТовары.Ссылка.ПрибытиеНаОтгрузку КАК ПрибытиеНаОтгрузку,
		|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
		|	СУММА(РеализацияТоваровУслугТовары.КоличествоУпаковок) КАК Количество,
		|	ВЫБОР
		|		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|			ТОГДА РеализацияТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
		|		ИНАЧЕ РеализацияТоваровУслугТовары.Упаковка.ЕдиницаИзмерения
		|	КОНЕЦ КАК ЕдИзм,
		|	СУММА(РеализацияТоваровУслугТовары.Цена) КАК Цена,
		|	СУММА(РеализацияТоваровУслугТовары.СуммаСНДС) КАК Сумма,
		|	СУММА(РеализацияТоваровУслугТовары.СуммаНДС) КАК СуммаНДС,
		|	РеализацияТоваровУслугТовары.Ссылка.Дата КАК Дата,
		|	СУММА(РеализацияТоваровУслугТовары.СуммаРучнойСкидки + РеализацияТоваровУслугТовары.СуммаАвтоматическойСкидки) КАК СуммаСкидки,
		|	РеализацияТоваровУслугТовары.Номенклатура.Код КАК Код,
		|	ЕСТЬNULL(РеализацияТоваровУслугТовары.Склад.Ссылка, РеализацияТоваровУслугТовары.Ссылка.Склад) КАК Склад,
		|	РеализацияТоваровУслугТовары.Характеристика КАК Характеристика
		|ПОМЕСТИТЬ ВТ_Товары
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка В(&МассивДокументов)
		|	И НЕ РеализацияТоваровУслугТовары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
		|
		|СГРУППИРОВАТЬ ПО
		|	РеализацияТоваровУслугТовары.Ссылка,
		|	РеализацияТоваровУслугТовары.Номенклатура,
		|	ВЫБОР
		|		КОГДА РеализацияТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|			ТОГДА РеализацияТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
		|		ИНАЧЕ РеализацияТоваровУслугТовары.Упаковка.ЕдиницаИзмерения
		|	КОНЕЦ,
		|	РеализацияТоваровУслугТовары.Ссылка.ПрибытиеНаОтгрузку,
		|	РеализацияТоваровУслугТовары.Ссылка.Дата,
		|	РеализацияТоваровУслугТовары.Ссылка.Контрагент,
		|	РеализацияТоваровУслугТовары.Номенклатура.Код,
		|	РеализацияТоваровУслугТовары.Склад,
		|	РеализацияТоваровУслугТовары.Характеристика,
		|	ЕСТЬNULL(РеализацияТоваровУслугТовары.Склад.Ссылка, РеализацияТоваровУслугТовары.Ссылка.Склад)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Товары.Ссылка,
		|	Товары.Ссылка.Контрагент,
		|	NULL,
