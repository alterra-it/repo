		|	ЗаказКлиентаТовары.Ссылка,
		|	ЗаказКлиентаТовары.Номенклатура,
		|	ВЫБОР
		|		КОГДА ЗаказКлиентаТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|			ТОГДА ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения
		|		ИНАЧЕ ЗаказКлиентаТовары.Упаковка.ЕдиницаИзмерения
		|	КОНЕЦ,
		|	ЗаказКлиентаТовары.Ссылка.ПрибытиеНаОтгрузку,
		|	ЗаказКлиентаТовары.Ссылка.Дата,
		|	ЗаказКлиентаТовары.Ссылка.Контрагент,
		|	ЗаказКлиентаТовары.Номенклатура.Код,
		|	ЗаказКлиентаТовары.Склад,
		|	ЗаказКлиентаТовары.Характеристика,
		|	ЕСТЬNULL(ЗаказКлиентаТовары.Склад.Ссылка, ЗаказКлиентаТовары.Ссылка.Склад)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТВозвраты.Номенклатура КАК Номенклатура,
		|	ВТВозвраты.Характеристика КАК Характеристика,
		|	ВТВозвраты.Упаковка КАК Упаковка,
		|	СУММА(ВТВозвраты.Количество) КАК Количество,
		|	СУММА(ВТВозвраты.Сумма) КАК Сумма,
		|	ВТВозвраты.ДокументРеализации КАК ДокументРеализации
		|ПОМЕСТИТЬ ВТ_Возвраты
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВозвратТоваровОтКлиентаТовары.Номенклатура КАК Номенклатура,
		|		ВозвратТоваровОтКлиентаТовары.Характеристика КАК Характеристика,
		|		ВозвратТоваровОтКлиентаТовары.Упаковка КАК Упаковка,
		|		СУММА(ВозвратТоваровОтКлиентаТовары.Количество) КАК Количество,
		|		СУММА(ВозвратТоваровОтКлиентаТовары.Сумма) КАК Сумма,
		|		ВозвратТоваровОтКлиентаТовары.Ссылка.ДокументРеализации КАК ДокументРеализации
		|	ИЗ
		|		Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
		|	ГДЕ
		|		ВозвратТоваровОтКлиентаТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
		|		И ВозвратТоваровОтКлиентаТовары.ДокументРеализации В(&МассивДокументов)
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВозвратТоваровОтКлиентаТовары.Характеристика,
		|		ВозвратТоваровОтКлиентаТовары.Номенклатура,
		|		ВозвратТоваровОтКлиентаТовары.Упаковка,
		|		ВозвратТоваровОтКлиентаТовары.Ссылка.ДокументРеализации
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ЧекККМВозвратТовары.Номенклатура,
		|		ЧекККМВозвратТовары.Характеристика,
		|		ЧекККМВозвратТовары.Упаковка,
		|		СУММА(ЧекККМВозвратТовары.Количество),
		|		СУММА(ЧекККМВозвратТовары.Сумма),
		|		ЧекККМВозвратТовары.Ссылка.ЧекККМ
		|	ИЗ
		|		Документ.ЧекККМВозврат.Товары КАК ЧекККМВозвратТовары
		|	ГДЕ
		|		ЧекККМВозвратТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
		|		И ЧекККМВозвратТовары.Ссылка.ЧекККМ В(&МассивДокументов)
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ЧекККМВозвратТовары.Ссылка.ЧекККМ,
		|		ЧекККМВозвратТовары.Упаковка,
		|		ЧекККМВозвратТовары.Характеристика,
		|		ЧекККМВозвратТовары.Номенклатура
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		КорректировкаРеализацииРасхождения.Номенклатура,
		|		КорректировкаРеализацииРасхождения.Характеристика,
		|		КорректировкаРеализацииРасхождения.Упаковка,
		|		СУММА(-КорректировкаРеализацииРасхождения.Количество),
		|		СУММА(-КорректировкаРеализацииРасхождения.Сумма),
		|		КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование
		|	ИЗ
		|		Документ.КорректировкаРеализации.Расхождения КАК КорректировкаРеализацииРасхождения
		|	ГДЕ
		|		КорректировкаРеализацииРасхождения.Ссылка.ПометкаУдаления = ЛОЖЬ
		|		И КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование В(&МассивДокументов)
		|	
		|	СГРУППИРОВАТЬ ПО
		|		КорректировкаРеализацииРасхождения.Упаковка,
		|		КорректировкаРеализацииРасхождения.Характеристика,
		|		КорректировкаРеализацииРасхождения.Номенклатура,
		|		КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование) КАК ВТВозвраты
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТВозвраты.Номенклатура,
		|	ВТВозвраты.Характеристика,
		|	ВТВозвраты.Упаковка,
		|	ВТВозвраты.ДокументРеализации
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Товары.Документ КАК Документ,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Цена КАК Цена,
		|	Товары.Сумма КАК Сумма,
		|	Товары.Количество КАК Количество,
		|	Товары.Склад КАК Склад,
		|	ЕСТЬNULL(ВТ_Возвраты.Количество, 0) КАК Возврат,
		|	Товары.Количество - ЕСТЬNULL(ВТ_Возвраты.Количество, 0) КАК КВыдаче
		|ИЗ
		|	ВТ_Товары КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Возвраты КАК ВТ_Возвраты
		|		ПО Товары.Номенклатура = ВТ_Возвраты.Номенклатура
		|			И Товары.Документ = ВТ_Возвраты.ДокументРеализации
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура,
		|	Склад";
	
	Запрос.УстановитьПараметр("ГруппаУслугДоставки", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую());
	Запрос.УстановитьПараметр("МассивДокументов", мОснований);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции

Функция ЭтоКонтрагентИсключение(Контрагент) Экспорт
	
	мИНН= Новый Массив;
	мИНН.Добавить("2222058686");//НОВЭКС ООО
	мИНН.Добавить("7724490000");//ПОЧТА РОССИИ АО
	
	Если мИНН.Найти(Контрагент.ИНН) <> Неопределено Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;   
	
КонецФункции

Функция ПолучитьТЗКОплате(ЗаказНаДоставку)  Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
	|ГДЕ
	|	ЗаказНаДоставкуКлиентуОснования.Ссылка = &ЗаказНаДоставку
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ДокументыПродажи
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЧекККМ КАК ЧекККМ
	|		ПО ВТ_Основания.Документ = ЧекККМ.Ссылка
	|ГДЕ
	|	ЧекККМ.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслуг.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заказ.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заказ.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ДокументыПродажи.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТДок
	|ИЗ
	|	ВТ_ДокументыПродажи КАК ВТ_ДокументыПродажи
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РасчетыСКлиентамиОстатки.ЗаказКлиента КАК ЗаказКлиента,
	|	РасчетыСКлиентамиОстатки.СуммаОстаток КАК СуммаОстаток,
	|	РасчетыСКлиентамиОстатки.КОплатеОстаток КАК КОплатеОстаток,
	|	РасчетыСКлиентамиОстатки.ОплачиваетсяОстаток КАК ОплачиваетсяОстаток,
	|	РасчетыСКлиентамиОстатки.КОтгрузкеОстаток КАК КОтгрузкеОстаток,
	|	РасчетыСКлиентамиОстатки.ОтгружаетсяОстаток КАК ОтгружаетсяОстаток
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(
	|			,
	|			ЗаказКлиента В
	|				(ВЫБРАТЬ
	|					ВТДок.Ссылка
	|				ИЗ
	|					ВТДок)) КАК РасчетыСКлиентамиОстатки
	|ГДЕ
	|	РасчетыСКлиентамиОстатки.КОплатеОстаток > 0";
	
	Запрос.УстановитьПараметр("ЗаказНаДоставку", ЗаказНаДоставку);
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТЗ;
	
КонецФункции 

