	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ_Основания.Документ = РеализацияТоваровУслуг.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК Заказ
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|			ПО Заказ.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
	|		ПО ВТ_Основания.Документ = Заказ.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваров.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|		ПО ВТ_Основания.Документ = ПеремещениеТоваров.Ссылка
	|ГДЕ
	|	ПеремещениеТоваров.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОбращениеКлиента.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ОбращениеКлиента КАК ОбращениеКлиента
	|		ПО ВТ_Основания.Документ = ОбращениеКлиента.Ссылка
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиента.Ссылка
	|ИЗ
	|	ВТ_Основания КАК ВТ_Основания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВозвратТоваровОтКлиента КАК ВозвратТоваровОтКлиента
	|		ПО ВТ_Основания.Документ = ВозвратТоваровОтКлиента.Ссылка
	|ГДЕ
	|	ВозвратТоваровОтКлиента.Проведен";
	
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТЗ.ВыгрузитьКолонку("Ссылка");  
	
КонецФункции    

Функция ПолучитьЗаказыКлиентов(Объект)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК ЗаказНаДоставка,
	|	ЗаказНаДоставкуКлиентуОснования.Документ КАК ЗаказКлиента
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
	|ГДЕ
	|	ЗаказНаДоставкуКлиентуОснования.Ссылка = &ЗаказНаДоставка
	|	И ЗаказНаДоставкуКлиентуОснования.Документ.Ссылка ССЫЛКА Документ.ЗаказКлиента
	|	И ЗаказНаДоставкуКлиентуОснования.Документ.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказНаДоставкуКлиентуОснования.Ссылка,
	|	ЗаказНаДоставкуКлиентуОснования.Документ.ЗаказКлиента
	|ИЗ
	|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
	|ГДЕ
	|	ЗаказНаДоставкуКлиентуОснования.Ссылка = &ЗаказНаДоставка
	|	И ЗаказНаДоставкуКлиентуОснования.Документ.Ссылка ССЫЛКА Документ.РеализацияТоваровУслуг
	|	И ЗаказНаДоставкуКлиентуОснования.Документ.Проведен";
	
	Запрос.УстановитьПараметр("ЗаказНаДоставка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	Возврат ТЗ.ВыгрузитьКолонку("ЗаказКлиента");
	
КонецФункции

Функция ЕщёДокументыПродажиЗаСегодня(Объект)  Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЧекККМ.Ссылка КАК Ссылка,
	|	НЕОПРЕДЕЛЕНО КАК ЗаказКлиента
	|ПОМЕСТИТЬ ДокументыПродажи
	|ИЗ
	|	Документ.ЧекККМ КАК ЧекККМ
	|ГДЕ
	|	ЧекККМ.Дата МЕЖДУ &Дата1 И &Дата2
	|	И ЧекККМ.Партнер = &Партнер
	|	И ЧекККМ.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.ЗаказКлиента
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|ГДЕ
	|	РеализацияТоваровУслуг.Дата МЕЖДУ &Дата1 И &Дата2
	|	И РеализацияТоваровУслуг.Партнер = &Партнер
	|	И РеализацияТоваровУслуг.Проведен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыПродажи.Ссылка КАК Ссылка,
	|	ДокументыПродажи.ЗаказКлиента КАК ЗаказКлиента
	|ПОМЕСТИТЬ ВременныйПакетДокументовПродажи
	|ИЗ
	|	ДокументыПродажи КАК ДокументыПродажи
	|ГДЕ
	|	НЕ ДокументыПродажи.Ссылка В (&Основания)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВременныйПакетДокументовПродажи.Ссылка КАК Ссылка
	|ИЗ
	|	ВременныйПакетДокументовПродажи КАК ВременныйПакетДокументовПродажи
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
	|		ПО (ВременныйПакетДокументовПродажи.Ссылка = ЗаказНаДоставкуКлиентуОснования.Документ
	|				ИЛИ ВременныйПакетДокументовПродажи.ЗаказКлиента = ЗаказНаДоставкуКлиентуОснования.Документ)
	|ГДЕ
	|	(ЗаказНаДоставкуКлиентуОснования.Ссылка ЕСТЬ NULL
	|			ИЛИ ЗаказНаДоставкуКлиентуОснования.Ссылка.ПометкаУдаления
	|			ИЛИ НЕ ЗаказНаДоставкуКлиентуОснования.Ссылка.Проведен)";
	
		
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить().ВыгрузитьКолонку("Документ"));
	Запрос.УстановитьПараметр("Дата1", НачалоДня(ТекущаяДата()));   
	Запрос.УстановитьПараметр("Дата2", КонецДня(ТекущаяДата()));     
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер);
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ = РезультатЗапроса.Выгрузить();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ТЗ.ВыгрузитьКолонку("Ссылка");  
	
КонецФункции

Процедура ПеренестиЗоныВМакет(стрМакет, Подразделение, ВидДоставки) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗоныДоставкиДоКлиента.Ссылка КАК Ссылка,
	|	ЗоныДоставкиДоКлиента.Наименование КАК Наименование,
	|	ЗоныДоставкиДоКлиента.Координаты КАК Координаты,
	|	ЗоныДоставкиДоКлиента.Цвет КАК Цвет
	|ИЗ
	|	Справочник.ЗоныДоставкиДоКлиента КАК ЗоныДоставкиДоКлиента
	|ГДЕ
	|	ЗоныДоставкиДоКлиента.Подразделение = &Подразделение
	|	И ЗоныДоставкиДоКлиента.ПометкаУдаления = ЛОЖЬ
	|	И ЗоныДоставкиДоКлиента.ВидДоставки = &ВидДоставки
	|	И ЗоныДоставкиДоКлиента.Подразделение <> ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("ВидДоставки", ВидДоставки);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	стрФункций= "";
	стрСобытий= "";
	сч= 0;
	Пока Выборка.Следующий() Цикл
		стр1= СтрШаблон("var arCoordsZone = GetCoordsZone('%1');", Выборка.Координаты);
		стр2= СтрШаблон("Polygon%1 = new ymaps.Polygon(arCoordsZone, {hintContent: '%2'}, {fillColor: '#%3', strokeColor: strokeColor, strokeWidth: strokeWidth, opacity: opacity});", сч, Выборка.Наименование, Выборка.Цвет);
		стр3= СтрШаблон("AddEventPoligon(Polygon%1);", сч);
		стрФункций= стрФункций + стр1+Символы.ПС+стр2+Символы.ПС+стр3+Символы.ПС+Символы.ПС;
		
		стр1= СтрШаблон("if (Polygon%1.geometry.contains(position)) {", сч);
		стр2= СтрШаблон("document.getElementById('ans').value = Polygon%1.properties._data.hintContent;}", сч);
		стрСобытий= стрСобытий + стр1+Символы.ПС+стр2+Символы.ПС+Символы.ПС;
		
		сч= сч+1;
	КонецЦикла;
	
	стрМакет= СтрЗаменить(стрМакет, "#стрФункций#", стрФункций);
	стрМакет= СтрЗаменить(стрМакет, "#стрСобытий#", стрСобытий); 
	
КонецПроцедуры

Функция ПолучитьСтоимостьЗаКмПоТарифу(Подразделение, Тариф)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СтоимостьДоставкиПоРасстоянию.Подразделение КАК Подразделение,
		|	СтоимостьДоставкиПоРасстоянию.Тариф КАК Тариф,
		|	СтоимостьДоставкиПоРасстоянию.Стоимость КАК Стоимость
		|ИЗ
		|	РегистрСведений.СтоимостьДоставкиПоРасстоянию КАК СтоимостьДоставкиПоРасстоянию
		|ГДЕ
		|	СтоимостьДоставкиПоРасстоянию.Подразделение = &Подразделение
		|	И СтоимостьДоставкиПоРасстоянию.Тариф = &Тариф";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("Тариф", Тариф);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Стоимость;
	Иначе
		Возврат 0;
	КонецЕсли; 
	
КонецФункции

Функция ПолучитьКоличествоЗаказовНаДОставку(НаДату, Подразделение) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказНаДоставкуКлиенту.Ссылка) КАК КолЗаказов,
		|	ИнтервалыДоставки.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ИнтервалыДоставки КАК ИнтервалыДоставки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|		ПО ИнтервалыДоставки.Ссылка = ЗаказНаДоставкуКлиенту.Интервал
		|			И (ЗаказНаДоставкуКлиенту.Проведен)
		|			И (ЗаказНаДоставкуКлиенту.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная))
		|			И (НАЧАЛОПЕРИОДА(ЗаказНаДоставкуКлиенту.ПрибытиеНаОтгрузку, ДЕНЬ) = НАЧАЛОПЕРИОДА(&НаДату, ДЕНЬ))
		|ГДЕ
		|	ИнтервалыДоставки.ДеньНедели = &ДеньНедели
		|	И ЗаказНаДоставкуКлиенту.Подразделение = &Подразделение
		|
		|СГРУППИРОВАТЬ ПО
		|	ИнтервалыДоставки.Наименование
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("НаДату", НаДату);
	
	Если ДеньНедели(НаДату) < 6 Тогда
		Запрос.УстановитьПараметр("ДеньНедели", 0);
	Иначе 
		Запрос.УстановитьПараметр("ДеньНедели", ДеньНедели(ТекущаяДата()));
	КонецЕсли	;
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Возврат Выборка; 
	
КонецФункции  

