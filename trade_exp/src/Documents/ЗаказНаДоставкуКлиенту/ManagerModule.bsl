//При проведении Проверим нет ли заказов на доставку ещё в каких то рейсах
Функция ПроверитьЧтоПоДокументамПродажиЕстьДругиеЗаказы(Объект)  Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку,
	|	ЗаказыКДоставке.ДокументПродажи КАК ДокументПродажи
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставке КАК ЗаказыКДоставке
	|ГДЕ
	|	ЗаказыКДоставке.ДокументПродажи В(&мОснований)
	|	И ЗаказыКДоставке.ЗаказНаДоставку <> &Ссылка
	|	И ЗаказыКДоставке.ВидДвижения = &ВидДвижения";
	
	ТЗОснования= Объект.Основания.Выгрузить();
	мОснований= Новый Массив;
	Для Каждого стрОснование Из ТЗОснования Цикл
		Документ= стрОснование.Документ;
		мОснований.Добавить(Документ);
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			Если ЗначениеЗаполнено(Документ.ЗаказКлиента)  Тогда
				мОснований.Добавить(Документ.ЗаказКлиента);
			КонецЕсли;
		ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
			мРеализаций= АльтерраОбщегоНазначения.ПолучитьРеализацииПоЗаказу(Документ);
			Для Каждого Реализация Из мРеализаций Цикл
				мОснований.Добавить(Реализация);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("мОснований", мОснований);
	Запрос.УстановитьПараметр("ВидДвижения", ВидДвиженияНакопления.Приход);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат ВыборкаДетальныеЗаписи;
	
КонецФункции  

