#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область Заполнение
Процедура ЗаполнитьДанныеПоОснованию(Источник, Объект)   Экспорт
	
	Если ЗначениеЗаполнено(Источник) Тогда               
		Объект.Автор = Пользователи.ТекущийПользователь();
		Объект.Статус = Перечисления.СтатусыЗаказовНаДоставку.Ожидает;
		
		Если ТипЗнч(Источник) = Тип("Массив") Тогда
			мОснований= Источник;            
		ИначеЕсли ТипЗнч(Источник) = Тип("Структура") И Объект.ЭтоНовый() Тогда
			ЗаполнитьЗначенияСвойств(Объект, Источник);
			Возврат;
		Иначе
			мОснований= Новый Массив;
			мОснований.Добавить(Источник);
		КонецЕсли;
		
		Для Каждого стрОснование Из мОснований Цикл
			ТЗОснований = Объект.Основания.Выгрузить();
			НоваяСтрока = ТЗОснований.Найти(стрОснование, "Документ");
			Если НоваяСтрока = Неопределено Тогда 
				НоваяСтрока = Объект.Основания.Добавить();
				НоваяСтрока.Документ = стрОснование;
			КонецЕсли;
			Если ТипЗнч(стрОснование) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда 
				Основание = стрОснование;
				ТипЗнчОснование = ТипЗнч(стрОснование);
			КонецЕсли;
		КонецЦикла;
		
		Если Не ЗначениеЗаполнено(Основание) Тогда
			Основание = стрОснование;
			ТипЗнчОснование = ТипЗнч(стрОснование);
		КонецЕсли;
		
		//Общие                                           
		Если ТипЗнчОснование = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			ЗаполнитьПоОбращениюКлиента(Основание, Объект);
		ИначеЕсли ТипЗнчОснование = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
			ЗаполнитьЗначенияСвойств(Объект, Основание, "Партнер, Организация, Подразделение, Контрагент");
		ИначеЕсли ТипЗнчОснование = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ЗаполнитьЗначенияСвойств(Объект, Основание, , "Дата, Номер, Проведен, Комментарий, ПрибытиеНаОтгрузку, АдресДоставки");
		Иначе
			ЗаполнитьЗначенияСвойств(Объект, Основание, , "Дата, Номер, Проведен, Комментарий, ПрибытиеНаОтгрузку, АдресДоставки, Акции");
		КонецЕсли;
	
		ЗаполнитьАдресДоставки(Объект, Основание);
		
		Если ТипЗнчОснование = Тип("ДокументСсылка.ПеремещениеТоваров") или ТипЗнчОснование = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя;
		ИначеЕсли ТипЗнчОснование = Тип("ДокументСсылка.ОбращениеКлиента") ИЛИ ТипЗнчОснование = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда
			Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная;
		КонецЕсли;
		
		АвтоопределениеДистрибуция = Ложь;
				
		Если ТипЗнчОснование <> Тип("ДокументСсылка.ОбращениеКлиента") И ТипЗнчОснование <> Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда  
			
			АвтоопределениеДистрибуция = ДопМодуль.ЕстьСвойствоОбъекта(Основание, "РаспределитьТранспортныеДистрибуция") И Основание.РаспределитьТранспортныеДистрибуция; 
		
			//По перемещениям
			Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
				ЗаполнитьПоПеремещению(Основание, Объект);
				Объект.ТелефонКлиентаНаВыгрузке = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание.СкладПолучатель.Подразделение, "ТелефонДиспетчераПоДоставке");
		        Объект.ЗонаДоставкиДляВодителя = Основание.СкладПолучатель.Подразделение.ЗонаДоставкиДляВодителя;
				
			//По документам продажи
			Иначе			
				Если ТипЗнчОснование <> Тип("ДокументСсылка.ЧекККМ") И Основание.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания Тогда 
					Объект.Контрагент = Основание.Контрагент;
				Иначе
					Объект.Контрагент = Неопределено;
				КонецЕсли;
				
				Если ТипЗнчОснование = Тип("ДокументСсылка.РеализацияТоваровУслуг")  ИЛИ ТипЗнчОснование = Тип("ДокументСсылка.ЗаказКлиента") ИЛИ ТипЗнчОснование = Тип("ДокументСсылка.ЧекККМ") Тогда  
					
					//АвтоопределениеДистрибуция
					Если АвтоопределениеДистрибуция  Тогда
						Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы;  
						ЗаполнитьЗначенияСвойств(Объект,Основание.ОбъектДоставки,"ЗонаДоставкиДляВодителя,Широта,Долгота");
					КонецЕсли;
					//
					Объект.КомментарийДляСклада = Основание.КомментарийДляСклада;
					Объект.НаправлениеДоставки = Основание.Партнер.БизнесРегион;
					
				КонецЕсли;
				
				ОбновитьРеквизитыДоставки(Объект);
			КонецЕсли;
		КонецЕсли;
		
		ОбновитьИтогиПоОснованиям(Объект);
		//АвтоопределениеДистрибуция
		Если  АвтоопределениеДистрибуция Тогда 
			Объект.СтоимостьДоставкиПоДокументуПродажи = Объект.СтоимостьДоставкиСНДС;
		КонецЕсли; 
		//
	КонецЕсли;
	
КонецПроцедуры

Процедура ПерезаполнитьРеквизитыЗаказа(Объект) Экспорт
	
	Основания = Объект.Основания;
	
	Если Основания.Количество() > 0 И Объект.ВидДоставки <> Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
		Основание = Основания[0].Документ;
		Для Каждого стрОснования Из Основания Цикл
			Если ТипЗнч(стрОснования.Документ) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда 
				Основание = стрОснования.Документ;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			ЗаполнитьПоОбращениюКлиента(Основание, Объект, Ложь);
		ИначеЕсли ТипЗнч(Основание) = Тип("ДокументСсылка.ЧекККМ") Тогда
			ЗаполнитьЗначенияСвойств(Объект, Основание, "Партнер, Организация, Подразделение");
		Иначе
			ЗаполнитьЗначенияСвойств(Объект, Основание, "Партнер, Организация, Подразделение, Контрагент");
		КонецЕсли;          
		
		ЗаполнитьАдресДоставки(Объект, Основание);
		
		стрНомера = "";
		Комментарии = "";
		
		ДокументыПродажи = ПолучитьДокументыПродажи(Объект);	
		Для Каждого Документ Из ДокументыПродажи Цикл
			стрНомера = ?(ЗначениеЗаполнено(стрНомера), стрНомера + "; " + Документ.Номер, Документ.Номер);
			
			Если ТипЗнч(Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ИЛИ 
				ТипЗнч(Документ) = Тип("ДокументСсылка.ЧекККМ") ИЛИ 
				ТипЗнч(Документ) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
				
				Комментарии = ?(ЗначениеЗаполнено(Комментарии), Комментарии + "; " + Документ.КомментарийДляСклада, Документ.КомментарийДляСклада);
			КонецЕсли;
		КонецЦикла;
		
		Объект.НомераДокументовПродажи = стрНомера;
		Если НЕ ЗначениеЗаполнено(объект.КомментарийДляСклада) Тогда
			Объект.КомментарийДляСклада = Комментарии;
		КонецЕсли;
	КонецЕсли;
	
	ОбновитьИтогиПоОснованиям(Объект); 
	
КонецПроцедуры   

Процедура ЗаполнитьАдресДоставки(Объект, Основание)

	Если Не ЗначениеЗаполнено(Объект.АдресДоставки) Тогда 
		Если ТипЗнч(Основание) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда	             
			Объект.АдресДоставки = Основание.СкладПолучатель.Подразделение.Адрес;
			Объект.АдресДоставкиКарта= Основание.СкладПолучатель.Подразделение.Адрес;
		ИначеЕсли Основание.Метаданные().Реквизиты.Найти("АдресДоставки") <> Неопределено Тогда 
			Объект.АдресДоставки = Основание.АдресДоставки;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПоОбращениюКлиента(Обращение, Объект, ПерезаписыватьЗонуДоставкиДляВодителя = Истина) Экспорт 
	
	Если Не ЗначениеЗаполнено(Объект.Комментарий) Тогда
		Объект.Комментарий = "Обмен/довоз по обращению №" + Обращение.Номер;
	КонецЕсли;
	
	ТелефонКлиентаНаВыгрузке = Обращение.ТелефонКлиентаНаВыгрузке;
	Если ЗначениеЗаполнено(ТелефонКлиентаНаВыгрузке) Тогда
		Объект.ТелефонКлиента = ТелефонКлиентаНаВыгрузке;
		Объект.ТелефонКлиентаНаВыгрузке = ТелефонКлиентаНаВыгрузке;
	КонецЕсли;
	
	Акция = Справочники.МаркетинговыеМероприятия.НайтиПоНаименованию("Обмен/довоз");
	Если ЗначениеЗаполнено(Акция) Тогда
		Объект.Акция = Акция;
	КонецЕсли;
		
	СтруктураЗаполнения = Документы.ОбращениеКлиента.ПолучитьДанныеПоОснованию(Обращение);
	ЗаполнитьЗначенияСвойств(Объект, СтруктураЗаполнения, "Организация, Подразделение, Контрагент, Партнер");
	
	Если ТипЗнч(Обращение.ИсточникЗаполненияТоваровДляДовоза) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		ЗаполнитьПоПеремещению(Обращение.ИсточникЗаполненияТоваровДляДовоза, Объект);
	КонецЕсли;          
	
	ДопОснование = Обращение.ДополнительнаяРеализация;
	Если ЗначениеЗаполнено(ДопОснование) И 
		Объект.Основания.Выгрузить().Найти(ДопОснование, "Документ") = Неопределено Тогда 
		
		НоваяСтрока = Объект.Основания.Добавить();
		НоваяСтрока.Документ = ДопОснование;
	КонецЕсли;    
	
	Если ЗначениеЗаполнено(Обращение.ЗаказНадоставку) Тогда 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаДоставкуКлиенту.Широта КАК Широта,
		|	ЗаказНаДоставкуКлиенту.Долгота КАК Долгота,
		|	ЗаказНаДоставкуКлиенту.ЗонаДоставкиДляВодителя КАК ЗонаДоставкиДляВодителя
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту КАК ЗаказНаДоставкуКлиенту
		|ГДЕ
		|	ЗаказНаДоставкуКлиенту.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Обращение.ЗаказНадоставку.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда 
		Объект.Широта = Выборка.Широта;    
		Объект.Долгота = Выборка.Долгота; 
		
		Если ПерезаписыватьЗонуДоставкиДляВодителя ИЛИ Не ЗначениеЗаполнено(Объект.ЗонаДоставкиДляВодителя) Тогда
			Объект.ЗонаДоставкиДляВодителя = Выборка.ЗонаДоставкиДляВодителя;       
		КонецЕсли;
	КонецЕсли;

	КонецЕсли;	
	
КонецПроцедуры

Процедура ЗаполнитьПоПеремещению(Перемещение, Объект) 
	
	Объект.Партнер = Перемещение.СкладПолучатель.Подразделение;
	Объект.Подразделение = Перемещение.СкладОтправитель.Подразделение;
	
	// Получаем организацию, если хоть в одном складе альтерра то альтерру, иначе если АСК сервис то его.
	Если Перемещение.СкладОтправитель.Подразделение.Организация.Наименование = "Альтерра ООО" Тогда
		Объект.Организация = Перемещение.СкладОтправитель.Подразделение.Организация;	
	ИначеЕсли Перемещение.СкладПолучатель.Подразделение.Организация.Наименование = "Альтерра ООО" Тогда
		Объект.Организация = Перемещение.СкладПолучатель.Подразделение.Организация;
	ИначеЕсли Перемещение.СкладОтправитель.Подразделение.Организация.Наименование = "АСК-Сервис ООО" Тогда
		Объект.Организация = Перемещение.СкладОтправитель.Подразделение.Организация;	
	ИначеЕсли Перемещение.СкладПолучатель.Подразделение.Организация.Наименование = "АСК-Сервис ООО" Тогда
		Объект.Организация = Перемещение.СкладПолучатель.Подразделение.Организация;
	КонецЕсли; 
	
КонецПроцедуры

Процедура ОбновитьРеквизитыДоставки(Объект) Экспорт

	СведенияОКлиенте= АльтерраОбщегоНазначения.ПолучитьСведеньяОПартнере(Объект.Партнер);
	Объект.ФИОКлиента = Объект.Партнер.Наименование;	
	Объект.АдресДоставки = ?(ЗначениеЗаполнено(Объект.ОбъектДоставки),Объект.ОбъектДоставки.Адрес,СведенияОКлиенте.ФактическийАдрес);
	
КонецПроцедуры

Процедура ОбновитьИтогиПоОснованиям(Объект) Экспорт 
	Запрос = Новый Запрос; 
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	Запрос.МенеджерВременныхТаблиц =  МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Основания.Документ КАК Основание
	|ПОМЕСТИТЬ Основания
	|ИЗ
	|	&Основания КАК Основания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	РеализацияТоваровУслугТовары.Сумма КАК Сумма,
	|	РеализацияТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоСтрокВДокументе
	|ПОМЕСТИТЬ ТоварПредварительно
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ТоварыДляДовоза.Номенклатура,
	|	ТоварыДляДовоза.Сумма,
	|	ТоварыДляДовоза.Количество,
	|	ВЫБОР
	|		КОГДА ТоварыДляДовоза.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ТоварыДляДовоза
	|ГДЕ
	|	ТоварыДляДовоза.Ссылка В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМТовары.Номенклатура,
	|	ЧекККМТовары.Сумма,
	|	ЧекККМТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЧекККМТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ЧекККМ.Товары КАК ЧекККМТовары
	|ГДЕ
	|	ЧекККМТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Номенклатура,
	|	ЗаказКлиентаТовары.Сумма,
	|	ЗаказКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|	И ЗаказКлиентаТовары.Отменено = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиентаТовары.Номенклатура,
	|	-ВозвратТоваровОтКлиентаТовары.Сумма,
	|	-ВозвратТоваровОтКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ВозвратТоваровОтКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
	|ГДЕ
	|	(ВозвратТоваровОтКлиентаТовары.ДокументРеализации В
	|				(ВЫБРАТЬ
	|					Основания.Основание
	|				ИЗ
	|					Основания КАК Основания)
	|			ИЛИ ВозвратТоваровОтКлиентаТовары.ДокументРеализации.ЗаказКлиента В
	|				(ВЫБРАТЬ
	|					Основания.Основание
	|				ИЗ
	|					Основания КАК Основания))
	|	И ВозвратТоваровОтКлиентаТовары.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиентаТовары.Номенклатура,
	|	-ВозвратТоваровОтКлиентаТовары.Сумма,
	|	-ВозвратТоваровОтКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ВозвратТоваровОтКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
	|ГДЕ
	|	ВозвратТоваровОтКлиентаТовары.Ссылка.ЧекККМ В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|	И ВозвратТоваровОтКлиентаТовары.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровОтКлиентаТовары.Номенклатура,
	|	ВозвратТоваровОтКлиентаТовары.Сумма,
	|	ВозвратТоваровОтКлиентаТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ВозвратТоваровОтКлиентаТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
	|ГДЕ
	|	ВозвратТоваровОтКлиентаТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|	И ВозвратТоваровОтКлиентаТовары.Ссылка.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЧекККМВозвратТовары.Номенклатура,
	|	-ЧекККМВозвратТовары.Сумма,
	|	-ЧекККМВозвратТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЧекККМВозвратТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ЧекККМВозврат.Товары КАК ЧекККМВозвратТовары
	|ГДЕ
	|	ЧекККМВозвратТовары.Ссылка.ЧекККМ В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|	И ЧекККМВозвратТовары.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЧековККМ.Пробит)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	СУММА(ЕСТЬNULL(СебестоимостьТоваров.Стоимость + СебестоимостьТоваров.ДопРасходы, 0)),
	|	ПеремещениеТоваровТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СебестоимостьТоваров КАК СебестоимостьТоваров
	|		ПО ПеремещениеТоваровТовары.Ссылка = СебестоимостьТоваров.Регистратор
	|			И ПеремещениеТоваровТовары.Ссылка.СкладОтправитель = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.МестоХранения
	|			И ПеремещениеТоваровТовары.Номенклатура = СебестоимостьТоваров.АналитикаУчетаНоменклатуры.Номенклатура
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка В
	|			(ВЫБРАТЬ
	|				Основания.Основание
	|			ИЗ
	|				Основания КАК Основания)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	ПеремещениеТоваровТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ПеремещениеТоваровТовары.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товар.Номенклатура КАК Номенклатура,
	|	СУММА(Товар.Сумма) КАК Сумма,
	|	СУММА(Товар.КоличествоУпаковок) КАК КоличествоУпаковок,
	|	Товар.КоличествоСтрокВДокументе КАК КоличествоСтрокВДокументе
	|ПОМЕСТИТЬ Товар
	|ИЗ
	|	ТоварПредварительно КАК Товар
	|
	|СГРУППИРОВАТЬ ПО
	|	Товар.Номенклатура,
	|	Товар.КоличествоСтрокВДокументе
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(Товар.Сумма, 0)) КАК СтоимостьДоставки
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиДоставкиБезНДС)
	|	И Товар.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(Товар.Сумма, 0)) КАК СтоимостьДоставки
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиДоставкиСНДС)
	|	И Товар.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Товар.Сумма) КАК СуммаДокумента,
	|	СУММА(ВЫБОР
	|			КОГДА Товар.КоличествоУпаковок > 0
	|				ТОГДА Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры
	|			ИНАЧЕ -(Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры)
	|		КОНЕЦ) КАК Вес,
	|	СУММА(ВЫБОР
	|			КОГДА Товар.КоличествоУпаковок > 0
	|				ТОГДА Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры
	|			ИНАЧЕ -(Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры)
	|		КОНЕЦ) КАК Объем,
	|	СУММА(Товар.КоличествоСтрокВДокументе) КАК КоличествоСтрокВДокументе,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Товар.Номенклатура.ДлинаЗнаменатель <> 0
	|				ТОГДА Товар.Номенклатура.ДлинаЧислитель / Товар.Номенклатура.ДлинаЗнаменатель
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК МаксимальнаяДлина
	|ИЗ
	|	Товар КАК Товар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(Товар.Сумма, 0)) КАК СтоимостьТовара
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура.ТипНоменклатуры = &ТипНоменклатурыТовар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Товар.Сумма) КАК Сумма,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры) КАК Вес,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры) КАК Объем,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Товар.Номенклатура.ДлинаЗнаменатель <> 0
	|				ТОГДА Товар.Номенклатура.ДлинаЧислитель / Товар.Номенклатура.ДлинаЗнаменатель
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК МаксимальнаяДлина,
	|	Товар.Номенклатура КАК Номенклатура
	|ИЗ
	|	Товар КАК Товар
	|
	|СГРУППИРОВАТЬ ПО
	|	Товар.Номенклатура
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(Товар.Сумма, 0)) КАК СтоимостьРазгрузки
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиРазгрузкиБезНДС)
	|	И Товар.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(ЕСТЬNULL(Товар.Сумма, 0)) КАК СтоимостьРазгрузки
	|ИЗ
	|	Товар КАК Товар
	|ГДЕ
	|	Товар.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиРазгрузкиСНДС)
	|	И Товар.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Товар.Номенклатура КАК Номенклатура,
	|	ВЫБОР
	|		КОГДА Товар.КоличествоУпаковок > 0
	|			ТОГДА Товар.КоличествоУпаковок
	|		ИНАЧЕ -Товар.КоличествоУпаковок
	|	КОНЕЦ КАК КоличествоУпаковок
	|ИЗ
	|	Товар КАК Товар";
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	
	Основания = Объект.Основания.Выгрузить();
	Запрос.УстановитьПараметр("Основания", Основания);
	Запрос.УстановитьПараметр("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Услуга);
	Запрос.УстановитьПараметр("ТипНоменклатурыТовар", Перечисления.ТипыНоменклатуры.Товар); 
	
	мГруппаУслугиДоставкиБезНДС = Новый Массив;
	мГруппаУслугиДоставкиБезНДС.Добавить(АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиБезНДС());
	мГруппаУслугиДоставкиБезНДС.Добавить(АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиБезНДСОРК());
	Запрос.УстановитьПараметр("ГруппаУслугиДоставкиБезНДС", мГруппаУслугиДоставкиБезНДС);
	
	Запрос.УстановитьПараметр("ГруппаУслугиДоставкиСНДС", АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиСНДС());
	
	Запрос.УстановитьПараметр("ГруппаУслугиРазгрузкиБезНДС", АльтерраОбщегоНазначения.ПолучитьГруппуУслугРазгрузкиБезНДС());
	Запрос.УстановитьПараметр("ГруппаУслугиРазгрузкиСНДС", АльтерраОбщегоНазначения.ПолучитьГруппуУслугРазгрузкиСНДС());
	
	РезультатПакета = Запрос.ВыполнитьПакет();
	
	СтавкаНДС = УчетНДСУП.СтавкаНДСПоУмолчанию(Объект.Организация,Объект.Дата);
	СтавкаНДСЧислом = ЦенообразованиеКлиентСервер.ПолучитьСтавкуНДСЧислом(СтавкаНДС) / 100 + 1;
	
	Если Объект.ВидДоставки <> Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
		ВыборкаСтоимостьДоставки = РезультатПакета[3].Выбрать();
		Если ВыборкаСтоимостьДоставки.Следующий() Тогда
			Объект.СтоимостьДоставки =  ВыборкаСтоимостьДоставки.СтоимостьДоставки;//Услуга доставки из документа
		КонецЕсли;
		
		Если ЭтоКонтрагентИсключение(Объект.Контрагент) ИЛИ ЗначениеЗаполнено(Объект.Акция) Тогда
			Объект.СтоимостьДоставкиСНДС = Объект.СтоимостьДляВодителя*СтавкаНДСЧислом;
		Иначе
			ВыборкаСтоимостьДоставки = РезультатПакета[4].Выбрать();
			Если ВыборкаСтоимостьДоставки.Следующий() Тогда
				Объект.СтоимостьДоставкиСНДС =  ВыборкаСтоимостьДоставки.СтоимостьДоставки;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная ИЛИ Объект.ВидДоставки.Пустая() Тогда
		ВыборкаСтоимостьРазгрузки = РезультатПакета[8].Выбрать();
		Если ВыборкаСтоимостьРазгрузки.Следующий() Тогда
			Объект.Разгрузка =  ВыборкаСтоимостьРазгрузки.СтоимостьРазгрузки;//Услуга разгрузки из документа
		КонецЕсли;
	
		ВыборкаСтоимостьРазгрузки = РезультатПакета[9].Выбрать();
		Если ВыборкаСтоимостьРазгрузки.Следующий() Тогда
			Объект.РазгрузкаСНДС =  ВыборкаСтоимостьРазгрузки.СтоимостьРазгрузки;
		КонецЕсли;	
	КонецЕсли;

	ВыборкаИтоги = РезультатПакета[5].Выбрать();
	Если ВыборкаИтоги.Следующий() Тогда
		Объект.СуммаДокумента = ВыборкаИтоги.СуммаДокумента;
		Объект.Вес = ВыборкаИтоги.Вес;
		Объект.КоличествоСтрокВДокументе = ВыборкаИтоги.КоличествоСтрокВДокументе;
		Объект.Объем = ВыборкаИтоги.Объем;
		Объект.МаксимальнаяДлина = ПолучитьМаксимальнуюДлинуСУчетомНарезки(Объект.Основания.Выгрузить(,"Документ")); 
	КонецЕсли;
	
	//Объем поликарбоната
	ОбъемСУчетомСкрутокПоликарбоната = УправлениеЛогистикойСервер.ПолучитьОбъемСУчетомСкрутокПоликарбоната(РезультатПакета[10].Выгрузить());   	
	Объект.ОбъемСУчетомСкрутокПоликарбоната =?(ОбъемСУчетомСкрутокПоликарбоната = 0, Объект.Объем, ОбъемСУчетомСкрутокПоликарбоната);	
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда 
		 Объект.Объем = Объект.ОбъемСУчетомСкрутокПоликарбоната;		
	КонецЕсли;
		
	ВыборкаСтоимостьТовара = РезультатПакета[6].Выбрать();
	Если ВыборкаСтоимостьТовара.Следующий() Тогда
		Объект.СтоимостьТовара =  ВыборкаСтоимостьТовара.СтоимостьТовара;
	КонецЕсли;
	
	Если Не Объект.ТарифВРучную Тогда 
		//И ЗначениеЗаполнено (Объект.Ссылка) Тогда
		Критерии = УправлениеЛогистикойСервер.ПодборКритериевДляТиповТС(Основания.ВыгрузитьКолонку("Документ")); 
		УстановитьТариф(Объект, УправлениеЛогистикойСервер.МассивНесовместимыхТиповТС(Критерии));
	КонецЕсли;
	
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя Тогда
		
	Иначе
		Стоимости = ПолучитьСтоимостьПоТарифуИЗоне(Объект.Тариф, Объект.ЗонаДоставкиДляВодителя, Объект.Подразделение, Объект.Дата);
		Объект.СтоимостьДляКлиента = Стоимости.СтоимостьДляКлиента;
		Объект.СтоимостьДляВодителя = Стоимости.СтоимостьДляВодителя;
		Если Не ЗначениеЗаполнено(Объект.СтоимостьДоставкиСНДС) И ЗначениеЗаполнено(Объект.Акция) И ЗначениеЗаполнено(Объект.СтоимостьДляВодителя) Тогда
			Объект.СтоимостьДоставкиСНДС = Объект.СтоимостьДляВодителя * СтавкаНДСЧислом;
		КонецЕсли;	
		Объект.МинимальнаяСтоимость = Стоимости.МинимальнаяСтоимость;		
	КонецЕсли;
	
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная И (Объект.СтоимостьДоставки+Объект.СтоимостьДоставкиСНДС/СтавкаНДСЧислом <> Объект.СтоимостьДляКлиента) Тогда
		Сообщить("Стоимость доставки по тарифу и документу не совпадают!");
	КонецЕсли;
	
	ВыборкаТовар = РезультатПакета[7].Выбрать();
	Пока ВыборкаТовар.Следующий() Цикл
		Если ВыборкаТовар.Номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Товар Тогда
			Если ВыборкаТовар.Вес = 0 Тогда
				Сообщить("В номенклатуре: """ + ВыборкаТовар.Номенклатура + """ не заполнен вес!");
			КонецЕсли;
			Если ВыборкаТовар.Объем = 0 Тогда
				Сообщить("В номенклатуре: """ + ВыборкаТовар.Номенклатура + """ не заполнен объем!");
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	УстановитьЗначениеРеквизитовЕГАИС(Объект);
		
КонецПроцедуры
Функция ПолучитьМаксимальнуюДлинуСУчетомНарезки(Основания = Неопределено, Товары = Неопределено, Нарезка = Неопределено)   Экспорт
	
	Запрос = Новый Запрос();   
	
	Если Основания = Неопределено Тогда
		Запрос.Текст =	УправлениеЛогистикойСервер.ТекстЗапросаТоварыСУчетомНарезкиПоОбъекту();
		Запрос.УстановитьПараметр("ВнешняяТаблицаНоменклатуры", Товары); 
		Запрос.УстановитьПараметр("ВнешняяТаблицаНарезки", Нарезка);
	Иначе
		Запрос.Текст = УправлениеЛогистикойСервер.ТекстЗапросаТоварыСУчетомНарезкиПоОснованиям();
		Запрос.УстановитьПараметр("МассивДокументов", Основания); 
		
	КонецЕсли;

    Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстЗапросаДлинаНоменклатуры",Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаДлинаУпаковки(
	"ВТ_ТоварыИтоги.Номенклатура.ЕдиницаИзмерения",
	"ВТ_ТоварыИтоги.Номенклатура")); 
	

	Запрос.Текст = Запрос.Текст + "
		|ВЫБРАТЬ 
	    |ЕстьNull(МАКСИМУМ(Длина),0) КАК МаксимальнаяДлина
		|ИЗ ВТ_ТоварыНарезка";	
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	МаксимальнаяДлина = 0;
	Если Выборка.Следующий() Тогда
		МаксимальнаяДлина = Выборка.МаксимальнаяДлина;
	КонецЕсли;                                          
	
	Возврат МаксимальнаяДлина; 
	
КонецФункции	



Функция ЗапросДляВыбораТарифа(ВидДоставки, Экспресс, ВесГруза, ОбъемГруза, НесовместимыеТипыТС = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТарифыПеревозчиков.Ссылка КАК Ссылка,
	               |	ТарифыПеревозчиков.Экспресс КАК Экспресс,
	               |	ТарифыПеревозчиков.ГрузоподъемностьВТоннах КАК ГрузоподъемностьВТоннах,
	               |	ТарифыПеревозчиков.МаксимальнаяДлинаГруза КАК МаксимальнаяДлинаГруза,
	               |	ТарифыПеревозчиков.Приоритет КАК Приоритет
	               |ИЗ
	               |	Справочник.ТарифыПеревозчиков КАК ТарифыПеревозчиков
	               |ГДЕ
	               |	ТарифыПеревозчиков.Экспресс = &Экспресс
	               |	И ТарифыПеревозчиков.ГрузоподъемностьВТоннах >= &ВесГруза
	               |	И ТарифыПеревозчиков.ВидДоставки = &ВидДоставки
				   |	И НЕ ТарифыПеревозчиков.ТипТС В (&НесовместимыеТипыТС)
	               |	И ТарифыПеревозчиков.ПометкаУдаления = ЛОЖЬ
	               |	И ТарифыПеревозчиков.ВидДоставки = ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	ТарифыПеревозчиков.Ссылка,
	               |	ТарифыПеревозчиков.Экспресс,
	               |	ТарифыПеревозчиков.ГрузоподъемностьВТоннах,
	               |	ТарифыПеревозчиков.МаксимальнаяДлинаГруза,
	               |	NULL
	               |ИЗ
	               |	Справочник.ТарифыПеревозчиков КАК ТарифыПеревозчиков
	               |ГДЕ
	               |	ТарифыПеревозчиков.ВидДоставки = &ВидДоставки
				   |	И НЕ ТарифыПеревозчиков.ТипТС В (&НесовместимыеТипыТС)
	               |	И ТарифыПеревозчиков.ПометкаУдаления = ЛОЖЬ
	               |	И ТарифыПеревозчиков.ВидДоставки <> ЗНАЧЕНИЕ(Перечисление.ВидыДоставокДоКлиента.Розничная)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	МаксимальнаяДлинаГруза,
	               |	ГрузоподъемностьВТоннах,
	               |	Приоритет УБЫВ";
	
	Запрос.УстановитьПараметр("ВидДоставки", ВидДоставки);
	Если ЗначениеЗаполнено(НесовместимыеТипыТС) Тогда
		Запрос.УстановитьПараметр("НесовместимыеТипыТС", НесовместимыеТипыТС);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НЕ ТарифыПеревозчиков.ТипТС В (&НесовместимыеТипыТС)", "");
	КонецЕсли;
	Запрос.УстановитьПараметр("Экспресс", Экспресс);
	Запрос.УстановитьПараметр("ВесГруза", ВесГруза);
	
	ВыборкаТарифов = Запрос.Выполнить().Выбрать();
	Если ВыборкаТарифов.Следующий() Тогда
		Возврат ВыборкаТарифов.Ссылка;
	Иначе
		Возврат "";
	КонецЕсли; 
	
КонецФункции

Процедура УстановитьТариф(Объект, НесовместимыеТипыТС = Неопределено) Экспорт  
	
	//АвтоопределениеТарифа
	Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда
		
		Если  ЗначениеЗаполнено(Объект.Интервал)
			И ЗначениеЗаполнено(Объект.ЗонаДоставкиДляВодителя)Тогда
			СтруктураТарифТип = УправлениеЛогистикойСервер.АвтопределениеТарифа_И_ТипаТС(Объект);
			
			Если ТипЗнч(Объект) = Тип("ДокументОбъект.ЗаказНаДоставкуКлиенту") Тогда 
				Объект.ТипТС = СтруктураТарифТип.ТипТС;
			КонецЕсли;
			Объект.Тариф = СтруктураТарифТип.Тариф; 
			
			Если СтруктураТарифТип.СообщениеОбОшибке <> "" Тогда  
				Сообщить(СтруктураТарифТип.СообщениеОбОшибке);
			КонецЕсли;
			
		Иначе 
			Возврат;
		КонецЕсли; 
	//АвтоопределениеДистрибуция	
   ИначеЕсли Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы Тогда 
	 Результат = УправлениеЛогистикойСервер.ОпределитьТарифДистрибуция(Объект,Объект.ПрибытиеНаОтгрузку,Объект.Подразделение);   
	 Объект.Тариф = Результат.Тариф;
     ЭтоПомощникПродаж = ДопМодуль.ЕстьСвойствоОбъекта(Объект, "ЭтоПомощникПродаж"); 
	 
	 Если ЭтоПомощникПродаж Тогда
		 Объект.ТарифЗаКг           = Результат.ТарифЗаКг;
	 Иначе 
		 Объект.СтоимостьДляКлиента = Результат.ТарифЗаКг;
	 КонецЕсли; 
	 
   Иначе 
		
		Если ЗначениеЗаполнено(Объект.ВидДоставки) Тогда
			Объект.Тариф = ЗапросДляВыбораТарифа(Объект.ВидДоставки, Объект.ЭкспрессДоставка, Объект.Вес/1000, 0, НесовместимыеТипыТС);
		Иначе
			Объект.Тариф = ЗапросДляВыбораТарифа(Перечисления.ВидыДоставокДоКлиента.Розничная, Объект.ЭкспрессДоставка, Объект.Вес/1000, 0, НесовместимыеТипыТС);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Объект.Тариф) Тогда
			Сообщить("Не удалось определить тариф перевозчика!", СтатусСообщения.ОченьВажное);
		КонецЕсли; 
		
	КонецЕсли;

	
КонецПроцедуры


Функция ПолучитьТариф(ТЗ_Товары, ВидДоставки, ЭкспрессДоставка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = "ВЫБРАТЬ * ПОМЕСТИТЬ Товар ИЗ &ТЗ_Товары КАК ТЗ_Товары";
	Запрос.УстановитьПараметр("ТЗ_Товары", ТЗ_Товары);
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товар.Номенклатура КАК Номенклатура,
	|	Товар.Количество КАК Количество
	|ИЗ
	|	Товар КАК Товар
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Товар.Количество * &ТекстЗапросаВесНоменклатуры), 0) КАК ВесГруза,
	|	ЕСТЬNULL(СУММА(Товар.Количество * &ТекстЗапросаОбъемНоменклатуры), 0) КАК ОбъемГруза
	|ИЗ
	|	Товар КАК Товар";
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
		
	ВесГруза = Запрос.Выполнить().Выбрать();
	Если ВесГруза.Следующий() Тогда 
		Возврат ЗапросДляВыбораТарифа(ВидДоставки, ЭкспрессДоставка, ВесГруза.ВесГруза/1000, ВесГруза.ОбъемГруза);
	Иначе
		Возврат ЗапросДляВыбораТарифа(ВидДоставки, ЭкспрессДоставка, 0, 0);
	КонецЕсли;
	
КонецФункции

Процедура УстановитьЗначениеРеквизитовЕГАИС(Объект)
	
	ЕстьЗаявкаЕгаис = ЗаявкиЛесЕгаисИНомерДекларации(Объект);
	Если ЕстьЗаявкаЕгаис.Количество() > 0 Тогда
		Объект.ЕстьЗаявкаЛесЕГАИС = Истина;
		НетНомераДекларации = Новый ТаблицаЗначений;
		НетНомераДекларации.Колонки.Добавить("Заявка");
		Для Каждого Строка Из ЕстьЗаявкаЕгаис Цикл
			Если Строка.НомерДекларации = "" И Строка.ТипКлиента = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда
				НоваяСтрока = НетНомераДекларации.Добавить();
				НоваяСтрока.Заявка = Строка.ЗаявкаЕГАИС;
			КонецЕсли;
		КонецЦикла;
		Если НетНомераДекларации.Количество() > 0 Тогда
			Объект.НетНомераДекларацииЕГАИСуЮрЛица = Истина;
		Иначе 
			Объект.НетНомераДекларацииЕГАИСуЮрЛица = Ложь;
		КонецЕсли;
	Иначе 
		Объект.ЕстьЗаявкаЛесЕГАИС = Ложь;
		Объект.НетНомераДекларацииЕГАИСуЮрЛица = Ложь;
	КонецЕсли;
		
КонецПроцедуры

