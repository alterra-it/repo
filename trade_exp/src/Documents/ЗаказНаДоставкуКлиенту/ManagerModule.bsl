// Наличие заявки Егаис Лес и номер декларации в Егаис (Задача № 99153)
Функция ЗаявкиЛесЕгаисИНомерДекларации(Объект) Экспорт 
	
	ЛесЕГАИС = Новый ТаблицаЗначений;
	ЛесЕГАИС.Колонки.Добавить("Документ");
	ЛесЕГАИС.Колонки.Добавить("ЗаявкаЕГАИС");
	ЛесЕГАИС.Колонки.Добавить("НомерДекларации");
	ЛесЕГАИС.Колонки.Добавить("ТипКлиента");
	
	ДокументыПродажи = ПолучитьДокументыПродажи(Объект);
	Для Индекс = 0 По ДокументыПродажи.ВГраница() Цикл
		Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание", ДокументыПродажи[Индекс].Ссылка);
		Если НЕ Заявка.Пустая() И Заявка.Проведен Тогда
			НоваяСтрока = ЛесЕГАИС.Добавить();
			НоваяСтрока.ЗаявкаЕГАИС = Заявка.Ссылка;
			НоваяСтрока.НомерДекларации = Заявка.НомерДекларацииЮЛ;
			НоваяСтрока.ТипКлиента = Заявка.ТипКлиента;
		КонецЕсли;
	КонецЦикла;
		
	ЗаказКлиента = Объект.Основания;
	Для Каждого Стр Из ЗаказКлиента Цикл
		Если ТипЗнч(Стр.Документ) = Тип ("ДокументСсылка.ЗаказКлиента") Тогда
			Заявка = Документы.ЗаявкаВЕГАИСЛес.НайтиПоРеквизиту("Основание", Стр.Документ);
			Если НЕ Заявка.Пустая() И Заявка.Проведен Тогда
				НоваяСтрока = ЛесЕГАИС.Добавить();
				НоваяСтрока.ЗаявкаЕГАИС = Заявка.Ссылка;
				НоваяСтрока.НомерДекларации = Заявка.НомерДекларацииЮЛ;
				НоваяСтрока.ТипКлиента = Заявка.ТипКлиента;
			КонецЕсли;
		КонецЕсли;
	 КонецЦикла;
	 
	 Возврат ЛесЕГАИС;
	 
КонецФункции

Функция ПолучитьНомераОснованийПоДокументамПродажи(мДокументовПродажи) Экспорт
	
	//Список номеров заказов в рейсе
	стрНоменов = "";
	
	Для Каждого Документ Из мДокументовПродажи Цикл
		//Пропускаем АСКР задача 87160 
		Если ТипЗнч(Документ) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			Если Документы.ОбращениеКлиента.ПолучитьОрганизацию(Документ).Наименование = "АСК-Р" Тогда
				Продолжить;
			КонецЕсли;
		ИначеЕсли Документ.Организация.Наименование = "АСК-Р" Тогда
			Продолжить;
		КонецЕсли;
		
		стрНоменов = стрНоменов+Документ.Номер+", ";
	КонецЦикла;
	стрНоменов = Лев(стрНоменов, СтрДлина(стрНоменов)-2);
	Возврат стрНоменов;  
	
КонецФункции  

Функция ПолучитьНомераОснований(Ссылка) Экспорт
	
	//Список номеров заказов в рейсе
	стрНоменов = "";
	Для Каждого стрОснование Из Ссылка.Основания Цикл
		Основание = стрОснование.Документ;
		стрНоменов = стрНоменов+Основание.Номер+", ";
	КонецЦикла;
	стрНоменов = Лев(стрНоменов, СтрДлина(стрНоменов)-2);
	Возврат стрНоменов;
	
КонецФункции

Функция ПолучитьУслугуДоставкиИзДокумента(Товары, ГруппаУслугиДоставки)  Экспорт
	
	Запрос= Новый Запрос;
	Запрос.Текст=
	"ВЫБРАТЬ
	|	ВЫРАЗИТЬ(Товары.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
	|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	Товары.СуммаСНДС КАК СуммаСНДС
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура КАК Номенклатура,
	|	ВТ_Товары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВТ_Товары.СуммаСНДС КАК СтоимостьТовара
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары
	|ГДЕ
	|	ВТ_Товары.Номенклатура В ИЕРАРХИИ(&ГруппаУслугиДоставки)" ;
	
	Запрос.УстановитьПараметр("Товары", Товары);
	Запрос.УстановитьПараметр("ГруппаУслугиДоставки", ГруппаУслугиДоставки);    
	
	Выборка= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Номенклатура;
	КонецЕсли;
	
	Возврат Справочники.Номенклатура.ПустаяСсылка();
	
КонецФункции

Функция ПолучитьСтоимостьПоТарифуИЗоне(Тариф, Зона, Филиал, Период = Неопределено)  Экспорт
	
	Рез = Новый Структура("СтоимостьДляВодителя, СтоимостьДляКлиента,МинимальнаяСтоимость", 0, 0, 0);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтоимостьДоставкиПоЗонамСрезПоследних.ЗонаДоставки КАК ЗонаДоставки,
	|	СтоимостьДоставкиПоЗонамСрезПоследних.Тариф КАК Тариф,
	|	СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляВодителя КАК СтоимостьДляВодителя,
	|	СтоимостьДоставкиПоЗонамСрезПоследних.СтоимостьДляКлиента КАК СтоимостьДляКлиента,
	|	СтоимостьДоставкиПоЗонамСрезПоследних.МинимальнаяСтоимость КАК МинимальнаяСтоимость
	|ИЗ
	|	РегистрСведений.СтоимостьДоставкиПоЗонам.СрезПоследних(&Период, ) КАК СтоимостьДоставкиПоЗонамСрезПоследних
	|ГДЕ
	|	СтоимостьДоставкиПоЗонамСрезПоследних.ЗонаДоставки = &ЗонаДоставки
	|	И СтоимостьДоставкиПоЗонамСрезПоследних.Тариф = &Тариф
	|	И СтоимостьДоставкиПоЗонамСрезПоследних.Филиал = &Филиал";
	
	Запрос.УстановитьПараметр("ЗонаДоставки", Зона);
	Запрос.УстановитьПараметр("Тариф", Тариф);
	Запрос.УстановитьПараметр("Филиал", Филиал);   
	Запрос.УстановитьПараметр("Период", Период);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, ВыборкаДетальныеЗаписи); 
	КонецЕсли;
	
	Возврат Рез; 
	
КонецФункции 

Функция ПолучитьДокументыПродажи(Объект) Экспорт
	
