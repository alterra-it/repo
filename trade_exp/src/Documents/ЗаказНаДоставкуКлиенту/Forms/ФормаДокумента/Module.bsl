	Элементы.ВремяДоставкиПо.Доступность = Ложь;
	
КонецПроцедуры 

&НаСервере
Функция ПолучитьВремяСПоправкойНаИнтервал()
	
	ТекущийЧас = Час(ТекущаяДата());
	НеКруглаяМинуты = Минута(ТекущаяДата()) - 1;
	ТекущиеМинуты = Цел(НеКруглаяМинуты/10)*10 + 10;
	
	Если ТекущиеМинуты = 60 Тогда
		ТекущиеМинуты = 0;
		ТекущийЧас = ТекущийЧас + 1;
	КонецЕсли;
	
	Если ТекущийЧас = 24 Тогда
		ТекущийЧас = 0;
	КонецЕсли;
	
	ТекущееВремя = Дата(0001,01,01, ТекущийЧас, ТекущиеМинуты, 0);
	
	Если Объект.ДоставкаСРазгрузкой Тогда
		ИнтервалЗакрытия = Объект.Интервал.ЗакрытиеИнтервалаПоРазгрузке*60;
	Иначе 
		ИнтервалЗакрытия = Объект.Интервал.ИнтервалЗакрытия*60;
	КонецЕсли;
	
	Если Объект.Интервал.ЗакрыватьСКонцаИнтервала Тогда
		НачальноеВремя = Дата(0001,01,01, ТекущийЧас, ТекущиеМинуты, 0) + ИнтервалЗакрытия;
	Иначе
		НачальноеВремя = Дата(0001,01,01, ТекущийЧас, ТекущиеМинуты, 0) - ИнтервалЗакрытия;
	КонецЕсли; 
	
	Возврат НачальноеВремя; 
	
КонецФункции  

