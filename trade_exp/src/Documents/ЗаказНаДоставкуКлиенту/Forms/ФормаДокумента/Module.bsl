&НаСервереБезКонтекста
Функция ЕстьРейсСоСтатусом(Документ, МассивСтатусов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Основания.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ЗаданиеНаПеревозкуРейс.Основания КАК Основания
	|ГДЕ
	|	Основания.Документ = &Документ
	|	И Основания.Ссылка.Проведен
	|	И Основания.Ссылка.Статус В(&МассивСтатусов)";
	
	Запрос.УстановитьПараметр("Документ", Документ);
	Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Возврат РезультатЗапроса.Следующий(); 
	
КонецФункции

&НаСервере
