 &НаКлиенте
 Процедура УстановитьВидимостьПоВидуДоставки()  
	 
  УстановитьВидимостьОснованияДобавить();
  
  ВидДоставкиНеДистрибуцияСборныеГрузы = НЕ Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы");
  
  Элементы.ДоставкаСРазгрузкой.Видимость                   = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.Этаж.Видимость                                  = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.НомерКвартиры.Видимость                         = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.ВариантРазгрузки.Видимость                      = ВидДоставкиНеДистрибуцияСборныеГрузы; 
  Элементы.НаличиеПандуса.Видимость                        = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.РучнаяКорректировкаВариантовРазгрузки.Видимость = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.СтоимостьРазгрузкиДляВодителя.Видимость         = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.СтоимостьРазгрузкиДляКлиента.Видимость          = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.СтоимостьДляВодителя1.Видимость                 = ВидДоставкиНеДистрибуцияСборныеГрузы;
  Элементы.МинимальнаяСтоимость.Видимость                  = ВидДоставкиНеДистрибуцияСборныеГрузы;

  
 КонецПроцедуры
	 
