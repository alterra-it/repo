
#Область СобытияФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	//интервал доставки - время
	НачальноеВремя = ПолучитьВремяСПоправкойНаИнтервал(); 
	
	ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС, НачальноеВремя, Объект.Интервал.ВремяПо);
	ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо, НачальноеВремя, Объект.Интервал.ВремяПо);
	
	Если Не РольДоступна("ПолныеПрава") И (Объект.СтоимостьДоставки+Объект.Разгрузка)>0 И (Объект.СтоимостьДоставкиСНДС+Объект.РазгрузкаСНДС)>0 И Не Объект.ПометкаУдаления Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В документе не может быть одновременно услуги с НДС и Без НДС!");
		Отказ= Истина;
	КонецЕсли;
	ТоварОснований.ТекстЗапроса=ТекстЗапросаОснований();
	ОбновитьДинамическийСписок();
	ОбновитьНадписиНаСервере();
	
	Если ИмеетПолныеПрава() Тогда
		Элементы.Организация.ТолькоПросмотр = Ложь;
		Элементы.Партнер.ТолькоПросмотр = Ложь;
		Элементы.Подразделение.ТолькоПросмотр = Ложь;
		Элементы.Контрагент.ТолькоПросмотр = Ложь;
		Элементы.Статус.ТолькоПросмотр = Ложь;
		Элементы.ПричинаОтказа.ТолькоПросмотр = Ложь;
	КонецЕсли;
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды	
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	Если РольДоступна("_ОтделБухгалтерии") Тогда
		Элементы.ГруппаБухг.Видимость = Истина;
	КонецЕсли;
	
	РежимТолькоПросмотра = Ложь;
	
	Если Не Объект.Ссылка.Пустая() И Не РольДоступна("ПолныеПрава") И Не РольДоступна("РуководительОтделаЛогистики") И Не РольДоступна("_ОтделБухгалтерии") Тогда
		МассивСтатусов = Новый Массив;
		Если Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда    
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.РейсСогласованПоискТС);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ТСНаПогрузке);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ТСВПути);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ДоставкаОсуществлена);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ПоданНаОплатуПеревозчику);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ОригиналыСданыВБухгалтерию);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ДокументыНаПогрузкуГотовы);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ВодительДокументыПолучил); 
			
			РежимТолькоПросмотра = ЕстьРейсСоСтатусом(Объект.Ссылка, МассивСтатусов);
		ИначеЕсли Объект.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Розничная Тогда                  
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ПредварительнаяКомплектация);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ДокументыНаПогрузкуГотовы);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ВодительДокументыПолучил);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ТСНаПогрузке);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ТСВПути);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ДоставкаОсуществлена);
			МассивСтатусов.Добавить(Перечисления.СтатусыРейсов.ПоданНаОплатуПеревозчику); 
			
			РежимТолькоПросмотра = ЕстьРейсСоСтатусом(Объект.Ссылка, МассивСтатусов);
		КонецЕсли;
		
		Если РежимТолькоПросмотра И Не РольДоступна("ЛогистДиспетчер")Тогда
			Для Каждого Элемент Из Элементы Цикл
				Если Элемент.Имя = "ОценкаКачестваДоставки" И РольДоступна("ЛогистОператор") Тогда
					Продолжить; 
				КонецЕсли;
				Если ТипЗнч(Элемент) = Тип("ПолеФормы") ИЛИ ТипЗнч(Элемент) = Тип("ТаблицаФормы") Тогда
					Элемент.ТолькоПросмотр = Истина;
				ИначеЕсли ТипЗнч(Элемент) = Тип("КнопкаФормы") И Элемент.Вид <> ВидКнопкиФормы.КнопкаКоманднойПанели Тогда
					Элемент.Доступность = Ложь;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
	
	ПроверкаТарифаПоКритериямДляТС();
	
	Элементы.КомментарийДляСклада.ТолькоПросмотр = ЕстьЛюбойРейс();
	
	ПолучитьСтатусыДоставкиЯндекс();
	
	Если Не Объект.Проведен и Не Объект.ПометкаУдаления Тогда
		Объект.Интервал = Справочники.ИнтервалыДоставки.ПустаяСсылка();
	КонецЕсли;
	НужнаЗаписьСобытияОбъектов = Ложь;
КонецПроцедуры

&НаСервере
Функция ТекстЗапросаОснований()

	возврат 
	    "ВЫБРАТЬ
                  |	Товары.Ссылка КАК Документ,
                  |	Товары.Ссылка.Контрагент КАК Контрагент,
                  |	Товары.Ссылка.ПрибытиеНаОтгрузку КАК ПрибытиеНаОтгрузку,
                  |	Товары.Номенклатура КАК Номенклатура,
                  |	СУММА(Товары.КоличествоУпаковок) КАК Количество,
                  |	ВЫБОР
                  |		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ КАК ЕдИзм,
                  |	СУММА(Товары.Цена) КАК Цена,
                  |	СУММА(Товары.СуммаСНДС) КАК Сумма,
                  |	СУММА(Товары.СуммаНДС) КАК СуммаНДС,
                  |	Товары.Ссылка.Дата КАК Дата,
                  |	СУММА(Товары.СуммаРучнойСкидки + Товары.СуммаАвтоматическойСкидки) КАК СуммаСкидки,
                  |	Товары.Номенклатура.Код КАК Код,
                  |	ЕСТЬNULL(Товары.Склад.Ссылка, Товары.Ссылка.Склад) КАК Склад,
                  |	Товары.Характеристика КАК Характеристика
                  |ПОМЕСТИТЬ ВТ_Товары
                  |ИЗ
                  |	Документ.РеализацияТоваровУслуг.Товары КАК Товары
                  |ГДЕ
                  |	Товары.Ссылка В(&МассивДокументов)
                  |	И НЕ Товары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	Товары.Ссылка,
                  |	Товары.Номенклатура,
                  |	ВЫБОР
                  |		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	Товары.Ссылка.ПрибытиеНаОтгрузку,
                  |	Товары.Ссылка.Дата,
                  |	Товары.Ссылка.Контрагент,
                  |	Товары.Номенклатура.Код,
                  |	Товары.Склад,
                  |	Товары.Характеристика,
                  |	ЕСТЬNULL(Товары.Склад.Ссылка, Товары.Ссылка.Склад)
                  |
                  |ОБЪЕДИНИТЬ ВСЕ
                  |
                  |ВЫБРАТЬ
                  |	Товары.Ссылка,
                  |	Товары.Ссылка.Контрагент,
                  |	NULL,
                  |	Товары.Номенклатура,
                  |	СУММА(Товары.КоличествоУпаковок),
                  |	ВЫБОР
                  |		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	СУММА(Товары.Цена),
                  |	СУММА(Товары.СуммаСНДС),
                  |	СУММА(Товары.СуммаНДС),
                  |	Товары.Ссылка.Дата,
                  |	0,
                  |	Товары.Номенклатура.Код,
                  |	Товары.Ссылка.Склад,
                  |	Товары.Характеристика
                  |ИЗ
                  |	Документ.ВозвратТоваровОтКлиента.Товары КАК Товары
                  |ГДЕ
                  |	Товары.Ссылка В(&МассивДокументов)
                  |	И НЕ Товары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	Товары.Ссылка,
                  |	Товары.Номенклатура,
                  |	ВЫБОР
                  |		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	Товары.Ссылка.Дата,
                  |	Товары.Ссылка.Контрагент,
                  |	Товары.Номенклатура.Код,
                  |	Товары.Характеристика,
                  |	Товары.Ссылка.Склад
                  |
                  |ОБЪЕДИНИТЬ ВСЕ
                  |
                  |ВЫБРАТЬ
                  |	ПеремещениеТоваровТовары.Ссылка,
                  |	ПеремещениеТоваровТовары.Ссылка.Организация,
                  |	ПеремещениеТоваровТовары.Ссылка.ПрибытиеНаОтгрузку,
                  |	ПеремещениеТоваровТовары.Номенклатура,
                  |	СУММА(ПеремещениеТоваровТовары.КоличествоУпаковок),
                  |	ВЫБОР
                  |		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	0,
                  |	0,
                  |	0,
                  |	ПеремещениеТоваровТовары.Ссылка.Дата,
                  |	0,
                  |	ПеремещениеТоваровТовары.Номенклатура.Код,
                  |	ПеремещениеТоваровТовары.Ссылка.СкладОтправитель,
                  |	ПеремещениеТоваровТовары.Характеристика
                  |ИЗ
                  |	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
                  |ГДЕ
                  |	ПеремещениеТоваровТовары.Ссылка В(&МассивДокументов)
                  |	И НЕ ПеремещениеТоваровТовары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	ПеремещениеТоваровТовары.Ссылка,
                  |	ПеремещениеТоваровТовары.Номенклатура,
                  |	ПеремещениеТоваровТовары.Ссылка.Дата,
                  |	ПеремещениеТоваровТовары.Номенклатура.Код,
                  |	ПеремещениеТоваровТовары.Характеристика,
                  |	ВЫБОР
                  |		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	ПеремещениеТоваровТовары.Ссылка.Организация,
                  |	ПеремещениеТоваровТовары.Ссылка.СкладОтправитель,
                  |	ПеремещениеТоваровТовары.Ссылка.ПрибытиеНаОтгрузку
                  |
                  |ОБЪЕДИНИТЬ ВСЕ
                  |
                  |ВЫБРАТЬ
                  |	ТоварыДляДовоза.Ссылка,
                  |	NULL,
                  |	NULL,
                  |	ТоварыДляДовоза.Номенклатура,
                  |	СУММА(ТоварыДляДовоза.Количество),
                  |	ТоварыДляДовоза.Номенклатура.ЕдиницаИзмерения,
                  |	СУММА(ТоварыДляДовоза.Цена),
                  |	СУММА(ТоварыДляДовоза.Сумма),
                  |	0,
                  |	ТоварыДляДовоза.Ссылка.Дата,
                  |	0,
                  |	ТоварыДляДовоза.Номенклатура.Код,
                  |	ТоварыДляДовоза.Склад,
                  |	NULL
                  |ИЗ
                  |	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ТоварыДляДовоза
                  |ГДЕ
                  |	ТоварыДляДовоза.Ссылка В(&МассивДокументов)
                  |	И НЕ ТоварыДляДовоза.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	ТоварыДляДовоза.Ссылка,
                  |	ТоварыДляДовоза.Номенклатура,
                  |	ТоварыДляДовоза.Ссылка.Дата,
                  |	ТоварыДляДовоза.Номенклатура.Код,
                  |	ТоварыДляДовоза.Номенклатура.ЕдиницаИзмерения,
                  |	ТоварыДляДовоза.Склад
                  |
                  |ОБЪЕДИНИТЬ ВСЕ
                  |
                  |ВЫБРАТЬ
                  |	ВозвратТоваровПоставщикуТовары.Ссылка,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.Контрагент,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.ПрибытиеНаОтгрузку,
                  |	ВозвратТоваровПоставщикуТовары.Номенклатура,
                  |	СУММА(ВозвратТоваровПоставщикуТовары.КоличествоУпаковок),
                  |	ВЫБОР
                  |		КОГДА ВозвратТоваровПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ВозвратТоваровПоставщикуТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ВозвратТоваровПоставщикуТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	СУММА(ВозвратТоваровПоставщикуТовары.Цена),
                  |	СУММА(ВозвратТоваровПоставщикуТовары.СуммаСНДС),
                  |	СУММА(ВозвратТоваровПоставщикуТовары.СуммаНДС),
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.Дата,
                  |	0,
                  |	ВозвратТоваровПоставщикуТовары.Номенклатура.Код,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.Склад,
                  |	ВозвратТоваровПоставщикуТовары.Характеристика
                  |ИЗ
                  |	Документ.ВозвратТоваровПоставщику.Товары КАК ВозвратТоваровПоставщикуТовары
                  |ГДЕ
                  |	ВозвратТоваровПоставщикуТовары.Ссылка В(&МассивДокументов)
                  |	И НЕ ВозвратТоваровПоставщикуТовары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	ВозвратТоваровПоставщикуТовары.Ссылка,
                  |	ВозвратТоваровПоставщикуТовары.Номенклатура,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.Дата,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.Контрагент,
                  |	ВозвратТоваровПоставщикуТовары.Номенклатура.Код,
                  |	ВозвратТоваровПоставщикуТовары.Характеристика,
                  |	ВЫБОР
                  |		КОГДА ВозвратТоваровПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ВозвратТоваровПоставщикуТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ВозвратТоваровПоставщикуТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.Склад,
                  |	ВозвратТоваровПоставщикуТовары.Ссылка.ПрибытиеНаОтгрузку
                  |
                  |ОБЪЕДИНИТЬ ВСЕ
                  |
                  |ВЫБРАТЬ
                  |	ЧекККМТовары.Ссылка,
                  |	NULL,
                  |	NULL,
                  |	ЧекККМТовары.Номенклатура,
                  |	СУММА(ЧекККМТовары.КоличествоУпаковок),
                  |	ВЫБОР
                  |		КОГДА ЧекККМТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ЧекККМТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ЧекККМТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	СУММА(ЧекККМТовары.Цена),
                  |	СУММА(ЧекККМТовары.Сумма),
                  |	0,
                  |	ЧекККМТовары.Ссылка.Дата,
                  |	0,
                  |	ЧекККМТовары.Номенклатура.Код,
                  |	ЧекККМТовары.Ссылка.Склад,
                  |	ЧекККМТовары.Характеристика
                  |ИЗ
                  |	Документ.ЧекККМ.Товары КАК ЧекККМТовары
                  |ГДЕ
                  |	ЧекККМТовары.Ссылка В(&МассивДокументов)
                  |	И НЕ ЧекККМТовары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	ЧекККМТовары.Ссылка,
                  |	ЧекККМТовары.Номенклатура,
                  |	ВЫБОР
                  |		КОГДА ЧекККМТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ЧекККМТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ЧекККМТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	ЧекККМТовары.Ссылка.Дата,
                  |	ЧекККМТовары.Номенклатура.Код,
                  |	ЧекККМТовары.Ссылка.Склад,
                  |	ЧекККМТовары.Характеристика
                  |
                  |ОБЪЕДИНИТЬ ВСЕ
                  |
                  |ВЫБРАТЬ
                  |	ЗаказКлиентаТовары.Ссылка,
                  |	NULL,
                  |	NULL,
                  |	ЗаказКлиентаТовары.Номенклатура,
                  |	СУММА(ЗаказКлиентаТовары.КоличествоУпаковок),
                  |	ВЫБОР
                  |		КОГДА ЗаказКлиентаТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ЗаказКлиентаТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	СУММА(ЗаказКлиентаТовары.Цена),
                  |	СУММА(ЗаказКлиентаТовары.Сумма),
                  |	0,
                  |	ЗаказКлиентаТовары.Ссылка.Дата,
                  |	0,
                  |	ЗаказКлиентаТовары.Номенклатура.Код,
                  |	ЗаказКлиентаТовары.Ссылка.Склад,
                  |	ЗаказКлиентаТовары.Характеристика
                  |ИЗ
                  |	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
                  |ГДЕ
                  |	ЗаказКлиентаТовары.Ссылка В(&МассивДокументов)
                  |	И НЕ ЗаказКлиентаТовары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	ЗаказКлиентаТовары.Ссылка,
                  |	ЗаказКлиентаТовары.Номенклатура,
                  |	ВЫБОР
                  |		КОГДА ЗаказКлиентаТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
                  |			ТОГДА ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения
                  |		ИНАЧЕ ЗаказКлиентаТовары.Упаковка.ЕдиницаИзмерения
                  |	КОНЕЦ,
                  |	ЗаказКлиентаТовары.Ссылка.Дата,
                  |	ЗаказКлиентаТовары.Номенклатура.Код,
                  |	ЗаказКлиентаТовары.Ссылка.Склад,
                  |	ЗаказКлиентаТовары.Характеристика
                  |;
                  |
                  |////////////////////////////////////////////////////////////////////////////////
                  |ВЫБРАТЬ
                  |	ВТВозвраты.Номенклатура КАК Номенклатура,
                  |	ВТВозвраты.Характеристика КАК Характеристика,
                  |	ВТВозвраты.Упаковка КАК Упаковка,
                  |	СУММА(ВТВозвраты.Количество) КАК Количество,
                  |	СУММА(ВТВозвраты.Сумма) КАК Сумма,
                  |	ВТВозвраты.ДокументРеализации КАК ДокументРеализации
                  |ПОМЕСТИТЬ ВТ_Возвраты
                  |ИЗ
                  |	(ВЫБРАТЬ
                  |		ВозвратТоваровОтКлиентаТовары.Номенклатура КАК Номенклатура,
                  |		ВозвратТоваровОтКлиентаТовары.Характеристика КАК Характеристика,
                  |		ВозвратТоваровОтКлиентаТовары.Упаковка КАК Упаковка,
                  |		СУММА(ВозвратТоваровОтКлиентаТовары.Количество) КАК Количество,
                  |		СУММА(ВозвратТоваровОтКлиентаТовары.Сумма) КАК Сумма,
                  |		ВозвратТоваровОтКлиентаТовары.Ссылка.ДокументРеализации КАК ДокументРеализации
                  |	ИЗ
                  |		Документ.ВозвратТоваровОтКлиента.Товары КАК ВозвратТоваровОтКлиентаТовары
                  |	ГДЕ
                  |		ВозвратТоваровОтКлиентаТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
                  |		И ВозвратТоваровОтКлиентаТовары.ДокументРеализации В(&МассивДокументов)
                  |	
                  |	СГРУППИРОВАТЬ ПО
                  |		ВозвратТоваровОтКлиентаТовары.Характеристика,
                  |		ВозвратТоваровОтКлиентаТовары.Номенклатура,
                  |		ВозвратТоваровОтКлиентаТовары.Упаковка,
                  |		ВозвратТоваровОтКлиентаТовары.Ссылка.ДокументРеализации
                  |	
                  |	ОБЪЕДИНИТЬ ВСЕ
                  |	
                  |	ВЫБРАТЬ
                  |		ЧекККМВозвратТовары.Номенклатура,
                  |		ЧекККМВозвратТовары.Характеристика,
                  |		ЧекККМВозвратТовары.Упаковка,
                  |		СУММА(ЧекККМВозвратТовары.Количество),
                  |		0,
                  |		ЧекККМВозвратТовары.Ссылка.ЧекККМ
                  |	ИЗ
                  |		Документ.ЧекККМВозврат.Товары КАК ЧекККМВозвратТовары
                  |	ГДЕ
                  |		ЧекККМВозвратТовары.Ссылка.ПометкаУдаления = ЛОЖЬ
                  |		И ЧекККМВозвратТовары.Ссылка.ЧекККМ В(&МассивДокументов)
                  |	
                  |	СГРУППИРОВАТЬ ПО
                  |		ЧекККМВозвратТовары.Ссылка.ЧекККМ,
                  |		ЧекККМВозвратТовары.Упаковка,
                  |		ЧекККМВозвратТовары.Характеристика,
                  |		ЧекККМВозвратТовары.Номенклатура
                  |	
                  |	ОБЪЕДИНИТЬ ВСЕ
                  |	
                  |	ВЫБРАТЬ
                  |		КорректировкаРеализацииРасхождения.Номенклатура,
                  |		КорректировкаРеализацииРасхождения.Характеристика,
                  |		КорректировкаРеализацииРасхождения.Упаковка,
                  |		СУММА(-КорректировкаРеализацииРасхождения.Количество),
                  |		0,
                  |		КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование
                  |	ИЗ
                  |		Документ.КорректировкаРеализации.Расхождения КАК КорректировкаРеализацииРасхождения
                  |	ГДЕ
                  |		КорректировкаРеализацииРасхождения.Ссылка.ПометкаУдаления = ЛОЖЬ
                  |		И КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование В(&МассивДокументов)
                  |	
                  |	СГРУППИРОВАТЬ ПО
                  |		КорректировкаРеализацииРасхождения.Упаковка,
                  |		КорректировкаРеализацииРасхождения.Характеристика,
                  |		КорректировкаРеализацииРасхождения.Номенклатура,
                  |		КорректировкаРеализацииРасхождения.Ссылка.ДокументОснование) КАК ВТВозвраты
                  |
                  |СГРУППИРОВАТЬ ПО
                  |	ВТВозвраты.Номенклатура,
                  |	ВТВозвраты.Характеристика,
                  |	ВТВозвраты.Упаковка,
                  |	ВТВозвраты.ДокументРеализации
                  |;
                  |
                  |////////////////////////////////////////////////////////////////////////////////
                  |ВЫБРАТЬ
                  |	Товары.Документ КАК Документ,
                  |	Товары.Номенклатура КАК Номенклатура,
                  |	Товары.Цена КАК Цена,
                  |	Товары.Сумма КАК Сумма,
                  |	Товары.Количество КАК Количество,
                  |	Товары.Склад КАК Склад,
                  |	ВЫБОР
                  |		КОГДА Товары.Документ ССЫЛКА Документ.ВозвратТоваровОтКлиента
                  |			ТОГДА Товары.Количество
                  |		ИНАЧЕ ЕСТЬNULL(ВТ_Возвраты.Количество, 0)
                  |	КОНЕЦ КАК Возврат,
                  |	ВЫБОР
                  |		КОГДА Товары.Документ ССЫЛКА Документ.ВозвратТоваровОтКлиента
                  |			ТОГДА 0
                  |		ИНАЧЕ Товары.Количество - ЕСТЬNULL(ВТ_Возвраты.Количество, 0)
                  |	КОНЕЦ КАК КВыдаче,
                  |	Товары.Характеристика КАК Характеристика
                  |ИЗ
                  |	ВТ_Товары КАК Товары
                  |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Возвраты КАК ВТ_Возвраты
                  |		ПО Товары.Номенклатура = ВТ_Возвраты.Номенклатура
                  |			И Товары.Документ = ВТ_Возвраты.ДокументРеализации
                  |
                  |УПОРЯДОЧИТЬ ПО
                  |	Номенклатура,
                  |	Склад"     ;            

КонецФункции // ТекстЗапросаОснований()


