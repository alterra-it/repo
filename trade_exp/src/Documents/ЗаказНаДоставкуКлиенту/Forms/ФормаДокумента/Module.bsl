КонецФункции

&НаСервере
Процедура ОбъектДоставкиПриИзмененииНаСервере()
	
	Если ЗначениеЗаполнено(Объект.ОбъектДоставки) Тогда
		
		ОбъектДоставки = Объект.ОбъектДоставки;
		ЗаполнитьЗначенияСвойств(Объект,ОбъектДоставки,,"Автор");
		
		Объект.АдресДоставки = ОбъектДоставки.Адрес; 
		Если ЗначениеЗаполнено(ОбъектДоставки.ТелефонНаВыгрузке) Тогда
			Объект.ТелефонКлиентаНаВыгрузке = ОбъектДоставки.ТелефонНаВыгрузке;
		КонецЕсли;  
		
		//АвтоопределениеДистрибуция
		Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы")  Тогда 
			УстановитьТариф();    
			УстановкаСтоимостиПоДокументуПродажи(); 
		КонецЕсли; 
		//
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура АкцияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)   
	СтандартнаяОбработка = Ложь;
	
	Если ЗначениеЗаполнено(Объект.Подразделение) Тогда
		
		ЗначениеОтбора = Новый Структура;              
		
		ЗначениеОтбора.Вставить("Ссылка",ПолучитьАкции(Объект.Подразделение)); 
		
		ПараметрыФормы = Новый Структура("Отбор", ЗначениеОтбора);	
		
		ОткрытьФорму("Справочник.МаркетинговыеМероприятия.ФормаВыбора", ПараметрыФормы,,,,,Новый ОписаниеОповещения("ВыбратьРезультат", ЭтаФорма)); 
	Иначе
		Сообщить("Для выбора акции заполните поле подразделение!");	
	КонецЕсли;	
	
КонецПроцедуры   

&НаСервереБезКонтекста
Функция ПолучитьАкции(Подразделение, ВМассив = Истина, Наименование = "") 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	МаркетинговыеМероприятияПодразделения.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.МаркетинговыеМероприятия.Подразделения КАК МаркетинговыеМероприятияПодразделения
	|ГДЕ
	|	МаркетинговыеМероприятияПодразделения.Подразделение = &Подразделение
	|	И НЕ МаркетинговыеМероприятияПодразделения.Ссылка.ПометкаУдаления
	|	И НЕ МаркетинговыеМероприятияПодразделения.Ссылка.Завершено
	|	И МаркетинговыеМероприятияПодразделения.Ссылка.Наименование ПОДОБНО &Наименование";
	
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("Наименование",Наименование+"%");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если ВМассив Тогда
		Выборка = РезультатЗапроса.Выбрать();
		
		МассивСсылок = Новый Массив;
		Пока Выборка.Следующий() Цикл  
			МассивСсылок.Добавить(Выборка.Ссылка);
		КонецЦикла;
		Возврат МассивСсылок;	
	Иначе       
		СписокСсылок = Новый СписокЗначений;
		СписокСсылок.ЗагрузитьЗначения(РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка"));
		Возврат СписокСсылок; 
	КонецЕсли;
КонецФункции	

&НаКлиенте 
Процедура ВыбратьРезультат(Результат, ДополнительныеПараметры) Экспорт 
	Объект.Акция = Результат;
КонецПроцедуры

&НаКлиенте
Процедура АкцияАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;                                                                   
	Если ЗначениеЗаполнено(Объект.Подразделение) Тогда
		ДанныеВыбора = ПолучитьАкции(Объект.Подразделение, Ложь, Текст); 
	Иначе
		Сообщить("Для выбора акции заполните поле подразделение!");	
КонецЕсли;		
КонецПроцедуры

&НаСервере
Функция ЕстьРеализацииПоДоговоруБезОтметкиКассы()
	
Результат = УправлениеЛогистикойСервер.ПолучитьРеализацииПоДоговоруБезОтметкиКассы(Объект.Основания.Выгрузить(),Объект.Автор);

Если Результат.Пустой() Тогда
   Возврат Ложь;
КонецЕсли;

ВыборкаРеализация = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,,);

Сообщение = "Заказ на доставку будет записан, но не проведен. Не установлена отметка кассы в реализациях:
|";
УстановитьПривилегированныйРежим(Истина);
Событие = Справочники.СобытияОбъектовАльтерра.НайтиПоНаименованию("Оповещение запрет доставки");
ОтправлятьСообщения = НЕ РегистрыСведений.СобытияОбъектовАльтерра.БылоСобытие(Объект.Ссылка, Событие) И АльтерраОбщегоНазначения.ЭтоРабочаяБаза();
УстановитьПривилегированныйРежим(Ложь);
СообщениеВБитрикс = "Заказ на доставку " + Объект.Номер + " не проведен, в реализациях: 
|";
НужнаЗаписьСобытияОбъектов = Ложь;
Попытка
	
Пока ВыборкаРеализация.Следующий() Цикл
	
    Выборка = ВыборкаРеализация.Выбрать();
    Выборка.Следующий();
    
	Сообщение = Сообщение + Выборка.Номер + " "+ Формат(Выборка.Дата,"ДФ=dd.MM.yyyy;") + "
	|";  
	
	СообщениеВБитрикс = СообщениеВБитрикс + Выборка.Номер + " "+ Формат(Выборка.Дата,"ДФ=dd.MM.yyyy;") +"
	|";
	
	РуководительОтдела = Выборка.РуководительОтдела;
	РуководительНаправления = Выборка.РуководительНаправления;
КонецЦикла;

Если ОтправлятьСообщения Тогда	  
	   СообщениеВБитрикс = СообщениеВБитрикс + " нет отметки кассы, Автор: " + Объект.Автор;
	   ОтправкаСообщений(СообщениеВБитрикс, Объект.Автор);
	   ОтправкаСообщений(СообщениеВБитрикс, РуководительОтдела);
	   ОтправкаСообщений(СообщениеВБитрикс, РуководительНаправления);
	   Пока Выборка.Следующий() Цикл
	      ОтправкаСообщений(СообщениеВБитрикс, Выборка.РуководительНаправления);
	   КонецЦикла;
	   НужнаЗаписьСобытияОбъектов =  Истина;	   
КонецЕсли;

Исключение
	 // Записываем информацию об ошибке в журнал регистрации
                ЗаписьЖурналаРегистрации(
                    "Ошибка при отправке сообщений из заказа на доставку, основание " + Объект.Основания[0].Документ,
                    УровеньЖурналаРегистрации.Ошибка,
                    ,
                    ,
                    ОписаниеОшибки());
КонецПопытки;

Сообщить(Сообщение);

Возврат Истина;

Конецфункции

&НаСервере
Процедура ОтправкаСообщений(СообщениеВБитрикс, Получатель)
	
Если Получатель <> Справочники.Пользователи.ПустаяСсылка() Тогда
    АльтерраВзаимодействиеСБитрикс24.ОтправитьСообщениеВБитрикс(СообщениеВБитрикс, Получатель);
КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаписатьСобытиеОбъектовАльтерра();
	 УстановитьПривилегированныйРежим(Истина);
	   Событие = Справочники.СобытияОбъектовАльтерра.НайтиПоНаименованию("Оповещение запрет доставки");
	   РегистрыСведений.СобытияОбъектовАльтерра.ЗаписатьСобытие(Объект.Ссылка, Событие);
	 УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

