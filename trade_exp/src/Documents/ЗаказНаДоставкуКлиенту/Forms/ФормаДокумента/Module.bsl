#Область ОбъектДоставки 

&НаСервере
Процедура СохранитьАдресДоставкиВОбъектДоставки()
			
		Если Не ОбъектДоставкиЕстьУПартнера(Объект.Широта,Объект.Долгота,Объект.Партнер) Тогда
			
			СтруктураОбъекта = Справочники.ОбъектыДоставки.ПолучитьСтруктуруОбъектаДоставки();
			ЗаполнитьЗначенияСвойств(СтруктураОбъекта,Объект);
			
			НаименованиеЭлемента = СтрЗаменить(Объект.АдресДоставки,"Россия, ","");
			НаименованиеЭлемента = СтрЗаменить(НаименованиеЭлемента,"Алтайский край, ","");
			
			СтруктураОбъекта.Наименование = НаименованиеЭлемента;
			СтруктураОбъекта.Владелец = Объект.Партнер;	
			СтруктураОбъекта.Адрес = Объект.АдресДоставки;			
			СтруктураОбъекта.ТелефонНаВыгрузке = Объект.ТелефонКлиентаНаВыгрузке;
			СтруктураОбъекта.Автор = Объект.Автор;
			СтруктураОбъекта.СозданАвтоматически = Истина;
			
			ОбъектДоставки = Справочники.ОбъектыДоставки.СоздатьОбъектДоставки(СтруктураОбъекта);  
			Объект.ОбъектДоставки = ОбъектДоставки;  
			
		КонецЕсли; 
		
		
		
			
КонецПроцедуры

