&НаСервере
Процедура ОбновитьНадписиНаСервере()
	ЕщёДокументыЗаСегодня = "";	
	Если Объект.Партнер <> Справочники.Партнеры.РозничныйПокупатель Тогда
		мДокПродажи = Документы.ЗаказНаДоставкуКлиенту.ЕщёДокументыПродажиЗаСегодня(Объект);
		Если мДокПродажи.Количество() > 0 Тогда
			Для Каждого ДокПродажи Из мДокПродажи Цикл 
				Если ТипЗнч(ДокПродажи) = Тип("ДокументСсылка.ЧекККМ") Тогда
					ЕщёДокументыЗаСегодня = ЕщёДокументыЗаСегодня + "Чек ККМ " + ДокПродажи.Номер + "; ";
				ИначеЕсли ТипЗнч(ДокПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
					ЕщёДокументыЗаСегодня = ЕщёДокументыЗаСегодня + "Реализация " + ДокПродажи.Номер + "; ";
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;	
		Элементы.ЕщёДокументыЗаСегодня.Видимость = мДокПродажи.Количество(); 
	Иначе
		Элементы.ЕщёДокументыЗаСегодня.Видимость = Ложь;	
	КонецЕсли;
КонецПроцедуры

