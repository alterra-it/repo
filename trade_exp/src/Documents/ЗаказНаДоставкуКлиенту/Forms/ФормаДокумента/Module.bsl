Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	Если Объект.Ссылка.ЭкспрессДоставка <> Объект.ЭкспрессДоставка И Объект.ЭкспрессДоставка Тогда
		стрТелефоны= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Подразделение, "ТелефонДиспетчераПоДоставке");
		мТелефонов= СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(стрТелефоны, ",");
		Если мТелефонов.Количество() > 0 Тогда
			Телефон= СокрЛП(мТелефонов[0]);
			АльтерраОбщегоНазначения.ПривестиКФорматуНомерТелефона(Телефон,,,,,"+7");
			АльтерраОбщегоНазначения.ОтправитьСМС(Телефон, "Оформлена экспресс-доставка. Заказ "+ Объект.Номер);
		КонецЕсли;
	КонецЕсли; 
	
