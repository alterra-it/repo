		Новый Структура("МножественныйВыбор",истина), ЭтаФорма, УникальныйИдентификатор,,, ОписаниеОповещения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборПеремещенийЗавершение(Результат, ДополнительныеПараметры) экспорт
	
	Если типзнч(Результат)= тип("Массив") Тогда
		Объект.Основания.Удалить(Объект.Основания.Количество()-1);
		Для Каждого стр Из Результат Цикл
			стрДобавления = Объект.Основания.Добавить();
			стрДобавления.Документ = стр;
		КонецЦикла;	
	КонецЕсли;	
	ОбновитьДанныеПоОснованиямНаСервере();	
	
КонецПроцедуры   

