&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	
	ВидДоставкиРозничная   = Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная");
	ВидДоставкиСборная     = Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.СборнаяОРК");
	ВидДоставкиДистрибуция = Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы");
						 
	Элементы.ВидРазгрузки.Видимость = ВидДоставкиСборная;
	Элементы.ЭкспрессДоставка.Видимость = ВидДоставкиРозничная;
	Элементы.СтоимостьДляКлиента.Видимость = ВидДоставкиРозничная ИЛИ ВидДоставкиДистрибуция; 
	Элементы.СтоимостьДоставкиПоДокументуПродажи.Видимость = ВидДоставкиДистрибуция; 
	
	Если ВидДоставкиДистрибуция  Тогда
		 Элементы.СтоимостьДляКлиента.Заголовок = "Стоимость для клиента (за кг.)";
    Иначе 
		 Элементы.СтоимостьДляКлиента.Заголовок = "Стоимость для клиента";
	КонецЕсли;
	
	Если Не Элементы.ТарифВРучную.ТолькоПросмотр Тогда
		Элементы.Тариф.ТолькоПросмотр = Не Объект.ТарифВРучную;
	КонецЕсли;
	
	Элементы.Инкассация.Видимость = Объект.НужнаИнкассация;
	
	Элементы.ВремяДоставкиС.Доступность = Объект.ЭкспрессДоставка;
	Элементы.ВремяДоставкиПо.Доступность = Объект.ЭкспрессДоставка;
	
	Элементы.Акция.Видимость =  ВидДоставкиРозничная;
	
	ПроверитьОграничениеПоТранспорту();
	
	Элементы.ЗонаДоставкиДляВодителя.ТолькоПросмотр = Не Объект.ЗонаДоставкиВручную;
	
	Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Внутренняя") Тогда
		Элементы.ГруппаМенеджерПраво.Видимость = Ложь;
		Элементы.ФИОКлиента.Видимость = Ложь;
		Элементы.ТелефонКлиента.Видимость = Ложь;
		Элементы.Контрагент.Видимость = Ложь;
	Иначе
		Элементы.ГруппаМенеджерПраво.Видимость = Истина;
		Элементы.ФИОКлиента.Видимость = Истина;
		Элементы.ТелефонКлиента.Видимость = Истина;
		Элементы.Контрагент.Видимость = Истина;
	КонецЕсли;
	
	Элементы.АдресДоставки.ТолькоПросмотр = Истина;
	
	КонтрольЭлементаСдача();
	
	Элементы.Сдача.Видимость = Не Объект.ОплатаБанковскойКартой И Объект.Инкассация<>0;
	
	Элементы.ГруппаОбъектаДоставки.Видимость = Не ЭтоРозница(); 
	Элементы.КомментарийДляСклада.ТолькоПросмотр = ЕстьЛюбойРейс();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНадписи()
	
	Если Объект.МаксимальнаяДлина >= 6 И Объект.МаксимальнаяДлина < 12 Тогда
		ЭлементНеГобарит = "Внимание 6-ти метровый  негабарит";
	ИначеЕсли Объект.МаксимальнаяДлина >= 12 Тогда
		ЭлементНеГобарит = "Внимание 12-ти метровый  негабарит";
	Иначе
		ЭлементНеГобарит = "";
	КонецЕсли;
	Элементы.ЭлементНеГобарит.Видимость= Не ПустаяСтрока(ЭлементНеГобарит);   
	
