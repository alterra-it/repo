КонецФункции 


&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьДоступность();
	ОбновитьНадписи();        
	
	РезультатПроверки = ПроверитьФормуОплатыДатуДоставкиВЛистеСогласованияНаСервере();
	Если РезультатПроверки <> Неопределено Тогда  
		ОчиститьСообщения();
		Для Каждого ТекущийРезультат Из РезультатПроверки Цикл 
			ТекущееСообщение = Новый СообщениеПользователю;
			ТекущееСообщение.Текст = СтрШаблон("%1 %2",ТекущийРезультат.Ошибка,ТекущийРезультат.Документ);
			ТекущееСообщение.КлючДанных = ТекущийРезультат.Документ;
			ТекущееСообщение.Сообщить();
		КонецЦикла;	
	КонецЕсли;   
	НеиспользованныеДокументы = ПолучитьДокументыПоКлиенту();
	Если НеиспользованныеДокументы.Количество() > 0 Тогда
		СообщитьСписокДокументов(НеиспользованныеДокументы);	
	КонецЕсли;  
	
	//АвтоопределениеДистрибуция 
	УстановитьВидимостьПоВидуДоставки();
	//		
КонецПроцедуры 

&НаСервере
Функция ПроверитьФормуОплатыДатуДоставкиВЛистеСогласованияНаСервере()
	
	Если Не Объект.Ссылка.Пустая() Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛистСогласования.Ссылка КАК Ссылка,
		|	ЛистСогласования.ФормаОплаты КАК ФормаОплаты,
		|	ЛистСогласования.ДатаДоставки КАК ДатаДоставки,
		|	ЛистСогласования.Основание КАК Основание
		|ИЗ
		|	Документ.ЛистСогласования КАК ЛистСогласования
		|ГДЕ
		|	ЛистСогласования.Основание В(&Основание)
		|	И ЛистСогласования.Проведен
		|	И НЕ ЛистСогласования.Аннулирован";   
		
		ДокументыОснования = Новый Массив;
		Для Каждого Основание Из Объект.Основания Цикл  
			ДокументыОснования.Добавить(Основание.Документ);
		КонецЦикла;	
		
		Запрос.УстановитьПараметр("Основание", ДокументыОснования);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();     
		
		Если Объект.ОплатаБанковскойКартой Тогда   
			ФормаОплатыПоДокументу = Перечисления.ФормыОплаты.ПлатежнаяКарта;
		ИначеЕсли Объект.НужнаИнкассация Тогда  
			ФормаОплатыПоДокументу = Перечисления.ФормыОплаты.Наличная;  
		Иначе
			ФормаОплатыПоДокументу = Неопределено;
		КонецЕсли;	
		
		РезультатПроверки = Новый Массив;  
		Пока Выборка.Следующий() Цикл 
			ОшибкаПоДокументу = "";
			Для Каждого Основание Из Объект.Основания Цикл  
				Если Основание.Документ = Выборка.Основание Тогда 
					Если Объект.ПрибытиеНаОтгрузку <> Выборка.ДатаДоставки Тогда  
						Если ЗначениеЗаполнено(Выборка.ДатаДоставки) Тогда
							ОшибкаПоДокументу = СтрШаблон("%1%2. ","Разные даты доставки - ",Выборка.ДатаДоставки);
						Иначе
							ОшибкаПоДокументу = СтрШаблон("%1%2. ","Разные даты доставки - ","Не заполнено");
						КонецЕсли;	
					КонецЕсли;	
					Если ФормаОплатыПоДокументу <> Выборка.ФормаОплаты Тогда  
						Если ЗначениеЗаполнено(Выборка.ФормаОплаты) Тогда
							ОшибкаПоДокументу = СтрШаблон("%1%2%3. ",ОшибкаПоДокументу,"Разные формы оплаты - ",Выборка.ФормаОплаты);
						Иначе 
							ОшибкаПоДокументу = СтрШаблон("%1%2%3. ",ОшибкаПоДокументу,"Разные формы оплаты - ","Не заполнено");
						КонецЕсли;	
					КонецЕсли;
				КонецЕсли;	
			КонецЦикла;
			Если ОшибкаПоДокументу <> "" Тогда  
				ТекущиеОшибки = Новый Структура();
				ТекущиеОшибки.Вставить("Ошибка",ОшибкаПоДокументу);
				ТекущиеОшибки.Вставить("Документ",Выборка.Ссылка);
				РезультатПроверки.Добавить(ТекущиеОшибки);
			КонецЕсли;	
		КонецЦикла;    
		
		Если РезультатПроверки.Количество() > 0 Тогда
			Возврат РезультатПроверки; 
		Иначе
			Возврат Неопределено;
		КонецЕсли;	
	КонецЕсли;
	
	Возврат Неопределено;    
	
КонецФункции	

&НаКлиенте
Процедура ПередЗаписью(Отказ, ПараметрыЗаписи)
	
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение И объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная") Тогда
		Если ЕстьРеализацииПоДоговоруБезОтметкиКассы() Тогда
		   ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Запись;
        КонецЕсли;  	
    КонецЕсли;
	
	Если Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная") И (Объект.Широта = 0 ИЛИ Объект.Долгота = 0) Тогда
		ПоказатьПредупреждение(,"Не заданы координаты! Выберите точку доставки на карте.",10);
		Отказ = Истина;
	КонецЕсли;    
	
	Если ПроверкаНаДублиЗаказРеализация() Тогда 
		Сообщить("В основаниях задвоен документ продажи. Присутствует и заказ клиента, и реализация"); 
		Отказ = Истина; 
	КонецЕсли;   
	
	Если ИнтервалИзменен Тогда 
		Если ЭтоЛогист() ИЛИ ДоступностьИнтервала() Тогда 
			ИнтервалИзменен = Ложь; 
		Иначе
			Сообщить("Интервал закрылся, выберите другой интервал доставки или обратитесь в отдел Логистики"); 
			Объект.Интервал = неопределено; 
			Отказ = Истина; 
		КонецЕсли; 
	КонецЕсли; 
	
	СохранитьАдресДоставкиВОбъектДоставки();   
	КомментарийВозвратнойТары();
	
	Если Объект.ДубльТТН Тогда
		Объект.Комментарий = Объект.Комментарий + " , Дубль ТТН - передать клиенту";
	КонецЕсли;
		
	
КонецПроцедуры    

&НаСервере 
Процедура КомментарийВозвратнойТары()
	Если Объект.Тариф.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.Внутренняя тогда
		Если Не СтрНайти(Объект.Комментарий,"Забрать возвратную тару!") Тогда
			ДеньНедели = ДеньНедели(Объект.ПрибытиеНаОтгрузку);	
			Если ДеньНедели = 1 ИЛИ ДеньНедели = 3 ИЛИ ДеньНедели = 5 Тогда
				Объект.Комментарий = Объект.Комментарий + " Забрать возвратную тару!";
			КонецЕсли;
		КонецЕсли;
	Конецесли;
КонецПроцедуры

&НаСервере
Функция ДоступностьИнтервала()
	ТекстЗапроса = Справочники.ИнтервалыДоставки.ПолучитьТекстЗапросаДляВыбораИнтервала();
	Запрос = Новый Запрос;    
	Запрос.Текст =  ТекстЗапроса + "
	|Где Результат2.Ссылка = &Интервал";

	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	Запрос.УстановитьПараметр("ДатаОтгрузки", Объект.ПрибытиеНаОтгрузку);
	Запрос.УстановитьПараметр("Подразделение", Объект.Подразделение);
	Запрос.УстановитьПараметр("ВидДоставки", Объект.ВидДоставки);
	Если ДеньНедели(Объект.ПрибытиеНаОтгрузку) < 6  И Объект.ВидДоставки <> Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
		Запрос.УстановитьПараметр("ДеньНедели", 0);
	Иначе
		Запрос.УстановитьПараметр("ДеньНедели", ДеньНедели(Объект.ПрибытиеНаОтгрузку));
	КонецЕсли;
	Если Объект.НетНомераДекларацииЕГАИСуЮрЛица Тогда
		Запрос.УстановитьПараметр("КорИнтервала", 30);
	Иначе 
		Запрос.УстановитьПараметр("КорИнтервала", 0);
	КонецЕсли;
	Запрос.УстановитьПараметр("ДоставкаСРазгрузкой", Объект.ДоставкаСРазгрузкой);
	Запрос.УстановитьПараметр("Интервал", Объект.Интервал); 
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.МожноВыбрать; 
	Иначе 
		Возврат Ложь; 
	КонецЕсли; 
КонецФункции

&НаСервере 
Функция ПроверкаНаДублиЗаказРеализация()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказНаДоставкуКлиентуОснования.Документ КАК Документ,
	|	1 КАК Количество
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	&Основания КАК ЗаказНаДоставкуКлиентуОснования 
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Документ КАК Документ
	|ПОМЕСТИТЬ ВТ2
	|ИЗ
	|	ВТ КАК ВТ
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ВТ.Документ) = ТИП(Документ.РеализацияТоваровУслуг)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка
	|ИЗ
	|	ВТ КАК ВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ПО ВТ.Документ = РеализацияТоваровУслуг.ЗаказКлиента
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(ВТ.Документ) = ТИП(Документ.ЗАказКлиента)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ2.Документ КАК Документ,
	|	СУММА(1) КАК Количество
	|ПОМЕСТИТЬ ВТ3
	|ИЗ
	|	ВТ2 КАК ВТ2
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ2.Документ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ3.Документ КАК Документ,
	|	ВТ3.Количество КАК Количество
	|ИЗ
	|	ВТ3 КАК ВТ3
	|ГДЕ
	|	ВТ3.Количество > 1";
	
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ТипЗнч(ВыборкаДетальныеЗаписи.Документ) = Тип("ДокументСсылка.РеализацияТоваровУслуг") ТОгда 
			Возврат Истина; 
		КонецЕсли; 
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Если НужнаЗаписьСобытияОбъектов Тогда
		ЗаписатьСобытиеОбъектовАльтерра();
		НужнаЗаписьСобытияОбъектов = Ложь;
	КонецЕсли;
	
	УстановитьВидимостьДоступность();
	ОбновитьНадписи();  
	
	РезультатПроверки = ПроверитьФормуОплатыДатуДоставкиВЛистеСогласованияНаСервере();
	Если РезультатПроверки <> Неопределено Тогда    
		ОчиститьСообщения();
		Для Каждого ТекущийРезультат Из РезультатПроверки Цикл 
			ТекущееСообщение = Новый СообщениеПользователю;
			ТекущееСообщение.Текст = СтрШаблон("%1 %2",ТекущийРезультат.Ошибка,ТекущийРезультат.Документ);
			ТекущееСообщение.КлючДанных = ТекущийРезультат.Документ;
			ТекущееСообщение.Сообщить();
		КонецЦикла;	 
	КонецЕсли; 
	
КонецПроцедуры

