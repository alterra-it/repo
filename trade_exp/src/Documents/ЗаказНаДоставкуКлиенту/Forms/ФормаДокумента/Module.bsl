	КонецЕсли;  
	
	//Автоопределение 
	УстановитьТариф(); 
	
	Если  Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная")  Тогда
	    УстановитьСтоимостиДляКлиента();	
	ИначеЕсли Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы") Тогда
		УстановкаСтоимостиПоДокументуПродажи();
	КонецЕсли;  
	
