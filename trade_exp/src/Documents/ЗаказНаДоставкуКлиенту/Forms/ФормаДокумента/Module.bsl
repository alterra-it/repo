#Область Разгрузка

&НаСервере
Функция ПолучитьАдресПараметровРазгрузки()
	
	ПараметрыРазгрузки = УправлениеЛогистикойСервер.ПолучитьСтруктуруПараметровРазгрузки();
	ЗаполнитьЗначенияСвойств(ПараметрыРазгрузки, Объект, "Этаж, НомерКвартиры, ВариантРазгрузки, НаличиеПандуса, РучнаяКорректировкаВариантовРазгрузки");
	
	ТоварыКРазгрузке = УправлениеЛогистикойСервер.ПолучитьТаблицуРазгрузкиТовара(Объект);
	
	Для каждого Строка Из ТоварыКРазгрузке Цикл 
		Количество = Строка.Количество;
		Если Количество < 0  Тогда  
			Строка.Количество = Количество *(-1);
			Строка.Вес = Строка.Вес *(-1); 
			Строка.Объем = Строка.ОбЪем *(-1);
		КонецЕсли;
		
	КонецЦикла;
	
	ПараметрыРазгрузки.ТЗТоварыКРазгрузке = ТоварыКРазгрузке;
	ПараметрыРазгрузки.Зона = УправлениеЛогистикойСервер.ПолучитьГлобальнуюЗону(Объект.ЗонаДоставкиДляВодителя, Объект.Подразделение);
	ПараметрыРазгрузки.СНДС = Объект.СтоимостьДоставкиСНДС > 0; 
	
	ПараметрыРазгрузкиАдресВХранилище = ПоместитьВоВременноеХранилище(ПараметрыРазгрузки, ЭтотОбъект.УникальныйИдентификатор);
	
	Возврат ПараметрыРазгрузкиАдресВХранилище;
	
КонецФункции

