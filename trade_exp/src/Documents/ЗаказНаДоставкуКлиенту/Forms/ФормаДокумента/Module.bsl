&НаСервере
Процедура ПолучитьСтатусыДоставкиЯндекс()
       
       ДоставкаЯндекс.Параметры.УстановитьЗначениеПараметра("ЗаказНаДоставку", Объект.Ссылка);
       
       Запрос = Новый Запрос;
       Запрос.Текст =
               "ВЫБРАТЬ
               |       Трекинг,
               |       ПлановоеВремяДоставки
               |ИЗ 
               |       РегистрСведений.ДоставкаЯндекс
               |ГДЕ 
               |       ЗаказНаДоставку = &ЗаказНаДоставку
               |       И СтатусДоставки = ЗНАЧЕНИЕ(Перечисление.СтатусыДоставкиЯндекс.ПолученТрекинг)";
               
       Запрос.УстановитьПараметр("ЗаказНаДоставку", Объект.Ссылка);
       
       Выборка = Запрос.Выполнить().Выбрать();
       Если Выборка.Следующий() Тогда
               ТрекингДоставки = Выборка.Трекинг;
               ПлановоеВремяДоставки = Выборка.ПлановоеВремяДоставки;
               Элементы.ПлановоеВремяДоставки.Видимость = ЗначениеЗаполнено(ПлановоеВремяДоставки);
       Иначе
               Элементы.ПерейтиТрекингДоставкиЗаказа.Видимость = Ложь;
               Элементы.ПлановоеВремяДоставки.Видимость = Ложь; 
       КонецЕсли
       
