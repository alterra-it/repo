&НаСервере
Процедура ОбновитьДинамическийСписок()
	
	мОснование = Новый Массив;
	Для Каждого стрОснование Из Объект.Основания Цикл
		мОснование.Добавить(стрОснование.Документ);
	КонецЦикла;
	ГруппаУслугДоставки = АльтерраОбщегоНазначения.ПолучитьГруппуУслугДоставкиОбщую();
	
	//+после изменения типа у реквизита Цена (Расширение / РеализацияТоваровУслуг / Товары) исправить запрос в свойствах дин списка
	ТоварОснований.ТекстЗапроса = ПолучитьТекстЗапросаТоварОснований();
	//-
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ТоварОснований, "МассивДокументов", мОснование, Истина);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(ТоварОснований, "ГруппаУслугДоставки", ГруппаУслугДоставки, Истина);
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Рейсы, "Ссылка", Объект.Ссылка, Истина);
	
	мОснованиеНарезка = Новый Массив;
	Для Каждого стрОснование Из Объект.Основания Цикл
		Если типзнч(стрОснование.Документ) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			мОснованиеНарезка.Добавить(стрОснование.Документ.ДокументПродажи);
		Иначе
			мОснованиеНарезка.Добавить(стрОснование.Документ);
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(Нарезка, "МассивДокументов", мОснованиеНарезка, Истина);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьТекстЗапросаТоварОснований()
	Текст = "ВЫБРАТЬ
	|	Товары.Ссылка КАК Документ,
	|	Товары.Ссылка.Контрагент КАК Контрагент,
	|	Товары.Ссылка.ПрибытиеНаОтгрузку КАК ПрибытиеНаОтгрузку,
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.КоличествоУпаковок) КАК Количество,
	|	ВЫБОР
	|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ КАК ЕдИзм,
	|	СУММА(Товары.Цена) КАК Цена,
	|	СУММА(Товары.СуммаСНДС) КАК Сумма,
	|	СУММА(Товары.СуммаНДС) КАК СуммаНДС,
	|	Товары.Ссылка.Дата КАК Дата,
	|	СУММА(Товары.СуммаРучнойСкидки + Товары.СуммаАвтоматическойСкидки) КАК СуммаСкидки,
	|	Товары.Номенклатура.Код КАК Код,
	|	ЕСТЬNULL(Товары.Склад.Ссылка, Товары.Ссылка.Склад) КАК Склад,
	|	Товары.Характеристика КАК Характеристика
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка В(&МассивДокументов)
	|	И НЕ Товары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Ссылка,
	|	Товары.Номенклатура,
	|	ВЫБОР
	|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	Товары.Ссылка.ПрибытиеНаОтгрузку,
	|	Товары.Ссылка.Дата,
	|	Товары.Ссылка.Контрагент,
	|	Товары.Номенклатура.Код,
	|	Товары.Склад,
	|	Товары.Характеристика,
	|	ЕСТЬNULL(Товары.Склад.Ссылка, Товары.Ссылка.Склад)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Товары.Ссылка,
	|	Товары.Ссылка.Контрагент,
	|	NULL,
	|	Товары.Номенклатура,
	|	СУММА(Товары.КоличествоУпаковок),
	|	ВЫБОР
	|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	СУММА(Товары.Цена),
	|	СУММА(Товары.СуммаСНДС),
	|	СУММА(Товары.СуммаНДС),
	|	Товары.Ссылка.Дата,
	|	СУММА(0),
	|	Товары.Номенклатура.Код,
	|	Товары.Ссылка.Склад,
	|	Товары.Характеристика
	|ИЗ
	|	Документ.ВозвратТоваровОтКлиента.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка В(&МассивДокументов)
	|	И НЕ Товары.Номенклатура В ИЕРАРХИИ (&ГруппаУслугДоставки)
	|
	|СГРУППИРОВАТЬ ПО
	|	Товары.Ссылка,
	|	Товары.Номенклатура,
	|	ВЫБОР
	|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
	|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
	|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
	|	КОНЕЦ,
	|	Товары.Ссылка.Дата,
	|	Товары.Ссылка.Контрагент,
	|	Товары.Номенклатура.Код,
	|	Товары.Характеристика,
	|	Товары.Ссылка.Склад
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Ссылка,
	|	ПеремещениеТоваровТовары.Ссылка.Организация,
