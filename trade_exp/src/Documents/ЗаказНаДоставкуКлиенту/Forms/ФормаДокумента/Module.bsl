&НаКлиенте
Процедура ТоварОснованийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ТоварОснований.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда 
		Документ = ТекущиеДанные.Документ;
		Если ТипЗнч(Документ)  = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			ОткрытьФорму("Документ.РеализацияТоваровУслуг.ФормаОбъекта", Новый Структура("Ключ", Документ), ЭтаФорма);
		ИначеЕсли ТипЗнч(Документ)  = Тип("ДокументСсылка.ЧекККМ") Тогда
			ОткрытьФорму("Документ.ЧекККМ.ФормаОбъекта", Новый Структура("Ключ", Документ), ЭтаФорма);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РейсыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Документ = Элементы.Рейсы.ТекущиеДанные.Рейс;
	ОткрытьФорму("Документ.ЗаданиеНаПеревозкуРейс.ФормаОбъекта", Новый Структура("Ключ", Документ), ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ТарифВРучнуюПриИзменении(Элемент)
	
	Если  Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.Розничная") Тогда
		
		Если (Не ЗначениеЗаполнено(Объект.Интервал)Или Не ЗначениеЗаполнено(Объект.ЗонаДоставкиДляВодителя))
			И Объект.ТарифВРучную Тогда
			Объект.ТарифВРучную = Ложь;
			Сообщить("Для выбора тарифа не заполнены необходимые параметры");	
			Возврат;
		ИначеЕсли Не Объект.ТарифВРучную Тогда
			УстановитьТариф();	
			УстановитьСтоимостиДляКлиента();
		КонецЕсли;  
		
	ИначеЕсли  Объект.ВидДоставки = ПредопределенноеЗначение("Перечисление.ВидыДоставокДоКлиента.ДистрибуцияСборныеГрузы") Тогда
		
		Если Не Объект.ТарифВРучную Тогда
			УстановитьТариф();	
			УстановкаСтоимостиПоДокументуПродажи();
		КонецЕсли;

	КонецЕсли;
	
    УстановитьВидимостьДоступность();

КонецПроцедуры

