&НаСервере
Процедура ИнтервалПриИзмененииСервер()
	
	ПоказыватьИнтервал = Истина;	
	Если ЗначениеЗаполнено(Объект.Интервал) Тогда
		Объект.ВремяДоставкиС= Объект.Интервал.ВремяС;
		Объект.ВремяДоставкиПо= Объект.Интервал.ВремяПО;
		НачальноеВремя = Объект.Интервал.ВремяС;
		
		Если Объект.Интервал.ЭкспрессДоставка Тогда
			Если НачалоДня(Объект.ПрибытиеНаОтгрузку) = НачалоДня(ТекущаяДата()) Тогда
				
				ТекущееВремя = ПолучитьВремяСПоправкойНаИнтервал();
				Если (ТекущееВремя >= Объект.Интервал.ВремяС) И (ТекущееВремя <= Объект.Интервал.ВремяПо) Тогда
					НачальноеВремя = ТекущееВремя;
					
				ИначеЕсли ТекущееВремя > Объект.Интервал.ВремяПо Тогда
					Если РольДоступна("ОтделЛогистики") или РольДоступна("ПолныеПрава") Тогда 
						ПоказыватьИнтервал = истина; 
					Иначе 	  
						Сообщить("Время сегодня выходит за пределы интервала отгрузки");
						ПоказыватьИнтервал = Ложь;
					КонецЕсли;
				КонецЕсли;	
			КонецЕсли;
		Иначе
			ПоказыватьИнтервал = Ложь;
		КонецЕсли;
		
		Если ПоказыватьИнтервал Тогда
			Объект.ЭкспрессДоставка = Объект.Интервал.ЭкспрессДоставка;
			Элементы.ВремяДоставкиС.Доступность = Истина;
			Элементы.ВремяДоставкиПо.Доступность = Истина;
			Элементы.ВремяДоставкиС.АвтоВыборНезаполненного = Истина;
			Элементы.ВремяДоставкиПо.АвтоВыборНезаполненного = Истина;
			ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиС, НачальноеВремя, Объект.Интервал.ВремяПо);
			ЗаполнитьСписокВыбораПоляВремени(Элементы.ВремяДоставкиПо, НачальноеВремя, Объект.Интервал.ВремяПо);
		Иначе
			Объект.ЭкспрессДоставка = Ложь;
			Элементы.ВремяДоставкиС.Доступность = Ложь;
			Элементы.ВремяДоставкиПо.Доступность = Ложь;
		КонецЕсли;
		
		Если Объект.ЭкспрессДоставка Тогда
			Объект.ВремяДоставкиС = '00010101000000';
			Объект.ВремяДоставкиПо = '00010101000000';
		КонецЕсли;
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РасчетПоРасстояниюПриИзменении(Элемент)
	
	Если Объект.РасчетПоРасстоянию Тогда
		Дистанция = Элементы.КартаЯндекс.document.getElementById("distance").value;
		Попытка
			Объект.Расстояние = Число(Дистанция) / 1000;
		Исключение
			Объект.Расстояние = 0;
		КонецПопытки;
		
		Объект.СтоимостьЗаКМ = ПолучитьСтоимостьЗаКмПоТарифу(Объект.Подразделение, Объект.Тариф);
		РасстояниеПриИзменении(Неопределено);
	Иначе
		Объект.СтоимостьПоРасстоянию = 0;
	КонецЕсли;   
	
КонецПроцедуры  

