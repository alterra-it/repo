	ЧекККМНарезка.Отрезок8,
	ЧекККМНарезка.Отрезок9,
	ЧекККМНарезка.Отрезок10,
	ЧекККМНарезка.Отрезок11,
	ЧекККМНарезка.Отрезок12
ИЗ
	Документ.ЧекККМ.Нарезка КАК ЧекККМНарезка
ГДЕ
	ЧекККМНарезка.Ссылка В(&amp;МассивДокументов)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗаказКлиентаНарезка.Номенклатура,
	ЗаказКлиентаНарезка.Длина,
	ЗаказКлиентаНарезка.Равные,
	ЗаказКлиентаНарезка.Количество,
	ЗаказКлиентаНарезка.Отрезок1,
	ЗаказКлиентаНарезка.Отрезок2,
	ЗаказКлиентаНарезка.Отрезок3,
	ЗаказКлиентаНарезка.Отрезок4,
	ЗаказКлиентаНарезка.Отрезок5,
	ЗаказКлиентаНарезка.Отрезок6,
	ЗаказКлиентаНарезка.Отрезок7,
	ЗаказКлиентаНарезка.Отрезок8,
	ЗаказКлиентаНарезка.Отрезок9,
	ЗаказКлиентаНарезка.Отрезок10,
	ЗаказКлиентаНарезка.Отрезок11,
	ЗаказКлиентаНарезка.Отрезок12
ИЗ
	Документ.ЗаказКлиента.Нарезка КАК ЗаказКлиентаНарезка
ГДЕ
	ЗаказКлиентаНарезка.Ссылка В(&amp;МассивДокументов)</queryText>
