Процедура СформироватьДвиженияВИспользованиеИнтерваловДоставки() 
	
	   				
	Если ДополнительныеСвойства.ИзменитьПериодИнтервала Тогда
		ДатаВыбораИнтервала = ТекущаяДата();  
	Иначе
		НаборЗаписей = РегистрыНакопления.ИспользованиеИнтерваловДоставки.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Ссылка);
		НаборЗаписей.Прочитать(); 
		ДатаВыбораИнтервала = ?(НаборЗаписей.Количество() = 0,ТекущаяДата(),НаборЗаписей[0].Период);
	КонецЕсли;
	
	    Движения.ИспользованиеИнтерваловДоставки.Записывать = Истина;
		Движение = Движения.ИспользованиеИнтерваловДоставки.Добавить();

		Движение.Период = ДатаВыбораИнтервала;
	    Движение.ДатаИспользования = ПрибытиеНаОтгрузку;
		Движение.Интервал = Интервал;	
		Движение.ВидДоставки = ВидДоставки;
		Движение.Подразделение = Подразделение; 
		
		Если ДоставкаСРазгрузкой  Тогда 
			Движение.КоличествоСРазгрузкой = 1;
			Движение.ДляРазгрузки = Истина;
		Иначе
			Движение.Количество = 1; 
			Движение.ДляРазгрузки = Ложь;
		КонецЕсли;
	
КонецПроцедуры


