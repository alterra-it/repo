#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Процедура ПодобратьТипНалога(ДокументОбъект) Экспорт
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.СписаниеБезналичныхДенежныхСредств") Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	СписаниеБезналичныхДенежныхСредств.Ссылка КАК Ссылка,
			|	СписаниеБезналичныхДенежныхСредств.Ссылка.ТипНалога КАК ТипНалога,
			|	СписаниеБезналичныхДенежныхСредств.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств
			|ИЗ
			|	Документ.СписаниеБезналичныхДенежныхСредств.РасшифровкаПлатежа КАК СписаниеБезналичныхДенежныхСредств
			|ГДЕ
			|	СписаниеБезналичныхДенежныхСредств.Ссылка.Организация = &Организация
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.ТипПлатежногоДокумента = &ТипПлатежногоДокумента
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.БанковскийСчет = &БанковскийСчет
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.ХозяйственнаяОперация = &ХозяйственнаяОперация
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.Контрагент = &Контрагент
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.БанковскийСчетКонтрагента = &БанковскийСчетКонтрагента
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.КодБК = &КодБК
			|	И СписаниеБезналичныхДенежныхСредств.Ссылка.ТипНалога <> ЗНАЧЕНИЕ(Справочник.ВидыНалоговВзносов.ПустаяСсылка)
			|
			|УПОРЯДОЧИТЬ ПО
			|	СписаниеБезналичныхДенежныхСредств.Ссылка.Дата УБЫВ";
		
		Запрос.УстановитьПараметр("Организация", ДокументОбъект.Организация);
		Запрос.УстановитьПараметр("ТипПлатежногоДокумента", ДокументОбъект.ТипПлатежногоДокумента);
		Запрос.УстановитьПараметр("БанковскийСчет", ДокументОбъект.БанковскийСчет);
		Запрос.УстановитьПараметр("ХозяйственнаяОперация", ДокументОбъект.ХозяйственнаяОперация);
		Запрос.УстановитьПараметр("Контрагент", ДокументОбъект.Контрагент);
		Запрос.УстановитьПараметр("БанковскийСчетКонтрагента", ДокументОбъект.БанковскийСчетКонтрагента);
		Запрос.УстановитьПараметр("КодБК", ДокументОбъект.КодБК);
		
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() И ЗначениеЗаполнено(Результат.ТипНалога) Тогда
			ДокументОбъект.ТипНалога = Результат.ТипНалога;
			Коллекция = ДокументОбъект.РасшифровкаПлатежа;
			Для Каждого Элемент Из Коллекция Цикл 
				Элемент.СтатьяДвиженияДенежныхСредств = Результат.СтатьяДвиженияДенежныхСредств;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

