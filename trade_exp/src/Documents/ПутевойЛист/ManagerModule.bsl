Функция СформироватьПутевойЛистБОт01092023(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЗапросПоДокументам = Новый Запрос;
	ЗапросПоДокументам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоДокументам.Текст =
	"ВЫБРАТЬ
	|	ПутевойЛистМаршруты.Дата КАК Дата,
	|	ПутевойЛистМаршруты.МестоОтправления КАК МестоОтправления,
	|	ПутевойЛистМаршруты.МестоНазначения КАК МестоНазначения,
	|	ПутевойЛистМаршруты.Обратно КАК Обратно,
	|	ПутевойЛистМаршруты.Пройдено КАК Пройдено,
	|	ПутевойЛистМаршруты.ВремяВыезда КАК ВремяВыезда,
	|	ПутевойЛистМаршруты.ВремяВозвращения КАК ВремяВозвращения,
	|	ПутевойЛистМаршруты.Ссылка.Водитель.ФизическоеЛицо КАК Водитель
	|ИЗ
	|	Документ.ПутевойЛист.Маршруты КАК ПутевойЛистМаршруты
	|ГДЕ
	|	ПутевойЛистМаршруты.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ
	|	СУММА(Пройдено)
	|ПО
	|	ОБЩИЕ";
	 	
	ВыборкаПоИтогам		= ЗапросПоДокументам.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПоИтогам.Следующий();
	ВыборкаПоСтрокам = ВыборкаПоИтогам.Выбрать();
	
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.ПутевойЛист.ПФ_MXL_ПутевойЛистБОт01092023");
	ТабДокумент = Новый ТабличныйДокумент;
