Функция СформироватьПутевойЛист(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЗапросПоДокументам = Новый Запрос;
	ЗапросПоДокументам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоДокументам.Текст =
	"ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(ПутевойЛист.Организация.НаименованиеСокращенное) КАК ОрганизацияПредставление,
	|	ПРЕДСТАВЛЕНИЕ(ПутевойЛист.Организация.КодПоОКПО) КАК ОрганизацияПоОКПО,
	|	ПРЕДСТАВЛЕНИЕ(ПутевойЛист.Организация.Префикс) КАК Префикс,
	|	ПутевойЛист.Ссылка КАК Ссылка,
	|	ПутевойЛист.Номер КАК Номер,
	|	ПутевойЛист.Дата КАК ДатаДокумента,
	|	ПутевойЛист.Организация КАК Организация,
	|	ПутевойЛист.Водитель.ФизическоеЛицо КАК Водитель,
	|	ПутевойЛист.Механик,
	|	ПутевойЛист.ТранспортноеСредство.ГосНомер КАК ГосНомер,
	|	ПутевойЛист.ТранспортноеСредство.Модель КАК МаркаАвтомобиля,
	|	ПутевойЛист.Водитель.НомерВодительскогоУдостоверения КАК НомерУдостоверения,
	|	ПутевойЛист.РасходПоНорме,
	|	ПутевойЛист.РасходФактический,
	|	ВЫБОР
	|		КОГДА ПутевойЛист.ТранспортноеСредство.УчитыватьПоказанияСпидометра
	|			ТОГДА ПутевойЛист.СпидометрНачало
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК СпидометрНачало,
	|	ВЫБОР
	|		КОГДА ПутевойЛист.ТранспортноеСредство.УчитыватьПоказанияСпидометра
	|			ТОГДА ПутевойЛист.СпидометрВозвращение
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК СпидометрВозвращение,
	|	ВЫБОР
	|		КОГДА ПутевойЛист.Водитель.УчитыватьОстатокТоплива
	|			ТОГДА ПутевойЛист.ОстатокПриВыезде
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ОстатокПриВыезде,
	|	ВЫБОР
	|		КОГДА ПутевойЛист.Водитель.УчитыватьОстатокТоплива
	|			ТОГДА ПутевойЛист.ОстатокПриВозвращении
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК ОстатокПриВозвращении,
	|	ВЫБОР
	|		КОГДА ПутевойЛист.РасходПоНорме > ПутевойЛист.РасходФактический
	|			ТОГДА ПутевойЛист.РасходПоНорме - ПутевойЛист.РасходФактический
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Экономия,
	|	ВЫБОР
	|		КОГДА ПутевойЛист.РасходПоНорме < ПутевойЛист.РасходФактический
	|			ТОГДА ПутевойЛист.РасходФактический - ПутевойЛист.РасходПоНорме
	|		ИНАЧЕ """"
	|	КОНЕЦ КАК Перерасход
	|ИЗ
	|	Документ.ПутевойЛист КАК ПутевойЛист
	|ГДЕ
	|	ПутевойЛист.Ссылка в (&МассивОбъектов)";
	 	
	ВыборкаПоДокументам		= ЗапросПоДокументам.Выполнить().Выбрать();
	
	
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.ПутевойЛист.ПФ_MXL_ПутевойЛист");
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПутевойЛист";
	ОбластьШапки 						= Макет.ПолучитьОбласть("Шапка");
	
	ВыборкаПоДокументам.Следующий();
		
	ОбластьШапки.Параметры.Заполнить(ВыборкаПоДокументам);
	ОбластьШапки.Параметры.Водитель=ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ВыборкаПоДокументам.Водитель);
	ОбластьШапки.Параметры.Механик=ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ВыборкаПоДокументам.Механик);
	ОбластьШапки.Параметры.НомерДокумента=ВыборкаПоДокументам.Номер;
	ОбластьШапки.Параметры.ДатаДокумента=ВыборкаПоДокументам.ДатаДокумента;
	ТабДокумент.Вывести(ОбластьШапки);
	
	ТабДокумент.АвтоМасштаб = Истина;
	
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат ТабДокумент; 
	
КонецФункции

Функция СформироватьПутевойЛистБ(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЗапросПоДокументам = Новый Запрос;
	ЗапросПоДокументам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоДокументам.Текст =
	"ВЫБРАТЬ
	|	ПутевойЛистМаршруты.Дата КАК Дата,
	|	ПутевойЛистМаршруты.МестоОтправления,
	|	ПутевойЛистМаршруты.МестоНазначения,
	|	ПутевойЛистМаршруты.Обратно,
	|	ПутевойЛистМаршруты.Пройдено КАК Пройдено,
	|	ПутевойЛистМаршруты.ВремяВыезда,
	|	ПутевойЛистМаршруты.ВремяВозвращения
	|ИЗ
	|	Документ.ПутевойЛист.Маршруты КАК ПутевойЛистМаршруты
	|ГДЕ
	|	ПутевойЛистМаршруты.Ссылка в (&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ
	|	СУММА(Пройдено)
	|ПО
	|	ОБЩИЕ";
	 	
	ВыборкаПоИтогам		= ЗапросПоДокументам.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПоИтогам.Следующий();
	ВыборкаПоСтрокам = ВыборкаПоИтогам.Выбрать();
	
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.ПутевойЛист.ПФ_MXL_ПутевойЛистБ");
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПутевойЛистНовый";
	ОбластьШапки 						= Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьСтроки 						= Макет.ПолучитьОбласть("СтрокаТаблицы");
	ОбластьСтрокиПустая					= Макет.ПолучитьОбласть("СтрокаТаблицыПустая");
	ОбластьПодвала 						= Макет.ПолучитьОбласть("ПодвалТаблицы");

	ТабДокумент.Вывести(ОбластьШапки);
    к=0;
	пока ВыборкаПоСтрокам.Следующий() цикл
	к=к+1;	
