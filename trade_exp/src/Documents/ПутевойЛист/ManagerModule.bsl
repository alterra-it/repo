Функция СформироватьПутевойЛистБНовый(МассивОбъектов, ОбъектыПечати, ПараметрыПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЗапросПоДокументам = Новый Запрос;
	ЗапросПоДокументам.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	ЗапросПоДокументам.Текст =
	"ВЫБРАТЬ
	|	ПутевойЛистМаршруты.Дата КАК Дата,
	|	ПутевойЛистМаршруты.МестоОтправления КАК МестоОтправления,
	|	ПутевойЛистМаршруты.МестоНазначения КАК МестоНазначения,
	|	ПутевойЛистМаршруты.Обратно КАК Обратно,
	|	ПутевойЛистМаршруты.Пройдено КАК Пройдено,
	|	ПутевойЛистМаршруты.ВремяВыезда КАК ВремяВыезда,
	|	ПутевойЛистМаршруты.ВремяВозвращения КАК ВремяВозвращения,
	|	ПутевойЛистМаршруты.Ссылка.Водитель.ФизическоеЛицо КАК Водитель
	|ИЗ
	|	Документ.ПутевойЛист.Маршруты КАК ПутевойЛистМаршруты
	|ГДЕ
	|	ПутевойЛистМаршруты.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ
	|	СУММА(Пройдено)
	|ПО
	|	ОБЩИЕ";
	 	
	ВыборкаПоИтогам		= ЗапросПоДокументам.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВыборкаПоИтогам.Следующий();
	ВыборкаПоСтрокам = ВыборкаПоИтогам.Выбрать();
	
	Макет 		= УправлениеПечатью.МакетПечатнойФормы("Документ.ПутевойЛист.ПФ_MXL_ПутевойЛистБНОвый");
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПутевойЛистБНовый";
	ОбластьШапки 						= Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьСтроки 						= Макет.ПолучитьОбласть("СтрокаТаблицы");
	ОбластьСтрокиПустая					= Макет.ПолучитьОбласть("СтрокаТаблицыПустая");
	ОбластьПодвала 						= Макет.ПолучитьОбласть("ПодвалТаблицы");

	ТабДокумент.Вывести(ОбластьШапки);
	к=0;     
	пока ВыборкаПоСтрокам.Следующий() цикл
		к=к+1; 
		Если к = 1 тогда
			ОбластьПодвала.Параметры.Водитель = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ВыборкаПоСтрокам.Водитель);
		КонецЕсли;
		ОбластьСтроки.Параметры.Номер = к;
		ОбластьСтроки.Параметры.Заполнить(ВыборкаПоСтрокам);
		ОбластьСтроки.Параметры.Маршрут=СОКРЛП(ВыборкаПоСтрокам.МестоОтправления)+" - "+СОКРЛП(ВыборкаПоСтрокам.МестоНазначения)+?(ВыборкаПоСтрокам.Обратно," - "+СОКРЛП(ВыборкаПоСтрокам.МестоОтправления),"");
		ТабДокумент.Вывести(ОбластьСтроки); 
	конеццикла;
	
	для н=к по 25 цикл
		ТабДокумент.Вывести(ОбластьСтрокиПустая);
	конеццикла;	
	ОбластьПодвала.Параметры.ИтогоКМ=ВыборкаПоИтогам.Пройдено; 
	ТабДокумент.Вывести(ОбластьПодвала);
	ТабДокумент.АвтоМасштаб = Истина;
	Если ПривилегированныйРежим() Тогда
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат ТабДокумент;
	
