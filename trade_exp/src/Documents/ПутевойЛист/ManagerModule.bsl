#Область ОбработчикиСобытий

Функция ПоказаниеСпидометра(ДокументСсылка,ТС)экспорт
   	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоказанияСпидометраСрезПоследних.Показания
		|ИЗ
		|	РегистрСведений.ПоказанияСпидометра.СрезПоследних(&период, ТранспортноеСредство = &ТранспортноеСредство) КАК ПоказанияСпидометраСрезПоследних";

	Запрос.УстановитьПараметр("Период", ДокументСсылка.Дата-1);
	Запрос.УстановитьПараметр("ТранспортноеСредство", ТС);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.Количество() = 1 Тогда
		Показание = Выборка.Показания;
	иначе
		Показание=ТС.НачальноеПоказание;
	конецесли;
	Возврат Показание;
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА

КонецФункции // ПоказаниеСпидометра()

Функция ОстатокГСМ(ДокументСсылка,Склад,Топливо)экспорт
   	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыНаСкладахОстатки.Номенклатура КАК Топливо,
		|	ЕСТЬNULL(ТоварыНаСкладахОстатки.ВНаличииОстаток, 0) + ЕСТЬNULL(ДвижениеТопливаОстатки.КоличествоОстаток, 0) КАК Количество
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(
		|			&период,
		|			Склад = &Склад
		|				И Номенклатура = &Топливо) КАК ТоварыНаСкладахОстатки
		|		ПОЛНОЕ СОЕДИНЕНИЕ РегистрНакопления.ДвижениеТоплива.Остатки(
		|				&период,
		|				Склад = &Склад
		|					И Топливо = &топливо) КАК ДвижениеТопливаОстатки
		|		ПО ТоварыНаСкладахОстатки.Номенклатура = ДвижениеТопливаОстатки.Топливо
		|			И ТоварыНаСкладахОстатки.Склад = ДвижениеТопливаОстатки.Склад
		|{ИТОГИ ПО
		|	Количество}";

	Запрос.УстановитьПараметр("Период", ДокументСсылка.Дата-1);
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("топливо", Топливо);


	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() И Выборка.Количество() = 1 Тогда
		Показание = Выборка.Количество;
	иначе
		Показание=0;
	конецесли;
	Возврат Показание;
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА

КонецФункции // ПоказаниеСпидометра()

