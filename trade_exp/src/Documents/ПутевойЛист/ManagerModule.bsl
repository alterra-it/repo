	к=0;     
	пока ВыборкаПоСтрокам.Следующий() цикл
		к=к+1; 
		Если к = 1 тогда
			ОбластьПодвала.Параметры.Водитель = ФизическиеЛицаУТ.ФамилияИнициалыФизЛица(ВыборкаПоСтрокам.Водитель);
		КонецЕсли;
		ОбластьСтроки.Параметры.Номер = к;
		ОбластьСтроки.Параметры.Заполнить(ВыборкаПоСтрокам);
		ОбластьСтроки.Параметры.Маршрут=СОКРЛП(ВыборкаПоСтрокам.МестоОтправления)+" - "+СОКРЛП(ВыборкаПоСтрокам.МестоНазначения)+?(ВыборкаПоСтрокам.Обратно," - "+СОКРЛП(ВыборкаПоСтрокам.МестоОтправления),"");
		
		ВремяВыезда = ВыборкаПоСтрокам.ВремяВыезда;
		ВремяВозвращения = ВыборкаПоСтрокам.ВремяВозвращения;
		Позиция=Найти(ВремяВыезда,":");
		
		ВремяВыездаЧас=Лев(ВремяВыезда,Позиция-1); 
		ВремяВыездаМинуты=Прав(ВремяВыезда,Позиция-1); 
		ВремяВозвратаЧас=Лев(ВремяВозвращения,Позиция-1); 
		ВремяВозвратаМинуты=Прав(ВремяВозвращения,Позиция-1);
		
		ОбластьСтроки.Параметры.ВремяВыездаЧасы = ВремяВыездаЧас; 
		ОбластьСтроки.Параметры.ВремяВыездаМинуты = ВремяВыездаМинуты; 
		ОбластьСтроки.Параметры.ВремяВозвратаЧасы = ВремяВозвратаЧас; 
		ОбластьСтроки.Параметры.ВремяВозвратаМинуты = ВремяВозвратаМинуты;
		
		ТабДокумент.Вывести(ОбластьСтроки); 
	конеццикла;
	
	для н=к по 25 цикл
		ТабДокумент.Вывести(ОбластьСтрокиПустая);
	конеццикла;	
	ОбластьПодвала.Параметры.ИтогоКМ=ВыборкаПоИтогам.Пройдено; 
