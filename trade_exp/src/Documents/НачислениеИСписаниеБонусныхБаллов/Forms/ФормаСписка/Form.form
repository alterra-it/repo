    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ДокументНачислениеИСписаниеБонусныхБаллов.Ссылка КАК Ссылка,
	ДокументНачислениеИСписаниеБонусныхБаллов.ПометкаУдаления КАК ПометкаУдаления,
	//ДокументНачислениеИСписаниеБонусныхБаллов.Номер КАК Номер,
	ДокументНачислениеИСписаниеБонусныхБаллов.Дата КАК Дата,
	ДокументНачислениеИСписаниеБонусныхБаллов.Проведен КАК Проведен,
	ДокументНачислениеИСписаниеБонусныхБаллов.ПравилоНачисления КАК ПравилоНачисления,
	ДокументНачислениеИСписаниеБонусныхБаллов.ПериодДействия КАК ПериодДействия,
	ДокументНачислениеИСписаниеБонусныхБаллов.КоличествоПериодовОтсрочкиНачалаДействия КАК КоличествоПериодовОтсрочкиНачалаДействия,
	ДокументНачислениеИСписаниеБонусныхБаллов.Комментарий КАК Комментарий,
	ДокументНачислениеИСписаниеБонусныхБаллов.МаркетинговоеМероприятие КАК МаркетинговоеМероприятие,
	ДокументНачислениеИСписаниеБонусныхБаллов.ДатаОкончанияСрокаДействия КАК ДатаОкончанияСрокаДействия,
	ДокументНачислениеИСписаниеБонусныхБаллов.БонуснаяПрограммаЛояльности КАК БонуснаяПрограммаЛояльности,
	ДокументНачислениеИСписаниеБонусныхБаллов.КоличествоПериодовДействия КАК КоличествоПериодовДействия,
	ДокументНачислениеИСписаниеБонусныхБаллов.ПериодОтсрочкиНачалаДействия КАК ПериодОтсрочкиНачалаДействия,
	ДокументНачислениеИСписаниеБонусныхБаллов.ЗаСчет КАК ЗаСчет,
	ДокументНачислениеИСписаниеБонусныхБаллов.Причина КАК Причина,
	ДокументНачислениеИСписаниеБонусныхБаллов.Документ КАК Документ,
	ДокументНачислениеИСписаниеБонусныхБаллов.СуммаДокумента КАК СуммаДокумента,
	ДокументНачислениеИСписаниеБонусныхБаллов.Ответственный КАК Ответственный,
	ДокументНачислениеИСписаниеБонусныхБаллов.ВидПравила КАК ВидПравила,
	ДокументНачислениеИСписаниеБонусныхБаллов.КомментарийВКарточкиПартнеров КАК КомментарийВКарточкиПартнеров,
	ДокументНачислениеИСписаниеБонусныхБаллов.Статус КАК Статус,
	ДокументНачислениеИСписаниеБонусныхБаллов.Утверждающий1 КАК Утверждающий1,
	ДокументНачислениеИСписаниеБонусныхБаллов.Утверждающий2 КАК Утверждающий2,
	ВЫБОР
		КОГДА НЕ Альтерра_ИдентификаторыОбъектовБ24.Идентификатор ЕСТЬ NULL
				И Альтерра_ИдентификаторыОбъектовБ24.Идентификатор &lt;> &quot;&quot;
			ТОГДА Альтерра_ИдентификаторыОбъектовБ24.Идентификатор
		ИНАЧЕ ДокументНачислениеИСписаниеБонусныхБаллов.ИДЭлементаВБитриксе
	КОНЕЦ КАК ИДЭлементаВБитриксе,
	ДокументНачислениеИСписаниеБонусныхБаллов.Исполнитель КАК Исполнитель,
	ДокументНачислениеИСписаниеБонусныхБаллов.Списание.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		Партнер КАК Партнер,
		Баллы КАК Баллы
	) КАК Списание,
	ДокументНачислениеИСписаниеБонусныхБаллов.Начисление.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		Партнер КАК Партнер,
		Баллы КАК Баллы
	) КАК Начисление,
	ДокументНачислениеИСписаниеБонусныхБаллов.НачислитьЗаСчет.(
		Ссылка КАК Ссылка,
		НомерСтроки КАК НомерСтроки,
		Сотрудник КАК Сотрудник,
		Сумма КАК Сумма
	) КАК НачислитьЗаСчет,
	ДокументНачислениеИСписаниеБонусныхБаллов.МоментВремени КАК МоментВремени
ИЗ
	Документ.НачислениеИСписаниеБонусныхБаллов КАК ДокументНачислениеИСписаниеБонусныхБаллов
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Альтерра_ИдентификаторыОбъектовБ24 КАК Альтерра_ИдентификаторыОбъектовБ24
		ПО ДокументНачислениеИСписаниеБонусныхБаллов.Ссылка = Альтерра_ИдентификаторыОбъектовБ24.Объект</queryText>
      <mainTable>Document.НачислениеИСписаниеБонусныхБаллов</mainTable>
