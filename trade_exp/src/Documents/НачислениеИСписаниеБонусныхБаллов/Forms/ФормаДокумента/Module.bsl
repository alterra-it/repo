&НаСервере                  
Процедура Док__ДокументПриИзмененииПослеНаСервере()
	
	Если ЗначениеЗаполнено(Объект.Документ) И Объект.ссылка.Документ <> Объект.Документ Тогда 
		
			
		ОчиститьТаблицы();
		Объект.Комментарий = "";

		ОтделАналитики = ДопМодуль.РольДоступнаОтделАналитики(); 
		НастройкиВидимостиСОснованием(ОтделАналитики); 
		
		ДокОбъект = РеквизитФормыВЗначение("Объект"); 
		
		ТекстОшибки = ДокОбъект.ЗаполнитьДанныеПоОснованию(ДокОбъект.Документ); 
		Если НЕ ТекстОшибки = "" Тогда     
			ДокОбъект.Документ = Документы.ОбращениеКлиента.ПустаяСсылка();
			Сообщить(ТекстОшибки,СтатусСообщения.Важное);
		КонецЕсли;
		
		ЗначениеВРеквизитФормы(ДокОбъект, "Объект");	
		
		Элементы.ГруппаСписания.Видимость = Ложь;
		Элементы.ГруппаНачисления.Видимость = Истина; 
		Элементы.Начисления.Видимость = Истина;
		ВариантРучногоРасчета = 1;
		
	ИначеЕсли Не ЗначениеЗаполнено(Объект.Документ) Тогда 
		
		ОчиститьТаблицы();
		Объект.Комментарий = "";	
		
	КонецЕсли;   
	
КонецПроцедуры  

