#Область ОбработчикиСобытийФормы 

 &НаСервере
 Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	 
	ОтказПриЗаписи = Ложь;

	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ИспользоватьПериодДействия = 0;
		ИспользоватьОтсрочкуНачалаДействия = 1;
		Объект.КоличествоПериодовДействия = 0;
		Объект.КоличествоПериодовОтсрочкиНачалаДействия = 1;
		Объект.ПериодОтсрочкиНачалаДействия = Перечисления.Периодичность.День;
		
		ИзменитьДоступность(ЭтаФорма);
	КонецЕсли;
	
	ОтделАналитики = ДопМодуль.РольДоступнаОтделАналитики();   
	
	Элементы.ГруппаПравилоНачисления.ТолькоПросмотр  = Ложь;
	Элементы.МаркетинговоеМероприятие.ТолькоПросмотр = Ложь;
	Элементы._Причина.ТолькоПросмотр                 = Ложь; 
	
	Если  ЗначениеЗаполнено(Объект.Документ) Тогда  
		НастройкиВидимостиСОснованием(ОтделАналитики);
	КонецЕсли;
	
	Элементы._Причина.РедактированиеТекста = ОтделАналитики;
	
	Элементы._Причина.БыстрыйВыбор                 = Не ОтделАналитики;
	Элементы.Статус.ТолькоПросмотр                 = Не ОтделАналитики;
	Элементы.ГруппаСрокДействия.ТолькоПросмотр     = Не ОтделАналитики;
	Элементы.ГруппаОтсрочкаДействия.ТолькоПросмотр = Не ОтделАналитики;
	
	Если ЗначениеЗаполнено(Объект.ИДЭлементаВБитриксе) Тогда
		ИДЭлементаВБитриксеФ = Объект.ИДЭлементаВБитриксе;
	ИначеЕсли ЗначениеЗаполнено(ПолучитьИДЭлементаВБитриксе()) Тогда
		ИДЭлементаВБитриксеФ = ПолучитьИДЭлементаВБитриксе();
	Иначе
		ИДЭлементаВБитриксеФ = "";
	КонецЕсли;
	
	Элементы.Утверждающий1.ТолькоПросмотр = ЗначениеЗаполнено(ИДЭлементаВБитриксеФ);
	
	ИзменениеДоступностиФормыДляРедакрирования(); 
	Элементы.Утверждающий2.Подсказка = "Сотрудник, имеющий полномочия на согласование суммы от " + ДопМодуль.ПолучитьКонстанту_ДопустимаяСуммаУтвержденияББ() + " рублей"; 
	
	Элементы.НадписьНельзяРедактировать.Видимость = НЕ ЗначениеЗаполнено(ИДЭлементаВБитриксеФ);
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПриОткрытииПеред(Отказ)
	
	Если Объект.ЗаСчет = Истина Тогда
	    Элементы.НачислитьЗаСчет.Видимость = Истина
	Иначе
		Элементы.НачислитьЗаСчет.Видимость = Ложь
	КонецЕсли; 	
		
	ДокументНовый = Не ЗначениеЗаполнено(Объект.Ссылка);
КонецПроцедуры

&НаКлиенте
Процедура Док_ПередЗаписьюПосле(Отказ, ПараметрыЗаписи)
  Если Объект.НачислитьЗаСчет.Количество() = 0 Тогда
	  Объект.ЗаСчет = Ложь;
	  Элементы.НачислитьЗаСчет.Видимость = Ложь
  КонецЕсли;  
	ДопЗаполнение(); 
	
КонецПроцедуры  


&НаСервере
Процедура Док_ПриЗаписиНаСервереПеред(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	СообщениеОбОшибке = ДопМодуль.СуммаПревышаетДопустимую(Объект);	
	Если СообщениеОбОшибке <> "" Тогда
		Отказ = Истина; 
		ОтказПриЗаписи = Истина;
		Сообщить(СообщениеОбОшибке);
	КонецЕсли;	    
	
КонецПроцедуры


&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	
	Если ЗначениеЗаполнено(СокрЛП(Объект.КомментарийВКарточкиПартнеров)) И ДокументНовый Тогда
		Комментарий = Строка(Объект.ВидПравила) + " " + Строка(Объект.Дата) + ": " + СокрЛП(Объект.КомментарийВКарточкиПартнеров);
		Если Объект.ВидПравила = ПредопределенноеЗначение("Перечисление.ВидыПравилНачисленияБонусныхБаллов.Начисление") Тогда
			Для Каждого стрНачисление Из Объект.Начисление Цикл
				Если ЗначениеЗаполнено(стрНачисление.Партнер) Тогда
					ЗаписатьКомментарийВПартнераНаСервере(Комментарий + " (" + Строка(стрНачисление.Баллы) + " бб)", стрНачисление.Партнер);
				КонецЕсли;
			КонецЦикла;
		ИначеЕсли Объект.ВидПравила = ПредопределенноеЗначение("Перечисление.ВидыПравилНачисленияБонусныхБаллов.Списание") Тогда
			Для Каждого стрСписание Из Объект.Списание Цикл
				Если ЗначениеЗаполнено(стрСписание.Партнер) Тогда
					ЗаписатьКомментарийВПартнераНаСервере(Комментарий + " (" + Строка(стрСписание.Баллы) + " бб)", стрСписание.Партнер);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		ДокументНовый = Ложь;
	КонецЕсли;
		
	//Если НЕ Объект.ИДЭлементаВБитриксе = "" Тогда
	//	ОбновитьБП_Бонусы(); 
	//КонецЕсли;  
	
КонецПроцедуры

#КонецОбласти  


