&НаКлиенте
Процедура Док_БонусныеБаллыПартнерПриИзмененииПеред(Элемент) 
	ПроверитьПартнера("Начисление");	
КонецПроцедуры 

&НаСервере
Процедура ПроверитьПартнера(ИмяТабЧасти)  
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");     
	
	Если Не ДокументОбъект.КлиентуМожноНачислятьББ(Объект[ИмяТабЧасти][0].Партнер) Тогда   
		Объект[ИмяТабЧасти][0].Партнер = Справочники.Партнеры.ПустаяСсылка();
		ВызватьИсключение "Выбранный клиент не является ни Частным лицом,ни Бригадиром! Для таких клиентов не предусмотрено участие в Бонусной программе.";
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Функция  КомментарийОбязателенДляЗаполнения() 
	
	Если Объект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("За отзыв (по бп)") 
		Или Объект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Прочее (по бп)") 	
		Или Объект.Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Списание бонусов (по бп)") Тогда
		
		Возврат Истина;
		
	КонецЕсли;
	
	 Возврат Ложь;     
	 
КонецФункции

&НаСервере
Процедура НастройкиВидимостиСОснованием(ОтделАналитики) 
		
		Элементы.ГруппаПравилоНачисления.ТолькоПросмотр  = Не ОтделАналитики;
		Элементы.МаркетинговоеМероприятие.ТолькоПросмотр = Не ОтделАналитики; 
		
		Если Объект.Документ = Тип("ДокументСсылка.ОбращениеКлиента") 
			Или Объект.Документ = Тип("ДокументСсылка.ПересчетТоваров") Тогда  
			Элементы._Причина.ТолькоПросмотр = Не ОтделАналитики;
		КонецЕсли;
				
	КонецПроцедуры

	
&НаСервере
Функция ПолучитьИДЭлементаВБитриксе()
	НаборЗаписей = РегистрыСведений.Альтерра_ИдентификаторыОбъектовБ24.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Установить(Объект.Ссылка);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество() <> 0  Тогда
		Запись = НаборЗаписей.Получить(0);
	Иначе
		возврат Неопределено;
	КонецЕсли;
	Если Запись <> Неопределено Тогда
		возврат Запись.Идентификатор;
	Иначе
		возврат Неопределено;
	КонецЕсли
КонецФункции



