КонецФункции

&НаСервере
Функция ОпределитьИДСтатуса() 
	
	Статус = Объект.Статус;
	
	Если Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.НаСогласовании Тогда	
		ИДСтатуса = "5419" ;
	ИначеЕсли  Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Согласован Тогда 
		ИДСтатуса = "5420" ;   
	ИначеЕсли  Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Исполнен Тогда
		ИДСтатуса = "5421" ;   
	ИначеЕсли  Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Отклонен Тогда
		ИДСтатуса = "5422" ; 
	ИначеЕсли  Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Доработка Тогда
		ИДСтатуса = "5423" ;  
	Иначе
		ИДСтатуса = "";
	КонецЕсли;  
	
	Возврат ИДСтатуса;
	
КонецФункции

