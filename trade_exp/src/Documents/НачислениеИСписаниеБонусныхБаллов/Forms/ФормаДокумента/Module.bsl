КонецПроцедуры 

функция ПолучитьБизнесПроцессыЭлементаИнфоблока(ИДЭлементаВБитриксе, СтруктураОтбора = Неопределено, СтруктураСортировки = Неопределено, ВернутьСтрокойJSON = Ложь) Экспорт
	
	МассивПолей = Новый Массив;
	МассивПолей.Добавить("ID"); 
	МассивПолей.Добавить("MODULE_ID");
	МассивПолей.Добавить("ENTITY");
	МассивПолей.Добавить("DOCUMENT_ID");
	МассивПолей.Добавить("STARTED");
	МассивПолей.Добавить("STARTED_BY");
	МассивПолей.Добавить("TEMPLATE_ID");
	
	ПараметрыЗапроса = Новый Структура;
	
	ПараметрыЗапроса.Вставить("SELECT", МассивПолей);
	Если СтруктураОтбора  <> Неопределено Тогда
		ПараметрыЗапроса.Вставить("FILTER", структураОтбора);  
	КонецЕсли;  
	Если СтруктураСортировки  <> Неопределено Тогда	
		ПараметрыЗапроса.Вставить("ORDER", СтруктураСортировки); 
	КонецЕсли;
	
	Возврат АльтерраВзаимодействиеСБитрикс24.ВыполнитьПроизвольныйЗапрос("bizproc.workflow.instances", ПараметрыЗапроса, ВернутьСтрокойJSON)["result"];
	
КонецФункции 

&НаСервере
Функция ПолучитьСтруктуруБП()    
	
	Если Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание  Тогда
		СтрокаТЧ = Объект.Списание[0];
		ВидПравилаДляБП = "списа";
		СписатьИлиНачислить ="списа";
	ИначеЕсли Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление Тогда 
		СтрокаТЧ = Объект.Начисление[0]; 
		ВидПравилаДляБП = "начисле"; 
		СписатьИлиНачислить ="начисли";
	Иначе   
		Сообщить("Для документов без вида списания не предусмотрено создание БП");
		Возврат "";
	КонецЕсли;	
	
	Клиент = СтрокаТЧ.Партнер;
	
	ИДВидНачисления = ОпределитьИДВидаНачисления();  
	
	Если Объект.Комментарий = "" Тогда
		ПричинаНачисления = "Причина не указана";
	Иначе  
		ПричинаНачисления = Объект.Комментарий;
	КонецЕсли;
	
	СтруктураБП  = Новый Структура(); 

	СтруктураБП.Вставить("NAME", "Заявка на согласование " + ВидПравилаДляБП + "ния бонусов № " + ИДЭлементаВБитриксеФ);
	СтруктураБП.Вставить("CREATED_BY", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Ответственный));
	СтруктураБП.Вставить("PROPERTY_1341", Клиент.Код );
	СтруктураБП.Вставить("PROPERTY_1342", Клиент.Наименование);
	СтруктураБП.Вставить("PROPERTY_1359", Строка(Объект.СуммаДокумента));
	СтруктураБП.Вставить("PROPERTY_1360", ПричинаНачисления);   // причина начисления
	СтруктураБП.Вставить("PROPERTY_1361", ИДВидНачисления); //вид начисления
	СтруктураБП.Вставить("PROPERTY_3274", ВидПравилаДляБП); //Списание или начисление 
	СтруктураБП.Вставить("PROPERTY_3275", СписатьИлиНачислить); //Списать или начислить
	СтруктураБП.Вставить("PROPERTY_1350", ОпределитьИДСтатуса()); //Статус  
	СтруктураБП.Вставить("PROPERTY_3785","Да");
	
	Если ЗначениеЗаполнено(Объект.Утверждающий1) Тогда
		СтруктураБП.Вставить("PROPERTY_1343", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Утверждающий1.Пользователь));
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Утверждающий2) Тогда
		СтруктураБП.Вставить("PROPERTY_1344", АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Утверждающий2.Пользователь));
	КонецЕсли;
	
	Если Не ДопМодуль.НужноСогласованиеАналитиков(Объект.Причина) Тогда
		СтруктураБП.Вставить("PROPERTY_3784","Нет" );      
	КонецЕсли;
	Если  ЗначениеЗаполнено(Объект.Документ) Тогда   
		ДокументОснование = Объект.Документ;    
		Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда   
			 ИДОбращения = ИДОбращениявБитрикс(ДокументОснование);
			 СтруктураБП.Вставить("PROPERTY_3790", ИДОбращения); 
		КонецЕсли;
	КонецЕсли;	 
	Возврат СтруктураБП;
	
КонецФункции

&НаСервере
Функция ИДОбращениявБитрикс(ДокументОснование)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Альтерра_ИдентификаторыОбъектовБ24.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.Альтерра_ИдентификаторыОбъектовБ24 КАК Альтерра_ИдентификаторыОбъектовБ24
		|ГДЕ
		|	Альтерра_ИдентификаторыОбъектовБ24.Объект = &Объект";
	Запрос.УстановитьПараметр("Объект", ДокументОснование);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Идентификатор;
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции


