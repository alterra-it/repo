#Область ЗагрузкаИзФайла

&НаКлиенте
Процедура ЗагрузитьИзФайла_Альтерра(Команда)
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗагрузкиИзФайла", ЭтотОбъект);
	ПараметрыФормы= Новый Структура();
	ПараметрыФормы.Вставить("НастройкиТаблицы",СтруктураТаблицы());
	ОткрытьФорму("Обработка.ЗагрузкаИзВнешнегоФайла_Альтерра.Форма.ФормаПроизвольная", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Функция СтруктураТаблицы()
	
	СтруктураТаблицы=Новый Структура();
	
	СтруктураТаблицы.Вставить("Код","СправочникСсылка.Партнеры#Код#15#1#Справочники.Партнеры.НайтиПоКоду(""&Ячейка&"")#Код");
	СтруктураТаблицы.Вставить("Партнер","СправочникСсылка.Партнеры#Партнер#30#1#Справочники.Партнеры.НайтиПоНаименованию(""&Ячейка&"", Истина)#Партнер");
	СтруктураТаблицы.Вставить("Баллы","Число#Баллы#8#1#?(ЗначениеЗаполнено(""&Ячейка&""), ""&Ячейка&"", Неопределено)#Баллы");

	Возврат  СтруктураТаблицы;
	
КонецФункции 

&НаКлиенте
Процедура ПослеЗагрузкиИзФайла(Результат, ДополнительныеПараметры) Экспорт
	
    ПослеЗагрузкиИзФайлаСервер(Результат, ДополнительныеПараметры);

КонецПроцедуры

&НаСервере
Процедура ПослеЗагрузкиИзФайлаСервер(Результат, ДополнительныеПараметры)
	
	Если Не Результат = Неопределено Тогда
		ТаблицаДанных = ПолучитьИзВременногоХранилища(Результат);
				
		Если ТаблицаДанных<>Неопределено Тогда
			ОчищеннаяТД = ТаблицаДанных.СкопироватьКолонки();
			ОчищеннаяТД.Колонки.Добавить("ДоступныеБаллы");
			ОчищеннаяТД.Колонки.Добавить("ДоступныеБаллыБудут");
			Для Каждого СтрТД Из ТаблицаДанных Цикл
				Партнер_ = Неопределено;
				Если ЗначениеЗаполнено(СтрТД.Код) Тогда // если нашли по коду, то этот результат в приоритете
					Партнер_ = СтрТД.Код;
				ИначеЕсли ЗначениеЗаполнено(СтрТД.Партнер) Тогда
					Партнер_ = СтрТД.Партнер;
				КонецЕсли;
				Если ЗначениеЗаполнено(Партнер_) И ЗначениеЗаполнено(СтрТД.Баллы) Тогда
					НоваяСтрока = ОчищеннаяТД.Добавить();
					НоваяСтрока.Партнер = Партнер_;
					НоваяСтрока.Баллы = СтрТД.Баллы;
					СтруктураИнформацииПоБаллам = БонусыАльтерраРезерв.ПолучитьИнформациюПоБаллам(ТекущаяДата(), Партнер_);
					НоваяСтрока.ДоступныеБаллы = СтруктураИнформацииПоБаллам.ДоступныеБаллы;
					НоваяСтрока.ДоступныеБаллыБудут = РассчитатьБаллыБудут(Партнер_, СтруктураИнформацииПоБаллам.ДоступныеБаллы, СтрТД.Баллы);
				КонецЕсли;
			КонецЦикла;
			
			Объект.Начисление.Загрузить(ОчищеннаяТД);
			Объект.Списание.Загрузить(ОчищеннаяТД);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область Взаимодействие_С_Битриксом  

&НаКлиенте
Процедура Док_ОтправитьНаУтверждение(Команда)
	Если ИДЭлементаВБитриксеФ = "" Тогда
		Если ЭтаФорма.Модифицированность Тогда
			Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение));    
			
			Если ОтказПриЗаписи Тогда  
				ОтказПриЗаписи = Ложь;
				Возврат;
			КонецЕсли; 
			
		КонецЕсли; 
		
		Если Объект.Комментарий = "" Тогда 
			Если КомментарийОбязателенДляЗаполнения()  Тогда 
				Сообщить("Перед отправкой на утверждение необходимо заполнить комментарий");
				Возврат;
			КонецЕсли;
		КонецЕсли;    
		
		Если Объект.СуммаДокумента = 0 Тогда
			Возврат;
		КонецЕсли;
		
		СоздатьБП_Бонусы(); 		 
	Иначе
		Сообщить("По данному документу уже создан БП " + ИДЭлементаВБитриксеФ);
	КонецЕсли; 
	
КонецПроцедуры 

&НаСервере	
Процедура СоздатьБП_Бонусы()
	
	СтруктураБП = ПолучитьСтруктуруБП();
	
	КодЭлементаПроцесса = Строка(Объект.Ссылка.УникальныйИдентификатор());
	
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовыйЭлементСписка("lists_socnet", "101", КодЭлементаПроцесса,СтруктураБП);
	
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
		ЗаписьЖурналаРегистрации("Бизнес-Процесс Начисление ББ не создан",
		УровеньЖурналаРегистрации.Ошибка, , ,
		"Ошибка при создании БП в Битрикс по документу № " + Объект.Номер + " от " + Объект.Дата +": " + СтруктураОтвета.ОписаниеОшибки 
		+ " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
	КонецЕсли;   	
	
	Если СтруктураОтвета.Свойство("Результат") Или СтруктураОтвета.Свойство("result") Тогда   	
		ИДЭлементаВБитриксе = СтруктураОтвета.result;
		ИДЭлементаВБитриксе = СтрЗаменить(ИДЭлементаВБитриксе," ","");
		НаборЗаписейИДБП = РегистрыСведений.Альтерра_ИдентификаторыОбъектовБ24.СоздатьНаборЗаписей();
        НаборЗаписейИДБП.Отбор.Объект.Установить(Объект.Ссылка);
		НаборЗаписейИДБП.Записывать = Истина;
		НоваяЗапись = НаборЗаписейИДБП.Добавить();
		НоваяЗапись.Идентификатор = ИДЭлементаВБитриксе;
		НоваяЗапись.Объект = Объект.Ссылка;
		НаборЗаписейИДБП.Записать();
		
		ИДЭлементаВБитриксеФ = ИДЭлементаВБитриксе;
		
		Сообщить("В Битриксе успешно запущен БП " + ИДЭлементаВБитриксе);
		Элементы.Утверждающий1.ТолькоПросмотр = Истина;
		Попытка 
			Записать();
		Исключение
			ЗаписьЖурналаРегистрации("Элемент Начисление ББ не записан",
			УровеньЖурналаРегистрации.Ошибка, , ,
			"Ошибка при записи документа №" + Объект.Номер + " от " + Объект.Дата +": "+ ИДЭлементаВБитриксе 
			+" " + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		КонецПопытки;	 
		ИзменениеДоступностиФормыДляРедакрирования();
	Иначе
		ЗаписьЖурналаРегистрации("Бизнес-Процесс Начисление ББ", УровеньЖурналаРегистрации.Ошибка, , ,"Ошибка при записи документа №" + Объект.Номер + " от " + Объект.Дата +": "+ "Нет ответа от Битрикс"); 	
	КонецЕсли;
	Элементы.НадписьНельзяРедактировать.Видимость = Не ЗначениеЗаполнено(ИДЭлементаВБитриксеФ);	
	
КонецПроцедуры 

&НаСервере
Процедура ОбновитьБП_Бонусы()
	
	//Изменить Эл списка
	СтруктураБП = ПолучитьСтруктуруБП();
	КодЭлементаПроцесса = Строка(Объект.Ссылка.УникальныйИдентификатор());
	
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ИзменитьЭлементСписка("lists_socnet", "101", КодЭлементаПроцесса,СтруктураБП); 
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
