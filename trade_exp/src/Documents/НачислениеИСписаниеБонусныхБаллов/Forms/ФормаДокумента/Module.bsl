&НаСервере
Функция РассчитатьБаллыБудут(Партнер, ДоступныеБаллы, Баллы)
	
	Будут = Неопределено;
	Если Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление Тогда
		Будут = ДоступныеБаллы + Баллы;
	ИначеЕсли Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание Тогда
		Будут = ДоступныеБаллы - Баллы;
	Иначе
		Сообщить("Вариант расчета бонусных баллов документа не подходит для ручной корректировки данных");
		Возврат Неопределено;
	КонецЕсли;
	Если Будут < 0 Тогда Сообщить("Баланс Партнера " + Партнер + " станет отрицательным"); КонецЕсли;
	Возврат Будут;
	
КонецФункции

&НаКлиенте
Процедура ПересчитатьБаллыПоТекущейСтрокеСписания()
	
	Партнер = Элементы.Списания.ТекущиеДанные.Партнер;
	Если ЗначениеЗаполнено(Партнер) Тогда
		СтруктураИнформацииПоБаллам = БонусыАльтерраРезерв.ПолучитьИнформациюПоБаллам(ТекущаяДата(), Партнер);
		Элементы.Списания.ТекущиеДанные.ДоступныеБаллы = СтруктураИнформацииПоБаллам.ДоступныеБаллы;
		Элементы.Списания.ТекущиеДанные.ДоступныеБаллыБудут = РассчитатьБаллыБудут(Партнер, СтруктураИнформацииПоБаллам.ДоступныеБаллы, Элементы.Списания.ТекущиеДанные.Баллы);
	КонецЕсли;
	
КонецПроцедуры

