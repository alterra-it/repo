&НаСервере
Функция ПолучитьМассивПричинНачисления() 
	
	МассивЗначений = Новый Массив;
	ТипДокумента = ТипЗнч(Объект.Документ);  
	
	Если Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление Тогда
		Если ТипДокумента = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
			
			МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("По жалобе (по БП)")); 
			
		ИначеЕсли ТипДокумента = Тип("ДокументСсылка.РеализацияТоваровУслуг") Или  ТипДокумента = Тип("ДокументСсылка.ЧекККМ") Тогда   
			
			МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Доначисление (по бп)")); 
			МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Неверный ценник (по бп)"));  
			
		ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ПересчетТоваров") Тогда 
			
			МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Обмен в ТЗ (по БП)")); 
			
		Иначе
			Если РольДоступна("ОтделРекламы") Или РольДоступна("ОтделАналитики") Или РольДоступна("ПолныеПрава")  Тогда
				МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("За отзыв (по бп)"));
			КонецЕсли;
			МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Прочее (по бп)")); 
		КонецЕсли;
		
	ИначеЕсли  Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание Тогда
		МассивЗначений.Добавить(Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Списание бонусов (по бп)")); 
	КонецЕсли;	
	
	Возврат МассивЗначений;  
	
КонецФункции

