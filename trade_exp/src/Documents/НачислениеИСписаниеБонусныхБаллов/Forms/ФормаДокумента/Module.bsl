	Док_СуммаДокументаПриИзмененииПослеНаСервере();	
КонецПроцедуры   

&НаСервере
Процедура Док_СуммаДокументаПриИзмененииПослеНаСервере() 
	
	СтрокаТаблицы = Неопределено;
	
	Если Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление  Тогда
		Если Объект.Начисление.Количество() > 0 Тогда
			СтрокаТаблицы = Объект.Начисление[0]; 
		КонецЕсли;
	ИначеЕсли Объект.ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание Тогда
		Если Объект.Списание.Количество() > 0 Тогда
			СтрокаТаблицы = Объект.Списание[0]; 
		КонецЕсли;
	КонецЕсли;  
	
	Если СтрокаТаблицы = Неопределено Тогда
		Сообщить("Табличная часть не заполнена!");
		Объект.СуммаДокумента = 0;
	Иначе 
		СтрокаТаблицы.Баллы = Объект.СуммаДокумента;
	КонецЕсли;
	
	
КонецПроцедуры

