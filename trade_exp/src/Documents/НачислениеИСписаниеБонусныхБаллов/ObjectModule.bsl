&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка) Экспорт  
	
	Если Не ЗначениеЗаполнено(БонуснаяПрограммаЛояльности.Ссылка) Тогда
		ЗначениеПоУмолчанию = Справочники.БонусныеПрограммыЛояльности.НайтиПоНаименованию("Бонус от ALTERRA");
		БонуснаяПрограммаЛояльности = ЗначениеПоУмолчанию;	
	КонецЕсли;  
	
	Ответственный = Пользователи.ТекущийПользователь();  
	Утверждающий1 = ДопМодуль.ПолучитьРуководителяОтдела(Ответственный);

	ТекстОшибки = ЗаполнитьДанныеПоОснованию(ДанныеЗаполнения); 
	Если ТекстОшибки <> "" Тогда
		ВызватьИсключение ТекстОшибки;
	КонецЕсли;
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения) 	
	ЗаполнитьОтвественного();
	ЗаполнитьСуммуДокумента(); 
КонецПроцедуры

Процедура ЗаполнитьОтвественного()
	Если ЭтотОбъект.Ответственный = Справочники.Пользователи.ПустаяСсылка() ТОгда 
		ЭтотОбъект.Ответственный = Справочники.Пользователи.НайтиПоНаименованию("Администратор");   
	КонецЕсли;
КонецПроцедуры 

Процедура ЗаполнитьСуммуДокумента()
	СуммаДокумента = 0;  
	ВидПравила = ЭтотОбъект.ВидПравила; 
	Если ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Списание Тогда 
		Для каждого строка из ЭтотОбъект.Списание Цикл
			СуммаДокумента = СуммаДокумента + Строка.Баллы; 
		КонецЦикла;   
		СуммаДОкумента = СуммаДокумента * (-1); 
	ИНачеЕсли ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление Тогда 
		Для каждого строка из ЭтотОбъект.Начисление Цикл
			СуммаДокумента = СуммаДокумента + Строка.Баллы; 
		КонецЦикла;  
	КонецЕсли; 
	ЭтотОбъект.СуммаДокумента = СуммаДокумента; 		
КонецПроцедуры

&ИзменениеИКонтроль("ОбработкаПроведения")   
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения) 
	
	#Вставка	
	Если Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.Исполнен Тогда
		#КонецВставки 	
		
		ПроведениеДокументов.ОбработкаПроведенияДокумента(ЭтотОбъект, Отказ);
		
		#Вставка 
	ИначеЕсли Проведен Тогда
		УдалитьДвиженияББ();
		//ПроведениеДокументов.ОбработкаУдаленияПроведенияДокумента(ЭтотОбъект, Отказ);	
	КонецЕсли;
	#КонецВставки  
	
КонецПроцедуры

Процедура ЗаполнитьПоОбращениюКлиента(ДанныеЗаполнения) 
	
	Документ = ДанныеЗаполнения;                    		
	Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("По жалобе (по бп)"); 
	КлиентИзОснования = ДанныеЗаполнения.Клиент;  	
	Комментарий = ДанныеЗаполнения.Содержание;
	НС = Начисление.Добавить();  
	НС.Партнер = КлиентИзОснования;  
	
КонецПроцедуры 

Процедура ЗаполнитьПоДокументуПродажи(ДанныеЗаполнения)
	
	Документ = ДанныеЗаполнения;  
	КлиентИзОснования = ДанныеЗаполнения.Партнер; 
	НС = Начисление.Добавить();  
	НС.Партнер = КлиентИзОснования;  	
	
КонецПроцедуры

Процедура ЗаполнитьПоПересчетуТоваров(ДанныеЗаполнения)
	
	Причина = Справочники.ПричиныНачисленияБонусныхБаллов.НайтиПоНаименованию("Обмен в ТЗ (по БП)"); 
	Документ = ДанныеЗаполнения; 
	
	ТоварCписываемый = "";
	ТоварПриходуемый = "";
	
	Для Каждого Строка Из Документ.Товары Цикл 
		
		Факт = Строка.КоличествоУпаковокФакт;
		Учет = Строка.КоличествоУпаковок; 
		
		Если Факт < Учет  Тогда   
			
			ТоварCписываемый = ТоварCписываемый + "
			|" + Строка.Номенклатура + " ("+(Факт-Учет)+")";
			
		ИначеЕсли  Факт > Учет Тогда 
			
			ТоварПриходуемый = ТоварПриходуемый + "
			|" + Строка.Номенклатура + " ("+(Факт-Учет)+")";
			
		КонецЕсли;
		
	КонецЦикла;
	
	Комментарий = "Товар списываемый:" + ТоварCписываемый + " 
	|
	|Товар приходуемый:" +  ТоварПриходуемый;
	
КонецПроцедуры

Функция УжеЕстьДокументНачисленияББ(ДокОснование,ТипДокумента)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НачислениеИСписаниеБонусныхБаллов.Ссылка КАК Ссылка
	|ИЗ
	|	&ДокументОснование КАК ДокументОснование
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеИСписаниеБонусныхБаллов КАК НачислениеИСписаниеБонусныхБаллов
	|		ПО ДокументОснование.Ссылка = НачислениеИСписаниеБонусныхБаллов.Документ
	|ГДЕ
	|	ДокументОснование.Ссылка = &Ссылка
	|	И НачислениеИСписаниеБонусныхБаллов.ПометкаУдаления = ЛОЖЬ";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст,"&ДокументОснование",ТипДокумента);	
	
	Запрос.УстановитьПараметр("Ссылка", ДокОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
	
	
КонецФункции


Процедура УдалитьДвиженияББ()
	
	Набор = РегистрыНакопления.БонусныеБаллы.СоздатьНаборЗаписей();
	Набор.Отбор.Регистратор.Установить(Ссылка);
	Набор.Записать();
	
КонецПроцедуры

Функция КлиентуМожноНачислятьББ(Партнер)  Экспорт 
	
	
	Если НЕ (АльтерраОбщегоНазначения.ЭтоБригадир(Партнер) Или АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Партнер)) Тогда 
		
		Если Не ДопМодуль.РольДоступнаОтделАналитики() Тогда 
			Возврат Ложь;
		КонецЕсли;
		
	КонецЕсли;
	Возврат Истина;	
Конецфункции

Функция ЗаполнитьДанныеПоОснованию(ДанныеЗаполнения)Экспорт  
	

	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения); 
	ТекстИсключенияПоКлиенту = "Клиент не является ни Частным лицом,ни Бригадиром! Для таких клиентов не предусмотрено участие в Бонусной программе.";  
	ВидПравила = Перечисления.ВидыПравилНачисленияБонусныхБаллов.Начисление;
	
	Если ТипДанныхЗаполнения = Тип("ДокументСсылка.ОбращениеКлиента") Тогда 
		
		Если НЕ ДанныеЗаполнения.ВидОбращения = Перечисления.ВидыОбращений.Жалоба Тогда
			Возврат "Создание документа ""Начисление и списание бонусных баллов"" возможен на основании Обращения только по жалобе"; 
		ИначеЕсли УжеЕстьДокументНачисленияББ(ДанныеЗаполнения,"Документ.ОбращениеКлиента") Тогда
			Возврат "На основании данного Обращения уже создан документ ""Начисление и списание бонусных баллов"" "; 
		КонецЕсли;
		
		Если Не КлиентуМожноНачислятьББ(ДанныеЗаполнения.Клиент) Тогда 
			Возврат ТекстИсключенияПоКлиенту;
		КонецЕсли;
		
		ЗаполнитьПоОбращениюКлиента(ДанныеЗаполнения);  
		
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.РеализацияТоваровУслуг") Или  ТипДанныхЗаполнения = Тип("ДокументСсылка.ЧекККМ") Тогда 
		
		Если Не КлиентуМожноНачислятьББ(ДанныеЗаполнения.Партнер) Тогда
			Возврат ТекстИсключенияПоКлиенту;
		КонецЕсли;
		
		ЗаполнитьПоДокументуПродажи(ДанныеЗаполнения);   
		
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.ПересчетТоваров") Тогда
		
		Если ДанныеЗаполнения.ТипПересчета = Справочники.ТипыПересчетов.НайтиПоНаименованию("Обмен") Тогда
			
			Если УжеЕстьДокументНачисленияББ(ДанныеЗаполнения, "Документ.ПересчетТоваров") Тогда
				Возврат "На основании данного Пересчета уже создан документ ""Начисление и списание бонусных баллов"" "; 
			КонецЕсли; 
			ЗаполнитьПоПересчетуТоваров(ДанныеЗаполнения); 
		Иначе
			Возврат "Создание документа ""Начисление и списание бонусных баллов"" возможен на основании Пересчета только с типом ""Обмен"""; 
		КонецЕсли;
		
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(Документ) Тогда
		Комментарий = "Начисление создано на основании документа """ + Документ + """" +"
		|" +"
		|"+ Комментарий;
	КонецЕсли; 
		
	Статус = Перечисления.СтатусыНачислениеИСписаниеБонусныхБаллов.НаСогласовании;
	
	Возврат "";
	
КонецФункции

