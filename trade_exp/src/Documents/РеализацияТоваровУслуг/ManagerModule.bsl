#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
#Область КонтрольИзмененийТЧПриНаличииРасходногоОрдера

Функция ПоРеализацииЕстьРасходныйОрдер(Ссылка)
	
	Запрос = Новый Запрос( 
		"ВЫБРАТЬ
		|	ИСТИНА КАК Результат
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары КАК Ордер
		|ГДЕ             
		|	НЕ Ордер.ПометкаУдаления 
		|	И Ордер.Накладная = &Накладная");
	
	Запрос.УстановитьПараметр("Накладная", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	
	Возврат РезультатЗапроса.Следующий();

КонецФункции

Процедура КонтрольИзмененийТЧПриНаличииРасходногоОрдера(Отказ, Объект, ПередЗаписью_ПриЗаписи) Экспорт
	
	Если НЕ Отказ Тогда
		Если ПередЗаписью_ПриЗаписи И // ПередЗаписью 
			ЗначениеЗаполнено(Объект.Ссылка) И
			НЕ Объект.ПометкаУдаления И
			ПоРеализацииЕстьРасходныйОрдер(Объект.Ссылка) Тогда  
			
			Объект.ДополнительныеСвойства.Вставить("КонтрольнаяСуммаТЧбезУслуг", КонтрольнаяСуммаТЧбезУслуг_Запрос(Объект.Ссылка));
			
		ИначеЕсли НЕ ПередЗаписью_ПриЗаписи И // ПриЗаписи 
			Объект.ДополнительныеСвойства.Свойство("КонтрольнаяСуммаТЧбезУслуг") И
			Объект.ДополнительныеСвойства.КонтрольнаяСуммаТЧбезУслуг <> КонтрольнаяСуммаТЧбезУслуг_Запрос(Объект.Ссылка) Тогда
			
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По реализации есть расходный ордер. Список товаров был изменен. Обратитесь к складу!",,,,Отказ);
	    КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Функция КонтрольнаяСуммаТЧбезУслуг_Запрос(Ссылка)
	Запрос = Новый Запрос( 
		"ВЫБРАТЬ
		|	Товары.НомерСтроки КАК НомерСтроки,
		|	Товары.КодСтроки КАК КодСтроки,
		|	Товары.Номенклатура КАК Номенклатура,
		|	Товары.Характеристика КАК Характеристика,
		|	Товары.Назначение КАК Назначение,
		|	Товары.Упаковка КАК Упаковка,
		|	Товары.Подразделение КАК Подразделение,
		|	Товары.Склад КАК Склад,
		|	Товары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Товары.Количество КАК Количество
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК Товары
		|ГДЕ
		|	Товары.Номенклатура.ТипНоменклатуры <> ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
		|	И Товары.Ссылка = &Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	Товары.НомерСтроки");

	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Возврат ОбщегоНазначения.КонтрольнаяСуммаСтрокой(Запрос.Выполнить().Выгрузить());
КонецФункции  

#КонецОбласти

#Область СоздатьРеализациюПоРейсу
 
Функция СоздатьРеализациюПоРейсу(ЗаказНаДоставку, ЗаказКлиента, Рейс) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);

	Если ТипЗнч(ЗаказКлиента) <> Тип("ДокументСсылка.ЗаказКлиента") ИЛИ ЕстьРеализацияПоЗаказу(ЗаказКлиента) Тогда
		Возврат Ложь; // наличие ошибки
	Иначе
		ЗаказОбъект = ЗаказКлиента.ПолучитьОбъект();
		ТекДата = ТекущаяДата();
		ИзмененияВЗаказе = Ложь;
		Отказ = Ложь;
		
		Для Каждого стрТовар Из ЗаказОбъект.Товары Цикл
			Если стрТовар.ВариантОбеспечения <> Перечисления.ВариантыОбеспечения.Отгрузить И НЕ стрТовар.Отменено Тогда
				стрТовар.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить;
				стрТовар.ДатаОтгрузки = ТекДата;
				ИзмененияВЗаказе = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если ИзмененияВЗаказе Тогда
			Попытка            
				ЗаказОбъект.ДополнительныеСвойства.Вставить("Регламент", Истина);
				ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отгружен: " + ЗаказОбъект.Ссылка, ЗаказОбъект.Ссылка);
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать документ 'Заказ клиента'",,,,Отказ);
			КонецПопытки;
		КонецЕсли;
		
		Если Не Отказ Тогда
			
			РеализацияОбъект = Документы.РеализацияТоваровУслуг.СоздатьДокумент();
			Комментарий = "Создан автоматически из: " + Рейс;
			
			ДанныеЗаполнения = Новый Структура;
			ДанныеЗаполнения.Вставить("ВариантОформленияПродажи", Перечисления.ВариантыОформленияПродажи);
			ДанныеЗаполнения.Вставить("ДокументОснование", ЗаказКлиента);
			ДанныеЗаполнения.Вставить("СкладОтгрузки", Неопределено);
			РеализацияОбъект.Заполнить(ДанныеЗаполнения);
			
			РеализацияОбъект.Склад = ЗаказКлиента.Склад;
			РеализацияОбъект.Комментарий = Комментарий;
			РеализацияОбъект.Дата = ТекДата;
			РеализацияОбъект.Менеджер = ЗаказКлиента.Менеджер;
			РеализацияОбъект.Магазин = ЗаказКлиента.Магазин;
			РеализацияОбъект.Кассир = Справочники.Пользователи.ПустаяСсылка();
			РеализацияОбъект.ДатаОтметкиКасса = Дата('00010101');
			
			Если РеализацияОбъект.Товары.Количество() > 0 Тогда 
				Попытка
					РеализацияОбъект.СкидкиРассчитаны = Истина;
					РеализацияОбъект.Записать(РежимЗаписиДокумента.Проведение);
					
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создан документ: " + РеализацияОбъект.Ссылка, РеализацияОбъект.Ссылка);
				Исключение                          
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать документ 'Реализация товаров и услуг'",,,,Отказ);
				КонецПопытки;
				
				Если Не Отказ Тогда
					// Создаем 'Счет-фактура выданный'
				Если НЕ ЗаказКлиента.Контрагент.ЮрФизЛицо = ПредопределенноеЗначение("Перечисление.ЮрФизЛицо.физЛицо") Тогда
					ДанныеСчетаФактуры = Новый Структура;
					ДанныеСчетаФактуры.Вставить("ДокументОснование", РеализацияОбъект.Ссылка);
					ДанныеСчетаФактуры.Вставить("Организация", РеализацияОбъект.Организация);
					ДанныеСчетаФактуры.Вставить("Дата", РеализацияОбъект.Дата);
					
					СчетФактураВыданный = Документы.СчетФактураВыданный.СоздатьДокумент();
					СчетФактураВыданный.Заполнить(ДанныеСчетаФактуры); 
					СчетФактураВыданный.Комментарий = Комментарий;
					Попытка
						СчетФактураВыданный.Записать(РежимЗаписиДокумента.Проведение);
						
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создан документ: " + СчетФактураВыданный.Ссылка, СчетФактураВыданный.Ссылка);
					Исключение                     
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать документ 'Счет-фактура выданный'");
					КонецПопытки;
				КонецЕсли;
		
					// Создаем 'Заявка в ЕГАИС Лес'
					Если Документы.ЗаявкаВЕГАИСЛес.ПроверкаНаличияЗаявкиНаСоответствующийДокументПродажи(РеализацияОбъект.Ссылка) Тогда
						ДокЗаявка = Документы.ЗаявкаВЕГАИСЛес.СоздатьДокумент();
						ДокЗаявка.Дата = ТекДата;
						ДокЗаявка.Заполнить(РеализацияОбъект.Ссылка);
						
						Попытка
							ДокЗаявка.Записать(РежимЗаписиДокумента.Проведение);
							
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создан документ: " + ДокЗаявка.Ссылка, ДокЗаявка.Ссылка);
						Исключение
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать документ 'Заявка в ЕГАИС Лес'");
						КонецПопытки;
					КонецЕсли;                           
					
					// Создаем 'Лист согласования'
					
					//лист задолженности
					// 1) отгрузка по ТЧ(контрагент физ лицо), с проставлением галочки инкассация в заказе на доставку 
					Если (ЗаказНаДоставку.НужнаИнкассация И ЗаказКлиента.Контрагент.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо) ИЛИ
					// 2) если клиент отгружается по с/ф, и стоит галочка инкассация в заказе на доставку
				    (ЗаказНаДоставку.НужнаИнкассация И ЗначениеЗаполнено(ЗаказКлиента.Договор)) ИЛИ
					// 3) если клиент отгружается по с/ф (контрагент НЕ физлицо), и у него есть договор отсрочки, но выходит за рамки лимита (отгрузка запрещена)
					(ЗначениеЗаполнено(ЗаказКлиента.Договор) И ЗаказКлиента.Контрагент.ЮрФизЛицо <> Перечисления.ЮрФизЛицо.ФизЛицо И ПроверкаОграниченияЗадолженности(ЗаказКлиента.Договор, ТекДата)) Тогда
						СоздатьЛистСогласования(Отказ, ТекДата, РеализацияОбъект, Перечисления.ВидыОперацийЛистовСогласования.СогласованиеЗадолженности, Комментарий);	
					КонецЕсли;
					
					//лист оформления. должен создаваться по документам с договором
					Если ЗначениеЗаполнено(ЗаказКлиента.Договор) Тогда
						СоздатьЛистСогласования(Отказ, ТекДата, РеализацияОбъект, Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления, Комментарий);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Возврат Отказ;
	КонецЕсли;
	
КонецФункции

Функция ПроверкаОграниченияЗадолженности(Договор, Дата)
		
	ДанныеДоговора = Новый Структура; 
	ДанныеДоговора.Вставить("ОграничиватьСуммуЗадолженности", Ложь); 
	ДанныеДоговора.Вставить("ДопустимаяСуммаЗадолженности", 0); 
	ДанныеДоговора.Вставить("ВалютаВзаиморасчетов", Неопределено); 
	ДанныеДоговора.Вставить("ЗапрещаетсяПросроченнаяЗадолженность", Ложь); 
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	|	ДоговорыКонтрагентов.ОграничиватьСуммуЗадолженности КАК ОграничиватьСуммуЗадолженности,
	|	ДоговорыКонтрагентов.ДопустимаяСуммаЗадолженности КАК ДопустимаяСуммаЗадолженности,
	|	ДоговорыКонтрагентов.ВалютаВзаиморасчетов КАК ВалютаВзаиморасчетов,
	|	ДоговорыКонтрагентов.ЗапрещаетсяПросроченнаяЗадолженность КАК ЗапрещаетсяПросроченнаяЗадолженность
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.Ссылка = &Договор");
	
	Запрос.УстановитьПараметр("Договор", Договор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ДанныеДоговора = Выборка;
	КонецЕсли;
	
	ПревышенаСумма = Ложь;
	Если ДанныеДоговора.ОграничиватьСуммуЗадолженности Тогда
		ОстатокДопустимогоКредита = ОстатокДопустимогоКредита(Договор, ДанныеДоговора.ДопустимаяСуммаЗадолженности);
		ПревышенаСумма = ОстатокДопустимогоКредита < 0;
	КонецЕсли;
	
	ПревышенСрок = Ложь;
	Если ДанныеДоговора.ЗапрещаетсяПросроченнаяЗадолженность Тогда
		СуммаПросроченнойЗадолженности = СуммаПросроченнойЗадолженности(Договор, Дата);
		ПревышенСрок = СуммаПросроченнойЗадолженности > 0;
	КонецЕсли;
	
	Возврат ПревышенаСумма ИЛИ ПревышенСрок;
		
КонецФункции

Функция ОстатокДопустимогоКредита(Договор, ДопустимыйКредит)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос("
	|ВЫБРАТЬ
	|	РасчетыСКлиентамиОстатки.СуммаОстаток + РасчетыСКлиентамиОстатки.ОтгружаетсяОстаток КАК ОстатокДолга
	|ИЗ
	|	РегистрНакопления.РасчетыСКлиентами.Остатки(
	|		,
	|		АналитикаУчетаПоПартнерам В (
	|			ВЫБРАТЬ
	|				АналитикаПоПартнерам.КлючАналитики КАК КлючАналитики
	|			ИЗ
	|				РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаПоПартнерам
	|			ГДЕ
	|				АналитикаПоПартнерам.Договор = &Договор
	|			)
	|	) КАК РасчетыСКлиентамиОстатки
	|");
	Запрос.УстановитьПараметр("Договор", Договор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат ДопустимыйКредит - Выборка.ОстатокДолга;
	Иначе
		Возврат ДопустимыйКредит;
	КонецЕсли;
	
КонецФункции

Функция СуммаПросроченнойЗадолженности(Договор, ДатаДокумента)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПолучитьФункциональнуюОпцию("НоваяАрхитектураВзаиморасчетов") Тогда
		Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	РасчетыСКлиентамиОстатки.ДолгОстаток КАК ПросроченнаяЗадолженность
		|ИЗ
		|	РегистрНакопления.РасчетыСКлиентамиПоСрокам.Остатки(
		|		,
		|		АналитикаУчетаПоПартнерам В (
		|			ВЫБРАТЬ
		|				АналитикаПоПартнерам.КлючАналитики КАК КлючАналитики
		|			ИЗ
		|				РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаПоПартнерам
		|			ГДЕ
		|				АналитикаПоПартнерам.Договор = &Договор
		|			) И ДатаПлановогоПогашения < &ПериодКонтроляСрокаДолга
		|	) КАК РасчетыСКлиентамиОстатки
		|
		|ГДЕ
		|	РасчетыСКлиентамиОстатки.ДолгОстаток > 0
		|");
		Запрос.УстановитьПараметр("ПериодКонтроляСрокаДолга", НачалоДня(Макс(ТекущаяДатаСеанса(), ДатаДокумента)));
	Иначе
		Запрос = Новый Запрос("
		|ВЫБРАТЬ
		|	ЕСТЬNULL(СУММА(ВЫБОР КОГДА РасчетыСКлиентамиОстатки.СуммаОстаток >
		|			РасчетыСКлиентамиОстатки.КОплатеОстаток - РасчетыСКлиентамиОстатки.ОплачиваетсяОстаток ТОГДА
		|		РасчетыСКлиентамиОстатки.КОплатеОстаток - РасчетыСКлиентамиОстатки.ОплачиваетсяОстаток
		|	ИНАЧЕ
		|		РасчетыСКлиентамиОстатки.СуммаОстаток
		|	КОНЕЦ), 0) КАК ПросроченнаяЗадолженность
		|
		|ИЗ
		|	РегистрНакопления.РасчетыСКлиентами.Остатки(
		|		&ПериодКонтроляСрокаДолга,
		|		АналитикаУчетаПоПартнерам В (
		|			ВЫБРАТЬ
		|				АналитикаПоПартнерам.КлючАналитики КАК КлючАналитики
		|			ИЗ
		|				РегистрСведений.АналитикаУчетаПоПартнерам КАК АналитикаПоПартнерам
		|			ГДЕ
		|				АналитикаПоПартнерам.Договор = &Договор
		|			)
		|	) КАК РасчетыСКлиентамиОстатки
		|
		|ГДЕ
		|	РасчетыСКлиентамиОстатки.СуммаОстаток > 0
		|	И (РасчетыСКлиентамиОстатки.КОплатеОстаток - РасчетыСКлиентамиОстатки.ОплачиваетсяОстаток) > 0
		|");
		Запрос.УстановитьПараметр("ПериодКонтроляСрокаДолга", Макс(КонецДня(ТекущаяДатаСеанса()), КонецДня(ДатаДокумента)));
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Договор", Договор);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		Возврат Выборка.ПросроченнаяЗадолженность;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция ЕстьРеализацияПоЗаказу(ЗаказКлиента)
	
	Массив = АльтерраОбщегоНазначения.ПолучитьРеализацииПоЗаказу(ЗаказКлиента);
	Если ЗначениеЗаполнено(Массив) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По заказу '" + ЗаказКлиента + "' уже существует реализация: '" + Массив[0] + "'", Массив[0]);
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;

КонецФункции

Процедура СоздатьЛистСогласования(Отказ, ТекДата, РеализацияОбъект, ВидОперации, Комментарий)
	
	ДокЛистСогласования = Документы.ЛистСогласования.СоздатьДокумент();
	ДокЛистСогласования.ДополнительныеСвойства.Вставить("ПрограммноеСозданиеЛиста", Истина);
	
	Документы.ЛистСогласования.ЗаполнитьДанныеПоОснованию(
		РеализацияОбъект.Ссылка, 
		ДокЛистСогласования, 
		ВидОперации);      
	
	Если ВидОперации = Перечисления.ВидыОперацийЛистовСогласования.СогласованиеОформления Тогда
		ДокЛистСогласования.Проблема = Справочники.Проблемы.НайтиПоКоду("000000016"); // Реализация (отсутствие оригинала/некорректное оформление -ПАКЕТ ДОКУМЕНТОВ)
	КонецЕсли;
	
	ДокЛистСогласования.Комментарий = Комментарий;

	Попытка
		ДокЛистСогласования.Записать(РежимЗаписиДокумента.Проведение);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Создан документ: " + ДокЛистСогласования.Ссылка, ДокЛистСогласования.Ссылка);
	Исключение                                                     
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удалось записать документ 'Лист согласования'");
	КонецПопытки;
КонецПроцедуры

#КонецОбласти

Процедура ПроверкаКорректностиПримененияСкидокВЗаказе(Реализация_Ссылка, ЗаказКлиента, Отказ) Экспорт
	Если Не ЗначениеЗаполнено(Реализация_Ссылка) И ЗначениеЗаполнено(ЗаказКлиента) И Не Отказ Тогда  
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	ЗаказКлиента.НомерСтроки КАК НомерСтроки,
			|	ЗаказКлиента.Номенклатура КАК Номенклатура,
			|	ЗаказКлиента.СуммаРучнойСкидки + ЗаказКлиента.СуммаАвтоматическойСкидки КАК Скидка
			|ИЗ
			|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиента
			|ГДЕ
			|	ЗаказКлиента.Ссылка = &Ссылка
			|	И ЗаказКлиента.КоличествоУпаковок * ЗаказКлиента.Цена = ЗаказКлиента.Сумма
			|	И ЗаказКлиента.СуммаРучнойСкидки + ЗаказКлиента.СуммаАвтоматическойСкидки <> 0";
		
		Запрос.УстановитьПараметр("Ссылка", ЗаказКлиента);
		
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		Если РезультатЗапроса.Количество() <> 0 Тогда
			Пока РезультатЗапроса.Следующий() Цикл
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(
					"По строке заказа #" + РезультатЗапроса.НомерСтроки + 
					" скдика (" + РезультатЗапроса.Скидка + ") не учитывается. " +
					"Номенклатура: '" + РезультатЗапроса.Номенклатура + "'");
			КонецЦикла;
		
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&После("ДобавитьКомандыСозданияНаОсновании")
Процедура Док_ДобавитьКомандыСозданияНаОсновании(КомандыСоздатьНаОсновании, Параметры)
