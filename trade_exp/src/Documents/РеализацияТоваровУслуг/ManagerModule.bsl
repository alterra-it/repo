#Область АвтоопределениеДистрибуция

Процедура КонтрольУслугиДоставкиПриНеполнойОтгрузке(Объект)  Экспорт
	УслугаДоставки =  АльтерраОбщегоНазначения.УслугаДоставкиСНДС();
	СтрокаРеализации = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура", УслугаДоставки)); 
	Если СтрокаРеализации.Количество() > 0 Тогда	
		СтоимостьДоставкиРеализация = Объект.Товары.Итог("СуммаРТ");
		Если СтрокаРеализации[0].Сумма <>  СтоимостьДоставкиРеализация Тогда
			СтоимостьДоставкиРеализация = Объект.Товары.Итог("СуммаРТ"); 
			АльтерраОбщегоНазначения.ИзменитьУслугуДоставки(Объект, СтоимостьДоставкиРеализация);	
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 

  #КонецОбласти

