
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ОбщегоНазначенияУТ.НастроитьПодключаемоеОборудование(ЭтаФорма);

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШтрихкодыПоСекциямДокумента.Штрихкод,
		|	ШтрихкодыПоСекциямДокумента.Секция,
		|	ШтрихкодыПоСекциямДокумента.Сумма,
		|	ШтрихкодыПоСекциямДокумента.Назначение,
		|	ВЫБОР
		|		КОГДА ШтрихкодыПоСекциямДокумента.Штрихкод = &Штрихкод
		|			ТОГДА НЕ &Признак
		|		ИНАЧЕ &Признак
		|	КОНЕЦ КАК Проверен,
		|	&Признак КАК ПроверенДо
		|ИЗ
		|	РегистрСведений.ШтрихкодыПоСекциямДокумента КАК ШтрихкодыПоСекциямДокумента
		|ГДЕ
		|	ШтрихкодыПоСекциямДокумента.Документ = &Документ";

	Запрос.УстановитьПараметр("Документ", Параметры.Ссылка);
	Запрос.УстановитьПараметр("Признак", Параметры.Признак);
	Запрос.УстановитьПараметр("Штрихкод", Параметры.Штрихкод);

	РезультатЗапроса = Запрос.Выполнить();
	
	Штрихкоды.Загрузить(РезультатЗапроса.Выгрузить());
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	Закрыть(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура ШтрихкодыПроверенПриИзменении(Элемент)
	
	ШК = ПолучитьКопиюШтрихкоды();
	ДоступностьОК = Ложь;
	Если ШК.Количество() = 1 И ШК[0].Проверен <> ШК[0].ПроверенДо Тогда
		ДоступностьОК = Истина;
	КонецЕсли;
	
	Элементы.ФормаОК.Доступность = ДоступностьОК;
	
	Если ДоступностьОК Тогда
		ПодключитьОбработчикОжидания("ЗакрытьФормуИВернутьРезультат", 0.1, Истина);
		//ЗакрытьФормуИВернутьРезультат();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// +++ РС, 03.02.2015
	МенеджерОборудованияКлиент.НачатьПодключениеОборудованиеПриОткрытииФормы(Неопределено, ЭтаФорма, "СканерШтрихкода");
	// --- РС, 03.02.2015

	Элементы.ФормаОК.Доступность = Ложь;
	
	// +++ РС, 29.01.2015
	ШтрихкодыПроверенПриИзменении(Неопределено);
	// --- РС, 29.01.2015
КонецПроцедуры

&НаСервере
Функция ПолучитьКопиюШтрихкоды()
	ТаблицаШтрихкодов = Новый Массив;
	ШК = Штрихкоды.Выгрузить();
	ШК.Свернуть("Проверен, ПроверенДо", "Сумма");
	Для Каждого Стр Из ШК Цикл
		СтрокаТаблицы = Новый Структура("Проверен, ПроверенДо, Сумма");
		ЗаполнитьЗначенияСвойств(СтрокаТаблицы, Стр);
		ТаблицаШтрихкодов.Добавить(СтрокаТаблицы);
	КонецЦикла;
	Возврат ТаблицаШтрихкодов;	
КонецФункции

&НаКлиенте
Процедура ОК(Команда)
	// +++ РС, 29.01.2015
	ЗакрытьФормуИВернутьРезультат();	
	// --- РС, 29.01.2015
	
КонецПроцедуры

&НаКлиенте
Процедура ПоискПоШтрихкоду(Команда)
	ОчиститьСообщения();
	Оповещение = Новый ОписаниеОповещения("ПоискПоШтрихкодуЗавершение", ЭтотОбъект);
	ШтрихкодированиеНоменклатурыКлиент.ПоказатьВводШтрихкода(Оповещение);
	
КонецПроцедуры
&НаКлиенте
Процедура ПоискПоШтрихкодуЗавершение(ДанныхШтрихкода, ДополнительныеПараметры) Экспорт
	
	ОбработатьШтрихкоды(ДанныхШтрихкода);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьШтрихкоды(Данные)
	Если ЗначениеЗаполнено(Данные) Тогда
		ПараметрыОтбора = Новый Структура;
		ПараметрыОтбора.Вставить("Штрихкод", Данные.Штрихкод);
		СтрокиШК = Штрихкоды.НайтиСтроки(ПараметрыОтбора);
		Если СтрокиШК.Количество() > 0 Тогда
			СтрокиШК[0].Проверен = НЕ СтрокиШК[0].Проверен;
			ШтрихкодыПроверенПриИзменении(Неопределено);
		Иначе
			СообщениеОшибка = Новый СообщениеПользователю;
			СообщениеОшибка.Текст = "Штрихкод не найден!";
			СообщениеОшибка.Сообщить();
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры


&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	// ПодключаемоеОборудование
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" Тогда
			Данные = ПодключаемоеОборудованиеУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
			ОбработатьШтрихкоды(Данные);
		КонецЕсли;
	КонецЕсли;
	// Конец ПодключаемоеОборудование
	
КонецПроцедуры

// РС, 29.01.2015
&НаКлиенте
Процедура ЗакрытьФормуИВернутьРезультат()
	ШК = ПолучитьКопиюШтрихкоды();
	
	РезультатПроверки = Ложь;
	Если ШК.Количество() = 1 И  ШК[0].Проверен <> ШК[0].ПроверенДо Тогда
		РезультатПроверки = ШК[0].Проверен;
	КонецЕсли;
	
	Закрыть(РезультатПроверки);
КонецПроцедуры


&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
		// +++ РС, 03.02.2015
	МенеджерОборудованияКлиент.НачатьОтключениеОборудованиеПриЗакрытииФормы(Неопределено, ЭтаФорма);
	// --- РС, 03.02.2015

КонецПроцедуры

