
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЗаполнитьЗначенияСвойств(ЭтаФорма, Параметры,,"ТолькоПросмотр,ЗакрыватьПриВыборе,ЗакрыватьПриЗакрытииВладельца,КлючНазначенияИспользования");
	Массив=СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Параметры.РеквизитыТранспортногоСредства,"&");
	если Массив.Количество()<>0 тогда
	РегНомерАвтомобиля=Массив[0];
	МаркаАвтомобиля=Массив[1];
	конецесли;
КонецПроцедуры


&НаКлиенте
Процедура ОК(Команда)
	Если Не ТолькоПросмотр Тогда
		СохранитьПараметры = Истина;
		СохранитьВСтроку();	
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры
&НаСервере
Процедура СохранитьВСтроку()
Массив=Новый Массив;
Массив.Добавить(РегНомерАвтомобиля);
Массив.Добавить(МаркаАвтомобиля);
РеквизитыТранспортногоСредства=СтроковыеФункцииКлиентСервер.СтрокаИзМассиваПодстрок(Массив,"&");	

КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии()
		Если СохранитьПараметры Тогда
		
		СтруктураПараметров = ИзменяемыеРеквизиты(ЭтотОбъект);
		ОповеститьОВыборе(СтруктураПараметров);
		
	КонецЕсли;

КонецПроцедуры
&НаКлиенте
Функция ИзменяемыеРеквизиты(Источник)
	
	СтруктураПараметров = Новый Структура();
	СтруктураПараметров.Вставить("Водитель", Источник.Водитель);
	СтруктураПараметров.Вставить("РеквизитыТранспортногоСредства",     Источник.РеквизитыТранспортногоСредства);
	
	Возврат СтруктураПараметров;
	
КонецФункции

