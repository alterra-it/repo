#Область РетеилСервис
&НаКлиенте
Процедура ОтметкаКассыСканирование()
	УстановкаОтметки=Объект.Кассир.Пустая();
	
	Если УстановкаОтметки тогда
		//Беспалов
		Если Не ЗначениеЗаполнено(Объект.ПричинаПеределки) И ЗначениеЗаполнено(Объект.ДатаОтметкиКасса) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните причины правки документа", Объект.Ссылка, "Объект.ПричинаПеределки");
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	ПроверкаСекцийДокумента(УстановкаОтметки,ШтрихкодСекция);
	
	ОтметкуУстановить(УстановкаОтметки);
	
	УстановитьДоступностьПоОтметкеКассы();
	
КонецПроцедуры
&НаКлиенте
Функция ПоискШтрихкодаМенеджера(СтруктураДанных)
	
	Штрихкод = СтруктураДанных.Штрихкод;
	МенеджерСсылка = ПоискШтрихкодаМенеджераСервер(Штрихкод);
	
	Возврат МенеджерСсылка;
	
КонецФункции
&НаСервере
Функция ПоискШтрихкодаМенеджераСервер(ШК)
	МенеджерСсылка = Неопределено;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДополнительныеСведения.Объект
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|ГДЕ
	|	(ВЫРАЗИТЬ(ДополнительныеСведения.Значение КАК СТРОКА(13))) = &Штрихкод
	|	И ДополнительныеСведения.Свойство = &СвойствоШтрихкод";
	
	Запрос.УстановитьПараметр("СвойствоШтрихкод", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ШтрихкодПользователя"));
	Запрос.УстановитьПараметр("Штрихкод", ШК);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		МенеджерСсылка = Выборка.Объект;
	КонецЕсли;
	
	Возврат МенеджерСсылка;
	
КонецФункции
&НаКлиенте
Функция ДоступностьЭлемента(Элемент)
	
	Попытка 
		Если Не Элемент.Доступность Тогда
			Возврат Ложь;
		Иначе
			Возврат ДоступностьЭлемента(Элемент.Родитель);
		КонецЕсли;
	Исключение
		Возврат Истина;
	КонецПопытки;
	
КонецФункции
&НаСервере
Функция ЕстьПравоНаОтметкуКассы()
	
	возврат рольдоступна("Полныеправа") или рольдоступна("ОтметкаКассы");
	
КонецФункции // ПроверитьПравоНаОтметкуКассы()

&НаКлиенте
Процедура ПроверкаСекцийДокумента(Установить,ШК = Неопределено)
	если _ПроверкаОповещение тогда
		возврат;
	конецесли;	
	
	ИспользуетсяПроверкаШК = РСОбщийМодульВызовСервера.ПользовательИспользуетПроверкуПоШтрихкоду(ПолучитьПользователя());
	
	Если НЕ ИспользуетсяПроверкаШК Тогда
		Возврат ;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		Если ЗначениеЗаполнено(АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ЗаказКлиента, "Кассир")) Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;
	ОповещениеПроверкиПоСекциям = Новый ОписаниеОповещения("ПроверкиПоСекциямЗавершение",ЭтотОбъект); 
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ссылка", Объект.Ссылка);
	ПараметрыФормы.Вставить("Признак", не Установить);
	ПараметрыФормы.Вставить("Штрихкод", ШК);
	ОткрытьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаПроверкиПоСекциям",ПараметрыФормы,ЭтаФорма,,,,ОповещениеПроверкиПоСекциям,);
	_ПроверкаОповещение=истина;
КонецПроцедуры // ПроверкаСекцийДокумента()

&НаКлиенте
Процедура ПроверкиПоСекциямЗавершение(Результат, ДополнительныеПараметры) экспорт
	УстановкаОтметки=Объект.Кассир.Пустая();
	
	если результат=УстановкаОтметки тогда
		
		_ПроверкаОповещение=ложь;
		
		ОтметкуУстановить(УстановкаОтметки);
		
		УстановитьДоступностьПоОтметкеКассы();
		
	конецесли;
	
КонецПроцедуры

&НаКлиенте                       
Процедура ПроверкаИдентификацииКлиента(УстановкаОтметки)
	если УстановкаОтметки тогда
		ТекстСМС="";
		если ДопМодуль.ИдентифицироватьКлиентаПоСМС(Объект.Ссылка,ТекстСМС) тогда
			Оповещение = Новый ОписаниеОповещения("ОткрытьПараметрыОтправкиСМСЗавершение",ЭтотОбъект);   	
			ПараметрыФормы = Новый Структура("Владелец", Объект.Партнер);
			ПараметрыФормы.Вставить("ИдТолькоСМС");
			ПараметрыФормы.Вставить("ТекстСМС",ТекстСМС);
			ОткрытьФорму("Справочник.БонусныеПрограммыЛояльности.Форма.Спр_СМСИдентификация", ПараметрыФормы,ЭтаФорма,,,,Оповещение,);
			_ПроверкаОповещение=Истина;
		иначе
			ДопМодуль.ИнформироватьКлиентаПоСМС(Объект.Ссылка); 
		конецесли;	
	конецесли;
	
КонецПроцедуры
&НаКлиенте
Процедура ОткрытьПараметрыОтправкиСМСЗавершение(Результат, ДополнительныеПараметры) экспорт
	если результат=истина тогда
		УстановкаОтметки=Объект.Кассир.Пустая();
		
		_ПроверкаОповещение=ложь;
		
		ПроверкаСекцийДокумента(УстановкаОтметки);
		
		ОтметкуУстановить(УстановкаОтметки);
		
		УстановитьДоступностьПоОтметкеКассы();
		
	иначе
		Сообщить("Клиент не идентифицирован!");
	конецесли;
КонецПроцедуры

#КонецОбласти

