&НаКлиенте
Процедура Док_ТоварыПередУдалением(Элемент, Отказ)
	// Альтерра Устинов В.А. Зеленение 18.03.2013 13:45:30
	если ЗначениеЗаполнено(Объект.Кассир) тогда
		Предупреждение("Товар оплачен. Удаление строки запрещено!!!");
		Отказ=Истина;
	конецесли;	
	если ЗначениеЗаполнено(Элементы.товары.ТекущиеДанные.Кладовщик) тогда
		Предупреждение("Товар выдан со склада. Удаление строки запрещено!!!");
		Отказ=Истина;
	конецесли;
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	Если ТекущиеДанные <> неопределено Тогда                            
		УдаляемаяНоменклатура = ТекущиеДанные.номенклатура; 
		Если ЭтоУслугаРезки(УдаляемаяНоменклатура) ТОгда 
			Объект.Нарезка.Очистить();
		КонецЕсли;
	КонецЕсли;
	//-
КонецПроцедуры  

&НаСервере
Функция ЭтоУслугаРезки(номенклатура) 
	Если номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
		И Найти(Номенклатура.Наименование, "резк") > 0 Тогда 
		Возврат Истина; 
	Иначе
		Возврат Ложь; 
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура Док_ОбработкаОповещенияПеред(ИмяСобытия, Параметр, Источник)
	// Альтерра Беспалов
	Если ЗначениеЗаполнено(Объект.Кассир) Тогда 
		Возврат;
	КонецЕсли;
	
	Если Источник = "ПодключаемоеОборудование" И ВводДоступен() Тогда
		Если ИмяСобытия = "ScanData" И МенеджерОборудованияУТКлиент.ЕстьНеобработанноеСобытие() Тогда
			// Альтерра Беспалов РС, 29.01.2015
			СтруктураДанных= МенеджерОборудованияУТКлиент.ПреобразоватьДанныеСоСканераВСтруктуру(Параметр);
			Штрихкод= СокрЛП(СтруктураДанных.Штрихкод);
			Если СтрДлина(Штрихкод) > 13 Тогда 
				Если РСОбщийМодульВызовСервера.ПоискШтрихкодаСекцииСервер(Объект.Ссылка, Штрихкод) Тогда
					ПодключитьОбработчикОжидания("ОтметкаКассыСканирование", 0.1, Истина);
				КонецЕсли;
			Иначе
				// Беспалов  Обробатываем считанные штрихкоды
				//1. - начинается на 8888 - ставим менеджера
				//2. - начинается 21,22,23,24,25 - ставим карту лояльности
				//3. остальное подбор номенклатуры
				Если Источник = "ПодключаемоеОборудование" И ИмяСобытия = "ScanData" Тогда
					
					Если Лев(Штрихкод, 4) = "8888" Тогда//1. Менеджер
						МенеджерСсылка = РСС_УправлениеОчередьюИСборкойЗаказов.ПоискПользователяПоШтрихкоду(Штрихкод);
						Если МенеджерСсылка <> Неопределено И МенеджерСсылка <> Объект.Менеджер Тогда
							Объект.Менеджер = МенеджерСсылка;	
							Модифицированность = Истина;
						КонецЕсли
					ИначеЕсли Лев(Штрихкод, 4) = "5555" Тогда//2. Выбор принтера
						ИмяПринтера= АльтерраОбщегоНазначения.ПолучитьИмяПринтера(Штрихкод);
						Если ЗначениеЗаполнено(ИмяПринтера) Тогда
							АльтерраОбщегоНазначенияКлиент.НапечататьПакетНаПринтер(Объект, ЭтаФорма, ИмяПринтера);
						КонецЕсли;
					ИначеЕсли АльтерраОбщегоНазначенияКлиент.ЭтоШтрихкодКартыЛояльности(Штрихкод) Тогда //3. Карта лояльности
						КартыЛояльности = КартыЛояльностиВызовСервера.НайтиКартыЛояльностиПоШтрихкоду(Штрихкод);
						Если КартыЛояльности.ЗарегистрированныеКартыЛояльности.Количество() > 0 Тогда 
							КартаЛояльности= КартыЛояльности.ЗарегистрированныеКартыЛояльности[0];
							Если КартаЛояльности.Статус = АльтерраОбщегоНазначения.ПолучитьСтатусКартыЛояльностиДействует() Тогда
								Объект.КартаЛояльности= КартаЛояльности.Ссылка;
								Док_КартаЛояльностиПриИзмененииНаКлиенте(Неопределено);
								//158234 запись в чек способ ввода клиента
							    СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.КартаЛояльности");
							    Объект.СпособВводаКлиента = СпособВводаКлиента;    
							    //158234
							Иначе
								ТекстСообщения = НСтр("ru = 'Карта со штрихкодом %1 аннулирована. Зарегистрируйте карту с помощью помощника регистрации карт лояльности'");
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Штрихкод), , "Объект.КартаЛояльности");
							КонецЕсли
						Иначе 
							ТекстСообщения = НСтр("ru = 'Карта со штрихкодом %1 не зарегистрирована. Карты регистрируются только с помощью помощника регистрации карт лояльности'");
							ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Штрихкод), , "Объект.КартаЛояльности");
						КонецЕсли;
					ИначеЕсли СтрДлина(Штрихкод) <= 30 Тогда //4. Номенклатура
						ОбработатьШтрихкоды(СтруктураДанных);
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		//-
	КонецЕсли;
	//-
	
	Если ИмяСобытия = "СчитанаКартаЛояльности"
		И Параметр.ФормаВладелец = УникальныйИдентификатор Тогда
		//158234 запись в чек способ ввода клиента
        СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.КартаЛояльности");
        Объект.СпособВводаКлиента = СпособВводаКлиента;
        //158234
		Объект.КартаЛояльности= Параметр.КартаЛояльности;
		Док_КартаЛояльностиПриИзмененииНаКлиенте(Неопределено);
		ИмяСобытия= "прервать";
		Возврат;
	КонецЕсли;
	
	Если ИмяСобытия = "СчитанПартнер"	И Параметр.ФормаВладелец = УникальныйИдентификатор Тогда
		//158234 запись в чек способ ввода клиента
        СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.НомерТелефона");
        Объект.СпособВводаКлиента = СпособВводаКлиента;
        //158234
		Объект.Партнер= Параметр.Партнер;
		Док_ПартнерПриИзменении(Неопределено);				
		
		////ПартнерПриИзменении(Неопределено);
		//Объект.КартаЛояльности= АльтерраОбщегоНазначения.ПолучитьКартуЛояльности(Объект.Партнер);
		//Объект.Соглашение= АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности);
		
		//СоглашениеПриИзменении(Неопределено);
		ИмяСобытия= "прервать";
		Возврат;
	КонецЕсли;
	
//	//Исправление оповещения для автоматического отображения долга клиента
//	Если (ИмяСобытия = "ЗачтенаОплата" И Параметр = Объект.Ссылка)
//		Или ПродажиКлиент.ИзменилисьДокументыОплатыКлиентам(ИмяСобытия) Тогда
//		Если (НЕ Объект.РеализацияПоЗаказам И Объект.ПорядокРасчетов = ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоЗаказамНакладным"))
//			ИЛИ Объект.ПорядокРасчетов = ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоНакладным") Тогда
//			Прочитать();
//		КонецЕсли;
//		ИмяСобытия= "прервать";
//		Возврат;
//	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	ПоказатьИнформациюПоБонусам();
	
	//Инструкции
	мФайлов= АльтерраОбщегоНазначения.ПолучитьВыборкуФайловИзТовара(Объект.Ссылка);
	Если мФайлов.Количество() > 0 Тогда
		Оповещение= Новый ОписаниеОповещения("НапечататьФайлыЗавершение", ЭтотОбъект, мФайлов);
		ПоказатьВопрос(Оповещение, "По преобретаемому товару есть инструкции."+Символы.ПС+"Напечатать инструкции?", РежимДиалогаВопрос.ДаНет, 10, КодВозвратаДиалога.Да, "Печать инструкций");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура НапечататьФайлыЗавершение(Результат, мФайлов) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		РаботаСФайламиКлиент.НапечататьФайлы(мФайлов);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ДоговорПриИзмененииПосле(Элемент) 
	
	ЗаполнитьПорядокРасчетовПоДоговору();
	Элементы.ТекстДокументыНаОснованииПодвалРасш.Доступность = Объект.ПорядокРасчетов = ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоДоговорамКонтрагентов");	
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтаФорма);  
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		СуммаБонусныхБаллов = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
		ОчиститьБонусыСервер();
	ОчиститьСообщения();
		ОповещениеОбОчисткеБонусов(СуммаБонусныхБаллов); 
		Если ПолучитьМенеджераДоИзменения(Объект.Ссылка) <> Объект.Менеджер Тогда 
			Объект.ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Объект.Менеджер); 
			Объект.ОтделМенеджера = ПолучитьОтделМенеджера(Объект.Менеджер);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьМенеджераДоИзменения(Ссылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Менеджер КАК Менеджер
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Менеджер;
КонецФункции

&НаКлиенте
Процедура Док_КонтрагентПриИзмененииПосле(Элемент)
	
	ОчиститьСообщения();
	Док_КонтрагентПриИзмененииПослеНаСервере(); 
	
КонецПроцедуры 

&НаСервере
Процедура Док_КонтрагентПриИзмененииПослеНаСервере()
	
	Если ЗначениеЗаполнено(Объект.Контрагент.Партнер)Тогда
		Объект.Партнер = Объект.Контрагент.Партнер;
	КонецЕсли;  
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		СуммаБонусныхБаллов = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
		ОчиститьБонусыСервер();
		ОповещениеОбОчисткеБонусов(СуммаБонусныхБаллов);
	КонецЕсли;
	
	ЛистыСогласованияСервер.ЕстьНеисполненныеЛистыСогласования(Объект.Контрагент);
	
	ЗаполнитьПорядокРасчетовПоДоговору();  
	
	ПроверитьЭДО();
КонецПроцедуры

Процедура ПроверитьЭДО()
	если ДопМодуль.КонтрагентРаботаетВЭдо(Объект.Контрагент) тогда
		Элементы.КонтрагентРаботаетВЭДО.Видимость=истина;
		если Объект.СтатусДокументаВЭДО=Перечисления.СтатусыДокументаЭДО.НеВыгружен тогда
			Объект.СтатусДокументаВЭДО=Перечисления.СтатусыДокументаЭДО.ГотовКОтправке;
		конецесли;	 
	иначе
		если Объект.СтатусДокументаВЭДО=Перечисления.СтатусыДокументаЭДО.ГотовКОтправке тогда
			Объект.СтатусДокументаВЭДО=Перечисления.СтатусыДокументаЭДО.НеВыгружен;
		конецесли;	 
	конецесли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ОрганизацияПриИзмененииПосле(Элемент) 
	
	ЗаполнитьПорядокРасчетовПоДоговору();   
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьМенеджераДоИзменения(Объект.Ссылка) <> Объект.Менеджер Тогда 
			Объект.ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Объект.Менеджер); 
			Объект.ОтделМенеджера = ПолучитьОтделМенеджера(Объект.Менеджер);
		КонецЕсли;	
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
Процедура ЗаполнитьПорядокРасчетовПоДоговору()
	
	Если Объект.ИспользуетсяДоговор И ЗначениеЗаполнено(Объект.Договор) Тогда
		Объект.ПорядокРасчетов = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ПорядокРасчетов");
	КонецЕсли; 
	
КонецПроцедуры

&После("УстановитьДоступностьЭлементовПоСтатусуСервер")
Процедура Док_УстановитьДоступностьЭлементовПоСтатусуСервер()
	ДоступностьЦены=истина;
	если  рольДоступна("ЗапретИзменениеВидаЦеныВДокументе") тогда
		если не Объект.Склад.ЭтоГруппа	тогда
			ДоступностьЦены=не Объект.Склад.неРазрешеноРедактированиеЦены;
		конецесли;
	конецесли;	
	Элементы.ТоварыВидЦены.Доступность = ДоступностьЦены ;
	Элементы.ТоварыЗаполнитьЦеныВыделенныхСтрокПоВидуЦен.Доступность = ДоступностьЦены ;
	Элементы.ТоварыПодобратьТоварыПоЗаказамОрдерам.Доступность = Истина;

КонецПроцедуры

