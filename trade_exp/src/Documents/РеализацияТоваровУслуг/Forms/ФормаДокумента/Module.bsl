	Объект.Подразделение= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Подразделение");
	УведомленияПодрядчику_ИнициализацияЗначений();  
	если ДопМодуль.НовоеЦенообразование() тогда 
		СоглашениеПриИзмененииСервер();            
	конецесли;
	ОбновитьПараметрыВыбораЦен();
	
	Если НЕ ПроверитьЗапретБонусов() Тогда
		ОчиститьБонусыСервер();
		ПерераспределитьБонусы(СуммаОплатыБонусами);
