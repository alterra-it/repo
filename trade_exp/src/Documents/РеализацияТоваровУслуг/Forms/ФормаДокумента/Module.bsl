&НаСервере
Процедура УстановитьДоступностьПоОтметкеКассы()
	Если _ПроверкаОповещение Тогда
		Возврат;
	Конецесли;	
	
	ДопМодуль.УстановитьДоступностьПоОтметкеКассыОбщий(ЭтаФорма);
	
	ВидимостьФлажки();
	Если РольДоступна("ОтметкаКассы") ИЛИ РольДоступна("ПолныеПрава") Тогда
		ЭтаФорма.Элементы.ПричинаПеределки.ТолькоПросмотр = Ложь;
		//////Оплата картой при доставке
		СсылкаЗаказНаДоставку = Документы.ЗаказНаДоставкуКлиенту.ПолучитьЗаказНаДоставкуПоОснованию(Объект.Ссылка);
		Если СсылкаЗаказНаДоставку <> Документы.ЗаказНаДоставкуКлиенту.ПустаяСсылка() Тогда
			Элементы.ОплатаДоставкиКартой.Видимость = СсылкаЗаказНаДоставку.ОплатаБанковскойКартой;	
		КонецЕсли;	
		///////
	КонецЕсли;
	Если Объект.Кассир.Пустая() Тогда  
		Элементы._ЗаполнитьШапкуПоЗаказу.Видимость = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		ЭтаФорма.Элементы.Форма_Нарезка.Доступность = Ложь;      
		Элементы._ЗаполнитьНарезкуПоЗаказу.Видимость = Истина;
	КонецЕсли;
	Элементы.ФормаОбщаяКомандаНачислитьБонусы.Доступность = Истина;
КонецПроцедуры	

&НаСервере
Процедура УстановитьДоступностьФормыПоОтметкеКассы_Устарела(флаг)
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		Элементы.Партнер.ТолькоПросмотр= Истина;
		Элементы.Контрагент.ТолькоПросмотр= Истина;
		Элементы.Соглашение.ТолькоПросмотр= Истина;
		Элементы.Договор.ТолькоПросмотр= Истина;
		Элементы.Склад.ТолькоПросмотр= Истина;
		Элементы.Организация.ТолькоПросмотр= Истина;
		Элементы._ЗаполнитьШапкуПоЗаказу.Видимость= Истина;
		Элементы.Товары_ДобавитьУслугуБезНДС.Доступность = Ложь; //
		Элементы.ТоварыКонтекстноеМеню.Доступность= Ложь;
		Элементы.ТоварыСкопироватьСтроки.Доступность= Ложь;
		Элементы.ТоварыВставитьСтроки.Доступность= Ложь;
		Элементы.ТоварыРазбитьСтроку.Доступность= Ложь;
		Элементы.ТоварыПоискПоШтрихкоду.Доступность= Ложь;
		Элементы.ТоварыНоменклатура.ТолькоПросмотр= Истина;
		Элементы.ТоварыКоманднаяПанель.ПодчиненныеЭлементы.ТоварыДобавить.Доступность= Ложь;
		Элементы.ТоварыКоманднаяПанель.ПодчиненныеЭлементы.ГруппаЦеныСкидки.Доступность= Ложь;
		Элементы.ТоварыКоманднаяПанель.ПодчиненныеЭлементы.Форма_Нарезка.Доступность= Ложь;
		ТоварыГруппаЗаполнить= Элементы.ТоварыКоманднаяПанель.ПодчиненныеЭлементы.ГруппаТоварыПодобратьТовары.ПодчиненныеЭлементы.ТоварыГруппаЗаполнить.ПодчиненныеЭлементы;
		ТоварыГруппаЗаполнить.ТоварыДополнитьМногооборотнойТарой.Доступность= Ложь;
		ТоварыГруппаЗаполнить.ТоварыЗагрузитьИзВнешнегоФайла.Доступность= Ложь;
		ТоварыГруппаЗаполнить.ТоварыЗаполнитьСерииПоFEFO.Доступность= Ложь;
		ТоварыГруппаЗаполнить.ТоварыОткрытьПодбор.Доступность= Ложь;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		ЭтаФорма.Элементы.Форма_Нарезка.Доступность= Ложь;                    	
	иначе
		Элементы.ТоварыКоманднаяПанель.ПодчиненныеЭлементы.ГруппаТоварыПодобратьТовары.Доступность= Не флаг;
		ЭтаФорма.Элементы.Форма_Нарезка.Доступность= не флаг;
	КонецЕсли;	
	
	ЭтаФорма.ТолькоПросмотр= флаг;
	Элементы._ДопФлажки.ТолькоПросмотр= флаг;
	Элементы._ПровестиНапечататьЗакрыть.Доступность= не флаг;
	ЭтаФорма.Элементы.ТоварыСброситьПоСекции.Доступность= не флаг;
	ЭтаФорма.Элементы.Форма_Провести.Видимость= Ложь;
	
	Если ЭтаФорма.ТолькоПросмотр И (РольДоступна("ПроводитьПриОтметкеКассы") ИЛИ РольДоступна("ПолныеПрава")) Тогда
		ЭтаФорма.Элементы.Форма_Провести.Видимость= Истина;
	КонецЕсли;
	
КонецПроцедуры

