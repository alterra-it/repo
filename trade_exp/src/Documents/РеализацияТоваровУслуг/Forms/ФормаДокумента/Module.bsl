&НаКлиенте
Процедура ОчиститьРаспределение()
	
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		Возврат;
	КонецЕсли;
	//
	
	КоллекцияТовары = Объект.Товары;
	КоллекцияВидыЗапасов = Объект.ВидыЗапасов;
	
	ПроверкаИтоговПоСтрокам = 
	КоллекцияТовары.Итог("СуммаСНДСРТ") + 
	КоллекцияТовары.Итог("СуммаНДСРТ") + 
	КоллекцияТовары.Итог("СуммаРТ") + 
	КоллекцияТовары.Итог("Распределять") + 
	КоллекцияВидыЗапасов.Итог("СуммаСНДСРТ") + 
	КоллекцияВидыЗапасов.Итог("СуммаНДСРТ");
	
	Если ПроверкаИтоговПоСтрокам = 0 И Не Объект.РаспределитьТранспортные И Не Элементы.ТоварыРаспределять.Видимость Тогда  
		Возврат;
	КонецЕсли;
	
	СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	ОчиститьБонусыСервер();
	ОчиститьСообщения();
		ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
	
	Для Каждого Элемент Из КоллекцияТовары Цикл
		Элемент.СуммаСНДСРТ=0;
		Элемент.СуммаНДСРТ=0;
		Элемент.СуммаРТ=0;
		Элемент.Распределять=0;
	КонецЦикла;
	
	Для каждого Элемент из КоллекцияВидыЗапасов цикл
		Элемент.СуммаСНДСРТ=0;
		Элемент.СуммаНДСРТ=0;
	конеццикла;
	
	Объект.РаспределитьТранспортные=ложь;
	Элементы.ТоварыРаспределять.Видимость = Ложь;
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыСуммаПриИзмененииПосле(Элемент)
	Если НЕ Объект.РеализацияПоЗаказам Тогда
		СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
		ОчиститьБонусыСервер();
			
		Если НовыйПорядокНачисленияБонусов Тогда	
			ПерераспределитьБонусы(СуммаОплатыБонусами);
			Если Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте")<СуммаОплатыБонусами Тогда
				ОповеститьОСниженииБонусов();
			КонецЕсли;
		Иначе
			ОчиститьСообщения();
			ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
		КонецЕсли;
	РассчитатьИтоговыеПоказатели(ЭтотОбъект);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДанныеПоСтрокеИзЗаказа()
	МассивСтрок = Новый Массив;
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	МассивСтрок.Добавить(ТекущиеДанные.КодСтроки);
	ПересчитатьБонусыВСтрокеНаСервере(МассивСтрок);
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПоСтроке(ТекущаяСтрока)
	
	Строка = Объект.Товары.НайтиПоИдентификатору(ТекущаяСтрока);
	
	Если БонусыАльтерраРезерв.ПроверитьЗапретБонусов(Объект) Тогда
		Строка.СуммаБонусныхБалловКСписанию = 0;
		Строка.СуммаБонусныхБалловКСписаниюВВалюте = 0;
	КонецЕсли;
	
	Строка.СуммаНачисленныхБалловЗаКП = 0;
	Строка.СуммаНачисленныхБалловПрочее = 0;
	Строка.СуммаНачисленныхБалловЗаСтатус = 0;
	Строка.СуммаНачисленныхБонусныхБалловВВалюте = 0;
	
	БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, Строка);
	
	
КонецПроцедуры

&НаСервере
&Перед("НазначитьРучнуюСкидкуНаСервере")
Процедура Док_НазначитьРучнуюСкидкуНаСервере(СуммаСкидкиНаценки, Знач ВыделенныеСтроки, АдресВоВременномХранилище)
	Если НЕ Объект.РеализацияПоЗаказам Тогда
		Если НовыйПорядокНачисленияБонусов Тогда
			ЭтаФорма.Прочитать();
			Если ВыделенныеСтроки <> Неопределено Тогда
				Для Индекс = 1 - ВыделенныеСтроки.Количество() По 0 Цикл
					НайденнаяСтрока = Объект.Товары.НайтиПоИдентификатору(ВыделенныеСтроки[-Индекс]);
					Если Не ЗначениеЗаполнено(Объект.Кассир) Тогда
						БонусыАльтерраРезерв.ОчиститьБонусыПоСтроке(НайденнаяСтрока);
					Иначе
						ВыделенныеСтроки.Удалить(-Индекс);	
					КонецЕсли;
				КонецЦикла;
			КонецЕсли;
		Иначе
		СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
			ОчиститьБонусыСервер();
			ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
&После("ОбработкаПодбораТоваровИзЗаказа")
Процедура Док_ОбработкаПодбораТоваровИзЗаказа(АдресТоваровВХранилище)
	ЗаполнитьБонусыПоЗаказу();
