	ОчиститьСообщения();
		ОповещениеОбОчисткеБонусов(СуммаБонусныхБаллов);
	КонецЕсли;
	
	Если ИсточникВыбора.ИмяФормы = "Документ.ЗаказКлиента.Форма.ФормаРаспределения" Тогда
		ОбработкаРаспределенияТранспортных(ВыбранноеЗначение.АдресТоваровВХранилище);
		//-		
	КонецЕсли;
