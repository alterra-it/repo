&НаКлиенте
Процедура ОтметкаКассы(Команда)
	
	СФП_МаркерыКлиент.МаркерНачало("Реализация: Отметка кассы", Объект.Номер);
	
	УстановкаОтметки = Объект.Кассир.Пустая();
	// Блок проверок
	Если  УстановкаОтметки Тогда
		Если Не Объект.Проведен Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ не проведен! Установка отметки кассы невозможна!", Объект.Ссылка, "Объект.Кассир");
			Возврат;
		Иначе
			Если Не ЗначениеЗаполнено(Объект.ПричинаПеределки) И ЗначениеЗаполнено(Объект.ДатаОтметкиКасса) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заполните причины правки документа", Объект.Ссылка, "Объект.ПричинаПеределки");
				Возврат;
			КонецЕсли;
		КонецЕсли;
		//Проверка согласованного листа
		Если Не ЕстьСогласованныеЛисты() ИЛИ ЕстьНеСогласованныйРейс() Тогда             
			Возврат;
		КонецЕсли;		
	Иначе                                       
		Если  ПроверитьЕстьРейсыПоДокументу() Тогда       
			Возврат;
		КонецЕсли;
	КонецЕсли;
	_ПроверкаОповещение=Ложь;
	
	//ПроверкаИдентификацииКлиента(УстановкаОтметки);
	
	ПроверкаСекцийДокумента(УстановкаОтметки);
	
	ОтметкуУстановить(УстановкаОтметки);
	
	//УстановитьДоступностьПоОтметкеКассы();
	
КонецПроцедуры
&НаСервере
Процедура ЗаписьОтметкиКассы()
	ПараметрЗаписи =  Новый Структура;
	ПараметрЗаписи.Вставить("РежимЗаписи",РежимЗаписиДокумента.Запись);
	ЭтаФорма.Записать(ПараметрЗаписи);
	
КонецПроцедуры
&НаСервере
Функция ЕстьСогласованныеЛисты()
	ЛистыСогласования= ЛистыСогласованияСервер.ПолучитьЛистыСогласования(Объект.Ссылка);
	Пока ЛистыСогласования.Следующий() Цикл
		Если Не ЛистыСогласования.Согласован Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Есть не согласованный лист:"+Строка(ЛистыСогласования.Ссылка), ЛистыСогласования.Ссылка); 
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
КонецФункции
