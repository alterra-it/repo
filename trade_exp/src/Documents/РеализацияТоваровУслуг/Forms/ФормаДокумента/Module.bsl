#Область РаспределениеТранспортных
&НаСервере
Функция РаспределитьТранспортныеНаСервере()
	
	Запрос = Новый Запрос;
	МенеджерВременныхТаблиц= Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц=МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.Номенклатура
	|ПОМЕСТИТЬ ВТ_Товары
	|ИЗ
	|	&Товары КАК Товары
	|ГДЕ
	|	Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Товары.Номенклатура
	|ИЗ
	|	ВТ_Товары КАК ВТ_Товары";
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить(,"Номенклатура"));
	Результат = Запрос.ВыполнитьПакет();
	
	если Результат[0].Выгрузить().Количество()=0 тогда
		Возврат Ложь;
	иначе
		Возврат ИСТИНА;
	конецесли;	
	
КонецФункции 
&НаСервере
Процедура ОбработкаРаспределенияТранспортных(АдресТоваровВХранилище)
	
	ТаблицаРаспределения = ПолучитьИзВременногоХранилища(АдресТоваровВХранилище);
	если ТаблицаРаспределения = НЕОПРЕДЕЛЕНО тогда
		возврат;
	конецесли;	
	Структурапоиска=Новый Структура("Номенклатура,Характеристика,Склад,Количество");
	
	
	Для Каждого СтрокаТоваров Из ТаблицаРаспределения Цикл
		Структурапоиска.Номенклатура=СтрокаТоваров.Номенклатура;
		Структурапоиска.Характеристика=СтрокаТоваров.Характеристика;
		Структурапоиска.Склад=СтрокаТоваров.Склад;
		Структурапоиска.Количество=СтрокаТоваров.Количество;
		МассивСтрокТЧТовары = Объект.Товары.НайтиСтроки(СтруктураПоиска);
		
		для каждого стр из МассивСтрокТЧТовары цикл
			стр.Распределять=СтрокаТоваров.Распределять;
		конеццикла;	
		
	конеццикла;
	
	Элементы.ТоварыРаспределять.Видимость=Объект.Товары.Итог("Распределять")<>0;
КонецПроцедуры
&НаСервере
Функция ЕстьУслуги()
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РеализацияТоваровУслугТовары.Номенклатура
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|ГДЕ
	|	РеализацияТоваровУслугТовары.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
	|	И РеализацияТоваровУслугТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Услуга);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;;
	
	Возврат Ложь;
КонецФункции

&НаКлиенте
Процедура Док__РаспределитьТранспортные(Команда)
	// Вставить содержимое обработчика.
	Если АльтерраОбщегоНазначения.ПроверитьУслуги(Объект) Тогда 
		ТекстПредупреждения = НСтр("ru='В табличной части нет услуг к распределению.'");
		ПоказатьПредупреждение(,ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Товары", Объект.Товары);
	Модифицированность = Истина;	
	ОткрытьФорму("Документ.ЗаказКлиента.Форма.ФормаРаспределения",ПараметрыОткрытия,ЭтотОбъект);
	
		СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	ОчиститьБонусыСервер();// Альтерра ПроектЧеки
	ОчиститьСообщения();
		ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
	
КонецПроцедуры
