		//Объект.Касса=ДопМодуль.ПолучитьКассуПоУмолчанию(объект.Организация);
		Сотрудник= АльтерраОбщегоНазначения.ПолучитьСотрудника(Пользователи.ТекущийПользователь());
		Если ЗначениеЗаполнено(Сотрудник) Тогда
