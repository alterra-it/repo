&НаСервере
Процедура ОчиститьБонусыСервер()
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) И (БонусыАльтерраРезерв.ПолучитьСуммуБалловКСписаниюИзЗаказа(Объект.ЗаказКлиента) > 0
		ИЛИ БонусыАльтерраРезерв.ПолучитьСуммуБалловКНачислениюИзЗаказа(Объект.ЗаказКлиента) > 0) 
		Тогда
		МассивСтрок = Новый Массив;
		Для каждого Стр Из Объект.Товары Цикл
			МассивСтрок.Добавить(Стр.КодСтроки);
		КонецЦикла;
		ПересчитатьБонусыВСтрокеНаСервере(МассивСтрок);
	Иначе
		БонусыАльтерраРезерв.ОчиститьБонусыПолностью(Объект);
	КонецЕсли;
	
	ЗапретВидимостиБонусов(); 
	
КонецПроцедуры

&НаСервере
Процедура ЗапретВидимостиБонусов()
	
	ЗапретБонусов = ?(НовыйПорядокНачисленияБонусов, 
	БонусыАльтерраРезерв.ПроверитьЗапретБонусов(Объект),
	БонусыАльтерра.ПроверитьЗапретБонусов(Объект));
	
	Элементы._Бонусы.Доступность = НЕ ЗапретБонусов;
	
	Если ЗначениеЗаполнено(Объект.Кассир) Тогда
		Элементы._Бонусы.Доступность = Ложь;
	КонецЕсли;
КонецПроцедуры

