Процедура Док_СкладПриИзменении(Элемент)
	
	//АвтоопределениеДистрибуция
	ОчиститьРеквизитыДоставкиДистрибуция();
	УстановитьВидимостьРеквизитовДоставкиДистрибуция(); 
    //
	СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	
	Объект.Грузоотправитель= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Склад, "Грузоотправитель");
