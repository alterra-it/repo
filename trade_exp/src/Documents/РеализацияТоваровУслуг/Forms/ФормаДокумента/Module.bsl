&НаКлиенте
Процедура Док_ВызватьРаспределениеТранспортныхДистрибуцияПеред(Команда)
	
    Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		СнятьРаспределениеТранспортныхДистрибуция();
	Иначе   
		Если НЕ ЗначениеЗаполнено(Объект.Тариф) Тогда
			Сообщить("Не определен тариф, транспортные распределены не будут. Выберите объект доставки");
			Объект.РаспределитьТранспортныеДистрибуция = Ложь;
			Возврат;
		КонецЕсли;
		РаспределитьТранспортныеДистрибуция();
	КонецЕсли; 
	Объект.РаспределитьТранспортныеДистрибуция = Не Объект.РаспределитьТранспортныеДистрибуция;
   	УстановитьВидимостьПоРаспределитьТранспортные();
КонецПроцедуры

&НаКлиенте
Процедура СнятьРаспределениеТранспортныхДистрибуция()
	
	Если НЕ Объект.РаспределитьТранспортныеДистрибуция ИЛИ Объект.РеализацияПоЗаказам Тогда
		Возврат;
	КонецЕсли; 
	
	ИзменитьУслугуДоставки(1);
	АльтерраОбщегоНазначенияКлиент.СнятьРаспределениеТранспортныхДистрибуция(Объект);
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьСтроки() 
	АльтерраОбщегоНазначенияКлиент.ПересчитатьСтроки(Объект);
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьТранспортныеДистрибуцияПриИзмененииСтроки()
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		ТекСтрока = Элементы.Товары.ТекущиеДанные; 
		Если ТекСтрока.Цена >0  И ТекСтрока.Количество > 0 Тогда 
			РаспределитьТранспортныеДистрибуция();
		КонецЕсли;
	КонецЕсли
КонецПроцедуры

&НаКлиенте
Процедура РаспределитьТранспортныеДистрибуция()
	Если Объект.РеализацияПоЗаказам Тогда
		Возврат;
	КонецЕсли;
	СтоимостьДоставки  = РаспределитьТранспортныеДистрибуцияНаСервере(); 
	ИзменитьУслугуДоставки(СтоимостьДоставки);  
КонецПроцедуры 
	
 &НаСервере
 функция РаспределитьТранспортныеДистрибуцияНаСервере()  
 	Результат = УправлениеЛогистикойСервер.РаспределениеСтоимостиДоставкиДистрибуция(Объект);
 	ТранспортныеИтог = Результат.ТранспортныеИтог;
    Возврат	 Результат.СтоимостьДоставки;
 КонецФункции
 
&НаКлиенте
Процедура УстановитьВидимостьРеквизитовДоставкиДистрибуция() 
		
	КлиентДистрибуцииИлиКоммерческого = АльтерраОбщегоНазначения.КлиентДистрибуцииИлиКоммерческого(Объект.Партнер);
	ВидимостьАвтоопределениеДистрибуция = КлиентДистрибуцииИлиКоммерческого И Не Объект.РеализацияПоЗаказам;
	
    Элементы.ОбъектДоставки.Видимость    = ВидимостьАвтоопределениеДистрибуция;
    Элементы.Тариф.Видимость             = ВидимостьАвтоопределениеДистрибуция;
	Элементы.ТарифЗаКГ.Видимость         = ВидимостьАвтоопределениеДистрибуция;  
	Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Видимость = ВидимостьАвтоопределениеДистрибуция; 
	Если  Элементы.СтраницаДоставка.Видимость = Ложь Тогда
	    Элементы.СтраницаДоставка.Видимость = ВидимостьАвтоопределениеДистрибуция;   
	КонецЕсли;
	УстановитьВидимостьПоРаспределитьТранспортные();
КонецПроцедуры

&НаСервере
Процедура ИзменитьУслугуДоставки(СтоимостьДоставки)
	АльтерраОбщегоНазначения.ИзменитьУслугуДоставки(Объект, СтоимостьДоставки);	 
КонецПроцедуры

&НаСервере
Функция ОпределитьТарифДистрибуция()
	Возврат УправлениеЛогистикойСервер.ОпределитьТарифДистрибуция(Объект, Объект.ПрибытиеНаОтгрузку, Объект.Подразделение);
КонецФункции

&НаКлиенте
Процедура Док_ПартнерПриИзмененииПеред(Элемент)
    ОчиститьРеквизитыДоставкиДистрибуция();
	УстановитьВидимостьРеквизитовДоставкиДистрибуция();
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьРеквизитыДоставкиДистрибуция() 
	
	Если  Объект.РеализацияПоЗаказам Тогда  
		Возврат;
	КонецЕсли; 
	
	Объект.ОбъектДоставки = ПредопределенноеЗначение("Справочник.ОбъектыДоставки.ПустаяСсылка");
	Объект.Тариф = ПредопределенноеЗначение("Справочник.ТарифыПеревозчиков.ПустаяСсылка");
	Объект.ТарифЗаКг = 0;
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		 СнятьРаспределениеТранспортныхДистрибуция();
		 Объект.РаспределитьТранспортныеДистрибуция = Ложь;
		 УстановитьВидимостьПоРаспределитьТранспортные();
	КонецЕсли;	
КонецПроцедуры 

&НаКлиенте
Процедура УстановитьВидимостьПоРаспределитьТранспортные()  
	Элементы.ТоварыЦенаСДоставкойПечать.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Элементы.ТоварыСуммаРучнойСкидки.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Элементы.ТранспортныеИтог.Видимость = Объект.РаспределитьТранспортныеДистрибуция И НЕ Объект.РеализацияПоЗаказам; 
	Элементы.ТоварыПроцентТранспортных.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Заголовок = "Снять распределение транспортных дистрибуция";
	Иначе
		Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Заголовок = "Распределить транспортные дистрибуция";
	Конецесли;	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыЦенаПриИзмененииПосле(Элемент)
   //АвтоопределениеДистрибуция
   РаспределитьТранспортныеДистрибуцияПриИзмененииСтроки();
   //
КонецПроцедуры


&НаКлиенте
&После("ОбработкаВыбораПодборНаКлиенте")
Процедура Док_ОбработкаВыбораПодборНаКлиенте(ВыбранноеЗначение)
	Если Объект.РаспределитьТранспортныеДистрибуция И Не Объект.РеализацияПоЗаказам Тогда 
	    РаспределитьТранспортныеДистрибуция();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ОбъектДоставкиПриИзмененииПосле(Элемент)
	Результат = ОпределитьТарифДистрибуция();
	Объект.Тариф = Результат.Тариф;
	Объект.ТарифЗаКг = Результат.ТарифЗаКг;
	Если Объект.ТарифЗаКг = 0 Тогда
		Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		   СнятьРаспределениеТранспортныхДистрибуция();
		КонецЕсли;
		Сообщить("Не удалось определить тариф по выбранному объекту доставки");
	Иначе 
		Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		   РаспределитьТранспортныеДистрибуция();
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура КонтрольУслугиДоставкиПриНеполнойОтгрузке()
	Документы.РеализацияТоваровУслуг.КонтрольУслугиДоставкиПриНеполнойОтгрузке(Объект);
КонецПроцедуры 

#КонецОбласти

#Область ДинамическиеСсылки

&НаКлиенте
Процедура Док_ПринятьОплатуПоСсылкеПосле(Команда)
	
	Если Не Объект.Проведен Или ЭтаФорма.Модифицированность Тогда           
		Сообщить("Реализация должна быть проведена для оплаты по ссылке");                   
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.Кассир) Тогда           
		Сообщить("Установлена отметка кассы, оплата по ссылке не возможна");                   
		Возврат;
	КонецЕсли;
	
	СсылкаОплаты = ОткрытьАктивированнуюСсылку();   

	Если ЗначениеЗаполнено(СсылкаОплаты) Тогда
		ЗапуститьПриложение(СсылкаОплаты);
	КонецЕсли;
	
КонецПроцедуры                     

&НаСервере
Функция ОткрытьАктивированнуюСсылку()   
	
	СсылкаОплаты = ИнтеграцияБанки.ПолучитьАктивированнуюДинамическуюСсылку(Объект.Ссылка).Ответ.СсылкаОплаты;         
	
	Если Не ЗначениеЗаполнено(СсылкаОплаты) Тогда
		
		РезультатАктивации = ИнтеграцияБанки.АктивироватьДинамическуюСсылку(Объект.Ссылка, ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.КартаСБП"));	
		
		Если РезультатАктивации.Результат Тогда  
			СсылкаОплаты = РезультатАктивации.Ответ.СсылкаОплаты;
		Иначе
			Сообщить(РезультатАктивации.Сообщение);
		КонецЕсли;
	КонецЕсли;  
	
	Возврат СсылкаОплаты;
	
КонецФункции

&НаСервере
Функция	ПереактивироватьСсылкуНаОплату()
	
	Если ИнтеграцияБанки.НужнаПереактивацияДинамическойСсылки(Объект.Ссылка).Результат Тогда
		
		РезультатАктивации = ИнтеграцияБанки.АктивироватьДинамическуюСсылку(Объект.Ссылка, ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.КартаСБП"));	
		Если Не РезультатАктивации.Результат Тогда
			Сообщить(РезультатАктивации.Сообщение);
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции	

#КонецОбласти