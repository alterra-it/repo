&НаСервере
Процедура ПересчитатьСуммыСУчетомБонусов()
	Если НЕ ЗначениеЗаполнено(Объект.Кассир) Тогда
		Для каждого СтрРеализации Из Объект.Товары Цикл
			БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, стрРеализации);
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры // ПересчитатьСуммыСУчетомБонусов()

&НаКлиенте
Процедура Док_ПартнерПриИзменении(Элемент)
	
	//ПартнерПриИзменении(Неопределено);
	Объект.КартаЛояльности = АльтерраОбщегоНазначения.ПолучитьКартуЛояльности(Объект.Партнер);
	Объект.Контрагент = АльтерраОбщегоНазначения.ПолучитьЕдинственногоКонтрагента(Объект.Партнер);
	Объект.Соглашение = АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
	ПроверитьЭДО();	
	СоглашениеПриИзменении(Неопределено);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
		ОчиститьБонусыСервер();
		ПересчитатьСуммыСУчетомБонусов();
		ОчиститьСообщения();
		ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
	КонецЕсли;
	
	ОчиститьСообщения();
	АльтерраОбщегоНазначения.ПолучитьДополнительнуюИнформациюПоПартнеру(Объект.Партнер);// Вывод сообщением дополнительной информации по клиенту
	
	ПоказатьИнформациюПоБонусам();
	//Задача № 69132 Черный список
	УстановитьВидимостьЗапретаОтгрузкиПартнеру();
	Отказ = Ложь;
	АльтерраОбщегоНазначения.ЕстьПартнерСТакимТелефоном(Объект.Партнер, Отказ);
	Если Отказ Тогда
		Сообщить("Заполните у партнера его действительный номер телефона, иначе на кассе ЧЕК не пробъется!!!");
	КонецЕсли;  

	Если АльтерраОбщегоназначения.ЭтоБригадир(Объект.Партнер) Тогда
		Элементы.БонусныеБаллыСуммаБонусныхБалловЗаКП.Заголовок = "Доп. баллы";
		Элементы.ТоварыСуммаНачисленныхБалловЗаКП.Заголовок = "Доп. баллы";
	КонецЕсли;
	Если Объект.СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки.Самовывоз") Тогда
		Объект.АдресДоставки = "";
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьМенеджераДоИзменения(Объект.Ссылка) <> Объект.Менеджер Тогда 
			Объект.ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Объект.Менеджер); 
			Объект.ОтделМенеджера = ПолучитьОтделМенеджера(Объект.Менеджер);
		КонецЕсли;	
	КонецЕсли;

КонецПроцедуры 

&НаКлиенте
Процедура Док_СоглашениеПриИзменении(Элемент)
	СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	ОчиститьБонусыСервер();// Альтерра ПроектЧеки
	ПересчитатьСуммыСУчетомБонусов();
	ПоказатьИнформациюПоБонусам(); 
	ОчиститьСообщения();
	ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами); 
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		РаспределитьТранспортныеДистрибуция();
	КонецЕсли; 
	//

КонецПроцедуры 

&НаСервере
&После("СоглашениеПриИзмененииСервер")
Процедура Док_СоглашениеПриИзмененииСервер()
	
	ЗаполнитьПорядокРасчетовПоДоговору();   
	
	// Проверка на изменение цены товара по установке цен (заказ до изменения цены, реализация после)
	ПроверитьСоответствиеЦенСЗаказом();
	
КонецПроцедуры  

&НаКлиенте
Процедура Док_СоглашениеПриИзмененииПосле(Элемент)
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ПолучитьМенеджераДоИзменения(Объект.Ссылка) <> Объект.Менеджер Тогда 
			Объект.ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Объект.Менеджер); 
			Объект.ОтделМенеджера = ПолучитьОтделМенеджера(Объект.Менеджер);
		КонецЕсли;	
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПроверитьСоответствиеЦенСЗаказом()
	
	Если Не ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		Возврат;
	КонецЕсли;
	
	МассивСтрок = Новый Массив;
	Для Каждого Стр Из Объект.Товары Цикл
		МассивСтрок.Добавить(Стр.КодСтроки);
	КонецЦикла;      
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидЦены,
	|	Цена,
	|	КодСтроки,
	|	Номенклатура,
	|	Характеристика
	|ИЗ
	|	Документ.ЗаказКлиента.Товары 
	|ГДЕ
	|	Ссылка = &Ссылка
	|	И КодСтроки В(&МассивСтрок)";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.ЗаказКлиента);
	Запрос.УстановитьПараметр("МассивСтрок", МассивСтрок);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	ИзменениеЦены = Ложь;
	
	Пока Выборка.Следующий() Цикл
		Отбор = ?(НовыйПорядокНачисленияБонусов,	Новый Структура("КодСтроки", Выборка.КодСтроки),
		Новый Структура("Номенклатура, Характеристика", Выборка.Номенклатура, Выборка.Характеристика));
		
		стрРеализации = Объект.Товары.НайтиСтроки(Отбор)[0];
		
		Если Выборка.ВидЦены <> стрРеализации.ВидЦены Или Выборка.Цена <> стрРеализации.Цена Тогда
			стрРеализации.ВидЦены = Выборка.ВидЦены;
			стрРеализации.Цена = Выборка.Цена;
			БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, стрРеализации);
			ИзменениеЦены = Истина;
		КонецЕсли;         
	КонецЦикла;                    
	
	Если ИзменениеЦены Тогда	
		РассчитатьИтоговыеПоказатели(ЭтотОбъект);
	КонецЕсли;
КонецПроцедуры

