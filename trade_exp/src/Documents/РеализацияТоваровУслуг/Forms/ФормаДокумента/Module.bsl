&НаСервере
Функция РеквизитыШапки(Документ,СтруктураОшибок,СтруктураОрганизации)
	СтруктураРеквизитовШапки=Новый Структура;
	// ИНН обязательный
	ИНН=СтруктураОрганизации.ИНН+"/"+СтруктураОрганизации.КПП;
	СтруктураРеквизитовШапки.Вставить("INN_KONT",ИНН);
	если значениезаполнено(Документ.Договор) тогда
		// номер и дата договора обязательный
		СтруктураРеквизитовШапки.Вставить("NOM_DOG",Документ.Договор.Номер);
		СтруктураРеквизитовШапки.Вставить("DATE_DOG",Документ.Договор.Дата);
	иначе
		Сообщить("Не заполнен договор с клиентом!");
		СтруктураОшибок.Вставить("Договор","Не заполнен договор с клиентом!");
	конецесли;
	// номер и дата документа обязательный
	СтруктураРеквизитовШапки.Вставить("NOM_DOC",Документ.Номер);
	СтруктураРеквизитовШапки.Вставить("DATE_DOC",Документ.Дата);
	Возврат СтруктураРеквизитовШапки;
КонецФункции // РеквизитыШапки()

&НаСервере
Процедура ВыгрузитьДБФСервер(ИмяФайла,СтруктураОрганизации)
	
	УстановитьПривилегированныйРежим(истина);
	ФайлДБФ=СоздатьСтруктуруФайлаДБФ();
	ИмяТемпФайла=ПолучитьИмяВременногоФайла("dbf");
	
	ТемпФайл=Новый Файл(ИмяТемпФайла);
	
	ПутьВрФайла=ТемпФайл.Путь+лев(ТемпФайл.ИмяБезРасширения,8)+ТемпФайл.Расширение;
	
	ФайлДБФ.СоздатьФайл(ПутьВрФайла);
	СтруктураОшибок=новый Структура;
	
	РеквизитыШапки=РеквизитыШапки(Объект,СтруктураОшибок,СтруктураОрганизации);
	
	ТаблицаТоваров=Объект.Товары.Выгрузить();
	
	ТаблицаТоваров.Свернуть("Номенклатура,СтавкаНДС","КоличествоУпаковок,СуммаНДС,СуммаСНДС");
	
	НомерСтр=1;
	для каждого стр из ТаблицаТоваров цикл
		ФайлДБФ.Добавить();	
		заполнитьзначенияСвойств(ФайлДБФ,РеквизитыШапки);
		ФайлДБФ.NOM_PP=НомерСтр;
		ФайлДБФ.PROD_NAME1=стр.Номенклатура.Наименование;
		ФайлДБФ.ED_IZM="ШТ.";
		ФайлДБФ.ED_IZMOKEY="796";
		ФайлДБФ.KOL=стр.КоличествоУпаковок;
		ФайлДБФ.PRICE=окр(стр.СуммаСНДС/стр.КоличествоУпаковок,2);
		ФайлДБФ.RATE_NDS=УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(стр.СтавкаНДС);
		ФайлДБФ.SUMM_NDS=стр.СуммаНДС;
		ФайлДБФ.SUMM_TOTAL=стр.СуммаСНДС;
		ФайлДБФ.DATE_OUT=Объект.Дата+180*60*60*24;
		ФайлДБФ.Записать();
		НомерСтр=НомерСтр+1;
	конеццикла;	
	ФайлДБФ.ЗакрытьФайл();
	
	ФайлВыгрузки = Новый ДвоичныеДанные(ПутьВрФайла);
	СсылкаНаДвоичныеДанныеФайла = ПоместитьВоВременноеХранилище(ФайлВыгрузки);
	УдалитьФайлы(ПутьВрФайла);
	ИмяФайла.Вставить("АдресФайлаВыгрузки", СсылкаНаДвоичныеДанныеФайла);
	УстановитьПривилегированныйРежим(ложь);
КонецПроцедуры

