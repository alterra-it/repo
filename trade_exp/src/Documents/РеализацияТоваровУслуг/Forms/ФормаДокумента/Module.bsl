КонецПроцедуры
&НаСервере
Процедура Док_КартаЛояльностиПриИзмененииНаСервере()
	Если ЗначениеЗаполнено(Объект.КартаЛояльности) Тогда
		Объект.Партнер = Объект.КартаЛояльности.Партнер;
		Объект.Контрагент = Объект.КартаЛояльности.Контрагент;
		Если Не ЗначениеЗаполнено(Объект.Контрагент) Тогда
			Объект.Контрагент = АльтерраОбщегоНазначения.ПолучитьЕдинственногоКонтрагента(Объект.Партнер);
		КонецЕсли;
		
		Объект.Соглашение = АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
		
		СоглашениеПриИзмененииСервер();
	КонецЕсли;
	
	СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	ОчиститьБонусыСервер();// Альтерра ПроектЧеки
	ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
	АльтерраОбщегоНазначения.ПолучитьДополнительнуюИнформациюПоПартнеру(Объект.Партнер);// Вывод сообщением дополнительной информации по клиенту
	ПоказатьИнформациюПоБонусам();
	//Задача № 69132 Черный список
	УстановитьВидимостьЗапретаОтгрузкиПартнеру();
КонецПроцедуры

