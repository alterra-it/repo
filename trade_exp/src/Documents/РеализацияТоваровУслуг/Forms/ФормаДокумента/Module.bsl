&НаСервере
Функция ВернутьСтруктуруОрганизации()
	Структура=ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Объект.Организация,Объект.Дата);			
	Структура.Вставить("ДатаФайла",Объект.Дата);
	возврат Структура;
