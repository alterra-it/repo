	//СформироватьНадписьВалюты(ЭтаФорма);
	//ОбновитьСостояниеЭлементовУправленияИтоговПоРасчетам();
	//ОчиститьЭтапыГрафикаОплаты();
КонецПроцедуры

&НаСервере
Процедура ПересчитатьБонусыВСтрокеНаСервере(МассивСтрок)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ТоварыКОтгрузкеОстатки.КОтгрузкеОстаток), 0) КАК Остаток
	|ПОМЕСТИТЬ ВТ_Остаток
	|ИЗ
	|	РегистрНакопления.ТоварыКОтгрузке.Остатки(, ДокументОтгрузки = &Ссылка) КАК ТоварыКОтгрузкеОстатки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.СуммаНачисленныхБонусныхБалловВВалюте КАК НачисленоВсего,
	|	ЗаказКлиентаТовары.СуммаБонусныхБалловКСписаниюВВалюте КАК КСписанию,
	|	ЗаказКлиентаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ЗаказКлиентаТовары.СуммаНачисленныхБалловЗаСтатус КАК НачисленоЗаСтатус,
	|	ВЫБОР
	|		КОГДА ВТ_Остаток.Остаток = 0
	|			ТОГДА ЗаказКлиентаТовары.СуммаНачисленныхБалловЗаКП
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК НачисленоЗаКП,
	|	ЗаказКлиентаТовары.СуммаНачисленныхБалловПрочее КАК НачисленоПрочее,
	|	ЗаказКлиентаТовары.КодСтроки КАК КодСтроки,
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Характеристика КАК Характеристика
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары,
	|	ВТ_Остаток КАК ВТ_Остаток
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка = &Ссылка
	|	И ЗаказКлиентаТовары.КодСтроки В(&МассивСтрок)";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.ЗаказКлиента);
	Запрос.УстановитьПараметр("МассивСтрок", МассивСтрок);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Выборка.НачисленоВсего > 0 Или Выборка.КСписанию > 0 Тогда
			
			Отбор = ?(НовыйПорядокНачисленияБонусов, Новый Структура("КодСтроки", Выборка.КодСтроки),
			Новый Структура("Номенклатура, Характеристика", Выборка.Номенклатура, Выборка.Характеристика));
			
			стрРеализации = Объект.Товары.НайтиСтроки(Отбор)[0];
			стрРеализации.КоличествоУпаковок = Мин(стрРеализации.КоличествоУпаковок, Выборка.КоличествоУпаковок);
			стрРеализации.Количество = стрРеализации.КоличествоУпаковок;
			
			стрРеализации.СуммаБонусныхБалловКСписаниюВВалюте = (Выборка.КСписанию*стрРеализации.КоличествоУпаковок)/Выборка.КоличествоУпаковок;
			стрРеализации.СуммаБонусныхБалловКСписанию = стрРеализации.СуммаБонусныхБалловКСписаниюВВалюте;
			
			стрРеализации.СуммаНачисленныхБалловЗаКП = (Выборка.НачисленоЗаКП*стрРеализации.КоличествоУпаковок)/Выборка.КоличествоУпаковок;
			стрРеализации.СуммаНачисленныхБалловПрочее = (Выборка.НачисленоПрочее*стрРеализации.КоличествоУпаковок)/Выборка.КоличествоУпаковок;
			стрРеализации.СуммаНачисленныхБалловЗаСтатус = (Выборка.НачисленоЗаСтатус*стрРеализации.КоличествоУпаковок)/Выборка.КоличествоУпаковок;
			
			Если НовыйПорядокНачисленияБонусов Тогда
				стрРеализации.СуммаНачисленныхБонусныхБалловВВалюте = стрРеализации.СуммаНачисленныхБалловПрочее
				+ стрРеализации.СуммаНачисленныхБалловЗаКП
				+ стрРеализации.СуммаНачисленныхБалловЗаСтатус;
			Иначе
				стрРеализации.СуммаНачисленныхБонусныхБалловВВалюте = (Выборка.НачисленоВсего*стрРеализации.КоличествоУпаковок)/Выборка.КоличествоУпаковок;
			КонецЕсли;
			
			
			БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, стрРеализации);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область БонусыКоманды
//Оплата
&НаКлиенте
Процедура ОплатитьБонуснымиБаллами(Команда)
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		Сообщить("Установить оплату бонусными баллами возможно только в документе заказа.");
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Или Не Объект.Проведен Тогда
		Ответ = Неопределено;
		ПоказатьВопрос(Новый ОписаниеОповещения("ОткрытьФормуОплатыБаламиЗавершение", ЭтотОбъект),
		НСтр("ru = 'Неоходимо провести документ для выполнения операции. Провести документ?'"), РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	
	
	Если ПроверитьВозможностьОплаты() Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуОплатыБаламиФрагмент();
	
КонецПроцедуры
&НаКлиенте
Процедура ОткрытьФормуОплатыБаламиЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	ИначеЕсли Не Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение)) Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуОплатыБаламиФрагмент();
	
КонецПроцедуры
&НаКлиенте
Процедура ОткрытьФормуОплатыБаламиФрагмент()
	
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Партнер",                   Объект.Партнер);
	ПараметрыОткрытияФормы.Вставить("КартаЛояльности",           Объект.КартаЛояльности);
	ПараметрыОткрытияФормы.Вставить("АдресТабличнойЧастиТовары", АдресТабличнойЧастиТовары());
	ПараметрыОткрытияФормы.Вставить("Валюта",                    Объект.Валюта);
	
	ОткрытьФорму(
	"Справочник.БонусныеПрограммыЛояльности.Форма.ОплатаБонуснымиБаллами",
	ПараметрыОткрытияФормы,
	ЭтотОбъект,,,,
	Новый ОписаниеОповещения("ДобавитьОплатуБонуснымиБалламиЗавершение", ЭтотОбъект));
	
КонецПроцедуры

&НаСервере
Процедура ОплатитьБонуснымиБалламиНаСервере(АдресВоВременномХранилище=Неопределено)
	
	БонусыАльтерраРезерв.ПересчитатьБонусныеБаллыВТоваре(Объект, АдресВоВременномХранилище);
	
