	Иначе
		Объект.ПорядокРасчетов = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ПорядокРасчетов");
	КонецЕсли;
	ПорядокРасчетов = Объект.ПорядокРасчетов;
	СоглашениеПриИзмененииСервер();
	если Объект.РеализацияПоЗаказам и ЗначениеЗаполнено(Объект.ЗаказКлиента) тогда
		ОбъектСкидок = Объект.ЗаказКлиента;
	иначе
		ОбъектСкидок = Объект;
	конецесли;	
	РассчитатьСкидкиНаценкиКлиент();	
	Элементы.ТекстДокументыНаОснованииПодвалРасш.Доступность = Объект.ПорядокРасчетов = ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоДоговорамКонтрагентов");
	
	ОчиститьБонусыСервер(); 
	
КонецПроцедуры
&НаСервере
Процедура Док_ЗаполнитьШапкуПоЗаказуНаСервере()
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		
		Отказ= Ложь;
		Если АльтерраОбщегоНазначения.ЕстьЗеленение(Объект) > 0 Тогда
			Сообщить("В документе есть зелененные строки!");
			Отказ= Истина;
		КонецЕсли;
		Если ЗначениеЗаполнено(Объект.Кассир) Тогда
			Сообщить("В документе стоит отметка кассы!");
			Отказ= Истина;
		КонецЕсли;
		
		Если Не Отказ Тогда
			//ЗаполнитьЗначенияСвойств(Объект,Объект.ЗаказКлиента);
			Объект.Партнер= Объект.ЗаказКлиента.Партнер;
			Объект.Контрагент=  Объект.ЗаказКлиента.Контрагент;
			Объект.Соглашение=  Объект.ЗаказКлиента.Соглашение;
			Объект.Договор=  Объект.ЗаказКлиента.Договор;
			Объект.Склад=  Объект.ЗаказКлиента.Склад;
			Объект.Подразделение= Объект.ЗаказКлиента.Подразделение;
			//Светлакова
			Если Объект.Организация <> Объект.ЗаказКлиента.Организация Тогда
				Объект.Организация =  Объект.ЗаказКлиента.Организация;	
				ОрганизацияПриИзмененииСервер();
			КонецЕсли; 
			Объект.ИспользуетсяДоговор=  Объект.ЗаказКлиента.ИспользуетсяДоговор;
			//Харина
			_ТоварПодЗаказ = Объект.ЗаказКлиента.ТоварПодЗаказ;
			
			Для Каждого стрТовар Из Объект.Товары Цикл
				стрТовар.Склад=  Объект.Склад;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

