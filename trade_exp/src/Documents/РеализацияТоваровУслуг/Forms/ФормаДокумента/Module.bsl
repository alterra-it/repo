&НаСервере
Процедура Док_ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Документы.РеализацияТоваровУслуг.ПроверкаКорректностиПримененияСкидокВЗаказе(Объект.Ссылка, Объект.ЗаказКлиента, Отказ);
	
	Если ПустаяСтрока(Объект.Номер) И Не ЗначениеЗаполнено(Объект.Дата) И Не ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		АльтерраОбщегоНазначения.ЗаполнитьРеквизитыПродажи(Объект);
	КонецЕсли;
	Элементы.ОплатаДоставкиКартой.Видимость = Ложь;
	ЭтаФорма.Элементы.ОтметкаКассы.Видимость = РольДоступна("ПолныеПрава") или РольДоступна("ОтметкаКассы");
	ЭтаФорма.Элементы.ТоварыСброситьПоСекции.Видимость=рольДоступна("ПолныеПрава") или рольДоступна("СнятьЗеленение");
	
	Элементы._ЗаполнитьШапкуПоЗаказу.Видимость= Ложь;
	Элементы._ЗаполнитьНарезкуПоЗаказу.Видимость = Ложь;
	
	Элементы.ТекстДокументыНаОснованииПодвалРасш.Доступность=Объект.ПорядокРасчетов=ПредопределенноеЗначение("Перечисление.ПорядокРасчетов.ПоДоговорамКонтрагентов");
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
		_ТоварПодЗаказ = Объект.ЗаказКлиента.ТоварПодЗаказ;
	КонецЕсли;
	
	НовыйПорядокНачисленияБонусов = БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Объект);
	Если НовыйПорядокНачисленияБонусов Тогда
		ЗаполнитьБонусыПоЗаказу();
	КонецЕсли;
	
	// договор на форме	
	элементы.ИспользуетсяДоговор.Доступность = Не Объект.РеализацияПоЗаказам;
	Элементы._НаценкаКарта.Доступность = Не Объект.РеализацияПоЗаказам;
	Элементы.Товары_ВыгрузитьВДБФ.Видимость = Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПередачаНаКомиссию");
	_НаценкаКарта=найтиСкидку("Наценка на оплату картой",Объект);		
	
	ПоказатьИнформациюПоБонусам();
	
	// Альтерра Островская П.А. № 88786 Сделать доступным поле "Пробить чек" {+
	Элементы.ГруппаСчетФактураИСостояние.ГоризонтальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Нет;
	//Островская }+
	
	Элементы.ИсключитьИзКонтроля.Доступность = РольДоступна("РазрешитьИсключатьДокументыИзКонтроляОрдерногоУчета");
	
	Если Объект.Ссылка.Пустая() Тогда
		ДопМодуль.СохранитьПроцентРучнойСкидки(Объект.Товары);
	КонецЕсли;
	Элементы.КонтрагентРаботаетВЭДО.Видимость=ДопМодуль.КонтрагентРаботаетВЭдо(Объект.Контрагент);	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Товары_ДобавитьУслугуБезНДС", "Видимость", НЕ АльтерраОбщегоНазначения.ЕстьБлокировкаУслуги(текущаяДата()));
	
	Элементы.ПринятьОплатуПоСсылке.Видимость = Не ЗначениеЗаполнено(Объект.Кассир);
	
КонецПроцедуры


&НаСервере
Процедура Док_ПриЧтенииНаСервереПосле(ТекущийОбъект)
	УстановитьВидимостьДоступностьДополнительно();
	ДопМодуль.СохранитьПроцентРучнойСкидки(Объект.Товары);
КонецПроцедуры


&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если ЗначениеЗаполнено(Объект.ЗаказКлиента) Тогда
			Объект.ВариантВыбытияМаркируемойПродукции = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ЗаказКлиента, "ВариантВыбытияМаркируемойПродукции");
		КонецЕсли;
	конецесли;	
	
	УстановитьДоступностьПоОтметкеКассы();
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Форма_Провести", "Доступность", РольДоступна("ОтделАналитики"));
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	Если Объект.Кассир.Пустая() Тогда // проверка отметки кассы
		Объект.ДатаПоследнегоОткрытия = ТекущаяДатаСеанса();
	КонецЕсли;	
	Элементы.ТоварыВидЦены.БыстрыйВыбор = Истина;
	УведомленияПодрядчику_ИнициализацияЗначений(); 
	ОбновитьПараметрыВыбораЦен();
	
	УстановитьВидимостьДоступностьДополнительно();  
	
	НовыйЭлемент = Элементы.Вставить("Обособленно", Тип("ПолеФормы"), Элементы.Товары,Элементы.ТоварыКоличествоУпаковок);
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеФлажка;                                                                           
	НовыйЭлемент.ШиринаЭлемента = 10;
	НовыйЭлемент.ПутьКДанным = "Объект.Товары.Обособленно"; 
	НовыйЭлемент.ТолькоПросмотр = Истина;    
	
	ЗаполнитьКолонкуОбособленно();
КонецПроцедуры  

&НаСервере
Процедура ЗаполнитьКолонкуОбособленно()     
	Если Объект.Товары.Количество() > 0 Тогда 
		ТаблицаТоваров = Новый ТаблицаЗначений;
		ТаблицаТоваров.Колонки.Добавить("Заказ", Новый ОписаниеТипов("ДокументСсылка.ЗаказКлиента"));    
		ТаблицаТоваров.Колонки.Добавить("КодСтроки", Новый ОписаниеТипов("Число"));
		Для Каждого ТекущаяСтрока Из Объект.Товары Цикл  
			Если ЗначениеЗаполнено(ТекущаяСтрока.ЗаказКлиента) Тогда
				НовыйТовар = ТаблицаТоваров.Добавить();
				НовыйТовар.Заказ = ТекущаяСтрока.ЗаказКлиента; 
				НовыйТовар.КодСтроки = ТекущаяСтрока.КодСтроки;
			КонецЕсли;
		КонецЦикла;      
		
		Если ТаблицаТоваров.Количество() > 0 Тогда
			
			Запрос = Новый Запрос;  
			Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
			Запрос.Текст = "ВЫБРАТЬ * ПОМЕСТИТЬ ТЗ ИЗ &ТЗ КАК ТЗ";
			Запрос.УстановитьПараметр("ТЗ", ТаблицаТоваров);
			Запрос.Выполнить();
			
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ТЗ.КодСтроки КАК КодСтроки,
			|	ТЗ.Заказ КАК Заказ,
			|	ЕСТЬNULL(ЗаказКлиентаТовары.Обособленно, ЛОЖЬ) КАК Обособленно
			|ИЗ
			|	ТЗ КАК ТЗ
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
			|		ПО ТЗ.Заказ = ЗаказКлиентаТовары.Ссылка
			|			И ТЗ.КодСтроки = ЗаказКлиентаТовары.КодСтроки";
			
			РезультатЗапроса = Запрос.Выполнить();  
			Выборка = РезультатЗапроса.Выбрать();
			
			Пока Выборка.Следующий() Цикл 
				Отбор = Новый Структура();
				Отбор.Вставить("КодСтроки", Выборка.КодСтроки);
				Отбор.Вставить("ЗаказКлиента", Выборка.Заказ);
				НайденноеЗначение = Объект.Товары.НайтиСтроки(Отбор);
				
				Если НайденноеЗначение.Количество() > 0 Тогда
					Для каждого ТекущаяСтрока Из НайденноеЗначение Цикл
						ТекущаяСтрока.Обособленно = Выборка.Обособленно; 
					КонецЦикла;
				КонецЕсли;	
			КонецЦикла;	    
			
		КонецЕсли;
	КонецЕсли;	
КонецПроцедуры	


&НаКлиенте
Процедура Док_ПриОткрытии(Отказ)
	// Альтерра ПроектЧеки
	ЗапретВидимостиБонусов();
	Элементы.ДатаСоздания.ТолькоПросмотр = Истина;
	УстановитьУсловноеОформлениеПолей();
	
	ЕстьРольОтметкаКассы = ПроверитьРоль();
	Если ЕстьРольОтметкаКассы = Ложь Тогда 
		Элементы.ГруппаСоздатьНаОснованииПКОИЭквайринговаяОперация.Видимость = ложь;
	КонецЕсли;  
	
	Если АльтерраОбщегоназначения.ЭтоБригадир(Объект.Партнер) Тогда
		Элементы.БонусныеБаллыСуммаБонусныхБалловЗаКП.Заголовок = "Доп. баллы";
		Элементы.ТоварыСуммаНачисленныхБалловЗаКП.Заголовок = "Доп. баллы";
	КонецЕсли;
	
	Если Элементы.Найти("ПодобратьИПроверитьПродукциюГосИС")<> Неопределено Тогда   
		Для Каждого Элемент из Элементы.ПодобратьИПроверитьПродукциюГосИС.ПодчиненныеЭлементы Цикл  
			Элемент.Доступность = Истина;
		КонецЦикла;
	КонецЕсли;
	
	НомерТелефонаПартнера = ПолучитьНомерТелефонаПартнера();
	
КонецПроцедуры                                                  


&НаСервере
Процедура УстановитьВидимостьДоступностьДополнительно()
	
	Если Не (АльтерраОбщегоНазначения.ЭтоБригадир(Объект.Партнер)
		Или АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Объект.Партнер))
		Тогда
		Элементы.НачисленныеБаллы.Видимость = Ложь;
		Элементы.ТоварыСуммаБонусныхБалловКСписаниюВВалюте.Видимость = Ложь;
	Иначе
		Элементы.НачисленныеБаллы.Видимость = Истина;
		Элементы.ТоварыСуммаБонусныхБалловКСписаниюВВалюте.Видимость = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Кассир) И Объект.СтатусДокументаВЭДО <> Перечисления.СтатусыДокументаЭДО.Выгружен И Объект.СтатусДокументаВЭДО <> Перечисления.СтатусыДокументаЭДО.Подписан тогда
		Если НЕ(Элементы.Найти("ПодобратьИПроверитьПродукциюГосИС0_") = Неопределено) Тогда
			ЭлементыГруппыГИСМ = Элементы.ПодобратьИПроверитьПродукциюГосИС0_.ПодчиненныеЭлементы;
			Для Каждого Элемент из ЭлементыГруппыГИСМ Цикл
				Если ТипЗнч(Элемент) = Тип("КнопкаФормы") Тогда
				  Элемент.Доступность = Истина;
				КонецЕсли	
			КонецЦикла	
		КонецЕсли
	КонецЕсли;
	Если Не Элементы.Найти("СоответствиеТребованиямГИСМТГосИС") = Неопределено Тогда 
		Элементы.СоответствиеТребованиямГИСМТГосИС.Доступность = Истина
	КонецЕсли
КонецПроцедуры

&НаСервере
Функция ПроверитьРоль()
	Возврат РольДоступна("ОтметкаКассы");	
КонецФункции

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)
	УведомленияПодрядчику_ИнициализацияЗначений(); 
	//АвтоопределениеДистрибуция
	УстановитьВидимостьРеквизитовДоставкиДистрибуция();
	Если Объект.РаспределитьТранспортныеДистрибуция И НЕ Объект.РеализацияПоЗаказам Тогда
	   ТранспортныеИтог = АльтерраОбщегоНазначенияКлиент.ПолучитьТранспортныеИтог(Объект);
   КонецЕсли; 
   //
КонецПроцедуры 

&НаСервере
Процедура УстановитьУсловноеОформлениеПолей()
	
	Если ЗначениеЗаполнено(Объект.ЗаказКлиента)	Тогда
		
		ИменаПолей = Новый Массив;
		ИменаПолей.Добавить("ТоварыВидЦены");
		ИменаПолей.Добавить("ТоварыПроцентРучнойСкидки");
		ИменаПолей.Добавить("ТоварыСуммаРучнойСкидки");
		ИменаПолей.Добавить("ТоварыСумма");
		ИменаПолей.Добавить("ТоварыСуммаНДС");
		
		Для каждого ИмяПоля Из ИменаПолей Цикл
			Элемент = УсловноеОформление.Элементы.Добавить();
			
			ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
			ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
			
			ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
			ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли; 
			
			ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.СуммаБонусныхБалловКСписаниюВВалюте");
			ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно;
			ОтборЭлемента.ПравоеЗначение = 0;
			
			ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.СуммаНачисленныхБонусныхБалловВВалюте");
			ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно;
			ОтборЭлемента.ПравоеЗначение = 0;
			
			Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
			//Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
			
		КонецЦикла;
		
		Элементы.ТоварыОткрытьПодбор.Доступность = Ложь;
		Элементы.ТоварыРассчитатьСкидкиНаценки.Доступность = Ложь;
		Элементы.ТоварыНазначитьАвтоматическиеСкидки.Доступность = Ложь;
		Элементы.ТоварыЗаполнитьЦеныПоСоглашению.Доступность = Ложь;
		Элементы.ТоварыЗаполнитьЦеныВыделенныхСтрокПоВидуЦен.Доступность = Ложь;
		Элементы.ТоварыНазначитьРучнуюСкидку.Доступность = Ложь;
		Элементы.ТоварыНазначитьРучнуюСкидкуВыделенныхСтрок.Доступность = Ложь;
		Элементы.ТоварыОтменитьРучныеСкидки.Доступность = Ложь;
		
	КонецЕсли;
	
	ИменаПолей = Новый Массив;
	ИменаПолей.Добавить("ТоварыСуммаБонусныхБалловКСписанию");
	ИменаПолей.Добавить("ТоварыСуммаБонусныхБалловКСписаниюВВалюте");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБонусныхБалловВВалюте");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБалловЗаСтатус");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБалловЗаКП");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБалловПрочее");
	
	Для каждого ИмяПоля Из ИменаПолей Цикл
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли; 
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.СуммаРучнойСкидки");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
		ОтборЭлемента.ПравоеЗначение = 0;
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.ВидЦены");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ОтборЭлемента.ПравоеЗначение = Справочники.ВидыЦен.ПустаяСсылка();
		
		Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоРозовый);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция НайтиСкидку(имяскидки,ОбъектСкидок)
	Скидка=Справочники.СкидкиНаценки.НайтиПоНаименованию(ИмяСкидки);
	если ОбъектСкидок.СкидкиНаценки.Выгрузить().ВыгрузитьКолонку("СкидкаНаценка").Найти(Скидка)<>Неопределено тогда
		УправляемыеСкидки.Добавить(Скидка);
		результат=истина;
	иначе
		результат=ложь;	
	конецесли;
	Возврат результат;	
КонецФункции // НайтиСкидку()

&НаСервере
Процедура Док_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ДопМодуль.ПроверитьВозможностьРучныхСкидкок(Отказ, Объект.Товары, Объект.Соглашение);
	
	Если ТекущийОбъект.Ссылка.СуммаДокумента <> ТекущийОбъект.СуммаДокумента Тогда
		Документы.ЗаданиеНаПеревозкуРейс.СнятьСогласование(ТекущийОбъект.Ссылка);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущийОбъект.Ссылка.Кассир) Тогда
		Если НовыйПорядокНачисленияБонусов И ЗначениеЗаполнено(ТекущийОбъект.ЗаказКлиента) Тогда
			ЗаполнитьБонусыПоЗаказу();
		Иначе
			БонусыАльтерраРезерв.НачислитьБонусныеБаллы(ТекущийОбъект);
		КонецЕсли;
	КонецЕсли;
	
	Если ТекущийОбъект.ИспользуетсяДоговор И ЗначениеЗаполнено(ТекущийОбъект.Договор) Тогда
		ПорядокРасчетовДоговор = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ПорядокРасчетов");
		Если ТекущийОбъект.ПорядокРасчетов <> ПорядокРасчетовДоговор Тогда
			ТекущийОбъект.ПорядокРасчетов = ПорядокРасчетовДоговор;  
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)  
	
	ЗаполнитьКолонкуОбособленно();
	ДопМодуль.СохранитьПроцентРучнойСкидки(Объект.Товары); 
	
	Если Объект.Проведен И Не ЗначениеЗаполнено(Объект.Кассир) Тогда
		ПереактивироватьСсылкуНаОплату();
	КонецЕсли;
	
КонецПроцедуры

