#Область СобытияФормы
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Данные= ПолучитьИзВременногоХранилища(Параметры.АдресВХранилище);
	
	Нарезка.Загрузить(Данные.Нарезка);

	Данные.Товары.Свернуть("Номенклатура,Характеристика", "Количество");
	Товары.Загрузить(Данные.Товары);
			
	Если Нарезка.Количество() = 0 Тогда
		ЗаполнитьНарезку();
	КонецЕсли;
	
	ЗаполнитьНарезкуПоставщика();
	УстановитьВидимостьТаблицыНарезкаОтПоставщика();
		
КонецПроцедуры

&НаКлиенте
Процедура Ок(Команда)
	
	СФП_МаркерыКлиент.МаркерНачало("Нарезка перенос в документ (из формы)");
	
	Отказ= Ложь;
	
	ПроверитьКоличество(Отказ);
	ПроверитьОтрезкиИДлинну(Отказ);
	
	Если Не Отказ Тогда
		ДополнитьТаблицуНарезкойОтПоставщика();
		Закрыть(ПоместитьВоВременноеХранилищеНарезку());
	КонецЕсли;
	
КонецПроцедуры
&НаСервере
Функция ПоместитьВоВременноеХранилищеНарезку()
	АдресВхр= ПоместитьВоВременноеХранилище(Нарезка.Выгрузить());
	
	Возврат АдресВхр;
КонецФункции
&НаКлиенте
Процедура Отмена(Команда)
	Закрыть(Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура Перезаполнить(Команда)
	ЗаполнитьНарезку();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНарезку()
	Нарезка.Очистить();
	Для Каждого стрТовар Из Товары Цикл
		Если ЗначениеЗаполнено(стрТовар.Номенклатура.УслугаРезки) Тогда
			НоваяСтрока= Нарезка.Добавить();
			НоваяСтрока.Номенклатура= стрТовар.Номенклатура;
			НоваяСтрока.Характеристика= стрТовар.Характеристика;
			
			Если ЗначениеЗаполнено(стрТовар.Характеристика) Тогда
				НоваяСтрока.Количество= 1;
				НоваяСтрока.Длина= Цел(стрТовар.Количество*10)/10;
			Иначе
				НоваяСтрока.Количество= стрТовар.Количество;
				Если НоваяСтрока.Номенклатура.ДлинаИспользовать Тогда
					НоваяСтрока.Длина= НоваяСтрока.Номенклатура.ДлинаЧислитель/НоваяСтрока.Номенклатура.ДлинаЗнаменатель;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Процедура ЗаполнитьНарезкуПоставщика()
	
	МассивСтрок = Нарезка.НайтиСтроки(Новый Структура("НарезкаОтПоставщика",Истина));
	Для каждого Строка из МассивСтрок Цикл
		НоваяСтрока = НарезкаПоставщика.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
		Нарезка.Удалить(Строка);
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ДополнитьНовыми(Команда)
	Сообщить("Необходимо следить за соответствием нарезки заказу");
	ДобавитьВНарезку();
КонецПроцедуры

&НаСервере
Процедура ДобавитьВНарезку()
	
	Для Каждого стрТовар Из Товары Цикл
		
		Если ЗначениеЗаполнено(стрТовар.Номенклатура.УслугаРезки) Тогда
			
			ПараметрыОтбора = Новый Структура;
			ПараметрыОтбора.Вставить("Номенклатура", стрТовар.Номенклатура);
			ПараметрыОтбора.Вставить("Характеристика", стрТовар.Характеристика);
			НайденныеСтроки = Нарезка.НайтиСтроки(ПараметрыОтбора); 		
			
			Если НайденныеСтроки.Количество() = 0 Тогда
			
				НоваяСтрока= Нарезка.Добавить();
				НоваяСтрока.Номенклатура= стрТовар.Номенклатура;
				НоваяСтрока.Характеристика= стрТовар.Характеристика;
				
				Если ЗначениеЗаполнено(стрТовар.Характеристика) Тогда
					НоваяСтрока.Количество= 1;
					НоваяСтрока.Длина= Цел(стрТовар.Количество*10)/10;
				Иначе
					НоваяСтрока.Количество= стрТовар.Количество;
					Если НоваяСтрока.Номенклатура.ДлинаИспользовать Тогда
						НоваяСтрока.Длина= НоваяСтрока.Номенклатура.ДлинаЧислитель/НоваяСтрока.Номенклатура.ДлинаЗнаменатель;
					КонецЕсли;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СобытияНарезки
&НаКлиенте
Процедура Скопировать(Команда)
		ТекущаяСтрока= Элементы.Нарезка.ТекущиеДанные;
		ИндексСтроки = Элементы.Нарезка.ТекущаяСтрока;
		
	Если (ТекущаяСтрока.Количество-1) > 0 Тогда
		//НоваяСтрока= Нарезка.Вставить(ИндексСтроки+1);
		НоваяСтрока= Нарезка.Добавить();
		НоваяСтрока.Номенклатура= ТекущаяСтрока.Номенклатура;
		НоваяСтрока.Количество= 1;
		НоваяСтрока.Длина= ТекущаяСтрока.Длина;
		
		ТекущаяСтрока.Количество= ТекущаяСтрока.Количество-1;	
	КонецЕсли;
КонецПроцедуры

