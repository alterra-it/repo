//ВСПОМОГАТЕЛЬНЫЕ
&НаКлиенте
Процедура УстановитьСледующийОтрезок(ТекИнд)
	ТекущаяСтрока= Элементы.Нарезка.ТекущиеДанные;
	Длина= ТекущаяСтрока.Длина;
	
	ОкруглитьОтрезок(ТекИнд);
	
	Для Инд=1 По ТекИнд Цикл
		Длина= Длина-ТекущаяСтрока["Отрезок"+Инд];
	КонецЦикла;
	
	Если Длина >= 0 Тогда
		ТекущаяСтрока["Отрезок"+(ТекИнд+1)]= Длина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ОбнулитьСтроку(ТекущаяСтрока, НачИндекс=1)
	Для Инд=НачИндекс По 5 Цикл
		ТекущаяСтрока["Отрезок"+Инд]= 0;
		Если Инд > 1 Тогда
			Элементы["НарезкаОтрезок"+Инд].ТолькоПросмотр= ТекущаяСтрока.Равные;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОкруглитьОтрезок(ТекИнд)
	ТекущаяСтрока= Элементы.Нарезка.ТекущиеДанные;
	Остаток10 = ТекущаяСтрока["Отрезок"+(ТекИнд)] % 0.1; 
	Если Остаток10 <> 0 и Остаток10 <> 0.05 Тогда
		Если Остаток10 < 0.05 Тогда
			ТекущаяСтрока["Отрезок"+(ТекИнд)] = ТекущаяСтрока["Отрезок"+(ТекИнд)] - Остаток10 + 0.05;
		Иначе
			ТекущаяСтрока["Отрезок"+(ТекИнд)] = ТекущаяСтрока["Отрезок"+(ТекИнд)] - Остаток10 + 0.1; 
		КонецЕсли;
		ТекстПредупрежения = "Регламент оборудования требует кратность 0,05 м. Отрезок" + Строка(ТекИнд) +" увеличен до "+ Строка(ТекущаяСтрока["Отрезок"+(ТекИнд)])+" м";
		ПоказатьПредупреждение(,ТекстПредупрежения,,"Внимание");
	КонецЕсли; 
КонецПроцедуры

#КонецОбласти

#Область Проверки
&НаСервере
Процедура ПроверитьКоличество(Отказ)
	ТЗНарезка= Нарезка.Выгрузить().Скопировать();
	ТЗНарезка.Свернуть("Номенклатура, Характеристика", "Количество, Длина, НарезкаОтПоставщика");
	
	ТЗТовары= Товары.Выгрузить().Скопировать();
	
	Для Каждого стрНарезка ИЗ ТЗНарезка Цикл
		Если стрНарезка.НарезкаОтПоставщика Тогда
			Продолжить;
		КонецЕсли;
		Отбор= Новый Структура("Номенклатура, Характеристика", стрНарезка.Номенклатура, стрНарезка.Характеристика, );
		НайденыеСтроки= ТЗТовары.НайтиСтроки(Отбор);
		Если НайденыеСтроки.Количество() > 0 Тогда
			НайденаяСтрока= НайденыеСтроки[0];
			Если Не ЗначениеЗаполнено(стрНарезка.Характеристика) И НайденаяСтрока.Количество < стрНарезка.Количество Тогда
				Сообщить("Количество по номенклатуре """+стрНарезка.Номенклатура+""" не совпадает");
				Отказ= Истина;
			КонецЕсли;
			Если ЗначениеЗаполнено(стрНарезка.Характеристика) И Цел(НайденаяСтрока.Количество*10)/10 <> стрНарезка.Длина Тогда
				Сообщить("Длина по номенклатуре """+стрНарезка.Номенклатура+""" не совпадает");
				Отказ= Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПроверитьОтрезкиИДлинну(Отказ)
	Для Каждого стрНарезка ИЗ Нарезка Цикл
		Если стрНарезка.НарезкаОтПоставщика Тогда
			Продолжить;
		КонецЕсли;
		ДлинаОтрезков= ПолучитьКоличествоОтрезков(стрНарезка,отказ);
		Если ДлинаОтрезков <> стрНарезка.Длина Тогда 
			Сообщить("Длина отрезков по номенклатуре """+стрНарезка.Номенклатура+""" не совпадает с длиной товара");
			Отказ= Истина;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры
Функция ПолучитьКоличествоОтрезков(стрНарезка,отказ)
	ДлинаОтрезков= 0;
	Для Инд=1 По 5 Цикл
		Если стрНарезка["Отрезок"+Инд] > 0 Тогда
			ДлинаОтрезков= ДлинаОтрезков+стрНарезка["Отрезок"+Инд];
			если стрНарезка["Отрезок"+Инд]<0.5 тогда
				Сообщить("Длина отрезка - Отрезок"+Инд+ " по номенклатуре """+стрНарезка.Номенклатура+" меньше 0.5"+стрНарезка.Номенклатура.ДлинаЕдиницаИзмерения+", измените нарезку.");
				Отказ= Истина;
			конецесли;	
		КонецЕсли;
	КонецЦикла;
	
	Возврат ДлинаОтрезков;
КонецФункции

&НаКлиенте
Процедура ДобавитьНарезкуОтПоставщика(Команда)
	УстановитьВидимостьГруппПриВыбореНоменклатурыПоставщика(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ТоварыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)	
	
	ДобавитьСтроку(ВыбраннаяСтрока);
	
	УстановитьВидимостьГруппПриВыбореНоменклатурыПоставщика(Истина);
	УстановитьВидимостьТаблицыНарезкаОтПоставщика();
	
КонецПроцедуры
&НаСервере
Процедура ДобавитьСтроку(МассивВыбранныхСтрок) 
	
	Для каждого ЭлементМассива из МассивВыбранныхСтрок Цикл
		
		ВыбраннаяСтрока = Товары[ЭлементМассива];
		Номенклатура = ВыбраннаяСтрока.Номенклатура;
		
		НоваяСтрока= НарезкаПоставщика.Добавить();
		НоваяСтрока.Номенклатура= Номенклатура;
		НоваяСтрока.Характеристика= ВыбраннаяСтрока.Характеристика;
		НоваяСтрока.Количество= ВыбраннаяСтрока.Количество;
		НоваяСтрока.НарезкаОтПоставщика = Истина;
				
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьВидимостьТаблицыНарезкаОтПоставщика()
		
	Элементы.НарезкаПоставщика.Видимость = НарезкаПоставщика.Количество()>0;
	
КонецПроцедуры

Процедура УстановитьВидимостьГруппПриВыбореНоменклатурыПоставщика(Видимость)
	Элементы.Товары.Видимость= Не Видимость;
	Элементы.Нарезка.Видимость=Видимость;
	Элементы.НарезкаПоставщика.Видимость=Видимость;
	Элементы.ГруппаОк.Видимость=Видимость;
КонецПроцедуры

&НаКлиенте
Процедура НарезкаПоставщикаПослеУдаления(Элемент)
	УстановитьВидимостьТаблицыНарезкаОтПоставщика();
КонецПроцедуры

Процедура ДополнитьТаблицуНарезкойОтПоставщика()
	
	Для каждого Строка из НарезкаПоставщика Цикл
		НоваяСтрока = Нарезка.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура НарезкаПоставщикаПриИзменении(Элемент)
	
