&НаКлиенте
Процедура НарезкаОтрезок1ПриИзменении(Элемент)
	ТекущаяСтрока= Элементы.Нарезка.ТекущиеДанные;
	
	Длина= ТекущаяСтрока.Длина;
	
	ОкруглитьОтрезок(1); 
	
	Отрезок1= ТекущаяСтрока.Отрезок1;
	
	ОбнулитьСтроку(ТекущаяСтрока, 2);
		
	Если ТекущаяСтрока.Равные Тогда
		Для Инд=2 По 5 Цикл
			Длина= Длина-Отрезок1;
			Если Длина <= Отрезок1 Тогда
				ТекущаяСтрока["Отрезок"+Инд]= Длина;
				Прервать;
			КонецЕсли;
			
			ТекущаяСтрока["Отрезок"+Инд]= Отрезок1;
		КонецЦикла;
		Если ТекущаяСтрока.Длина>Отрезок1*5 Тогда
			ТекущаяСтрока.Отрезок5 = ТекущаяСтрока.Длина-Отрезок1*4;
		КонецЕсли;
	Иначе
		ТекущаяСтрока["Отрезок"+2]= Длина-Отрезок1;
	КонецЕсли;
КонецПроцедуры

