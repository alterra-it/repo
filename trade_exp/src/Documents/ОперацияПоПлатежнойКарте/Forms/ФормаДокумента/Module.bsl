#Область ДинамическиеСсылки

&НаСервере
Процедура ПроверитьВозможностьВозвратаДинамическиеСсылки()
	
	УстановитьВидимостьВозвратаДинамическиеСсылки(Ложь, Ложь);
	
	Если Строка(ФискальнаяОперацияСтатус) = "Чек не пробит" Или Строка(ФискальнаяОперацияСтатус) = "Пробить чек" Тогда
	
		ОснованиеПлатежа = ПолучитьОснованиеПлатежа();
		
		Если ЗначениеЗаполнено(ОснованиеПлатежа) Тогда
	
			ВозможностьВозврата = ИнтеграцияБанки.ПолучитьОплатуДинамическойСсылки(ОснованиеПлатежа, Объект.Ссылка);
			
			Если ВозможностьВозврата.ЭквайринговыйТерминал = Объект.ЭквайринговыйТерминал 
				И ВозможностьВозврата.ЭквайринговыйТерминал.Владелец = Объект.ДоговорЭквайринга Тогда
				
				Если ВозможностьВозврата.ТребуетсяВозврат Тогда    
				
					// Оплата по Альфабанку, возврат не выполнен
					Если ВозможностьВозврата.ВозвратОбработан = Null Тогда
						УстановитьВидимостьВозвратаДинамическиеСсылки(Истина, Истина);		
						
					// Оплата по Альфабанку, возврат в очереди к пробитию, но не пробит 		
					ИначеЕсли Не ВозможностьВозврата.ВозвратОбработан Тогда
						УстановитьВидимостьВозвратаДинамическиеСсылки(Истина, Ложь);
					
					// Оплата по Альфабанку, возврат пробит
					Иначе 
						УстановитьВидимостьВозвратаДинамическиеСсылки(Ложь, Ложь);
					КонецЕсли;
					
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры    

Функция ПолучитьОснованиеПлатежа()
	
	ОснованиеПлатежа = Неопределено;
	Если Объект.РасшифровкаПлатежа.Количество() > 0 Тогда
		ОснованиеПлатежа = Объект.РасшифровкаПлатежа[0].ОснованиеПлатежа;
		
		Если Не ЗначениеЗаполнено(ОснованиеПлатежа) Тогда                
			ОснованиеПлатежа = Объект.РасшифровкаПлатежа[0].ОбъектРасчетов.Объект;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ОснованиеПлатежа;
		
КонецФункции	

&НаСервере
Процедура УстановитьВидимостьВозвратаДинамическиеСсылки(Видимость, Доступность)
	
	Элементы.ВозвратДС.Видимость 					= Видимость;
	Элементы.ОплатаВозвратСБПГазпромбанк.Видимость 	= Не Видимость;
	Элементы.ФискальнаяОперацияСтатус.Видимость 	= Не Видимость;
	
	Элементы.ВозвратДС.Доступность 					= Доступность;
	
КонецПроцедуры	

&НаКлиенте
Процедура Док_ВозвратДСПосле(Команда)
	
	Если Не Объект.Проведен Тогда
		Сообщить("Необходимо провести документ");
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Тогда
		Сообщить("Необходимо записать документ");
		Возврат;
	КонецЕсли;	
	
    Оповещение = Новый ОписаниеОповещения("ВыполнитьВозвратДС", ЭтотОбъект);	
 
    ПоказатьВопрос(Оповещение, СтрШаблон("Выполнить возврат Альфа-Банка на сумму %1 руб.?", Формат(Объект.СуммаДокумента, "ЧДЦ=2")),
    	РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Да, "Возврат");    
	
КонецПроцедуры    
	
&НаКлиенте
Процедура ВыполнитьВозвратДС(Результат, Параметры) Экспорт
 
	Если Результат = КодВозвратаДиалога.Да Тогда      
	
		ОснованиеПлатежа = ПолучитьОснованиеПлатежа();
		
		Если ЗначениеЗаполнено(ОснованиеПлатежа) Тогда
			
			ВозвратПоДинамическойСсылке = ИнтеграцияБанки.ПолучитьОплатуДинамическойСсылки(ОснованиеПлатежа, Объект.Ссылка);
			
			Если ВозвратПоДинамическойСсылке.ТребуетсяВозврат Тогда	
				Элементы.ВозвратДС.Доступность = Ложь;	
				
				ФормаОжидания = ОткрытьФорму("Обработка.БезналичнаяОплатаБезПодключенияОборудования.Форма.ФормаОжиданияВозвратаДС",, ЭтаФорма ,,,,, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
				
				ВыполнениеВозврата = ИнтеграцияБанки.ВыполнитьВозвратДинамическойСсылки(ВозвратПоДинамическойСсылке.ДокументОснование,
					ОснованиеПлатежа, Объект.СуммаДокумента, Объект.Ссылка);
				
				Если ВыполнениеВозврата.Результат Тогда
					ПодключитьОбработчикОжидания("ПроверкаПробитияВозвратаДинамическиеСсылки", 5, Ложь);
				Иначе
					Элементы.ВозвратДС.Доступность = Истина;   
					
					Если ФормаОжидания <> Неопределено Тогда
						ФормаОжидания.Выполнено();
					КонецЕсли;   
					
					ПоказатьПредупреждение(, СтрШаблон("Не выполнен возврат: %1", ВыполнениеВозврата.Сообщение), 0, "Статус возврата");		
				КонецЕсли;
			КонецЕсли;
		КонецЕсли; 
		
    КонецЕсли;	                      
  
КонецПроцедуры 		

&НаКлиенте
Процедура ПроверкаПробитияВозвратаДинамическиеСсылки()

	ОснованиеПлатежа = ПолучитьОснованиеПлатежа();
	ВозвратПоДинамическойСсылке = ИнтеграцияБанки.ПолучитьОплатуДинамическойСсылки(ОснованиеПлатежа, Объект.Ссылка);
	
	// Оперерация помещена в очередь	
	Если ВозвратПоДинамическойСсылке.ВозвратОбработан <> Null Тогда 

		ПроверитьВозможностьВозвратаДинамическиеСсылки();
		Прочитать();
		
		// Чек пробит
		Если ВозвратПоДинамическойСсылке.ВозвратОбработан Тогда
			ОтключитьОбработчикОжидания("ПроверкаПробитияВозвратаДинамическиеСсылки");
			
			Если ФормаОжидания <> Неопределено Тогда
				ФормаОжидания.Выполнено();
			КонецЕсли;   
		
			ПоказатьПредупреждение(, "Выполнен возврат в Альфа-банк", 0, "Статус возврата");		
		
		// Чек не пробит
		Иначе
			// Ошибка пробития
			Если ВозвратПоДинамическойСсылке.Информация <> "Чек помещен в очередь!" Тогда
				ОтключитьОбработчикОжидания("ПроверкаПробитияВозвратаДинамическиеСсылки");

				Если ФормаОжидания <> Неопределено Тогда
					ФормаОжидания.Выполнено();
				КонецЕсли;                                                                          
				
				ПоказатьПредупреждение(, ВозвратПоДинамическойСсылке.Информация, 0, "Статус возврата");		
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

&НаСервере
Процедура ПроверитьВозможностьВозвратаСБПГазпромбанк() 
	
КонецПроцедуры 

&НаКлиенте
Процедура НастроитьОтображениеСБП() 
	
	Если Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту") Тогда
		Элементы.ОплатаВозвратСБПГазпромбанк.Заголовок = НСтр("ru = 'Возврат оплаты СБП Газпромбанк'");	
	ИначеЕсли Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПоступлениеОплатыОтКлиента") Тогда
		Элементы.ОплатаВозвратСБПГазпромбанк.Заголовок = НСтр("ru = 'Оплата СБП Газпромбанк'");
	КонецЕсли;
	
	ПроверитьВозможностьВозвратаДинамическиеСсылки();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьВозможностьОплатыСБПГазпромбанк() 
	//вызывать при создании и при окончании редактирования объектов расчета и если эквайринг еще не пробит
	Если Объект.ОплатаВыполнена Тогда
		Возврат;
	КонецЕсли;	
	
	ТекущаяКассаККМ = РозничныеПродажи.ПолучитьКассуККМТекущегоПользователя();
	
	Если ТекущаяКассаККМ <> Неопределено Тогда
		ДанныеКС = ИнтеграцияСБПГазпромбанк.ПолучитьКассовуюСсылкуДляТерминалаКассы(ТекущаяКассаККМ);
		Если ТипЗнч(ДанныеКС) = Тип("Структура") Тогда
			КассоваяСсылка = ДанныеКС.grcId;
		КонецЕсли;
	Иначе
		Сообщить("Для текущего пользователя касса ККМ не настроена или настроено больше 1");
	КонецЕсли;
	
КонецПроцедуры


&НаСервере
функция ПолучитьКассуККМ() 

	ТекущаяКассаККМ = РозничныеПродажи.ПолучитьКассуККМТекущегоПользователя();	
	Возврат ТекущаяКассаККМ;
	
конецфункции


&НаКлиенте
Процедура Док_ОплатаВозвратСБПГазпромбанкПосле(Команда)
	
	ЭтоВозврат = Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ВозвратОплатыКлиенту");
	
	Если Не Объект.Проведен Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Необходимо провести документ");
		Возврат;
	КонецЕсли;
	
	Если Объект.ОплатаВыполнена Тогда
		ТекстСообщения = ?(ЭтоВозврат, "Возврат уже выполнен", "Оплата уже выполнена");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	
	Если ЭтоВозврат Тогда
		ПоказатьВводСтроки(Новый ОписаниеОповещения("ВводИДТранзакцииЗавершение", ЭтотОбъект), "", "ID транзакции оплаты");
	Иначе

		ТекущаяКассаККМ = ПолучитьКассуККМ();
	
		Если ТекущаяКассаККМ <> Неопределено Тогда
			ДанныеКС = ИнтеграцияСБПГазпромбанк.ПолучитьКассовуюСсылкуДляТерминалаКассы(ТекущаяКассаККМ);
			Если ТипЗнч(ДанныеКС) = Тип("Структура") Тогда
				Идентификатор = ДанныеКС.grcId;
                ОткрытьФормуСБПГазпромбанк(Идентификатор);
			Иначе
				ОбщегоНазначенияКлиент.СообщитьПользователю("Для текущей кассы не найдена зарегистрированная кассовая ссылка");
			КонецЕсли;
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю("Для текущего пользователя касса ККМ не настроена или настроено больше 1");
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВводИДТранзакцииЗавершение(Результат, ДополнительныеПараметры)  Экспорт 
	Если Результат <> "" и ИнтеграцияСБПГазпромбанк.БылаОперацияСБП(Результат) Тогда
		ОткрытьФормуСБПГазпромбанк(Результат);
	Иначе	
		ОбщегоНазначенияКлиент.СообщитьПользователю("По такому ID транзакции не было оплаты по СБП");
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ОткрытьФормуСБПГазпромбанк(Идентификатор)
	
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Документ", Объект.Ссылка); 
	ПараметрыОткрытияФормы.Вставить("КОплате", Объект.СуммаДокумента);
	ПараметрыОткрытияФормы.Вставить("Идентификатор", Идентификатор);

	ОткрытьФорму("ОбщаяФорма.СБПГазпромбанк", ПараметрыОткрытияФормы, ЭтотОбъект,,,, Новый ОписаниеОповещения("Док_ЗавершениеОплатыСБП", ЭтотОбъект),РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры


&НаКлиенте
Процедура Док_ЗавершениеОплатыСБП(Результат, ДополнительныеПараметры)   Экспорт
	
	Если Результат = Неопределено
		ИЛИ Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.СтатусОперации = "ACCEPTED" или Результат.СтатусОперации = "PERFORMED" Тогда 
		Если Результат.ИдентификаторОплаты <> Неопределено Тогда
			IDТранзакции = Результат.ИдентификаторОплаты;
		КонецЕсли;	
		//Объект.ОплатаВыполнена = Истина;
		//ТерминалСБП = ИнтеграцияСБПГазпромбанк.ПолучитьТерминалСБППоУмолчанию();
		//Объект.ЭквайринговыйТерминал = ТерминалСБП;
		//Объект.ДоговорЭквайринга = ТерминалСБП.Владелец;
		Док_ОбработкаОплатыСБП(Результат);
		
		ОбщегоНазначенияУТКлиент.Записать(ЭтаФорма);
	КонецЕсли;
	   
КонецПроцедуры

&НаСервере
Процедура Док_ОбработкаОплатыСБП(Результат)
	ДокОбъект = РеквизитФормыВЗначение("Объект");
	ИнтеграцияСБПГазпромбанк.ОбработатьОплатуВЭквайринге(Результат, ДокОбъект);
	ЗначениеВРеквизитФормы(ДокОбъект, "Объект");	
КонецПроцедуры


&НаКлиенте
Процедура Док_ХозяйственнаяОперацияПриИзмененииПосле(Элемент)
	НастроитьОтображениеСБП();
КонецПроцедуры

&НаКлиенте
Процедура Док_ОбработкаОповещенияПосле(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "ПроблемыДеактивацииКСФормаСБП" Тогда
		Сообщить(Параметр);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	
	НастроитьОтображениеСБП();	
	
КонецПроцедуры
