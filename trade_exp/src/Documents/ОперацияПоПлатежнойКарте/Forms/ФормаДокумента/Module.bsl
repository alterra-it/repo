&НаКлиенте
Перем ФормаОжидания;      

&НаКлиенте
Процедура Док_ПриОткрытииПосле(Отказ)        
	Если Не ЗначениеЗаполнено(Объект.Номер) Тогда//Новый
		Если Объект.РасшифровкаПлатежа.Количество() > 0  Тогда
			стрРасшифровки= Объект.РасшифровкаПлатежа[0];
			ДокПродажи= стрРасшифровки.ОснованиеПлатежа;
			Если ТипЗнч(ДокПродажи) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				Объект.СуммаДокумента= АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокПродажи, "СуммаДокумента");
				СуммаДокументаПриИзменении(Неопределено);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Если Объект.РасшифровкаПлатежа.Количество() > 0 Тогда
			ОснованиеПлатежа= Объект.РасшифровкаПлатежа[0].ОснованиеПлатежа;
			Если ТипЗнч(ОснованиеПлатежа) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
				Если ПоказатьПредупреждениеОбИзмененииСуммы(ОснованиеПлатежа) Тогда
					//ПоказатьПредупреждение(, "Измени сумму", 10);
					АльтерраОбщегоНазначения.СообщитьПользователю(Объект.Ссылка, "Необходимо изменить сумму", "Объект.СуммаДокумента");
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
		
		//Проверка подключения терминала к оборудованию
		Если ПроверитьЭквайринговыйТерминал() Тогда
			Сообщить("ВНИМАНИЕ!!! Выбран терминал без подключения оборудования!!!");
		КонецЕсли;
	КонецЕсли;   

	НастроитьОтображениеСБП();
	
КонецПроцедуры   

&НаСервере
Функция ПроверитьЭквайринговыйТерминал()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиРМКЭквайринговыеТерминалы.ИспользоватьБезПодключенияОборудования КАК ИспользоватьБезПодключенияОборудования
		|ИЗ
		|	Справочник.НастройкиРМК.ЭквайринговыеТерминалы КАК НастройкиРМКЭквайринговыеТерминалы
		|ГДЕ
		|	НастройкиРМКЭквайринговыеТерминалы.ЭквайринговыйТерминал = &ЭквайринговыйТерминал 
		|	И НастройкиРМКЭквайринговыеТерминалы.Ссылка.РабочееМесто.Код = &Код	";
	  
	
	Запрос.УстановитьПараметр("Код", МенеджерОборудованияВызовСервера.ПолучитьРабочееМестоКлиента().Код);  
	Запрос.УстановитьПараметр("ЭквайринговыйТерминал", Объект.ЭквайринговыйТерминал.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	
	Если Выборка.Следующий() Тогда   
		Возврат Выборка.ИспользоватьБезПодключенияОборудования; 
	Иначе
		Возврат Ложь;	
	КонецЕсли;
	
КонецФункции	

&НаСервере
Функция ПоказатьПредупреждениеОбИзмененииСуммы(Знач ОснованиеПлатежа)
	Если НЕ ОснованиеПлатежа.ИспользуетсяДоговор Тогда
		Если ЗначениеЗаполнено(ОснованиеПлатежа.ЗаказКлиента) Тогда
			ДокРасчетов= ОснованиеПлатежа.ЗаказКлиента;
		Иначе
			ДокРасчетов= ОснованиеПлатежа;
		КонецЕсли;
		ДолгКлиента= ПолучитьДолг(ДокРасчетов);
		
		Если ДолгКлиента <> ОснованиеПлатежа.СуммаДокумента Тогда
			Возврат Истина
		КонецЕсли;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьДолг(ЗаказКлиента)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РасчетыСКлиентамиОстатки.КОплатеОстаток КАК КОплатеОстаток
		|ИЗ
		|	РегистрНакопления.РасчетыСКлиентами.Остатки(, ОбъектРасчетов.Объект = &ЗаказКлиента) КАК РасчетыСКлиентамиОстатки";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", ЗаказКлиента);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.КОплатеОстаток;
	КонецЦикла;
	
	Возврат 0;
КонецФункции 

//поиск ID транзакции
&НаКлиенте
&После("ФискальнаяОперацияЗавершение")
Процедура Док_ФискальнаяОперацияЗавершение(Результат, ДополнительныеПараметры) Экспорт
	ТерминалСБПГПБ = ИнтеграцияСБПГазпромбанк.ПолучитьТерминалСБППоУмолчанию();
	Попытка
		ДанныеОперации = ИнтеграцияСБПГазпромбанк.ПолучитьДанныеТранзакции(Объект.Ссылка);
		Если НЕ (Объект.ЭквайринговыйТерминал = ТерминалСБПГПБ или (ТипЗнч(ДанныеОперации) = Тип("Структура") и ДанныеОперации.СБП)) Тогда	
			АльтерраОбщегоНазначенияКлиент.ИзвлечьIDТранзакции(Объект.Ссылка, Объект.Дата, Объект.СуммаДокумента);
		КонецЕсли;	
	Исключение
		ЗарегистрироватьОшибкуВЖурнале(ОписаниеОшибки());  
	КонецПопытки; 	  
КонецПроцедуры

&НаСервере
Процедура ЗарегистрироватьОшибкуВЖурнале(ОписаниеОшибки)
	ЗаписьЖурналаРегистрации("Регистрация ID-транзакции", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки);
КонецПроцедуры // Зарегистрировать()

&НаСервере
Функция КассаВходитВСписок(ИмяКассы)
	СтрокаСписка = Константы.СписокКассЗаписиIDТранзакции.Получить();
	Если СтрНайти(ВРег(СтрокаСписка), ВРег(ИмяКассы)) > 0 Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции // КассаВходитВСписок()         

#Область НапечататьПоследнийСлипЧек

&НаКлиенте
Процедура НапечататьПоследнийСлипЧек(Команда)   
	ФискальнаяОперацияПодключенноеОборудование = ПодключаемоеОборудованиеУТВызовСервера.ОборудованиеПодключенноеКТерминалу(Объект.ЭквайринговыйТерминал);
	Если ЗначениеЗаполнено(ФискальнаяОперацияПодключенноеОборудование) И ЗначениеЗаполнено(ФискальнаяОперацияПодключенноеОборудование.ККТ) Тогда
		ДопМодульКлиент.НапечататьПоследнийСлипЧек(ЭтотОбъект.УникальныйИдентификатор, ФискальнаяОперацияПодключенноеОборудование.ККТ);
    КонецЕсли;
КонецПроцедуры        

&НаКлиенте
Процедура Док_ЭквайринговыйТерминалНачалоВыбораВместо(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ЗначениеОтбора = Новый Структура;
	Если ЗначениеЗаполнено(Объект.ДоговорЭквайринга) Тогда
		ЗначениеОтбора.Вставить("Владелец", Объект.ДоговорЭквайринга);
	КонецЕсли;
	ЗначениеОтбора.Вставить("ЭтоГруппа", Ложь);
	ЗначениеОтбора.Вставить("ПометкаУдаления", Ложь);
	
	ОтборСписка = Новый Структура("Отбор", ЗначениеОтбора);	
	
	Форма = ПолучитьФорму("Справочник.ЭквайринговыеТерминалы.ФормаВыбора", ОтборСписка, Элемент);
	Форма.Элементы.Список.Отображение = ОтображениеТаблицы.Список; 
	Форма.Открыть();

КонецПроцедуры

&НаКлиенте
Процедура Док_ЭквайринговыйТерминалОбработкаВыбораВместо(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Объект.ЭквайринговыйТерминал = ВыбранноеЗначение;     
	Модифицированность = Истина;  
	
	//Проверка подключения терминала к оборудованию
	Если ПроверитьЭквайринговыйТерминал() Тогда
		Сообщить("ВНИМАНИЕ!!! Выбран терминал без подключения оборудования!!!");
	КонецЕсли;  
	
	ПроверитьВозможностьВозвратаДинамическиеСсылки();
	
КонецПроцедуры  

&НаКлиенте
Процедура Док_ДоговорЭквайрингаОбработкаВыбораПосле(Элемент, ВыбранноеЗначение, ДополнительныеДанные, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;                      

	Если Объект.ДоговорЭквайринга <> ВыбранноеЗначение Тогда 
		Объект.ЭквайринговыйТерминал = ПредопределенноеЗначение("Справочник.ЭквайринговыеТерминалы.ПустаяСсылка");     
	КонецЕсли;
	
	Объект.ДоговорЭквайринга = ВыбранноеЗначение;     
	Модифицированность = Истина; 	
	
	ПроверитьВозможностьВозвратаДинамическиеСсылки();

КонецПроцедуры

