#Область Печать 

Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.ПроверкаЦенников";
	КомандаПечати.Идентификатор = "ПФ_MXL_ПроверкаЦенников";
	КомандаПечати.Представление = НСтр("ru = 'Печать'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Ложь;
	КомандаПечати.СразуНаПринтер = Ложь;
	КомандаПечати.Порядок = 1;	
	
КонецПроцедуры

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт

	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ПроверкаЦенников") Тогда
		ТабДок = СформироватьПроверкуЦенников(МассивОбъектов, ОбъектыПечати);		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"ПФ_MXL_ПроверкаЦенников", 
			НСтр("ru = 'Проверка ценников'"), ТабДок) //, "Документ.ПроверкаЦенников.ПФ_MXL_ПроверкаЦенников");
	КонецЕсли;
	
	ФормированиеПечатныхФорм.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);	
КонецПроцедуры	


Функция СформироватьПроверкуЦенников(МассивОбъектов, ОбъектыПечати) Экспорт
	
	Ссылка = МассивОбъектов[0];
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПроверкаЦенников.ПФ_MXL_ПроверкаЦенников");
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкода");
	ОбластьШапки = Макет.ПолучитьОбласть("ОбластьШапки");
	ОбластьЗаголовка = Макет.ПолучитьОбласть("ОбластьЗаголовка");
	ОбластьСтроки = Макет.ПолучитьОбласть("ОбластьСтроки");
	ОбластьПодвала = Макет.ПолучитьОбласть("ОбластьПодвала");
	
	
	ЗапросПоШапке = Новый Запрос;
	ЗапросПоШапке.Текст = 
	"ВЫБРАТЬ
	|	ПроверкаЦенников.Ссылка КАК Ссылка,
	|	ПроверкаЦенников.Номер КАК Номер,
	|	ПроверкаЦенников.Дата КАК Дата,
	|	ПроверкаЦенников.Склад.Представление КАК Склад,
	|	ПроверкаЦенников.Ответственный КАК Ответственный
	|ИЗ
	|	Документ.ПроверкаЦенников КАК ПроверкаЦенников
	|ГДЕ
	|	ПроверкаЦенников.Ссылка В(&МассивДокументов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	Дата";
	
	ЗапросПоШапке.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	
	РезультатПоШапке = ЗапросПоШапке.Выполнить().Выгрузить();
	
	ПерваяСтрокаОбъектов = Истина;
	ПервыйДокумент = Истина;
	
	Для Каждого Строка Из РезультатПоШапке Цикл
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		Если Не ПервыйДокумент ИЛИ (ПервыйДокумент И НЕ ПерваяСтрокаОбъектов) Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;

		ОбластьШапки.Параметры.НомерДокумента = Строка.Номер;
		ОбластьШапки.Параметры.ДатаДокумента = Строка.Дата;
		ОбластьШапки.Параметры.Склад = Строка.Склад;
		ОбластьШапки.Параметры.Исполнитель = Строка.Ответственный;
		
		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабличныйДокумент, Макет, ОбластьШапки, Строка.Ссылка);

		
		ТабличныйДокумент.Вывести(ОбластьШапки);
		ТабличныйДокумент.Вывести(ОбластьЗаголовка);

		ЗапросПоТоварам = Новый Запрос;
		ЗапросПоТоварам.УстановитьПараметр("МассивОбъектов", Строка.Ссылка);
		
		ТекстЗапросаПоТоварам = 
		"ВЫБРАТЬ
		|	ТаблицаТовары.Ссылка КАК Ссылка,
		|	ТаблицаТовары.Номенклатура КАК Номенклатура,
		|	ТаблицаТовары.Номенклатура.Код КАК Код,
		|	ТаблицаТовары.Номенклатура.Артикул КАК Артикул,
		|	ТаблицаТовары.НомерСтроки КАК НомерСтроки,
		|	ТаблицаТовары.НетЦенника КАК НетЦенника,
		|	ТаблицаТовары.ЕстьРасхождения КАК ЕстьРасхождения,		
		|	ДополнительныеСведения.Значение КАК ДополнительноеСведение
		|ИЗ
		|	Документ.ПроверкаЦенников.Товары КАК ТаблицаТовары
		|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|	ПО ТаблицаТовары.Номенклатура.Ссылка = ДополнительныеСведения.Объект 
        |		И ДополнительныеСведения.Свойство = ТаблицаТовары.Ссылка.ДополнительноеСведениеКолонки
		|ГДЕ
		|	ТаблицаТовары.Ссылка В(&МассивОбъектов)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка,
		|	ТаблицаТовары.НомерСтроки";
		
		ЗапросПоТоварам.Текст = ТекстЗапросаПоТоварам;
		ВыборкаПоТоварам = ЗапросПоТоварам.Выполнить().Выбрать();
					
		// Выборка товаров
			
		НомерСтроки = 1;
			
		Пока ВыборкаПоТоварам.НайтиСледующий(Новый Структура("Ссылка", Строка.Ссылка)) Цикл
				
			//ОбластьСтроки.Параметры.Номер = НомерСтроки;
			ОбластьСтроки.Параметры.Номер = ВыборкаПоТоварам.НомерСтроки;
			ОбластьСтроки.Параметры.Код = ВыборкаПоТоварам.Код;
			ОбластьСтроки.Параметры.Номенклатура = ВыборкаПоТоварам.Номенклатура;
			ОбластьСтроки.Параметры.Сведение = ВыборкаПоТоварам.ДополнительноеСведение;
			ОбластьСтроки.Параметры.ЕстьРасхождения = ВыборкаПоТоварам.ЕстьРасхождения;
			
			ТабличныйДокумент.Вывести(ОбластьСтроки);
			
			НомерСтроки = НомерСтроки + 1;
								
		КонецЦикла;
			
			
		ТабличныйДокумент.Вывести(ОбластьПодвала);
		
		ПерваяСтрокаОбъектов = Ложь;
		
	КонецЦикла;
	
	
	Возврат ТабличныйДокумент;
КонецФункции

#КонецОбласти


#КонецЕсли


