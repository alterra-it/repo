#Область ОбработчикиСобытийФормы
&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	НашеПредприятие = Справочники.Партнеры.ПолучитьСсылку(Новый УникальныйИдентификатор("97403c2a-4260-481c-8835-1ea87e51a4aa")); // Наше предприятие
	Если НЕ НашеПредприятие.Пустая() Тогда
		МассивКонтрагентов = ПартнерыИКонтрагенты.ПолучитьВсехКонтрагентовПартнера(НашеПредприятие);
		НоваяСвязь = Новый ПараметрВыбора("Отбор.Ссылка", МассивКонтрагентов);
		Массив = Новый Массив();
		Массив.Добавить(НоваяСвязь);
		Элементы.Грузополучатель.ПараметрыВыбора = Новый ФиксированныйМассив(Массив);
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти
