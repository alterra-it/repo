&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	ДвиженияПеремещенийКПередаче(ЭтотОбъект, ЭтотОбъект.Движения);
КонецПроцедуры 
	
Процедура ДвиженияПеремещенийКПередаче(ДокОбъект,Движения)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВозвратТоваровМеждуОрганизациямиТовары.Номенклатура,
	|	ВозвратТоваровМеждуОрганизациямиТовары.Количество,
	|	ВозвратТоваровМеждуОрганизациямиТовары.Ссылка.Склад,
	|	ВозвратТоваровМеждуОрганизациямиТовары.Ссылка.СкладПолучатель,
	|	ВозвратТоваровМеждуОрганизациямиТовары.Ссылка.ОрганизацияПолучатель как Организация,
	|	&Период,
	|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Расход) как ВидДвижения,
	|	&Ссылка,
	|	ВозвратТоваровМеждуОрганизациямиТовары.НомерСтроки,
	|	ВозвратТоваровМеждуОрганизациямиТовары.Характеристика
	|ИЗ
	|	Документ.ВозвратТоваровМеждуОрганизациями.Товары КАК ВозвратТоваровМеждуОрганизациямиТовары
	|ГДЕ
	|	ВозвратТоваровМеждуОрганизациямиТовары.Ссылка = &Ссылка
	|	И НЕ ВозвратТоваровМеждуОрганизациямиТовары.Ссылка.СкладПолучатель.Ссылка ЕСТЬ NULL ";
	
	Запрос.УстановитьПараметр("Ссылка", ДокОбъект.Ссылка);
	Запрос.УстановитьПараметр("Период", ДокОбъект.Дата);
	
	НаборЗаписей = Движения.ТоварыОрганизацийКПередачеПеремещения;
	НаборЗаписей.Записывать = Истина;
	НаборЗаписей.Загрузить(Запрос.Выполнить().Выгрузить());   
	
КонецПроцедуры

&Перед("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	
КонецПроцедуры  

