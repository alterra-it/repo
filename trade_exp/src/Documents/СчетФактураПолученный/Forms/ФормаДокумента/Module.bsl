&НаСервере
&После("ОбновитьИнформацию")
Процедура Док_ОбновитьИнформацию()
	ОбъектДокумента = РеквизитФормыВЗначение("Объект");
    ОбъектДокумента.УстановкаПравильнойДаты();
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ЗаполнитьДатуПолучения")
Процедура Док_ЗаполнитьДатуПолучения()
    #Удаление
	Если Объект.Исправление И ЗначениеЗаполнено(Объект.ДатаИсправления) Тогда
		Объект.Дата = Объект.ДатаИсправления;
	ИначеЕсли ЗначениеЗаполнено(Объект.ДатаСоставления) Тогда
		Объект.Дата = Объект.ДатаСоставления;
	КонецЕсли;
    
	ДатаПолученияПриИзмененииКлиент();
    #КонецУдаления
	
	#Вставка
	УстановкаПравильнойДаты();
	
	ДатаПолученияПриИзмененииКлиент();
	#КонецВставки
	
КонецПроцедуры

&НаСервере
Процедура УстановкаПравильнойДаты()
	Если ЗначениеЗаполнено(ДокументыОснованияПредставление) Тогда
		ОбъектДокумента = РеквизитФормыВЗначение("Объект");
    	ОбъектДокумента.УстановкаПравильнойДаты();
	КонецЕсли;	
КонецПроцедуры