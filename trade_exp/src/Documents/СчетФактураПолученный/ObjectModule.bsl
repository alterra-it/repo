
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

//nzk Задача № 156477
Процедура ПолеПолученПриНесколькихОснованиях() 	
	 	
Если ЭтотОбъект.ДокументыОснования.Количество() = 0 Тогда
    Возврат;
КонецЕсли;

Запрос = Новый Запрос;
Запрос.Текст = 
"ВЫБРАТЬ
|	ПриобретениеТоваровУслуг.Дата КАК Дата
|ПОМЕСТИТЬ ВТ_ДатыОснований
|ИЗ
|	Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
|ГДЕ
|	ПриобретениеТоваровУслуг.Ссылка В(&ТаблицаОснований)
|
|ОБЪЕДИНИТЬ ВСЕ
|
|ВЫБРАТЬ
|	ПриобретениеУслугПрочихАктивов.Дата
|ИЗ
|	Документ.ПриобретениеУслугПрочихАктивов КАК ПриобретениеУслугПрочихАктивов
|ГДЕ
|	ПриобретениеУслугПрочихАктивов.Ссылка В(&ТаблицаОснований)
|
|ОБЪЕДИНИТЬ ВСЕ
|
|ВЫБРАТЬ
|	КорректировкаПриобретения.Дата
|ИЗ
|	Документ.КорректировкаПриобретения КАК КорректировкаПриобретения
|ГДЕ
|	КорректировкаПриобретения.Ссылка В(&ТаблицаОснований)
|;
|
|////////////////////////////////////////////////////////////////////////////////
|ВЫБРАТЬ
|	МАКСИМУМ(ВТ_ДатыОснований.Дата) КАК МаксимальнаяДата
|ИЗ
|	ВТ_ДатыОснований КАК ВТ_ДатыОснований";	
	
ТаблицаОснований = ЭтотОбъект.ДокументыОснования.Выгрузить(, "ДокументОснование");
Запрос.УстановитьПараметр("ТаблицаОснований", ТаблицаОснований);

Выборка = Запрос.Выполнить().Выбрать();
Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.МаксимальнаяДата) Тогда
    ЭтотОбъект.Дата = Выборка.МаксимальнаяДата;
КонецЕсли;	
	
КонецПроцедуры	
			
&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(ДокументыОснования) Тогда
		ПолеПолученПриНесколькихОснованиях();		
	КонецЕсли;
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	ДополнительныеСвойства.Вставить("ДокументУдаляют", НЕ Ссылка.ПометкаУдаления И ПометкаУдаления);	
	Если Ссылка.Пустая() Тогда	
		ЭтотОбъект.ДатаСозданияДокумента = ТекущаяДата();
	КонецЕсли;	
КонецПроцедуры

&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)	
	Если Не Отказ И ДополнительныеСвойства.ДокументУдаляют И Не ОбменДанными.Загрузка Тогда
		ДокументыОснованияСтрока = "";
		Для Каждого СтрокаТЧ из ДокументыОснования Цикл
			ДокументыОснованияСтрока = ДокументыОснованияСтрока + СтрокаТЧ.ДокументОснование + ", ";		
		КонецЦикла;
			
		Документы.КорректировкаПриобретения.ОтправитьИнформациюВЧат_ИзменениеПриходныхДокументовВЗакрытомПериоде(
			Организация,
			?(Исправление, ДатаИсправления, ДатаСоставления),
			"Удален документ " + Ссылка + " к " + Лев(ДокументыОснованияСтрока, СтрДлина(ДокументыОснованияСтрока) - 2));
		КонецЕсли;
		
КонецПроцедуры

//nzk Задача № 156477
Процедура УстановкаПравильнойДаты() Экспорт
    Если ЗначениеЗаполнено(ДокументыОснования) Тогда
		ПолеПолученПриНесколькихОснованиях();	
	КонецЕсли;	    
КонецПроцедуры

&После("ЗаполнитьПараметрыСчетаФактурыПоОснованию")
Процедура Док_ЗаполнитьПараметрыСчетаФактурыПоОснованию()
	Если ЗначениеЗаполнено(ДокументыОснования) Тогда
		ПолеПолученПриНесколькихОснованиях();		
	КонецЕсли;
КонецПроцедуры

#КонецЕсли

