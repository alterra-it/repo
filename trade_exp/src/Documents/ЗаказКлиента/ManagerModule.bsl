&После("ДобавитьКомандыПечати")
Процедура Док_ДобавитьКомандыПечати(КомандыПечати)    
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Обработка.ПечатьЗаданияНаОтборРазмещениеТоваров";
	КомандаПечати.Идентификатор = "ЗаданиеНаОтборРазмещениеТовара";
	КомандаПечати.Представление = НСтр("ru = 'Задание на отбор товаров'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	КомандаПечати.ДополнительныеПараметры.Вставить("ИмяФормы", "ЗаданиеНаОтбор");  
	
КонецПроцедуры

&После("ДобавитьКомандыСозданияНаОсновании")
Процедура Док_ДобавитьКомандыСозданияНаОсновании(КомандыСоздатьНаОсновании, Параметры)
	Документы.ЛистСогласования.ДобавитьКомандуСоздатьНаОсновании(КомандыСоздатьНаОсновании);
КонецПроцедуры


#Область Транзит
Процедура УстановитьТранзитФизЛицо(Объект) Экспорт 
	
	ЭтоТранзит = Объект.Склад.Транзит;
	ЭтоФизЛицо = АльтерраОбщегоНазначения.ЭтоФизическоеЛицо(Объект.Контрагент);
	
	Если ЭтоТранзит Тогда
		Если Объект.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.Компания И Не ЭтоФизЛицо Тогда
			Объект.ТранзитФизЛицо = Ложь;
		Иначе
			Объект.ТранзитФизЛицо = Истина;
		КонецЕсли;
	Иначе 
		Объект.ТранзитФизЛицо = Ложь;
	КонецЕсли; 
	
КонецПроцедуры

Процедура РасчитатьТранспортныеТранзит(Объект) Экспорт
	
	Объект.ПроцентТранспортных = ПолучитьпроцентТранспортных(Объект);
	Объект.РазмерТранспортных = ПолучитьРазмерТранспортных(Объект);

	Если Не ЕстьОтгруженныеСтроки(Объект) Тогда
		Если Объект.КоличествоМашин = 0 Тогда
			ОбщегоНазначения.СообщитьПользователю("Укажите Количество машин", , "Объект.КоличествоМашин");
			Возврат;
		КонецЕсли;
		
		РазмерТранспортныхНаМашину = Объект.РазмерТранспортных/Объект.КоличествоМашин;
		Объект.РаспределениеТранспортныхРасходов.Очистить();
		Для сч = 1 По Объект.КоличествоМашин Цикл
			НоваяСтрока = Объект.РаспределениеТранспортныхРасходов.Добавить();
			НоваяСтрока.Сумма = РазмерТранспортныхНаМашину;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры
	
Функция ПолучитьпроцентТранспортных(Объект) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ВТТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЗаказКлиентаТовары.Номенклатура.ВидНоменклатуры.ПроцентТранспортных) КАК ПроцентТранспортных
		|ИЗ
		|	ВТТовары КАК ЗаказКлиентаТовары";
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.ПроцентТранспортных;
	КонецЦикла; 
	
КонецФункции

Функция ПолучитьРазмерТранспортных(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТТовары.Номенклатура КАК Номенклатура,
		|	ВТТовары.Отменено КАК Отменено,
		|	ВТТовары.СуммаСНДС КАК СуммаСНДС
		|ПОМЕСТИТЬ ВТТовары
		|ИЗ
		|	&Товары КАК ВТТовары
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ЗаказКлиентаТовары.СуммаСНДС*&ПроцентТранспортных/100) КАК РазмерТранспортных
		|ИЗ
		|	ВТТовары КАК ЗаказКлиентаТовары
		|ГДЕ
		|	ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры = Значение(Перечисление.ТипыНоменклатуры.Товар)
		|И НЕ ЗаказКлиентаТовары.Отменено
		|";
	
	Запрос.УстановитьПараметр("Товары", Объект.Товары.Выгрузить());
	Запрос.УстановитьПараметр("ПроцентТранспортных", Объект.ПроцентТранспортных);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.РазмерТранспортных;
	КонецЦикла;
	
КонецФункции

Функция ЕстьОтгруженныеСтроки(Объект)
	
	Отбор = Новый Структура("Распределено", Истина);
	Строки = Объект.РаспределениеТранспортныхРасходов.НайтиСтроки(Отбор);
	
	Возврат (Строки.Количество() > 0);    
	
КонецФункции 

#КонецОбласти

#Область Эквайринг
Процедура СоздатьЭквайринговуюОперацию(Заказ, ВыводитьСообщение = Истина) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ЭквайринговыйТерминал = Документы.ОперацияПоПлатежнойКарте.ПолучитьТерминалССайтаПоУмолчанию();
	Если Не ЗначениеЗаполнено(Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(Заказ, ЭквайринговыйТерминал)) Тогда
		Док = Документы.ОперацияПоПлатежнойКарте.СоздатьДокумент();
		Док.Заполнить(Заказ);
		Док.Дата = ТекущаяДата();
		Док.НомерПлатежнойКарты = "0101";
		Док.ЭквайринговыйТерминал = ЭквайринговыйТерминал;
		Док.Комментарий = "Создана автоматически по заказу на сайт";
		Док.ДоговорЭквайринга = ЭквайринговыйТерминал.Владелец;
		Док.Записать(РежимЗаписиДокумента.Запись);
		
		Если ВыводитьСообщение Тогда
			ОбщегоНазначения.СообщитьПользователю("Создана: " + Док.Ссылка, Док.Ссылка);
		КонецЕсли;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Ложь); 
	
КонецПроцедуры
#КонецОбласти

#Область ФормированиеДвиженийПоБонуснымБаллам 
&ИзменениеИКонтроль("ДанныеДокументаДляПроведения")
Функция Док_ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры)
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		ДокументОбъект = Документ;
		ДокументСсылка = Документ.Ссылка;
	Иначе
		ДокументОбъект = Документ.ПолучитьОбъект();
		ДокументСсылка = Документ;
	КонецЕсли;
	
	Запрос			= Новый Запрос;
	ТекстыЗапроса	= Новый СписокЗначений;
	
	ПолучитьДанныеДокумента(Запрос, ДокументСсылка);
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		СформироватьСуммыДокументаВВалютахУчета(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		
		ТекстЗапросаТаблицаРаспоряженияНаОтгрузку(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
		ТекстЗапросаТаблицаРеестрДокументов(Запрос, ТекстыЗапроса, Регистры);
#Удаление
		ТекстЗапросаБонусныеБаллы(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
#КонецУдаления
#Вставка
		Если БонусыАльтерраРезерв.ПрименитьНовыйПорядокРаспределенияБонусов(Документ) Тогда
			ТекстЗапросаБонусныеБаллыСРезервом(Запрос, ТекстыЗапроса, Регистры);	
		КонецЕсли;
#КонецВставки
	КонецЕсли;
	
	ОтразитьРаспределениеЗапасовДвижения(Запрос, ТекстыЗапроса, Регистры);
	ДобавитьТекстыОтраженияВзаиморасчетов(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	ОтразитьРезерв(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	ЗапланироватьОтгрузкуТоваров(Запрос, ТекстыЗапроса, Регистры, ДокументОбъект);
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	
КонецФункции

Функция ТекстЗапросаБонусныеБаллыСРезервом(Запрос, ТекстыЗапроса, Регистры)

	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьРасширенныеВозможностиЗаказаКлиента") Тогда
		Возврат "";
	КонецЕсли;

	ИмяРегистра = "БонусныеБаллы";

	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли; 

	Если НЕ ПроведениеДокументов.ЕстьТаблицаЗапроса("ВтБонусныеБаллы", ТекстыЗапроса) Тогда
		ИмяДопРегистра = "ВтБонусныеБаллы";
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	БонусныеПрограммыЛояльности.Ссылка КАК БПЛ
		|ПОМЕСТИТЬ ВТБонусныеПрограммы
		|ИЗ
		|	Справочник.БонусныеПрограммыЛояльности КАК БонусныеПрограммыЛояльности
		|ГДЕ
		|	БонусныеПрограммыЛояльности.Наименование = ""Бонус от ALTERRA""
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НачалоПериода(&Период, ДЕНЬ)                КАК Период,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаКОбработке,
		|	ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)      КАК ВидДвижения,
		|	ВТБонусныеПрограммы.БПЛ		                КАК БонуснаяПрограммаЛояльности,
		|	&Партнер                                    КАК Партнер,
		|	0											КАК Начислено,
		|	0                                           КАК КСписанию,
		|	ТабличнаяЧасть.СуммаБонусныхБалловКСписанию КАК ВРезерве
		|ПОМЕСТИТЬ ВтБонусныеБаллы
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК ТабличнаяЧасть,
		|	ВТБонусныеПрограммы КАК ВТБонусныеПрограммы
		|ГДЕ
		|	ТабличнаяЧасть.Ссылка = &Ссылка
		|	И ТабличнаяЧасть.СуммаБонусныхБалловКСписанию <> 0
		|	И НЕ ТабличнаяЧасть.Отменено
		|";
		
		ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяДопРегистра);
	КонецЕсли; 

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	БонусныеБаллы.Период                      КАК Период,
	|	БонусныеБаллы.ДатаКОбработке              КАК ДатаКОбработке,
	|	БонусныеБаллы.ВидДвижения                 КАК ВидДвижения,
	|	БонусныеБаллы.БонуснаяПрограммаЛояльности КАК БонуснаяПрограммаЛояльности,
	|	БонусныеБаллы.Партнер                     КАК Партнер,
	|	СУММА(БонусныеБаллы.Начислено)            КАК Начислено,
	|	СУММА(БонусныеБаллы.КСписанию)            КАК КСписанию,
    |СУММА(БонусныеБаллы.ВРезерве)      		  КАК ВРезерве
	|ИЗ
	|	ВтБонусныеБаллы КАК БонусныеБаллы
	|
	|СГРУППИРОВАТЬ ПО
	|	БонусныеБаллы.БонуснаяПрограммаЛояльности,
	|	БонусныеБаллы.Партнер,
	|	БонусныеБаллы.Период,
	|	БонусныеБаллы.ДатаКОбработке,
	|	БонусныеБаллы.ВидДвижения
	|ИМЕЮЩИЕ
	|	СУММА(БонусныеБаллы.ВРезерве) <> 0
	|";

	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);

	Возврат ТекстЗапроса;

КонецФункции
#КонецОбласти


#КонецЕсли
