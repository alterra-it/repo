	НаправлениеДеятельности = Справочники.НаправленияДеятельности.ПустаяСсылка();
	ДатаСогласования = Дата(1,1,1,0,0,0);
	НалогообложениеНДС = Перечисления.ТипыНалогообложенияНДС.ПустаяСсылка(); 
	ВернутьМногооборотнуюТару = Ложь;
	СрокВозвратаМногооборотнойТары = 0;
	ТребуетсяЗалогЗаТару = Ложь;
	НомерПоДаннымКлиента = "";
	ДатаПоДаннымКлиента = Дата(1,1,1,0,0,0);
	ДатаОтметкиКасса = Дата(1,1,1,0,0,0);
	ДополнительнаяИнформация = "";
	СрокДействия = Дата(1,1,1,0,0,0);
	
	// Вкладка "Информация о заказе с сайта"
	ССайта = Ложь;
	НомерНаСайте = "";
	СуммаССайта = 0;
	ДатаЗагрузкиССайта = Дата(1,1,1,0,0,0);
	ДатаСоздания = ТекущаяДата();
	ДатаПервогоИзменения = Дата(1,1,1,0,0,0);
	ДатаСменыСтатусаКВыполнению = Дата(1,1,1,0,0,0);
	
	// Вкладка "Акции"
	Акции.Очистить();
	
