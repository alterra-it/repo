&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	КоммерческоеПредложение = Ложь;
	Если Не ЗначениеЗаполнено(ПодразделениеМенеджера) и Не ЗначениеЗаполнено(ОтделМенеджера) Тогда
		ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Менеджер); 
		ОтделМенеджера = ПолучитьОтделМенеджера(Менеджер);
	КонецЕсли;  
КонецПроцедуры

&Перед("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ТранзитФизЛицо Тогда
		ПроверяемыеРеквизиты.Добавить("СпособДоставки");
		ПроверяемыеРеквизиты.Добавить("КоличествоМашин");
		Если СпособДоставки = Перечисления.СпособыДоставки.ДоКлиента Тогда
			ПроверяемыеРеквизиты.Добавить("ТелефонКлиентаНаВыгрузке");
			ПроверяемыеРеквизиты.Добавить("АдресДоставки");
		КонецЕсли;
	КонецЕсли;
	
	МассивНепроверяемыхРеквизитов = Новый Массив;
	МассивНепроверяемыхРеквизитов.Добавить("Договор");
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

&После("ОбработкаПроверкиЗаполнения")
Процедура Док_ОбработкаПроверкиЗаполненияПосле(Отказ, ПроверяемыеРеквизиты)  
	
	Если ИспользуетсяДоговор Тогда
		ПроверяемыеРеквизиты.Добавить("Договор");
	КонецЕсли;
	
КонецПроцедуры

&После("ПриКопировании")
Процедура Док_ПриКопированииПосле(ОбъектКопирования)
	
	ЭтотОбъект.ДополнительныеРеквизиты.Очистить();
	
	// Вкладка "Доставка"
	ТранзитФизЛицо = Ложь;           
	РазмерТранспортных = 0;
	ПроцентТранспортных = 0; 
	ТелефонКлиентаНаВыгрузке = "";
	КоличествоМашин = 0;
	ПеревозчикПартнер = Справочники.Партнеры.ПустаяСсылка();
	ЗонаДоставки = Справочники.ЗоныДоставки.ПустаяСсылка();
	ВремяДоставкиС = Дата(1,1,1,0,0,0);            
	ВремяДоставкиПо = Дата(1,1,1,0,0,0);           
	ДополнительнаяИнформацияПоДоставке = "";  
	ОсобыеУсловияПеревозки = Ложь;              
	ОсобыеУсловияПеревозкиОписание = "";
	РаспределениеТранспортныхРасходов.Очистить();
	
	// Вкладка "Дополнительно"
	Кассир = Справочники.Пользователи.ПустаяСсылка();
	Сделка = Справочники.СделкиСКлиентами.ПустаяСсылка();
	Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка();
