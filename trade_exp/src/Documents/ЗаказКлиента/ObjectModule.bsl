КонецПроцедуры

&После("ОбработкаПроведения")
Процедура Док_ОбработкаПроведения(Отказ, РежимПроведения)
	
	Если Дата < Дата(2019,1,1)  Тогда
		Если РольДоступна("ПолныеПрава") Тогда
			Сообщить("Внимание! Вы перепроведите документ прошлых периодов!");
		Иначе
			Сообщить("Нельзя проводить документы прошлых периодов (только с 01.01.2019)!");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	ДопМодуль.КонтрольОтгрузки(ЭтотОбъект,Отказ);
	Альтерра_СкладСервер.КонтрольОстатковПоТоварамНаСкладах(ЭтотОбъект,Отказ);
	ДопМодуль.КонтрольОбособленногоОстатка(ЭтотОбъект, Отказ);
	
КонецПроцедуры

&После("ОбработкаУдаленияПроведения")
Процедура Док_ОбработкаУдаленияПроведения(Отказ)
	
	Если Дата < Дата(2019,1,1) Тогда
		Если РольДоступна("ПолныеПрава") Тогда
			Сообщить("Внимание! Вы отменяете проведение документа прошлых периодов!");
			Иначе
			Сообщить("Нельзя отменять проведение документов прошлых периодов (только с 01.01.2019)!");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Документы.ЗаданиеНаПеревозкуРейс.ПроверитьЧтоНетРейсовИлизаказовНаДоставку(ЭтотОбъект, Отказ);
	
	АльтерраОбщегоНазначения.КонтрольОтметкиКассы(ЭтотОбъект, Отказ);    
	
КонецПроцедуры

&После("ПриЗаписи")
Процедура Док_ПриЗаписи(Отказ)
	
	Если Не Отказ Тогда
		Для Каждого Строка Из Товары Цикл 
			Если Строка.Обособленно Тогда
				ТоварПодЗаказ = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(Сделка) Тогда
			ПартнерВСделку = ?(Партнер = Сделка.Партнер, Неопределено, Партнер);
		    КонтрагентВСделку = ?(Контрагент = Сделка.Контрагент, Неопределено, Контрагент);
			Справочники.СделкиСКлиентами.НазваниеСделки(Сделка, ПартнерВСделку, КонтрагентВСделку);
		КонецЕсли;
	КонецЕсли;   
	
КонецПроцедуры

&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью1(Отказ, РежимЗаписи, РежимПроведения) 
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	ДопМодуль.ПодставитьКонтрагентаФизическоеЛицо(ЭтотОбъект);
	Если ЭтоНовый() И ЭтотОбъект.Комментарий = "Создан из помощника продаж" Тогда 
		ЭтотОбъект.АдресДоставки = "";
	КонецЕсли;
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	ТекущийПользователь = Пользователи.ТекущийПользователь();
	
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Отказ=АльтерраОбщегоНазначения.ПроверкаБлокировкиУслуги(Дата,Товары);
	БонусыАльтерраРезерв.КонтрольОстатковПоБонуснымБаллам(ЭтотОбъект, Отказ);
	
	Если ЗначениеЗаполнено(Ссылка.Кассир) И (ЗначениеЗаполнено(Ссылка.Кассир) = ЗначениеЗаполнено(Кассир))  Тогда
		Если Не ЭтотОбъект.ДополнительныеСвойства.Свойство("Регламент") Тогда
			Сообщить("Установлена отметка кассы!");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
	//проверяем есть ли согласованный рей и сбрасываем согласование, если сумма изменилась
	Если ЭтотОбъект.СуммаДокумента <> Ссылка.СуммаДокумента И Не Отказ И ЗначениеЗаполнено(Ссылка) Тогда
		Рейс = Документы.ЗаданиеНаПеревозкуРейс.ПолучитьРейсПоДокументуПродажи(Ссылка);
		Если ЗначениеЗаполнено(Рейс) И Рейс.ВидДоставки = Перечисления.ВидыДоставокДоКлиента.СборнаяОРК Тогда
			Если Рейс.Согласован Тогда
				РейсОбъект = Рейс.ПолучитьОбъект();
				РейсОбъект.Согласован = Ложь;
				РейсОбъект.Записать();
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Снято согласование у " + Рейс, Рейс);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	НовыйЗаказ = ЭтоНовый(); 
	Администратор = Пользователи.НайтиПоИмени("Администратор");
	Если ССайта Тогда
		Если НовыйЗаказ Тогда
			Автор = Неопределено;
			Менеджер = Администратор;
		КонецЕсли;		
		Если Не ЗначениеЗаполнено(СуммаССайта) И НовыйЗаказ Тогда
			СуммаССайта = СуммаДокумента;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ДатаЗагрузкиССайта) И НовыйЗаказ Тогда
			ДатаЗагрузкиССайта = ТекущаяДата();
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ДатаПервогоИзменения) И Не НовыйЗаказ Тогда
			Автор = ТекущийПользователь;
		КонецЕсли;
		
		Если Менеджер = Администратор И ЗначениеЗаполнено(ДатаСменыСтатусаКВыполнению) Тогда
			ДатаСменыСтатусаКВыполнению = Дата("00010101");
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ДатаСменыСтатусаКВыполнению) И Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению И Не НовыйЗаказ Тогда
			ДатаСменыСтатусаКВыполнению = ТекущаяДата();
			Менеджер = ТекущийПользователь;
			Магазин = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(ТекущийПользователь, Неопределено);
		КонецЕсли;
	КонецЕсли;	
	
	Если Не РольДоступна("ПолныеПрава") И Не ЗначениеЗаполнено(ДатаПервогоИзменения) Тогда
		ДатаПервогоИзменения = ТекущаяДата();
	КонецЕсли;	
	
	Если Не ЗначениеЗаполнено(ДатаСоздания) Тогда
		ДатаСоздания = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если режимзаписи = РежимЗаписиДокумента.Запись ИЛИ режимзаписи = РежимЗаписиДокумента.Проведение Тогда
		ДопМодуль.РаспределениеТранспортных(ЭтотОбъект);
	КонецЕсли;
	
	//ДопМодуль.ПодставитьКонтрагентаФизическоеЛицо(ЭтотОбъект);
	
	Если ИзменениеДатыПриУстановкеРезерваИлиДобавленииНовыхПозиций(ЭтотОбъект) Тогда 
		ИзменениеДатыПлатежаДатыОтгрузкиДаты(ЭтотОбъект);
	КонецЕсли;
	
	Документы.ЗаказКлиента.УстановитьТранзитФизЛицо(ЭтотОбъект);
	
	Справочники.МаркетинговыеМероприятия.РасчетПоМаркетинговымМероприятиям(ЭтотОбъект);
	
	Если Не Отказ И 
		(ЭтоНовый() ИЛИ Дата > Дата(2021, 8, 4)) И
		Не ЗначениеЗаполнено(Кассир) И
		Не Склад.Транзит И 
		Не ЗначениеЗаполнено(ПричинаОтклоненияОтЦеновыхУсловий) И 
		РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда	
		ДопМодуль.ПроверкаНаОтклонениеОтЦеновыхУсловий(ЭтотОбъект, Отказ);
	КонецЕсли; 
	
	Если  ЗначениеЗаполнено(ЭтотОбъект.Склад) Тогда
		ЭтотОбъект.Подразделение = ЭтотОбъект.Склад.Подразделение;
	КонецЕсли; 
	
 //Проверяем, есть ли строки с отличающимися кодами строк в Реализациях по Заказу 
 Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Распоряжения.Распоряжение КАК Распоряжение,
		|	Распоряжения.КодСтроки КАК КодСтроки,
		|	Распоряжения.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВременнаяТаблица
		|ИЗ
		|	РегистрНакопления.РаспоряженияНаОтгрузку.Обороты(,,, Распоряжение = &ЗаказКлиента) КАК Распоряжения
		|ГДЕ
		|	Распоряжения.ЗаказаноОборот < 0
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.Номенклатура КАК Номенклатура,
		|	Распоряжения.Регистратор КАК Регистратор
		|ИЗ
		|	ВременнаяТаблица КАК ВременнаяТаблица
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.РаспоряженияНаОтгрузку КАК Распоряжения
		|		ПО (Распоряжения.Распоряжение = ВременнаяТаблица.Распоряжение)
		|			И (Распоряжения.КодСтроки = ВременнаяТаблица.КодСтроки)
		|ГДЕ
		|	Распоряжения.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг";
	
	Запрос.УстановитьПараметр("ЗаказКлиента", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл   
		ОбщегоНазначения.СообщитьПользователю("Номенклатура " + """" + Выборка.Номенклатура + """" +  " из  " + Выборка.Регистратор + " не связана с Заказом!",Выборка.регистратор);
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(Менеджер) Тогда
			Менеджер = ТекущийПользователь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПодразделениеМенеджера) и Не ЗначениеЗаполнено(ОтделМенеджера) Тогда
		ПодразделениеМенеджера = ПолучитьПодразделениеМенеджера(Менеджер); 
        ОтделМенеджера = ПолучитьОтделМенеджера(Менеджер);
	КонецЕсли;
	
КонецПроцедуры 

Функция ИзменениеДатыПриУстановкеРезерваИлиДобавленииНовыхПозиций(Объект)
	
	РезультатПроверки = Ложь;
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказКлиентаТовары.КодСтроки КАК КодСтроки,
	|	ЗаказКлиентаТовары.ВариантОбеспечения КАК ВариантОбеспечения,
	|	ЗаказКлиентаТовары.Обособленно КАК Обособленно
	|
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	
	ПредВерсияТовары = РезультатЗапроса.Выгрузить();
	
	НастВерсияТовары = Объект.Товары.Выгрузить();
	
	Для Каждого Строка Из НастВерсияТовары Цикл
		Если Не Строка.Отменено Тогда
		НайденнаяСтрока = ПредВерсияТовары.Найти(Строка.КодСтроки,"КодСтроки");
			Если НайденнаяСтрока <> Неопределено Тогда
				Если ((НайденнаяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.КОбеспечению
					ИЛИ НайденнаяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.НеТребуется
					ИЛИ НайденнаяСтрока.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.РезервироватьПоМереПоступления)
					И 
					(Строка.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.СоСклада 
					ИЛИ Строка.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить)) 
					ИЛИ 
					(НайденнаяСтрока.Обособленно<>Строка.Обособленно)
					Тогда
					
			     	РезультатПроверки = Истина;
				 	Прервать;
					 
				КонецЕсли;
			ИначеЕсли 
				Строка.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.СоСклада ИЛИ 
				Строка.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить ИЛИ
				Строка.Обособленно Тогда
				
				РезультатПроверки = Истина;
				Прервать;
				
			 КонецЕсли;
		 КонецЕсли;
	КонецЦикла;
	
	Возврат РезультатПроверки; 
	
КонецФункции

Процедура ИзменениеДатыПлатежаДатыОтгрузкиДаты(Объект)
	
	ТекущаяДатаДокумента = ТекущаяДата();
	Объект.Дата = ТекущаяДатаДокумента;
	Если ТипЗнч(Объект) <> Тип("ДокументОбъект.ЗаказНаПеремещение") Тогда		
		Для Каждого Строка Из Объект.Товары Цикл
			Если Строка.ДатаОтгрузки < ТекущаяДатаДокумента Тогда
				Строка.ДатаОтгрузки = ТекущаяДатаДокумента;
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого Строка Из Объект.ЭтапыГрафикаОплаты Цикл
			Если Строка.ДатаПлатежа < ТекущаяДатаДокумента Тогда
				Строка.ДатаПлатежа = ТекущаяДатаДокумента;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого Строка Из Объект.Товары Цикл
			Если Строка.НачалоОтгрузки < ТекущаяДатаДокумента Тогда
				Строка.НачалоОтгрузки = ТекущаяДатаДокумента;
			КонецЕсли;
		КонецЦикла;
	Конецесли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьОтделМенеджера(Менеджер)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДополнительныеСведения.Значение.Наименование КАК Отдел
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО (ДополнительныеСведения.Объект = Пользователи.Ссылка)
		|ГДЕ
		|	Пользователи.Ссылка = &Ссылка
		|	И ДополнительныеСведения.Свойство.Наименование = ""Отделы (Пользователи)""";
	
	Запрос.УстановитьПараметр("Ссылка", Менеджер);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Отдел;
КонецФункции

&НаСервере
Функция ПолучитьПодразделениеМенеджера(Менеджер)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Пользователи.Подразделение КАК Подразделение
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|ГДЕ
		|	Пользователи.Ссылка = &Пользователь";
	
	Запрос.УстановитьПараметр("Пользователь", Менеджер);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Подразделение;
КонецФункции

#Область НовоеЦенообразование

&ИзменениеИКонтроль("ЗаполнитьУсловияПродажПоСоглашению")
Функция Док_ЗаполнитьУсловияПродажПоСоглашению(ПересчитыватьЦены = Истина) Экспорт
	
	ЦеныРассчитаны = Ложь;
	
	УсловияПродаж = ПродажиСервер.ПолучитьУсловияПродаж(Соглашение, Истина);
	ЗаполнитьУсловияПродаж(УсловияПродаж);
	
	ПараметрыЗаполнения = Документы.ЗаказКлиента.ПараметрыЗаполненияНалогообложенияНДСПродажи(ЭтотОбъект);
	УчетНДСУП.ЗаполнитьНалогообложениеНДСПродажи(НалогообложениеНДС, ПараметрыЗаполнения);
	
	СтруктураДействий = Новый Структура;
	
	Если ПересчитыватьЦены = Истина Тогда
		
		ПараметрыЗаполнения = Новый Структура;
		ПараметрыЗаполнения.Вставить("Дата", Дата);
		ПараметрыЗаполнения.Вставить("Организация", Организация);
		ПараметрыЗаполнения.Вставить("Валюта", Валюта);
		ПараметрыЗаполнения.Вставить("Соглашение", Соглашение);
		ПараметрыЗаполнения.Вставить("РассчитыватьНаборы", Истина);
		ПараметрыЗаполнения.Вставить("НалогообложениеНДС", НалогообложениеНДС);
		ПараметрыЗаполнения.Вставить("ВозвращатьМногооборотнуюТару", ВернутьМногооборотнуюТару);
		ПараметрыЗаполнения.Вставить("ПоляЗаполнения", "Цена, СтавкаНДС, ВидЦены, СрокПоставки");
		
		СтруктураДействий.Вставить("ПересчитатьСумму", "КоличествоУпаковок");
		СтруктураДействий.Вставить("ПересчитатьСуммуРучнойСкидки", "КоличествоУпаковок");
		СтруктураДействий.Вставить("ОчиститьАвтоматическуюСкидку", Неопределено);
		СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
		
		#Вставка     
		Если ДопМодуль.НовоеЦенообразование() Тогда
			ПараметрыЗаполнения.Вставить("Подразделение", Подразделение);
		КонецЕсли;
		#КонецВставки
		ЦеныРассчитаны = ЦеныПредприятияЗаполнениеСервер.ЗаполнитьЦены(
			Товары,,
			ПараметрыЗаполнения,
			СтруктураДействий);
		
	КонецЕсли;
	
	СтруктураПересчетаСуммы =
		ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(ЭтотОбъект);
	
	СтруктураДействий.Очистить();
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	
	ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьТЧ(Товары, СтруктураДействий);
	
	СтруктураПараметров = ДенежныеСредстваСервер.ПараметрыЗаполненияБанковскогоСчетаОрганизацииПоУмолчанию();
	СтруктураПараметров.Организация = Организация;
	СтруктураПараметров.БанковскийСчет = БанковскийСчет;
	СтруктураПараметров.НаправлениеДеятельности = УсловияПродаж.НаправлениеДеятельности;
	БанковскийСчет = ЗначениеНастроекПовтИсп.ПолучитьБанковскийСчетОрганизацииПоУмолчанию(СтруктураПараметров);
	
	БанковскийСчетКонтрагента = ЗначениеНастроекПовтИсп.ПолучитьБанковскийСчетКонтрагентаПоУмолчанию(Контрагент, , БанковскийСчетКонтрагента);
	
	Возврат ЦеныРассчитаны;
	
КонецФункции

