&НаСервере
Процедура СформироватьСсылкуНаОплату() 
	
	ПараметрыHTTPСоединения = Новый Структура;
	ПараметрыHTTPСоединения.Вставить("ИспользоватьSSL", Истина);
	ПараметрыHTTPСоединения.Вставить("АдресСервера", "tg-alterra.ru");
	ПараметрыHTTPСоединения.Вставить("Порт", 443);
	ПараметрыHTTPСоединения.Вставить("Логин", "");
	ПараметрыHTTPСоединения.Вставить("Пароль", "");
	
	АдресHTTPЗапроса = "/api/v1/order.getPaymentURI?id=";	
	
	Если ЗначениеЗаполнено(Объект.НомерНаСайте) Тогда
		АдресHTTPЗапроса = АдресHTTPЗапроса + Объект.НомерНаСайте;
	Иначе
		Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
			АдресHTTPЗапроса = АдресHTTPЗапроса + Объект.Ссылка.УникальныйИдентификатор();
		Иначе
			Сообщить("Сначала необходимо записать документ!");
			Возврат;
		КонецЕсли;
	КонецЕсли;
		
	СтруктураОтвета = ОбщийHTTPСервер.ПослатьGETЗапрос(ПараметрыHTTPСоединения, АдресHTTPЗапроса);

	// Тестирование ответа
	// СтруктураОтвета = ПолучитьМокОтветСсылки();
	
	Если ЗначениеЗаполнено(СтруктураОтвета) И ТипЗнч(СтруктураОтвета) = Тип("Структура") Тогда
		Если СтруктураОтвета.Свойство("response") Тогда
			response = СтруктураОтвета.response;
			Если ТипЗнч(response) = Тип("Структура") Тогда 
				Если response.Свойство("link") Тогда
					СсылкаНаОплату = response.link;
				КонецЕсли;
				
				Попытка
					Если response.Свойство("order_id") Тогда
						Объект.НомерНаСайте = response.order_id;
						ДокументОбъект = РеквизитФОрмыВЗначение("Объект"); 
						ДокументОбъект.Записать();
						ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
					КонецЕсли;
				Исключение
				КонецПопытки;
				
			Иначе
				Сообщить("Ошибка при разборе ответа. Свойство 'link' не обнаружено!");
			КонецЕсли;
		Иначе
			Сообщить("Ошибка при разборе ответа. Свойство 'response' не обнаружено!");
		КонецЕсли;
	КонецЕсли; 
	
КонецПроцедуры

