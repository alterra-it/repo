&НаКлиенте
Функция УстановитьОтметку_Устарела(Признак, Ссылка, ШК = Неопределено)
	ИспользуетсяПроверкаШК = РСОбщийМодульВызовСервера.ПользовательИспользуетПроверкуПоШтрихкоду(ПолучитьПользователя());
	
	Если НЕ ИспользуетсяПроверкаШК Тогда
		Возврат Не Признак;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ссылка", Ссылка);
	ПараметрыФормы.Вставить("Признак", Признак);
	ПараметрыФормы.Вставить("Штрихкод", ШК);
	
	Форма = ПолучитьФорму("Документ.РеализацияТоваровУслуг.Форма.ФормаПроверкиПоСекциям", ПараметрыФормы, ЭтаФорма);
	
	ПризнакНовый = Форма.ОткрытьМодально();
	
	Если ПризнакНовый = Неопределено Тогда
		Возврат Признак;
	Иначе
		Возврат ПризнакНовый;
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПроверитьОтметкуКассыУРеализаций(Заказ)
	
	Есть = Ложь;
	мРеализаций = АльтерраОбщегоНазначения.ПолучитьРеализацииПоЗаказу(Заказ);
	Для Каждого Реализация Из мРеализаций Цикл
		Если ЗначениеЗаполнено(Реализация.Кассир) Тогда
			АльтерраОбщегоНазначения.СообщитьПользователю(Реализация, Реализация);
			Есть = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Есть; 
	
