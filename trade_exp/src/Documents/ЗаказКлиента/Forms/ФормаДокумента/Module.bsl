&НаКлиенте
Процедура ОплатитьБонуснымиБаллами(Команда)
	
	Если Не ПроверитьВозможностьИзменения() И Объект.Товары.Итог("СуммаБонусныхБалловКСписанию") = 0 Тогда
		СообщениеОтказаИзменения();
		Возврат;
	КонецЕсли;
	
	Если Модифицированность Или Не Объект.Проведен Тогда
		Ответ = Неопределено;
		ПоказатьВопрос(Новый ОписаниеОповещения("ОткрытьФормуОплатыБаламиЗавершение", ЭтотОбъект),
		НСтр("ru = 'Неоходимо провести документ для выполнения операции. Провести документ?'"), РежимДиалогаВопрос.ДаНет);
		Возврат;
	КонецЕсли;
	
	Если ПроверитьВозможностьОплаты() Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуОплатыБаламиФрагмент();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуОплатыБаламиЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Ответ = РезультатВопроса;
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	ИначеЕсли Не Записать(Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение)) Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьФормуОплатыБаламиФрагмент();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуОплатыБаламиФрагмент()
		
	ПараметрыОткрытияФормы = Новый Структура;
	ПараметрыОткрытияФормы.Вставить("Партнер",                   Объект.Партнер);
	ПараметрыОткрытияФормы.Вставить("КартаЛояльности",           Объект.КартаЛояльности);
	ПараметрыОткрытияФормы.Вставить("АдресТабличнойЧастиТовары", АдресТабличнойЧастиТовары());
	ПараметрыОткрытияФормы.Вставить("Валюта",                    Объект.Валюта);
	ПараметрыОткрытияФормы.Вставить("Документ",                  Объект.Ссылка);
	
		ОткрытьФорму(
		"Справочник.БонусныеПрограммыЛояльности.Форма.ОплатаБонуснымиБаллами",
		ПараметрыОткрытияФормы,
		ЭтотОбъект,,,,
		Новый ОписаниеОповещения("ДобавитьОплатуБонуснымиБалламиЗавершение", ЭтотОбъект));
		
КонецПроцедуры
	
