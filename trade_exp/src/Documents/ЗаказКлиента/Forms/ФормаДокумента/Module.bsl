&НаКлиенте
Процедура Док_ПартнерПриИзменении(Элемент)
	ОчиститьСообщения();
	Док_ПартнерПриИзмененииНаСервере();
	СоглашениеПриИзменении(Неопределено); 
	Если Объект.СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки.Самовывоз") Тогда
		Объект.АдресДоставки = "";
	КонецЕсли;
    ОчиститьРеквизитыДоставкиДистрибуция();
	УстановитьВидимостьРеквизитовДоставкиДистрибуция();
КонецПроцедуры

&НаСервере
Процедура Док_ПартнерПриИзмененииНаСервере()
	
	Объект.Контрагент = АльтерраОбщегоНазначения.ПолучитьЕдинственногоКонтрагента(Объект.Партнер);

	Объект.КартаЛояльности = АльтерраОбщегоНазначения.ПолучитьКартуЛояльности(Объект.Партнер);
	Объект.Соглашение = АльтерраОбщегоНазначения.ПолучитьСоглашениеПоУмолчанию(Объект.Партнер, Объект.Подразделение, Объект.КартаЛояльности, Объект.Дата);
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ОчиститьБонусыВывестиСообщение();
	КонецЕсли;
	
	АльтерраОбщегоНазначения.ПолучитьДополнительнуюИнформациюПоПартнеру(Объект.Партнер);// Вывод сообщением дополнительной информации по клиенту
	ПоказатьИнформациюПоБонусам();
	УстановитьВидимостьЗапретаОтгрузкиПартнеру();
	Отказ = Ложь;
	АльтерраОбщегоНазначения.ЕстьПартнерСТакимТелефоном(Объект.Партнер, Отказ);
	Если Отказ Тогда
		Сообщить("Заполните у партнера его действительный номер телефона, иначе на кассе ЧЕК не пробъется!!!");
	КонецЕсли;
	
	ЗапретВидимостиБонусов();
	УстановитьТранзитФизЛицо(); 
	
КонецПроцедуры

