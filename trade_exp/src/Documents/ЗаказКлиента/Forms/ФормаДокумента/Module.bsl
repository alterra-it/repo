&НаКлиенте
Процедура Док_ПриОткрытии(Отказ)
	
	УстановитьСкидкиНаформе();	
	ЗапретВидимостиБонусов();
	Если НовыйПорядокНачисленияБонусов Тогда
		УстановитьУсловноеОформлениеСтрок();
		УстановитьУсловноеОформлениеПолей();
	КонецЕсли;
	
	ЕстьРольОтметкаКассы = ПроверитьРоль();
	Если ЕстьРольОтметкаКассы = Ложь Тогда 
		Элементы.ГруппаСоздатьНаОснованииПКОИЭквайринговаяОперация.Видимость = ложь;
	КонецЕсли;
	
    Если АльтерраОбщегоназначения.ЭтоБригадир(Объект.Партнер) Тогда
		Элементы.БонусныеБаллыСуммаБонусныхБалловЗаКп.Заголовок = "Доп. баллы";
		Элементы.ТоварыСуммаНачисленныхБалловЗаКП.Заголовок = "Доп. баллы";
    КонецЕсли;
    
  	ПроверитьQRНаОплату(); 
    
КонецПроцедуры 

