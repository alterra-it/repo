&НаКлиенте
&ИзменениеИКонтроль("ОтменитьВыделенныеСтрокиЗавершение")
Процедура Док_ОтменитьВыделенныеСтрокиЗавершение(Результат, ДополнительныеПараметры) Экспорт

	ПричинаОтмены = Результат;
	Если Не ЗначениеЗаполнено(ПричинаОтмены) Тогда
		Возврат;
	КонецЕсли;  
	
	#Вставка   
	ОчиститьБонусыВывестиСообщение();  
	#КонецВставки
	 
	ОтменитьВыделенныеСтрокиФрагмент(ПричинаОтмены);
   #Вставка 
   //АвтоопределениеДистрибуция. При новом распределении транспортных, если уже есть отгруженные строки,
   //то от неотгруженной услуги доставки нужно отнимать СуммуРТ отменяемых строк...
   Если Объект.РаспределитьТранспортныеДистрибуция Тогда 
	   ОтгруженныеСтроки = Объект.Товары.НайтиСтроки(Новый Структура("ОтметкаРеализации", Истина));
	   Если ОтгруженныеСтроки.Количество()>0 Тогда 
		   ВыделенныеСтроки = Элементы.Товары.ВыделенныеСтроки; 
		   СуммаРТ = 0;
		   Для Каждого Ид из  ВыделенныеСтроки Цикл 
			   Стр =  Объект.Товары.НайтиПоИдентификатору(Ид);
			   СуммаРТ = Стр.СуммаРТ + СуммаРТ;
			   Стр.СуммаРТ = 0;
		   КонецЦикла;
		   ИзменитьУслугуДоставки(СуммаРТ, ПричинаОтмены);
	   Иначе
		  РаспределитьТранспортныеДистрибуция(); 
	   КонецЕсли;
   КонецЕсли;
   #КонецВставки

КонецПроцедуры

