&НаСервере
Процедура ОчиститьБонусыВывестиСообщение()
	
	ОтметитьСтрокиСРеализацией();
	
	Отбор = Новый Структура;
	Отбор.Вставить("ОтметкаРеализации", Ложь);
	ТаблицаСтрокБезРеализации = Объект.Товары.НайтиСтроки(Отбор);
	
	СуммаОплатыБонусами = 0;
	
	Для Каждого Строка Из ТаблицаСтрокБезРеализации Цикл
		СуммаОплатыБонусами = СуммаОплатыБонусами + Строка.СуммаБонусныхБалловКСписаниюВВалюте
	КонецЦикла;
	
	Если СуммаОплатыБонусами > 0 Тогда
		//ОтметитьСтрокиСРеализацией();
		ОчиститьБонусыСервер();
		ОповещениеОбОчисткеБонусов(СуммаОплатыБонусами);
	КонецЕсли;
КонецПроцедуры

