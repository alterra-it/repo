#Область ОтправкаСмсКлиентуОГотовностиЗаказаСОбособленнымОбеспечением 
&НаСервере
Функция ОтправитьСообщениеКлиентуВопрос()
	
	// Проверяем было ли уже отправлено сообщение по этому заказу. Если да, тогда не спрашиваем и не отправляем повторно
	НаборЗаписей = РегистрыСведений.СобытияОбъектовАльтерра.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Установить(Объект.Ссылка);
	НаборЗаписей.Отбор.Событие.Установить(Справочники.СобытияОбъектовАльтерра.ОтправленаСМСклиентуОГотовности);
	НаборЗаписей.Прочитать();
	Если НаборЗаписей.Количество()> 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Состояние = Перечисления.СостоянияЗаказовКлиентов.Закрыт Тогда
		Возврат Ложь;
	КонецЕсли;
		
	Товары = Объект.Товары.Выгрузить();
	Товары.Свернуть("Отменено, ВариантОбеспечения, Обособленно");

	ЗаказСОбособленнымОбеспечением = Новый ТаблицаЗначений();
	ЗаказСОбособленнымОбеспечением.Колонки.Добавить("ВариантОбеспечения");
	
	НеОтгружено = Новый ТаблицаЗначений();
	НеОтгружено.Колонки.Добавить("ВариантОбеспечения");

	Для Каждого Стр Из Товары Цикл
		
		Если Стр.Отменено Тогда
			Продолжить;
		КонецЕсли;
						
		Если НЕ Стр.ВариантОбеспечения = Перечисления.ВариантыОбеспечения.Отгрузить Тогда  //(Стр.Обособленно ИЛИ)
			СтрокаН = НеОтгружено.Добавить();
			СтрокаН.ВариантОбеспечения = Стр.ВариантОбеспечения;
		КонецЕсли;
	
		Если Стр.Обособленно Тогда
			СтрокаЗ = ЗаказСОбособленнымОбеспечением.Добавить();
			СтрокаЗ.ВариантОбеспечения = Стр.ВариантОбеспечения;
		КонецЕсли;
	КонецЦикла;
	
	Если ЗаказСОбособленнымОбеспечением.Количество() > 0 Тогда 
		Если НеОтгружено.Количество() > 0 Тогда 
			Возврат Ложь;
		Иначе 
			Возврат Истина;
		КонецЕсли;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ПослеЗакрытияВопроса(Результат, Параметры) Экспорт
 
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОтправитьСообщениеКлиентуОГотовностиЗаказа()	
	КонецЕсли;	
 
КонецПроцедуры

&НаСервере
Процедура ОтправитьСообщениеКлиентуОГотовностиЗаказа()

	Если ТелефонПартнера <> "" Тогда  
	НомерТелефонаПартнера = АльтерраОбщегоНазначения.ПолчитьТелефонБезКода(ТелефонПартнера);
		Если СтрДлина(НомерТелефонаПартнера) = 10 Тогда
			СтрокаНомерТелефона = "+7" + Строка(НомерТелефонаПартнера);
			//ТекстСообщения = СтрШаблон("Заказ № %1 готов к выдаче. Подробнее по телефону %2", Объект.Номер, Объект.Склад.Подразделение.НомерКонтактногоЦентраПодразделения);
			ТекстСообщения = СтрШаблон("Заказ № %1 готов к выдаче. Подробнее по тел. %2", Объект.Номер, "8 (3852) 548-301");
			АльтерраОбщегоНазначения.ОтправитьСМС(СтрокаНомерТелефона, ТекстСообщения);
			Сообщить("СМС сообщение отправлено");
			Запись = РегистрыСведений.СобытияОбъектовАльтерра.СоздатьМенеджерЗаписи();
			Запись.Период = ТекущаяДата();
			Запись.Объект = Объект.Ссылка; 
			Запись.Событие = Справочники.СобытияОбъектовАльтерра.ОтправленаСМСклиентуОГотовности; 
			Запись.Записать();  
		Иначе 
			Сообщить("Некорректный номер телефона");
		КонецЕсли;
	Иначе 
		Сообщить("Телефонный номер пуст");
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти

&НаКлиенте
Процедура Док_ТоварыПередНачаломДобавленияПосле(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Если Не Отказ Тогда
		ОчиститьРаспределение();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыПриНачалеРедактированияПосле(Элемент, НоваяСтрока, Копирование)
	Если Копирование Или НоваяСтрока Тогда
		ДобавляемаяСтрока = Элемент.ТекущиеДанные;
		ДобавляемаяСтрока.ОтметкаРеализации = Ложь;
		
		ДобавляемаяСтрока.ПроцентРучнойСкидки = 0;
		ДобавляемаяСтрока.ПроцентРучнойСкидки_СтароеЗначение = 0;
		ДобавляемаяСтрока.Номенклатура_СтароеЗначение = ПредопределенноеЗначение("Справочник.Номенклатура.ПустаяСсылка");
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыПослеУдаленияПосле(Элемент)
	ОчиститьРаспределение(); 
	РасчитатьВесОбъем();
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
	    РаспределитьТранспортныеДистрибуция();
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыНоменклатураПриИзмененииПосле(Элемент)
	ТекущаяСтрока=Элементы.Товары.ТекущиеДанные;
	ТекущаяСтрока.ИндексМТ=ПолучитьИндексМТ(ТекущаяСтрока.Номенклатура);
	Элементы.ТоварыИндексМТ.Видимость=Объект.Товары.Итог("ИндексМТ")>0;
	ОчиститьРаспределение();  
	РаспределитьТранспортныеДистрибуцияПриИзмененииСтроки(); 
КонецПроцедуры

