	РаспределитьТранспортныеДистрибуция();
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьРаспределение()
	
	Коллекция = Объект.Товары;
	ПроверкаИтоговПоСтрокам = 
		Коллекция.Итог("СуммаСНДСРТ") + 
		Коллекция.Итог("СуммаНДСРТ") + 
		Коллекция.Итог("СуммаРТ") + 
		Коллекция.Итог("Распределять");

	Если ПроверкаИтоговПоСтрокам = 0 И Не Объект.РаспределитьТранспортные Тогда 
		Возврат;
	КонецЕсли;

	Для Каждого Элемент Из Коллекция Цикл
		Элемент.СуммаСНДСРТ = 0;
		Элемент.СуммаНДСРТ = 0;
		Элемент.СуммаРТ = 0;
		Элемент.Распределять = 0;
	КонецЦикла;

	Объект.РаспределитьТранспортные = Ложь;
	Элементы.ТоварыРаспределять.Видимость = Ложь;
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ОткрытьЗаписиРегистраСобытийПосле(Команда) 
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Отбор", УстановитьОтбор());
	ПараметрыФормы.Вставить("КлючНазначенияИспользования", Новый УникальныйИдентификатор);
	ОткрытьФорму("РегистрСведений.СобытияОбъектовАльтерра.ФормаСписка", ПараметрыФормы); 
	
КонецПроцедуры

&НаСервере
