&НаСервере
Процедура ДобавитьУправляемуюСкидкуНаСервере(Добавить,ИмяСкидки)
	
	ОчиститьБонусыВывестиСообщение(); 
	Объект.СкидкиРассчитаны = Ложь;
	
	Скидка = Справочники.СкидкиНаценки.НайтиПоНаименованию(ИмяСкидки);
	Если добавить Тогда
		УправляемыеСкидки.Добавить(Скидка, Истина);
	Иначе
		УправляемыеСкидки.Удалить(УправляемыеСкидки.НайтиПоЗначению(Скидка));
	КонецЕсли;
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Ложь);
	СтруктураПараметры.Вставить("УправляемыеСкидки", УправляемыеСкидки);
	
	Если Не ИмяСкидки = "Наценка на оплату картой" Тогда
		СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры);
	Иначе
		СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере2(СтруктураПараметры);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция НайтиСкидку(имяскидки) 
	
	Скидка = Справочники.СкидкиНаценки.НайтиПоНаименованию(ИмяСкидки);
	Если Объект.СкидкиНаценки.Выгрузить().ВыгрузитьКолонку("СкидкаНаценка").Найти(Скидка) <> Неопределено Тогда
		УправляемыеСкидки.Добавить(Скидка);
		результат = Истина;
	Иначе
		результат = Ложь;	
	КонецЕсли;
	Возврат результат;	
	
КонецФункции 

&НаКлиенте
Процедура УстановитьСкидкиНаформе()	
	_НаценкаКарта = НайтиСкидку("Наценка на оплату картой");	
КонецПроцедуры

&НаСервере
Функция РассчитатьСкидкиНаценкиНаСервере2(СтруктураПараметры, ВзятьИзВременногоХранилища = Ложь)
	
	ПримененныеСкидки = СкидкиНаценкиЗаполнениеСервер.Рассчитать(Объект, СтруктураПараметры);
	
	//+Альтерра
	Для каждого Строка Из Объект.Товары Цикл
		Если Не Строка.ОтметкаРеализации Тогда
			БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, Строка);
		КонецЕсли;
	КонецЦикла;
	//-
	
	Объект.СкидкиРассчитаны = Истина;
	ОбновитьДубликатыЗависимыхРеквизитов();
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);
	
	СтруктураСообщений = СкидкиНаценкиЗаполнениеСервер.СтруктураСообщений(Объект);
	СкидкиНаценкиЗаполнениеСервер.НастроитьКомандуПоказатьСообщения(Объект, Элементы.ПоказатьСообщения);
	
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		АльтерраОбщегоНазначения.ПересчитатьЦенуСДоставкойПечать(Объект.Товары);
	КонецЕсли;
	
	Возврат СтруктураСообщений;
	
КонецФункции
#КонецОбласти


