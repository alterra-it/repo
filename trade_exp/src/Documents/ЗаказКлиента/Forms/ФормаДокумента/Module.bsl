&НаКлиенте
Процедура ЗаполнитьВариантОбеспеченияКП()
	
	Для Каждого СтрокаТабличнойЧасти Из Объект.Товары Цикл
        СтрокаТабличнойЧасти.ВариантОбеспечения = ПредопределенноеЗначение("Перечисление.ВариантыОбеспечения.НеТребуется");
	КонецЦикла; 
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТипКПЗаказПриИзмененииПосле(Элемент)
	
	Если НЕ РазрешеноИзменятьПроизвольныеЦены() Тогда
		Если Не РазрешеныПроизвольныеЦеныТранзин() Тогда
		Если ТипКПЗаказ = "КП" Тогда
			Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.НеСогласован");
			Объект.КоммерческоеПредложение = Истина;
			ЗаполнитьВариантОбеспеченияКП();
			УстановитьДоступностьЭлементовПоСтатусуСервер();
		ИначеЕсли ТипКПЗаказ = "Заказ" Тогда
			Для каждого Строка Из Объект.Товары Цикл
				Если НЕ ПроверкиАльтерраСервер.РазрешеноИзменятьВидЦены(Объект) Тогда
					Если НЕ ВидЦеныПроизвольный(Строка.ВидЦены) Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Запрещено менять заказ клиента на ""Заказ"" т.к присутствуют произвольные цены и отсутствуют права на установку произвольных цен");
						Объект.КоммерческоеПредложение = Истина;
						ТипКПЗаказ = "КП";
						Возврат;
					КонецЕсли;
				КонецЕсли;
				Если Строка.Цена = 0 Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнено колонка ""Цена"" в строке " + Строка.НомерСтроки);
					Объект.КоммерческоеПредложение = Истина;
					ТипКПЗаказ = "КП";
					Возврат; 
				КонецЕсли;
				Если НЕ ПроверкаВидЦены(Строка.ВидЦены) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Запрещено менять тип заказа с видом цены: " + Строка.ВидЦены);
					ТипКПЗаказ = "КП";
					Возврат
				КонецЕсли;
			КонецЦикла;	
			Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению");
			Объект.КоммерческоеПредложение = Ложь;
			УстановитьДоступностьЭлементовПоСтатусуСервер();
		КонецЕсли;
		КонецЕсли;
		УправлениеВидимостьюДоступностьюКоманд();
		ВидимостьПечатиКомплеткаДокументов();
	КонецЕсли;
	Если ТипКПЗаказ = "КП" Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.НеСогласован");
		Объект.КоммерческоеПредложение = Истина;
		ЗаполнитьВариантОбеспеченияКП();
		УправлениеВидимостьюДоступностьюКоманд();
	ИначеЕсли	ТипКПЗаказ = "Заказ" Тогда
		Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению");
		Объект.КоммерческоеПредложение = Ложь;
	КонецЕсли;	
КонецПроцедуры

&НаСервере
Функция ПроверкаВидЦены(ВидЦены)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ВидыЦен.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыЦен КАК ВидыЦен
	|ГДЕ
	|	ВидыЦен.Родитель.Наименование Подобно ""Розница%""
	|	И ВидыЦен.Ссылка = &ВидЦены";
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Выборка = Запрос.Выполнить();
	Возврат НЕ Выборка.Пустой();
КонецФункции

&НаСервере
Процедура Док_МенеджерПриИзмененииПослеНаСервере()
	Объект.Магазин = ЗначениеНастроекПовтИсп.ПодразделениеПользователя(Объект.Менеджер, Неопределено);
КонецПроцедуры

&НаКлиенте
Процедура Док_МенеджерПриИзмененииПосле(Элемент)
	
	Если Объект.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению") Тогда
		Док_МенеджерПриИзмененииПослеНаСервере();
	КонецЕсли;
	Док_МенеджерПриИзмененииПослеНаСервере1();
	ПроверитьЗаполнениеСклада();
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполнениеСклада() 
	
	Если Не ЗначениеЗаполнено(Объект.Склад) Тогда
		Объект.Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка(); 
	Иначе
		Объект.Подразделение = Объект.Склад.Подразделение;
	КонецЕсли;
	
КонецПроцедуры	

&НаКлиенте
Процедура Док_ТоварыКоличествоУпаковокПриИзмененииВместо(Элемент)
	
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	//ПроверкаОплатыБонуснымиБаллами(ТекущаяСтрока);
	
	СтруктураДействий = Новый Структура;
	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий,Объект);
	ДобавитьДействияОбеспеченияНаКлиенте(СтруктураДействий, "ДоступноВДругихСтроках");
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	Если ОбеспечениеВДокументахКлиент.ТребуетсяОбновитьКолонкуДоступно(СтруктураДействий) Тогда
		ОбновитьКолонкуДоступноСервер();
	КонецЕсли;
	
	//Док_ОбработатьБонуснуюЧасть();
	
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтаФорма);
	РаспределитьТранспортныеДистрибуцияПриИзмененииСтроки();
КонецПроцедуры

