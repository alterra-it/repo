	МассивБлокировки.Добавить("Товары_ДобавитьУслугуБезНДС");
	МассивБлокировки.Добавить("ТоварыРаспределитьТранспортные");

	ОбщегоНазначенияУТКлиентСервер.УстановитьСвойствоЭлементовФормы(Элементы, МассивБлокировки, "ТолькоПросмотр", флаг);
	
