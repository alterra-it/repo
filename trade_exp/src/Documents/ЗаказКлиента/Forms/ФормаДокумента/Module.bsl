
&НаКлиенте
Процедура Док_СтатусПриИзмененииПосле(Элемент)
	Если Объект.КоммерческоеПредложение Тогда
	Если НЕ РазрешеноИзменятьПроизвольныеЦены() Тогда
		Если НЕ РазрешеныПроизвольныеЦеныТранзин() Тогда
		Если Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОтгрузке") ИЛИ
		 	 Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению") Тогда
		 	 	
			СтруктураОтбора = Новый Структура("ВидЦены",ПредопределенноеЗначение("Справочник.ВидыЦен.ПустаяСсылка"));	 	
			СтрокиПускойВидЦены = Объект.Товары.НайтиСтроки(СтруктураОтбора);	
			Если СтрокиПускойВидЦены.Количество() <> 0 Тогда
			 	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Недостаточно прав. В заказе есть произвольные цены");
				Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.НеСогласован");
				Возврат; 
			КонецЕсли; 	 	
			Для Каждого Строка из Объект.Товары Цикл
				Если НЕ ПроверкаВидЦены(Строка.ВидЦены) Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Запрещено менять статус заказа с видом цены: " + Строка.ВидЦены);
					Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.НеСогласован");
					Возврат;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция РазрешеноИзменятьПроизвольныеЦены()
	Возврат  НЕ РольДоступна("ЗапретИзменениеВидаЦеныВДокументе");
КонецФункции

&НаСервере
Функция РазрешеныПроизвольныеЦеныТранзин()
	Возврат РольДоступна("ОтделДистрибуции") И НЕ Объект.Склад.НеРазрешеноРедактированиеЦены;     
КонецФункции

&НаКлиенте
Процедура Док_ПартнерОбработкаВыбораПосле(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	//158234 запись в чек способ ввода клиента
    СпособВводаКлиента = ПредопределенноеЗначение("Перечисление.СпособВводаКлиента.РучнойВвод");
    Объект.СпособВводаКлиента = СпособВводаКлиента;    
КонецПроцедуры

&НаКлиенте             
Процедура Док_ПриОткрытииПосле(Отказ)  	
	СвойстваВыполнитьОтложеннуюИнициализацию();
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);		
	ЗаполнитьГруппуДопРеквизитов();
	ВидимостьПечатиКомплеткаДокументов();
	УстановитьВидимостьРеквизитовДоставкиДистрибуция();
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
	   ТранспортныеИтог = АльтерраОбщегоНазначенияКлиент.ПолучитьТранспортныеИтог(Объект);
	КонецЕсли;
КонецПроцедуры  

&НаКлиенте
Процедура ВидимостьПечатиКомплеткаДокументов()
	Элементы.ПодменюПечатьОбычное__КомплектДокументов.Видимость = НЕ Объект.КоммерческоеПредложение;
    Элементы.ПодменюПечатьОбычное__КомплектДокументовСНастройкой.Видимость = НЕ Объект.КоммерческоеПредложение;
КонецПроцедуры

&НаСервере
Функция ПроверитьРоль()
	
	Возврат РольДоступна("ОтметкаКассы");
		
КонецФункции

#Область ДинамическиеСсылки

&НаСервереБезКонтекста
Функция	ПереактивироватьQRНаОплату(Заказ)
	
	Если ИнтеграцияБанки.НужнаПереактивацияДинамическойСсылки(Заказ).Результат Тогда
		РезультатАктивации = ИнтеграцияБанки.АктивироватьДинамическуюСсылку(Заказ, ПредопределенноеЗначение("Перечисление.ТипДинамическойСсылки.СБП"));	
		Если Не РезультатАктивации.Результат Тогда
			Сообщить(РезультатАктивации.Сообщение);
		КонецЕсли;
	КонецЕсли;
	
КонецФункции	

&НаКлиенте
Процедура ПроверитьQRНаОплату()
	
	QRНаОплату = ИнтеграцияБанки.ПолучитьАктивированнуюДинамическуюСсылку(Объект.Ссылка).Ответ.СсылкаОплаты;
	
	Элементы.АктивированQRНаОплату.Видимость = QRНаОплату <> "";
	Если Элементы.АктивированQRНаОплату.Видимость И Не Элементы.ФормаОплатаНаМесте.Видимость Тогда
		Элементы.ФормаОплатаНаМесте.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_АктивированQRНаОплатуПеред(Команда)

	Если QRНаОплату <> "" Тогда
		ЗапуститьПриложение(QRНаОплату);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура Док_ОплатаНаМестеПеред(Команда)
	
	ВозможностьВозврата = ИнтеграцияБанки.ПолучитьОплатуДинамическойСсылки(Объект.Ссылка);	
		
	Если ВозможностьВозврата.ТребуетсяВозврат Тогда
		
		Если Не Объект.Проведен Тогда
			Сообщить("Необходимо провести документ");
			Возврат;
		КонецЕсли;
		
		Если Модифицированность Тогда
			Сообщить("Необходимо записать документ");
			Возврат;
		КонецЕсли;	
		
		ОповещениеОбОплате = Новый ОписаниеОповещения("ПослеОплатыДС", ЭтотОбъект);
		//ОткрытьФорму("Обработка.БезналичнаяОплатаБезПодключенияОборудования.Форма", Новый Структура("ДокументПродажи", Объект.Ссылка),,,,, ОповещениеОбОплате);	
		ОткрытьФорму("Обработка.БезналичнаяОплатаБезПодключенияОборудования.Форма.ФормаВозвратаДС", Новый Структура("ВозможностьВозврата", ВозможностьВозврата),,,,, ОповещениеОбОплате);

	Иначе
		Сообщить("Возврат невозможен: возвращаемая сумма равна нулю");
	КонецЕсли;
	
КонецПроцедуры  

&НаКлиенте
Процедура ПослеОплатыДС(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если ТипЗнч(РезультатЗакрытия) = Тип("Булево") И РезультатЗакрытия Тогда
		Прочитать();
	КонецЕсли;
	
КонецПроцедуры

#Конецобласти

&После ("Подключаемый_ВыполнитьКоманду")
&НаКлиенте
Процедура Док_Подключаемый_ВыполнитьКоманду(Команда)
	
	Если 	Команда.Имя = "ПодменюПечатьОбычное__ПечатьСчета"
		Или Команда.Имя = "ПодменюПечатьОбычное__ПечатьСчетаФаксимиле" 
		Или Команда.Имя = "ПодменюПечатьОбычное__ПечатьСчетаФаксимилеВМ3"
		Или Команда.Имя = "ПодменюПечатьОбычное__ПечатьСчетаШтрихкоды" 
		Или Команда.Имя = "ПодменюПечатьОбычное__ПечатьКоммерческогоПредложения"
		Или Команда.Имя = "ПодменюПечатьОбычное__ПечатьКоммерческогоПредложенияСИзображениями" Тогда

			ПодключитьОбработчикОжидания("ПроверитьQRНаОплату", 10, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура Док_ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	ДопМодуль.ПроверитьВозможностьРучныхСкидкок(Отказ, Объект.Товары, Объект.Соглашение);
	
	Если ТекущийОбъект.ССайта И ТекущийОбъект.Партнер.ЮрФизЛицо = Перечисления.КомпанияЧастноеЛицо.ЧастноеЛицо И ТекущийОбъект.Партнер <> Справочники.Партнеры.РозничныйПокупатель Тогда
		Если Объект.Ссылка.Статус = Перечисления.СтатусыЗаказовКлиентов.НеСогласован И ТекущийОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению Тогда
			АльтерраОбщегоНазначения.ЗаполнитьПочтуИТелефонВКлиентеПоКомментарию(ТекущийОбъект);
		КонецЕсли;
	КонецЕсли;
	
	ТекущийОбъект.СуммаДокументаОбщая = ТекущийОбъект.Товары.Итог("СуммаСНДС");
	
	Если ТекущийОбъект.Ссылка.СуммаДокумента <> ТекущийОбъект.СуммаДокумента Тогда
		Документы.ЗаданиеНаПеревозкуРейс.СнятьСогласование(ТекущийОбъект.Ссылка);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущийОбъект.Ссылка.Кассир) Тогда
		БонусыАльтерраРезерв.НачислитьБонусныеБаллы(ТекущийОбъект);
	КонецЕсли;
	
	УстановитьТранзитФизЛицо();
	
	Если Регламент Тогда
		ТекущийОбъект.ДополнительныеСвойства.Вставить("Регламент", Истина);
	КонецЕсли;

	Если ТекущийОбъект.ИспользуетсяДоговор И ЗначениеЗаполнено(ТекущийОбъект.Договор) Тогда
		ПорядокРасчетовДоговор = АльтерраОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Договор, "ПорядокРасчетов");
		Если ТекущийОбъект.ПорядокРасчетов <> ПорядокРасчетовДоговор Тогда
			ТекущийОбъект.ПорядокРасчетов = ПорядокРасчетовДоговор;  
		КонецЕсли;
	КонецЕсли;
	РасчитатьВесОбъем(); 
		
КонецПроцедуры

&НаСервере
Процедура Док_ПослеЗаписиНаСервереПосле(ТекущийОбъект, ПараметрыЗаписи)
	
	Регламент = Ложь;
	
	УстановитьВидимостьДоступностьДополнительно();
	УстановитьДоступностьПоОтметкеКассы();
	
	Если Объект.ПередатьНаСайт Тогда
		Документы.ЗаказКлиента.СоздатьЭквайринговуюОперацию(Объект.Ссылка);
	КонецЕсли;               
	
	ДопМодуль.СохранитьПроцентРучнойСкидки(Объект.Товары);
	
	ПеренестиВКалендарьЗначение = ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "ПеренестиВКалендарь");
	Если ПеренестиВКалендарьЗначение <> Неопределено Тогда
		Если  ПеренестиВКалендарьЗначение И Объект.ИДСобытия = "" Тогда
			ДобавитьСобытиеВ_КалендарьБитрикс();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)

	Если (Объект.ССайта ИЛИ Объект.ПередатьНаСайт) И Объект.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению") Тогда
		Док_ПослеЗаписиПослеНаСервере(Объект.Ссылка);
	КонецЕсли;   
	
	ОтметитьСтрокиСРеализацией();
	ПоказатьИнформациюПоБонусам();
	
	Если ОтправитьСообщениеКлиентуВопрос() Тогда
		Оповещение = Новый ОписаниеОповещения("ПослеЗакрытияВопроса", ЭтотОбъект);	
    	ПоказатьВопрос(Оповещение, "Заказ полностью скомплектован. Отправить СМС клиенту?", РежимДиалогаВопрос.ДаНет); 
	КонецЕсли;
	
	ПроверитьQRНаОплату();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура Док_ПослеЗаписиПослеНаСервере(Заказ)
	
	УстановитьПривилегированныйРежим(Истина); 
	
	// Перезаполнение ЭО
	Выборка = Документы.ОперацияПоПлатежнойКарте.ПолучитьЭквайринговуюОперацию(Заказ);   
	Пока Выборка.Следующий() Цикл
		ЭО = Выборка.Ссылка;
		ПерезаполнитьЭО = Ложь;   
		Для каждого Строка из ЭО.РасшифровкаПлатежа Цикл 
			Если Строка.ОбъектРасчетов <> Заказ.ОбъектРасчетов Тогда
				ПерезаполнитьЭО = Истина;
				Прервать;
			КонецЕсли;	
		КонецЦикла;                                                   	
		Если Заказ.СуммаДокумента <> ЭО.СуммаДокумента ИЛИ ПерезаполнитьЭО Тогда
			ДокЭО = ЭО.ПолучитьОбъект();
			ДокЭО.РасшифровкаПлатежа.Очистить();
			ДокЭО.Заполнить(Заказ);
			Попытка
				ДокЭО.Записать();
				ОбщегоНазначения.СообщитьПользователю("Обновлена: "+ДокЭО.Ссылка, ДокЭО.Ссылка);
			Исключение
				ОбщегоНазначения.СообщитьПользователю("Не удалось записать документ " + ДокЭО.ссылка,ДокЭО.Ссылка);
				
				Инфо = ИнформацияОбОшибке();
				
				ЗаписьЖурналаРегистрации((ОбщегоНазначенияЕГАИСКлиентСервер.СобытиеЖурналаРегистрации()),
				УровеньЖурналаРегистрации.Ошибка,,Заказ,
				НСтр("ru='Описание=';en='Description='") + Инфо.Описание + "'  
				|" + НСтр("ru='ИмяМодуля=';en='ModuleName='") + Инфо.ИмяМодуля + "' 
				|" + НСтр("ru='НомерСтроки=';en='LineNumber='") + Инфо.НомерСтроки + "' 
				|" +НСтр("ru='ИсходнаяСтрока=';en='SourceLine='") + Инфо.ИсходнаяСтрока + "' ");
				
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
  
	ПереактивироватьQRНаОплату(Заказ);
	
	УстановитьПривилегированныйРежим(Ложь); 
		
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьДоступностьДополнительно()
	
	 Элементы.ГруппаДоставкаДоПолучателяДопИнфо.Видимость = Ложь;
	 Элементы.ОсобыеУсловияПеревозки.Видимость = Ложь;
	 Элементы.ОсобыеУсловияПеревозкиОписание.Видимость = Ложь;
	 Элементы.ГруппаЗонаВремя.Видимость = Ложь;
	
	//Транзит
	ЭтоТразнит = Объект.ТранзитФизЛицо;
	Элементы.ГруппаТранзитФизлицо.Видимость = ЭтоТразнит;
	Элементы.ТоварыДобавитьУслугуПоТранзитам.Видимость = ЭтоТразнит;
	Элементы.Товары_ДобавитьУслугуБезНДС.Видимость = Не ЭтоТразнит;
	Элементы.РаспределениеТранспортныхРасходов.Видимость = ЭтоТразнит;
	
	//Реализованные строки
	Если Объект.Товары.НайтиСтроки(Новый Структура("ОтметкаРеализации", Истина)).Количество() > 0 Тогда
		Элементы.Партнер.ТолькоПросмотр = Истина;
		Элементы.Контрагент.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если Не (АльтерраОбщегоНазначения.ЭтоБригадир(Объект.Партнер)
		Или АльтерраОбщегоНазначения.ЭтоЧастноеЛицо(Объект.Партнер))
	Тогда
		Элементы.НачисленныБаллы.Видимость = Ложь;
		Элементы.ТоварыСуммаБонусныхБалловКСписаниюВВалюте.Видимость = Ложь;
	Иначе
		Элементы.НачисленныБаллы.Видимость = Истина;
		Элементы.ТоварыСуммаБонусныхБалловКСписаниюВВалюте.Видимость = Истина;
	КонецЕсли;     
	
	// Возврат по динамической ссылке
	Элементы.ФормаОплатаНаМесте.Видимость = ИнтеграцияБанки.ПолучитьОплатуДинамическойСсылки(Объект.Ссылка).ТребуетсяВозврат;	
		
КонецПроцедуры

&НаСервере
Процедура ОтметитьСтрокиСРеализацией()
	
	Если Не ЗначениеЗаполнено(Объект.Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	Результат = БонусыАльтерраРезерв.ПолучитьСтрокиИзРеализацийПоЗаказу(Объект.Ссылка);
	
	//АвтоопределениеДистрибуция
	Если  Результат.Пустой() Тогда
		Элементы.Товары.ТолькоПросмотр = Ложь; 
		Возврат;
	Иначе
		Если Объект.РаспределитьТранспортныеДистрибуция Тогда
			Элементы.Товары.ТолькоПросмотр = Истина; 
			//Элементы.ТоварыВариантОбеспечения.ТолькоПросмотр = Ложь;
		КонецЕсли;
		Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Видимость = Ложь;  		
	КонецЕсли;
	//

	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		Строка = Объект.Товары.НайтиСтроки(Новый Структура("КодСтроки",Выборка.КодСтроки));
		Если Строка.Количество() > 0 Тогда
			Строка[0].ОтметкаРеализации = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервере
Процедура УстановитьУсловноеОформлениеСтрок()

    Элемент = УсловноеОформление.Элементы.Добавить();
    
    ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
    ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(Элементы.Товары.Имя);
    
    ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
    ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.ОтметкаРеализации");
    ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = Истина;
    
    Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
    Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
    
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеПолей()
	
	ИменаПолей = Новый Массив;
	ИменаПолей.Добавить("ТоварыСуммаБонусныхБалловКСписаниюВВалюте");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБонусныхБалловВВалюте");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБалловЗаСтатус");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБалловЗаКП");
	ИменаПолей.Добавить("ТоварыСуммаНачисленныхБалловПрочее");
	
	Для Каждого ИмяПоля Из ИменаПолей Цикл
		Элемент = УсловноеОформление.Элементы.Добавить();
		
		ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
		ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
		
		ГруппаОтбора = Элемент.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
		ГруппаОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли; 
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.СуммаРучнойСкидки");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Больше;
		ОтборЭлемента.ПравоеЗначение = 0;
		
		ОтборЭлемента = ГруппаОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Объект.Товары.ВидЦены");
		ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		ОтборЭлемента.ПравоеЗначение = Справочники.ВидыЦен.ПустаяСсылка();
		
		Элемент.Оформление.УстановитьЗначениеПараметра("ТолькоПросмотр", Истина);
		Элемент.Оформление.УстановитьЗначениеПараметра("ЦветФона", WebЦвета.СветлоРозовый);
	КонецЦикла;

КонецПроцедуры

