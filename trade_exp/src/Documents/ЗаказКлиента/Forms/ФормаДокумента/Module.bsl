 &НаСервере
функция РаспределитьТранспортныеДистрибуцияНаСервере(Второйвариант)
	Если Объект.Товары.НайтиСтроки(Новый Структура("Отменено",Истина)).Количество() > 0 Тогда
		ТЗбезОтмененныхСтрок =Объект.Товары.Выгрузить();    
		ТЗбезОтмененныхСтрок = ТЗбезОтмененныхСтрок.Скопировать(Новый Структура("Отменено", Ложь)); 
	КонецЕсли;
 	Результат = УправлениеЛогистикойСервер.РаспределениеСтоимостиДоставкиДистрибуция(Объект,ТЗбезОтмененныхСтрок,,,ВторойВариант);
 	ТранспортныеИтог = Результат.ТранспортныеИтог;
    Возврат	 Результат.СтоимостьДоставки;
 КонецФункции
 
&НаКлиенте
Процедура УстановитьВидимостьРеквизитовДоставкиДистрибуция() 
	
	КлиентДистрибуцииИлиКоммерческого = АльтерраОбщегоНазначения.КлиентДистрибуцииИлиКоммерческого(Объект.Партнер); 
	
    Элементы.ОбъектДоставки.Видимость    = КлиентДистрибуцииИлиКоммерческого;
    Элементы.Тариф.Видимость             = КлиентДистрибуцииИлиКоммерческого;
	Элементы.ТарифЗаКГ.Видимость         = КлиентДистрибуцииИлиКоммерческого;   
	Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Видимость = КлиентДистрибуцииИлиКоммерческого И Не Элементы.Товары.ТолькоПросмотр; 
	                             
	УстановитьВидимостьПоРаспределитьТранспортные();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьПоРаспределитьТранспортные()
    Элементы.ТоварыЦенаСДоставкойПечать.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Элементы.ТоварыСуммаРучнойСкидки.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Элементы.ТранспортныеИтог.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Элементы.ТоварыПроцентТранспортных.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Элементы.ТранспортныеИтог.Видимость = Объект.РаспределитьТранспортныеДистрибуция;
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
         Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Заголовок = "Снять распределение транспортных дистрибуция";
	Иначе
		 Элементы.ТоварыВызватьРаспределениеТранспортныхДистрибуция.Заголовок = "Распределить транспортные дистрибуция";
	Конецесли;
КонецПроцедуры

