&НаКлиенте
Процедура Док_СоздатьБППоЗаказуССайтаПеред(Команда)
	ОчиститьСообщения();
	Если Модифицированность Тогда
		Отказ = Истина;
        ТекстВопроса = НСтр("ru = 'Перед запуском БП необходимо сохранить изменения. Перепровести документ?'");
        Оповещение = Новый ОписаниеОповещения("ВопросПередЗаписьюЗавершение", ЭтотОбъект);
        ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
	Иначе
		Если Объект.НомерНаСайте <> "" Тогда
			ЗапуститьБППоЗаказуССайта(ОпределитьТипБП());
		Иначе
			Сообщить("Не заполнен номер заказа на сайте. БП не запущен");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВопросПередЗаписьюЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		Записать();
		ЗапуститьБППоЗаказуССайта(ОпределитьТипБП());
	КонецЕсли;
        
КонецПроцедуры

&НаСервере
Процедура ЗапуститьБППоЗаказуССайта(ТипБП)
	
	ИДТипаБлока = "lists_socnet";
	ИДБлока = "89";
	КодЭлементаПроцесса = Формат(ТекущаяДата(), "ДФ=ггггММддЧЧммсс");
	
	ТекущийПользовательБитрикс = АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Пользователи.ТекущийПользователь());
	ТипКлиента = "ТЗ";
	ДанныеДляРасшифровки = "Склад: " + Объект.Склад.Наименование+Символы.ПС + "Интернет-заказ: "+Строка(Объект.Номер)+Символы.ПС;
	Если ТипБП = "ОД" ИЛИ ТипБП = "КР" Тогда
		ДанныеДляРасшифровки = ДанныеДляРасшифровки+Строка(Объект.Партнер.ОсновнойМенеджер)+Символы.ПС;
		Подразделение = Объект.Партнер.ОсновнойМенеджер.Подразделение;
		ТипКлиента = ТипБП;
	КонецЕсли;
	ДанныеДляРасшифровки = ДанныеДляРасшифровки+Строка(Объект.Партнер)+Символы.ПС;
	
	Если БылаОтправкаБП() Тогда
		ДанныеДляРасшифровки = ДанныеДляРасшифровки+"Менеджер: "+Строка(Объект.Менеджер);
	КонецЕсли;
	
	Поля = Новый Структура;
	Поля.Вставить("CREATED_BY", ТекущийПользовательБитрикс);
	Поля.Вставить("NAME", "Интернет-заказ "+Строка(Объект.НомерНаСайте));//Заявка
	Поля.Вставить("DETAIL_TEXT", ДанныеДляРасшифровки);//расшифровка
	Поля.Вставить("Active_from", Строка(ТекущаяДата()));
	
	Поля.Вставить("PROPERTY_342", "-");//Подразделениеобязательное поле
	Поля.Вставить("PROPERTY_3799", Строка(Объект.Склад.Подразделение));//Подразделение
	//Поля.Вставить("PROPERTY_343", ПолучитьТипКлиента(ТипКлиента));//Тип клиента/отдел
	Поля.Вставить("PROPERTY_343", "-");//Тип клиента/отдел обязательное поле
	Поля.Вставить("PROPERTY_3832", Строка(ТипКлиента));//Тип клиента/отдел
	Поля.Вставить("PROPERTY_710", "1174");//Новый клиент
	Поля.Вставить("PROPERTY_2302", ?(ЗначениеЗаполнено(этаформа.ТелефонПартнера), этаформа.ТелефонПартнера, Число(0)));//Входящий номер телефона
	
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовыйЭлементСписка(ИДТипаБлока, ИДБлока, КодЭлементаПроцесса, Поля);
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
	КонецЕсли;   	
	
	Если СтруктураОтвета.Свойство("Результат") Или СтруктураОтвета.Свойство("result") Тогда 
		Сообщить("В Битриксе успешно запущен БП");  
	КонецЕсли;
	ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "СозданБПНаИнтернетЗаказ", Истина);
	Записать();
	
КонецПроцедуры

&НаСервере
Функция ОпределитьТипБП()
	ОтделОМ = ПолучитьОтделПоОсновномуМенеджеру(Объект.Партнер.ОсновнойМенеджер);
	
	Если ОтделОМ = "ОД" Тогда
		ТипБП = "ОД";
	ИначеЕсли ОтделОМ = "КР" Тогда
		ТипБП = "КР";
	ИначеЕсли Объект.Склад.Подразделение.ФорматПодразделения = Справочники.ФорматыПодразделений.НайтиПоКоду("000000001") Тогда
		ТипБП = "МД";
	Иначе
		ТипБП = "ТСК";
	КонецЕсли;
	
	Возврат ТипБП;
КонецФункции

&НаСервере
Функция ПолучитьОтделПоОсновномуМенеджеру(ОМ)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДополнительныеСведения.Значение.Наименование КАК Отдел
		|ИЗ
		|	Справочник.Пользователи КАК Пользователи
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|		ПО (ДополнительныеСведения.Объект = Пользователи.Ссылка)
		|ГДЕ
		|	Пользователи.Ссылка = &Ссылка
		|	И ДополнительныеСведения.Свойство.Наименование = ""Отделы (Пользователи)""";
	
	Запрос.УстановитьПараметр("Ссылка", ОМ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Если ВыборкаДетальныеЗаписи.Отдел = "Коммерческий отдел" Тогда
			Возврат "КР";
		ИначеЕсли ВыборкаДетальныеЗаписи.Отдел = "Отдел Дистрибуции" Тогда
			Возврат "ОД";
		КонецЕсли;
	КонецЕсли;
	Возврат "";
	
КонецФункции

&НаСервере
Функция ПолучитьАдресСклада(Склад)

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СкладыКонтактнаяИнформация.Представление КАК Адрес
		|ИЗ
		|	Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяИнформация
		|ГДЕ
		|	СкладыКонтактнаяИнформация.Ссылка = &Ссылка
		|	И СкладыКонтактнаяИнформация.Вид.Наименование = ""Адрес склада""";
	
	Запрос.УстановитьПараметр("Ссылка", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Адрес;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

