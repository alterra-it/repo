&НаКлиенте
Процедура ПринятьОплатуПоQR(Результат, ДополнительныеПараметры) Экспорт 

	Если Результат = КодВозвратаДиалога.Да Тогда
			
		ДлительнаяОперация = ПринятьОплатуПоQRНаСервере();
	   	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	    ПараметрыОжидания.Интервал = 5;
		ПараметрыОжидания.ТекстСообщения = "Данная операция может занять длительное время.";
		
	    ДлительныеОперацииКлиент.ОжидатьЗавершение(
	        ДлительнаяОперация,
	        Новый ОписаниеОповещения("ПринятьОплатуПоQRЗавершение", ЭтотОбъект),
	        ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПринятьОплатуПоQRНаСервере()
		
	Документы.ЗаказКлиента.СоздатьЭквайринговуюОперацию(Объект.Ссылка, Ложь);
	Объект.ПередатьНаСайт = Истина;
	Записать(); 	

	УзелОбмена = ПланыОбмена.Б_ОбменССайтом.НайтиПоКоду("000000002");   //Б_ Обмен заказами tg-alterra.ru
		
	Данные = Новый ТаблицаЗначений();
	Данные.Колонки.Добавить("Объект", Новый ОписаниеТипов("ДокументСсылка.ЗаказКлиента"));
	Данные.Колонки.Добавить("Пакет");
	Данные.Колонки.Добавить("ТипОбъекта");
	
	НоваяСтрока = Данные.Добавить();
	НоваяСтрока.Объект = Объект.Ссылка;
	НоваяСтрока.Пакет = 1;
	НоваяСтрока.ТипОбъекта = "Заказ";

	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("УзелОбмена", УзелОбмена);
	СтруктураПараметров.Вставить("ТаблицаЗаказов", Данные);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор); 
	
    ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Выгрузить заказ на сайт'");
	
	ДлительнаяОперация = ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, 
		"ДопМодульСервер.ВыгрузитьЗаказыНаСайт", 
		УзелОбмена, 
		Данные); 
	 
    Возврат ДлительнаяОперация;	
		
КонецФункции

&НаКлиенте
Процедура ПринятьОплатуПоQRЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда      
		Возврат;
	КонецЕсли; 
	 
	Если Результат.Статус = "Ошибка" Тогда 
		Сообщить(Результат.КраткоеПредставлениеОшибки);	
	Иначе   
		ЗаказПереданНаСайт = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
 		УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Если ЗаказПереданНаСайт = Неопределено Тогда
			Возврат; 
		КонецЕсли;
	
		Если ЗаказПереданНаСайт Тогда
			СсылкаНаПроцессОплаты = ПолучитьСсылкуНаПроцессОплаты();
			Если СсылкаНаПроцессОплаты <> Неопределено Тогда
				ПерейтиПоНавигационнойСсылке(СсылкаНаПроцессОплаты);    
			КонецЕсли;
		Иначе 
			Сообщить("При передачи заказа на сайт произошла ошибка, необходимо обратиться в техническую поддержку.");	
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьСсылкуНаПроцессОплаты()
	
	ПараметрыHTTPСоединения = Новый Структура;
	ПараметрыHTTPСоединения.Вставить("ИспользоватьSSL", Истина);
	ПараметрыHTTPСоединения.Вставить("АдресСервера", "tg-alterra.ru");
	ПараметрыHTTPСоединения.Вставить("Порт", 443);
	ПараметрыHTTPСоединения.Вставить("Логин", "");
	ПараметрыHTTPСоединения.Вставить("Пароль", "");
	Если ЗначениеЗаполнено(Объект.Ссылка.НомерНаСайте) Тогда
		АдресHTTPЗапроса = "/api/v1/order.getPaymentProcessURI?id=" + Объект.Ссылка.НомерНаСайте;
	Иначе
		АдресHTTPЗапроса = "/api/v1/order.getPaymentProcessURI?id=" + Объект.Ссылка.УникальныйИдентификатор();	
	КонецЕсли;
	СтруктураОтвета = ОбщийHTTPСервер.ПослатьGETЗапрос(ПараметрыHTTPСоединения, АдресHTTPЗапроса);
	
	// Тестирование ответа
	// СтруктураОтвета = ПолучитьМокОтветСсылки();
	
	Если ЗначениеЗаполнено(СтруктураОтвета) И ТипЗнч(СтруктураОтвета) = Тип("Структура") Тогда
		Если СтруктураОтвета.Свойство("response") Тогда
			response = СтруктураОтвета.response;
			Если ТипЗнч(response) = Тип("Структура") Тогда
			 
				Если response.Свойство("link") Тогда
					
					Попытка				
						Если response.Свойство("order_id") Тогда
							Объект.НомерНаСайте = response.order_id;
							ДокументОбъект = РеквизитФОрмыВЗначение("Объект"); 
							ДокументОбъект.Записать();
							ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
						КонецЕсли;
					Исключение
					КонецПопытки;
					
					Возврат response.link;
				КонецЕсли;
			Иначе
				Сообщить("Ошибка при разборе ответа. Свойство 'link' не обнаружено!");
			КонецЕсли;
		Иначе
			Сообщить("Ошибка при разборе ответа. Свойство 'response' не обнаружено!");
		КонецЕсли;
	КонецЕсли;
	
КонецФункции

