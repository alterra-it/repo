	МассивБлокировки.Добавить("ГруппаТоварыПодобратьТовары");
	МассивБлокировки.Добавить("ТоварыЗаполнитьОбеспечение");
	МассивБлокировки.Добавить("ТоварыЗаполнитьСкладВВыделенныхСтроках");
	МассивБлокировки.Добавить("ЗаполнитьДатуОтгрузки");
	МассивБлокировки.Добавить("ГруппаОбеспечение");
	МассивБлокировки.Добавить("ГруппаЦеныСкидки");
