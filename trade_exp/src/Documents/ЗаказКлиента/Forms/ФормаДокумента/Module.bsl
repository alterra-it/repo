&НаСервере
Процедура Док_ОтправитьЭлектронноеПисьмоПоОплатеПередНаСервере()
	
	Если Не ЗначениеЗаполнено(СсылкаНаОплату) Тогда
		СформироватьСсылкуНаОплату();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СсылкаНаОплату) Тогда
		Если ЗначениеЗаполнено(ЭлектроннаяПочтаПартнера) Тогда  
			ПараметрыОтправки = Новый Структура;
			ПараметрыОтправки.Вставить("Кому", ЭлектроннаяПочтаПартнера);
			ПараметрыОтправки.Вставить("Тема", "Здравствуйте!");
			ПараметрыОтправки.Вставить("Тело", "Для оплаты Вашего заказа (№" + Объект.Номер + ") перейдите по ссылке: " + СсылкаНаОплату);
			ПараметрыОтправки.Вставить("Кодировка", КодировкаТекста.UTF8);
			ПараметрыОтправки.Вставить("ТипТекста", Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст);
			РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(
				Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты, 
				ПараметрыОтправки);
			Сообщить("Сообщение на e-mail успешно отправлено");
		Иначе 
			Сообщить("Электронная почта не указана");
		КонецЕсли;
	Иначе
		Сообщить("Ссылка на оплату отсутствует!");
	КонецЕсли;
	
КонецПроцедуры

