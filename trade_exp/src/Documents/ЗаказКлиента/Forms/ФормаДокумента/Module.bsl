#Область ОтметкаКассы
&НаКлиенте
Процедура ОтметкаКассы(Команда)
	
	Пользователь = ПолучитьПользователя();
	ДопМодульКлиент.УстановитьОтметкуКассы(ЭтаФорма, Пользователь);
	
	Если не Объект.Кассир.Пустая() Тогда
		Если Не Объект.Проведен Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ не проведен! Установка отметки кассы невозможна!", Объект.Ссылка, "Объект.Кассир");
			Возврат;
		КонецЕсли;

		//Проверка согласованного листа
		Если Не ЕстьСогласованныеЛисты() ИЛИ ЕстьНеСогласованныйРейс() Тогда
			Возврат;
		КонецЕсли;          	
	Иначе 
		Если ПроверитьОтметкуКассыУРеализаций(Объект.Ссылка) Тогда
			Сообщить("По документу существуют реализации с отметкой кассы. Снимите сначало их.");
			Возврат;
		КонецЕсли;
		
		Если ПроверитьЕстьРейсыПоДокументу() Тогда
			Возврат;
		КонецЕсли;
		
		Объект.ДатаОтгрузки = ТекущаяДата() + 24*60*60; 
		
	КонецЕсли;
	
	УстановитьДоступностьПоОтметкеКассы();
	
	Если ЗначениеЗаполнено(Объект.Кассир) Тогда
		СоздатьЗаявкуЛесЕГАИС();	
	КонецЕсли;                                                                   
		
КонецПроцедуры

