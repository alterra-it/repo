&НаКлиенте
&ИзменениеИКонтроль("НазначитьАвтоматическиеСкидкиЗавершение")
Процедура Док_НазначитьАвтоматическиеСкидкиЗавершение(ВозвращенноеЗначение, ДополнительныеПараметры)

	Если ВозвращенноеЗначение <> Неопределено Тогда

		ОчиститьСообщения();
		#Удаление
		ПрименитьОплатуБонуснымиБалламиКлиент(, Истина);
		#КонецУдаления
		
		УправляемыеСкидки = ВозвращенноеЗначение;
		
		СтруктураПараметры = Новый Структура;
		СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
		СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
		СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Ложь);
		СтруктураПараметры.Вставить("УправляемыеСкидки", УправляемыеСкидки);
		
		СтруктураСообщений = РассчитатьСкидкиНаценкиНаСервере(СтруктураПараметры);
		Если СтруктураСообщений.Сообщения.Количество() > 0 И СтруктураСообщений.АвтоматическиОткрывать Тогда
			ОткрытьФорму("ОбщаяФорма.СообщенияСкидокНаценок", СтруктураСообщений, ЭтаФорма, УникальныйИдентификатор);
		КонецЕсли;
		
		ПоказатьОповещениеПользователя(
			НСтр("ru = 'Скидки (наценки)'"),
			,
			НСтр("ru = 'Скидки (наценки) рассчитаны'"),
			БиблиотекаКартинок.Информация32);
		
	КонецЕсли;
	#Вставка
	Док_ОбработатьБонуснуюЧасть(Ложь);
	#КонецВставки

КонецПроцедуры

&НаКлиенте
Процедура Док_ОбработатьБонуснуюЧасть(РассчитатьИтоги = Истина)
	
	СуммаОплатыБонусами = Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте");
	ОчиститьБонусыСервер();
	ПерераспределитьБонусы(СуммаОплатыБонусами);
	Если Объект.Товары.Итог("СуммаБонусныхБалловКСписаниюВВалюте") < СуммаОплатыБонусами Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Сумма бонусных баллов к списанию уменьшена!");
	КонецЕсли;
	
	Если РассчитатьИтоги Тогда
		РассчитатьИтоговыеПоказателиЗаказа(ЭтотОбъект);
	КонецЕсли;
	
КонецПроцедуры



