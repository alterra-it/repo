&НаСервере
Процедура СоздатьЗадачуВБТ24НаСервере()
	
	//Подключаемся к хранилищу настроек 
	ХранилищеСсылка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Настройки хранилища");
	Хранилище = ХранилищеСсылка.ХранилищеНастроек.Получить(); 
	
	Запрос = Новый запрос; 
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Ссылка КАК Ссылка,
	|	ЗаказКлиентаТовары.Номенклатура.Код КАК НоменклатураКод,
	|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура,
	|	ЗаказКлиентаТовары.Номенклатура.ЕдиницаИзмерения КАК НоменклатураЕдиницаИзмерения,
	|	ЗаказКлиентаТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ЗаказКлиентаТовары.Номенклатура.Родитель КАК НоменклатураРодитель,
	|	ЗаказКлиентаТовары.Номенклатура.МенеджерПоставок КАК МенеджерОП,
	|	ЗаказКлиентаТовары.Номенклатура.КатегорийныйМенеджер КАК КатегорийныйМенеджер,
	|	ЗаказКлиентаТовары.ВариантОбеспечения КАК ВариантОбеспечения,
	|	ЗаказКлиентаТовары.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ЗаказКлиентаТовары.Ссылка.Менеджер КАК Менеджер,
	|	ЗапасыИПотребностиОстатки.КОбеспечениюОстаток КАК КЗаказуОстаток
	|ПОМЕСТИТЬ ПакетИнформации
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыИПотребности.Остатки(,) КАК ЗапасыИПотребностиОстатки
	|		ПО ЗаказКлиентаТовары.Номенклатура = ЗапасыИПотребностиОстатки.Номенклатура
	|		И ЗаказКлиентаТовары.Ссылка = ЗапасыИПотребностиОстатки.Заказ
	|ГДЕ
	|	ЗаказКлиентаТовары.Ссылка = &Ссылка
	|	И ЗаказКлиентаТовары.Обособленно
	|	И ЗапасыИПотребностиОстатки.КОбеспечениюОстаток > 0
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПакетИнформации.МенеджерОП КАК МенеджерОП
	|ИЗ
	|	ПакетИнформации КАК ПакетИнформации
	|ГДЕ
	|	НЕ ПакетИнформации.МенеджерОП.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПакетИнформации.Менеджер КАК Менеджер,
	|	Сотрудники.Отдел КАК Отдел,
	|	Сотрудники.Подразделение КАК Подразделение,
	|	Сотрудники.Уволен КАК Уволен,
	|	Сотрудники.ПометкаУдаления КАК ПометкаУдаления
	|ПОМЕСТИТЬ ВТ_Менеджер
	|ИЗ
	|	ПакетИнформации КАК ПакетИнформации
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО ПакетИнформации.Менеджер = Сотрудники.Пользователь
	|		И НЕ Сотрудники.Уволен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Сотрудники.Отдел.Руководитель КАК Руководитель
	|ПОМЕСТИТЬ ВТ_Руководители
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Пользователь В
	|		(ВЫБРАТЬ
	|			ПакетИнформации.МенеджерОП
	|		ИЗ
	|			ПакетИнформации КАК ПакетИнформации
	|		ГДЕ
	|			НЕ ПакетИнформации.МенеджерОП = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка))
	|	И НЕ Сотрудники.Уволен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Отделы.Руководитель
	|ИЗ
	|	Справочник.Отделы КАК Отделы
	|ГДЕ
	|	Отделы.Ссылка В
	|		(ВЫБРАТЬ
	|			ВТ_Менеджер.Отдел
	|		ИЗ
	|			ВТ_Менеджер КАК ВТ_Менеджер)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПакетИнформации.НоменклатураКод КАК НоменклатураКод,
	|	ПакетИнформации.НоменклатураЕдиницаИзмерения КАК НоменклатураЕдиницаИзмерения,
	|	ПакетИнформации.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ПакетИнформации.ДатаОтгрузки КАК ДатаОтгрузки,
	|	ПакетИнформации.КЗаказуОстаток КАК КЗаказуОстаток,
	|	ПакетИнформации.Номенклатура КАК Номенклатура
	|ИЗ
	|	ПакетИнформации КАК ПакетИнформации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПакетИнформации.НоменклатураРодитель.Наименование КАК НоменклатураРодитель
	|ИЗ
	|	ПакетИнформации КАК ПакетИнформации
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка КАК Ссылка,
	|	ЗаказКлиента.Номер КАК Номер,
	|	ЗаказКлиента.Склад.Наименование КАК Склад,
	|	ЗаказКлиента.Партнер.Наименование КАК Партнер,
	|	ЗаказКлиента.ДатаОтгрузки КАК ЖелаемаяДатаОтгрузки,
	|	ЗаказКлиента.Менеджер КАК Менеджер,
	|	ЗаказКлиента.АдресДоставки КАК АдресДоставки,
	|	ЗаказКлиента.ТелефонКлиентаНаВыгрузке КАК ТелефонКлиентаНаВыгрузке,
	|	ЗаказКлиента.Склад.Транзит КАК СкладТранзит,
	|	ЕСТЬNULL(КИ.НомерТелефона, """") КАК НомерКлиента
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК КИ
	|		ПО ЗаказКлиента.Партнер = КИ.Ссылка
	|		И (КИ.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон))
	|		И (КИ.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера))
	|ГДЕ
	|	ЗаказКлиента.Ссылка = &Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПакетИнформации.КатегорийныйМенеджер КАК Наблюдатель
	|ИЗ
	|	ПакетИнформации КАК ПакетИнформации
	|ГДЕ
	|	НЕ ПакетИнформации.КатегорийныйМенеджер.ПометкаУдаления
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Сотрудники.Пользователь
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	Сотрудники.Должность = &Должность
	|	И (Сотрудники.Отдел, Сотрудники.Подразделение) В
	|		(ВЫБРАТЬ
	|			ВТ_Менеджер.Отдел,
	|			ВТ_Менеджер.Подразделение
	|		ИЗ
	|			ВТ_Менеджер КАК ВТ_Менеджер)
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Уволен
	|	И Сотрудники.Состояние <> ЗНАЧЕНИЕ(Перечисление.СостоянияСотрудника.ОтпускПоУходуЗаРебенком)
	|	И Сотрудники.Состояние <> ЗНАЧЕНИЕ(Перечисление.СостоянияСотрудника.ОтпускПоБеременностиИРодам)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Сотрудники.Пользователь
	|ИЗ
	|	ВТ_Руководители КАК ВТ_Руководители
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО ВТ_Руководители.Руководитель = Сотрудники.Ссылка
	|ГДЕ
	|	НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Уволен
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Менеджер.Отдел КАК Отдел,
	|	ВТ_Менеджер.Подразделение КАК Подразделение
	|ИЗ
	|	ВТ_Менеджер КАК ВТ_Менеджер
	|ГДЕ
	|	НЕ ВТ_Менеджер.Уволен
	|	И НЕ ВТ_Менеджер.ПометкаУдаления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПакетИнформации.Ссылка.Партнер.ОсновнойМенеджер КАК ОсновнойМенеджер,
	|	ПакетИнформации.Ссылка.Партнер.МАП КАК МАП
	|ИЗ
	|	ПакетИнформации КАК ПакетИнформации"; 
			
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка); 
	Запрос.УстановитьПараметр("Должность", Хранилище.НастройкиСозданияЗадач.ДолжностьАдминистратораТЗ); 
	Запрос.УстановитьПараметр("Подразделение", Объект.Ссылка.Менеджер.Подразделение); 
	СотрудникМенеджер = Справочники.Сотрудники.НайтиПоНаименованию(Объект.Ссылка.Менеджер.Наименование); 
	Запрос.УстановитьПараметр("Отдел", СотрудникМенеджер.Отдел); 
	Результат = Запрос.ВыполнитьПакет();

	Выборка1 = Результат[1].выбрать();
	МассивОтветственных = Новый Массив;
	Пока Выборка1.Следующий() Цикл
		Если Выборка1.МенеджерОП <>"" Тогда
			МассивОтветственных.Добавить(Выборка1.МенеджерОП); 
		КонецЕсли;
	КонецЦикла;
	
	Выборка7 = Результат[7].Выбрать();
	Выборка9 = Результат[9].Выбрать(); 
	МассивНаблюдателей = Новый Массив; 
	Пока Выборка7.Следующий() Цикл
		Если не Выборка7.Наблюдатель = NULL Тогда
			МассивНаблюдателей.Добавить(Выборка7.Наблюдатель);
		КонецЕсли;
	КонецЦикла;
	Пока Выборка9.Следующий() Цикл
		Если не Выборка9.ОсновнойМенеджер = NULL Тогда
			МассивНаблюдателей.Добавить(Выборка9.ОсновнойМенеджер);
			МассивНаблюдателей.Добавить(Выборка9.МАП); 
		КонецЕсли;
	КонецЦикла; 
	
	Выборка5 = Результат[5].Выбрать(); 
	СтрокаТитульная = "";
	Пока Выборка5.Следующий() Цикл
		Если Выборка5.НоменклатураРодитель <>"" Тогда
			СтрокаТитульная = СтрокаТитульная + Выборка5.НоменклатураРодитель + ", ";
		КонецЕсли;
	КонецЦикла; 
	
	Выборка6 = Результат[6].Выбрать(); 
	Выборка6.Следующий();
	СтрокаТитульная = СтрокаТитульная + " Склад: " + Выборка6.Склад +" Номер заказа: №"+ Выборка6.Номер+ " Клиент: " + Выборка6.Партнер;
	Постановщик = Выборка6.Менеджер;     
	
	Если Выборка6.СкладТранзит Тогда 
		ДопИнформация = Символы.ПС + 
			?(ЗначениеЗаполнено(Выборка6.АдресДоставки), ("Адрес доставки: " + Выборка6.АдресДоставки + Символы.ПС), "") +
			?(ЗначениеЗаполнено(Выборка6.ТелефонКлиентаНаВыгрузке), ("Телефон клиента на выгрузке: " + Выборка6.ТелефонКлиентаНаВыгрузке), "");  
	Иначе
		ДопИнформация = "";
	КонецЕсли;
	
	Выборка4 = Результат[4].Выбрать();
	СтрокаОписание = "";
	Пока Выборка4.Следующий() Цикл
		СтрокаОписание = СтрокаОписание + Выборка4.НоменклатураКод + "  " + Выборка4.Номенклатура + " " + Выборка4.КоличествоУпаковок + " " + Выборка4.НоменклатураЕдиницаИзмерения + символы.ПС; 
	КонецЦикла;
	
	Если Выборка4.ДатаОтгрузки <> неопределено Тогда 
		ДатаОтгрузки = Выборка4.ДатаОтгрузки;
		СтрокаОписание = СтрокаОписание + "Желаемый срок поставки: " + ДатаОтгрузки;
	Иначе
		ДатаОтгрузки = Выборка6.ЖелаемаяДатаОтгрузки;
		СтрокаОписание = СтрокаОписание + "Желаемый срок поставки: " + ДатаОтгрузки;
	КонецЕсли; 
	
	СтрокаОписание = СтрокаОписание + Символы.ПС + ?(ЗначениеЗаполнено(Выборка6.НомерКлиента), ("Телефон клиента: " + Выборка6.НомерКлиента + Символы.ПС), "Телефон клиента: Не указан");             
	
	СтрокаОписание = СтрокаОписание + ДопИнформация;
	
	Если ЗначениеЗаполнено(Выборка6.АдресДоставки) Тогда
		СтрокаОписание = СтрокаОписание + Символы.ПС + "Адрес доставки: " + Выборка6.АдресДоставки;
	КонецЕсли;
	
	ДатаОтгрузки = ДатаОтгрузки - 60*24*60;
	Выборка8 = Результат[8].Выбрать(); 
	Выборка8.Следующий();

	Отбор = Новый структура; 
	Отбор.Вставить("Отдел", Выборка8.Отдел); 
	Отбор.Вставить("Подразделение", Выборка8.Подразделение); 
	Строка = Хранилище.НастройкиСозданияЗадач.РодительскиеЗадачи.НайтиСтроки(Отбор); 
	ИдРодительскойЗадачи = Строка[0].ИдентификаторРодительскойЗадачи;  
	ИдРабочейГруппы = Строка[0].ИдентификаторРабочейГруппы; 
	
	ИДПостановщика = АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Постановщик);   
		
	СтруктураПараметров = Новый Структура; 
	СтруктураПараметров.Вставить("Заголовок",СтрокаТитульная);
	СтруктураПараметров.Вставить("Описание", СтрокаОписание);
	СтруктураПараметров.Вставить("КрайнийСрок", ДатаОтгрузки); 
	СтруктураПараметров.Вставить("Постановщик", Постановщик); 
	СтруктураПараметров.Вставить("Ответственные", МассивОтветственных);
	СтруктураПараметров.Вставить("Наблюдатели", МассивНаблюдателей);
	//СтруктураПараметров.Вставить("ИДГруппы", Хранилище.НастройкиСозданияЗадач.ИдентификаторРабочейГруппы);
	СтруктураПараметров.Вставить("ИДГруппы",ИдРабочейГруппы);
	СтруктураПараметров.Вставить("ИДРодительскойЗадачи", ИдРодительскойЗадачи);
		
	Результат = АльтерраВзаимодействиеСБитрикс24.СоздатьЗадачу(СтруктураПараметров);  
	НомерЗадачи = Формат(Результат, "ЧГ=0");
	Объект.ИдентификаторЗадачиПодЗаказ = Результат; 
	Комментарий = "В Битриксе стоит задача № " + Результат + Символы.ПС + Объект.Комментарий + Символы.ПС + "bitrix.tg-alterra.ru/company/personal/user/" + ИДПостановщика + "/tasks/task/view/" + НомерЗадачи + "/"; 
	Объект.Комментарий = Комментарий; 
	Записать(); 

	
	События = РегистрыСведений.СобытияДокументовАльтерра.СоздатьНаборЗаписей();
	События.Отбор.Документ.Установить(Объект.Ссылка); 
	События.Отбор.Событие.Установить(Перечисления.СобытияДокументов.ОповещениеОВыполненииЗадачи); 
	События.Отбор.Период.Установить(ТекущаяДата());
	
	НовоеСобытие = События.Добавить();
	НовоеСобытие.Документ = Объект.Ссылка;
	НовоеСобытие.Событие = Перечисления.СобытияДокументов.ОповещениеОВыполненииЗадачи;
	НовоеСобытие.Период = ТекущаяДата(); 
	События.Записать(); 
	 
КонецПроцедуры     


&НаСервере
Функция ПроверкаДоступностиБТ()
	
	Если ЭтаФорма.Модифицированность Тогда 
		Сообщить("Проведите заказ перед отправкой задачи в битрикс"); 
		Возврат Ложь; 
	КонецЕсли; 
	
	Если не Объект.Статус = Перечисления.СтатусыЗаказовКлиентов.КОбеспечению Тогда  
		Сообщить("Статус заказа должен быть ""К Выполнению"""); 
		Возврат Ложь; 
	КонецЕсли;  
	
	
	Запрос = Новый запрос;  
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиентаТовары.Номенклатура КАК Номенклатура
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ЗапасыИПотребности.Остатки(, ) КАК ЗапасыИПотребностиОстатки
		|		ПО ЗаказКлиентаТовары.Номенклатура = ЗапасыИПотребностиОстатки.Номенклатура
		|			И ЗаказКлиентаТовары.Ссылка = ЗапасыИПотребностиОстатки.Заказ
		|ГДЕ
		|	ЗаказКлиентаТовары.Ссылка = &Ссылка
		|	И ЗаказКлиентаТовары.Обособленно
		|	И ЗапасыИПотребностиОстатки.КОбеспечениюОстаток > 0
		|;
		|
		|//////////////////////////////
		|
		|ВЫБРАТЬ
		|	ВТ.Номенклатура КАК Номенклатура
		|ИЗ
		|	ВТ КАК ВТ
		|ГДЕ
		|	ВТ.Номенклатура.МенеджерПоставок = ЗНАЧЕНИЕ(Справочник.Пользователи.ПустаяСсылка)";
	

	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	Результат = Запрос.ВыполнитьПакет();
	
	Выборка1 = Результат[0].Выбрать();
	
	Если Не Выборка1.Следующий() Тогда 
		Сообщить("Нет товара, который требуется для заказа"); 
		Возврат Ложь; 
	КонецЕсли;
	
	Выборка2 = Результат[1].Выбрать();
	НоменклатураБезМенеджера = Новый Массив;
	
	Пока Выборка2.Следующий() Цикл
		НоменклатураБезМенеджера.Добавить(Выборка2.Номенклатура);
	КонецЦикла;
	
	Если НоменклатураБезМенеджера.Количество() > 0 Тогда
		СтрокаСообщения = СтрСоединить(НоменклатураБезМенеджера, Символы.ПС);
		Сообщить("Для следующей номенклатуры не указан Менеджер поставок:" + Символы.ПС + СтрокаСообщения);
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос; 
	Запрос.Текст =  "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Подразделение КАК Подразделение,
		|	Сотрудники.Отдел КАК Отдел
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|   	Сотрудники.Пользователь = &Пользователь
		|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
		|	И Сотрудники.Уволен = ЛОЖЬ"; 
	Запрос.УстановитьПараметр("Пользователь", Объект.Менеджер); 
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	Если Выборка.Следующий() Тогда 	
		//Подключаемся к хранилищу настроек 
		ХранилищеСсылка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Настройки хранилища");
		Хранилище = ХранилищеСсылка.ХранилищеНастроек.Получить(); 
		Отбор = Новый структура; 
		Отбор.Вставить("Отдел", Выборка.Отдел); 
		Отбор.Вставить("Подразделение", Выборка.Подразделение); 
		Массив = Хранилище.НастройкиСозданияЗадач.РодительскиеЗадачи.НайтиСтроки(Отбор);  
		Если Массив.Количество() = 0 ТОгда 
			Сообщить("Для данного менеджера не внесены настройки по созданию задач. Обратитесь в ИТ-отдел"); 
			Возврат Ложь; 	
		КонецЕсли; 
	Иначе
		Сообщить("Для данного менеджера не заполнен пользователь в справочнике Сотрудники"); 
		Возврат Ложь; 
	КонецЕсли;     
	
	Если ЗначениеЗаполнено(Объект.ИдентификаторЗадачиПодЗаказ) Тогда 
		Сообщить("Уже стоит задача в битриксе"); 
		Возврат Ложь; 
	КонецЕсли; 
	
	Возврат Истина; 
	
	
	
КонецФункции	

&НаСервере
Функция НаличиеЛистовСогласования()

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЛистСогласования.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЛистСогласования КАК ЛистСогласования
		|ГДЕ
		|	ЛистСогласования.Основание = &Основание
		|	И ЛистСогласования.ВидОперации = Значение(Перечисление.ВидыОперацийЛистовСогласования.СогласованиеТранзитов)";
	
	Запрос.УстановитьПараметр("Основание", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

 &НаКлиенте
Процедура СозданиеЛистаСогласования(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса 			= КодВозвратаДиалога.Да Тогда
		
		ПараметрыФормы 				= Новый Структура("Основание", Объект.Ссылка);
		
		ОткрытьФорму("Документ.ЛистСогласования.Форма.ФормаДокумента", ПараметрыФормы);
		
	ИначеЕсли РезультатВопроса 		= КодВозвратаДиалога.Нет Тогда
		СоздатьЗадачуВБТ24НаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_СоздатьЗадачуВБТПосле(Команда)
	
	Если ПроверкаДоступностиБТ() Тогда 
		Если НЕ НаличиеЛистовСогласования() Тогда
			
			ТекстВопроса 			= НСтр						("ru = 'По этому заказу не создан лист согласования с видом операции ""Транзит""'");
			Кнопки 					= Новый СписокЗначений;
			
			Кнопки.Добавить(КодВозвратаДиалога.Да, НСтр			("ru = 'Создать лист согласования'"));
			Кнопки.Добавить(КодВозвратаДиалога.Нет, НСтр		("ru = 'Продолжить без листа согласования'"));
			Кнопки.Добавить(КодВозвратаДиалога.Прервать, НСтр   ("ru = 'Отмена'"));
			
	        ПоказатьВопрос(Новый ОписаниеОповещения("СозданиеЛистаСогласования", ЭтотОбъект),
						   ТекстВопроса,
						   Кнопки);
		Иначе
			СоздатьЗадачуВБТ24НаСервере();
		КонецЕсли;
	КонецЕсли; 
КонецПроцедуры

&НаСервере
Функция ЗаполнитьФормуЛистаСогласования(ДанныеФормы)
	Док = ДанныеФормыВЗначение(ДанныеФормы, Тип("ДокументОбъект.ЛистСогласования"));
	Документы.ЛистСогласования.ЗаполнитьДанныеПоОснованию(ЭтотОбъект, Док, Перечисления.ВидыОперацийЛистовСогласования.СогласованиеТранзитов);
	ЗначениеВДанныеФормы(Док, ДанныеФормы);
КонецФункции

&НаКлиенте
Процедура Док_ТоварыПередУдалениемПосле(Элемент, Отказ)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные; 
	Если ТекущиеДанные <> неопределено Тогда                            
		УдаляемаяНоменклатура = ТекущиеДанные.номенклатура; 
		Если ЭтоУслугаРезки(УдаляемаяНоменклатура) ТОгда 
			Объект.Нарезка.Очистить();
		КонецЕсли;
	КонецЕсли;
	//-
КонецПроцедуры  

&НаСервере
Функция ЭтоУслугаРезки(номенклатура) 
	Если номенклатура.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга
		И Найти(Номенклатура.Наименование, "резк") > 0 Тогда 
		Возврат Истина; 
	Иначе
		Возврат Ложь; 
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура Док_ЗагрузитьЗаявкуКлиентаПосле(Команда)    
	ПараметрыЗагрузки=Новый Структура();
	ПараметрыЗагрузки.Вставить("Партнер",Объект.Партнер);
	ПараметрыЗагрузки.Вставить("Склад",Объект.Склад);
	ОповещениеОЗагрузке = Новый ОписаниеОповещения("ЗагрузитьЗаявкаКлиентаЗавершение", ЭтотОбъект);
	ОткрытьФорму("Обработка.ЗагрузкаТоваровИзВнешнихФайлов.Форма.ФормаЗаявкиКлиентов", ПараметрыЗагрузки,
	ОповещениеОЗагрузке.Модуль, , , , ОповещениеОЗагрузке);
	
КонецПроцедуры

 &НаКлиенте
Процедура ЗагрузитьЗаявкаКлиентаЗавершение(АдресЗагруженныхДанных, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(АдресЗагруженныхДанных) Тогда
		ПолучитьТоварыЗаявкиИзХранилища(АдресЗагруженныхДанных);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьТоварыЗаявкиИзХранилища(АдресТоваровВХранилище)
	Объект.Товары.Очистить();
	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ПроверитьЗаполнитьСклад", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСкладаВСтрокеТЧ(Объект, СкладГруппа));
	СтруктураДействий.Вставить("ЗаполнитьСтавкуНДСВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействий.Вставить("ЗаполнитьПризнакБезВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияСтавкиНДС(Объект, Истина));
	СтруктураДействий.Вставить("ЗаполнитьПризнакОтмененоБезВозвратнойТары", Объект.ВернутьМногооборотнуюТару);
	СтруктураДействий.Вставить("ЗаполнитьСодержание", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияСодержанияУслугиВСтрокеТЧ(Объект, Ложь));
	СтруктураДействий.Вставить("ЗаполнитьПризнакВариантОформленияПродажи", Новый Структура("Номенклатура", "ВариантОформленияПродажи"));
	СтруктураДействий.Вставить("ЗаполнитьПодразделениеВСтрокеТЧ", Новый Структура("Подразделение", Объект.Подразделение));
	СтруктураДействий.Вставить("ЗаполнитьУсловияПродаж", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруЗаполненияУсловийПродажВСтрокеТЧ(Объект));

	ДобавитьВСтруктуруДействияПриИзмененииКоличестваУпаковок(СтруктураДействий,Объект);
	
	КэшированныеЗначения = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
	
	ТоварыИзХранилища = ПолучитьИзВременногоХранилища(АдресТоваровВХранилище);
	
	Для Каждого СтрокаТоваров Из ТоварыИзХранилища Цикл
		СтрокаТЧТовары = Объект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЧТовары, СтрокаТоваров,,"КодСтроки");
		СтрокаТЧТовары.Склад = Объект.Склад;   
		СтрокаТЧТовары.ТипНоменклатуры = СтрокаТЧТовары.Номенклатура.ТипНоменклатуры;
		Если Объект.НеОтгружатьЧастями Тогда
			СтрокаТЧТовары.ДатаОтгрузки = Объект.ДатаОтгрузки;
		КонецЕсли;
		
		ДобавитьДействияОбеспеченияНаСервере(СтруктураДействий,
			"СкладОбязателен,ДатаОтгрузкиОбязательна");
		ПакетнаяОбработкаТабличнойЧастиСервер.ОбработатьСтрокуТЧ(СтрокаТЧТовары, СтруктураДействий, КэшированныеЗначения);
		
	КонецЦикла;
	
	НоменклатураСервер.ЗаполнитьСтатусыУказанияСерий(Объект, ПараметрыУказанияСерий);
	
	СкладыСервер.ПриИзмененииСкладаВТабличнойЧасти(Объект.Товары, ТаблицаСкладов, СкладГруппа);
	ВсегоСкладов = ТаблицаСкладов.Количество();
	СкладыКлиентСервер.ОбновитьКартинкуГруппыСкладов(НадписьНесколькоСкладов, Элементы.КартинкаНесколькоСкладов, ВсегоСкладов);
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);
	МногооборотнаяТараСервер.ОбновитьСостояниеЗаполненияМногооборотнойТары(Объект.СостояниеЗаполненияМногооборотнойТары);
	
КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("СоглашениеПриИзмененииСервер")
Функция Док_СоглашениеПриИзмененииСервер(ПересчитыватьЦены)
	#Вставка     
	Если Не ЗначениеЗаполнено(Объект.Менеджер) И ЗначениеЗаполнено(Объект.Соглашение) Тогда
		Объект.Менеджер = Пользователи.ТекущийПользователь();
	КонецЕсли;
	если Этаформа.ТекущийЭлемент.Имя <> "Склад" Тогда
		ОчиститьБонусыВывестиСообщение();
	КонецЕсли;
    #КонецВставки
	
	КомиссионныеПродажи25 = ПродажиСервер.ЭтоСоглашениеПоНовойКомиссии(Объект.Соглашение);
	
	ЗаполнитьПараметрыСвязиВидаЦенИПризнакЦенаВключаетНДС();
	
	ДокументПродажи = РеквизитФормыВЗначение("Объект");
	ЦеныРасчитаны = ДокументПродажи.ЗаполнитьУсловияПродажПоСоглашению(ПересчитыватьЦены);
	ЗначениеВРеквизитФормы(ДокументПродажи, "Объект");
	
	ПараметрыДоговора = ПараметрыДоговора(Объект.Договор, Объект.ХозяйственнаяОперация);
	Если ПараметрыДоговора.ПоНовойКомиссии Тогда
		Объект.ЦенаВключаетНДС = ПараметрыДоговора.ЦенаВключаетНДС;
	КонецЕсли;
		
	ВалютаДокумента = Объект.Валюта;
	
	ХозяйственнаяОперацияПриИзмененииСервер(Ложь);
	СкладПриИзмененииСервер();
	
	ЗаполнитьСлужебныеРеквизитыПоНоменклатуре();
	ЗаполнитьСлужебныеРеквизитыФормыДокумента();
	
	ОбновитьДубликатыЗависимыхРеквизитов();
	Объект.БанковскийСчетКонтрагента = ПолучитьБанковскийСчетКонтрагентаПоУмолчаниюСервер(Объект.Контрагент, Объект.БанковскийСчет);
	ДенежныеСредстваСервер.ПроверитьЗаполнитьБанковскийСчетОрганизацииПоВладельцу(Объект.Организация, Объект.БанковскийСчет, , Объект.НаправлениеДеятельности);
	ДенежныеСредстваСервер.ПроверитьЗаполнитьКассуОрганизацииПоВладельцу(Объект.Организация, Объект.Касса, Объект.ФормаОплаты, Объект.НаправлениеДеятельности, Объект.Курьер);
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);
	
	ЗаполнитьСписокВыбораОпераций(Ложь);
	ЗаполнитьГруппуФинУчета();
	ОбновитьДоступностьЭлементовВозвратнойТары(ЭтаФорма);

	МассивРеквизитов = Новый Массив;
	МассивРеквизитов.Добавить("Договор");
	МассивРеквизитов.Добавить("Соглашение");
	ВзаиморасчетыСервер.ФормаПриИзмененииРеквизитов(ЭтотОбъект, МассивРеквизитов);
	
	ОтветственныеЛицаСервер.ЗаполнитьСписокВыбораМенеджера(Элементы.Менеджер, Объект);
	#Удаление
	ОтветственныеЛицаСервер.УстановитьМенеджера(Объект, Объект.ДокументОснование);
	#КонецУдаления
	Если Объект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ПередачаНаКомиссию Тогда
		ЗаполнитьДоговорПоУмолчанию();
	Иначе
		ЗаполнитьПодчиненныеСвойстваПоСтатистике("Договор");
	КонецЕсли;
	
	ОтветственныеЛицаСервер.ПриИзмененииСвязанныхРеквизитовДокумента(Объект);
	
	ВариантОбеспеченияПоУмолчанию = ВариантОбеспеченияПоУмолчанию();
	ВариантОбеспеченияИФлагОбособленно = ПродажиСервер.ВариантОбеспеченияИФлагОбособленноПоУмолчанию(
		Объект.Соглашение,
		Объект.Статус,
		ВариантОбеспеченияПоУмолчанию,
		Не Объект.ЭтоЗаказКакСчет);
	
	Если ИспользоватьНаправленияДеятельности Тогда
		НаправленияДеятельностиСервер.ЗаполнитьНаправлениеПоУмолчанию(Объект.НаправлениеДеятельности, Объект.Соглашение, Объект.Договор);
	КонецЕсли;
	НаправленияДеятельностиСервер.ПриИзмененииНаправленияДеятельности(ЭтотОбъект);
	
	ПодготовитьЗаполнитьУстановитьВидимостьСборкиИДоставки();
	ОбеспечениеВДокументахСервер.ПриИзмененииРеквизитаДокумента(ЭтотОбъект);
	
	// ЭлектронноеВзаимодействие.ЭлектронноеАктированиеЕИС
	ЭлектронноеАктированиеЕИСУТ.ДоговорПриИзмененииЭлектронноеАктированиеЕИС(ЭтотОбъект, Объект);
	// Конец ЭлектронноеВзаимодействие.ЭлектронноеАктированиеЕИС

	Возврат ЦеныРасчитаны;
	
КонецФункции

&НаКлиенте
Процедура Док_ПартнерПриИзмененииПосле(Элемент)
	Если АльтерраОбщегоназначения.ЭтоБригадир(Объект.Партнер) Тогда
		Элементы.БонусныеБаллыСуммаБонусныхБалловЗаКп.Заголовок = "Доп. баллы";
		Элементы.ТоварыСуммаНачисленныхБалловЗаКП.Заголовок = "Доп. баллы";
	КонецЕсли;
	ОчиститьБонусыВывестиСообщение();
	Если Объект.СпособДоставки = ПредопределенноеЗначение("Перечисление.СпособыДоставки.Самовывоз") Тогда
		Объект.АдресДоставки = "";
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ДобавитьОплатуБонуснымиБалламиЗавершение")
Процедура Док_ДобавитьОплатуБонуснымиБалламиЗавершение1(Результат, ДополнительныеПараметры)
    #Удаление
	Если Не ЗначениеЗаполнено(Результат) Тогда
		РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);
		Возврат;
	КонецЕсли;

	ПрименитьОплатуБонуснымиБалламиКлиент(Результат.АдресВоВременномХранилище);

	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтаФорма);
    #КонецУдаления
    #Вставка
	Если Не Результат = Неопределено Тогда
		ОплатитьБонуснымиБалламиНаСервере(Результат.АдресВоВременномХранилище);
		Если НовыйПорядокНачисленияБонусов Тогда
			Объект.СуммаОплатыБаллами = Результат.КОплатеБаллами;
		КонецЕсли;
		Модифицированность = Истина;
	КонецЕсли;
    #КонецВставки

КонецПроцедуры

&НаСервере
&ИзменениеИКонтроль("РассчитатьСкидкиНаценкиНаСервере")
Функция Док_РассчитатьСкидкиНаценкиНаСервере1(СтруктураПараметры, ВзятьИзВременногоХранилища)

	#Вставка
	СтруктураПараметры = Новый Структура;
	СтруктураПараметры.Вставить("ПрименятьКОбъекту",                Истина);
	СтруктураПараметры.Вставить("ТолькоПредварительныйРасчет",      Ложь);
	СтруктураПараметры.Вставить("ВосстанавливатьУправляемыеСкидки", Истина);
	СтруктураПараметры.Вставить("УправляемыеСкидки", УправляемыеСкидки);
	#КонецВставки
	#Удаление
	Если ВзятьИзВременногоХранилища Тогда
		ПримененныеСкидки = ПолучитьИзВременногоХранилища(АдресПримененныхСкидокВоВременномХранилище);
		СкидкиНаценкиЗаполнениеСервер.ПрименитьРезультатРасчета(Объект, ПримененныеСкидки);
	Иначе
		ПримененныеСкидки = СкидкиНаценкиЗаполнениеСервер.Рассчитать(Объект, СтруктураПараметры); 
		АдресПримененныхСкидокВоВременномХранилище = ПоместитьВоВременноеХранилище(ПримененныеСкидки, УникальныйИдентификатор);
	КонецЕсли;
	#КонецУдаления
	
	#Вставка
	ПримененныеСкидки = СкидкиНаценкиЗаполнениеСервер.Рассчитать(Объект, СтруктураПараметры);
	
	Для каждого Строка Из Объект.Товары Цикл
		Если Не Строка.ОтметкаРеализации Тогда
			БонусыАльтерраРезерв.ПересчитатьСуммыСУчетомБонусов(Объект, Строка);
		КонецЕсли;
	КонецЦикла;
	#КонецВставки
	
	Объект.СкидкиРассчитаны = Истина;
	ОбновитьДубликатыЗависимыхРеквизитов();
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтаФорма);
	
	СтруктураСообщений = СкидкиНаценкиЗаполнениеСервер.СтруктураСообщений(Объект);
	СкидкиНаценкиЗаполнениеСервер.НастроитьКомандуПоказатьСообщения(Объект, Элементы.ПоказатьСообщения);
	
	Возврат СтруктураСообщений;

КонецФункции

&НаКлиенте
&ИзменениеИКонтроль("СчитатьКартуЛояльности")
Процедура Док_СчитатьКартуЛояльности(Команда)

	Если Объект.Согласован Тогда
		Возврат;
	КонецЕсли;

	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Партнер", Объект.Партнер);
	#Удаление
	ПараметрыОткрытия.Вставить("Организация", Объект.Организация);
	#КонецУдаления
	// ЭлектронноеВзаимодействие.СервисEDI
	Если Не РедактированиеРеквизитовEDIКлиентСервер.РеквизитДоступенДляРедактирования(ЭтотОбъект, "Покупатель") Тогда
		ПараметрыОткрытия.Вставить("Контрагент", Объект.Контрагент);
		ПараметрыОткрытия.Вставить("ИзменениеКонтрагентаНедоступно", Истина);
		ПараметрыОткрытия.Вставить("ИзменениеПартнераНедоступно", Истина);
	КонецЕсли;
	// Конец ЭлектронноеВзаимодействие.СервисEDI
	
	ОткрытьФорму(
		"Справочник.КартыЛояльности.Форма.СчитываниеКартыЛояльности",
		ПараметрыОткрытия,
		ЭтаФорма,
		ЭтаФорма.УникальныйИдентификатор); 
КонецПроцедуры

&НаКлиенте
&ИзменениеИКонтроль("ОткрытьПодбор")
Процедура Док_ОткрытьПодбор1(Команда)

	// &ЗамерПроизводительности
	ОценкаПроизводительностиКлиент.НачатьЗамерВремени(Истина,
		"Документ.ЗаказКлиента.ФормаДокумента.Команда.ОткрытьПодбор");
	
	Отказ = Ложь;
	Если (ИспользоватьСоглашенияСКлиентами И Не ЗначениеЗаполнено(Объект.Соглашение))
		Или Не ЗначениеЗаполнено(Объект.Валюта) Тогда
		ОчиститьСообщения();
		СообщитьОбОшибкахОткрытияПодбора(Отказ);
	КонецЕсли;
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	#Вставка
	ОчиститьРаспределение();
	#КонецВставки

	ПараметрЗаголовок = НСтр("ru = 'Подбор товаров в %Документ%'");
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ПараметрЗаголовок = СтрЗаменить(ПараметрЗаголовок, "%Документ%", Объект.Ссылка);
	Иначе
		ПараметрЗаголовок = СтрЗаменить(ПараметрЗаголовок, "%Документ%", НСтр("ru='заказ клиента'"));
	КонецЕсли;
	
	ОперацииПередачи = ОперацииПередачиТоваров();
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Партнер",                  Объект.Партнер);
	ПараметрыФормы.Вставить("Соглашение",               Объект.Соглашение);
	ПараметрыФормы.Вставить("Организация",              Объект.Организация);
	ПараметрыФормы.Вставить("ЦенаВключаетНДС",          Объект.ЦенаВключаетНДС);
	ПараметрыФормы.Вставить("НалогообложениеНДС",       Объект.НалогообложениеНДС);
	ПараметрыФормы.Вставить("ВозвращатьМногооборотнуюТару", Объект.ВернутьМногооборотнуюТару);
	Если ОперацииПередачи.Найти(Объект.ХозяйственнаяОперация) <> Неопределено Тогда
		Если Объект.ХозяйственнаяОперация = ПредопределенноеЗначение("Перечисление.ХозяйственныеОперации.ПоставкаПодПринципала") Тогда
			ПараметрыФормы.Вставить("ОтборПоТипуНоменклатуры", Новый ФиксированныйМассив(НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТареРаботе()));
		Иначе
			ПараметрыФормы.Вставить("ОтборПоТипуНоменклатуры", Новый ФиксированныйМассив(НоменклатураКлиентСервер.ОтборПоТоваруМногооборотнойТаре()));
		КонецЕсли;
		ПараметрыФормы.Вставить("СкрыватьРучныеСкидки", Истина);
	КонецЕсли;
	ПараметрыФормы.Вставить("РежимПодбораИспользоватьСкладыВТабличнойЧасти", Истина);
	ПараметрыФормы.Вставить("ИспользоватьДатыОтгрузки",                ИспользоватьПострочнуюОтгрузкуВЗаказеКлиента);
	ПараметрыФормы.Вставить("Склад",                                   Объект.Склад);
	ПараметрыФормы.Вставить("Валюта",                                  Объект.Валюта);
	ПараметрыФормы.Вставить("Заголовок",                               ПараметрЗаголовок);
	ПараметрыФормы.Вставить("Дата",                                    Объект.Дата);
	ПараметрыФормы.Вставить("Документ",                                Объект.Ссылка);
	ПараметрыФормы.Вставить("ПараметрыУказанияСерий",                  ПараметрыУказанияСерий);
	ПараметрыФормы.Вставить("Назначение",                              Объект.Назначение);
	ПараметрыФормы.Вставить("Подразделение",                           Объект.Подразделение);
	ПараметрыФормы.Вставить("ПодборВариантовОбеспечения",              ИспользоватьПострочнуюОтгрузкуВЗаказеКлиента);
	ПараметрыФормы.Вставить("ВариантОбеспеченияИФлагОбособленно",      ВариантОбеспеченияИФлагОбособленно);
	ПараметрыФормы.Вставить("ОграничиватьВариантыОбеспечения",         Не ИспользоватьПострочнуюОтгрузкуВЗаказеКлиента);
	

	ПараметрыФормы.Вставить("ДоступныеОстаткиПараметрыДокумента",
		ОбеспечениеВДокументахКлиент.ДоступныеОстаткиПараметрыДокумента(ЭтотОбъект));
		
	#Вставка
	ПараметрыФормы.Вставить("СтруктураКлиента", Новый Структура("Партнер,Контрагент",Объект.Партнер,Объект.Контрагент));
	#КонецВставки
		
	ОткрытьФорму("Обработка.ПодборТоваровВДокументПродажи.Форма", ПараметрыФормы, ЭтаФорма, УникальныйИдентификатор);

КонецПроцедуры

#КонецОбласти   

#Область ДополнительныеРеквизиты 

 &НаСервере
Процедура ЗаполнитьГруппуДопРеквизитов() 
	 
	ДопМодуль.ПереместитьДополнительныйРеквизит(ЭтаФорма, "КомментарийМенеджера", "ГруппаДопРеквизитов");
	ДопМодуль.ПереместитьДополнительныйРеквизит(ЭтаФорма, "Дата", "ГруппаДопРеквизитов");
	ДопМодуль.ПереместитьДополнительныйРеквизит(ЭтаФорма, "КомментарийРуководителя", "ГруппаДопРеквизитов");  
	
	Если ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "ПеренестиВКалендарь") <>  Неопределено Тогда
		ДопМодуль.ПереместитьДополнительныйРеквизит(ЭтаФорма, "ПеренестиВКалендарь", "ГруппаДопРеквизитовОбщая");  
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
&После("Подключаемый_ПриИзмененииДополнительногоРеквизита")
Процедура Док_Подключаемый_ПриИзмененииДополнительногоРеквизита(Элемент)
	ПриИзмененииДополнительногоРеквизитаНаСервере(Элемент.Имя)
КонецПроцедуры  

&НаСервере
Процедура ПриИзмененииДополнительногоРеквизитаНаСервере(ИмяЭлементаФормы)   
	
	СтруктураПоиска = Новый Структура("ИмяРеквизитаЗначение", ИмяЭлементаФормы);
	МассивСтрок = ЭтотОбъект.Свойства_ОписаниеДополнительныхРеквизитов.НайтиСтроки(СтруктураПоиска);
	ОписаниеСвойства = МассивСтрок[0];
	Если  ОписаниеСвойства.Наименование = "Перенести в календарь" Тогда
		
		ПеренестиВКалендарьЗначение = ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтотОбъект, "ПеренестиВКалендарь");
		
		Если ПеренестиВКалендарьЗначение  Тогда 
			ИзменитьДопРеквизитыПриПереносеВКалендарь();
		КонецЕсли;  
		
	КонецЕсли;
КонецПроцедуры

#КонецОбласти 

#Область СозданиеСобытияКалендаряВБитриксе
&НаСервере
Процедура ДобавитьСобытиеВ_КалендарьБитрикс()
	
	ЗначениеДопРеквизитаДата = ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "Дата");
	Если Час(ЗначениеДопРеквизитаДата) = 0 И Минута(ЗначениеДопРеквизитаДата) = 0 Тогда	
		ЗначениеДопРеквизитаДата = ЗначениеДопРеквизитаДата + 36000;
	КонецЕсли;
	ЗначениеДопРеквизитаКомментарийМенеджера = ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "КомментарийМенеджера");
	НазваниеСобытия = "" + ЗначениеДопРеквизитаКомментарийМенеджера + ", Заказ клиента " + Объект.Номер + ", " + Объект.Партнер;  
	
	ИДВладельцаКалендаря = АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Менеджер);
		
	СтруктураПараметров  = Новый Структура(); 
	СтруктураПараметров.Вставить("ТипКалендаря", "user"); 
    СтруктураПараметров.Вставить("ИДВладельцаКалендаря", ИДВладельцаКалендаря); 
	

    ИДКалендаря = АльтерраВзаимодействиеСБитрикс24.ПолучитьКалендариПользователя(СтруктураПараметров)[0]["ID"];

	
	СтруктураПараметров.Вставить("ИДКалендаря",ИДКалендаря);
	СтруктураПараметров.Вставить("НазваниеСобытия", НазваниеСобытия);
	СтруктураПараметров.Вставить("ОписаниеСобытия", Объект.Комментарий);
	СтруктураПараметров.Вставить("ДатаНачала", ЗначениеДопРеквизитаДата); 
	СтруктураПараметров.Вставить("ДатаОкончания", ЗначениеДопРеквизитаДата + 900); 
	
	Если НужнаВстреча()Тогда  
		ПризнакВстречиСУчастникамиСобытия = "Y";
		СтруктураПараметров.Вставить("СписокУчастников", ПолучитьМассивУчастниковСобытия());
	Иначе
		ПризнакВстречиСУчастникамиСобытия = "N"; 
	КонецЕсли;
	СтруктураПараметров.Вставить("ПризнакВстречиСУчастниками",ПризнакВстречиСУчастникамиСобытия);

	

	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ДобавитьНовоеСобытиеКалендаря(СтруктураПараметров);
	
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
	КонецЕсли;   
	
	Если СтруктураОтвета.Свойство("Результат") Или СтруктураОтвета.Свойство("result") Тогда 
					
	  Объект.ИДСобытия = СтруктураОтвета.result;
	  Записать();			
	  Сообщить("Добавлено Событие Календаря в Битриксе для " + Объект.Менеджер + ". Время события: " + ЗначениеДопРеквизитаДата);   
	КонецЕсли;   	
		
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивУчастниковСобытия()
	
	Руководитель = ДопМодуль.ПолучитьРуководителяОтдела(Объект.Менеджер);
	
	МассивУчастников = Новый Массив;
	МассивУчастников.Добавить(АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(Объект.Менеджер));
	Если Руководитель <> Справочники.Сотрудники.ПустаяСсылка() Тогда	
		РуководительПользователь = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Руководитель, "Пользователь");
		МассивУчастников.Добавить(АльтерраВзаимодействиеСБитрикс24.ПолучитьИДПользователя(РуководительПользователь));
	КонецЕсли;
		
	Возврат МассивУчастников;
 
КонецФункции  

&НаСервере
функция НужнаВстреча() 
	
	НастройкиСозданияСобытий = ПолучитьНастройкиСозданияСобытий();  
	
	Если НастройкиСозданияСобытий = Неопределено Тогда 
		Возврат Ложь;	
	КонецЕсли;
	
	Если Объект.СуммаДокумента > НастройкиСозданияСобытий.МаксимальнаяСуммаСозданияСобытияБезРуководителя Тогда
		Возврат Истина
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции  
  
&НаСервере
Процедура УстановитьЗначениеПеренестиВКалендарьАвтоматически() 
	
	ИнКонца = СтрНайти(СтрокаСоединенияИнформационнойБазы(),";")-1;	 
	
	Если Сред(СтрокаСоединенияИнформационнойБазы(), 7, ИнКонца-7)  <> ПолучитьНастройкиХранилища().НастройкиРабочейБазы.АдресБазы Тогда
		Возврат;	
	КонецЕсли;
 
	ПеренестиВКалендарьЗначение =  ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "ПеренестиВКалендарь"); 
	
	Если ПеренестиВКалендарьЗначение =  Неопределено Тогда 
		Возврат;
    КонецЕсли;
	
	Если НЕ ПеренестиВКалендарьЗначение Тогда
		
		Если ЭтоКлиент_ОтделаРазвития_Или_Коммерческого() Тогда 
			
			НастройкиСозданияСобытий = ПолучитьНастройкиСозданияСобытий();  
			
				Если Объект.Товары.Итог("Сумма") > НастройкиСозданияСобытий.МаксимальнаяСуммаБезАвтоматическогоПереносаВКалендарь Тогда
					ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "ПеренестиВКалендарь", Истина); 
					ИзменитьДопРеквизитыПриПереносеВКалендарь();  
				Иначе
					ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "ПеренестиВКалендарь", Ложь); 
				КонецЕсли;  
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
функция ПолучитьНастройкиСозданияСобытий()
	
	Хранилище = ПолучитьНастройкиХранилища(); 
	
	Если Хранилище.Свойство("НастройкиСозданияСобытийКалендаряИзЗаказаКлиента") Тогда	
		НастройкиСозданияСобытий = Хранилище.НастройкиСозданияСобытийКалендаряИзЗаказаКлиента;
	Иначе 
		НастройкиСозданияСобытий = Неопределено;
	КонецЕсли;
	
	Если НастройкиСозданияСобытий = Неопределено Тогда
		Сообщить("В обработке ""Настройки хранилища"" отсутствуют ""Настройки создания Событий Календаря из Заказа Клиента"" ");
	КонецЕсли;
	
	Возврат НастройкиСозданияСобытий;  
	
КонецФункции 

&НаСервере
функция ПолучитьНастройкиХранилища()
	
	ХранилищеСсылка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Настройки хранилища");
	Возврат ХранилищеСсылка.ХранилищеНастроек.Получить(); 
	
КонецФункции  

&НаСервере
Процедура ИзменитьДопРеквизитыПриПереносеВКалендарь();
	
	ЗначениеДопРеквизитаКомментарийМенеджера =  ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "КомментарийМенеджера");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеДопРеквизитаКомментарийМенеджера) Тогда	
		ДопРеквизитКомментарийМенеджера = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Комментарий менеджера"); 
		ЗвонокКлиенту = Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Звонок клиенту",,, ДопРеквизитКомментарийМенеджера);
		ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "КомментарийМенеджера", ЗвонокКлиенту);
	КонецЕсли;
	
	ЗначениеДопРеквизитаДата =  ДопМодуль.ПолучитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "Дата");
	
	Если НЕ ЗначениеЗаполнено(ЗначениеДопРеквизитаДата) Тогда
		ДопМодуль.УстановитьЗначениеДополнительногоРеквизитаНаФорме(ЭтаФорма, "Дата", Объект.ДатаСоздания + 86400);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЭтоКлиент_ОтделаРазвития_Или_Коммерческого()  
	
	НастройкиСозданияСобытий = ПолучитьНастройкиСозданияСобытий(); 
	
	Если НастройкиСозданияСобытий = Неопределено Тогда 
		Возврат Ложь;	
	КонецЕсли;

	Отделы = НастройкиСозданияСобытий.ОтделыОсновногоМенеджера;
	ПользователиОсновногоМенеджера = НастройкиСозданияСобытий.ПользователиОсновногоМенеджера; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Отдел КАК ОтделИлиПользователь
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО (Сотрудники.Пользователь = Партнеры.ОсновнойМенеджер)
	|ГДЕ 
	|   Партнеры.Ссылка = &Партнер
	|	И Сотрудники.Уволен = ЛОЖЬ
	|	И Сотрудники.ПометкаУдаления = ЛОЖЬ
	|	И Сотрудники.Отдел В (&Отделы)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Партнеры.ОсновнойМенеджер
	|ИЗ
	|	Справочник.Партнеры КАК Партнеры
	|ГДЕ
	|	Партнеры.Ссылка = &Партнер
	|	И Партнеры.ОсновнойМенеджер В (&Пользователи)";  
	
	Запрос.УстановитьПараметр("Партнер", Объект.Партнер); 
	Запрос.УстановитьПараметр("Отделы", Отделы); 
	Запрос.УстановитьПараметр("Пользователи",ПользователиОсновногоМенеджера);
	
	Возврат НЕ Запрос.Выполнить().Пустой();
КонецФункции

&НаКлиенте
Процедура Док_ТоварыПроцентРучнойСкидкиПриИзмененииВместо(Элемент)
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	ОчиститьСообщения();
	ПрименитьОплатуБонуснымиБаллами(ОтправитьВоВременноеХранилище());

	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьЦенуПродажи", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияЦеныВСтрокеТЧ(Объект));
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами");
	СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтотОбъект);
	
	Док_ОбработатьБонуснуюЧасть();
	
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		АльтерраОбщегоНазначенияКлиент.ПересчитатьЦенуСДоставкойПечатьПоСтроке(Текущаястрока);
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Функция ОтправитьВоВременноеХранилище()

	Возврат ПоместитьВоВременноеХранилище(Объект.Товары.Выгрузить());

КонецФункции 

&НаКлиенте
Процедура Док_ТоварыСуммаРучнойСкидкиПриИзмененииВместо(Элемент)
	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	ОчиститьСообщения();
	ПрименитьОплатуБонуснымиБаллами(ОтправитьВоВременноеХранилище());

	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьЦенуПродажи", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияЦеныВСтрокеТЧ(Объект));
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ПересчитатьПроцентРучнойСкидки");
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать, ПересчитыватьСуммуРучнойСкидки", Ложь, Ложь));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами");
	СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтаФорма);
	
	Док_ОбработатьБонуснуюЧасть(); 
	
	//АвтоопределениеДистрибуция
	Если Объект.РаспределитьТранспортныеДистрибуция Тогда
		АльтерраОбщегоНазначенияКлиент.ПересчитатьЦенуСДоставкойПечатьПоСтроке(Текущаястрока);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Док_ТоварыВидЦеныПриИзмененииВместо(Элемент)

	ТекущаяСтрока = Элементы.Товары.ТекущиеДанные;
	
	СтруктураПересчетаСуммы = ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыПересчетаСуммыНДСВСтрокеТЧ(Объект);
	
	ОчиститьСообщения();
	ПрименитьОплатуБонуснымиБаллами(ОтправитьВоВременноеХранилище());

	СтруктураДействий = Новый Структура;
	СтруктураДействий.Вставить("ЗаполнитьЦенуПродажи", ПакетнаяОбработкаТабличнойЧастиКлиентСервер.ПараметрыЗаполненияЦеныВСтрокеТЧ(Объект));
	СтруктураДействий.Вставить("ПересчитатьСуммуНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСуммуСНДС", СтруктураПересчетаСуммы);
	СтруктураДействий.Вставить("ПересчитатьСумму");
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
	СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомСкидкиБонуснымиБаллами");
	СтруктураДействий.Вставить("ЗаполнитьДубликатыЗависимыхРеквизитов", ЗависимыеРеквизиты());
	
	ПакетнаяОбработкаТабличнойЧастиКлиент.ОбработатьСтрокуТЧ(ТекущаяСтрока, СтруктураДействий, КэшированныеЗначения);
	
	РассчитатьИтоговыеПоказателиЗаказа(ЭтотОбъект);
	
	СкидкиНаценкиЗаполнениеКлиент.СброситьФлагСкидкиРассчитаны(ЭтотОбъект);
	
	Док_ОбработатьБонуснуюЧасть();
	РаспределитьТранспортныеДистрибуцияПриИзмененииСтроки();
КонецПроцедуры

