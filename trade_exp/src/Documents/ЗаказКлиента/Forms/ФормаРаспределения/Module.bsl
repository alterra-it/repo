
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ТаблТоваров = Параметры.Товары.Выгрузить();
	
	ТаблицаРаспределения.Загрузить(ТаблицаБезУслуг(ТаблТоваров));
	
КонецПроцедуры   

&НаСервере
Функция ТаблицаБезУслуг(ТаблТоваров)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблТоваров.Номенклатура,
		|	ТаблТоваров.Характеристика,
		|	ТаблТоваров.Склад,
		|	ТаблТоваров.Количество,
		|	ТаблТоваров.Распределять
		|ПОМЕСТИТЬ ТаблОбщая
		|ИЗ
		|	&ТаблТоваров КАК ТаблТоваров
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблОбщая.Номенклатура,
		|	ТаблОбщая.Характеристика,
		|	ТаблОбщая.Склад,
		|	ТаблОбщая.Количество,
		|	ТаблОбщая.Распределять
		|ИЗ
		|	ТаблОбщая КАК ТаблОбщая
		|ГДЕ
		|	ТаблОбщая.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)";
		
	Запрос.УстановитьПараметр("ТаблТоваров"	,ТаблТоваров);
	Возврат Запрос.Выполнить().Выгрузить();	

Конецфункции 

&НаКлиенте
Процедура ВыбратьСтроки(Команда)
	ОтметитьСтроки(1);
КонецПроцедуры

&НаКлиенте
Процедура ИсключитьСтроки(Команда)
	ОтметитьСтроки(0);
КонецПроцедуры

&НаСервере
Процедура ОтметитьСтроки(Значение)

	Для Каждого СтрокаТЧ Из ТаблицаРаспределения Цикл

		СтрокаТЧ.Распределять = Значение;

	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	ПеренестиСтрокиВДокумент();
КонецПроцедуры  

&НаКлиенте
Процедура ПеренестиСтрокиВДокумент()

	// Снятие модифицированности, т.к. перед закрытием признак проверяется.
	Модифицированность = Ложь;

	АдресВХранилище = ПоместитьТоварыВХранилище();

	Закрыть();

	ОповеститьОВыборе(Новый Структура("АдресТоваровВХранилище", АдресВХранилище));

КонецПроцедуры 

&НаСервере
Функция ПоместитьТоварыВХранилище()

	АдресВХранилище = ПоместитьВоВременноеХранилище(ТаблицаРаспределения.Выгрузить(),Новый УникальныйИдентификатор);

	Возврат АдресВХранилище;

КонецФункции

