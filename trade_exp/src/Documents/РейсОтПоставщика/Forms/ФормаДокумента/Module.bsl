//Этапы
&НаСервере
Процедура ПерейтиНаСледующийЭтап()
	Отказ= Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.СтавкаНДС) Тогда
		Отказ= Истина;
		Сообщить("Не заполнена ставка НДС!", СтатусСообщения.ОченьВажное);
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Статус) Тогда
		Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Создан;
		
	ИначеЕсли Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Создан Тогда
		Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Выполняется;
		
	ИначеЕсли Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Выполняется Тогда
		Если Не Отказ Тогда
			Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.ВПути;
		КонецЕсли;
		
	ИначеЕсли Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.ВПути Тогда
		Если Объект.ТранзитФизЛицо Тогда 
			Документы.РейсОтПоставщика.ОтгрузитьТранзитныйЗаказНаСервере(Объект, (Объект.СтавкаНДС = Перечисления.СтавкиНДС.БезНДС), Отказ);
			РасчитатьИтоги();
			Если Отказ Тогда
				Сообщить("Распределение не произошло!", СтатусСообщения.ОченьВажное);
			КонецЕсли;
		КонецЕсли;
		
		Если Не Отказ Тогда
			Разница= Объект.ФактическаяСтоимостьДоставки - (Объект.ЗаложеноВСтоимость+Объект.ЗаложеноВСтоимостьБезНДС); 
			Если Разница > 5 Тогда
				Отказ= Истина;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Фактическая стоимость рейса не совпадает со стоимостью заложенной в транспортные расходы!", Объект.Ссылка, "Объект.ЗаложеноВСтоимость");
			КонецЕсли;
		КонецЕсли;
		
		Если Не Отказ Тогда
			Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Прибыл;//Перечисления.СтатусыРейсовНаПоставку.Доставлен;
		КонецЕсли;
		
	ИначеЕсли Объект.Статус = Перечисления.СтатусыРейсовНаПоставку.Прибыл Тогда
		Объект.Статус = Перечисления.СтатусыРейсовНаПоставку.Доставлен;
		
	ИначеЕсли Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Доставлен Тогда
		Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.ДокументыСданы;
		
	ИначеЕсли Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.ДокументыСданы Тогда
		Объект.ДатаПодачиНаОплату= ТекущаяДата();
		Объект.Статус= Перечисления.СтатусыРейсовНаПоставку.Оплачен;
	КонецЕсли;
	
	Если Не Отказ Тогда
		//ЭтаФорма.Модифицированность= Истина;
		Записать();
	КонецЕсли;

КонецПроцедуры
