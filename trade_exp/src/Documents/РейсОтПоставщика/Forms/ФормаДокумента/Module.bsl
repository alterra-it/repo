	МассивСкладовИНормативов.Колонки.Добавить("Поток", Новый ОписаниеТипов("СправочникСсылка.ПотокиТранспортныхСредствПоставкиНаСклад"));
	МассивСкладовИНормативов.Колонки.Добавить("ДатаНачалаИнтервала", Новый ОписаниеТипов("Дата"));
