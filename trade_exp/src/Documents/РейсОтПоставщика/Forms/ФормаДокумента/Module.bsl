&НаКлиенте
Процедура ПредупредитьПользователя(ТекстОповещения)
	ПоказатьОповещениеПользователя("Сетка поставок | заказ "+ Объект.Номер, ПолучитьНавигационнуюСсылку(Объект.Ссылка), ТекстОповещения, БиблиотекаКартинок.ИсторияДанных, СтатусОповещенияПользователя.Важное); 
КонецПроцедуры

&НаКлиенте
Процедура ПресчитатьСекциюНаКлиенте(Команда)
	СекцияИзменилась = Ложь;
	МассивСкладов = Новый массив;
	ИдентификаторыВыделенныхСтрок = Элементы.ГруппаПоставки.ВыделенныеСтроки;
	
	Для каждого Идентификатор из ИдентификаторыВыделенныхСтрок Цикл
		ТекущаяСтрока = Объект.ГруппаПоставки.НайтиПоИдентификатору(Идентификатор);
		МассивСкладов.Добавить(ТекущаяСтрока.Склад);
	КонецЦикла;
	
	ПресчитатьСекцию(СекцияИзменилась, МассивСкладов);
	Если СекцияИзменилась Тогда 
		ПредупредитьПользователя("Секция изменилась. Запланируйте новое время в сетке");
		ДанныеПоставкиИзменились = Истина;
	КонецЕсли;
	
	ПересчитатьПоНормативу(ИдентификаторыВыделенныхСтрок);
КонецПроцедуры

&НаСервере
Процедура ПресчитатьСекцию(СекцияИзменилась, Склады = Неопределено)
	
	РезультатЗапроса = Документы.РейсОтПоставщика.ПолучитьДанныеПоСкладамИСекциям(Объект, Склады);
	ВыборкаИтог = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Если ВыборкаИтог.Следующий() Тогда
		СтрокиТекущегоСклада = Объект.ГруппаПоставки.НайтиСтроки(Новый Структура("Склад", ВыборкаИтог.Склад));
		Выборка = ВыборкаИтог.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			Если ВыборкаИтог.ОбъемПоСекции = Выборка.ОбъемПоСекции Тогда
				СекцияБыла = СтрокиТекущегоСклада[0].Секция;
				СтрокиТекущегоСклада[0].Секция = Выборка.Секция;
				 
				Если СекцияБыла <> СтрокиТекущегоСклада[0].Секция Тогда		
					ВремяПоступления = '00010101000000';//
					СекцияИзменилась = Истина;
				КонецЕсли;
				Модифицированность = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыборВремениВручнуюНаКлиенте(Команда)
	ИдентификаторыВыделенныхСтрок = Элементы.ГруппаПоставки.ВыделенныеСтроки;
	Если ИдентификаторыВыделенныхСтрок.Количество()>1 Тогда
		Сообщить("Необходимо выделить одну строку для выбора времени вручную");
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = Элементы.ГруппаПоставки.ТекущиеДанные;
	Если ТекущаяСтрока.ПродолжительностьРазгрузки = 0 Тогда
		Сообщить("Укажите ненулевую длительность погрузки!");
		Возврат;
	КонецЕсли;
	
	//записать изменения
	Если Модифицированность Тогда
		//Предупреждение("Документ будет записан!",2,"Изменения в поставке");
		Если Объект.Проведен Тогда
			ЭтотОбъект.Записать();
		Иначе
			Сообщить("Документ требуется провести!");
			Возврат;
		КонецЕсли;
		ЗаписатьИнтервалДоставкиСервер(ТекущаяСтрока.ПолучитьИдентификатор());
	КонецЕсли;
	Если ТекущаяСтрока.Секция <> ПредопределенноеЗначение("Справочник.РабочиеУчастки.ПустаяСсылка") Тогда
		ПараметрыОткрытияФормыПодбора = Новый Структура;
		ПараметрыОткрытияФормыПодбора.Вставить("Период", ?(ТекущаяСтрока.ДатаРазгрузки=Дата(1,1,1), ТекущаяДата(), ТекущаяСтрока.ДатаРазгрузки));
		ПараметрыОткрытияФормыПодбора.Вставить("Секция", ТекущаяСтрока.Секция);
		ПараметрыОткрытияФормыПодбора.Вставить("ИзФормыЗаказа", Истина);
		ПараметрыОткрытияФормыПодбора.Вставить("ПродолжительностьРазгрузки", ТекущаяСтрока.ПродолжительностьРазгрузки);
		ПараметрыОткрытияФормыПодбора.Вставить("ЗаказПоставщику", Объект.Ссылка);
		ПараметрыОткрытияФормыПодбора.Вставить("КомментарийКПоставке", ТекущаяСтрока.ПримечаниеКПоставке);
		
		СписокДопРесурсов = Новый СписокЗначений;
		Если ТекущаяСтрока.Эстакада Тогда
			СписокДопРесурсов.Добавить(ПолучитьЭстакаду(Истина));
		Иначе
			СписокДопРесурсов.Добавить(ПолучитьЭстакаду(Ложь));
		КонецЕсли;
		ПараметрыОткрытияФормыПодбора.Вставить("ДополнительныеРесурсы", СписокДопРесурсов);
		
		//ПараметрыОткрытияФормыПодбора.Вставить("Оборудование", ?(ТекущаяСтрока.Эстакада, ПолучитьЭстакаду(Истина), ПолучитьЭстакаду(Ложь))); 
		//ПараметрыОткрытияФормыПодбора.Вставить("НельзяВыбиратьДату", ЕстьРейсПоПоставке());
		
		ОткрытьФорму("Обработка.ПланировщикПоставокНаСклад.Форма", ПараметрыОткрытияФормыПодбора, ЭтаФорма,,,,Новый ОписаниеОповещения("ОбновитьДанныеПоставкиПослеЗакрытияПланировщика", ЭтотОбъект));
		ОчиститьСообщения();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеПоставкиПослеЗакрытияПланировщика(Результат=Неопределено, ДополнительныеПараметры=Неопределено) Экспорт
	 ОбновитьВремяИИнтервалПоставки();
КонецПроцедуры

&НаСервере
Функция ПолучитьЭстакаду(НеПустая = Истина)
	Если НеПустая Тогда
		Возврат Справочники.ТехническиеРесурсыСклада.НайтиПоКоду("000000001");
	Иначе 
		Возврат Справочники.ТехническиеРесурсыСклада.ПустаяСсылка();
	КонецЕсли;
КонецФункции

&НаСервере
Процедура ЗаписатьИнтервалДоставкиСервер(ИдентицикаторТекущейСтроки)
	
	ТекущаяСтрока = Объект.ГруппаПоставки.НайтиПоИдентификатору(ИдентицикаторТекущейСтроки);
	
	Если //ДанныеПоставкиИзменились И 
		Альтерра_СеткаПоставок.ЕстьСекцииУСклада(ТекущаяСтрока.Склад) Тогда
		ПараметрыЗаписи = Новый Соответствие;
		ОсновнойПоток = ПолучитьПотокПоСекции(ТекущаяСтрока.Секция);
		ЗначениеПараметров = Новый Структура;
		ЗначениеПараметров.Вставить("Поток", ОсновнойПоток);
		ЗначениеПараметров.Вставить("ЗаказПоставщику", Объект.Ссылка);
		ЗначениеПараметров.Вставить("ДатаВремяРазгрузкиПлан", ТекущаяСтрока.ДатаРазгрузки + Минута(ТекущаяСтрока.ВремяПоступления)*60 + Час(ТекущаяСтрока.ВремяПоступления)*3600);
		ЗначениеПараметров.Вставить("ПродолжительностьРазгрузки", ТекущаяСтрока.ПродолжительностьРазгрузки);
		ЗначениеПараметров.Вставить("СогласованоСоСкладом", ТекущаяСтрока.СогласованоСоСкладом);
		ЗначениеПараметров.Вставить("ТекстПоставки", ТекущаяСтрока.ПримечаниеКПоставке);
		ЗначениеПараметров.Вставить("Склад", ТекущаяСтрока.Склад);
		ЗначениеПараметров.Вставить("Оборудование", ?(ТекущаяСтрока.Эстакада, ПолучитьЭстакаду(Истина), ПолучитьЭстакаду(Ложь)));
		ПараметрыЗаписи.Вставить(Объект.Ссылка, ЗначениеПараметров);
		Альтерра_СеткаПоставок.ИзменитьДанныеСеткиПоставок(Объект.Ссылка, "Новое",  ПараметрыЗаписи, Истина, ТекущаяСтрока.Склад, Альтерра_СеткаПоставок.ПолучитьДопПотокиПоСкладу(ТекущаяСтрока.Склад, Объект.Ссылка, ОсновнойПоток));
	КонецЕсли; 
	
КонецПроцедуры 

&НаКлиенте
Процедура ПересчитатьПоНормативуНаКлиенте(Команда)
	ИдентификаторыВыделенныхСтрок = Элементы.ГруппаПоставки.ВыделенныеСтроки;
	ПересчитатьПоНормативу(ИдентификаторыВыделенныхСтрок);
КонецПроцедуры

&НаСервере
Процедура ПересчитатьПоНормативу(ИдентификаторыВыделенныхСтрок = Неопределено)
	МассивСкладовИНормативов = Новый ТаблицаЗначений;
	МассивСкладовИНормативов.Колонки.Добавить("Склад", Новый ОписаниеТипов("СправочникСсылка.Склады"));
	МассивСкладовИНормативов.Колонки.Добавить("Норматив", Новый ОписаниеТипов("СправочникСсылка.НормативыПриемкиПоставкиНаСклад"));
	МассивСкладовИНормативов.Колонки.Добавить("Поток", Новый ОписаниеТипов("СправочникСсылка.ПотокиТранспортныхСредствПоставкиНаСклад"));
	МассивСкладовИНормативов.Колонки.Добавить("ДатаНачалаИнтервала", Новый ОписаниеТипов("Дата"));
	МассивСкладовИНормативов.Колонки.Добавить("ДатаОкончанияИнтервала", Новый ОписаниеТипов("Дата"));
	МассивСкладовИНормативов.Колонки.Добавить("ПродолжительностьРазгрузки", Новый ОписаниеТипов("Число"));
	МассивСкладовИНормативов.Колонки.Добавить("Эстакада", Новый ОписаниеТипов("Булево"));
	
	Для каждого Идентификатор из ИдентификаторыВыделенныхСтрок Цикл
		ТекущаяСтрока = Объект.ГруппаПоставки.НайтиПоИдентификатору(Идентификатор);
		НоваяСтрока = МассивСкладовИНормативов.Добавить();//поправить ТЗ
		НоваяСтрока.Склад = ТекущаяСтрока.Склад;
		НоваяСтрока.Норматив = ТекущаяСтрока.Норматив;
		НоваяСтрока.Поток = ТекущаяСтрока.Поток;
		НоваяСтрока.ДатаНачалаИнтервала = ТекущаяСтрока.ДатаРазгрузки;
		НоваяСтрока.ДатаОкончанияИнтервала = ТекущаяСтрока.ДатаРазгрузки+ТекущаяСтрока.ПродолжительностьРазгрузки;
		НоваяСтрока.ПродолжительностьРазгрузки = ТекущаяСтрока.ПродолжительностьРазгрузки;
		НоваяСтрока.Эстакада = ТекущаяСтрока.Эстакада;
	КонецЦикла;
	ЗаполнитьПоНормативу(, МассивСкладовИНормативов);
	ДанныеПоставкиИзменились = Истина;
	ПроверитьИнтервалыСкладовНаДоступность(МассивСкладовИНормативов);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоНормативу(РучнойПересчет=Ложь, ТЗСкладИНорматив = Неопределено)

	Запрос = Новый Запрос; // Переписать запрос на рейс от поставщика
	Запрос.Текст = "ВЫБРАТЬ
		|	ТЗНормативы.Склад КАК Склад,
		|	ТЗНормативы.Норматив КАК Норматив
		|ПОМЕСТИТЬ ВТНормативыПоСкладу
		|ИЗ
		|	&ТЗНормативы КАК ТЗНормативы
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТЗ.Документ КАК ДокументОснование
		|ПОМЕСТИТЬ ВТОснованияРейса
		|ИЗ
		|	&ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.Номенклатура КАК Номенклатура,
		|	ПеремещениеТоваровТовары.Ссылка КАК Перемещение,
		|	ПеремещениеТоваровТовары.Упаковка КАК Упаковка,
		|	ПеремещениеТоваровТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВТНормативыПоСкладу.Норматив КАК Норматив
		|ПОМЕСТИТЬ втТовары
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОснованияРейса КАК ВТОснованияРейса
		|		ПО (ВТОснованияРейса.ДокументОснование = ЗаказНаДоставкуКлиентуОснования.Ссылка)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНормативыПоСкладу КАК ВТНормативыПоСкладу
		|			ПО ВТНормативыПоСкладу.Склад = ПеремещениеТоваровТовары.Ссылка.СкладПолучатель
		|		ПО (ЗаказНаДоставкуКлиентуОснования.Документ = ПеремещениеТоваровТовары.Ссылка) 
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втТовары.Перемещение КАК Перемещение,
		|	втТовары.Номенклатура КАК Номенклатура,
		|	втТовары.Перемещение.СкладПолучатель КАК Склад,
		|	втТовары.Норматив КАК Норматив,
		|	втТовары.КоличествоУпаковок КАК КоличествоУпаковок,
		|	ВЫБОР
		|		КОГДА втТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
		|			ТОГДА спрНоменклатура.ЕдиницаИзмерения
		|		ИНАЧЕ втТовары.Упаковка
		|	КОНЕЦ КАК Упаковка,
		|	спрНоменклатура.ВесЕдиницаИзмерения КАК НоменклатураВесЕдиницаИзмерения,
		|	спрНоменклатура.ОбъемЕдиницаИзмерения КАК НоменклатураОбъемЕдиницаИзмерения,
		|	ВЫБОР
		|		КОГДА спрНоменклатура.ВесЗнаменатель <> 0
		|			ТОГДА спрНоменклатура.ВесЧислитель / спрНоменклатура.ВесЗнаменатель
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ВесКоэффициентНоменклатура,
		|	ВЫБОР
		|		КОГДА спрНоменклатура.ОбъемЗнаменатель <> 0
		|			ТОГДА спрНоменклатура.ОбъемЧислитель / спрНоменклатура.ОбъемЗнаменатель
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ОбъемКоэффициентНоменклатура
		|ПОМЕСТИТЬ втНоменклатураДокумента
		|ИЗ
		|	втТовары КАК втТовары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК спрНоменклатура
		|		ПО втТовары.Номенклатура = спрНоменклатура.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	втНоменклатураДокумента.Номенклатура КАК Номенклатура,
		|	втНоменклатураДокумента.Упаковка КАК Упаковка,
		|	втНоменклатураДокумента.КоличествоУпаковок КАК КоличествоУпаковок,
		|	втНоменклатураДокумента.Перемещение КАК Ссылка,
		|	втНоменклатураДокумента.Склад КАК Склад,      
		|	ВЫБОР
		|		КОГДА НормативыПриемкиПоставкиНаСклад.ЕдИзмеренияЗнаменателя.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Вес)
		|			ТОГДА втНоменклатураДокумента.НоменклатураВесЕдиницаИзмерения
		|		ИНАЧЕ втНоменклатураДокумента.НоменклатураОбъемЕдиницаИзмерения
		|	КОНЕЦ КАК НоменклатураЕдиницаИзмерения,
		|	ВЫБОР
		|		КОГДА НормативыПриемкиПоставкиНаСклад.ЕдИзмеренияЗнаменателя.ТипИзмеряемойВеличины = ЗНАЧЕНИЕ(Перечисление.ТипыИзмеряемыхВеличин.Вес)
		|			ТОГДА втНоменклатураДокумента.ВесКоэффициентНоменклатура
		|		ИНАЧЕ втНоменклатураДокумента.ОбъемКоэффициентНоменклатура
		|	КОНЕЦ КАК НоменклатураКоэффициент,
		|	НормативыПриемкиПоставкиНаСклад.Норматив КАК Норматив,
		|	НормативыПриемкиПоставкиНаСклад.ЕдИзмеренияЗнаменателя КАК ЕдИзмеренияЗнаменателя,
		|	НормативыПриемкиПоставкиНаСклад.МинимальноеВремя КАК МинимальноеВремя,
		|	НормативыПриемкиПоставкиНаСклад.МаксимальноеВремя КАК МаксимальноеВремя
		|ПОМЕСТИТЬ втИтогДляВремени
		|ИЗ
		|	Справочник.НормативыПриемкиПоставкиНаСклад КАК НормативыПриемкиПоставкиНаСклад
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втНоменклатураДокумента КАК втНоменклатураДокумента   
		|		ПО втНоменклатураДокумента.Норматив = НормативыПриемкиПоставкиНаСклад.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Итог.Упаковка КАК Упаковка,
		|	Итог.КоличествоУпаковок КАК КоличествоУпаковок,
		|	Итог.НоменклатураКоэффициент КАК НоменклатураКоэффициент,
		|	Итог.НоменклатураЕдиницаИзмерения.Числитель КАК НоменклатураЕдиницаИзмеренияЧислитель,
		|	Итог.НоменклатураЕдиницаИзмерения.Знаменатель КАК НоменклатураЕдиницаИзмеренияЗнаменатель,
		|	Итог.ЕдИзмеренияЗнаменателя.Числитель КАК ЕдИзмеренияЗнаменателяЧислитель,
		|	Итог.Норматив КАК Норматив,
		|	ЕСТЬNULL(Итог.КоличествоУпаковок * Итог.НоменклатураКоэффициент * Итог.НоменклатураЕдиницаИзмерения.Числитель / Итог.НоменклатураЕдиницаИзмерения.Знаменатель * Итог.ЕдИзмеренияЗнаменателя.Знаменатель / Итог.ЕдИзмеренияЗнаменателя.Числитель * Итог.Норматив, 0) КАК ВремяРассчитанное,
		|	Итог.Ссылка КАК Ссылка,
		|	Итог.Склад КАК Склад,
		|	Итог.МинимальноеВремя КАК МинимальноеВремя,
		|	Итог.МаксимальноеВремя КАК МаксимальноеВремя
		|ИЗ
		|	втИтогДляВремени КАК Итог
		|ИТОГИ
		|	МАКСИМУМ(МинимальноеВремя),
		|	МАКСИМУМ(МаксимальноеВремя)
		|ПО
		|	Склад";
	Запрос.УстановитьПараметр("ТЗ", Объект.Основания.Выгрузить());
	Запрос.УстановитьПараметр("ТЗНормативы", ?(ТЗСкладИНорматив = Неопределено, Объект.ГруппаПоставки.Выгрузить(), ТЗСкладИНорматив));
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	ВыборкаИтог = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ВремяРазгрузки = 0;
	Пока ВыборкаИтог.Следующий() Цикл 
		СтрокиТекущегоСклада = Объект.ГруппаПоставки.НайтиСтроки(Новый Структура("Склад", ВыборкаИтог.Склад));
		ВыборкаДетальные = ВыборкаИтог.Выбрать();
		Пока ВыборкаДетальные.Следующий() Цикл
			ВремяРазгрузки = ВремяРазгрузки + ВыборкаДетальные.ВремяРассчитанное;
		КонецЦикла;
		СтрокиТекущегоСклада[0].ПродолжительностьРазгрузки = Мин(Макс(ВремяРазгрузки, ВыборкаИтог.МинимальноеВремя), ВыборкаИтог.МаксимальноеВремя);
		ОкрПродолжительностьРазгрузки = Окр(СтрокиТекущегоСклада[0].ПродолжительностьРазгрузки, -1, РежимОкругления.Окр15как20);
		Если ОкрПродолжительностьРазгрузки < СтрокиТекущегоСклада[0].ПродолжительностьРазгрузки Тогда
			СтрокиТекущегоСклада[0].ПродолжительностьРазгрузки = ОкрПродолжительностьРазгрузки+5;
		КонецЕсли;
	
		Если СтрокиТекущегоСклада[0].ПродолжительностьРазгрузки = 0 Тогда
			СтрокиТекущегоСклада[0].ПродолжительностьРазгрузки = СтрокиТекущегоСклада[0].Норматив.МинимальноеВремя;
		КонецЕсли;
	КонецЦикла;	
	
	Модифицированность = Истина;
	
КонецПроцедуры // ЗаполнитьПоНормативу()

&НаСервере
Процедура ПроверитьИнтервалыСкладовНаДоступность(МассивСкладовИНормативов)
	
	РезультатПроверки = Новый Структура;
	РезультатПроверки.Вставить("ИнтервалДоступен", Истина);
	РезультатПроверки.Вставить("СброситьВремя", Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	&Рейс КАК Рейс,
	|	ТЧ.Склад КАК Склад,
	|	ТЧ.ДатаНачалаИнтервала КАК ДатаНачалаИнтервала,
	|	ТЧ.ДатаОкончанияИнтервала КАК ДатаОкончанияИнтервала,
	|	ТЧ.Поток КАК Поток,
	|	ТЧ.Эстакада КАК Эстакада
	|ПОМЕСТИТЬ втРесурсыДокумента
	|ИЗ
	|	&СписокОборудования КАК ТЧ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику КАК ЗаказПоставщику,
	|	ГрафикПоставокНаСкладСрезПоследних.Поток КАК Поток,
	|	втРесурсыДокумента.Склад КАК Склад,
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК НачалоИнтервала,
	|	ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки) КАК КонецИнтервала,
	|	""Занятый интервал"" КАК Причина
	|ПОМЕСТИТЬ ВТЗанятыеИнтервалы
	|ИЗ
	|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних КАК ГрафикПоставокНаСкладСрезПоследних
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ втРесурсыДокумента КАК втРесурсыДокумента
	|		ПО ГрафикПоставокНаСкладСрезПоследних.Поток = втРесурсыДокумента.Поток
	|			И (НЕ ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику = втРесурсыДокумента.Рейс)
	|
	|ГДЕ
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан <> &ПустаяДата
	|
	|СГРУППИРОВАТЬ ПО
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику,
	|	ГрафикПоставокНаСкладСрезПоследних.Поток,
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан,
	|	ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки,
	|	втРесурсыДокумента.ДатаНачалаИнтервала,
	|	втРесурсыДокумента.ДатаОкончанияИнтервала,
	|	втРесурсыДокумента.Склад
	|
	|ИМЕЮЩИЕ
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан МЕЖДУ втРесурсыДокумента.ДатаНачалаИнтервала И ДОБАВИТЬКДАТЕ(втРесурсыДокумента.ДатаОкончанияИнтервала, СЕКУНДА, -1)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику КАК ЗаказПоставщику,
	|	втРесурсыДокумента.Склад КАК Склад,
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК ДатаВремяРазгрузкиПлан,
	|	ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки) КАК ДатаВремяОкончанияРазгрузки,
	|	ГрафикПоставокНаСкладСрезПоследних.Оборудование КАК Оборудование,
	|	ВЫБОР
	|		КОГДА НЕ ГрафикПоставокНаСкладСрезПоследних.Оборудование = ЗНАЧЕНИЕ(Справочник.ТехническиеРесурсыСклада.ПустаяСсылка)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЭстакадаРегистр,
	|	ВЫБОР
	|		КОГДА втРесурсыДокумента.Эстакада
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК ЭстакадаДокумент,
	|	""Эстакада"" КАК Причина
	|ПОМЕСТИТЬ ВТЭстакада
	|ИЗ
	|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних КАК ГрафикПоставокНаСкладСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.Секции КАК ПотокиТранспортныхСредствПоставкиНаСкладСекции
	|			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РабочиеУчастки КАК РабочиеУчастки
	|				ЛЕВОЕ СОЕДИНЕНИЕ втРесурсыДокумента КАК втРесурсыДокумента
	|				ПО РабочиеУчастки.Владелец = втРесурсыДокумента.Склад
	|			ПО ПотокиТранспортныхСредствПоставкиНаСкладСекции.Секция = РабочиеУчастки.Ссылка
	|		ПО ГрафикПоставокНаСкладСрезПоследних.Поток = ПотокиТранспортныхСредствПоставкиНаСкладСекции.Ссылка
	|
	|ГДЕ
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан <> &ПустаяДата
	|
	|СГРУППИРОВАТЬ ПО
	|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику,
	|	втРесурсыДокумента.Склад,
	|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан,
	|	ГрафикПоставокНаСкладСрезПоследних.Оборудование,
	|	втРесурсыДокумента.Эстакада,
	|	втРесурсыДокумента.ДатаНачалаИнтервала,
	|	втРесурсыДокумента.ДатаОкончанияИнтервала,
	|	ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки
	|
	|ИМЕЮЩИЕ
	|	(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан МЕЖДУ втРесурсыДокумента.ДатаНачалаИнтервала И ДОБАВИТЬКДАТЕ(втРесурсыДокумента.ДатаОкончанияИнтервала, СЕКУНДА, -1)
	|		ИЛИ ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки) МЕЖДУ втРесурсыДокумента.ДатаНачалаИнтервала И ДОБАВИТЬКДАТЕ(втРесурсыДокумента.ДатаОкончанияИнтервала, СЕКУНДА, -1)
	|		ИЛИ втРесурсыДокумента.ДатаНачалаИнтервала МЕЖДУ ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан И ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки)
	|		ИЛИ втРесурсыДокумента.ДатаОкончанияИнтервала МЕЖДУ ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан И ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки)) И
	|	ВЫБОР
	|		КОГДА НЕ ГрафикПоставокНаСкладСрезПоследних.Оборудование = ЗНАЧЕНИЕ(Справочник.ТехническиеРесурсыСклада.ПустаяСсылка)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ = ВЫБОР
	|		КОГДА втРесурсыДокумента.Эстакада
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ И
	|	ВЫБОР
	|		КОГДА втРесурсыДокумента.Эстакада
	|			ТОГДА 1
	|		ИНАЧЕ 0
