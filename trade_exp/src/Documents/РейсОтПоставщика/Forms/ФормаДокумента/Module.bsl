&НаКлиенте
Процедура ОтправитьТТНПоПочте(Команда)
	ТабличныйДокумент = ПолучитьТабДокТТН();
	Если ТабличныйДокумент = Неопределено Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю("Печатная форма не была сформирована!");
		Возврат;
	КонецЕсли;
	
	ИмяПечатнойФормы= "ТТН";
		
	ПараметрыОтправки = Новый Структура;//Кому, Тема, Тело, Вложения, АдресОтвета, ТипТекста, Копии, СлепыеКопии;
	Партнер= Объект.ПеревозчикПартнер;
	ПочтаПартнера= АльтерраОбщегоНазначения.ПолучитьСведеньяОПартнере(Партнер).ПочтаПартнера;
	ПараметрыОтправки.Вставить("Кому", ПочтаПартнера);
	Получатель= Новый СписокЗначений;
	Получатель.Добавить(ПочтаПартнера, Партнер);
	ПараметрыОтправки.Вставить("Получатель", Получатель);


	ПараметрыОтправки.Вставить("Тема", ИмяПечатнойФормы);
	ПараметрыОтправки.Вставить("Тело", "Отправляем вам "+ИмяПечатнойФормы);
	ПараметрыОтправки.Вставить("Текст", "Отправляем вам "+ИмяПечатнойФормы);
	
	Отправитель= Новый СписокЗначений; 
	
    ИмяОтправителя = ПолучитьИмяОтправителя();
	
	Отправитель.Добавить(ПредопределенноеЗначение("Справочник.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты"), ИмяОтправителя);
	ПараметрыОтправки.Вставить("Отправитель", Отправитель);
	
	ИмяФайла= ИмяПечатнойФормы+"." + "pdf";
	АдресВоВременномХранилище = ПоместитьТабличныеДокументыВоВременноеХранилище(ТабличныйДокумент,  ИмяФайла);
	Вложения= Новый Массив;
	Вложение= Новый Структура("Представление,АдресВоВременномХранилище", ИмяФайла, АдресВоВременномХранилище);
	Вложения.Добавить(Вложение);
	ПараметрыОтправки.Вставить("Вложения", Вложения);
	
	//ПараметрыОтправки.Вставить("АдресОтвета", АдресОтвета);
	
	//ОтправитьПочтовоеСообщение(ПараметрыОтправки);  //Отправка фоном
	
	ТабличныеДокументы= Новый СписокЗначений;
	ТабличныеДокументы.Добавить(ТабличныйДокумент, ИмяПечатнойФормы);
	МодульРаботаСПочтовымиСообщениямиКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("РаботаСПочтовымиСообщениямиКлиент");
	МодульРаботаСПочтовымиСообщениямиКлиент.ОтправитьТабличныеДокументы(ТабличныеДокументы, ИмяПечатнойФормы, ПараметрыОтправки);
КонецПроцедуры

