&НаКлиенте
Процедура ПроверитьСостояниеОплаты(Команда)
	БылиИзменения = ПроверитьСостояниеОплатыНаСервере();
	Если БылиИзменения Тогда
		Прочитать();    
	КонецЕсли;  
	РасчитатьИтоги();
КонецПроцедуры
&НаСервере

Функция ПроверитьСостояниеОплатыНаСервере()
	МассивРейсов = Новый Массив;
	МассивРейсов.Добавить(Объект.Ссылка);
	БылиИзменения = Документы.РейсОтПоставщика.ПроверитьСостояниеОплатыРейса(МассивРейсов);
	Возврат БылиИзменения;
КонецФункции  

&НаКлиенте
Процедура РаспределитьТранспортные(Команда)

Если ЕщеНеРаспределено() Тогда
	ДополнительнаяОбработкаСсылка = ПолучитьСсылку(); 
	ДоступноВыполнениеВФоне = НЕ ДополнительнаяОбработкаСсылка.Пустая(); 
	Если ДоступноВыполнениеВФоне Тогда
		ДлительнаяОперация = РаспределитьТранспортныеНаСервере(ДополнительнаяОбработкаСсылка);
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ОбработатьРезультат", ЭтотОбъект);
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;   
КонецЕсли;   

КонецПроцедуры                     

&НаКлиенте
Процедура ОбработатьРезультат(Результат, ДополнительныеПараметры) Экспорт 
	Если Результат = Неопределено Тогда
     Возврат; 
 	ИначеЕсли Результат.Статус = "Выполнено" Тогда
       ТекстСообщения = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	 	Если ТекстСообщения > 0 Тогда
			Прочитать(); 
			РасчитатьИтоги();
			ОбщегоНазначенияКлиент.СообщитьПользователю("Данные оплат обновлены.");
		КонецЕсли;
	ИначеЕсли Результат.Статус = "Ошибка" Тогда                                     
    	ТекстСообщения = Результат.ПодробноеПредставлениеОшибки;   
		ОбщегоНазначенияКлиент.СообщитьПользователю("При создании документа возникла ошибка: "+ ТекстСообщения);
	КонецЕсли;   
	
КонецПроцедуры	

&НаСервере                                 
Функция РаспределитьТранспортныеНаСервере(ВнешняяОбработка)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор); 
	ПараметрыРасчета = Новый Структура("ТолькоПроверка, ПереданныйРейс", Ложь, Объект.Ссылка);
	ВыполняемыйМетод = "ДлительныеОперации.ВыполнитьПроцедуруМодуляОбъектаОбработки";
	ПараметрыЗадания = Новый Структура;
	ПараметрыЗадания.Вставить("ДополнительнаяОбработкаСсылка", ВнешняяОбработка);
	ПараметрыЗадания.Вставить("ИмяМетода", "РаспределениеТранспортных");
	ПараметрыЗадания.Вставить("ЭтоВнешняяОбработка", Истина);
	ПараметрыЗадания.Вставить("ПараметрыВыполнения",ПараметрыРасчета);
	РезультатВыполнения = ДлительныеОперации.ВыполнитьВФоне(ВыполняемыйМетод, ПараметрыЗадания, ПараметрыВыполнения);
	Возврат РезультатВыполнения;
	
КонецФункции    

&НаСервере
Функция ПолучитьСсылку()
 Возврат Документы.РейсОтПоставщика.НайтиВнешнююОбработкуРаспределения();	
КонецФункции

&НаСервере
Функция ЕщеНеРаспределено()
	Возврат Объект.СостояниеОплатыШапка = Перечисления.СостояниеОплатыВРейсахОтПоставщика.НеГотовКОплате ИЛИ Объект.СостояниеОплатыШапка = Перечисления.СостояниеОплатыВРейсахОтПоставщика.ЧастичноГотовКОплате;
КонецФункции
#КонецОбласти

