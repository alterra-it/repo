&НаСервере
Процедура РассчитатьСтроку(НомерСтроки)
	Документы.РейсОтПоставщика.РассчитатьСтроку(НомерСтроки, Объект);
	РасчитатьИтоги();
КонецПроцедуры
&НаСервере
Процедура РасчитатьИтоги()
	Элементы.РасчетДоставкиВес.ТекстПодвала= Объект.РасчетДоставки.Итог("Вес");
	Элементы.РасчетДоставкиОбъем.ТекстПодвала= Объект.РасчетДоставки.Итог("Объем");
	Элементы.РасчетДоставкиСтоимостьТовара.ТекстПодвала= Объект.РасчетДоставки.Итог("СтоимостьТовара");
	Элементы.РасчетДоставкиРаспределенныеДеньгиНаДоставку.ТекстПодвала= Объект.РасчетДоставки.Итог("РаспределенныеДеньгиНаДоставку");
	Элементы.РасчетДоставкиРасчетнаяРекомендованнаяСтоимость.ТекстПодвала= Объект.РасчетДоставки.Итог("РасчетнаяРекомендованнаяСтоимость");
	
	Объект.ЗаложеноВСтоимость= Объект.РасчетДоставки.Итог("ЗаложеноВСтоимость");
	Объект.ЗаложеноВСтоимостьБезНДС= Объект.РасчетДоставки.Итог("ЗаложеноВСтоимостьБезНДС");
	
	Элементы.РасчетДоставкиИтоговаяСтоимость.ТекстПодвала= Объект.ЗаложеноВСтоимость;
	Элементы.РасчетДоставкиЗаложеноВСтоимостьБезНДС.ТекстПодвала= Объект.ЗаложеноВСтоимостьБезНДС;
	
	Итоги= Документы.РейсОтПоставщика.ПолучитьИтоги(Объект);
	ЗаполнитьЗначенияСвойств(Объект, Итоги);
	Элементы.РасчетДоставкиЗаказНаДоставкуСтоимостьДоставки.ТекстПодвала= Итоги.СтоимостьДоставки;
	
	ЗаложеноВСтоимостьИтого= Объект.ЗаложеноВСтоимость+Объект.ЗаложеноВСтоимостьБезНДС;
КонецПроцедуры

&НаСервере
Функция ИмеетПолныеПрава() 
	Возврат РольДоступна("ПолныеПрава");
КонецФункции

&НаСервере
Процедура УстановитьВидимостьДоступность()
	//Права на статус
	Если РольДоступна("ПолныеПрава") Тогда 
		Элементы.ФормаНапечататьКомплектДокументов.Доступность= Истина;
		Элементы.Статус.ТолькоПросмотр= Ложь;
		Элементы.Статус.Доступность= Истина;
	КонецЕсли;
	
	//Доступность по провам
	Если РольДоступна("ОтделЛогистики") Тогда 
		//Права на статус
		Элементы.Статус.ТолькоПросмотр= Ложь;
		Элементы.Статус.Доступность= Истина;
	Иначе
	КонецЕсли;
	
	Если НЕ (РольДоступна ("ПравоЗапускаАвтораспределенияТранспортных") ИЛИ РольДоступна("ПолныеПрава")) Тогда
		Элементы.РаспределитьТранспортные.Доступность = Ложь;
		Элементы.ПроверитьСостояниеОплаты.Доступность = Ложь;
	КонецЕсли
	
КонецПроцедуры
#КонецОбласти

