#Область СеткаПоставок

&НаКлиенте
Процедура ОткрытьСетку(Команда)
	ОчиститьСообщения();
	Если Не ТаблицаЗаказовИзменена ИЛИ Не Модифицированность И Объект.Проведен Тогда  
		ТекущаяСтрока = Элементы.РасчетДоставки.ТекущиеДанные;
		ДанныеЗаказа = ПолучитьДанныеЗаказа(ТекущаяСтрока.ДокументОснование);
		ПараметрыОткрытияФормыПланировщика = Новый Структура;
		ПериодОткрытия = ?(ТекущаяСтрока.ДатаВремяРазгрузки='00010101' ИЛИ ТекущаяСтрока.ДатаВремяРазгрузки=НачалоДня(ТекущаяСтрока.ДатаВремяРазгрузки), Объект.ДатаПрибытияНаСклад, ТекущаяСтрока.ДатаВремяРазгрузки);
		ПараметрыОткрытияФормыПланировщика.Вставить("Период", ПериодОткрытия);
		ПараметрыОткрытияФормыПланировщика.Вставить("ИзФормыЗаказа", Истина);
		ПараметрыОткрытияФормыПланировщика.Вставить("Секция", ДанныеЗаказа.Секция);
		ПараметрыОткрытияФормыПланировщика.Вставить("ПродолжительностьРазгрузки", ТекущаяСтрока.ПродолжительностьРазгрузки);
		ПараметрыОткрытияФормыПланировщика.Вставить("ЗаказПоставщику", ТекущаяСтрока.ДокументОснование);
		
		Если ТекущаяСтрока.АдресОборудованияЗаказа <> "" Тогда
			СписокДопРесурсов = ПолучитьИзВременногоХранилища(ТекущаяСтрока.АдресОборудованияЗаказа);
		КонецЕсли;
		ПараметрыОткрытияФормыПланировщика.Вставить("ДополнительныеРесурсы", СписокДопРесурсов); 
		
		ОткрытьФорму("Обработка.ПланировщикПоставокНаСклад.Форма", ПараметрыОткрытияФормыПланировщика, ЭтаФорма,,,, Новый ОписаниеОповещения("ОтобразитьВремяДоставки", ЭтотОбъект));
	Иначе
		ТекстСообщения = "";
		Если ТаблицаЗаказовИзменена Тогда
			ТекстСообщения = "В таблицу с заказами был добавлен новый документ. ";	
		ИначеЕсли Модифицированность Тогда
			ТекстСообщения = "Документ был изменен. ";
		КонецЕсли;
		
		ТекстСообщения =ТекстСообщения + "Необходимо провести рейс!";
		Сообщить(ТекстСообщения);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПолучитьДанныеЗаказа(Заказ)
	ДанныеЗаказа = Новый Структура;
	ДанныеЗаказа.Вставить("Секция", Заказ.Секция);
	ДанныеЗаказа.Вставить("Дата", Заказ.ДатаПоступления);
	
	Возврат ДанныеЗаказа;
КонецФункции // ПолучитьСекциюЗаказа()

&НаСервере
Процедура ОтобразитьВремяДоставки(РезультатЗакрытия=Неопределено, ДополнительныеПараметры=Неопределено) Экспорт
	Если Не Объект.ПометкаУдаления Тогда
		//собрать данные по дате поступления поставок
		//добавить даты в таблицу
		ДокументыОснования = Объект.РасчетДоставки.Выгрузить(,"ДокументОснование");
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГрафикПоставокНаСкладСрезПоследних.ЗаказПоставщику КАК ЗаказПоставщику,
		|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан КАК НачалоРазгрузки,
		|	ДОБАВИТЬКДАТЕ(ГрафикПоставокНаСкладСрезПоследних.ДатаВремяРазгрузкиПлан, МИНУТА, ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки) КАК КонецРазгрузки,
		|	ГрафикПоставокНаСкладСрезПоследних.ДатаВремяПриездаФакт КАК ДатаВремяПриездаФакт,
		|	ГрафикПоставокНаСкладСрезПоследних.ПродолжительностьРазгрузки КАК ПродолжительностьРазгрузки,
		|	ГрафикПоставокНаСкладСрезПоследних.Оборудование КАК Оборудование,
		|	ГрафикПоставокНаСкладСрезПоследних.КоличествоИспользуется КАК КоличествоИспользуется,
		|	ГрафикПоставокНаСкладСрезПоследних.СогласованоСоСкладом КАК СогласованоСоСкладом
		|ИЗ
		|	РегистрСведений.ГрафикПоставокНаСклад.СрезПоследних(, ЗаказПоставщику В (&СписокЗаказов)) КАК ГрафикПоставокНаСкладСрезПоследних
		|ИТОГИ
		|	МАКСИМУМ(СогласованоСоСкладом),
		|	МАКСИМУМ(НачалоРазгрузки),
		|	МАКСИМУМ(КонецРазгрузки),
		|	МАКСИМУМ(ДатаВремяПриездаФакт),
		|	МАКСИМУМ(ПродолжительностьРазгрузки)
		|ПО
		|	ЗаказПоставщику";
		Запрос.УстановитьПараметр("СписокЗаказов", ДокументыОснования);
		Результат = Запрос.Выполнить();
		ВыборкаЗаказ = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ЗаказПоставщику");
		Пока ВыборкаЗаказ.Следующий() Цикл
			ОтборСтрокВТЧ = Новый Структура;
			ОтборСтрокВТЧ.Вставить("ДокументОснование", ВыборкаЗаказ.ЗаказПоставщику);
			СтрПоставки = Объект.РасчетДоставки.НайтиСтроки(ОтборСтрокВТЧ);
			СписокОборудования = Новый СписокЗначений;
			Выборка = ВыборкаЗаказ.Выбрать();
			Пока Выборка.Следующий() Цикл 
				Стр = Новый Структура;
				Стр.Вставить("Ресурс", Выборка.Оборудование);
				Стр.Вставить("ТребуемоеКоличество", Выборка.КоличествоИспользуется);
				СписокОборудования.Добавить(Стр);
			КонецЦикла;
			
			Для Каждого Стр Из СтрПоставки Цикл
				Если ВыборкаЗаказ.НачалоРазгрузки = НачалоДня(ВыборкаЗаказ.НачалоРазгрузки) Тогда
					Стр.ВремяРазгрузки = "";
				Иначе
					Стр.ВремяРазгрузки = Строка(Формат(ВыборкаЗаказ.НачалоРазгрузки,"ДФ=HH:mm")) + "-" + Строка(Формат(ВыборкаЗаказ.КонецРазгрузки,"ДФ=HH:mm"));
				КонецЕсли;	
				Стр.ПродолжительностьРазгрузки = ВыборкаЗаказ.ПродолжительностьРазгрузки;
				Стр.ДатаВремяРазгрузки = ВыборкаЗаказ.НачалоРазгрузки;
				Стр.АдресОборудованияЗаказа = ПоместитьВоВременноеХранилище(СписокОборудования, Новый УникальныйИдентификатор);
				Стр.СогласованоСоСкладом = ВыборкаЗаказ.СогласованоСоСкладом; 
				Стр.СкладРазгрузки = Стр.ДокументОснование.Склад;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры // ОтобразитьВремяДоставки()

