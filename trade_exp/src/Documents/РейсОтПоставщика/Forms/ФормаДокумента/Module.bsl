&НаСервере
Процедура ПроверитьИзменениеСеткиПоставок()
	ГруппаПоставкиДоИзменения = Объект.Ссылка.ГруппаПоставки.Выгрузить();
	Документы.РейсОтПоставщика.ЗаполнитьГруппуПоставки(Объект);
	
	Для каждого Строка из Объект.ГруппаПоставки Цикл
		МассивСтрок = ГруппаПоставкиДоИзменения.НайтиСтроки(Новый Структура("Склад", Строка.Склад));
		Если МассивСтрок.Количество()>0 Тогда
			СтрокаДоИзменений = МассивСтрок[0];
			Если СтрокаДоИзменений.Секция <> Строка.Секция
				ИЛИ СтрокаДоИзменений.ПродолжительностьРазгрузки <> Строка.ПродолжительностьРазгрузки Тогда
					
				Строка.ВремяПоступления = '00010101000000';
				Строка.Поток = ПредопределенноеЗначение("Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка");
				
				Если Строка.ДатаРазгрузки <> '00010101' Тогда
					Модифицированность = Истина;		
					ПараметрыЗаписи = Новый Соответствие;
					ОсновнойПоток = ПолучитьПотокПоСекции(СтрокаДоИзменений.Секция);
					ЗначениеПараметров = Новый Структура;
					ЗначениеПараметров.Вставить("Поток", ОсновнойПоток);
					ЗначениеПараметров.Вставить("ЗаказПоставщику", Объект.Ссылка);
					ЗначениеПараметров.Вставить("ДатаВремяРазгрузкиПлан", СтрокаДоИзменений.ДатаРазгрузки + Минута(СтрокаДоИзменений.ВремяПоступления)*60 + Час(СтрокаДоИзменений.ВремяПоступления)*3600);
					ЗначениеПараметров.Вставить("ПродолжительностьРазгрузки", СтрокаДоИзменений.ПродолжительностьРазгрузки);
					ЗначениеПараметров.Вставить("СогласованоСоСкладом", СтрокаДоИзменений.СогласованоСоСкладом);
					ЗначениеПараметров.Вставить("ТекстПоставки", СтрокаДоИзменений.ПримечаниеКПоставке);
					ЗначениеПараметров.Вставить("Склад", СтрокаДоИзменений.Склад);
					ЗначениеПараметров.Вставить("Оборудование", ?(СтрокаДоИзменений.Эстакада, ПолучитьЭстакаду(Истина), ПолучитьЭстакаду(Ложь)));
					ПараметрыЗаписи.Вставить(Объект.Ссылка, ЗначениеПараметров);
					Альтерра_СеткаПоставок.ИзменитьДанныеСеткиПоставок(Объект.Ссылка, "Удаление",  ПараметрыЗаписи, Истина, СтрокаДоИзменений.Склад, Альтерра_СеткаПоставок.ПолучитьДопПотокиПоСкладу(СтрокаДоИзменений.Склад, Объект.Ссылка, ОсновнойПоток));
					Сообщить("Для склада '"+Строка(Строка.Склад)+"' изменились данные поставки. Необходимо заново запланировать поставку.")
				КонецЕсли;
				
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Если Модифицированность Тогда
		Записать();
	КонецЕсли;
КонецПроцедуры


&НаСервере
Функция ПолучитьПотокПоСекции(Секция)
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПотокиТранспортныхСредствПоставкиНаСкладСекции.Ссылка КАК Поток
		|ИЗ
		|	Справочник.ПотокиТранспортныхСредствПоставкиНаСклад.Секции КАК ПотокиТранспортныхСредствПоставкиНаСкладСекции
		|ГДЕ
		|	ПотокиТранспортныхСредствПоставкиНаСкладСекции.Секция = &Секция";
	
	Запрос.УстановитьПараметр("Секция", Секция);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Поток;
	КонецЕсли;
	Возврат Справочники.ПотокиТранспортныхСредствПоставкиНаСклад.ПустаяСсылка();
КонецФункции

#КонецОбласти

