КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды


#Область Команды
&НаКлиенте
Процедура ЗаполнитьАкт(Команда)
	НомерАкта= "";
	ВводНомераАктаЗавершение= Новый ОписаниеОповещения("ВводНомераАктаЗавершение", ЭтотОбъект);
	ПоказатьВводСтроки(ВводНомераАктаЗавершение, НомерАкта, "Введите номер присваимого Акта:");
КонецПроцедуры
&НаКлиенте
Процедура ВводНомераАктаЗавершение(РезультатВыполнения, ДопПараметры) Экспорт 
		Для Каждого Рейс Из Элементы.Список.ВыделенныеСтроки Цикл 
		ЗаполнитьАктНаСервере(Рейс, РезультатВыполнения);
	КонецЦикла;
КонецПроцедуры
&НаСервере
Процедура ЗаполнитьАктНаСервере(Рейс, НомерАкта)
	Если Рейс.Статус = Перечисления.СтатусыРейсовНаПоставку.Доставлен Тогда
		Если ПустаяСтрока(Рейс.УПДАктОтПеревозчика) Тогда
			РейсОбъект= Рейс.ПолучитьОбъект();
			РейсОбъект.УПДАктОтПеревозчика= СокрЛП(НомерАкта);
			РейсОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			АльтерраОбщегоНазначения.СообщитьПользователю(Рейс, ""+Рейс+" присвоен номер Акта: "+РейсОбъект.УПДАктОтПеревозчика);
		Иначе
			АльтерраОбщегоНазначения.СообщитьПользователю(Рейс, "У "+Рейс+" уже задан номер Акта: "+Рейс.УПДАктОтПеревозчика);
		КонецЕсли;
	Иначе
		АльтерраОбщегоНазначения.СообщитьПользователю(Рейс, ""+Рейс+" находится в статусе "+Рейс.Статус+", а должен "+Перечисления.СтатусыРейсовНаПоставку.Доставлен);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьНаОснованииРейсовОтПоставщиков(Команда)
	ПоказатьВводСтроки(Новый ОписаниеОповещения("ОкончаниеВводаНомераАкта", ЭтотОбъект), "", "Введите номер присваимого Акта:");
КонецПроцедуры
&НаКлиенте
Процедура ОкончаниеВводаНомераАкта(РезультатВыполнения, ДопПараметры) Экспорт 
	Если ЗначениеЗаполнено(РезультатВыполнения) Тогда
		мРейсов = Элементы.Список.ВыделенныеСтроки;
		Если ЗначениеЗаполнено(мРейсов) Тогда
			Массивы = ОкончаниеВводаНомераАктаНаСервере(мРейсов, РезультатВыполнения);
			Если ЗначениеЗаполнено(Массивы) Тогда
				Для Каждого Массив Из Массивы Цикл                                                                                                 
					Форма = ПолучитьФорму("Документ.ПриобретениеУслугПрочихАктивов.Форма.ФормаДокумента", Новый Структура("РейсОтПоставщика", Массив[0]), ЭтаФорма, Новый УникальныйИдентификатор);
					Форма.ОбработатьВыбранныеРейсыПоПоставкам(Массив, Неопределено);
					Форма.Открыть();                                                                                                                
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
&НаСервере
Функция ОкончаниеВводаНомераАктаНаСервере(мРейсов, НомерАкта)
	
	ПервыйЭлементРейс = мРейсов[0];
	ПеревозчикПартнер = ПервыйЭлементРейс.ПеревозчикПартнер;
	ОтменаВыполнения = Ложь;
	СтатусРейсаДоставлен = Перечисления.СтатусыРейсовНаПоставку.Доставлен;

	НачатьТранзакцию();
	Попытка
		Для Каждого Рейс Из мРейсов Цикл	
			Если Рейс.Статус = СтатусРейсаДоставлен Тогда
				Если ПустаяСтрока(Рейс.УПДАктОтПеревозчика) И Не ОтменаВыполнения Тогда
					РейсОбъект= Рейс.ПолучитьОбъект();
					РейсОбъект.УПДАктОтПеревозчика= НомерАкта;
					РейсОбъект.Записать(); 
				ИначеЕсли СокрЛП(Рейс.УПДАктОтПеревозчика) <> НомерАкта Тогда 
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю("У "+Рейс+" уже задан другой номер Акта: "+Рейс.УПДАктОтПеревозчика, Рейс);
					ОтменаВыполнения = Истина;
				КонецЕсли;
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(""+Рейс+" находится в статусе "+Рейс.Статус+", а должен "+СтатусРейсаДоставлен, Рейс);
				ОтменаВыполнения = Истина;
			КонецЕсли;
			
			Если Рейс.ПеревозчикПартнер <> ПеревозчикПартнер Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Рейсы "+Рейс+" и "+ПервыйЭлементРейс+" имеют разных перевозчиков ("+Рейс.ПеревозчикПартнер+", "+ПеревозчикПартнер+")", Рейс);
				ОтменаВыполнения = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если ОтменаВыполнения Тогда
			ОтменитьТранзакцию();
		Иначе
			ЗафиксироватьТранзакцию();
			Возврат МассивыРейсов(мРейсов);
		КонецЕсли;
	Исключение
	    Если ТранзакцияАктивна() Тогда
	        ОтменитьТранзакцию();
		КонецЕсли;
		
	    ВызватьИсключение;
	КонецПопытки;

	Возврат Неопределено;
КонецФункции
&НаСервереБезКонтекста
Функция МассивыРейсов(мРейсов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РейсОтПоставщика.Ссылка КАК Ссылка,
		|	РейсОтПоставщика.Перевозчик КАК Перевозчик
		|ИЗ
		|	Документ.РейсОтПоставщика КАК РейсОтПоставщика
		|ГДЕ
		|	РейсОтПоставщика.Ссылка В(&мРейсов)
		|	И НЕ РейсОтПоставщика.ПометкаУдаления
		|ИТОГИ ПО
		|	Перевозчик";
	
	Запрос.УстановитьПараметр("мРейсов", мРейсов);	
	
	МассивИтоговыхЗаписей = Новый Массив;
	ИтоговыеЗаписи = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ИтоговыеЗаписи.Следующий() Цикл
		ДетальныеЗаписи = ИтоговыеЗаписи.Выбрать();
		МассивДетальныхЗаписей = Новый Массив;
		Пока ДетальныеЗаписи.Следующий() Цикл
			МассивДетальныхЗаписей.Добавить(ДетальныеЗаписи.Ссылка);
		КонецЦикла;
		Если ЗначениеЗаполнено(МассивДетальныхЗаписей.Количество()) Тогда
			МассивИтоговыхЗаписей.Добавить(МассивДетальныхЗаписей);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивИтоговыхЗаписей;
КонецФункции
#КонецОбласти