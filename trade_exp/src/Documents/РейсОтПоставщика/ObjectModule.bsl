#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&Вместо("ОбработкаЗаполнения")
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Документы.РейсОтПоставщика.ЗаполнитьДанныеПоОснованию(ДанныеЗаполнения, ЭтотОбъект);
КонецПроцедуры

&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Отказ И РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		//Поставки на склад {	
		Если ЭтоНовый() ИЛИ Ссылка.ДатаПрибытияНаСклад<>ДатаПрибытияНаСклад ИЛИ Ссылка.РасчетДоставки.Количество() <> РасчетДоставки.Количество() Тогда
			//получим текущие данные заказов из ТЧ. Изменим дату разгрузки и время поступления, при прочих равных условиях
			ДатыВПоставкахИзменены = Ложь;
			ИзменитьДанныеСеткиПоставокПоРейсу(ДатыВПоставкахИзменены);
			Если ДатыВПоставкахИзменены Тогда
				Сообщить("Для заказов на вкладке документов клиентов необходимо установить новое время прибытия для текущей даты", СтатусСообщения.ОченьВажное);
			КонецЕсли;
		КонецЕсли;
		//} Поставки на склад
		
		Документы.РейсОтПоставщика.РассчитатьСтроки(ЭтотОбъект);
		
		Вес= РасчетДоставки.Итог("Вес");
		Объем= РасчетДоставки.Итог("Объем");
		
		//Транзит
		Если ЭтотОбъект.ТранзитФизЛицо Тогда
			Если ЭтотОбъект.Статус = Перечисления.СтатусыРейсовНаПоставку.Доставлен И ЭтотОбъект.Статус <> Ссылка.Статус Тогда
				//Документы.РейсОтПоставщика.ЗаменитьУслугуДоставки(ЭтотОбъект, Отказ);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения Тогда
		ИзменитьДанныеСеткиПоставокПоРейсу(Ложь, Истина);
	КонецЕсли;
	
	ДатаЗапускаАвтоматическогоРаспределения = Документы.РейсОтПоставщика.ПолучитьНастройкиОбработкиРаспределения();
	Если ЭтоНовый() И ДатаЗапускаАвтоматическогоРаспределения <> Дата(1, 1, 1) И ЭтотОбъект.Дата >= ДатаЗапускаАвтоматическогоРаспределения Тогда
		СостояниеОплатыШапка = Перечисления.СостояниеОплатыВРейсахОтПоставщика.НеГотовКОплате;
	КонецЕсли;
	//ЕстьНакладныеЭТрН(Отказ);
	
КонецПроцедуры

Процедура ЕстьНакладныеЭТрН(Отказ)
	
	Если НЕ Отказ И Не ЭтоНовый() И Не Ссылка.ПометкаУдаления И ПометкаУдаления Тогда
		Запрос = Новый Запрос;
		Запрос.Текст =	
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ИСТИНА КАК Результат
			|ИЗ
			|	Документ.Saby_ТранспортнаяНакладная КАК Накладная
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РейсОтПоставщика.РасчетДоставки КАК Рейс
			|		ПО Накладная.ДокументОснование_Идентификатор = УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Рейс.Ссылка)
			|ГДЕ
			|	Рейс.Ссылка = &Рейс
			|	И НЕ Накладная.ПометкаУдаления";

		Запрос.УстановитьПараметр("Рейс", Ссылка);
		
		Если НЕ Запрос.Выполнить().Пустой() Тогда
			Отказ = Истина;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("По рейсу есть накладные!");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ИзменитьДанныеСеткиПоставокПоРейсу(ДатыВПоставкахИзменены, ЭтоУдаление=Ложь)
	УсловиеЗаписи = "";
	ИзменяемыеПараметры = Неопределено;
	Если ЭтоУдаление Тогда
		УсловиеЗаписи = "Удаление";
	Иначе
		УсловиеЗаписи = "РейсИзменениеПлана";
		ИзменяемыеПараметры = Новый Структура;
		ИзменяемыеПараметры.Вставить("ДатаВремяРазгрузкиПлан", ДатаПрибытияНаСклад);
	КонецЕсли;
	
	Альтерра_СеткаПоставок.ИзменитьДанныеСеткиПоставок(РасчетДоставки.Выгрузить().ВыгрузитьКолонку("ДокументОснование"), УсловиеЗаписи, ИзменяемыеПараметры);
КонецПроцедуры

&Вместо("ОбработкаПроведения")
Процедура ОбработкаПроведения(Отказ, Режим)
	//Проверим нет ли заказов на доставку ещё в каких то рейсах
	Документы.РейсОтПоставщика.КонтрольОстатков(ЭтотОбъект, Отказ);
	
	Если Не Отказ Тогда
		Движения.ЗаказыКДоставкеОтПоставщика.Записывать = Истина;
		Движения.ЗатратыПоДоставкеОтПоставщика.Записывать = Истина;
		
		Для Каждого ТекСтрока Из РасчетДоставки Цикл
			//ЗаказыКДоставке
			Движение = Движения.ЗаказыКДоставкеОтПоставщика.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.Период = Дата;
			Движение.ЗаказНаДоставку = ТекСтрока.ЗаказНаДоставку;
			Движение.Документ = ТекСтрока.ДокументОснование;
			Движение.Количество = 1;
			
			//ЗатратыПоДоставкеОтПоставщика
			Если Дата >= Документы.РейсОтПоставщика.ДатаСтартаАктовПоРегистру() Тогда
				мДокументов= Новый Массив;
				Если ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
					мДокументов= Документы.РейсОтПоставщика.ПолучитьДокументыПоЗаказу(ТекСтрока.ДокументОснование);
					Если мДокументов.Количество() = 0 Тогда
						мДокументов.Добавить(ТекСтрока.ДокументОснование);
					КонецЕсли;
				ИначеЕсли ТипЗнч(ТекСтрока.ДокументОснование) = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
					мДокументов.Добавить(ТекСтрока.ДокументОснование);
				КонецЕсли;
				
				СуммаПоступлений= 0;
				Для Каждого ДокументОснование Из мДокументов Цикл
					СуммаПоступлений= СуммаПоступлений+ДокументОснование.СуммаДокумента;
				КонецЦикла;

				СуммаРаспределили= 0;
				Для Каждого ДокументОснование Из мДокументов Цикл
					Движение = Движения.ЗатратыПоДоставкеОтПоставщика.Добавить();
					Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
					Движение.Период = Дата;
					Движение.Перевозчик = Перевозчик;
					Движение.Документ = ДокументОснование;
					Движение.ЗаказНаДоставку= ТекСтрока.ЗаказНаДоставку;
					Движение.ДокументОснование= ТекСтрока.ДокументОснование;
					
					Коэффициент= ТекСтрока.РаспределенныеДеньгиНаДоставку/СуммаПоступлений;
					
					Движение.Сумма = Коэффициент*ДокументОснование.СуммаДокумента;
					
					СуммаРаспределили= СуммаРаспределили+Движение.Сумма;
				КонецЦикла;
				Движение.Сумма= Движение.Сумма+ТекСтрока.РаспределенныеДеньгиНаДоставку-СуммаРаспределили;
			Иначе
				Движения.ЗатратыПоДоставкеОтПоставщика.Очистить();
			КонецЕсли;
		
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

&Вместо("ОбработкаПроверкиЗаполнения")
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	Если ТранзитФизЛицо Тогда
		ПроверяемыеРеквизиты.Добавить("СтавкаНДС");
	КонецЕсли;
КонецПроцедуры

#КонецЕсли
