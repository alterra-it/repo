
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	АдресДокументыОснования = Параметры.ДокументыОснованияАдресХранилища;
	ДокументыОснования = ПолучитьИзВременногоХранилища(АдресДокументыОснования);
	Тр_Заказы.Очистить();
	ПроверкаДоступностиСозданияРейса(ДокументыОснования);
	
КонецПроцедуры

&НаКлиенте
Процедура Тр_СоздатьЗаявки(Команда)
	
	ОбязательныеПоляЗаполнены = (Тр_НазваниеЗаявки<>"" И Тр_ПрибытиеНаПогрузку<>'00010101' И Тр_СтоимостьДоставки<>0);
	Если Не Элементы.Тр_СтраницаЗаказов.ТолькоПросмотр И ОбязательныеПоляЗаполнены Тогда 
		Попытка
			СоздатьДокументыСервер();
			Элементы.Тр_Страницы.ТекущаяСтраница = Элементы.Тр_СтраницаЗаявок;
			Элементы.Тр_СтраницаЗаказов.ТолькоПросмотр = Истина;
			Элементы.НадписьКоличествоЗаявокИтог.Заголовок = "Создано заявок: " + Строка(Тр_Заявки.Количество());
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
	ИначеЕсли Не ОбязательныеПоляЗаполнены Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Поле обязательно для заполнения!";
		Сообщение.Поле = ?(Тр_НазваниеЗаявки="", "Тр_НазваниеЗаявки", ?(Тр_ПрибытиеНаПогрузку='00010101', "Тр_ПрибытиеНаПогрузку", ?(Тр_СтоимостьДоставки=0, "Тр_СтоимостьДоставки","")));
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументыСервер()
	
	ДанныеОснования = Тр_Заказы.Выгрузить();
	
	//обработка тч
	//определение количества порций документов заказов
	//1 порция = 1 документ доставки
	//формирование выборки данных заполнения (которые заданы)
	
	//1ый вариант
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗ.Заказ КАК Заказ,
		|	ТЗ.КоличествоМест КАК КоличествоМест,
		|	ТЗ.ТипУпаковки КАК ТипУпаковки
		|ПОМЕСТИТЬ втЗаказы
		|ИЗ
		|	&ТЗ КАК ТЗ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втЗаказы.Заказ КАК Заказ,
		|   втЗаказы.Грузополучатель Как Грузополучатель,
		|   втЗаказы.Грузоотправитель КАК Грузоотправитель,
		|	втЗаказы.КоличествоМест КАК КоличествоМест,
		|	втЗаказы.ТипУпаковки КАК ТипУпаковки,
		|	втЗаказы.СуммаДокумента
		|ИЗ
		|(ВЫБРАТЬ
		|	втЗаказы.Заказ КАК Заказ,
		|   втЗаказы.Заказ.Организация Как Организация,
		|   втЗаказы.Заказ.Склад КАК Грузополучатель,
		|   втЗаказы.Заказ.Партнер КАК Грузоотправитель,
		|	втЗаказы.КоличествоМест КАК КоличествоМест,
		|	втЗаказы.ТипУпаковки КАК ТипУпаковки,
		|   втЗаказы.Заказ.СуммаДокумента КАК СуммаДокумента
		|	ИЗ втЗаказы КАК втЗаказы
		|) КАК втЗаказы
		|
		|УПОРЯДОЧИТЬ ПО
		|	втЗаказы.Грузополучатель,
		|	втЗаказы.Грузоотправитель
		|ИТОГИ
		|	СУММА(КоличествоМест),
		|	СУММА(СуммаДокумента)
		|ПО
		|	ОБЩИЕ,
		|	втЗаказы.Грузополучатель
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	втЗаказы.Заказ КАК Заказ,
		|   втЗаказы.Грузополучатель Как Грузополучатель,
		|   втЗаказы.Грузоотправитель КАК Грузоотправитель,
		|	втЗаказы.КоличествоМест КАК КоличествоМест,
		|	втЗаказы.ТипУпаковки КАК ТипУпаковки,
		|	втЗаказы.СуммаДокумента
		|ИЗ
		|(ВЫБРАТЬ
		|	втЗаказы.Заказ КАК Заказ,
		|   втЗаказы.Заказ.Организация Как Организация,
		|   втЗаказы.Заказ.Склад КАК Грузополучатель,
		|   втЗаказы.Заказ.Партнер КАК Грузоотправитель,
		|	втЗаказы.КоличествоМест КАК КоличествоМест,
		|	втЗаказы.ТипУпаковки КАК ТипУпаковки,
		|   втЗаказы.Заказ.СуммаДокумента КАК СуммаДокумента
		|	ИЗ втЗаказы КАК втЗаказы
		|) КАК втЗаказы
		|
		|УПОРЯДОЧИТЬ ПО
		|	втЗаказы.Грузополучатель,
		|	втЗаказы.Грузоотправитель
		|ИТОГИ
		|	СУММА(КоличествоМест),
		|	СУММА(СуммаДокумента)
		|ПО
		|	ОБЩИЕ,
		|	втЗаказы.Грузополучатель";
	Запрос.УстановитьПараметр("ТЗ", ДанныеОснования);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаИтог = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаИтог.Следующий() Цикл
		ВыборкаГрузополучатель = ВыборкаИтог.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Грузополучатель");
		Пока ВыборкаГрузополучатель.Следующий() Цикл
			ДокументДоставки = Документы.ЗаказНаДоставкуОтПоставщика.СоздатьДокумент();
			ВыборкаДетальныеЗаписи = ВыборкаГрузополучатель.Выбрать();
			ДокиОснования = Новый Массив;
			ТипУпаковки = "";
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				//заполнение по основанию, по данным
				ДокиОснования.Добавить(ВыборкаДетальныеЗаписи.Заказ);
				ТипУпаковки = ВыборкаДетальныеЗаписи.ТипУпаковки;
			КонецЦикла;
			Документы.ЗаказНаДоставкуОтПоставщика.ЗаполнитьДанныеПоОснованию(ДокиОснования, ДокументДоставки);
			ДокументДоставки.Дата = ТекущаяДата();
			ДокументДоставки.НаименованиеГруза = Тр_НазваниеЗаявки;
			ДокументДоставки.ПрибытиеНаПогрузку = Тр_ПрибытиеНаПогрузку;
			ДокументДоставки.КоличествоМест = ВыборкаГрузополучатель.КоличествоМест;
			ДокументДоставки.СтоимостьДоставки = Тр_СтоимостьДоставки*ВыборкаГрузополучатель.СуммаДокумента/ВыборкаИтог.СуммаДокумента; 
			ДокументДоставки.ТипУпаковки = ТипУпаковки;
			ДокументДоставки.Записать(РежимЗаписиДокумента.Проведение);
			Заявка = Тр_Заявки.Добавить();
			Заявка.Документ = ДокументДоставки.Ссылка;
		КонецЦикла;	
	КонецЦикла;

КонецПроцедуры 


&НаКлиенте
Процедура Тр_Открыть(Команда)
	
	Если Элементы.Тр_Страницы.ТекущаяСтраница = Элементы.Тр_СтраницаЗаявок Тогда
		Документ = Элементы.Тр_Заявки.ТекущиеДанные.Документ;
	Иначе
		Документ = Элементы.Тр_Заказы.ТекущиеДанные.Заказ;
	КонецЕсли;
	АльтерраОбщегоНазначенияКлиент.ОткрытьДокумент(Документ, ЭтаФорма); 
	
КонецПроцедуры

// Рейс можно создать только по заказам в статусах "Подтвержден" или "Согласован"
//	Параметры		
//		СписокЗаказов - список заказов, которые необходимо либо обновить, либо добавить в текущую таблицу
//
&НаСервере
Процедура ПроверкаДоступностиСозданияРейса(Знач СписокЗаказов)

	Если ТипЗнч(СписокЗаказов) <> Тип("Массив") Тогда
		Если ТипЗнч(СписокЗаказов) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			Заказ = СписокЗаказов;
			СписокЗаказов = Новый Массив;
			СписокЗаказов.Добавить(Заказ);
		Иначе
			ТаблицаФормыЗаказов = СписокЗаказов;
			СписокЗаказов = ТаблицаФормыЗаказов.Выгрузить().ВыгрузитьКолонку("Заказ");
		КонецЕсли;	
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПоставщику.Ссылка КАК Заказ,
		|	ВЫБОР
		|		КОГДА ЗаказПоставщику.Статус В (&ДопустимыеСтатусы)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК МожноСоздатьРейс
		|ИЗ
		|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
		|ГДЕ
		|	ЗаказПоставщику.Ссылка В(&СписокЗаказов)";
	ДопустимыеСтатусы = Новый Массив;
	ДопустимыеСтатусы.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Согласован);
	ДопустимыеСтатусы.Добавить(Перечисления.СтатусыЗаказовПоставщикам.Подтвержден);
	Запрос.УстановитьПараметр("ДопустимыеСтатусы", ДопустимыеСтатусы);
	Запрос.УстановитьПараметр("СписокЗаказов", СписокЗаказов);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	РейсСоздатьНельзя = Ложь;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтрЗаказа = Неопределено;
		Если Тр_Заказы.Количество() > 0 Тогда
			ОтборСтрокПоЗаказу = Новый Структура;
			ОтборСтрокПоЗаказу.Вставить("Заказ", ВыборкаДетальныеЗаписи.Заказ);
			НайденныеСтроки = Тр_Заказы.НайтиСтроки(ОтборСтрокПоЗаказу);
			
			Если НайденныеСтроки <> Неопределено И НайденныеСтроки.Количество()>0 Тогда
				СтрЗаказа = НайденныеСтроки[0];
			КонецЕсли;
		КонецЕсли;
		
		Если СтрЗаказа = Неопределено Тогда
			СтрЗаказа = Тр_Заказы.Добавить();
		КонецЕсли;

		ЗаполнитьЗначенияСвойств(СтрЗаказа, ВыборкаДетальныеЗаписи);
		Если Не СтрЗаказа.МожноСоздатьРейс Тогда
			РейсСоздатьНельзя = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Элементы.Тр_ЗаказыТр_СоздатьЗаявки.Видимость = Не РейсСоздатьНельзя;
	
	Если РейсСоздатьНельзя Тогда
		Сообщить("Выделенные заказы не согласованы, невозможно создать по ним рейс!", СтатусСообщения.Важное);
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура Тр_ЗаказыПослеУдаления(Элемент)
	ПроверкаДоступностиСозданияРейса(Тр_Заказы);
КонецПроцедуры

&НаКлиенте
Процедура Тр_ЗаказыПриИзменении(Элемент)
	
	ОчиститьСообщения();
	ТекущийЭлементТрЗаказов = Элементы.Тр_Заказы.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТекущийЭлементТрЗаказов.Заказ) И Не  ЗначениеЗаполнено(ТекущийЭлементТрЗаказов.МожноСоздатьРейс) Тогда
		ПроверкаДоступностиСозданияРейса(ТекущийЭлементТрЗаказов.Заказ);
	КонецЕсли; 
	
КонецПроцедуры
