  <attributes>
    <name>ТоварОснований</name>
    <title>
      <key>ru</key>
      <value>Товар оснований</value>
    </title>
    <id>2</id>
    <valueType>
      <types>DynamicList</types>
    </valueType>
    <view>
      <common>true</common>
    </view>
    <edit>
      <common>true</common>
    </edit>
    <extInfo xsi:type="form:DynamicListExtInfo">
      <queryText>ВЫБРАТЬ
	ЗаказПоставщикуТовары.Ссылка КАК Документ,
	ЗаказПоставщикуТовары.Ссылка.Контрагент КАК Контрагент,
	NULL КАК ПрибытиеНаОтгрузку,
	ЗаказПоставщикуТовары.Номенклатура КАК Номенклатура,
	СУММА(ЗаказПоставщикуТовары.КоличествоУпаковок) КАК Количество,
	ВЫБОР
		КОГДА ЗаказПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЗаказПоставщикуТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ЗаказПоставщикуТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ КАК ЕдИзм,
	СУММА(ЗаказПоставщикуТовары.Цена) КАК Цена,
	СУММА(ЗаказПоставщикуТовары.СуммаСНДС) КАК Сумма,
	СУММА(ЗаказПоставщикуТовары.СуммаНДС) КАК СуммаНДС,
	ЗаказПоставщикуТовары.Ссылка.Дата КАК Дата,
	ЗаказПоставщикуТовары.Номенклатура.Код КАК Код,
	ЕСТЬNULL(ЗаказПоставщикуТовары.Склад.Ссылка, ЗаказПоставщикуТовары.Ссылка.Склад) КАК Склад,
	ЗаказПоставщикуТовары.Характеристика КАК Характеристика
ПОМЕСТИТЬ ВТ_Товары
ИЗ
	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
ГДЕ
	ЗаказПоставщикуТовары.Ссылка В(&amp;МассивДокументов)
	И НЕ ЗаказПоставщикуТовары.Отменено

СГРУППИРОВАТЬ ПО
	ЗаказПоставщикуТовары.Ссылка,
	ЗаказПоставщикуТовары.Номенклатура,
	ВЫБОР
		КОГДА ЗаказПоставщикуТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЗаказПоставщикуТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ЗаказПоставщикуТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	ЗаказПоставщикуТовары.Ссылка.Дата,
	ЗаказПоставщикуТовары.Ссылка.Контрагент,
	ЗаказПоставщикуТовары.Номенклатура.Код,
	ЗаказПоставщикуТовары.Склад,
	ЗаказПоставщикуТовары.Характеристика,
	ЕСТЬNULL(ЗаказПоставщикуТовары.Склад.Ссылка, ЗаказПоставщикуТовары.Ссылка.Склад)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПоступлениеТоваровУслугТовары.Ссылка,
	ПоступлениеТоваровУслугТовары.Ссылка.Контрагент,
	NULL,
	ПоступлениеТоваровУслугТовары.Номенклатура,
	СУММА(ПоступлениеТоваровУслугТовары.КоличествоУпаковок),
	ВЫБОР
		КОГДА ПоступлениеТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ПоступлениеТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ПоступлениеТоваровУслугТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	СУММА(ПоступлениеТоваровУслугТовары.Цена),
	СУММА(ПоступлениеТоваровУслугТовары.СуммаСНДС),
	СУММА(ПоступлениеТоваровУслугТовары.СуммаНДС),
	ПоступлениеТоваровУслугТовары.Ссылка.Дата,
	ПоступлениеТоваровУслугТовары.Номенклатура.Код,
	ЕСТЬNULL(ПоступлениеТоваровУслугТовары.Склад.Ссылка, ПоступлениеТоваровУслугТовары.Ссылка.Склад),
	ПоступлениеТоваровУслугТовары.Характеристика
ИЗ
	Документ.ПриобретениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
ГДЕ
	ПоступлениеТоваровУслугТовары.Ссылка В(&amp;МассивДокументов)

СГРУППИРОВАТЬ ПО
	ПоступлениеТоваровУслугТовары.Ссылка,
	ПоступлениеТоваровУслугТовары.Номенклатура,
	ВЫБОР
		КОГДА ПоступлениеТоваровУслугТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ПоступлениеТоваровУслугТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ПоступлениеТоваровУслугТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	ПоступлениеТоваровУслугТовары.Ссылка.Дата,
	ПоступлениеТоваровУслугТовары.Ссылка.Контрагент,
	ПоступлениеТоваровУслугТовары.Номенклатура.Код,
	ПоступлениеТоваровУслугТовары.Склад,
	ПоступлениеТоваровУслугТовары.Характеристика,
	ЕСТЬNULL(ПоступлениеТоваровУслугТовары.Склад.Ссылка, ПоступлениеТоваровУслугТовары.Ссылка.Склад)

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ПеремещениеТоваровТовары.Ссылка,
	ПеремещениеТоваровТовары.Ссылка.Организация,
	ПеремещениеТоваровТовары.Ссылка.ПрибытиеНаОтгрузку,
	ПеремещениеТоваровТовары.Номенклатура,
	СУММА(ПеремещениеТоваровТовары.КоличествоУпаковок),
	ВЫБОР
		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	0,
	0,
	0,
	ПеремещениеТоваровТовары.Ссылка.Дата,
	ПеремещениеТоваровТовары.Номенклатура.Код,
	ПеремещениеТоваровТовары.Ссылка.СкладПолучатель,
	ПеремещениеТоваровТовары.Характеристика
ИЗ
	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
ГДЕ
	ПеремещениеТоваровТовары.Ссылка В(&amp;МассивДокументов)

СГРУППИРОВАТЬ ПО
	ПеремещениеТоваровТовары.Ссылка,
	ПеремещениеТоваровТовары.Номенклатура,
	ПеремещениеТоваровТовары.Ссылка.Дата,
	ПеремещениеТоваровТовары.Номенклатура.Код,
	ПеремещениеТоваровТовары.Характеристика,
	ВЫБОР
		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	ПеремещениеТоваровТовары.Ссылка.Организация,
	ПеремещениеТоваровТовары.Ссылка.ПрибытиеНаОтгрузку,
	ПеремещениеТоваровТовары.Ссылка.СкладПолучатель

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗаказНаПеремещениеТовары.Ссылка,
	ЗаказНаПеремещениеТовары.Ссылка.Организация,
	NULL,
	ЗаказНаПеремещениеТовары.Номенклатура,
	СУММА(ЗаказНаПеремещениеТовары.КоличествоУпаковок),
	ВЫБОР
		КОГДА ЗаказНаПеремещениеТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЗаказНаПеремещениеТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ЗаказНаПеремещениеТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	0,
	0,
	0,
	ЗаказНаПеремещениеТовары.Ссылка.Дата,
	ЗаказНаПеремещениеТовары.Номенклатура.Код,
	ЗаказНаПеремещениеТовары.Ссылка.СкладПолучатель,
	ЗаказНаПеремещениеТовары.Характеристика
ИЗ
	Документ.ЗаказНаПеремещение.Товары КАК ЗаказНаПеремещениеТовары
ГДЕ
	ЗаказНаПеремещениеТовары.Ссылка В(&amp;МассивДокументов)
	И НЕ ЗаказНаПеремещениеТовары.Отменено

СГРУППИРОВАТЬ ПО
	ЗаказНаПеремещениеТовары.Ссылка,
	ЗаказНаПеремещениеТовары.Номенклатура,
	ЗаказНаПеремещениеТовары.Ссылка.Дата,
	ЗаказНаПеремещениеТовары.Номенклатура.Код,
	ЗаказНаПеремещениеТовары.Характеристика,
	ВЫБОР
		КОГДА ЗаказНаПеремещениеТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			ТОГДА ЗаказНаПеремещениеТовары.Номенклатура.ЕдиницаИзмерения
		ИНАЧЕ ЗаказНаПеремещениеТовары.Упаковка.ЕдиницаИзмерения
	КОНЕЦ,
	ЗаказНаПеремещениеТовары.Ссылка.Организация,
	ЗаказНаПеремещениеТовары.Ссылка.СкладПолучатель
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Товары.Документ КАК Документ,
	Товары.Номенклатура КАК Номенклатура,
	Товары.Склад КАК Склад,
	Товары.Количество КАК Количество,
	Товары.Цена КАК Цена,
	Товары.Сумма КАК Сумма
ИЗ
	ВТ_Товары КАК Товары

УПОРЯДОЧИТЬ ПО
	Номенклатура,
	Склад</queryText>
      <autoFillAvailableFields>true</autoFillAvailableFields>
      <customQuery>true</customQuery>
      <autoSaveUserSettings>true</autoSaveUserSettings>
      <getInvisibleFieldPresentations>true</getInvisibleFieldPresentations>
    </extInfo>
  </attributes>
