#Область СозданиеНаОсновании  

Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСоздатьНаОсновании) Экспорт
	
	ИмяДокумента = "ЗаказНаДоставкуОтПоставщика";
	Если ПравоДоступа("Добавление", Метаданные.Документы[ИмяДокумента]) Тогда
		КомандаСоздатьНаОсновании = КомандыСоздатьНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Менеджер = Метаданные.Документы[ИмяДокумента].ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление = Строка(ОбщегоНазначенияУТ.ПредставлениеОбъекта(Метаданные.Документы[ИмяДокумента])) + " (множественный выбор)";
		КомандаСоздатьНаОсновании.МножественныйВыбор= Истина;
		КомандаСоздатьНаОсновании.Идентификатор = "ЗаказНаДоставкуОтПоставщика_ЗаказПоставщику";
		КомандаСоздатьНаОсновании.Обработчик = "ВводНаОснованииДополнительноКлиент.ВводНаОснованииКлиент";
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ПолучитьДоверенность(ЗаказНаДоставку, Водитель)  Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДоверенностьВыданная.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ДоверенностьВыданная КАК ДоверенностьВыданная
	|ГДЕ
	|	ДоверенностьВыданная.Проведен
	|	И ДоверенностьВыданная.ДокументОснование = &ЗаказНаДоставку
	|	И ДоверенностьВыданная.ФизЛицо = &Водитель";
	
	Запрос.УстановитьПараметр("ЗаказНаДоставку", ЗаказНаДоставку);
	Запрос.УстановитьПараметр("Водитель", Водитель);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка= РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Документы.ДоверенностьВыданная.ПустаяСсылка();
	КонецЕсли; 
	
КонецФункции 

Функция СоздатьДоверенность(ЗаказНаДоставку, Рейс)  Экспорт
	
	ДокДоверенность = Документы.ДоверенностьВыданная.СоздатьДокумент();
	ДокДоверенность.Дата = ТекущаяДата();
	ДокДоверенность.Валюта = Константы.ВалютаРегламентированногоУчета.Получить();
	ДокДоверенность.ДокументОснование = ЗаказНаДоставку;
	ДокДоверенность.Должность = "Водитель"; 
	ДокДоверенность.Комментарий = "На основании: "+ ЗаказНаДоставку;
	ДокДоверенность.Контрагент = ЗаказНаДоставку.Контрагент;
	ДокДоверенность.Организация = ЗаказНаДоставку.Организация;
	БанковскийСчет = АльтерраОбщегоНазначения.ПолучитьБанковскийСчетПоУмолчанию(ДокДоверенность.Организация);
	ДокДоверенность.БанковскийСчет = БанковскийСчет;
	ДокДоверенность.Ответственный = Пользователи.ТекущийПользователь();
	ДокДоверенность.Партнер = ЗаказНаДоставку.Партнер;
	ДокДоверенность.Статус = Перечисления.СтатусыДоверенностей.НеВыдана; 
	ДокДоверенность.СрокДействия = 10;
	ДокДоверенность.ДатаОкончанияДействия = ТекущаяДата()+3600*24*ДокДоверенность.СрокДействия;
	ДокДоверенность.СуммаДокумента = ЗаказНаДоставку.СтоимостьТовара;
	ДокДоверенность.СуммаОплатПоДокументу =  ЗаказНаДоставку.СтоимостьДоставки;
	ДокДоверенность.ФизЛицо = Рейс.Водитель;
	ДокДоверенность.ПоДокументу = ЗаказНаДоставку.ПоДокументу;
	
	СписокГрузополучателей = ПолучитьНастройкиХранилища("СоотвтетствиеСкладовИГрузополучатеей");
	СкладПолучатель = Рейс.РасчетДоставки[0].СкладРазгрузки;
	
	Для каждого Склад Из СписокГрузополучателей.ТаблицаНастройки Цикл
		Если Склад.СкладПолучатель = СкладПолучатель Тогда
			ДокДоверенность.Грузополучатель = Склад.Грузополучатель
		КонецЕсли;
	КонецЦикла;
		
	ЗаполнитьПаспортныеДанные(ДокДоверенность, ДокДоверенность.ФизЛицо);
	
	ОтветственныеЛица = ОтветственныеЛицаСервер.ПолучитьОтветственныеЛицаОрганизации(ДокДоверенность.Организация, ДокДоверенность.Дата);
	ДокДоверенность.ГлавныйБухгалтер = ОтветственныеЛица.ГлавныйБухгалтерСсылка;
	ДокДоверенность.Руководитель = ОтветственныеЛица.РуководительСсылка;
	
	ДокДоверенность.ТипДоверенности = Перечисления.ТипыВыданныхДоверенностей.НаПолучениеТоваров;
	ДокДоверенность.Товары.Загрузить(Документы.ЗаказНаДоставкуОтПоставщика.ПолучитьТоварыОснований(ЗаказНаДоставку));
	
	ДокДоверенность.Записать(РежимЗаписиДокумента.Проведение);
	
	Возврат ДокДоверенность.Ссылка;   
	
КонецФункции

Процедура ЗаполнитьПаспортныеДанные(ДокДоверенность, ФизЛицо) 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыФизическихЛицСрезПоследних.ВидДокумента КАК ВидДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Серия КАК СерияДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Номер КАК НомерДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.КемВыдан КАК КемВыданДокументФизлица,
	|	ДокументыФизическихЛицСрезПоследних.ДатаВыдачи КАК ДатаВыдачиДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Представление КАК ПредставлениеДокументаФизЛица
	|ПОМЕСТИТЬ ПаспортРФ
	|ИЗ
	|	РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыФизическихЛицСрезПоследних
	|ГДЕ
	|	ДокументыФизическихЛицСрезПоследних.Физлицо = &ФизЛицо
	|	И ДокументыФизическихЛицСрезПоследних.ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ПаспортРФ)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДокументыФизическихЛицСрезПоследних.ВидДокумента КАК ВидДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Серия КАК СерияДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Номер КАК НомерДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.КемВыдан КАК КемВыданДокументФизлица,
	|	ДокументыФизическихЛицСрезПоследних.ДатаВыдачи КАК ДатаВыдачиДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Представление КАК ПредставлениеДокументаФизЛица
	|ПОМЕСТИТЬ ДокументУдостоверяющийЛичность
	|ИЗ
	|	РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыФизическихЛицСрезПоследних
	|ГДЕ
	|	ДокументыФизическихЛицСрезПоследних.ЯвляетсяДокументомУдостоверяющимЛичность
	|	И ДокументыФизическихЛицСрезПоследних.Физлицо = &ФизЛицо
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументыФизическихЛицСрезПоследних.Период УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ПаспортРФ.ВидДокументаФизЛица ЕСТЬ NULL 
	|			ТОГДА ДокументУдостоверяющийЛичность.ВидДокументаФизЛица
	|		ИНАЧЕ ПаспортРФ.ВидДокументаФизЛица
	|	КОНЕЦ КАК ВидДокументаФизЛица
	|ПОМЕСТИТЬ ВыбранныйВидДокумента
	|ИЗ
	|	ПаспортРФ КАК ПаспортРФ
	|		ПОЛНОЕ СОЕДИНЕНИЕ ДокументУдостоверяющийЛичность КАК ДокументУдостоверяющийЛичность
	|		ПО (ИСТИНА)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДокументыФизическихЛицСрезПоследних.ВидДокумента КАК ВидДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Серия КАК СерияДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Номер КАК НомерДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.КемВыдан КАК КемВыданДокументФизлица,
	|	ДокументыФизическихЛицСрезПоследних.ДатаВыдачи КАК ДатаВыдачиДокументаФизЛица,
	|	ДокументыФизическихЛицСрезПоследних.Представление КАК ПредставлениеДокументаФизЛица
	|ИЗ
	|	ВыбранныйВидДокумента КАК ВыбранныйВидДокумента
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыФизическихЛицСрезПоследних
	|		ПО ВыбранныйВидДокумента.ВидДокументаФизЛица = ДокументыФизическихЛицСрезПоследних.ВидДокумента
	|ГДЕ
	|	ДокументыФизическихЛицСрезПоследних.Физлицо = &ФизЛицо";
	Запрос.УстановитьПараметр("ФизЛицо", ФизЛицо);
	Результат = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДокДоверенность, ВыборкаДетальныеЗаписи);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 


// Возвращает структуру из настроек хранилища дополнительной обработки.
//
// Параметры:
//	ИмяФайла - поиск элемента справочника по имени файла 
//  ИмяСтруктуры - название структуры в структуре хранилища значений
// Возвращаемое значение:
//	Структура со значениями сохраненных настроек.
//
Функция ПолучитьНастройкиХранилища(ИмяСтруктуры,ИмяФайла="НастройкиХранилища.epf") экспорт
	ДополнительнаяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоРеквизиту("ИмяФайла", имяФайла);		
	СтруктураХранилища=ДополнительнаяОбработка.ХранилищеНастроек.Получить();
	если типзнч(СтруктураХранилища)=тип("Структура") и СтруктураХранилища.Свойство(ИмяСтруктуры) тогда
		Возврат СтруктураХранилища[ИмяСтруктуры] ;
	конецесли;
	возврат неопределено;
КонецФункции

#КонецЕсли