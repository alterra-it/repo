//Проведение
Процедура КонтрольОстатков(Объект, Отказ)  Экспорт
	
	Если Объект.ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказНаДоставкуОтПоставщикаОснования.Документ КАК Документ
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	Документ.ЗаказНаДоставкуОтПоставщика.Основания КАК ЗаказНаДоставкуОтПоставщикаОснования
	|ГДЕ
	|	ЗаказНаДоставкуОтПоставщикаОснования.Ссылка = &Заказ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказыКДоставкеОтПоставщика.ЗаказНаДоставку КАК ЗаказНаДоставку,
	|	ЗаказыКДоставкеОтПоставщика.Документ КАК Документ
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставкеОтПоставщика КАК ЗаказыКДоставкеОтПоставщика
	|ГДЕ
	|	ЗаказыКДоставкеОтПоставщика.Документ В
	|			(ВЫБРАТЬ
	|				ВТ_Основания.Документ КАК Основание
	|			ИЗ
	|				ВТ_Основания КАК ВТ_Основания)
	|	И ЗаказыКДоставкеОтПоставщика.ВидДвижения = &ВидДвижения
	|	И ЗаказыКДоставкеОтПоставщика.Регистратор <> &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Объект.Ссылка);
	Запрос.УстановитьПараметр("ВидДвижения", ВидДвиженияНакопления.Приход);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда 
		Сообщить("Документы присутствуют в других заказах!");
		Отказ= Истина;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		АльтерраОбщегоНазначения.СообщитьПользователю(Выборка.ЗаказНаДоставку, Строка(Выборка.Документ));
	КонецЦикла; 
	
КонецПроцедуры

//Перед записью
Процедура ПроверитьЧтоЕстьДругиеЗаказы(Объект, Отказ)  Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВТ_Основания.Документ КАК Основание
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&Основания КАК ВТ_Основания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказыКДоставке.ЗаказНаДоставку КАК ЗаказНаДоставку,
	|	ЗаказыКДоставке.Документ КАК Документ
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставкеОтПоставщика КАК ЗаказыКДоставке
	|ГДЕ
	|	ЗаказыКДоставке.Документ В
	|			(ВЫБРАТЬ
	|				ВТ_Основания.Основание КАК Основание
	|			ИЗ
	|				ВТ_Основания КАК ВТ_Основания)
	|	И ЗаказыКДоставке.ЗаказНаДоставку <> &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ: "+Выборка.Документ+" присутствует в другом заказе: "+Выборка.ЗаказНаДоставку, Объект.Ссылка, "ОснованияДокумент", "Основания.Документ");
		Отказ= Истина;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Ложь); 
	
КонецПроцедуры   

//При отмене проведения
Процедура ПроверитьЧтоЕстьРейсы(Объект, Отказ)  Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВТ_Основания.Документ КАК Основание
	|ПОМЕСТИТЬ ВТ_Основания
	|ИЗ
	|	&Основания КАК ВТ_Основания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗаказыКДоставкеОтПоставщика.ЗаказНаДоставку КАК ЗаказНаДоставку,
	|	ЗаказыКДоставкеОтПоставщика.Документ КАК Документ
	|ИЗ
	|	РегистрНакопления.ЗаказыКДоставкеОтПоставщика КАК ЗаказыКДоставкеОтПоставщика
	|ГДЕ
	|	ЗаказыКДоставкеОтПоставщика.Документ В
	|			(ВЫБРАТЬ
	|				ВТ_Основания.Основание КАК Основание
	|			ИЗ
	|				ВТ_Основания КАК ВТ_Основания)
	|	И ЗаказыКДоставкеОтПоставщика.ЗаказНаДоставку <> &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Основания", Объект.Основания.Выгрузить());
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		АльтерраОбщегоНазначения.СообщитьПользователю(ВыборкаДетальныеЗаписи.ЗаказНаДоставку, "По " + ВыборкаДетальныеЗаписи.ЗаказНаДоставку + " существует активный рейс!");
		Отказ = Истина;                                                                                                                      
	КонецЦикла; 
	
КонецПроцедуры  

