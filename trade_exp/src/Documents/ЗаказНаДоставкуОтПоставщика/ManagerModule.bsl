#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область Заполнение 

Процедура ЗаполнитьДанныеПоОснованию(Основания, Объект)   Экспорт
	
	мОснований= Новый Массив;
	Если ТипЗнч(Основания) = Тип("Массив") Тогда
		мОснований= Основания;
	Иначе
		мОснований.Добавить(Основания);
	КонецЕсли;
	
	Для Каждого Основание Из мОснований Цикл
		Если ЗначениеЗаполнено(Основание) Тогда
			ТЗОснований= Объект.Основания.Выгрузить();
			НоваяСтрока= ТЗОснований.Найти(Основание, "Документ");
			Если НоваяСтрока= Неопределено Тогда 
				НоваяСтрока= Объект.Основания.Добавить();
				НоваяСтрока.Документ= Основание;
			КонецЕсли;
			
			ЗаполнитьЗначенияСвойств(Объект, Основание, , "Дата,Номер,Проведен,Комментарий");
			Объект.ФилиалВыгрузки= Основание.Склад.Подразделение;
			Если ТипЗнч(Основание)  = Тип("ДокументСсылка.ЗаказПоставщику") ИЛИ ТипЗнч(Основание)  = Тип("ДокументСсылка.ПриобретениеТоваровУслуг") Тогда
				Объект.НаправлениеДоставки= Основание.Партнер.БизнесРегион;
				ОбновитьРеквизитыДоставки(Объект);
			КонецЕсли;
			
			Объект.Автор= Пользователи.ТекущийПользователь();
			
			ОбновитьИтогиПоОснованиям(Объект);
		КонецЕсли;
	КонецЦикла;
	
	Если мОснований.Количество() > 0 Тогда
		ЗаказПоставщику= мОснований[0];
		Если ТипЗнч(ЗаказПоставщику) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			ЗаказКлиента= ЗаказПоставщику.ДокументОснование;
			Если ЗначениеЗаполнено(ЗаказКлиента) И ТипЗнч(ЗаказКлиента) = Тип("ДокументСсылка.ЗаказКлиента") Тогда
				Объект.Транзит= ЗаказКлиента.Склад.Транзит;
				Объект.ТранзитФизЛицо= ЗаказКлиента.ТранзитФизЛицо;
				Объект.Клиент= ЗаказКлиента.Партнер;
				Объект.КонтрагентКлиента= ЗаказКлиента.Контрагент;
				Объект.ТелефонНаВыгрузке= ЗаказКлиента.ТелефонКлиентаНаВыгрузке;
				Объект.АдресНаВыгрузке= ЗаказКлиента.АдресДоставки;
				Объект.АдресНаВыгрузкеЗначенияПолей= ЗаказКлиента.АдресДоставкиЗначенияПолей;
				Объект.СтоимостьДоставки= ЗаказКлиента.РазмерТранспортных;
				Объект.Комментарий= ЗаказКлиента.Комментарий;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьРеквизитыДоставки(Объект) Экспорт

	Объект.АдресНаПогрузке = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Объект.Контрагент, Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента, ТекущаяДата());
	Объект.ТелефонНаПогрузке = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Объект.Контрагент, Справочники.ВидыКонтактнойИнформации.ТелефонКонтрагента, ТекущаяДата());
	
	Объект.АдресНаВыгрузке = АльтерраОбщегоНазначения.ПолучитьАдресФилиала(Объект.ФилиалВыгрузки);     
	
КонецПроцедуры

Процедура ОбновитьИтогиПоОснованиям(Объект) Экспорт
	
	мСсылок = ПолучитьМассивОснований(Объект);
	
	Итоги = ПолучитьИтогиПоДокументам(мСсылок);
	
	ЗаполнитьЗначенияСвойств(Объект, Итоги);  
	
КонецПроцедуры

Функция ПолучитьМассивОснований(Объект)
	
	мСсылок = Новый Массив;
	Для Каждого стрОснование Из Объект.Основания Цикл
		мСсылок.Добавить(стрОснование.Документ);
	КонецЦикла;
	
	Возврат мСсылок;  
	
КонецФункции

Функция ПолучитьИтогиПоДокументам(мСсылок)  Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПоступлениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	ПоступлениеТоваровУслугТовары.Сумма КАК Сумма,
	|	ПоступлениеТоваровУслугТовары.КоличествоУпаковок КАК КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ПоступлениеТоваровУслугТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК КоличествоСтрокВДокументе,
	|	ПоступлениеТоваровУслугТовары.Ссылка.СуммаДокумента КАК СуммаДокумента
	|ПОМЕСТИТЬ Товар
	|ИЗ
	|	Документ.ПриобретениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|ГДЕ
	|	ПоступлениеТоваровУслугТовары.Ссылка В(&мСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказПоставщикуТовары.Номенклатура,
	|	ЗаказПоставщикуТовары.Сумма,
	|	ЗаказПоставщикуТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЗаказПоставщикуТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	ЗаказПоставщикуТовары.Ссылка.СуммаДокумента
	|ИЗ
	|	Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	|ГДЕ
	|	ЗаказПоставщикуТовары.Ссылка В(&мСсылок)
	|	И НЕ ЗаказПоставщикуТовары.Отменено
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказНаПеремещениеТовары.Номенклатура,
	|	0,
	|	ЗаказНаПеремещениеТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ЗаказНаПеремещениеТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ЗаказНаПеремещение.Товары КАК ЗаказНаПеремещениеТовары
	|ГДЕ
	|	ЗаказНаПеремещениеТовары.Ссылка В(&мСсылок)
	|	И НЕ ЗаказНаПеремещениеТовары.Отменено
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура,
	|	0,
	|	ПеремещениеТоваровТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	0
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|ГДЕ
	|	ПеремещениеТоваровТовары.Ссылка В(&мСсылок)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВозвратТоваровПоставщикуТовары.Номенклатура,
	|	-ВозвратТоваровПоставщикуТовары.Сумма,
	|	-ВозвратТоваровПоставщикуТовары.КоличествоУпаковок,
	|	ВЫБОР
	|		КОГДА ВозвратТоваровПоставщикуТовары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
	|			ТОГДА 1
	|		ИНАЧЕ 0
	|	КОНЕЦ,
	|	-ВозвратТоваровПоставщикуТовары.Ссылка.СуммаДокумента
	|ИЗ
	|	Документ.ВозвратТоваровПоставщику.Товары КАК ВозвратТоваровПоставщикуТовары
	|ГДЕ
	|	ВозвратТоваровПоставщикуТовары.Ссылка.ДокументПоступления В(&мСсылок)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Товар.Сумма) КАК СтоимостьТовара,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаВесНоменклатуры) КАК Вес,
	|	СУММА(Товар.КоличествоУпаковок * &ТекстЗапросаОбъемНоменклатуры) КАК Объем,
	|	СУММА(Товар.СуммаДокумента) КАК Стоимость,
	|	МАКСИМУМ(ВЫБОР
	|			КОГДА Товар.Номенклатура.ДлинаЗнаменатель <> 0
	|				ТОГДА Товар.Номенклатура.ДлинаЧислитель / Товар.Номенклатура.ДлинаЗнаменатель
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК МаксимальнаяДлина
	|ИЗ
	|	Товар КАК Товар" ;
	
	Запрос.УстановитьПараметр("мСсылок", мСсылок);
	
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаВесНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаВесУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	Запрос.Текст = СтрЗаменить(
	Запрос.Текст, 
	"&ТекстЗапросаОбъемНоменклатуры",
	Справочники.УпаковкиЕдиницыИзмерения.ТекстЗапросаОбъемУпаковки(
	"Товар.Номенклатура.ЕдиницаИзмерения",
	"Товар.Номенклатура"));
	
	Рез = Новый Структура("Вес,Объем,СтоимостьТовара,МаксимальнаяДлина,Стоимость",0,0,0,0);
	
	Выборка= Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Рез, Выборка);
	КонецЕсли;
	
	Возврат Рез;
	
КонецФункции

