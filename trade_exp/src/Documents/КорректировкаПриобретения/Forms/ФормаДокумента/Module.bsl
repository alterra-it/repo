#Область Зеленение
&После("УстановитьУсловноеОформление")
Процедура Спр_УстановитьУсловноеОформление()
	АльтерраОбщегоНазначения.УстановитьОформлениеЗеленениеСтрокТабличныхЧастей(ЭтаФорма,"Расхождения");
КонецПроцедуры
&НаКлиенте
Процедура СброситьПоСекции(Команда)
	МассивВыдСтрок=Элементы.Товары.ВыделенныеСтроки;
	если МассивВыдСтрок.Количество()<>0 тогда
		Для Каждого ТекСтрока Из МассивВыдСтрок Цикл
			СтрокаКоллекции=Объект.Товары.НайтиПоИдентификатору(ТекСтрока);
			СтрокаКоллекции.Кладовщик="";
		конеццикла;
	конецесли;	
КонецПроцедуры

&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	Элементы.ИсключитьИзКонтроля.Доступность = РольДоступна("РазрешитьИсключатьДокументыИзКонтроляОрдерногоУчета");
	ВидимостьКомандСозданияОрдера();
	СтрокаИзменений = "";
КонецПроцедуры

&НаСервере
Процедура ВидимостьКомандСозданияОрдера()
	Если ЗначениеЗаполнено(Объект.АктОРасхожденияхПослеПриемкиОснование) Тогда
		Элементы.ФормаСоздатьОрдерОтраженияИзлишков.Видимость = Ложь;
		Элементы.ФормаСоздатьОрдерОтраженияНедостач.Видимость = Ложь;
	Иначе
		Элементы.ФормаСоздатьОрдерОтраженияИзлишков.Видимость = Истина;
		Элементы.ФормаСоздатьОрдерОтраженияНедостач.Видимость = Истина;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура Док_СоздатьОрдерОтраженияИзлишковПосле(Команда)
	ВидОрдера = "Отражение излишков";
	Док_СоздатьОрдерНаСервере(ВидОрдера);
КонецПроцедуры

&НаСервере 
Процедура Док_СоздатьОрдерНаСервере(ВидОрдера)
	Если ЗначениеЗаполнено(Объект.АктОРасхожденияхПослеПриемкиОснование) Тогда
		ОбщегоНазначения.СообщитьПользователю("Создание оредра невозможно! Корректировка проведена по акту о расхождениях");
	Иначе
		Альтерра_СкладСервер.СоздатьОрдерДляКорректировкаПриобретения(Объект.Ссылка, ВидОрдера);
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура Док_СоздатьОрдерОтраженияНедостачПосле(Команда)
	ВидОрдера = "Отражение недостач";
	Док_СоздатьОрдерНаСервере(ВидОрдера);
КонецПроцедуры


&НаКлиенте
Процедура Док_ПередЗаписьюПеред(Отказ, ПараметрыЗаписи)
	Если ПараметрыЗаписи.РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		СФП_МаркерыКлиент.МаркерНачало("Корректировка приобретения: Проведение из формы");
	КонецЕсли;
	
	Если Объект.Ссылка.Пустая() Тогда  
		Объект.ДатаСозданияДокумента = ТекущаяДата();	
	КонецЕсли;	
КонецПроцедуры


&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	Если СтрокаИзменений <> "" Тогда 
		Если Объект.Проведен Тогда 
			ОтправитьИнформациюВЧат_ИзменениеПриходныхДокументовВЗакрытомПериоде();
		КонецЕсли;
		СтрокаИзменений = "";
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОтправитьИнформациюВЧат_ИзменениеПриходныхДокументовВЗакрытомПериоде()
	Документы.КорректировкаПриобретения.ОтправитьИнформациюВЧат_ИзменениеПриходныхДокументовВЗакрытомПериоде(
		Объект.Организация, 
		Объект.Дата, 
		"Изменен документ " + Объект.Ссылка + ". Внесены изменения в: " + Лев(СтрокаИзменений, СтрДлина(СтрокаИзменений) - 2));
КонецПроцедуры

#КонецОбласти       

#Область ПроверкаИзменений

&НаСервере
Функция ПроверкаДатаИзменилась()
	Если Формат(Объект.Ссылка.Дата, "ДЛФ=D") <> Формат(Объект.Дата, "ДЛФ=D") Тогда
		Возврат Истина;
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ПроверкаИзменений(Элемент)
	Если СтрНайти(СтрокаИзменений, Элемент.Заголовок) = 0  Тогда
		СтрокаИзменений = СтрокаИзменений + Элемент.Заголовок + ", ";
	КонецЕсли;
КонецПроцедуры 

&НаКлиенте
Процедура Док_ОперацияПриИзмененииПосле(Элемент)	
	ПроверкаИзменений(Элемент);	
КонецПроцедуры 

&НаКлиенте
Процедура Док_НомерПриИзмененииПосле(Элемент)	
	ПроверкаИзменений(Элемент); 	
КонецПроцедуры

