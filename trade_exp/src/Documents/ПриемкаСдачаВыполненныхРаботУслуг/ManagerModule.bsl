Функция СформироватьПечатнуюФорму(Документ, ЭтоСотрудник = Неопределено, Клининг = Ложь) Экспорт
	Если Клининг Тогда
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПриемкаСдачаВыполненныхРаботУслуг.МакетПриемкаСдача");
		Если ЭтоСотрудник = Неопределено Тогда
			Если Документ.Работы[0].Сотрудник <> Неопределено Тогда
				ЭтоСотрудник = Истина;
			КонецЕсли;
		КонецЕсли;
		ТабДокумент = Новый ТабличныйДокумент;
		Область = Макет.ПолучитьОбласть("Заголовок");
		Область.Параметры.Подрядчик = Документ.Подрядчик;
		Область.Параметры.Адрес = Документ.Подразделение.Адрес;
		Область.Параметры.Дата = Документ.Дата; 
		ТабДокумент.Вывести(Область);
		Область = Макет.ПолучитьОбласть("ЗаголовокТаблицыКлининг");
		ТабДокумент.Вывести(Область);
		ТабличнаяЧасть = Документ.Работы;
		ИтогСумма = 0;
		Для Каждого СтрокаТаблицы из ТабличнаяЧасть Цикл
			Область = Макет.ПолучитьОбласть("ТабличнаяЧастьКлининг");
			ЗаполнитьЗначенияСвойств(Область.Параметры, СтрокаТаблицы);
			ТабДокумент.Присоединить(Область);
		КонецЦикла;
		Область = Макет.ПолучитьОбласть("Подвал");
		НомерТелефона = ПолучитьТелефонПодрядчика(Документ.Подрядчик);
		Если НомерТелефона <> Неопределено Тогда
			Область.Параметры.Телефон = НомерТелефона;
		КонецЕсли;
		ТабДокумент.Вывести(Область);
		Возврат ТабДокумент;
	Иначе
		Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ПриемкаСдачаВыполненныхРаботУслуг.МакетПриемкаСдача");
		Если ЭтоСотрудник = Неопределено Тогда
			Если Документ.Работы[0].Сотрудник <> Неопределено Тогда
				ЭтоСотрудник = Истина;
			КонецЕсли;
		КонецЕсли;
		ТабДокумент = Новый ТабличныйДокумент;
		Область = Макет.ПолучитьОбласть("Заголовок");
		Область.Параметры.Подрядчик = Документ.Подрядчик;
		Область.Параметры.Адрес = Документ.Подразделение.Адрес;
		Область.Параметры.Дата = Документ.Дата; 
		ТабДокумент.Вывести(Область);
		Область = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабДокумент.Вывести(Область);
		ТабличнаяЧасть = Документ.Работы;
		ИтогВремя = 0;
		ИтогСумма = 0;
		Для Каждого СтрокаТаблицы из ТабличнаяЧасть Цикл
			Область = Макет.ПолучитьОбласть("ТабличнаяЧасть");
			ЗаполнитьЗначенияСвойств(Область.Параметры, СтрокаТаблицы);
			СтруктураРеквизитовБанка = ПолучитьНомерКартыФИО(СтрокаТаблицы.ФИОРаботника);
			Если СтруктураРеквизитовБанка <> Неопределено Тогда
				ЗаполнитьЗначенияСвойств(Область.Параметры, СтруктураРеквизитовБанка)
			КонецЕсли;
			ИтогВремя = ИтогВремя + СтрокаТаблицы.ВремяФакт;
			ИтогСумма = ИтогСумма + СтрокаТаблицы.ОплатаПодрядчику;
			ТабДокумент.Присоединить(Область);
		КонецЦикла;
		Область = Макет.ПолучитьОбласть("Итоги");
		Область.Параметры.ИтогВремя = ИтогВремя;
		Область.Параметры.ИтогСумма = ИтогСумма;
		ТабДокумент.Вывести(Область);
		Область = Макет.ПолучитьОбласть("Подвал");
		НомерТелефона = ПолучитьТелефонПодрядчика(Документ.Подрядчик);
		Если НомерТелефона <> Неопределено Тогда
			Область.Параметры.Телефон = НомерТелефона;
		КонецЕсли;
		ТабДокумент.Вывести(Область);
		Возврат ТабДокумент; 
	КонецЕсли
КонецФункции

Функция ПолучитьНомерКартыФИО(СотрудникАутсорс)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	СотрудникиАутсорс.НомерКарты КАК НомерКарты,
	|	СотрудникиАутсорс.ФИОПолучателя КАК Получатель
	|ИЗ
	|	Справочник.СотрудникиАутсорс КАК СотрудникиАутсорс
	|ГДЕ
	|	СотрудникиАутсорс.Ссылка = &Сотрудник";
	Запрос.УстановитьПараметр("Сотрудник", СотрудникАутсорс);
	Выборка = Запрос.Выполнить().Выбрать();
	Структура = Новый Структура;
	Пока Выборка.Следующий() Цикл
		Структура.Вставить("НомерКарты", Выборка.НомерКарты);
		Структура.Вставить("Получатель", Выборка.Получатель);
		Возврат Структура;
	КонецЦикла;	
	Возврат Неопределено;
КонецФункции

Функция ПолучитьТелефонПодрядчика(Подрядчик)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПартнерыКонтактнаяИнформация.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО (Контрагенты.Партнер = ПартнерыКонтактнаяИнформация.Ссылка)
	|ГДЕ
	|	ПартнерыКонтактнаяИнформация.НомерТелефона <> "" ""
	|	И Контрагенты.Ссылка = &Подрядчик";
	Запрос.УстановитьПараметр("Подрядчик", Подрядчик);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.НомерТелефона;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция РассылкаИсполнителю(Документ) Экспорт
	
	ПолучательПисьма = ПолучитьАдресЭП(Документ.Подрядчик);
	Если ПолучательПисьма = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Адрес электронной почты Исполнителя не найден");
		Возврат Ложь;
	КонецЕсли;
	ТабДок = СформироватьПечатнуюФорму(Документ);  
	
	ИмяФайла = ПолучитьИмяВременногоФайла(".xlsx");
	ТабДок.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.xlsx);
	АдресФайлаВоВременномХранилище = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяФайла));                     
                                                                                      
	МассивФайлов = Новый Массив;
	МассивФайлов.Добавить(Новый Структура("Представление, АдресВоВременномХранилище","Приемка-сдача выполненых работ (услуг)" + ".xlsx", АдресФайлаВоВременномХранилище));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ  
	|	ПрисоединенныеФайлы.Ссылка КАК Файл,
	|	ПрисоединенныеФайлы.Наименование КАК Наименование,
	|	ПрисоединенныеФайлы.Расширение КАК Расширение
	|ИЗ
	|	Справочник.ПриемкаСдачаВыполненныхРаботУслугПрисоединенныеФайлы КАК ПрисоединенныеФайлы
	|ГДЕ
	|	ПрисоединенныеФайлы.ВладелецФайла = &ВладелецФайла
	|	И НЕ ПрисоединенныеФайлы.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("ВладелецФайла", Документ.Ссылка);
	Результат = Запрос.Выполнить();
	Выборка = Результат.Выбрать();
	
	Если Выборка.Количество() > 0 Тогда
		Пока Выборка.Следующий() Цикл
			ДанныеФайла = РаботаСФайлами.ДанныеФайла(Выборка.Файл);
			
			СтруктураФайла = Новый Структура("Представление, АдресВоВременномХранилище");
			СтруктураФайла.Представление = ДанныеФайла.ИмяФайла;
			СтруктураФайла.АдресВоВременномХранилище = ДанныеФайла.СсылкаНаДвоичныеДанныеФайла;
			
			МассивФайлов.Добавить(СтруктураФайла);
		КонецЦикла;
	КонецЕсли;	
	
	ПараметрыОтправки = Новый Структура;
	ПараметрыОтправки.Вставить("Кому", ПолучательПисьма);
	ПараметрыОтправки.Вставить("Тема", "Приемка-сдача работ "+Формат(ТекущаяДата(), "ДФ=dd.MM.yyyy"));  

	ПараметрыОтправки.Вставить("Кодировка", КодировкаТекста.UTF8);
	ПараметрыОтправки.Вставить("ТипТекста", Перечисления.ТипыТекстовЭлектронныхПисем.ПростойТекст);
	ПараметрыОтправки.Вставить("Вложения", МассивФайлов);
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатОтправкиEmail = РаботаСПочтовымиСообщениями.ОтправитьПочтовоеСообщение(Справочники.УчетныеЗаписиЭлектроннойПочты.СистемнаяУчетнаяЗаписьЭлектроннойПочты, ПараметрыОтправки);		
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Истина;  
		
КонецФункции
#КонецОбласти
#КонецЕсли

Функция ПолучитьАдресЭП(Партнер)
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ПартнерыКонтактнаяИнформация.АдресЭП КАК Адрес
	|ИЗ
	|	Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформация
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО (Контрагенты.Партнер = ПартнерыКонтактнаяИнформация.Ссылка)
	|ГДЕ
	|	НЕ ПартнерыКонтактнаяИнформация.АдресЭП = """"
	|	И НЕ ПартнерыКонтактнаяИнформация.АдресЭП ЕСТЬ NULL
	|	И Контрагенты.Ссылка = &Партнер";
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Возврат Выборка.Адрес;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ОпределениеЦеныРабот(Партнер,ВидРабот,Подразделение) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ЦеныНоменклатурыПоставщиковСрезПоследних.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатурыПоставщиков.СрезПоследних КАК ЦеныНоменклатурыПоставщиковСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Контрагенты
	|		ПО (Контрагенты.Партнер = ЦеныНоменклатурыПоставщиковСрезПоследних.Партнер)
	|ГДЕ
	|	ЦеныНоменклатурыПоставщиковСрезПоследних.НоменклатураПартнера = &НоменклатураПартнера
	|	И Контрагенты.Ссылка = &Партнер
	|	И ЦеныНоменклатурыПоставщиковСрезПоследних.ВидЦеныПоставщика.РегионПрисутствия = &РегионПрисутствия";
	Запрос.УстановитьПараметр("НоменклатураПартнера", ВидРабот);
	Запрос.УстановитьПараметр("РегионПрисутствия", Подразделение.РегионПрисутствия);
	Запрос.УстановитьПараметр("Партнер", Партнер);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		УстановитьПривилегированныйРежим(Ложь);
		Возврат Выборка.Цена;
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	Возврат Неопределено;
КонецФункции

