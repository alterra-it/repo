#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ПересортицаТоваров") Тогда
		
		Склад = ДанныеЗаполнения.Склад;
		
		Для каждого Строка из ДанныеЗаполнения.Товары Цикл
			НоваяСтрока = Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
			НоваяСтрока.КоличествоУпаковок = Строка.Количество;
		КонецЦикла;

			
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АктОРасхожденияхПослеПеремещения") Тогда
		
		Основание =ДанныеЗаполнения.Ссылка;
		Склад = ДанныеЗаполнения.СкладОтправитель;
		
		Для каждого Строка из ДанныеЗаполнения.Товары Цикл
			//+Альтерра
			Если Строка.Действие = Перечисления.ВариантыДействийПоРасхождениямВАктеПослеОтгрузки.ПокупкаПерепоставленного Тогда
				НоваяСтрока = Товары.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка,,"Назначение");
				КоличУпаковок = Строка.КоличествоУпаковок - Строка.КоличествоУпаковокПоДокументу;
				МодульКоличУпаковок = Макс(КоличУпаковок, -КоличУпаковок);
				НоваяСтрока.КоличествоУпаковок = МодульКоличУпаковок;
				НоваяСтрока.Количество = МодульКоличУпаковок;
			КонецЕсли;	
			//-
			
			//-Альтерра
			//НоваяСтрока = Товары.Добавить();
			//ЗаполнитьЗначенияСвойств(НоваяСтрока,Строка);
			//НоваяСтрока.КоличествоУпаковок = 0;
			//НоваяСтрока.Количество = 0;
			//-
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры

