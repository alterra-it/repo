
&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	////////// Задача https://bitrix.tg-alterra.ru/company/personal/user/1794/tasks/task/view/149411/
	Если Не Склад.ТорговыйЗал Тогда
		Для каждого Товар из Товары Цикл
			НаборЗаписей = РегистрыСведений.ВариантыОбеспеченияТоварами.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Склад.Установить(Склад);
			НаборЗаписей.Отбор.Номенклатура.Установить(Товар.Номенклатура);
			Если БонусыАльтерраРезерв.ПолучитьЗначениеРеквизита(Товар, "Характеристика") <> Ложь Тогда
				НаборЗаписей.Отбор.Характеристика.Установить(Товар.Характеристика);
			КонецЕсли;
			НаборЗаписей.Прочитать();
			
			Если НаборЗаписей.Количество() > 0 
				И Строка(НаборЗаписей[0].СпособОбеспеченияПотребностей) = "Ассортимент ТЗ" Тогда
				Сообщить("Номенклатура " + Товар.Номенклатура + " не является ассортиментом " + Склад + ". Добавить в нехватку не возможно.");
				Отказ = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	//////////
КонецПроцедуры

