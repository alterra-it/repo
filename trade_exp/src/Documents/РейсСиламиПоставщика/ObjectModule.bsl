#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&Вместо("ОбработкаЗаполнения")
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ЕстьПриобретениеПоЗаказу(ДанныеЗаполнения) Тогда
		Документы.РейсСиламиПоставщика.ЗаполнитьДанныеПоОснованию(ДанныеЗаполнения, ЭтотОбъект);
	Иначе 
		Сообщить("По заказу не создано приобретение");
	КонецЕсли;
КонецПроцедуры

&Вместо("ПриЗаписи")
Процедура ПриЗаписи(Отказ)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	//Проверим нет ли заказов на доставку ещё в каких то рейсах
	Выборка= Документы.РейсСиламиПоставщика.ПроверитьПрисутствиеЗаказовВДругихРейсах(Ссылка);
	Пока Выборка.Следующий() Цикл
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(""+Выборка.Заказ+" присутствует в : "+Выборка.Рейс);
		Отказ= Истина;
	КонецЦикла;
КонецПроцедуры


#КонецЕсли
&Перед("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения ИЛИ ПометкаУдаления = Истина Тогда
		Документы.РейсСиламиПоставщика.УдалитьЗаписиВГрафикеПоставокНаСклад(Ссылка);
		Документы.РейсСиламиПоставщика.ОбновитьВремяИИнтервалПоставки(Ссылка);
	КонецЕсли;
КонецПроцедуры

Функция ЕстьПриобретениеПоЗаказу(Заказ)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПриобретениеТоваровУслуг.Ссылка КАК Приобретение,
		|	ДокЗаказПоставщику.Ссылка КАК Документ
		|ИЗ
		|	Документ.ПриобретениеТоваровУслуг КАК ПриобретениеТоваровУслуг
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ДокЗаказПоставщику
		|		ПО ПриобретениеТоваровУслуг.ЗаказПоставщику = ДокЗаказПоставщику.Ссылка
		|ГДЕ
		|	ДокЗаказПоставщику.Ссылка В (&Заказ)";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	РезультатЗапроса =  Запрос.Выполнить();
	
	ВыборкаИзРезультатаЗапроса = РезультатЗапроса.Выбрать();
	
	Если ВыборкаИзРезультатаЗапроса.Следующий() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;

КонецФункции