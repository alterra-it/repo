&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
Если ЗначениеЗаполнено(Параметры.Основание) Тогда
	Если Не Параметры.Основание = Неопределено Тогда
		
		Если Не Параметры.Основание.ПолучитьОбъект().Метаданные().ТабличныеЧасти.Найти("Товары") = Неопределено Тогда
			Товары.Очистить();
			Для каждого Строка из Параметры.Основание.Товары Цикл
				Если Строка.Номенклатура.ТипНоменклатуры <> Перечисления.ТипыНоменклатуры.Услуга Тогда
					НоваяСтрока = Товары.Добавить();
					НоваяСтрока.Номенклатура = Строка.Номенклатура;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
	КонецЕсли;
КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьВсе(Команда)
	 ВыборНаСервере(Истина);
КонецПроцедуры

&НаСервере
Процедура ВыборНаСервере(Значение=Ложь)
ТаблицаЗначений = Товары.Выгрузить();
ТаблицаЗначений.ЗаполнитьЗначения(Значение,"Выбрать");
Товары.Загрузить(ТаблицаЗначений);	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВыбор(Команда)
	ВыборНаСервере(Ложь);
КонецПроцедуры

&НаСервере
Функция ПеренестиВДокументНаСервере()
	
	Массив = Новый Массив();
	
	Структура = Новый Структура ("Выбрать",Истина);
    ТЗ.Загрузить(Товары.Выгрузить(Структура,"Номенклатура"));
	
	Для каждого СтрокаТЗ из ТЗ Цикл
		Массив.Добавить(СтрокаТЗ.Номенклатура);
	КонецЦикла;

	Возврат Массив;
	
КонецФункции

&НаКлиенте
Процедура ПеренестиВДокумент(Команда)
	МассивНоменклатуры = ПеренестиВДокументНаСервере();
	Закрыть(МассивНоменклатуры);
КонецПроцедуры
