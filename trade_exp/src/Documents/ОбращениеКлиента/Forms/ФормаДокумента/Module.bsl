&НаКлиенте
Процедура ТоварыДляДовозаКоличествоПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ТоварыДляДовоза.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		Если ТипНоменклатурыТовар(ТекущиеДанные.Номенклатура) Тогда
			Количество = ТекущиеДанные.Количество;
			Если Количество < 0 Тогда
				
				Если -Количество > ТекущиеДанные.МаксимальноеКоличествоПоДокументуПродажи Тогда
					Если ТекущиеДанные.МаксимальноеКоличествоПоДокументуПродажи = 0 Тогда  
						ОбщегоНазначенияКлиент.СообщитьПользователю("Товара нет в документе продажи, поэтому указать его недостачу невозможно! '");
					Иначе
						ОбщегоНазначенияКлиент.СообщитьПользователю("Введено большее количество, чем в документе '" + Объект.ДокументПродажи + "'", Объект.ДокументПродажи);
					КонецЕсли;
					ТекущиеДанные.Количество = -ТекущиеДанные.МаксимальноеКоличествоПоДокументуПродажи;
				КонецЕсли;
				
				Количество = -ТекущиеДанные.Количество;
			КонецЕсли;
			Если ТекущиеДанные.Цена = 0 Тогда 
				ТекущиеДанные.Склад = ПолучитьСклад();	
				ТекущиеДанные.ЕдиницаИзмерения = НоменклатураЕдиницаИзмерения(ТекущиеДанные.Номенклатура);	
				ТекущиеДанные.Цена = ПолучитьЦенуНоменклатуры(ТекущиеДанные.Номенклатура);
				ТекущиеДанные.СтавкаНДС = ПолучитьСтавкуНДС(ТекущиеДанные.Номенклатура);
			КонецЕсли;
			ТекущиеДанные.Сумма = Количество * ТекущиеДанные.Цена;
			ТекущиеДанные.СуммаНДС = ЦенообразованиеКлиентСервер.РассчитатьСуммуНДС(ТекущиеДанные.Сумма, ТекущиеДанные.СтавкаНДС, Истина);
			ТекущиеДанные.СуммаСНДС = ТекущиеДанные.Сумма + ТекущиеДанные.СуммаНДС; 
			
			Если Не ЗначениеЗаполнено(ТекущиеДанные.Организация) И ЗначениеЗаполнено(Объект.ДокументПродажи) Тогда
				ЗаполнитьЗначенияСвойств(ТекущиеДанные,ПолучитьШапкуДокументаПродажи());
			КонецЕсли;
			
		Иначе
			ТекущиеДанные.Сумма = ТекущиеДанные.Количество;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры 

&НаКлиенте
Процедура ТоварыДляДовозаКоличествоНедостачиПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ТоварыДляДовоза.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		Если ТипНоменклатурыТовар(ТекущиеДанные.Номенклатура) Тогда
			Если ЗначениеЗаполнено(ТекущиеДанные.КоличествоИзлишка) Тогда
				ОбщегоНазначенияКлиент.СообщитьПользователю("По этому товару указан излишек, поэтому указать его недостачу невозможно!");
				ТекущиеДанные.КоличествоНедостачи = 0;	
			Иначе
            	Количество = ТекущиеДанные.КоличествоНедостачи;
			
				Если Количество > ТекущиеДанные.МаксимальноеКоличествоПоДокументуПродажи Тогда
					Если ТекущиеДанные.МаксимальноеКоличествоПоДокументуПродажи = 0 Тогда  
						ОбщегоНазначенияКлиент.СообщитьПользователю("Товара нет в документе продажи, поэтому указать его недостачу невозможно! '");
					Иначе
						ОбщегоНазначенияКлиент.СообщитьПользователю("Введено большее количество, чем в документе '" + Объект.ДокументПродажи + "'", Объект.ДокументПродажи);
					КонецЕсли;                                                  
					ТекущиеДанные.КоличествоНедостачи = ТекущиеДанные.МаксимальноеКоличествоПоДокументуПродажи;
					Количество = ТекущиеДанные.КоличествоНедостачи;
				КонецЕсли;
				
				ТекущиеДанные.Количество = -Количество;
			
				Если ТекущиеДанные.Цена = 0 Тогда 
					ТекущиеДанные.Склад = ПолучитьСклад();	
					ТекущиеДанные.ЕдиницаИзмерения = НоменклатураЕдиницаИзмерения(ТекущиеДанные.Номенклатура);	
					ТекущиеДанные.Цена = ПолучитьЦенуНоменклатуры(ТекущиеДанные.Номенклатура);
					ТекущиеДанные.СтавкаНДС = ПолучитьСтавкуНДС(ТекущиеДанные.Номенклатура);
				КонецЕсли;
				ТекущиеДанные.Сумма = Количество * ТекущиеДанные.Цена;
				ТекущиеДанные.СуммаНДС = ЦенообразованиеКлиентСервер.РассчитатьСуммуНДС(ТекущиеДанные.Сумма, ТекущиеДанные.СтавкаНДС, Истина);
				ТекущиеДанные.СуммаСНДС = ТекущиеДанные.Сумма + ТекущиеДанные.СуммаНДС; 
				
				Если Не ЗначениеЗаполнено(ТекущиеДанные.Организация) И ЗначениеЗаполнено(Объект.ДокументПродажи) Тогда
					ЗаполнитьЗначенияСвойств(ТекущиеДанные,ПолучитьШапкуДокументаПродажи());
				КонецЕсли;
			КонецЕсли;
		Иначе
			Если ТекущиеДанные.Номенклатура = УслугаРазгрузки Тогда
				ОбщегоНазначенияКлиент.СообщитьПользователю("По этому товару указать недостачу невозможно!");
				ТекущиеДанные.КоличествоНедостачи = 0;
			ИначеЕсли Не ЗначениеЗаполнено(ТекущиеДанные.Номенклатура) Тогда
				ОбщегоНазначенияКлиент.СообщитьПользователю("Товар не указан, поэтому указать недостачу невозможно!");
				ТекущиеДанные.КоличествоНедостачи = 0;
			Иначе
				ТекущиеДанные.Количество = -ТекущиеДанные.КоличествоНедостачи;
				ТекущиеДанные.Сумма = ТекущиеДанные.Количество;
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

