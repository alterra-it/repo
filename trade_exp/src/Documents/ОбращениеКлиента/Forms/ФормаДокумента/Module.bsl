&НаКлиенте
Процедура ДобавитьУслугуРазгрузки(Команда)      
	Если Не ЗначениеЗаполнено(Объект.ТоварыДляДовоза.НайтиСтроки(Новый Структура("Номенклатура", УслугаРазгрузки))) Тогда 
		Если ЗначениеЗаполнено(Объект.ТоварыДляДовоза) Тогда 
			НоваяСтрока = Объект.ТоварыДляДовоза.Добавить();
			НоваяСтрока.Номенклатура = УслугаРазгрузки;
			НоваяСтрока.ЕдиницаИзмерения = НоменклатураЕдиницаИзмерения(УслугаРазгрузки);
			НоваяСтрока.Цена = 1;                 
						
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Объект.ТоварыДляДовоза[0], "Организация, Подразделение, Склад, Контрагент, Партнер");
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю("Сначала необходимо добавить в список товары!");
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиент.СообщитьПользователю("Услуга уже в списке!");
	КонецЕсли;
КонецПроцедуры   

&НаСервереБезКонтекста
