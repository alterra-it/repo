Функция ПолучитьШапкуДокументаПродажи()
	
	ДокПродажи = Объект.ДокументПродажи;
	
	Шапка = Новый Структура("Организация,Подразделение,Партнер,Контрагент",,,,);	
	ЗаполнитьЗначенияСвойств(Шапка,ДокПродажи);
	
	Возврат Шапка;	   
	
