&НаСервере
Процедура ЗаполнитьПоЗаказуНаДовоз()
	ЗаказНаДовоз = Объект.ЗаказНаДовоз;
	Объект.ПодразделениеОтгрузкиДовоза = ЗаказНаДовоз.Подразделение;
	Объект.ТелефонКлиентаНаВыгрузкеДовоза = ЗаказНаДовоз.ТелефонКлиентаНаВыгрузке;
	Объект.АдресДоставкиДовоза = ЗаказНаДовоз.АдресДоставки;
	ДокументОбращения = Объект.Ссылка.ПолучитьОбъект();
	Если ЗаказНаДовоз <> Документы.ЗаказНаДоставкуКлиенту.ПустаяСсылка() Тогда 
		СтрукутраВодительПеревозчик = ДокументОбращения.ПолучитьВодителя(ЗаказНаДовоз);
		Если ЗначениеЗаполнено(СтрукутраВодительПеревозчик) Тогда
			Объект.ВодительДовоза = СтрукутраВодительПеревозчик.Водитель;
			Объект.ПеревозчикДовоза = СтрукутраВодительПеревозчик.Перевозчик;
		КонецЕсли;
	Иначе
		Объект.ВодительДовоза = Неопределено;
		Объект.ПеревозчикДовоза = Неопределено;
	КонецЕсли;
КонецПроцедуры


