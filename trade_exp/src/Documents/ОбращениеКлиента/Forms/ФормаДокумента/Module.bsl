&НаКлиенте
Процедура ОбновитьИнформациюОКоличестве()
	ТаблицаТоваров = Объект.ТоварыДляДовоза;
	Если ТаблицаТоваров.Количество()>0 Тогда 
		Для Каждого Строка Из ТаблицаТоваров Цикл
			Если ЗначениеЗаполнено(Строка.Количество)
				И Не ЗначениеЗаполнено(Строка.КоличествоНедостачи) 
				И Не ЗначениеЗаполнено(Строка.КоличествоИзлишка) Тогда
				Если Строка.Количество<0 Тогда
					Строка.КоличествоНедостачи = -Строка.Количество;
					
				ИначеЕсли Строка.Количество>0 Тогда
					Строка.КоличествоИзлишка = Строка.Количество;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры // ОбновитьИнформациюОКоличестве()

