&НаСервере
Функция ПолучитьСвязанныеСДокументомЗаказыНаДоставку()	
	СписокОснований = Новый Массив;
	Если ЗначениеЗаполнено(Объект.Основание) Тогда
		СписокОснований.Добавить(Объект.Основание);
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.ДокументПродажи) Тогда
		СписокОснований.Добавить(Объект.ДокументПродажи);
	КонецЕсли;
	Если СписокОснований.Количество()=0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	ДоступныеЗаказыНаДоставку = Новый СписокЗначений;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ  различные
		|	ЗаказНаДоставкуКлиентуОснования.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаказНаДоставкуКлиенту.Основания КАК ЗаказНаДоставкуКлиентуОснования
		|ГДЕ
		|	ЗаказНаДоставкуКлиентуОснования.Документ В(&СписокОснований)";
	Запрос.УстановитьПараметр("СписокОснований", СписокОснований);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ДоступныеЗаказыНаДоставку.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	Возврат ДоступныеЗаказыНаДоставку;
КонецФункции // ПолучитьСвязанныеСДокументомЗаказыНаДоставку()


