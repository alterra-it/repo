&НаСервере
Процедура ЗаполнитьТоварыДляДовоза(МассивТоваров)
	Если ЗначениеЗаполнено(Объект.ДокументПродажи) Тогда
		ТЗ = Документы.ОбращениеКлиента.ПолучитьТоварыДляДовоза(Объект.ДокументПродажи,МассивТоваров);
		Если ЗначениеЗаполнено(ТЗ) Тогда
			Объект_ = РеквизитФормыВЗначение("Объект");
			Объект_.ТоварыДляДовоза.Загрузить(ТЗ);
			ЗначениеВРеквизитФормы(Объект_, "Объект");
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНаОснованииОбращения(Команда)     
	
	Если Объект.Ссылка.Пустая() ИЛИ ЭтаФорма.Модифицированность Тогда  
		ОбщегоНазначенияКлиент.СообщитьПользователю("Выполнение действия возможно только после записи данных!");
		Возврат;
	ИначеЕсли ЗначениеЗаполнено(Объект.ТелефонКлиентаНаВыгрузке) И 
		СтрДлина(АльтерраОбщегоНазначения.ПолчитьТелефонБезКода(Объект.ТелефонКлиентаНаВыгрузке)) <> 10 Тогда
		
		ОбщегоНазначенияКлиент.СообщитьПользователю("Неверно заполнен 'Телефон клиента на выгрузке'");
		Возврат;
	ИначеЕсли Не ПроверкаПоДопРеализации(Объект.ДополнительнаяРеализация, УслугаРазгрузки) И
		(Не ЗначениеЗаполнено(Объект.ТоварыДляДовоза) ИЛИ 
		Объект.ТоварыДляДовоза.Количество() = Объект.ТоварыДляДовоза.НайтиСтроки(Новый Структура("Номенклатура", УслугаРазгрузки)).Количество()) Тогда	
			
		ОбщегоНазначенияКлиент.СообщитьПользователю("В списке нет товаров!");
		Возврат;
	КонецЕсли;	   
	
	ИмяДокумента = "ЗаказНаДоставкуКлиенту";
	ФормаДок = ПолучитьФорму("Документ." +  ИмяДокумента + ".ФормаОбъекта");
	
	//Далее мы получаем объект только, что созданной формы и помещаем её в переменную
	//В объекте содержатся все реквизиты (элементы) формы
	ДанныеФормы = ФормаДок.Объект;
	
	//Мы помещаем объект формы в переменную,
	//так как должны передать её в процедуру на сервере,
	//где нельзя изменять объект формы, зато можно править переменную содержащую его
	СоздатьНовыйДокумент(ИмяДокумента, ДанныеФормы);
	
	//После выполнения процедуры на сервере мы получаем изменную переменную ДанныеФормы,
	//которую необходимо передать в уже созданную нами форму
	КопироватьДанныеФормы(ДанныеФормы, ФормаДок.Объект);
	 
	//Открываем результат выполнения обработки
	ФормаДок.Открыть(); 
	
	//Блокируем кнопку 
	Элементы.СоздатьНаОснованииОбращения.Доступность = Ложь;
	
КонецПроцедуры   

&НаСервереБезКонтекста
Функция ПроверкаПоДопРеализации(ДопРеализация, УслугаРазгрузки)  
	Возврат
		ЗначениеЗаполнено(ДопРеализация) И
		ЗначениеЗаполнено(ДопРеализация.Товары) И
		ДопРеализация.Товары.Количество() <> ДопРеализация.Товары.НайтиСтроки(Новый Структура("Номенклатура", УслугаРазгрузки)).Количество();
КонецФункции

&НаСервере
Процедура СоздатьНовыйДокумент(ИмяДокумента, НовыйОбъект)
	Документы[ИмяДокумента].ЗаполнитьДанныеПоОснованию(Объект.Ссылка, НовыйОбъект);
