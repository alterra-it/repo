
#Область РаботаСБитрикс
&НаКлиенте
Процедура ПередатьВБитрикс24(Команда)
	Если Модифицированность Тогда
		Сообщить("Документ необходимо записать, прежде чем отправлять в битрикс! Убедитесь, что все данные заполнены корректно.");
	Иначе   
		Попытка
			ПередатьВБитриксСервер();
			НомерОбращенияБитрикс = БылоОтправленоВБитрикс();	
			Элементы.ФормаПередатьВБитрикс24.Доступность = НомерОбращенияБитрикс=""; 
			
			ПроверкаДоступностиСоздатьНаОснованииОбращения();
			
			ПередатьВБитрикс24СкладуНаСервере();
		Исключение
       	КонецПопытки;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПередатьВБитриксСервер()
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	Документы.ОбращениеКлиента.ПередатьВБитриксСервер(ДокументОбъект);  
	ЗначениеВРеквизитФормы(ДокументОбъект,"Объект");
КонецПроцедуры 

&НаСервере
Функция БылоОтправленоВБитрикс()
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Альтерра_ИдентификаторыОбъектовБ24.Идентификатор КАК Идентификатор
		|ИЗ
		|	РегистрСведений.Альтерра_ИдентификаторыОбъектовБ24 КАК Альтерра_ИдентификаторыОбъектовБ24
		|ГДЕ
		|	Альтерра_ИдентификаторыОбъектовБ24.Объект = &Объект";
	Запрос.УстановитьПараметр("Объект", Объект.Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Идентификатор;
	Иначе
		Возврат "";
	КонецЕсли;
КонецФункции

&НаКлиенте
Процедура ПередатьВБитрикс24Складу(Команда)
	Если Модифицированность Тогда
		Сообщить("Документ необходимо записать, прежде чем отправлять в битрикс! Убедитесь, что все данные заполнены корректно.");
		Возврат;
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(Объект.ДокументПродажи) Тогда
		Сообщить("Не выбран документ продажи");
		Возврат;
	КонецЕсли;
	
	Если Объект.ТоварыДляДовоза.Количество() = 0 Тогда		
		Сообщить("Не добавлен товар на закладке ""Расхождения у клиента""");
		Возврат;
	КонецЕсли;    
	
	Если Элементы.ФормаПередатьВБитрикс24.Доступность Тогда
		ПередатьВБитрикс24СкладуНаСервере() 
	Иначе     
		ПоказатьВопрос(Новый ОписаниеОповещения("ПослеПодтвержденияОтправкиВБитрикс", ЭтотОбъект),
        "Отправить сообщение складу о расхождениях у клиента?", РежимДиалогаВопрос.ДаНет, 0, КодВозвратаДиалога.Да,
        "Отправка в Битрикс"); 
	КонецЕсли;
КонецПроцедуры    

&НаКлиенте
Процедура ПослеПодтвержденияОтправкиВБитрикс(Результат, Параметры) Экспорт
    Если Результат = КодВозвратаДиалога.Да Тогда
        ПередатьВБитрикс24СкладуНаСервере() 
    КонецЕсли;	
КонецПроцедуры

&НаСервере
Процедура ПередатьВБитрикс24СкладуНаСервере() 
	
	Если ЗначениеЗаполнено(Объект.ДокументПродажи) И Объект.ТоварыДляДовоза.Количество() > 0 Тогда   
		
		НаименованиеСклада = Строка(Объект.ДокументПродажи.Склад);
		НазваниеЧата = "Группа: """ + НаименованиеСклада + """";
	
		ТекстСообщения = ?(ЗначениеЗаполнено(Объект.ВидОбращения), "Вид обращения: " + Объект.ВидОбращения + Символы.ПС, "")
			+ "Номер Б24: " + НомерОбращенияБитрикс + " Дата обращения: " + Строка(Объект.Дата) + Символы.ПС
			+ ?(ЗначениеЗаполнено(Объект.Статус), "Статус: " + Объект.Статус + Символы.ПС, "")
			+ "---------------------------------------------------------------------------------" + Символы.ПС
			+ "Автор отправки: " + ПараметрыСеанса.ТекущийПользователь + Символы.ПС
			+ "Дата отправки: " + Строка(ТекущаяДата()) + Символы.ПС    
			+ Символы.ПС + ?(ЗначениеЗаполнено(Объект.Подразделение), "Подразделение: " + Объект.Подразделение + Символы.ПС, "")
			+ ?(ЗначениеЗаполнено(Объект.ДокументПродажи), "Документ продажи: " + Объект.ДокументПродажи + Символы.ПС, "")
			+ ?(ЗначениеЗаполнено(Объект.Клиент), "ФИО клиента: " + Объект.Клиент + Символы.ПС, "")
			+ ?(ЗначениеЗаполнено(Объект.Клиент), "Код клиента: " + Объект.Клиент.Код + Символы.ПС, "") 
			+ ?(ЗначениеЗаполнено(Объект.ВходящийНомерТелефона), "Входящий номер телефона: " + Объект.ВходящийНомерТелефона + Символы.ПС, "") 
			+ ?(ЗначениеЗаполнено(Объект.ТелефонКлиентаНаВыгрузке), "Телефон клиента на выгрузке: " + Объект.ТелефонКлиентаНаВыгрузке + Символы.ПС, "") 
			+ ?(ЗначениеЗаполнено(Объект.Содержание), Символы.ПС + "Содержание: " + Символы.ПС + Объект.Содержание + Символы.ПС, "")
			+ Символы.ПС;	
			
			
			Счетчик = 1;
			СписокТоваров = "";	
			Для Каждого Товар Из Объект.ТоварыДляДовоза Цикл    
				Если Товар.Количество < 0 Тогда
					СписокТоваров = СписокТоваров + Строка(Счетчик) + ". " + Товар.Номенклатура + Символы.ПС 
						+ ?(ЗначениеЗаполнено(Товар.Количество), Символы.Таб +  " кол-во: " + Строка(Товар.Количество), "")
						+ ?(ЗначениеЗаполнено(Товар.Сумма), " сумма: " + Строка(Товар.Сумма), "") + Символы.ПС; 
					Счетчик = Счетчик + 1;
				КонецЕсли;
			КонецЦикла;                           
			
			Если Счетчик > 1 Тогда
				ТекстСообщения = ТекстСообщения + "У клиента НЕДОСТАЧА, необходимо ОТГРУЗИТЬ СО СКЛАДА:" + Символы.ПС
					+ "----------------------------------------------------" + Символы.ПС 
					+ СписокТоваров + Символы.ПС; 
			КонецЕсли;
				
			Счетчик = 1;
			СписокТоваров = "";	
			Для Каждого Товар Из Объект.ТоварыДляДовоза Цикл    
				Если Товар.Количество > 0 Тогда
					СписокТоваров = СписокТоваров + Строка(Счетчик) + ". " + Товар.Номенклатура + Символы.ПС 
						+ ?(ЗначениеЗаполнено(Товар.Количество), Символы.Таб +  " кол-во: " + Строка(Товар.Количество), "")
						+ ?(ЗначениеЗаполнено(Товар.Сумма), " сумма: " + Строка(Товар.Сумма), "") + Символы.ПС; 
					Счетчик = Счетчик + 1;
				КонецЕсли;
			КонецЦикла;                           
			
			Если Счетчик > 1 Тогда
				ТекстСообщения = ТекстСообщения + "У клиента ИЗЛИШЕК, необходимо ПРИНЯТЬ НА СКЛАД:" + Символы.ПС
					+ "----------------------------------------------------" + Символы.ПС 
					+ СписокТоваров + Символы.ПС;
			КонецЕсли;
			
		АльтерраВзаимодействиеСБитрикс24.ОтправитьВЧат(НазваниеЧата, ТекстСообщения); 
	КонецЕсли;
КонецПроцедуры	

#КонецОбласти

&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ОбновитьИнформациюОФайлах();
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды  
	
	ОбновитьИнформациюОКоличестве();
	
	Если Параметры.Ключ.Пустая() Тогда
		Если ПроверкаДокументаОбращения() Тогда
			ПоказатьОповещениеДубль();
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПроверкаДокументаОбращения()
	
	ВыбДок = Объект.Основание;
	
	Если ТипЗнч(ВыбДок) <> Неопределено Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОбращениеКлиента.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|ГДЕ
		|	ОбращениеКлиента.Основание = &Основание";

		Запрос.УстановитьПараметр("Основание", ВыбДок); 
	
		Возврат НЕ Запрос.Выполнить().Пустой();
		
	КонецЕсли;
	
	Возврат Ложь;		
	
КонецФункции

&НаКлиенте
Процедура ПоказатьОповещениеДубль()
	
	ОбработатьОтветНет= Новый ОписаниеОповещения("ОбработатьОтветНет", ЭтаФорма);
	ПоказатьВопрос(ОбработатьОтветНет, "По данному документу продажи уже есть обращение. Продолжить?",
	РежимДиалогаВопрос.ДаНет, , КодВозвратаДиалога.Нет, "Оповещение", КодВозвратаДиалога.Нет);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОтветНет(Результат, ДопПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Нет Тогда
		ЭтаФорма.Закрыть();
	КонецЕсли;
КонецПроцедуры


#Область РаботаСФайлами

&НаСервере
Функция ПолучитьДатуИзмененияФайла(ФайлСсылка)
	Возврат МестноеВремя(ФайлСсылка.ПолучитьОбъект().ДатаМодификацииУниверсальная);
КонецФункции // ПолучитьДатуИзмененияФвйла()

&НаКлиенте
Процедура ОбновитьИнформациюОФайлах(НомерСтроки=Неопределено, ФайлСсылка=Неопределено)
	ТаблицаФайлов = Объект.ПрисоединенныеФайлы;
	Если ТаблицаФайлов.Количество()>0 Тогда 
		//Если ФайлСсылка=Неопределено Тогда
		Для НомерСтр=0 по ТаблицаФайлов.Количество()-1 Цикл
			Файл = ТаблицаФайлов[НомерСтр].Файл;
			Если ЗначениеЗаполнено(Файл) Тогда 
				ТаблицаФайлов[НомерСтр].Изменено = ПолучитьДатуИзмененияФайла(Файл);
			КонецЕсли;
		КонецЦикла;
		//Иначе
		//	НомерСтроки = ?(НомерСтроки=Неопределено, ТаблицаФайлов.Количество(), НомерСтроки);
		//	
		//КонецЕсли;
	КонецЕсли;
КонецПроцедуры // ОбновитьИнформациюОФвйлах()

&НаКлиенте
Процедура ПрисоединенныеФайлыПриИзменении(Элемент)
КонецПроцедуры

&НаКлиенте
Процедура ПрисоединенныеФайлыПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	ОбновитьИнформациюОФайлах();
КонецПроцедуры

#КонецОбласти

#Область Доставка

&НаКлиенте
Процедура ЗаказНаДоставкуПриИзменении(Элемент)
	Если ЗначениеЗаполнено(Объект.ЗаказНаДоставку) Тогда
		ЗаполнитьНаОснованииЗаказаНаДоставкуСервер();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаОснованииЗаказаНаДоставкуСервер()
	ЗаказНаДоставку = Объект.ЗаказНаДоставку;
	Объект.ДокументПродажи = ЗаказНаДоставку.Основания[0].Документ;
	Объект.ПодразделениеОтгрузки = ЗаказНаДоставку.Подразделение;
	Объект.ТелефонКлиентаНаВыгрузке = ЗаказНаДоставку.ТелефонКлиентаНаВыгрузке;
	Объект.АдресДоставки = ЗаказНаДоставку.АдресДоставки;
	ДокументОбращения = РеквизитФормыВЗначение("Объект");
	СтрукутраВодительПеревозчик = ДокументОбращения.ПолучитьВодителя(ЗаказНаДоставку);
	Если ЗначениеЗаполнено(СтрукутраВодительПеревозчик) Тогда
		Объект.Водитель = СтрукутраВодительПеревозчик.Водитель;
		Объект.Перевозчик = СтрукутраВодительПеревозчик.Перевозчик;
	КонецЕсли;
КонецПроцедуры // ЗаполнитьНаОснованииЗаказаНаДоставкуСервер()

#КонецОбласти

#Область КонтактнаяИнформация

&НаКлиенте
Процедура ОткрытьФормуВыбораКонтактнойИнформации(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	// Откроем диалог редактирования КИ
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Представление",           Элемент.ТекстРедактирования);
	ПараметрыОткрытия.Вставить("ВидКонтактнойИнформации", ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.МобильныйТелефонКонтактногоЛица"));
	СтруктураПолейТелефона = Новый Структура;
	СтруктураПолейТелефона.Вставить("Number", Объект.ВходящийНомерТелефона);
	ЗначениеПолей = ПолучитьСтруктуруВJSON(СтруктураПолейТелефона);
	ПараметрыОткрытия.Вставить("Значение", ЗначениеПолей);
	Оповещение = Новый ОписаниеОповещения("ОткрытьФормуВыбораКонтактнойИнформацииЗавершение", ЭтотОбъект);
	
	УправлениеКонтактнойИнформациейКлиент.ОткрытьФормуКонтактнойИнформации(ПараметрыОткрытия, ЭтотОбъект, Оповещение);
КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруВJSON(СтруктураПолейТелефона)
	Возврат УправлениеКонтактнойИнформациейСлужебный.СтруктураВСтрокуJSON(СтруктураПолейТелефона);
КонецФункции // ПолучитьСтруктуруВJSON()

&НаКлиенте
Процедура ОткрытьФормуВыбораКонтактнойИнформацииЗавершение(Результат, ДополнительныеПараметры) Экспорт
	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		Модифицированность = Истина;
		
		Объект.ВходящийНомерТелефона = Результат.Представление;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВходящийНомерТелефонаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	ОткрытьФормуВыбораКонтактнойИнформации(Элемент, ДанныеВыбора, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ВидОбращенияПриИзменении(Элемент)
	 ЭтоЖалоба = (Объект.ВидОбращения = ПредопределенноеЗначение("Перечисление.ВидыОбращений.Жалоба"));
	 ПерезаполнитьЗначениеВидаЖалобы(ЭтоЖалоба);
	 Элементы.ВидЖалобы.Видимость = ЭтоЖалоба;
КонецПроцедуры

&НаСервере
Процедура ПерезаполнитьЗначениеВидаЖалобы(ЭтоЖалоба)
	Если ЭтоЖалоба Тогда
		Объект.ВидЖалобы = Справочники.ВидыОбращенийКлиентов.ПустаяСсылка(); 
	Иначе
		Объект.ВидЖалобы = Справочники.ВидыОбращенийКлиентов.НайтиПоКоду("000000004"); //прочее
	КонецЕсли;
КонецПроцедуры // ПерезаполнитьЗначениеВидаЖалобы()

&НаСервере
Процедура ВидимостьДоступностьИнициализация()
	НомерОбращенияБитрикс = БылоОтправленоВБитрикс();	
	Элементы.ФормаПередатьВБитрикс24.Доступность = НомерОбращенияБитрикс="";
    
    РазрешеноПравитьРолью = РольДоступна("ПолныеПрава") ИЛИ РольДоступна("РедактироватьОбращениеПослеОтправки");
    Элементы.НадписьНельзяРедактировать.Видимость = (НЕ ЗначениеЗаполнено(Объект.Ссылка) И НЕ РазрешеноПравитьРолью) 
        ИЛИ (ЗначениеЗаполнено(Объект.Ссылка) И НЕ РазрешеноПравитьРолью И НомерОбращенияБитрикс="");
        
    //ЭтаФорма.Элементы.ФормаКоманднаяПанель.Доступность = НЕ ЗначениеЗаполнено(Объект.Ссылка) 
    //    ИЛИ НомерОбращенияБитрикс<>"" И РазрешеноПравитьРолью ИЛИ НомерОбращенияБитрикс="";  
	
	Если ЗначениеЗаполнено(Объект.Ссылка) И НомерОбращенияБитрикс<>"" И НЕ РазрешеноПравитьРолью Тогда
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы.ГруппаСвязанныеДокументы.ПодчиненныеЭлементы Цикл 
			ТекущийЭлемент.Доступность = Ложь;
		КонецЦикла;  
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы.ГруппаБлокРезультата.ПодчиненныеЭлементы Цикл 
			ТекущийЭлемент.Доступность = Ложь;
		КонецЦикла;
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы.ГруппаПрикрепленныеФайлы.ПодчиненныеЭлементы Цикл 
			ТекущийЭлемент.Доступность = Ложь;
		КонецЦикла;
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы.Группа1.ПодчиненныеЭлементы Цикл 
			ТекущийЭлемент.Доступность = Ложь;
		КонецЦикла;
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы.ГруппаОсновное.ПодчиненныеЭлементы Цикл  
			Если ТекущийЭлемент.Имя <> "ДополнительнаяРеализация" Тогда
				ТекущийЭлемент.Доступность = Ложь;   
			КонецЕсли;
		КонецЦикла;   
		Для Каждого ТекущийЭлемент Из ЭтаФорма.Элементы.ГруппаОбщаяИнформация.ПодчиненныеЭлементы Цикл 
			ТекущийЭлемент.Доступность = Ложь;
		КонецЦикла;
	КонецЕсли;
	
	Элементы.ОбменДовоз.Доступность = ЗначениеЗаполнено(Объект.ДокументПродажи);
	ПроверкаДоступностиСоздатьНаОснованииОбращения();

	
КонецПроцедуры


