//Функция ПолучитьПараметрыЗапроса(ОбщиеНастройки)
Функция ПолучитьПараметрыЗапроса(Объект)
	////Массив с идентификаторами
	////1 ИдентификаторыВидовОбращений
	//ИдентификаторыВидовОбращений = ИдентификаторыЗначенийРеквизитов[0];
	////2 ИдентификаторыТиповОбращений
	//ИдентификаторыТиповОбращений = ИдентификаторыЗначенийРеквизитов[1];
	////3 ИдентификаторыМаркетинговыхМероприятий
	//ИдентификаторыМаркетинговыхМероприятий = ИдентификаторыЗначенийРеквизитов[2];
	////4  ИдентификаторыИсточниковОбращений
	//ИдентификаторыИсточниковОбращений = ИдентификаторыЗначенийРеквизитов[3];
	////5  ИдентификаторыВидовОбращенийКлиентов
	//ИдентификаторыВидовОбращенийКлиентов = ИдентификаторыЗначенийРеквизитов[4];
	////6  ИдентификаторыСтатусов
	//ИдентификаторыСтатусов = ИдентификаторыЗначенийРеквизитов[5];
	
	МассивОбъектовДляИдентификации = Новый Массив;
	МассивОбъектовДляИдентификации.Добавить(Объект.ВидОбращения);
	Если ЗначениеЗаполнено(Объект.Статус) Тогда
		МассивОбъектовДляИдентификации.Добавить(Объект.Статус);
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.МаркетинговоеМероприятие) Тогда
		МассивОбъектовДляИдентификации.Добавить(Объект.МаркетинговоеМероприятие);
	КонецЕсли;
	МассивОбъектовДляИдентификации.Добавить(Объект.ИсточникОбращения);
	МассивОбъектовДляИдентификации.Добавить(Объект.ТипОбращения);
	МассивОбъектовДляИдентификации.Добавить(Объект.ВидЖалобы);
	МассивОбъектовДляИдентификации.Добавить(Объект.Подразделение);
	
	ТаблицаИдентификаторовБ24 = ПолучитьТаблицуИдентификаторов(МассивОбъектовДляИдентификации);
	Если ТипЗнч(ТаблицаИдентификаторовБ24) = Тип("Строка") Тогда
		Сообщить(ТаблицаИдентификаторовБ24);
		Возврат Неопределено;
	КонецЕсли;
	
	ОтборПоиска = Новый Структура;
	ОтборПоиска.Вставить("Объект");

	Поля = Новый Структура;
	НаименованиеЗаявки = Строка(Объект.ВидОбращения);
	Поля.Вставить("Name", НаименованиеЗаявки);
	//ТекущийПользовательБитрикс = ПолучитьИдПользователяБитрикс(ПараметрыСеанса.ТекущийПользователь,ОбщиеНастройки);
	
	Если Объект.ИсточникОбращения = Справочники.ИсточникиОбращенийКлиентов.НайтиПоНаименованию("Мобильное приложение") Тогда 
		ТекущийПользовательБитрикс = 1;
	Иначе
		ТекущийПользовательБитрикс = ПолучитьИдПользователяБитрикс(ПараметрыСеанса.ТекущийПользователь);
	КонецЕсли;
	
	Поля.Вставить("CREATED_BY", ТекущийПользовательБитрикс); 
	Поля.Вставить("Active_from", Строка(ТекущаяДата()));
	Поля.Вставить("DETAIL_TEXT", Объект.Содержание);
	
	ОтборПоиска.Объект = Объект.ВидОбращения;
	СтрокиВидовОбращений = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска);
	Если СтрокиВидовОбращений.Количество()>0 Тогда
		ВидОбращения = СтрокиВидовОбращений[0].Идентификатор;
		Поля.Вставить("Property_338", ВидОбращения);//вид обращения
	Иначе
		Сообщить("Для обязательного поля в значении " + Строка(Объект.ВидОбращения) + " не задан идентификатор Битрикс");
		Возврат Неопределено;
	КонецЕсли;
	ОтборПоиска.Объект = Объект.Статус;
	СтрокиСтатус = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска);
	Если СтрокиСтатус <> Неопределено И СтрокиСтатус.Количество() > 0 Тогда 
		Статус = СтрокиСтатус[0].Идентификатор;
		Поля.Вставить("Property_330", Статус);//статус
	КонецЕсли;
	
	Поля.Вставить("Property_1795", Строка(Объект.МаркетинговоеМероприятие));//маркетинговое мероприятие
	
	Поля.Вставить("Property_1436", Строка(Объект.Клиент));//фио клиента
	Поля.Вставить("Property_1435", Объект.Клиент.Код);//Клиент код
	
	ОтборПоиска.Объект = Объект.ИсточникОбращения;
	СтрокиИсточникиОбращения = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска);
	Если СтрокиИсточникиОбращения.Количество() Тогда
		ИсточникОбращения = СтрокиИсточникиОбращения[0].Идентификатор; 
		Поля.Вставить("Property_329", ИсточникОбращения);//Источник жалоб
	КонецЕсли;
	
	Поля.Вставить("Property_326", Объект.ДатаПроблемнойСитуации);//Дата проблемной ситуации
	
	//приложенные файлы
	ПрисоединенныеФайлы = Объект.ПрисоединенныеФайлы;
	МассивФайлов = ПрисоединенныеФайлы.Выгрузить().ВыгрузитьКолонку("Файл");
	Если ПрисоединенныеФайлы.Количество()>0 Тогда
		НастройкиАльтерра = Справочники.Альтерра_НастройкиОбменаБитрикс.НайтиПоКоду("Обращения_клиентов");
		МассивИДФайлов = АльтерраВзаимодействиеСБитрикс24.ЗагрузитьФайлыВБитрикс(НастройкиАльтерра.ИдПапкиСФайлами, МассивФайлов, ТекущийПользовательБитрикс, Строка(Объект.Ссылка.УникальныйИдентификатор()));
		Поля.Вставить("Property_414", МассивИДФайлов);//Приложенный файл
	КонецЕсли;
	
	ОтборПоиска.Объект = Объект.ТипОбращения;
	ТипОбращения =  ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска)[0].Идентификатор;
	Поля.Вставить("Property_711", ТипОбращения);//Тип жалобы
	
	ОтборПоиска.Объект = Объект.ВидЖалобы;
	ВидЖалобы = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска)[0].Идентификатор;
	Поля.Вставить("Property_712", ВидЖалобы);//Жалоба на
	
	//В новом алгоритме ответственный определяется автоматически, поэтому передаем ТекущийПользовательБитрикс
	//Пока оставим заполнение, чтобы можно было откатить на старый вариант 
	Поля.Вставить("Property_327", ТекущийПользовательБитрикс);//Ответственный за решение жалобы
	//Поля.Вставить("Property_327", ПолучитьИдПользователяБитрикс(Объект.ОтветственныйЗаРешение));//Ответственный за решение жалобы
		
	ОтборПоиска.Объект = Объект.Подразделение;
	СтрокиПодразделения = ТаблицаИдентификаторовБ24.НайтиСтроки(ОтборПоиска);
	Если СтрокиПодразделения<>Неопределено И СтрокиПодразделения.Количество()>0 Тогда
		Подразделение  = СтрокиПодразделения[0].Идентификатор;
		Поля.Вставить("Property_714", Подразделение);
	Иначе
		Сообщить("Для обязательного поля в значении " + Строка(Объект.Подразделение) + " не задан идентификатор Битрикс");
		Возврат Неопределено;
	КонецЕсли;
	
	Поля.Вставить("Property_1778", Строка(Объект.ВходящийНомерТелефона));
	Поля.Вставить("Property_1779", Объект.ИнициаторОбращения);
	//
	ДокументПродажи = ВернутьДокументПродажиИлиЗаказКлиента(Объект.Ссылка);
	Поля.Вставить("Property_1780", Строка(ДокументПродажи));
	
	//Если документ есть, то нужен менеджер 
	Если ДокументПродажи <> Неопределено Тогда
		МенеджерДокумента = ДокументПродажи.Менеджер;
		Попытка	
			Поля.Вставить("Property_3470", ПолучитьИдПользователяБитрикс(МенеджерДокумента));               
		Исключение
			Сообщить("Для пользователя " + Строка(МенеджерДокумента) + " не найден идентификатор Битрикс");	
		КонецПопытки;
   	КонецЕсли;   
	///Отдел жалоб                        
	Если Объект.ОтделОбращения = Справочники.ПолучателиОбращенийКлиентов.ПустаяСсылка() Тогда                                         
		Сообщить("Поле ""Отдел обращения"" должно быть заполнено");
		Возврат Неопределено;
	Иначе               
	    Поля.Вставить("Property_3467", Строка(Объект.ОтделОбращения));
	КонецЕсли;	
		
	Поля.Вставить("Property_1781", Строка(Объект.ЗаказНаДоставку));
	//Поля.Вставить("Property_1782", Информация по доставке   Объект.
	Поля.Вставить("Property_1783", Строка(Объект.Водитель));
	Поля.Вставить("Property_3002", Строка(Объект.Перевозчик));
	Если Объект.ВиноватВодитель Тогда
		Поля.Вставить("Property_3003", "23300");      
		Поля.Вставить("Property_3004", Объект.СуммаУдержанияСВодителя);
	Иначе
		Поля.Вставить("Property_3003", "23301");
		Поля.Вставить("Property_3004", 0);
	КонецЕсли;
	Поля.Вставить("Property_1784", Строка(Объект.ПодразделениеОтгрузки));
	Поля.Вставить("Property_1785", Объект.АдресДоставки);
	Поля.Вставить("Property_1786", Объект.ТелефонКлиентаНаВыгрузке);
	Поля.Вставить("Property_1787", Строка(ПолучитьГруппуПартнера(Объект.Клиент)));
	Поля.Вставить("Property_3464", Строка(Объект.РезультатКЦ));
	
	//параметры списка
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("IBLOCK_TYPE_ID", "lists_socnet");
	ПараметрыЗапроса.Вставить("IBLOCK_ID", "86");
	ПараметрыЗапроса.Вставить("ELEMENT_CODE", ПолучитьКодЭлемента());
	ПараметрыЗапроса.Вставить("FIELDS", Поля);
	
	Возврат ПараметрыЗапроса;
КонецФункции

Функция ВернутьДокументПродажиИлиЗаказКлиента(Ссылка)

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫБОР
		|		КОГДА ОбращениеКлиента.ДокументПродажи = НЕОПРЕДЕЛЕНО
		|			ТОГДА ВЫБОР
		|					КОГДА ТИПЗНАЧЕНИЯ(ОбращениеКлиента.Основание) = ТИП(Документ.ЗаказКлиента)
		|						ТОГДА ОбращениеКлиента.Основание
		|					ИНАЧЕ НЕОПРЕДЕЛЕНО
		|				КОНЕЦ
		|		ИНАЧЕ ОбращениеКлиента.ДокументПродажи
		|	КОНЕЦ КАК ДокументПродажиИлиЗаказКлиента
		|ИЗ
		|	Документ.ОбращениеКлиента КАК ОбращениеКлиента
		|ГДЕ
		|	ОбращениеКлиента.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ДокументПродажиИлиЗаказКлиента;
	КонецЕсли;
	
	Возврат "";

КонецФункции // ВернутьДокументПродажиИлиЗаказКлиента()


