Функция ПолучитьТаблицуИдентификаторов(МассивОбъектов)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Объект1С КАК Объект,
		|	Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Идентификатор КАК Идентификатор
		|ИЗ
		|	Справочник.Альтерра_НастройкиОбменаБитрикс.ЗначенияСписковДляОбъекта КАК Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта
		|ГДЕ
		|	Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Ссылка.Код = ""Обращения_клиентов""
		|	И Альтерра_НастройкиОбменаБитриксЗначенияСписковДляОбъекта.Объект1С В(&СписокОбъектов)";
	Запрос.УстановитьПараметр("СписокОбъектов", МассивОбъектов);
	РезультатЗапроса = Запрос.Выполнить();
	Таблица = РезультатЗапроса.Выгрузить();
	Если МассивОбъектов.Количество() > Таблица.Количество() Тогда
		СообщениеПользователю = "Для данных объектов не заданы идентификаторы в настройках синхронизации с Битрикс: ";
		МассивВыгруженных = Таблица.ВыгрузитьКолонку("Объект");
		Для каждого Стр из МассивОбъектов Цикл
			НайденныеПозиции = МассивВыгруженных.Найти(Стр);
			Если НайденныеПозиции=Неопределено Тогда
				СообщениеПользователю = СообщениеПользователю + Символы.ПС + Стр;
			КонецЕсли;
		КонецЦикла;
		Возврат СообщениеПользователю;
	Иначе
		Возврат Таблица;
	КонецЕсли;
КонецФункции
#КонецОбласти             

// Возвращает таблицы для движений, необходимые для проведения документа по регистрам учетных механизмов.
//
// Параметры:
//  Документ - ДокументСсылка - ссылка на документ, по которому необходимо получить данные
//  Регистры - Структура - список имен регистров, для которых необходимо получить таблицы
//  ДопПараметры - Структура - дополнительные параметры для получения данных, определяющие контекст проведения.
//
// Возвращаемое значение:
//  Структура - коллекция элементов:
//     * Таблица<ИмяРегистра> - ТаблицаЗначений - таблица данных для отражения в регистр.
//
Функция ДанныеДокументаДляПроведения(Документ, Регистры, ДопПараметры = Неопределено) Экспорт
	
	Если ДопПараметры = Неопределено Тогда
		ДопПараметры = ПроведениеДокументов.ДопПараметрыИнициализироватьДанныеДокументаДляПроведения();
	КонецЕсли;
	
	Запрос			= Новый Запрос;
	ТекстыЗапроса	= Новый СписокЗначений;
	
	Если ТипЗнч(Документ) = Тип("ДокументОбъект.ОбращениеКлиента") Тогда
		ДокументОбъект = Документ;
		ДокументСсылка = Документ.Ссылка;
	ИначеЕсли ТипЗнч(Документ) = Тип("ДокументСсылка.ОбращениеКлиента") Тогда
		ДокументОбъект = Документ.ПолучитьОбъект();
		ДокументСсылка = Документ;
	Иначе
		ДокументОбъект = Неопределено;
		ДокументСсылка = Неопределено;
	КонецЕсли;
	
	Если Не ДопПараметры.ПолучитьТекстыЗапроса Тогда
		////////////////////////////////////////////////////////////////////////////
		// Создадим запрос инициализации движений
		
		ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка);
		
		////////////////////////////////////////////////////////////////////////////
		// Сформируем текст запроса
		
		
		//++ НАЧАЛО ДОРАБОТКИ -->
		ТекстЗапросаТаблицаТоварыРасхожденияПоОбращениям(Запрос, ТекстыЗапроса, Регистры);	
		//-- КОНЕЦ ДОРАБОТКИ <--
	КонецЕсли;
	
	////////////////////////////////////////////////////////////////////////////
	// Получим таблицы для движений
	
	Возврат ПроведениеДокументов.ИнициализироватьДанныеДокументаДляПроведения(Запрос, ТекстыЗапроса, ДопПараметры);
	
КонецФункции


Процедура ЗаполнитьПараметрыИнициализации(Запрос, ДокументСсылка)
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);
		
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДанныеШапки.Дата КАК Период
	|ИЗ
	|	Документ.ОбращениеКлиента КАК ДанныеШапки
	|ГДЕ
	|	ДанныеШапки.Ссылка = &Ссылка";
	Реквизиты = Запрос.Выполнить().Выбрать();
	Реквизиты.Следующий();
	
	Запрос.УстановитьПараметр("Период",          	 Реквизиты.Период);
	
КонецПроцедуры

Функция ТекстЗапросаТаблицаТоварыРасхожденияПоОбращениям(Запрос, ТекстыЗапроса, Регистры)
	
	ИмяРегистра = "ТоварыРасхожденияПоОбращениям";
	
	Если НЕ ПроведениеДокументов.ТребуетсяТаблицаДляДвижений(ИмяРегистра, Регистры) Тогда
		Возврат "";
	КонецЕсли;
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	&Период КАК Период,
		|	ТаблицаТовары.Ссылка.ДокументПродажи КАК ДокументПродажи,
		|	ТаблицаТовары.Склад КАК Склад,
		|	ТаблицаТовары.Номенклатура КАК Номенклатура,
		|	ТаблицаТовары.Количество КАК Количество,
		|	ТаблицаТовары.Сумма КАК Сумма
		|ИЗ
		|	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ТаблицаТовары
		|ГДЕ
		|	ТаблицаТовары.Ссылка = &Ссылка";
	
	ТекстыЗапроса.Добавить(ТекстЗапроса, ИмяРегистра);
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ПолучитьОтветственногоЗаОтгрузку(Документ,Секция)

	Кладовщик = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	РасходныйОрдерНаТовары.Сотрудник КАК Сотрудник
		|ИЗ
		|	Документ.РасходныйОрдерНаТовары КАК РасходныйОрдерНаТовары
		|ГДЕ
		|	РасходныйОрдерНаТовары.Накладная = &Накладная
		|	И РасходныйОрдерНаТовары.Проведен
		|	И РасходныйОрдерНаТовары.РабочийУчасток = &РабочийУчасток";
	
	Запрос.УстановитьПараметр("РабочийУчасток", Секция);
	Запрос.УстановитьПараметр("Накладная", Документ);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Кладовщик = ВыборкаДетальныеЗаписи.Сотрудник;
	КонецЦикла;
	
	Возврат Кладовщик;
	
КонецФункции

#КонецЕсли
