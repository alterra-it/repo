			|ГДЕ
			|	Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Товар)
			|   И Товары.Номенклатура В (&МассивТоваров)
			|
			|СГРУППИРОВАТЬ ПО
			|	Товары.Организация,
			|	Товары.Подразделение,
			|	Товары.Склад,
			|	Товары.Контрагент,
			|	Товары.Партнер,
			|	Товары.Номенклатура,
			|	Товары.Характеристика,
			|	Товары.Назначение,
			|	Товары.ЕдиницаИзмерения,
			|	Товары.СтавкаНДС";
		
		Запрос.УстановитьПараметр("МассивСсылок", МассивСсылок);
		Запрос.УстановитьПараметр("МассивТоваров", МассивТоваров);
		Возврат Запрос.Выполнить().Выгрузить();
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Функция ПолучитьДанныеПоОснованию(Объект) Экспорт
	Если ЗначениеЗаполнено(Объект.ТоварыДляДовоза) Тогда
		Возврат Объект.ТоварыДляДовоза[0];  
	ИначеЕсли ЗначениеЗаполнено(Объект.ДополнительнаяРеализация) Тогда
		Возврат Объект.ДополнительнаяРеализация;
	КонецЕсли;      
	
	Возврат Новый Структура;
КонецФункции

Функция ПолучитьОрганизацию(ОбращениеКлиента) Экспорт 
	СтруктураЗаполнения = ПолучитьДанныеПоОснованию(ОбращениеКлиента); 
	
	Если ЗначениеЗаполнено(СтруктураЗаполнения) Тогда
		Возврат СтруктураЗаполнения.Организация;
	Иначе 
		Возврат Справочники.Организации.ПустаяСсылка();
	КонецЕсли;      
КонецФункции

Функция ПолучитьСклад(ОбращениеКлиента) Экспорт 
	СтруктураЗаполнения = ПолучитьДанныеПоОснованию(ОбращениеКлиента); 
	
	Если ЗначениеЗаполнено(СтруктураЗаполнения) Тогда
		Возврат СтруктураЗаполнения.Склад;
	Иначе 
		Возврат Справочники.Склады.ПустаяСсылка();
	КонецЕсли;      
КонецФункции

Функция ПолучитьПодразделение(ОбращениеКлиента) Экспорт 
	СтруктураЗаполнения = ПолучитьДанныеПоОснованию(ОбращениеКлиента); 
	
	Если ЗначениеЗаполнено(СтруктураЗаполнения) Тогда
		Возврат СтруктураЗаполнения.Подразделение;
	Иначе 
		Возврат Справочники.СтруктураПредприятия.ПустаяСсылка();
	КонецЕсли;      
КонецФункции
