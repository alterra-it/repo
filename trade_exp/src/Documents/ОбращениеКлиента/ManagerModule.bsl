#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
// Добавляет команду создания документа "Обращение клиентов".
//
// Параметры:
//   КомандыСозданияНаОсновании - ТаблицаЗначений - Таблица с командами создания на основании. Для изменения.
//       См. описание 1 параметра процедуры СозданиеНаОснованииПереопределяемый.ПередДобавлениемКомандСозданияНаОсновании().
//
Функция ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании) Экспорт
	ИмяДокумента= "ОбращениеКлиента";
	Если ПравоДоступа("Добавление", Метаданные.Документы[ИмяДокумента]) Тогда
		КомандаСоздатьНаОсновании = КомандыСозданияНаОсновании.Добавить();
		КомандаСоздатьНаОсновании.Менеджер = Метаданные.Документы[ИмяДокумента].ПолноеИмя();
		КомандаСоздатьНаОсновании.Идентификатор = Метаданные.Документы[ИмяДокумента].ПолноеИмя();
		КомандаСоздатьНаОсновании.Представление = ОбщегоНазначенияУТ.ПредставлениеОбъекта(Метаданные.Документы[ИмяДокумента]);
		КомандаСоздатьНаОсновании.РежимЗаписи = "Проводить";
		КомандаСоздатьНаОсновании.Важность = "Важное";
		Возврат КомандаСоздатьНаОсновании;
	КонецЕсли;
	
	Возврат Неопределено;
КонецФункции

Процедура ДобавитьКомандыСозданияНаОсновании(КомандыСозданияНаОсновании, Параметры) Экспорт	 
	Документы.НачислениеИСписаниеБонусныхБаллов.ДобавитьКомандуСоздатьНаОсновании(КомандыСозданияНаОсновании);
КонецПроцедуры

// Описывает учетные механизмы используемые в документе для регистрации в механизме проведения.
//
// Параметры:
//  МеханизмыДокумента - Массив - список имен учетных механизмов, для которых будет выполнена
//              регистрация в механизме проведения.
//
Процедура ЗарегистрироватьУчетныеМеханизмы(МеханизмыДокумента) Экспорт
	
	МеханизмыДокумента.Добавить("ТоварыРасхожденияПоОбращениям");
	
КонецПроцедуры


#Область СлужебныеПроцедурыИФункции
#Область Печать
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.ОбращениеКлиента";
	КомандаПечати.Идентификатор = "ПФ_MXL_ПечатнаяФорма_ОбращениеКлиента";
	КомандаПечати.Представление = НСтр("ru = 'Довоз/обмен по обращению'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	КомандаПечати.СразуНаПринтер = Ложь;
	КомандаПечати.Порядок = 1;  
	
КонецПроцедуры 

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_ПечатнаяФорма_ОбращениеКлиента") Тогда
		ТабДок= СформироватьОбращениеКлиента(МассивОбъектов,ОбъектыПечати);		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"ПФ_MXL_ПечатнаяФорма_ОбращениеКлиента", НСтр("ru = 'Обращение клиента'"), ТабДок);
	КонецЕсли;
	
	ФормированиеПечатныхФорм.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);
КонецПроцедуры  

Функция СформироватьОбращениеКлиента(МассивОбъектов,ОбъектыПечати) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ОбращениеКлиента.ПФ_MXL_ПечатнаяФорма_ОбращениеКлиента");
	ПервыйДокумент= Истина;               
	
	ОбластьЗаголовкиТаблицыНедостачи = Макет.ПолучитьОбласть("ЗаголовокТаблицыНедостача");
	ОбластьЗаголовкиТаблицыИзлишки = Макет.ПолучитьОбласть("ЗаголовокТаблицыИзлишки");
	ОбластьПодписи = Макет.ПолучитьОбласть("Подписи");
    ОбластьВремяПечати = Макет.ПолучитьОбласть("ВремяПечати");

	Для Каждого Ссылка Из МассивОбъектов Цикл
		ДокументПродажи = Ссылка.ДокументПродажи; 
		Если НЕ ЗначениеЗаполнено(ДокументПродажи) Тогда 
			Сообщить(СтрШаблон("В %1 не заполнен - Документ продажи!",Ссылка));
			Продолжить;	
		КонецЕсли;	
		Результат = ПолучитьДанныеДляПечати(Ссылка,ДокументПродажи.Склад);
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент= Ложь;
		
		ВыборкаПоСекциям= Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "РабочийУчасток");
		Пока ВыборкаПоСекциям.Следующий() Цикл
			
			ЭтоДубликат = Ложь;
			
			Если РегистрыСведений.СобытияДокументовАльтерра.БылоСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьОбращенияКлиента) Тогда
				ЭтоДубликат = Истина;
			КонецЕсли;
			
			Если ЭтоДубликат Тогда
				ОбластьПовторнаяПечать= Макет.ПолучитьОбласть("ПовторнаяПечать");
				ТабличныйДокумент.Вывести(ОбластьПовторнаяПечать);
			КонецЕсли;
			
			ОбластьШапкиОбменДовоз = Макет.ПолучитьОбласть("ЗаголовокДубльОбменДовоз");

			ОбластьШапкиОбменДовоз.Параметры.ПредставлениеДокумента = "Довоз по обращению №" + Ссылка.Номер + " от " + Ссылка.Дата;
			ОбластьШапкиОбменДовоз.Параметры.Секция = ВыборкаПоСекциям.РабочийУчасток;
			ОбластьШапкиОбменДовоз.Параметры.Склад = ДокументПродажи.Склад;
			ОбластьШапкиОбменДовоз.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДокументПродажи.Организация, ДокументПродажи.Дата), "ПолноеНаименование");
			ОбластьШапкиОбменДовоз.Параметры.ДокументПродажи = ДокументПродажи; 
			ОбластьШапкиОбменДовоз.Параметры.ПредставлениеПокупателя = ДокументПродажи.Партнер;
			ОбластьШапкиОбменДовоз.Параметры.АвторОбращения = Ссылка.Автор;
			ОбластьШапкиОбменДовоз.Параметры.Содержание = Ссылка.Содержание; 
			ОбластьШапкиОбменДовоз.Параметры.КомментарийДляСклада = ВРег(Ссылка.КомментарийДляСклада);
			ОбластьШапкиОбменДовоз.Параметры.ФИОКладовщика = ПолучитьОтветственногоЗаОтгрузку(ДокументПродажи,ВыборкаПоСекциям.РабочийУчасток);
			ТабличныйДокумент.Вывести(ОбластьШапкиОбменДовоз);
			
			ВыборкаПоТипуРассхождений = ВыборкаПоСекциям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ТипРассхождения");  
			
			Пока ВыборкаПоТипуРассхождений.Следующий() Цикл				
				
				ОбластьЗаголовокТаблицыДовозВозврат = Макет.ПолучитьОбласть("ШапкаТаблицыДовозВозврат");

				Если ВыборкаПоТипуРассхождений.ТипРассхождения = "НЕДОСТАЧА" Тогда
					ТабличныйДокумент.Вывести(ОбластьЗаголовкиТаблицыНедостачи);
				Иначе  
					ТабличныйДокумент.Вывести(ОбластьЗаголовкиТаблицыИзлишки);
				КонецЕсли;
				
				ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицыДовозВозврат);	
								
				НомерСтроки= 0;
				
				ОбластьСтрокаДовозВозврат = Макет.ПолучитьОбласть("СтрокаДовозВозврат");
				
				ВыборкаТовары = ВыборкаПоТипуРассхождений.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "");   
				
				Пока ВыборкаТовары.Следующий() Цикл
					
					СтрТовара = ВыборкаТовары.Номенклатура;					
					
					НомерСтроки = НомерСтроки + 1;
					ОбластьСтрокаДовозВозврат.Параметры.НомерСтроки = НомерСтроки;
					ОбластьСтрокаДовозВозврат.Параметры.Заполнить(ВыборкаТовары);
					
					Если ВыборкаТовары.Количество<0 Тогда
						ОбластьСтрокаДовозВозврат.Параметры.Количество = -ВыборкаТовары.Количество;
					КонецЕсли;
					
					стрШтрихкод= ВыборкаТовары.Штрихкод;
					
					Рисунок = ОбластьСтрокаДовозВозврат.Рисунки[0];					
					Эталон = Обработки.ПечатьЭтикетокИЦенников.ПолучитьМакет("Эталон");
					КоличествоМиллиметровВПикселе = Эталон.Рисунки.Квадрат100Пикселей.Высота / 100;
					
					ПараметрыШтрихкода = Новый Структура;
					ПараметрыШтрихкода.Вставить("Ширина",          Окр(Рисунок.Ширина / КоличествоМиллиметровВПикселе));
					ПараметрыШтрихкода.Вставить("Высота",          Окр(Рисунок.Высота / КоличествоМиллиметровВПикселе));
					ПараметрыШтрихкода.Вставить("Штрихкод",        СокрЛП(стрШтрихкод));
					ПараметрыШтрихкода.Вставить("ТипКода",         99);
					ПараметрыШтрихкода.Вставить("ОтображатьТекст", Истина);
					ПараметрыШтрихкода.Вставить("РазмерШрифта",    12);
					
					Рисунок.Картинка = ГенерацияШтрихкода.ИзображениеШтрихкода(ПараметрыШтрихкода).Картинка;	
					
					ТабличныйДокумент.Вывести(ОбластьСтрокаДовозВозврат);	
					
				КонецЦикла; 
				
				ТабличныйДокумент.Вывести(ОбластьПодписи);	

			КонецЦикла;	
			
			ОбластьВремяПечати.Параметры.ВремяПечати=""+ТекущаяДата()+" "+Пользователи.ТекущийПользователь();
            ТабличныйДокумент.Вывести(ОбластьВремяПечати);	
			
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЦикла; 
		
		Если Не РегистрыСведений.СобытияДокументовАльтерра.БылоСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьОбращенияКлиента) Тогда 
			
			РегистрыСведений.СобытияДокументовАльтерра.ЗаписатьСобытие(Ссылка, Перечисления.СобытияДокументов.ПечатьОбращенияКлиента);    
			
		КонецЕсли;  
		
	КонецЦикла;
	
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;

КонецФункции

Функция ПолучитьДанныеДляПечати(Ссылка,Склад)  

	Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток КАК РабочийУчасток,
		|	ВЫБОР
		|		КОГДА ОбращениеКлиентаТоварыДляДовоза.Количество > 0
		|			ТОГДА ""ИЗЛИШЕК""
		|		ИНАЧЕ ""НЕДОСТАЧА""
		|	КОНЕЦ КАК ТипРассхождения,
		|	ОбращениеКлиентаТоварыДляДовоза.Номенклатура КАК Номенклатура,
		|	ОбращениеКлиентаТоварыДляДовоза.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ОбращениеКлиентаТоварыДляДовоза.Количество КАК Количество,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка КАК Ячейка,
		|	МАКСИМУМ(ШтрихкодыНоменклатуры.Штрихкод) КАК Штрихкод
		|ПОМЕСТИТЬ ВТ_Промежуточная
		|ИЗ
		|	Документ.ОбращениеКлиента.ТоварыДляДовоза КАК ОбращениеКлиентаТоварыДляДовоза
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмещениеНоменклатурыПоСкладскимЯчейкам КАК РазмещениеНоменклатурыПоСкладскимЯчейкам
		|		ПО ОбращениеКлиентаТоварыДляДовоза.Номенклатура = РазмещениеНоменклатурыПоСкладскимЯчейкам.Номенклатура
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.Склад = &Склад)
		|			И (РазмещениеНоменклатурыПоСкладскимЯчейкам.ОсновнаяЯчейка = ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|		ПО ОбращениеКлиентаТоварыДляДовоза.Номенклатура = ШтрихкодыНоменклатуры.Номенклатура
		|ГДЕ
		|	ОбращениеКлиентаТоварыДляДовоза.Ссылка = &Ссылка
		|	И ОбращениеКлиентаТоварыДляДовоза.Номенклатура.ТипНоменклатуры = &ТипНоменклатуры
		|
		|СГРУППИРОВАТЬ ПО
		|	ОбращениеКлиентаТоварыДляДовоза.Номенклатура,
		|	ВЫБОР
		|		КОГДА ОбращениеКлиентаТоварыДляДовоза.Количество > 0
		|			ТОГДА ""ИЗЛИШЕК""
		|		ИНАЧЕ ""НЕДОСТАЧА""
		|	КОНЕЦ,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка,
		|	ОбращениеКлиентаТоварыДляДовоза.ЕдиницаИзмерения,
		|	РазмещениеНоменклатурыПоСкладскимЯчейкам.Ячейка.РабочийУчасток,
		|	ОбращениеКлиентаТоварыДляДовоза.Количество,
		|	ОбращениеКлиентаТоварыДляДовоза.Номенклатура.ЕдиницаИзмерения
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Промежуточная.РабочийУчасток КАК РабочийУчасток,
		|	ВТ_Промежуточная.ТипРассхождения КАК ТипРассхождения,
		|	ВТ_Промежуточная.Номенклатура КАК Номенклатура,
		|	ВТ_Промежуточная.ЕдиницаИзмерения КАК ЕдИзм,
		|	ВТ_Промежуточная.Количество КАК Количество,
		|	ВТ_Промежуточная.Ячейка КАК Ячейка,
		|	ВТ_Промежуточная.Штрихкод КАК Штрихкод
		|ИЗ
		|	ВТ_Промежуточная КАК ВТ_Промежуточная
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТипРассхождения УБЫВ
		|ИТОГИ ПО
		|	РабочийУчасток,
		|	ТипРассхождения"; 
				
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ТипНоменклатуры", Перечисления.ТипыНоменклатуры.Товар);
	Запрос.УстановитьПараметр("Склад", Склад); 
	
	Возврат Запрос.Выполнить();    
	
КонецФункции

#КонецОбласти
#КонецОбласти

#Область ОбменДовоз
Функция ПолучитьТоварыДляДовоза(МассивСсылок,МассивТоваров) Экспорт		
	Если ЗначениеЗаполнено(МассивСсылок) Тогда
		Запрос = Новый Запрос;                         	
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Товары.Ссылка.Организация КАК Организация,
			|	Товары.Ссылка.Подразделение КАК Подразделение,
			|	ЕСТЬNULL(Товары.Склад.Ссылка, Товары.Ссылка.Склад) КАК Склад,
			|	Товары.Ссылка.Контрагент КАК Контрагент,
			|	Товары.Ссылка.Партнер КАК Партнер,
			|	Товары.Номенклатура КАК Номенклатура,
			|	Товары.Характеристика КАК Характеристика,
			|	Товары.Назначение КАК Назначение,
			|	ВЫБОР
			|		КОГДА Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиЕдиницыИзмерения.ПустаяСсылка)
			|			ТОГДА Товары.Номенклатура.ЕдиницаИзмерения
			|		ИНАЧЕ Товары.Упаковка.ЕдиницаИзмерения
			|	КОНЕЦ КАК ЕдиницаИзмерения,
			|	0 КАК Количество,
			|	Товары.КоличествоУпаковок КАК МаксимальноеКоличествоПоДокументуПродажи,
			|	Товары.СтавкаНДС КАК СтавкаНДС,
			|	ВЫРАЗИТЬ(Товары.Сумма КАК ЧИСЛО(15, 2)) КАК Сумма,
			|	ВЫРАЗИТЬ(Товары.СуммаНДС КАК ЧИСЛО(15, 2)) КАК СуммаНДС,
