Процедура ПередатьВБитриксСервер(Объект) Экспорт
	//запись в очередь, как измененное к отправке. //пока пакетная отправка не работает
	//ДокументОбъект = Объект.Ссылка.ПолучитьОбъект();
	//Б24_Синхр_РегистрацияИзмененийВызовСервера.ЗарегистрироватьИзменения(ДокументОбъект);
	//
	//сразу отправить в Б24, по прямому обращению
	//НастройкаСинхронизации = Б24_Синхр_СинхронизацияПовтИсп.ПолучитьНастройкуСинхронизацииПоУмолчанию(); 
	//ОбщиеНастройки =  Б24_Синхр_СинхронизацияКлиентСервер.СформироватьБазовуюСтруктуруНастроек(НастройкаСинхронизации);  
	//Б24_Синхр_СинхронизацияВызовСервера.ДобавитьСложныеНастройкиОбменаВСтруктуру(ОбщиеНастройки);
	//Если ОбщиеНастройки = Неопределено Тогда
	//	Сообщить("Не удалось подключиться к Битрикс24");
	//	Возврат;
	//КонецЕсли;
	//ОбщиеНастройки.Измерение2 = "Отправить обращение клиента в Б24";	
	//Метод = "/rest/lists.element.add";
	
	Метод = "lists.element.add";
	ПараметрыЗапроса = ПолучитьПараметрыЗапроса(Объект);//ПолучитьПараметрыЗапроса(ОбщиеНастройки);
	Если ПараметрыЗапроса=Неопределено Тогда
		Возврат;
	КонецЕсли;       
	
	УстановитьПривилегированныйРежим(Истина); 
	СтруктураОтвета = АльтерраВзаимодействиеСБитрикс24.ВыполнитьПроизвольныйЗапрос(Метод, ПараметрыЗапроса);
	УстановитьПривилегированныйРежим(Ложь);
	Если СтруктураОтвета.Свойство("НазваниеОшибки") Тогда
		Сообщить("Ошибка отправки в Битрикс: "+ СтруктураОтвета.ОписаниеОшибки + " (код ошибки = " + СтруктураОтвета.КодСостояния + ")");
	КонецЕсли;
	Если СтруктураОтвета.Свойство("Результат") или СтруктураОтвета.Свойство("result") Тогда
		ЗаписатьВРегистрОбмена(Объект.Ссылка, СтруктураОтвета.result);
		УстановитьПривилегированныйРежим(Истина);
		Объект.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
КонецПроцедуры

