#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

&Перед("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполненияПеред(ДанныеЗаполнения, СтандартнаяОбработка)
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.АрендаНоменклатурыВозврат") Тогда
		ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту;
		ДокументОснование = ДанныеЗаполнения;
		Основание = ДанныеЗаполнения;
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения, , "Номер,Дата");
		
		ПоДокументу = ФизическиеЛицаУТ.ПолучитьДокументФизическогоЛицаПоУмолчанию(Контрагент).Представление;
		СтавкаНДС = АльтерраОбщегоНазначения.ПолучитьСтавкуНДСФилиала(ДанныеЗаполнения.Организация); 
		Выдать = "" + Контрагент + " (Обеспечительный платеж)";
		СуммаДокумента = ДанныеЗаполнения.СуммаЗалога; 
		
		НоваяСтрока = РасшифровкаПлатежа.Добавить();
		НоваяСтрока.ВалютаВзаиморасчетов 	      = Валюта;
		НоваяСтрока.Партнер            		      = ДанныеЗаполнения.Партнер;
		НоваяСтрока.ОбъектРасчетов   		      = Договор;
		НоваяСтрока.Сумма              			  = СуммаДокумента;
		НоваяСтрока.СуммаВзаиморасчетов 		  = СуммаДокумента;
		НоваяСтрока.Подразделение       		  = ДанныеЗаполнения.Подразделение;
		НоваяСтрока.Организация         		  = Организация;
		НоваяСтрока.СтавкаНДС           		  = СтавкаНДС;
		НоваяСтрока.СуммаНДС                      = УчетНДСУПКлиентСервер.РассчитатьСуммуНДС(
														СуммаДокумента, 
														УчетНДСУПКлиентСервер.ПолучитьСтавкуНДС(СтавкаНДС), 
														Истина); 
														
		ДанныеЗаполнения = Новый Структура;
	КонецЕсли;
КонецПроцедуры

&После("ОбработкаЗаполнения")
Процедура Док_ОбработкаЗаполненияПосле(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.ВозвратТоваровОтКлиента") Тогда  
		Документы.РасходныйКассовыйОрдер.ЗаполнитьСтатьюДДС(ЭтотОбъект);
		Выдать = ДокументОснование.Покупатель;
		Если ЗначениеЗаполнено(ДокументОснование.ВидДокументаПокупателя) Тогда
			ПоДокументу = Строка(ДокументОснование.ВидДокументаПокупателя) + " " + ДокументОснование.СерияДокументаПокупателя + " " + ДокументОснование.НомерДокументаПокупателя + " выдан " + Формат(ДокументОснование.ДатаВыдачиДокументаПокупателя, "ДЛФ=Д") + " " + ДокументОснование.КемВыданДокументПокупателя;
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.АрендаНоменклатурыВозврат") Тогда  
		Документы.РасходныйКассовыйОрдер.ЗаполнитьСтатьюДДС(ЭтотОбъект);
	КонецЕсли;

	Если ЗначениеЗаполнено(Касса) Тогда
		Подразделение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Касса, "Подразделение");
	КонецЕсли;           
КонецПроцедуры

&После("ПередЗаписью")
Процедура Док_ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
		                      
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
		
	АльтерраОбщегоНазначения.ПроверитьКассыОрганизаций(ЭтотОбъект, Отказ);
КонецПроцедуры                      

#КонецЕсли

&Перед("ПриКопировании")
Процедура Док_ПриКопировании(ОбъектКопирования)
	Если ВыдачаМатПомощи(ОбъектКопирования.Ссылка) Тогда 
		ВызватьИсключение "Создание расходника копированием на выдачу мат помощи запрещено!"; 
	КонецЕсли; 
КонецПроцедуры    

Функция ВыдачаМатПомощи(Ссылка) 
	Запрос = Новый запрос; 
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ИСТИНА
	               |ИЗ
	               |	Документ.РасходныйКассовыйОрдер.РасшифровкаПлатежа КАК РасходныйКассовыйОрдерРасшифровкаПлатежа
	               |ГДЕ
	               |	РасходныйКассовыйОрдерРасшифровкаПлатежа.СтатьяДвиженияДенежныхСредств = &СтатьяДвиженияДенежныхСредств
	               |	И РасходныйКассовыйОрдерРасшифровкаПлатежа.Ссылка = &Ссылка"; 
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка); 
	Запрос.УстановитьПараметр("СтатьяДвиженияДенежныхСредств", Документы.РасходныйКассовыйОрдер.Статья_РасчетыСПерсоналомПрочий73());    
	
	Выборка = Запрос.Выполнить().Выбрать(); 
	Возврат Выборка.Следующий();
КонецФункции

