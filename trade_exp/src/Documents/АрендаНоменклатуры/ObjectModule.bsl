#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
	
&Вместо("ОбработкаЗаполнения")
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	Автор= Пользователи.ТекущийПользователь();
	АльтерраОбщегоНазначения.ЗаполнитьПодразделение(ЭтотОбъект);
	АльтерраОбщегоНазначения.ЗаполнитьРеквизитыПродажи(ЭтотОбъект);
	Статус= Перечисления.СтатусыАренды.КЗаказу;
	ДатаСдачиВАренду= ТекущаяДата();
КонецПроцедуры

&Вместо("ОбработкаПроведения")
Процедура ОбработкаПроведения(Отказ, Режим)
	// регистр АрендаНоменклатуры Приход
	Движения.АрендаНоменклатуры.Записывать = Истина;
	
	Если Статус <> Перечисления.СтатусыАренды.Отменен Тогда
		
		Для Каждого ТекСтрокаТовары Из Товары Цикл
			Движение = Движения.АрендаНоменклатуры.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.ДокументАренды= Ссылка;
			Движение.Период = Дата;
			Движение.Организация = Организация;
			Движение.Подразделение = Подразделение;
			Движение.Партнер = Партнер;
			Движение.Номенклатура = ТекСтрокаТовары.Номенклатура;
			Движение.Характеристика = ТекСтрокаТовары.Характеристика;
			Движение.СтоимостьАренды = ТекСтрокаТовары.СуммаСНДСУслуги;
			Движение.ДатаВозврата = ДатаВозврата;
			
			Если Статус = Перечисления.СтатусыАренды.КЗаказу Тогда
				Движение.КАренде = ТекСтрокаТовары.Количество;
				Движение.ВАренде = 0;
			ИначеЕсли Статус = Перечисления.СтатусыАренды.ВАренде Или Статус = Перечисления.СтатусыАренды.Выполнен Тогда
				Движение.КАренде = 0;
				Движение.ВАренде = ТекСтрокаТовары.Количество;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
КонецПроцедуры

&Вместо("ПередЗаписью")
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения ИЛИ Статус = Перечисления.СтатусыАренды.Отменен ИЛИ Статус = Перечисления.СтатусыАренды.КЗаказу Тогда
		ЕстьОплата= Документы.АрендаНоменклатуры.ЕстьПКО_РКО(Ссылка);
		Если ЕстьОплата Тогда
			Сообщить("Документ оплачен!");
			Если Не РольДоступна("ПолныеПрава") Тогда
				Отказ= Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если РежимЗаписи = РежимЗаписиДокумента.ОтменаПроведения ИЛИ Статус = Перечисления.СтатусыАренды.Отменен ИЛИ Статус = Перечисления.СтатусыАренды.КЗаказу Тогда
		ЕстьВозврат= Документы.АрендаНоменклатуры.ЕстьВозврат(Ссылка);
		Если ЕстьВозврат Тогда
			Сообщить("Существует возврат");
			Если Не РольДоступна("ПолныеПрава") Тогда
				Отказ= Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&Вместо("ОбработкаУдаленияПроведения")
Процедура ОбработкаУдаленияПроведения(Отказ)
	Документы.АрендаНоменклатуры.УдалитьДокументПеремещение(Ссылка, Отказ);
КонецПроцедуры

&Вместо("ОбработкаПроверкиЗаполнения")
Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
		Отбор= Новый Структура("Физлицо", Контрагент);
		Выборка= РегистрыСведений.ДокументыФизическихЛиц.Выбрать(,, Отбор);
		Если Не Выборка.Следующий() Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не заполнен документ удостоверяющий личнсть", ЭтотОбъект, "Контрагент");
			Отказ= Истина;
		КонецЕсли;
КонецПроцедуры

#КонецЕсли
