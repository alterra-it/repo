#Область Перемещение
Процедура СоздатьДокументПеремещение(Основание, Отказ) Экспорт
	
	Перемещение = ПолучитьПеремещение(Основание);
	Если Не ЗначениеЗаполнено(Перемещение) Тогда
		ДокПеремещение = Документы.ПеремещениеТоваров.СоздатьДокумент();
	Иначе
		ДокПеремещение = Перемещение.ПолучитьОбъект();
	КонецЕсли;
	
	ДокПеремещение.Заполнить(Основание);
	
	Попытка
		Если ДокПеремещение.ПометкаУдаления Тогда
			ДокПеремещение.УстановитьПометкуУдаления(Ложь);
		КонецЕсли;
		ДокПеремещение.Записать(РежимЗаписиДокумента.Проведение);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Записан: " + ДокПеремещение, ДокПеремещение);
	Исключение
		Отказ = Истина;
		Сообщить(ИнформацияОбОшибке().Описание);
		Сообщить("Не удалось записать перемещение", СтатусСообщения.ОченьВажное);
	КонецПопытки;
	
КонецПроцедуры

Процедура УдалитьДокументПеремещение(Основание, Отказ) Экспорт

	Перемещение = ПолучитьПеремещение(Основание);
	Если ЗначениеЗаполнено(Перемещение) Тогда
		ДокПеремещение = Перемещение.ПолучитьОбъект();
	
		Попытка
			ДокПеремещение.УстановитьПометкуУдаления(Истина);
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Удален: " + ДокПеремещение, ДокПеремещение);
		Исключение
			Отказ = Истина;
			Сообщить("Не удалось записать перемещение", СтатусСообщения.ОченьВажное);
		КонецПопытки;
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьПеремещение(ДокументОснование)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеремещениеТоваров.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|ГДЕ
	|	ПеремещениеТоваров.ДокументОснование = &ДокументОснование";
	
	Запрос.УстановитьПараметр("ДокументОснование", ДокументОснование);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	Возврат Неопределено; 
	
КонецФункции
#КонецОбласти 


#Область Печать
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.МенеджерПечати = "Документ.АрендаНоменклатуры";
	КомандаПечати.Идентификатор = "Договор";
	КомандаПечати.Представление = НСтр("ru = 'Договор'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	КомандаПечати.СразуНаПринтер = Ложь;
	КомандаПечати.Порядок = 1; 
	
КонецПроцедуры

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "Договор") Тогда
		ТабДок = СформироватьДоговор(МассивОбъектов);		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,	"Договор", НСтр("ru = 'Договор'"), ТабДок, "Документ.АрендаНоменклатуры.Договор");
	КонецЕсли;	
	
	ФормированиеПечатныхФорм.ЗаполнитьПараметрыОтправки(ПараметрыВывода.ПараметрыОтправки, МассивОбъектов, КоллекцияПечатныхФорм);	

КонецПроцедуры

Функция СформироватьДоговор(МассивОбъектов) Экспорт
	
	ТабДок = Новый ТабличныйДокумент;
	
	Если МассивОбъектов.Количество() = 1 Тогда
		Ссылка = МассивОбъектов[0];
		СтатусСсылки = Ссылка.Статус;
		Если СтатусСсылки <> Перечисления.СтатусыАренды.ВАренде И СтатусСсылки <> Перечисления.СтатусыАренды.Выполнен Тогда
			Если Не (РольДоступна("_ОтделБухгалтерии") ИЛИ РольДоступна("ПолныеПрава")) Тогда
				Сообщить("Договор печатается для документов в статусе в аренде или выполнен!");
				Возврат ТабДок;
			КонецЕсли;
		КонецЕсли;
		
		РезультатЗапроса = ПолучитьДанныеДляДоговораНесколькоДоговоров(МассивОбъектов, СтатусСсылки);
	Иначе
		РезультатЗапроса = ПолучитьДанныеДляДоговораНесколькоДоговоров(МассивОбъектов, Перечисления.СтатусыАренды.ВАренде);
	КонецЕсли;
	                        
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.АрендаНоменклатуры.Договор");
	
	ОбластьКартинкиШапки = Макет.ПолучитьОбласть("Шапка_Логотип");
	ОбластьКартинкиПодвала = Макет.ПолучитьОбласть("Подвал_Лого");

	ОбластьШтрихкода = Макет.ПолучитьОбласть("ОбластьШтрихкода");
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
	ОбластьТовар = Макет.ПолучитьОбласть("Товар");
	ОбластьОсновнаяЧасть = Макет.ПолучитьОбласть("ОсновнаяЧасть");
	ВыборкаДоговора = РезультатЗапроса.Выбрать();
	Пока ВыборкаДоговора.Следующий() Цикл
		ТабДок.Вывести(ОбластьКартинкиШапки);

		ШтрихкодированиеПечатныхФорм.ВывестиШтрихкодВТабличныйДокумент(ТабДок, Макет, ОбластьШтрихкода, ВыборкаДоговора.Ссылка);
		ТабДок.Вывести(ОбластьШтрихкода);
		
		ОбластьЗаголовок.Параметры.Заполнить(ВыборкаДоговора);
	
		ОбластьЗаголовок.Параметры.ДатаВремя = Формат(ВыборкаДоговора.Дата, "ДФ=dd.MM.yyyy hh:mm");

		ТабДок.Вывести(ОбластьЗаголовок);
		
		ОбластьТовар.Параметры.Заполнить(ВыборкаДоговора);
		ТабДок.Вывести(ОбластьТовар);
		
		ОбластьОсновнаяЧасть.Параметры.Заполнить(ВыборкаДоговора);
		ТабДок.Вывести(ОбластьОсновнаяЧасть);
		
		ТабДок.Вывести(ОбластьКартинкиПодвала);
	
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла;	

	ТабДок.АвтоМасштаб = Истина;

	Возврат ТабДок;
	
КонецФункции 

Функция ПолучитьДанныеДляДоговора(МассивОбъектов)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АрендаНоменклатуры.Ссылка КАК Ссылка,
	|	АрендаНоменклатуры.Номер КАК Номер,
	|	АрендаНоменклатуры.Дата КАК Дата,
	|	АрендаНоменклатуры.Организация.ИНН КАК ИНН,
	|	АрендаНоменклатуры.Подразделение КАК Подразделение,
	|	АрендаНоменклатуры.Подразделение.Адрес КАК ПодразделениеАдрес,
	|	АрендаНоменклатуры.Автор.Наименование КАК Сотрудник,
	|	Сотрудники.Должность.Наименование КАК Должность,
	|	АрендаНоменклатуры.Контрагент.Наименование КАК КлиентФИО,
	|	ДокументыФизическихЛицСрезПоследних.Представление КАК Паспорт,
	|	АрендаНоменклатуры.Организация.Наименование КАК Организация,
	|	ПартнерыКонтактнаяИнформацияАдрес.Представление КАК КлиентАдрес,
	|	ПартнерыКонтактнаяИнформацияТелефон.НомерТелефона КАК НомерТелефона
	|ИЗ
	|	Документ.АрендаНоменклатуры КАК АрендаНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО АрендаНоменклатуры.Автор = Сотрудники.Пользователь
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДокументыФизическихЛиц.СрезПоследних КАК ДокументыФизическихЛицСрезПоследних
	|		ПО АрендаНоменклатуры.Контрагент = ДокументыФизическихЛицСрезПоследних.Физлицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияАдрес
	|		ПО АрендаНоменклатуры.Партнер = ПартнерыКонтактнаяИнформацияАдрес.Ссылка
	|			И (ПартнерыКонтактнаяИнформацияАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресПартнера))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Партнеры.КонтактнаяИнформация КАК ПартнерыКонтактнаяИнформацияТелефон
	|		ПО (АрендаНоменклатуры.Партнер = ПартнерыКонтактнаяИнформацияАдрес.Ссылка)
	|			И (ПартнерыКонтактнаяИнформацияАдрес.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонПартнера))
	|ГДЕ
	|	АрендаНоменклатуры.Ссылка В(&МассивДокументов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АрендаНоменклатурыТовары.НомерСтроки КАК Ном,
	|	АрендаНоменклатурыТовары.Номенклатура КАК Номенклатура,
	|	АрендаНоменклатурыТовары.Характеристика КАК Характеристика,
	|	АрендаНоменклатурыТовары.ЦенаУслуги КАК ЦенаУслуги,
	|	АрендаНоменклатурыТовары.КоличествоУслуги КАК КоличествоУслуги,
	|	АрендаНоменклатурыТовары.СуммаЗалога КАК СуммаЗалога
	|	, ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ИЗ
	|	Документ.АрендаНоменклатуры.Товары КАК АрендаНоменклатурыТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&Период, ) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО АрендаНоменклатурыТовары.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|			И АрендаНоменклатурыТовары.Характеристика = ЦеныНоменклатурыСрезПоследних.Характеристика
	|			И АрендаНоменклатурыТовары.ВидЦены = ЦеныНоменклатурыСрезПоследних.ВидЦены
	|ГДЕ
	|	АрендаНоменклатурыТовары.Ссылка В(&МассивДокументов)";
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("Период", МассивОбъектов[МассивОбъектов.Количество()-1].Дата);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Возврат РезультатЗапроса; 
	
КонецФункции

