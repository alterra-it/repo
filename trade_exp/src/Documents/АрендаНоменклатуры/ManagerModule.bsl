КонецПроцедуры       

#КонецОбласти 

Функция ПолучитьЦену(Номенклатура, Характеристика, ВидЦены) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	|	ЦеныНоменклатурыСрезПоследних.Характеристика КАК Характеристика,
	|	ЦеныНоменклатурыСрезПоследних.ВидЦены КАК ВидЦены,
	|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|			,
	|			Номенклатура = &Номенклатура
	|				И Характеристика = &Характеристика
	|				И ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Цена; 
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

Функция РасчитатьСтоимостьЗалога(Номенклатура, Характеристика, Подразделение) Экспорт
	
	ЦенаТовара = ПолучитьЦену(Номенклатура, Характеристика, Подразделение.ЦенаПоКарте);
	Если ЦенаТовара = 0 Тогда
		Сообщить("Стоимость товара по карте равна нулю", СтатусСообщения.ОченьВажное);
		Возврат 0;
	КонецЕсли;
	
	Залог = Цел(ЦенаТовара / 10 / 50) * 50 + 50;
	
	Возврат Залог; 
	
КонецФункции

Функция ЕстьОстаткиПоАренде(Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	АрендаНоменклатурыОстатки.Организация КАК Организация,
	|	АрендаНоменклатурыОстатки.Подразделение КАК Подразделение,
	|	АрендаНоменклатурыОстатки.Партнер КАК Партнер,
	|	АрендаНоменклатурыОстатки.Номенклатура КАК Номенклатура,
	|	АрендаНоменклатурыОстатки.Характеристика КАК Характеристика,
	|	АрендаНоменклатурыОстатки.КАрендеОстаток КАК КАрендеОстаток,
	|	АрендаНоменклатурыОстатки.ВАрендеОстаток КАК ВАрендеОстаток
	|ИЗ
	|	РегистрНакопления.АрендаНоменклатуры.Остатки(, ДокументАренды = &ДокументАренды) КАК АрендаНоменклатурыОстатки";
	
	Запрос.УстановитьПараметр("ДокументАренды", Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

Функция ПолучитьВозвратАренды(Основание) Экспорт
	
