&НаСервере
Процедура Док_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	ТипЗвонка=?(Объект.Входящий,1,0);
	ЗаполнитьТемуЗвонка(Предмет); 
	Элементы.Форма_СоздатьАнкету.доступность=значениезаполнено(Объект.Ссылка);
	Элементы.Форма_СоздатьАнкету.Заголовок=ВернутьЗаголовокКомандыОпроса();
КонецПроцедуры

&НаСервере
Функция ВернутьЗаголовокКомандыОпроса()
	если значениезаполнено(Объект.Ссылка) тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	АнкетированиеОтветы.Респондент КАК Респондент,
		|	АнкетированиеОтветы.ШаблонАнкеты КАК ШаблонАнкеты,
		|	АнкетированиеОтветы.ДатаЗаполнения КАК ДатаЗаполнения
		|ИЗ
		|	РегистрСведений.АнкетированиеОтветы КАК АнкетированиеОтветы
		|ГДЕ
		|	АнкетированиеОтветы.ВзаимодействиеОснование = &ВзаимодействиеОснование";
		
		Запрос.УстановитьПараметр("ВзаимодействиеОснование", Объект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		если ВыборкаДетальныеЗаписи.Следующий() тогда
			ПараметрыОпроса=Новый Структура();
			ПараметрыОпроса.Вставить("Респондент",ВыборкаДетальныеЗаписи.Респондент);
			ПараметрыОпроса.Вставить("ШаблонАнкеты",ВыборкаДетальныеЗаписи.ШаблонАнкеты);
			ПараметрыОпроса.Вставить("ДатаЗаполнения",ВыборкаДетальныеЗаписи.ДатаЗаполнения);
			возврат "Посмотреть результаты опроса";
		Конецесли;
	конецесли;	
	возврат "Создать опрос";
КонецФункции // ()

&НаСервере
Процедура ЗаполнитьТемуЗвонка(ВыбранныйПредмет)
	если не значениезаполнено(Объект.Тема) и  значениезаполнено(ВыбранныйПредмет) тогда
		если Метаданные.Документы.Содержит(Метаданные.НайтиПоТипу(типзнч(ВыбранныйПредмет))) тогда
			Объект.Тема=""+типзнч(ВыбранныйПредмет)+" №"+ВыбранныйПредмет.Номер+" от "+ВыбранныйПредмет.Дата;
		иначеесли Метаданные.Справочники.Содержит(Метаданные.НайтиПоТипу(типзнч(ВыбранныйПредмет))) тогда
			Объект.Тема=""+типзнч(ВыбранныйПредмет)+" "+ВыбранныйПредмет.Наименование;
		конецесли;	
	конецесли;
КонецПроцедуры

&НаКлиенте
Процедура Док_ТипЗвонкаПриИзмененииПосле(Элемент)
	Объект.Входящий=?(ТипЗвонка=1,истина,ложь);
КонецПроцедуры


&НаСервере
Процедура СформироватьТабличныйДокументОпроса(ПараметрыОпроса,ТабДок)
	
	РегистрыСведений.АнкетированиеОтветы.СформироватьТабличныйДокументОпроса(ПараметрыОпроса.Респондент, ПараметрыОпроса.ШаблонАнкеты,ПараметрыОпроса.ДатаЗаполнения, ТабДок);
	
КонецПроцедуры

&НаКлиенте
Процедура Док__СоздатьАнкетуПосле(Команда)
	если Элементы.Форма_СоздатьАнкету.Заголовок="Создать опрос" тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьОпросЗавершение", ЭтаФорма);
		ПараметрыФормы = Новый Структура("ВзаимодействиеОснование", Объект.ссылка);
		если типзнч(Объект.АбонентКонтакт)=тип("СправочникСсылка.Партнеры") тогда
			ПараметрыФормы.Вставить("Респондент",Объект.АбонентКонтакт);
		конецесли;	
		ОткрытьФорму("РегистрСведений.АнкетированиеОтветы.Форма.ФормаАнкетирования",ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	иначе
		ТабДок = Новый ТабличныйДокумент;
		СформироватьТабличныйДокументОпроса(ПараметрыОпроса,ТабДок);
		ТабДок.Показать("Результаты опроса");
	конецесли;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьОпросЗавершение(Результат, ДополнительныеПараметры) экспорт
	Элементы.Форма_СоздатьАнкету.Заголовок=ВернутьЗаголовокКомандыОпроса();
	если Элементы.Форма_СоздатьАнкету.Заголовок="Посмотреть результаты опроса" тогда
		Объект.описание=Объект.Описание+" Создан опрос";
    конецесли;
КонецПроцедуры


&НаКлиенте
Процедура Док_ПослеЗаписиПосле(ПараметрыЗаписи)
	Элементы.Форма_СоздатьАнкету.доступность=значениезаполнено(Объект.Ссылка);
КонецПроцедуры


&НаКлиенте
Процедура Док_ОбработкаВыбораПеред(ВыбранноеЗначение, ИсточникВыбора)
	если КонтекстВыбора = "ВыборПредмета" тогда
		ЗаполнитьТемуЗвонка(ВыбранноеЗначение);
	конецесли;
КонецПроцедуры


&НаКлиенте
Процедура Док__ПозвонитьПосле(Команда)
	
	ТелефонияКлиент.ПозвонитьПоНомеру(Объект.АбонентКакСвязаться, Объект.АбонентКонтакт,,);

КонецПроцедуры

